@page "/marcas"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject ToastService ToastService
@inject CurrentCompanyService Company

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>
            Marcas (@(visibleBrands?.Count ?? 0))
            @if (Company.HasCompany)
            {
                <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;"> · @Company.Current</span>
            }
        </h3>
        <div style="display: flex; gap: 0.4rem; align-items: center;">
            <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.8rem; cursor: pointer; color: #6b7280;">
                <input type="checkbox" @bind="showAllCompanies" />
                Ver marcas de todas las empresas
            </label>
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ Nueva Marca</button>
            <button class="btn btn-primary" @onclick="() => showImport = true" title="Subir varias marcas desde un Excel" style="background: #059669; border-color: #059669;">📤 Importar Excel</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando marcas...</p>
        }
        else if (visibleBrands is null || visibleBrands.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                @if (brands is null || brands.Count == 0)
                {
                    <span>Todavia no cargaste ninguna marca. Hace clic en "+ Nueva Marca" para empezar.</span>
                }
                else
                {
                    <span>No hay marcas visibles para <strong>@Company.Current</strong>. Tildá "Ver marcas de todas las empresas" para verlas todas, o creá una nueva.</span>
                }
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">Codigo</th>
                            <th>Nombre</th>
                            <th>Empresas</th>
                            <th>Descripcion</th>
                            <th>Vencimiento</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in visibleBrands)
                        {
                            <tr>
                                <td style="font-family: monospace; color: #374151;">@b.Code</td>
                                <td><strong>@b.Name</strong></td>
                                <td>
                                    @{
                                        var cos = ParseCompanies(b.Companies);
                                    }
                                    @if (cos.Count == 0)
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#e0f2fe; color:#075985; border-radius:999px; font-size:0.7rem; font-weight:600;">Todas</span>
                                    }
                                    else
                                    {
                                        @foreach (var co in cos)
                                        {
                                            <span style="display:inline-block; padding:0.15rem 0.45rem; background:#f3f4f6; color:#374151; border-radius:999px; font-size:0.7rem; font-weight:600; margin-right:0.2rem;">@co</span>
                                        }
                                    }
                                </td>
                                <td style="color: #6b7280; font-size: 0.85rem;">@(b.Description ?? "")</td>
                                <td>
                                    @if (b.HasExpiry)
                                    {
                                        <span style="display: inline-block; padding: 0.15rem 0.5rem; background: #fef3c7; color: #92400e; border-radius: 999px; font-size: 0.75rem; font-weight: 600;">Con vencimiento</span>
                                    }
                                    else
                                    {
                                        <span style="color: #9ca3af; font-size: 0.8rem;">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(b.IsActive ? "status-active" : "status-inactive")">
                                        @(b.IsActive ? "Activa" : "Inactiva")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEditForm(b)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(b)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar Marca" : "Nueva Marca")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Codigo</label>
                        <input class="form-input" @bind="formCode" placeholder="@(isEditing ? "" : "Se genera automatico")" />
                        <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">
                            @(isEditing ? "Podes cambiarlo, pero debe ser unico." : "Si lo dejas vacio, el sistema genera el siguiente codigo automaticamente (MAR-001, MAR-002, ...).")
                        </p>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-input" @bind="formName" placeholder="Ej: Samsung" autofocus />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-input" @bind="formDescription" rows="3" placeholder="Notas sobre la marca (opcional)"></textarea>
                </div>
                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; cursor: pointer;">
                        <input type="checkbox" @bind="formHasExpiry" style="width: 18px; height: 18px;" />
                        Producto con vencimiento
                    </label>
                    <p style="font-size: 0.78rem; color: #6b7280; margin: 0.3rem 0 0 1.7rem;">
                        Si lo tildas, los productos de esta marca van a manejar el stock por lotes (cantidad + fecha de vencimiento).
                    </p>
                </div>

                <div class="form-group">
                    <label class="form-label">Empresas en las que se muestra</label>
                    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                        @foreach (var co in CurrentCompanyService.Companies)
                        {
                            var name = co;
                            var isOn = formCompanies.Contains(name);
                            <label style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.4rem 0.7rem; border: 1.5px solid @(isOn ? "#15803d" : "#d1d5db"); background: @(isOn ? "#dcfce7" : "white"); border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.85rem;">
                                <input type="checkbox" checked="@isOn" @onchange="() => ToggleFormCompany(name)" style="margin: 0;" />
                                @name
                            </label>
                        }
                    </div>
                    <p style="font-size: 0.78rem; color: #6b7280; margin: 0.4rem 0 0;">
                        Si no tildas ninguna, la marca y sus productos se muestran en <strong>todas</strong> las empresas.
                    </p>
                </div>
                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="@true">Activa</option>
                            <option value="@false">Inactiva</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && brandToDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar marca</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar la marca <strong>@brandToDelete.Name</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">Esta accion no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

<BulkImportModal @bind-Visible="showImport"
                 EntityNameSingular="marca"
                 EntityNamePlural="marcas"
                 TemplateUrl="/api/brands/import-template"
                 TemplateFileName="marcas-template.xlsx"
                 ImportUrl="/api/brands/bulk-import"
                 OnImported="LoadData" />

@code {
    private bool showImport;
    private List<BrandDto>? brands;
    private bool isLoading = true;
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;
    private int? editingId;
    private string formCode = "";
    private string formName = "";
    private string formDescription = "";
    private bool formHasExpiry;
    private bool formIsActive = true;
    private HashSet<string> formCompanies = new(StringComparer.OrdinalIgnoreCase);
    private bool showDeleteConfirm;
    private BrandDto? brandToDelete;
    private bool showAllCompanies; // Si esta tildado, ignora el filtro por empresa actual

    // Marcas que se muestran segun la empresa actual (o todas si showAllCompanies)
    private List<BrandDto>? visibleBrands =>
        brands is null
            ? null
            : (showAllCompanies || !Company.HasCompany
                ? brands
                : brands.Where(b => CurrentCompanyService.IsVisibleForCompany(b.Companies, Company.Current!)).ToList());

    protected override async Task OnInitializedAsync()
    {
        Company.OnChange += OnCompanyChanged;
        await LoadData();
    }

    public void Dispose()
    {
        Company.OnChange -= OnCompanyChanged;
    }

    private void OnCompanyChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadData()
    {
        isLoading = true;
        try { brands = await Api.GetBrandsAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar las marcas"); brands = new(); }
        isLoading = false;
    }

    private void ShowCreateForm()
    {
        isEditing = false; editingId = null;
        formCode = ""; formName = ""; formDescription = "";
        formHasExpiry = false; formIsActive = true;
        // Si la usuario tiene una empresa elegida, pre-tildamos esa para que la marca arranque visible
        formCompanies = new(StringComparer.OrdinalIgnoreCase);
        if (Company.HasCompany) formCompanies.Add(Company.Current!);
        formError = null; showForm = true;
    }

    private void ShowEditForm(BrandDto b)
    {
        isEditing = true; editingId = b.Id;
        formCode = b.Code; formName = b.Name; formDescription = b.Description ?? "";
        formHasExpiry = b.HasExpiry;
        formIsActive = b.IsActive;
        formCompanies = new HashSet<string>(ParseCompanies(b.Companies), StringComparer.OrdinalIgnoreCase);
        formError = null; showForm = true;
    }

    private void ToggleFormCompany(string name)
    {
        if (formCompanies.Contains(name)) formCompanies.Remove(name);
        else formCompanies.Add(name);
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formName)) { formError = "El nombre es obligatorio"; return; }
        isSaving = true;
        try
        {
            // Serializa el HashSet en CSV en el orden canonico de las empresas
            string? companiesCsv = formCompanies.Count == 0
                ? null
                : string.Join(",", CurrentCompanyService.Companies.Where(c => formCompanies.Contains(c)));

            if (isEditing && editingId.HasValue)
            {
                var updated = await Api.UpdateBrandAsync(editingId.Value, new UpdateBrandRequest
                {
                    Code = formCode, Name = formName, Description = formDescription,
                    HasExpiry = formHasExpiry, IsActive = formIsActive,
                    Companies = companiesCsv ?? "" // string vacio explicito = "todas" (limpiar restriccion). El backend lo normaliza a null.
                });
                if (updated is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Marca actualizada");
            }
            else
            {
                var created = await Api.CreateBrandAsync(new CreateBrandRequest
                {
                    Code = string.IsNullOrWhiteSpace(formCode) ? null : formCode,
                    Name = formName, Description = formDescription,
                    HasExpiry = formHasExpiry,
                    Companies = companiesCsv
                });
                if (created is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Marca creada");
            }
            showForm = false;
            await LoadData();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    // Wrapper local para usar desde el markup
    private List<string> ParseCompanies(string? csv) => CurrentCompanyService.ParseCompanies(csv);

    private void ConfirmDelete(BrandDto b) { brandToDelete = b; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (brandToDelete is null) return;
        try
        {
            var ok = await Api.DeleteBrandAsync(brandToDelete.Id);
            if (ok) { ToastService.Success("Marca eliminada"); await LoadData(); }
            else { ToastService.Error("No se pudo eliminar la marca"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; brandToDelete = null; }
    }
}
