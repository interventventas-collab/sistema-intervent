    /// <summary>2026-06-01: dispara el push masivo agresivo a TODAS las publicaciones con SyncStock=ON.
    /// Confirma 2 veces antes de ejecutar. El backend lo procesa en background (~30 min).
    /// Despues se revisa el cotejo de ACTIVADAS vs PAUSADAS en las tablas MeliPushSnapshot_*.</summary>
    private async Task DispararPushMasivoAgresivo()
    {
        var confirma1 = await JS.InvokeAsync<bool>("confirm",
            "🚀 ¿Pushear stock de TODAS las publicaciones a MeLi?\n\n" +
            "MeLi va a:\n" +
            "  • PAUSAR publicaciones con stock 0 en el sistema\n" +
            "  • ACTIVAR publicaciones con stock>0 que estaban pausadas\n\n" +
            "Tarda ~30 minutos en segundo plano. Despues revisamos juntos.");
        if (!confirma1) return;

        var confirma2 = await JS.InvokeAsync<bool>("confirm",
            "Confirmación final: ¿Estás 100% seguro?\nEsta acción modifica MeLi en vivo.");
        if (!confirma2) return;

        pushMasivoEnCurso = true;
        StateHasChanged();
        try
        {
            var resp = await Api.DispararPushMasivoAgresivoAsync();
            if (resp is not null && resp.TryGetValue("encolados", out var enc))
            {
                ToastService.Success($"🚀 Push lanzado: {enc} publicaciones en segundo plano. Tarda ~30 min. Avisame en el chat.");
            }
            else
            {
                ToastService.Error("Respuesta inesperada. Revisar logs.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al lanzar push: " + ex.Message);
        }
        finally
        {
            // No volvemos a false: el background corre 30 min, el boton queda deshabilitado hasta que reload de pantalla
            // (es a proposito — evitar doble click).
        }
    }

    /// <summary>2026-06-19: dispara el refresco masivo de sale_fee real para todas las publicaciones activas.
    /// El backend procesa en background ~10-15 min. Una vez termina, los netos del listado coinciden al peso con MeLi.</summary>
    private async Task RefrescarComisionesMeLi()
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            "💰 ¿Refrescar las comisiones REALES de MeLi para TODAS las publicaciones activas?\n\n" +
            "Esto va a consultar a MeLi una por una (~3650 publicaciones) y guardar la comision exacta.\n" +
            "Tarda 10-15 minutos en segundo plano.\n\n" +
            "Una vez terminado, los netos del listado van a coincidir al peso con lo que MeLi te muestra.");
        if (!ok) return;

        refrescandoComisiones = true;
        StateHasChanged();
        try
        {
            var success = await Api.RefreshMeliItemsSaleFeeBulkAsync();
            if (success)
                ToastService.Success("💰 Refresco lanzado en background. Tarda 10-15 min. Cuando termine, recargá esta pantalla y los netos van a ser exactos.");
            else
                ToastService.Error("Error al lanzar el refresco. Revisar logs del API.");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
