                <div class="pagination-bar" style="display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0.75rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; margin:0.5rem 0; flex-wrap:wrap; font-size:0.875rem; justify-content:center;">
                    <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(1)" disabled="@(currentPage == 1)" title="Primera">⏮</button>
                    <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage == 1)" title="Anterior">◀</button>
                    <span style="padding:0 0.5rem;">Página <strong>@currentPage</strong> de <strong>@totalPagesBot</strong> (@totalRowsBot publicaciones)</span>
                    <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage >= totalPagesBot)" title="Siguiente">▶</button>
                    <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(totalPagesBot)" disabled="@(currentPage >= totalPagesBot)" title="Última">⏭</button>
                </div>
            }
            }
        }
    </div>
</div>

@* 2026-06-11: modal de Análisis de Margen por familia. Reutilizable: se abre con cualquier familyId. *@
@if (showAnalisisMargen)
{
    <div class="modal-overlay" @onclick="CerrarAnalisisMargen" style="position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:2000; display:flex; align-items:center; justify-content:center;">
        <div @onclick:stopPropagation="true" style="background:white; border-radius:8px; max-width:1100px; width:95vw; max-height:90vh; overflow:auto; padding:1.2rem; box-shadow:0 25px 50px rgba(0,0,0,0.3);">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.8rem;">
                <h3 style="margin:0;">📊 Análisis de margen — @(analisisMargenData?.sku ?? "")</h3>
                <button @onclick="CerrarAnalisisMargen" style="background:transparent; border:none; font-size:1.5rem; cursor:pointer; color:#6b7280;">×</button>
            </div>

            @if (analisisMargenLoading)
            {
                <p>Calculando neto y comisiones...</p>
            }
            else if (analisisMargenError is not null)
            {
                <p style="color:#dc2626;">@analisisMargenError</p>
            }
            else if (analisisMargenData is not null)
            {
                <div style="display:flex; gap:0.8rem; flex-wrap:wrap; margin-bottom:0.8rem; font-size:0.85rem;">
                    <div style="background:#f9fafb; padding:0.4rem 0.7rem; border-radius:6px;">
                        <strong>Precio sistema (PrecioOtro):</strong> $@analisisMargenData.precioOtroBase.ToString("N0")
                    </div>
                    <div style="background:#f9fafb; padding:0.4rem 0.7rem; border-radius:6px;">
                        <strong>Comisión categoría:</strong>
                        <input type="number" step="0.1" value="@analisisMargenComisionCat"
                               @onchange="OnCambioComision" style="width:60px; margin-left:0.3rem;" />%
                    </div>
                    <div style="background:#f9fafb; padding:0.4rem 0.7rem; border-radius:6px;">
                        <strong>Costo envío gratis estimado:</strong>
                        <input type="number" step="100" value="@analisisMargenEnvioCosto"
                               @onchange="OnCambioEnvio" style="width:80px; margin-left:0.3rem;" />
                    </div>
                </div>

                <table style="width:100%; border-collapse:collapse; font-size:0.82rem;">
                    <thead style="background:#f3f4f6;">
                        <tr>
                            <th style="text-align:left; padding:0.5rem;">MLA</th>
                            <th style="text-align:left; padding:0.5rem;">Tipo</th>
                            <th style="text-align:left; padding:0.5rem;">Cuotas</th>
                            <th style="text-align:center; padding:0.5rem;">Envío</th>
                            <th style="text-align:right; padding:0.5rem;">Precio MeLi</th>
                            <th style="text-align:right; padding:0.5rem;">Comis %</th>
                            <th style="text-align:right; padding:0.5rem;">Comis $</th>
                            <th style="text-align:right; padding:0.5rem;">NETO 💰</th>
                            <th style="text-align:right; padding:0.5rem;">vs Promedio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mla in analisisMargenData.mlas)
                        {
                            var fila = mla;
                            <tr style="border-bottom:1px solid #e5e7eb; @(fila.dentroDeRango ? "" : "background:#fef2f2;")">
                                <td style="padding:0.5rem; font-family:monospace; font-size:0.75rem;">
                                    @fila.MeliItemId
                                </td>
                                <td style="padding:0.5rem;">@fila.ListingTypeLabel</td>
                                <td style="padding:0.5rem;">
                                    <select value="@(fila.InstallmentTag ?? "")"
                                            @onchange="@(e => CambiarOverrideCuotas(fila.MeliItemId, e.Value?.ToString()))"
                                            style="font-size:0.8rem; padding:0.15rem 0.3rem; max-width:200px;">
                                        <option value="">Sin cuotas (0%)</option>
                                        <option value="co-funded">3 a 12 con interés bajo (+5%)</option>
                                        <option value="3x_campaign">3 al mismo precio (+8.4%)</option>
                                        <option value="6x_campaign">6 al mismo precio (+12.3%)</option>
                                        <option value="9x_campaign">9 al mismo precio (+15.7%)</option>
                                        <option value="12x_campaign">12 al mismo precio (+19.2%)</option>
                                    </select>
                                </td>
                                <td style="text-align:center; padding:0.5rem;">
                                    @if (fila.FreeShipping) { <span title="Envío gratis estimado">🚚</span> } else { <text>—</text> }
                                </td>
                                <td style="text-align:right; padding:0.5rem; font-weight:600;">$@fila.PrecioMeLi.ToString("N0")</td>
                                <td style="text-align:right; padding:0.5rem;">@fila.ComisionTotalPct.ToString("F1")%</td>
                                <td style="text-align:right; padding:0.5rem; color:#dc2626;">-$@fila.ComisionMonto.ToString("N0")</td>
                                <td style="text-align:right; padding:0.5rem; font-weight:700; color:@(fila.dentroDeRango ? "#16a34a" : "#dc2626");">
                                    $@fila.Neto.ToString("N0")
                                </td>
                                <td style="text-align:right; padding:0.5rem; color:@(fila.dentroDeRango ? "#6b7280" : "#dc2626"); font-weight:600;">
                                    @(fila.diferenciaVsPromedio >= 0 ? "+" : "")$@fila.diferenciaVsPromedio.ToString("N0")
                                    @if (fila.dentroDeRango) { <text> ✅</text> } else { <text> ⚠</text> }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot style="background:#f9fafb; font-weight:700;">
                        <tr>
                            <td colspan="7" style="text-align:right; padding:0.5rem;">Neto promedio:</td>
                            <td style="text-align:right; padding:0.5rem; color:#1e40af;">$@analisisMargenData.stats.netoPromedio.ToString("N0")</td>
                            <td style="padding:0.5rem; text-align:right; font-size:0.78rem;">
                                Spread: $@analisisMargenData.stats.spread.ToString("N0") (@analisisMargenData.stats.spreadPct.ToString("F1")%)
                            </td>
                        </tr>
                        <tr>
                            <td colspan="9" style="text-align:right; padding:0.5rem; font-size:0.8rem;">
                                <span style="color:#16a34a;">@analisisMargenData.stats.dentroDeRangoCount dentro del rango (±@analisisMargenData.toleranciaNetoPct%)</span> ·
                                <span style="color:#dc2626;">@analisisMargenData.stats.fueraDeRangoCount fuera</span>
                            </td>
                        </tr>
                    </tfoot>
                </table>

                <p style="font-size:0.78rem; color:#6b7280; margin-top:0.6rem;">
                    💡 Si MeLi no nos pasó bien las cuotas de una MLA, cambialas en el dropdown — se guarda como <strong>override manual</strong> y los cálculos se recalculan al instante.
                    Los precios marcados ⚠ son los que se desvían más de @(analisisMargenData.toleranciaNetoPct)% del neto promedio.
                </p>
            }
        </div>
    </div>
}

@if (showSyncMenu)
{
    <div class="filter-overlay" @onclick="() => showSyncMenu = false"></div>
}

@if (activeFilterColumn is not null)
{
    <div class="filter-overlay" @onclick="CloseAllDropdowns"></div>
}

@if (showItemModal && selectedItem is not null)
{
    <div class="modal-overlay" @onclick="CloseItemModal">
        <div class="modal-card modal-item-detail" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin:0; font-size:1rem;">Detalle de Publicacion</h3>
                <button class="modal-close" @onclick="CloseItemModal">&times;</button>
            </div>
            <div class="modal-body">
                <!-- Header: thumbnail + meta -->
                @if (!string.IsNullOrEmpty(selectedItem.CategoryPath) || !string.IsNullOrEmpty(selectedItem.CategoryId))
                {
                    <div style="font-size: 0.72rem; color: #9ca3af; margin-bottom: 0.2rem;">
                        @(selectedItem.CategoryPath ?? selectedItem.CategoryId) (@selectedItem.CategoryId)
                    </div>
                }
                <div style="margin-bottom: 0.75rem;">
                    <input type="text" class="form-input" @bind="editFamilyName" style="font-weight: 700; font-size: 1.05rem;" />
                </div>
                <div class="item-detail-header">
                    <div class="item-detail-thumb">
                        @if (!string.IsNullOrEmpty(selectedItem.Thumbnail))
                        {
                            <img src="@selectedItem.Thumbnail" alt="" />
                        }
                        else
                        {
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                        }
                    </div>
                    <div class="item-detail-meta">
                        <span class="item-detail-meli-id">@selectedItem.MeliItemId</span>
                        @if (!string.IsNullOrEmpty(selectedItem.Permalink))
                        {
                            <a href="@selectedItem.Permalink" target="_blank" class="item-detail-link">Ver en MercadoLibre <i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                        }
                        <span class="status-badge @GetStatusClass(selectedItem.Status)" style="width: fit-content;">@GetStatusLabel(selectedItem.Status)</span>
                        <span style="font-size: 0.8rem; color: #6b7280;">Cuenta: @selectedItem.AccountNickname</span>
                    </div>
                    <div style="font-size: 1.15rem; font-weight: 600; color: #374151; flex: 1; margin-left: 35px;">
                        @selectedItem.Title
                    </div>
                </div>
                <!-- Info + Cost Simulator side by side -->
                <div class="info-costs-row">
                    <div class="info-costs-left">
                        <div class="detail-section" style="margin-bottom: 0;">
                            <h4>Informacion</h4>
                            <div class="detail-info-grid">
                                <div class="detail-info-item">
                                    <span class="detail-label">SKU</span>
                                    <span class="detail-value">@(selectedItem.Sku ?? "-")</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Vendidos</span>
                                    <span class="detail-value">@selectedItem.SoldQuantity</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Tipo publicacion</span>
                                    <span class="detail-value">@GetListingTypeLabel(selectedItem.ListingTypeId) @GetInstallmentLabel(selectedItem.ListingTypeId, selectedItem.InstallmentTag)</span>
                                </div>
                                <div class="detail-info-item" style="grid-column: 1 / -1;">
                                    <span class="detail-label">Creada</span>
                                    <span class="detail-value">@(selectedItem.DateCreated?.ToArTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                                </div>
                                <div class="detail-info-item" style="grid-column: 1 / -1;">
                                    <span class="detail-label">Modificada</span>
                                    <span class="detail-value">@(selectedItem.LastUpdated?.ToArTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="info-costs-right">
                        <div class="cost-simulator">
                            @* 2026-07-01: rediseño — un solo bloque con flujo apilado hacia abajo.
                               Fusiona el simulador de costos + análisis de ganancia + calcular precio. *@
                            <h4>📊 Cuentas de esta venta</h4>
                            @if (isLoadingCosts)
                            {
                                <div class="cost-loading"><span>Calculando costos...</span></div>
                            }
                            else if (itemCosts is not null)
                            {
                                // 2026-06-19: descomposicion identica al simulador de MeLi.
                                // El sale_fee_amount de la API incluye comision base + cargo fijo + financiacion.
                                var financingEnPesos = Math.Round(itemCosts.Price * itemCosts.FinancingFee / 100m, 2);
                                var cargoPorVenderNeto = itemCosts.SaleFeeAmount - financingEnPesos;
                                var recibisConIva = CalculateNetAmount();
                                var ivaAAfip = recibisConIva - (recibisConIva / (1m + IvaAlicuota));
                                var teQuedaSinIva = RecibisSinIva();
                                var comisionPct = itemCosts.Price > 0 ? cargoPorVenderNeto / itemCosts.Price * 100m : 0m;
                                <div class="cost-line-items">
                                    <div class="cost-line cost-line-headline">
                                        <span class="cost-line-label"><strong>Precio publicado</strong></span>
                                        <span class="cost-line-amount"><strong>$ @itemCosts.Price.ToString("N2", argCulture)</strong></span>
                                    </div>
                                    <div class="cost-line">
                                        <span class="cost-line-label">Cargo por vender (@comisionPct.ToString("0.#", argCulture)%)</span>
                                        <span class="cost-line-amount negative">-$ @cargoPorVenderNeto.ToString("N2", argCulture)</span>
                                    </div>
                                    @if (itemCosts.FinancingFee > 0)
                                    {
                                        <div class="cost-line">
                                            <span class="cost-line-label">Costo por cuotas (@GetCuotasLabel(selectedItem?.InstallmentTag, selectedItem?.ListingTypeId))</span>
                                            <span class="cost-line-amount negative">-$ @financingEnPesos.ToString("N2", argCulture)</span>
                                        </div>
                                    }
                                    <div class="cost-line">
                                        <span class="cost-line-label">Costo por envío</span>
                                        <span class="cost-line-amount @(itemCosts.ShippingCost > 0 ? "negative" : "")">@(itemCosts.ShippingCost > 0 ? "-" : "")$ @itemCosts.ShippingCost.ToString("N2", argCulture)</span>
                                    </div>
                                    <div class="cost-line cost-line-tax">
                                        <div>
                                            <span class="cost-line-label" title="Más adelante los traeremos del padrón ARCA automáticamente. Por ahora lo cargás vos si querés simular.">Impuestos estimados ⓘ</span>
                                        </div>
                                        <div class="cost-tax-input">
                                            <input type="text" class="cost-tax-field" value="@FormatTaxPct()" @oninput="OnTaxPercentageChanged" inputmode="decimal" />
                                            <span class="cost-tax-pct">%</span>
                                            <span class="cost-line-amount negative" style="margin-left: 0.5rem;">-$ @(CalculateTaxAmount().ToString("N2", argCulture))</span>
                                        </div>
                                    </div>
                                    <div class="cost-line cost-line-subtotal">
                                        <span class="cost-line-label"><strong>Recibís de MeLi</strong></span>
                                        <span class="cost-line-amount"><strong>$ @recibisConIva.ToString("N2", argCulture)</strong></span>
                                    </div>
                                    <div class="cost-line">
                                        <span class="cost-line-label">IVA (21%) a AFIP</span>
                                        <span class="cost-line-amount negative">-$ @ivaAAfip.ToString("N2", argCulture)</span>
                                    </div>
                                    <div class="cost-line cost-line-subtotal">
                                        <span class="cost-line-label"><strong>Te queda (sin IVA)</strong></span>
                                        <span class="cost-line-amount"><strong>$ @teQuedaSinIva.ToString("N2", argCulture)</strong></span>
                                    </div>
                                    @if (isLoadingProductCost)
                                    {
                                        <div class="cost-line" style="color:#6b7280; font-style:italic;">
                                            <span class="cost-line-label">Costo del producto</span>
                                            <span class="cost-line-amount">Calculando...</span>
                                        </div>
                                    }
                                    else if (itemProductCost is null || itemProductCost.TotalCost == 0)
                                    {
                                        <div style="margin-top:0.5rem; padding:0.5rem 0.6rem; background:#fef3c7; border:1px solid #fcd34d; border-radius:6px; font-size:0.8rem; color:#92400e;">
                                            ⚠ Sin costo cargado en el sistema — no puedo calcular la ganancia real. Cargá el costo en el producto y volvé a abrir esta ficha.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="cost-line">
                                            <span class="cost-line-label">Costo del producto</span>
                                            <span class="cost-line-amount negative">-$ @itemProductCost.TotalCost.ToString("N2", argCulture)</span>
                                        </div>
                                        <div class="cost-line cost-line-total" style="background:@MarginColor(); color:white; padding:0.5rem 0.75rem; border-radius:6px; margin-top:0.35rem;">
                                            <span class="cost-line-label" style="color:white;"><strong>@MarginLabel().Split(' ')[0] GANANCIA REAL</strong></span>
                                            <span class="cost-line-amount" style="color:white;"><strong>$ @MarginGanancia().ToString("N2", argCulture)</strong></span>
                                        </div>
                                        <div style="display:flex; justify-content:space-between; padding:0.25rem 0.75rem 0; font-size:0.85rem; color:#6b7280;">
                                            <span>Margen</span>
                                            <span><strong style="color:@MarginColor();">@MarginPctSobreCosto().ToString("0.0", argCulture)% sobre costo</strong> · @MarginLabel()</span>
                                        </div>
                                        @* 2026-07-13: chip 🎯 objetivo — el objetivo es un PISO: estar ARRIBA es bueno (verde ✓),
                                           estar ABAJO conviene subir (ámbar ⚠). NO repetimos el % (ya está en "Margen" arriba). *@
                                        @if (selectedItem?.GananciaObjetivoPct.HasValue == true)
                                        {
                                            var _obj = selectedItem.GananciaObjetivoPct!.Value;
                                            var _real = MarginPctSobreCosto();
                                            var _arriba = _real >= _obj - 0.5m; // en el objetivo o por encima
                                            var _bg = _arriba ? "#dcfce7" : "#fef3c7";
                                            var _fg = _arriba ? "#166534" : "#92400e";
                                            <div style="display:flex; justify-content:space-between; align-items:center; padding:0.35rem 0.75rem; margin-top:0.35rem; background:@_bg; color:@_fg; border-radius:6px; font-size:0.82rem; font-weight:600;">
                                                <span>🎯 Objetivo <strong>@_obj.ToString("0.#", argCulture)%</strong></span>
                                                <span>@(_arriba ? "✓ estás arriba" : "⚠ estás abajo, conviene subir")</span>
                                            </div>
                                        }
                                        @if (itemProductCost.Components.Count > 1)
                                        {
                                            <div style="margin-top: 0.35rem; padding-top: 0.35rem; border-top: 1px dashed #d1d5db; font-size: 0.7rem; color: #6b7280;">
                                                📦 Costo = @string.Join(" + ", itemProductCost.Components.Select(c => $"{c.Cantidad}×{c.Sku} (${c.CostoTotal.ToString("N0", argCulture)})"))
                                            </div>
                                        }

                                        @* ─── Calculadora inversa: qué precio necesito para ganar X% ─── *@
                                        <div style="margin-top:1rem; padding-top:0.75rem; border-top:2px solid #e5e7eb;">
                                            <div style="font-weight:700; font-size:0.9rem; color:#1e40af; margin-bottom:0.5rem;">🧮 ¿Qué querés ganar?</div>
                                            <div style="display:flex; gap:0.5rem; align-items:flex-end; flex-wrap:wrap;">
                                                <div>
                                                    <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; margin-bottom:0.15rem;">Ganancia</div>
                                                    <div style="display:flex; gap:0.2rem;">
                                                        <input type="number" step="any" value="@calcGananciaValor"
                                                               @oninput="@(e => { if (decimal.TryParse(e.Value?.ToString()?.Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out var v)) calcGananciaValor = v; })"
                                                               style="width:75px; padding:0.35rem; border:1px solid #93c5fd; border-radius:5px; font-weight:700; text-align:right;" />
                                                        <button @onclick='() => calcGananciaModo = "%"'
                                                                style="padding:0.35rem 0.5rem; border:1px solid #93c5fd; border-radius:5px; cursor:pointer; font-weight:700; background:@(calcGananciaModo == "%" ? "#2563eb" : "white"); color:@(calcGananciaModo == "%" ? "white" : "#1e40af");">%</button>
                                                        <button @onclick='() => calcGananciaModo = "$"'
                                                                style="padding:0.35rem 0.5rem; border:1px solid #93c5fd; border-radius:5px; cursor:pointer; font-weight:700; background:@(calcGananciaModo == "$" ? "#2563eb" : "white"); color:@(calcGananciaModo == "$" ? "white" : "#1e40af");">$</button>
                                                    </div>
                                                    <div style="font-size:0.65rem; color:#9ca3af; margin-top:0.1rem;">@(calcGananciaModo == "%" ? "% sobre costo" : "$ por unidad")</div>
                                                </div>
                                                <div>
                                                    <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; margin-bottom:0.15rem;">Redondeo</div>
                                                    <div style="display:flex; gap:0.2rem;">
                                                        @foreach (var r in new[] { "exacto", "99", "999" })
                                                        {
                                                            var rLocal = r;
                                                            <button @onclick="() => calcRedondeo = rLocal"
                                                                    style="padding:0.35rem 0.5rem; border:1px solid #93c5fd; border-radius:5px; cursor:pointer; font-weight:700; background:@(calcRedondeo == rLocal ? "#2563eb" : "white"); color:@(calcRedondeo == rLocal ? "white" : "#1e40af");">@rLocal</button>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                            @{
                                                var precioCalc = CalcPrecioFinal();
                                            }
                                            @if (precioCalc.HasValue)
                                            {
                                                var netoCalc = CalcNetoAtPrecio(precioCalc.Value);
                                                var gananciaCalc = netoCalc - itemProductCost.TotalCost;
                                                <div style="margin-top:0.6rem; padding:0.5rem 0.75rem; background:#eff6ff; border:1px solid #bfdbfe; border-radius:6px;">
                                                    <div style="display:flex; justify-content:space-between; align-items:baseline;">
                                                        <span style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Precio sugerido</span>
                                                        <span style="font-size:1.15rem; font-weight:800; color:#1e40af;">$ @precioCalc.Value.ToString("N2", argCulture)</span>
                                                    </div>
                                                    <div style="font-size:0.75rem; color:#16a34a; font-weight:600; margin-top:0.15rem;">ganarías $@gananciaCalc.ToString("N0", argCulture)</div>
                                                </div>
                                                <button @onclick="AplicarPrecioCalculado" disabled="@(isPushingCalcPrecio)"
                                                        style="margin-top:0.5rem; width:100%; padding:0.55rem; background:#16a34a; color:white; border:none; border-radius:6px; font-weight:700; cursor:pointer;">
                                                    @(isPushingCalcPrecio ? "Pusheando..." : "✔ Aplicar una vez y pushear")
                                                </button>
                                                @if (calcGananciaModo == "%")
                                                {
                                                    <button @onclick="GuardarObjetivoYMantener" disabled="@(isGuardandoObjetivo)"
                                                            title="Guarda este % como objetivo de la publicación, prende el tilde de PRECIO y empuja el precio (nunca por debajo del piso sugerido). De ahí en más el sistema lo mantiene solo."
                                                            style="margin-top:0.4rem; width:100%; padding:0.55rem; background:#1e40af; color:white; border:none; border-radius:6px; font-weight:700; cursor:pointer;">
                                                        @(isGuardandoObjetivo ? "Guardando..." : "📌 Guardar objetivo y mantener")
                                                    </button>
                                                }
                                            }
                                            @* 2026-07-14: poner un precio EXACTO a mano (útil cuando el envío deja el cálculo trabado en un precio alto) *@
                                            <div style="margin-top:0.6rem; padding-top:0.5rem; border-top:1px dashed #e5e7eb;">
                                                <div style="font-size:0.72rem; color:#6b7280; margin-bottom:0.25rem;">O poné el precio a mano:</div>
                                                <div style="display:flex; gap:0.4rem;">
                                                    <input type="text" value="@precioManualStr" @oninput="OnPrecioManualInput" inputmode="decimal" placeholder="43399"
                                                           style="flex:1; padding:0.4rem 0.5rem; border:1px solid #d1d5db; border-radius:6px; text-align:right; font-weight:700;" />
                                                    <button @onclick="AplicarPrecioManual" disabled="@(isPushingManual || precioManual <= 0)"
                                                            style="padding:0.4rem 0.9rem; background:#b45309; color:white; border:none; border-radius:6px; font-weight:700; cursor:pointer; white-space:nowrap;">
                                                        @(isPushingManual ? "..." : "💵 Pushear")
                                                    </button>
                                                </div>
                                            </div>
                                            @if (selectedItem.GananciaObjetivoPct.HasValue)
                                            {
                                                <div style="margin-top:0.45rem; padding:0.4rem 0.6rem; background:@(selectedItem.SyncPrecio ? "#dcfce7" : "#fef3c7"); border-radius:6px; font-size:0.72rem; color:@(selectedItem.SyncPrecio ? "#166534" : "#92400e");">
                                                    🎯 Objetivo guardado: <strong>@selectedItem.GananciaObjetivoPct.Value.ToString("0.#", argCulture)%</strong>.
                                                    @(selectedItem.SyncPrecio ? "El tilde Precio está ON → se mantiene solo." : "Prendé el tilde 🏷 Precio para que se mantenga solo.")
                                                </div>
                                            }
                                            else
                                            {
                                                <div style="margin-top:0.6rem; font-size:0.78rem; color:#9ca3af;">Ingresá la ganancia deseada para calcular el precio.</div>
                                            }
                                            @{
                                                var catSibling = GetCatalogSibling(selectedItem);
                                            }
                                            @if (selectedItem.CatalogListing || catSibling is not null)
                                            {
                                                <div style="margin-top:0.5rem; padding:0.4rem 0.6rem; background:#fef9c3; border-left:3px solid #f59e0b; border-radius:4px; font-size:0.72rem; color:#92400e;">
                                                    📋 @(selectedItem.CatalogListing ? "Publi de CATÁLOGO" : "Hermana de CATÁLOGO")@(catSibling is not null ? $" ({catSibling.MeliItemId})" : "") — MeLi hermana los precios: cambiás una, la otra se mueve sola.
                                                </div>
                                            }
                                            <div style="margin-top:0.4rem; font-size:0.65rem; color:#9ca3af;">
                                                El cálculo usa los costos actuales del simulador (comisión @itemCosts.PercentageFee.ToString("0.#")%, cargo fijo, envío). No incluye IVA (se descuenta arriba) ni retenciones IIBB ~1% (que MeLi te aplica y todavía no las traemos). Si el precio cruza $30.000 el cargo fijo se elimina solo.
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="cost-loading"><span>No se pudieron obtener los costos</span></div>
                            }
                        </div>
                    </div>
                </div>
                @* 2026-07-01: se eliminaron los cuadros duplicados "Análisis de Ganancia" y "Calcular precio desde costo"
                   — ambos se fusionaron dentro del simulador arriba en un solo bloque con flujo apilado. *@

                @* ═══════════════════════════════════════════════════════════════════════════
                   2026-07-01: Modal FASE C — Push masivo de precios ya cargados a MeLi.
                   Este SÍ toca MeLi (los precios reales cambian). Preview obligatorio.
                   ═══════════════════════════════════════════════════════════════════════════ *@
                @if (showBulkPushModal)
                {
                    <div class="modal-overlay" @onclick="CerrarBulkPushModal">
                        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
                            <div class="modal-header" style="background:#ea580c; color:white;">
                                <h4 style="margin:0;">🚀 Pushear precios a MercadoLibre</h4>
                                <button class="modal-close" @onclick="CerrarBulkPushModal" style="color:white;">&times;</button>
                            </div>
                            <div class="modal-body">
                                @{
                                    var previewPush = GetBulkPushPreview();
                                }
                                <div style="background:#fef2f2; border:1px solid #dc2626; border-radius:6px; padding:0.7rem 0.9rem; margin-bottom:1rem; font-size:0.88rem; color:#991b1b;">
                                    <strong>⚠ Esta acción modifica precios REALES en MercadoLibre.</strong>
                                    Es reversible pusheando otro cambio, pero los compradores van a ver los precios nuevos ya. Revisá el preview con cuidado.
                                </div>

                                <div style="background:#f3f4f6; border-radius:6px; padding:0.6rem 0.8rem; margin-bottom:0.75rem; font-size:0.9rem;">
                                    <strong>@previewPush.PublisConAjuste</strong> se van a pushear a MeLi
                                    @if (previewPush.SinAjuste > 0)
                                    {
                                        <span style="color:#6b7280;"> · <strong>@previewPush.SinAjuste</strong> se saltan (no tienen ajuste cargado)</span>
                                    }
                                    <span style="color:#6b7280;"> · Total tildadas: @selectedItems.Count</span>
                                    @if (previewPush.DeltaTotal != 0)
                                    {
                                        var deltaColor = previewPush.DeltaTotal > 0 ? "#065f46" : "#991b1b";
                                        <div style="margin-top:0.35rem;">Impacto de los precios: <strong style="color:@deltaColor;">@(previewPush.DeltaTotal > 0 ? "+" : "")$@previewPush.DeltaTotal.ToString("N0")</strong> total sobre los precios actuales</div>
                                    }
                                </div>

                                @if (previewPush.PublisConAjuste == 0)
                                {
                                    <div style="padding:1rem; text-align:center; color:#9a3412; font-size:0.9rem; background:#fef3c7; border-radius:6px;">
                                        Ninguna de las publis tildadas tiene ajuste cargado. Cargá ajuste primero con ⚡ Cargar ajuste en lote.
                                    </div>
                                }
                                else
                                {
                                    <div style="max-height:340px; overflow-y:auto; border:1px solid #e5e7eb; border-radius:6px;">
                                        <table style="width:100%; font-size:0.82rem; border-collapse:collapse;">
                                            <thead style="background:#f9fafb; position:sticky; top:0;">
                                                <tr>
                                                    <th style="text-align:left; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Publicación</th>
                                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Ahora en MeLi</th>
                                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Nuevo</th>
                                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Δ</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in previewPush.Filas)
                                                {
                                                    var color = row.Delta > 0 ? "#065f46" : row.Delta < 0 ? "#991b1b" : "#6b7280";
                                                    <tr style="border-bottom:1px solid #f3f4f6;">
                                                        <td style="padding:0.35rem 0.6rem;">@Truncate(row.Titulo, 55)</td>
                                                        <td style="padding:0.35rem 0.6rem; text-align:right; color:#6b7280;">$@row.PrecioAhora.ToString("N0")</td>
                                                        <td style="padding:0.35rem 0.6rem; text-align:right; font-weight:600;">$@row.PrecioNuevo.ToString("N0")</td>
                                                        <td style="padding:0.35rem 0.6rem; text-align:right; color:@color; font-weight:600;">
                                                            @(row.Delta > 0 ? "+" : "")@row.Delta.ToString("N0")
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                        @if (previewPush.PublisConAjuste > previewPush.Filas.Count)
                                        {
                                            <div style="padding:0.4rem 0.6rem; text-align:center; color:#6b7280; font-size:0.78rem; background:#f9fafb;">
                                                Mostrando las primeras @previewPush.Filas.Count de @previewPush.PublisConAjuste
                                            </div>
                                        }
                                    </div>
                                }

                                @if (bulkPushResultado is not null)
                                {
                                    <div style="margin-top:1rem; padding:0.75rem 1rem; border-radius:6px; background:@(bulkPushResultado.Errores > 0 ? "#fef2f2" : "#dcfce7"); border:1px solid @(bulkPushResultado.Errores > 0 ? "#dc2626" : "#16a34a");">
                                        <div style="font-weight:700; font-size:0.9rem; margin-bottom:0.35rem;">Resultado del push</div>
                                        <div style="font-size:0.85rem;">
                                            ✅ Pusheadas OK: <strong>@bulkPushResultado.Pusheados</strong>
                                            @if (bulkPushResultado.SinAjuste > 0)
                                            {
                                                <span> · Sin ajuste (saltadas): @bulkPushResultado.SinAjuste</span>
                                            }
                                            @if (bulkPushResultado.Errores > 0)
                                            {
                                                <span style="color:#991b1b;"> · ❌ Errores: <strong>@bulkPushResultado.Errores</strong></span>
                                            }
                                        </div>
                                        @if (bulkPushResultado.Errores > 0)
                                        {
                                            <details style="margin-top:0.5rem; font-size:0.8rem;">
                                                <summary style="cursor:pointer; color:#991b1b;">Ver detalle de errores</summary>
                                                <div style="margin-top:0.35rem; max-height:120px; overflow-y:auto;">
                                                    @foreach (var d in bulkPushResultado.Detalles.Where(x => !x.Ok && !x.Message.Contains("Sin ajuste")))
                                                    {
                                                        <div style="padding:0.2rem 0.4rem; border-bottom:1px solid #fca5a5;">@d.MeliItemId — @d.Message</div>
                                                    }
                                                </div>
                                            </details>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="modal-footer">
                                <button class="btn btn-secondary btn-sm" @onclick="CerrarBulkPushModal" disabled="@bulkPushEjecutando">
                                    @(bulkPushResultado is not null ? "Cerrar" : "Cancelar")
                                </button>
                                @if (bulkPushResultado is null && previewPush.PublisConAjuste > 0)
                                {
                                    <button class="btn btn-sm" @onclick="EjecutarBulkPush" disabled="@bulkPushEjecutando"
                                            style="background:#ea580c; color:white; border:1px solid #c2410c; font-weight:600;">
                                        @(bulkPushEjecutando ? $"Pusheando... (esperá {previewPush.PublisConAjuste * 200 / 1000}s aprox)" : $"🚀 Pushear {previewPush.PublisConAjuste} precios ahora")
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }

                @* 2026-07-13: tarjeta "Ajuste de precio (para push)" RETIRADA a pedido de Osmar.
                   Ahora el precio se maneja SOLO con objetivo % + redondeo (sección "¿Qué querés ganar?").
                   Queda oculta detrás de mostrarAjusteViejo=false por si alguna vez hay que restaurarla. *@
                @if (mostrarAjusteViejo)
                {
                <div style="margin-top: 0.75rem; padding: 0.75rem 1rem; background: #fffbeb; border: 2px solid #fde68a; border-radius: 8px;">
                    <div style="font-weight: 700; font-size: 0.9rem; color: #92400e; margin-bottom: 0.6rem;">🏷 Ajuste de precio (para push)</div>
                    @{
                        var ajF = GetAjuste(selectedItem);
                        var prevF = PreviewPrecioAjustado(selectedItem);
                    }
                    <div style="display:flex; gap:1rem; align-items:flex-end; flex-wrap:wrap;">
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; margin-bottom:0.2rem;">% extra</div>
                            <input type="number" step="any" value="@(ajF.DeltaPct?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                   @onchange="(e) => OnAjustePctChange(selectedItem, e.Value?.ToString())"
                                   placeholder="0" style="width:80px; padding:0.4rem; border:1px solid #fcd34d; border-radius:6px; text-align:right;" />
                        </div>
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; margin-bottom:0.2rem;">$ extra</div>
                            <input type="number" step="any" value="@(ajF.DeltaPesos?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                   @onchange="(e) => OnAjustePesosChange(selectedItem, e.Value?.ToString())"
                                   placeholder="0" style="width:90px; padding:0.4rem; border:1px solid #fcd34d; border-radius:6px; text-align:right;" />
                        </div>
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; margin-bottom:0.2rem;">Redondeo</div>
                            <select value="@ajF.Redondeo" @onchange="(e) => OnAjusteRedondeoChange(selectedItem, e)"
                                    style="padding:0.4rem; border:1px solid #fcd34d; border-radius:6px;">
                                <option value="">—</option>
                                <option value="99">99</option>
                                <option value="999">999</option>
                                <option value="000">000</option>
                            </select>
                        </div>
                        @if (!string.IsNullOrEmpty(prevF))
                        {
                            <div style="padding:0.4rem 0.75rem; background:white; border:1px solid #fcd34d; border-radius:6px;">
                                <div style="font-size:0.65rem; color:#6b7280; text-transform:uppercase;">Precio con ajuste</div>
                                <div style="font-size:1.1rem; font-weight:800; color:#92400e;">→ $@prevF</div>
                            </div>
                        }
                        <div style="flex:1;"></div>
                        <button @onclick="() => QuickPushPrecio(selectedItem)"
                                style="padding:0.6rem 1rem; background:#b45309; color:white; border:none; border-radius:6px; font-weight:700; cursor:pointer; white-space:nowrap;"
                                title="Pushea el precio del sistema con este ajuste aplicado">
                            💵 Pushear precio
                        </button>
                        @if (!string.IsNullOrEmpty(selectedItem.FamilyId))
                        {
                            <button @onclick="PropagarAjusteDesdeFicha" disabled="@isPropagandoFicha"
                                    style="padding:0.6rem 1rem; background:white; color:#b45309; border:1px solid #b45309; border-radius:6px; font-weight:700; cursor:pointer; white-space:nowrap;"
                                    title="Copia este ajuste a las publicaciones hermanas de la familia (no las pushea)">
                                @(isPropagandoFicha ? "Propagando..." : "⚡ Propagar a familia")
                            </button>
                        }
                    </div>
                    @* Precio independiente (solo tiene sentido en familias) *@
                    @if (!string.IsNullOrEmpty(selectedItem.FamilyId))
                    {
                        <div style="margin-top:0.6rem; padding-top:0.6rem; border-top:1px dashed #fcd34d; display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
                            @if (selectedItem.PrecioIndependiente && selectedItem.PrecioFactor.HasValue)
                            {
                                <span style="padding:0.25rem 0.5rem; background:#dbeafe; color:#1d4ed8; border-radius:0.3rem; font-size:0.75rem; font-weight:600;">
                                    🔒 Precio independiente × @selectedItem.PrecioFactor.Value.ToString("F4")
                                    @if (selectedItem.PrecioBaseRef.HasValue)
                                    {
                                        <span style="font-weight:400; opacity:0.85;"> (base $@selectedItem.PrecioBaseRef.Value.ToString("N0"))</span>
                                    }
                                </span>
                                <button style="font-size:0.7rem; padding:0.2rem 0.5rem; background:#fff; color:#1d4ed8; border:1px solid #93c5fd; border-radius:0.25rem; cursor:pointer;" @onclick="() => RecalcularFactorPub(selectedItem)" title="Recalcular factor con precio actual MeLi">↻ Recalcular</button>
                                <button style="font-size:0.7rem; padding:0.2rem 0.5rem; background:#fef3c7; color:#92400e; border:1px solid #fde68a; border-radius:0.25rem; cursor:pointer;" @onclick="() => DesmarcarIndepPub(selectedItem)" title="Quitar precio independiente">✕ Quitar</button>
                            }
                            else
                            {
                                <button style="font-size:0.75rem; padding:0.3rem 0.6rem; background:#f3f4f6; color:#374151; border:1px solid #d1d5db; border-radius:0.25rem; cursor:pointer;" @onclick="() => MarcarIndepPub(selectedItem)" title="El precio de esta MLA deja de seguir a la familia y usa su propio factor">🔒 Marcar precio independiente</button>
                            }
                        </div>
                    }
                </div>
                }

                @* 2026-06-12: SECCIÓN STOCK Y SINCRONIZACIÓN — todo lo de stock de esta publicación en un lugar *@
                <div style="margin-top: 0.75rem; padding: 0.75rem 1rem; background: #f0fdf4; border: 2px solid #bbf7d0; border-radius: 8px;">
                    <div style="font-weight: 700; font-size: 0.9rem; color: #166534; margin-bottom: 0.6rem;">📦 Stock y sincronización</div>
                    <div style="display:flex; gap:1.25rem; align-items:center; flex-wrap:wrap;">
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Stock en MeLi</div>
                            <div style="font-size:1.2rem; font-weight:800; color:#166534;">@selectedItem.AvailableQuantity u.</div>
                        </div>
                        @if ((fichaStockFull.HasValue && fichaStockFull.Value > 0) || string.Equals(selectedItem.LogisticType, "fulfillment", StringComparison.OrdinalIgnoreCase))
                        {
                            <div>
                                <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Stock Full</div>
                                <div style="font-size:1.2rem; font-weight:800; color:#9a3412;" title="Unidades en la bodega Full de MercadoLibre (informativo, segun el ultimo sync de Full)">🏭 @(fichaStockFull ?? 0) u.</div>
                            </div>
                        }
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Linkeado a</div>
                            <div style="font-size:0.8rem; font-weight:600; color:#374151;">
                                @if (!string.IsNullOrEmpty(selectedItem.ComponentMappingsSummary))
                                {
                                    @selectedItem.ComponentMappingsSummary
                                }
                                else if (!string.IsNullOrEmpty(selectedItem.CafeProductoSku))
                                {
                                    @selectedItem.CafeProductoSku
                                }
                                else
                                {
                                    <span style="color:#dc2626;">⚠ Sin linkear — no se puede pushear stock</span>
                                }
                            </div>
                        </div>
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Sincronización automática</div>
                            <label style="display:flex; align-items:center; gap:0.35rem; cursor:pointer; margin-top:0.15rem;">
                                <input type="checkbox" checked="@selectedItem.SyncStock" disabled="@isSavingSyncStock"
                                       @onchange="ToggleSyncStockFicha" />
                                <span style="font-size:0.85rem; font-weight:700; color:@(selectedItem.SyncStock ? "#166534" : "#dc2626");">
                                    @(isSavingSyncStock ? "Guardando..." : selectedItem.SyncStock ? "✔ Activada" : "✖ Desactivada")
                                </span>
                            </label>
                        </div>
                        <div>
                            <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Último push de stock</div>
                            @if (selectedItem.LastStockPushedToMeli.HasValue)
                            {
                                var dias = (DateTime.UtcNow - selectedItem.LastStockPushedToMeli.Value).TotalDays;
                                <div style="font-size:0.85rem; font-weight:700; color:@(dias <= 7 ? "#166534" : "#b45309");">
                                    @(dias <= 7 ? "🟢" : "🟡") @selectedItem.LastStockPushedToMeli.Value.ToArTime().ToString("dd/MM HH:mm")
                                </div>
                            }
                            else
                            {
                                <div style="font-size:0.85rem; font-weight:700; color:#dc2626;">🔴 Nunca</div>
                            }
                        </div>
                        <div style="flex:1;"></div>
                        <button @onclick="PushStockDesdeFicha"
                                disabled="@(isPushingStockFicha || (string.IsNullOrEmpty(selectedItem.ComponentMappingsSummary) && string.IsNullOrEmpty(selectedItem.CafeProductoSku)))"
                                style="padding:0.6rem 1rem; background:#166534; color:white; border:none; border-radius:6px; font-weight:700; cursor:pointer; white-space:nowrap;">
                            @(isPushingStockFicha ? "Pusheando..." : "📦 Pushear stock ahora")
                        </button>
                    </div>
                </div>

                @* 2026-06-12: SECCIÓN MAYORISTA Y LÍMITES — lee y escribe directo en MeLi *@
                <div style="margin-top: 0.75rem; padding: 0.75rem 1rem; background: #faf5ff; border: 2px solid #e9d5ff; border-radius: 8px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.6rem;">
                        <span style="font-weight:700; font-size:0.9rem; color:#6b21a8;">🏪 Mayorista y límites de compra</span>
                        @if (isLoadingMayorista)
                        {
                            <span style="font-size:0.75rem; color:#6b7280;">Consultando MeLi...</span>
                        }
                    </div>
                    @if (fichaMayorista is null && !isLoadingMayorista)
                    {
                        <button @onclick="CargarMayoristaFicha"
                                style="padding:0.4rem 0.8rem; background:white; color:#6b21a8; border:1px solid #c4b5fd; border-radius:6px; font-weight:600; cursor:pointer; font-size:0.8rem;">
                            🔍 Cargar datos de MeLi
                        </button>
                    }
                    else if (fichaMayorista is not null)
                    {
                        <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; margin-bottom:0.3rem;">Precios por cantidad (mayorista — los ven compradores empresa)</div>
                        @for (int ti = 0; ti < mayoristaTiersEdit.Count; ti++)
                        {
                            var tIdx = ti;
                            var tier = mayoristaTiersEdit[tIdx];
                            <div style="display:flex; gap:0.4rem; align-items:center; margin-bottom:0.3rem;">
                                <span style="font-size:0.8rem; color:#374151;">Desde</span>
                                <input type="number" min="2" value="@tier.MinQty"
                                       @onchange="@(e => { if (int.TryParse(e.Value?.ToString(), out var v)) tier.MinQty = v; })"
                                       style="width:70px; padding:0.35rem; border:1px solid #c4b5fd; border-radius:6px; text-align:right;" />
                                <span style="font-size:0.8rem; color:#374151;">unidades →</span>
                                <span style="font-size:0.8rem; color:#374151;">$</span>
                                <input type="number" step="any" min="1" value="@tier.Amount"
                                       @onchange="@(e => { if (decimal.TryParse(e.Value?.ToString()?.Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out var v)) tier.Amount = v; })"
                                       style="width:110px; padding:0.35rem; border:1px solid #c4b5fd; border-radius:6px; text-align:right; font-weight:700;" />
                                @if (fichaMayorista.PrecioStandard > 0 && tier.Amount > 0)
                                {
                                    var descPct = (1 - tier.Amount / fichaMayorista.PrecioStandard) * 100;
                                    <span style="font-size:0.72rem; color:@(descPct > 0 ? "#16a34a" : "#dc2626");">(@(descPct > 0 ? "-" : "+")@Math.Abs(descPct).ToString("0.0")% vs $@fichaMayorista.PrecioStandard.ToString("N0"))</span>
                                }
                                <button @onclick="() => mayoristaTiersEdit.RemoveAt(tIdx)"
                                        style="padding:0.2rem 0.5rem; background:#fee2e2; color:#991b1b; border:none; border-radius:4px; cursor:pointer; font-weight:700;">✕</button>
                            </div>
                        }
                        @if (mayoristaTiersEdit.Count < 5)
                        {
                            <button @onclick="@(() => mayoristaTiersEdit.Add(new MayoristaTierEdit { MinQty = mayoristaTiersEdit.Count > 0 ? mayoristaTiersEdit[^1].MinQty * 2 : 5, Amount = fichaMayorista.PrecioStandard }))"
                                    style="padding:0.3rem 0.6rem; background:white; color:#6b21a8; border:1px dashed #c4b5fd; border-radius:6px; cursor:pointer; font-size:0.78rem;">
                                + Agregar escalón (@mayoristaTiersEdit.Count/5)
                            </button>
                        }
                        @if (fichaMayorista.EsAlimentos)
                        {
                            <div style="margin-top:0.6rem; padding:0.4rem 0.6rem; background:#fef3c7; border:1px solid #fde68a; border-radius:6px; font-size:0.72rem; color:#92400e;">
                                ⚠ Esta publicación es de categoría <b>Alimentos</b>: MercadoLibre administra el "Máximo por compra" y suele pisar el valor que pongas a los pocos minutos.
                            </div>
                        }
                        <div style="display:flex; gap:1rem; align-items:flex-end; margin-top:0.7rem; padding-top:0.6rem; border-top:1px dashed #e9d5ff; flex-wrap:wrap;">
                            <div>
                                <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Mínimo por compra</div>
                                <input type="number" min="0" value="@(mayoristaMinCompra?.ToString() ?? "")" placeholder="—"
                                       @onchange="@(e => mayoristaMinCompra = int.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : null)"
                                       style="width:90px; padding:0.35rem; border:1px solid #c4b5fd; border-radius:6px; text-align:right;" />
                            </div>
                            <div>
                                <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase;">Máximo por compra</div>
                                <input type="number" min="0" value="@(mayoristaMaxCompra?.ToString() ?? "")" placeholder="—"
                                       @onchange="@(e => mayoristaMaxCompra = int.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : null)"
                                       style="width:90px; padding:0.35rem; border:1px solid #c4b5fd; border-radius:6px; text-align:right;" />
                            </div>
                            <div style="font-size:0.65rem; color:#9ca3af; max-width:280px;">Vacío = sin límite. El máximo es cuántas unidades puede llevar un comprador en una misma compra.</div>
                            <div style="flex:1;"></div>
                            <button @onclick="GuardarMayoristaFicha" disabled="@isSavingMayorista"
                                    style="padding:0.6rem 1rem; background:#6b21a8; color:white; border:none; border-radius:6px; font-weight:700; cursor:pointer; white-space:nowrap;">
                                @(isSavingMayorista ? "Guardando en MeLi..." : "💾 Guardar en MeLi")
                            </button>
                        </div>
                    }
                </div>

                <!-- Editable fields -->
                <div class="detail-section">
                    @if (isLoadingPromotions)
                    {
                        <div class="promo-campaigns-loading">
                            <span>Cargando detalles de campañas...</span>
                        </div>
                    }
                    else if (itemPromotions is not null && itemPromotions.Any())
                    {
                        var activeCampaigns = itemPromotions.Where(p => p.Status == "started").ToList();
                        var otherCampaigns = itemPromotions.Where(p => p.Status != "started").ToList();

                        @if (activeCampaigns.Any())
                        {
                            <div class="promo-campaigns">
                                <span class="promo-campaigns-title">Campañas activas (@activeCampaigns.Count)</span>
                                @foreach (var promo in activeCampaigns)
                                {
                                    @RenderCampaignCard(promo)
                                }
                            </div>
                        }

                        @if (otherCampaigns.Any())
                        {
                            <div class="promo-campaigns promo-campaigns-other">
                                <button class="promo-collapse-toggle" @onclick="() => showOtherCampaigns = !showOtherCampaigns">
                                    <span>Otras campañas disponibles (@otherCampaigns.Count)</span>
                                    <span class="promo-collapse-icon">@(showOtherCampaigns ? "▲" : "▼")</span>
                                </button>
                                @if (showOtherCampaigns)
                                {
                                    @foreach (var promo in otherCampaigns)
                                    {
                                        @RenderCampaignCard(promo)
                                    }
                                }
                            </div>
                        }
                    }
                    else if (itemPromotions is not null && !itemPromotions.Any())
                    {
                        <div class="promo-campaigns-empty">
                            <span>No se encontraron campañas asociadas</span>
                        </div>
                    }
                    <div style="display: grid; grid-template-columns: 1fr 1.1fr 0.8fr 1fr; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Precio de venta (@selectedItem.CurrencyId)</label>
                            <div style="position: relative;"><span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #333;">$</span><input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px;" value="@editPriceFormatted" @oninput="OnPriceInput" inputmode="decimal" /></div>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label" style="color:#d97706; font-weight:700;">Precio de lista <span style="text-decoration:line-through;">(tachado)</span></label>
                            <div style="position: relative;"><span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #d97706;">$</span><input type="text" class="form-input" placeholder="Sin precio de lista" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px; border-color:#fbbf24; background:#fffbeb; color:#92400e;" value="@editListPriceFormatted" @oninput="OnListPriceInput" inputmode="decimal" /></div>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Stock</label>
                            <input type="number" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right;" @bind="editStock" min="0" />
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label class="form-label">Estado</label>
                            <div class="status-toggle">
                                <button class="status-toggle-btn @(editStatus == "active" ? "active-btn" : "")" @onclick='() => editStatus = "active"'>Activa</button>
                                <button class="status-toggle-btn @(editStatus == "paused" ? "paused-btn" : "")" @onclick='() => editStatus = "paused"'>Pausada</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseItemModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveItem" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

