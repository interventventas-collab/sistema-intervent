    /* Item detail modal */
    .modal-item-detail {
        max-width: 600px;
        width: 95%;
    }
    .item-detail-header {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .item-detail-thumb {
        width: 100px;
        height: 100px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f9fafb;
    }
    .item-detail-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .item-detail-meta {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        justify-content: center;
    }
    .item-detail-meli-id {
        font-size: 0.75rem;
        color: #9ca3af;
        font-family: monospace;
    }
    .item-detail-link {
        font-size: 0.8rem;
        color: #4f46e5;
        text-decoration: none;
    }
    .item-detail-link:hover {
        text-decoration: underline;
    }

    /* Info + Cost Simulator layout */
    .info-costs-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .info-costs-left {
        min-width: 0;
    }
    .info-costs-left .detail-section {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.75rem;
    }
    .info-costs-right {
        min-width: 0;
    }
    .cost-simulator {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.75rem;
    }
    .cost-simulator h4 {
        font-size: 0.85rem;
        color: #374151;
        margin: 0 0 0.5rem 0;
        padding-bottom: 0.35rem;
        border-bottom: 1px solid #e5e7eb;
    }
    .cost-price-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
        margin-bottom: 0.75rem;
    }
    .cost-price-label {
        font-size: 0.75rem;
        color: #6b7280;
    }
    .cost-price-value {
        font-size: 1rem;
        font-weight: 600;
        color: #1f2937;
    }
    .cost-line-items {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 0.5rem;
    }
    .cost-line {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        font-size: 0.8rem;
    }
    .cost-line-label {
        color: #374151;
    }
    .cost-line-sub {
        font-size: 0.7rem;
        color: #3b82f6;
        margin-top: 1px;
    }
    .cost-line-amount {
        color: #374151;
        font-weight: 500;
        white-space: nowrap;
        margin-left: 0.5rem;
    }
    .cost-line-amount.negative {
        color: #374151;
    }
    .cost-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .cost-total-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #374151;
    }
    .cost-total-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1f2937;
    }
    .cost-loading {
        text-align: center;
        padding: 1rem;
        color: #9ca3af;
        font-size: 0.8rem;
    }
    .cost-line-tax {
        flex-wrap: wrap;
    }
    .cost-tax-input {
        display: flex;
        align-items: center;
        gap: 2px;
    }
    .cost-tax-field {
        width: 50px;
        padding: 2px 4px;
        border: 1px solid #d1d5db;
        border-radius: 4px;
        font-size: 0.8rem;
        text-align: right;
        background: white;
    }
    .cost-tax-field:focus {
        outline: none;
        border-color: #3b82f6;
    }
    .cost-tax-pct {
        font-size: 0.75rem;
        color: #6b7280;
    }

    /* Detail sections */
    .detail-section {
        margin-bottom: 1rem;
    }
    .detail-section h4 {
        font-size: 0.85rem;
        color: #374151;
        margin: 0 0 0.5rem 0;
        padding-bottom: 0.35rem;
        border-bottom: 1px solid #e5e7eb;
    }
    .detail-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
    }
    .detail-info-item {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }
    .detail-label {
        font-size: 0.7rem;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }
    .detail-value {
        font-size: 0.85rem;
        color: #1f2937;
    }

    /* Status toggle */
    .status-toggle {
        display: flex;
        gap: 0.5rem;
    }
    .status-toggle-btn {
        flex: 1;
        padding: 0.5rem 1rem;
        border: 2px solid #d1d5db;
        border-radius: 8px;
        background: white;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 500;
        color: #6b7280;
        transition: all 0.15s;
    }
