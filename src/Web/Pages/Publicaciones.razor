        photosLoading = false;
        if (dto is null)
        {
            ToastService.Error("No se pudieron cargar las fotos de esta publicación.");
            return;
        }
        photosCatalog = dto.CatalogListing;
        photosEdit = dto.Pictures.Select(p => new PhotoEdit { Id = p.Id, PreviewUrl = p.Url }).ToList();
        MarcarFotosEnInfraccion(item);
        StateHasChanged();
    }

    // Marca en rojo la(s) foto(s) que MeLi señaló como en infracción: por ID exacto, y si esa foto
    // ya no está, marca la PORTADA cuando el motivo es de portada. Núcleo del ID = parte "MLA…".
    private void MarcarFotosEnInfraccion(MeliItemDto item)
    {
        foreach (var p in photosEdit) p.Problem = null;
        if (!photoInfractions.TryGetValue(item.MeliItemId, out var infr)) return;

        static string Core(string id)
        {
            if (string.IsNullOrEmpty(id)) return "";
            var m = System.Text.RegularExpressions.Regex.Match(id, "ML[A-Z]?\\d+");
            return m.Success ? m.Value : id;
        }
        var badCores = infr.PictureIds.Select(Core).Where(c => c.Length > 0).ToHashSet();

        int marcadas = 0;
        foreach (var p in photosEdit)
        {
            if (!string.IsNullOrEmpty(p.Id) && badCores.Contains(Core(p.Id)))
            {
                p.Problem = string.IsNullOrWhiteSpace(infr.Reason) ? "En infracción" : infr.Reason;
                marcadas++;
            }
        }
        // Si no coincidió ninguna por ID pero el problema es de portada, marco la primera (portada).
        if (marcadas == 0 && infr.AfectaPortada && photosEdit.Count > 0)
            photosEdit[0].Problem = string.IsNullOrWhiteSpace(infr.Reason) ? "Portada en infracción" : infr.Reason;
    }

    private bool photoAddingLink = false;
    private async Task PhotoAddLink()
    {
        var url = (photosLinkInput ?? "").Trim();
        if (string.IsNullOrEmpty(url)) return;
        if (!url.StartsWith("http")) { ToastService.Error("Pegá un enlace que empiece con http…"); return; }
        photoAddingLink = true;
        StateHasChanged();
        try
        {
            // El sistema baja la foto (esquiva bloqueos y convierte webp→jpg) y la deja capturada como
            // archivo: aunque el sitio la borre después, no se pierde y MeLi guarda su propia copia al guardar.
            var (dataUri, error) = await Api.FetchImageFromUrlAsync(url);
            if (string.IsNullOrEmpty(dataUri)) { ToastService.Error(error ?? "No se pudo traer la foto del enlace."); return; }
            photosEdit.Add(new PhotoEdit { DataUri = dataUri, PreviewUrl = dataUri });
            photosLinkInput = "";
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { photoAddingLink = false; StateHasChanged(); }
    }

    private async Task PhotoUploadFiles(InputFileChangeEventArgs e)
    {
        const long max = 10L * 1024 * 1024; // 10 MB (límite de MeLi)
        foreach (var file in e.GetMultipleFiles(12))
        {
            if (file.Size > max) { ToastService.Error($"{file.Name}: supera los 10 MB permitidos por MercadoLibre."); continue; }
            var ct = string.IsNullOrEmpty(file.ContentType) ? "image/jpeg" : file.ContentType;
            using var stream = file.OpenReadStream(max);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var dataUri = $"data:{ct};base64,{Convert.ToBase64String(ms.ToArray())}";
            photosEdit.Add(new PhotoEdit { DataUri = dataUri, PreviewUrl = dataUri });
        }
        StateHasChanged();
    }

    private void PhotoRemove(PhotoEdit p) => photosEdit.Remove(p);

    private void PhotoMove(PhotoEdit p, int dir)
    {
        var idx = photosEdit.IndexOf(p);
        var ni = idx + dir;
        if (idx < 0 || ni < 0 || ni >= photosEdit.Count) return;
        photosEdit.RemoveAt(idx);
        photosEdit.Insert(ni, p);
    }

    private async Task PhotoSave(MeliItemDto item)
