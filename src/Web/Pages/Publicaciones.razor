@* ═══════════════════════════════════════════════════════════════════════════
   2026-07-01: Modal UNIFICADO "Ajustar precios en lote" (fusión Fase B + C).
   Aplica %/$/Redondeo a las publis tildadas y AL PIE del modal el usuario elige:
   - "Solo guardar" (queda en base, MeLi sigue igual)
   - "🚀 Guardar y publicar en MeLi" (guarda + pushea en un solo paso)
   Preview se calcula 100% en frontend.
   ═══════════════════════════════════════════════════════════════════════════ *@
@if (showBulkAjusteModal)
{
    <div class="modal-overlay" @onclick="CerrarBulkAjusteModal">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header" style="background:#16a34a; color:white;">
                <h4 style="margin:0;">💵 Ajustar precios en lote — @selectedItems.Count publicaciones</h4>
                <button class="modal-close" @onclick="CerrarBulkAjusteModal" style="color:white;">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background:#dbeafe; border:1px solid #3b82f6; border-radius:6px; padding:0.6rem 0.8rem; margin-bottom:1rem; font-size:0.85rem; color:#1e40af;">
                    Ponés la <strong>ganancia que querés obtener sobre el costo</strong> y para cada publi el sistema calcula
                    el precio necesario considerando su costo + comisión MeLi + envío + IVA (mismo motor que la ficha individual "¿Qué querés ganar?").
                </div>

                <div style="display:grid; grid-template-columns: 1fr 1.2fr; gap:0.75rem; margin-bottom:1rem;">
                    <div>
                        <label style="display:block; font-size:0.78rem; color:#374151; font-weight:600; margin-bottom:0.2rem;">🎯 Ganancia deseada (% sobre costo)</label>
                        <input type="number" step="0.1" @bind="bulkGananciaPct" @bind:event="oninput"
                               placeholder="ej: 30"
                               style="width:100%; padding:0.4rem 0.5rem; border:1px solid #d1d5db; border-radius:4px; font-size:0.9rem;" />
                    </div>
                    <div>
                        <label style="display:block; font-size:0.78rem; color:#374151; font-weight:600; margin-bottom:0.2rem;">Redondeo</label>
                        <select @bind="bulkAjusteRedondeoOpt"
                                style="width:100%; padding:0.4rem 0.5rem; border:1px solid #d1d5db; border-radius:4px; font-size:0.9rem;">
                            <option value="">Sin redondeo (exacto)</option>
                            <option value="99">Termina en 99</option>
                            <option value="999">Termina en 999</option>
                            <option value="000">Múltiplo de 1000</option>
                        </select>
                    </div>
                </div>

                <div style="margin-bottom:0.75rem;">
                    <label style="display:inline-flex; align-items:center; gap:0.4rem; font-size:0.82rem; color:#6b7280;">
                        <input type="checkbox" @bind="bulkIncluirPrecioIndep" />
                        Incluir también las publis con <strong>precio independiente</strong> (avanzado)
                    </label>
                </div>

                @{
                    var preview = GetBulkPreview();
                    var totalTildadas = selectedItems.Count;
                    var saltadasPI = preview.SaltadasPrecioIndependiente;
                    var vanACambiar = preview.VanACambiar;
                }
                @* 2026-07-01: aviso rojo si hay publis que cruzarían el umbral de envío. *@
                @if (preview.CruzanUmbral > 0)
                {
                    <div style="background:#fef2f2; border:2px solid #dc2626; border-radius:6px; padding:0.65rem 0.85rem; margin-bottom:0.75rem; font-size:0.85rem; color:#991b1b;">
                        <strong>⚠ @preview.CruzanUmbral @(preview.CruzanUmbral == 1 ? "publicación cruza" : "publicaciones cruzan") el umbral de envío ($@UMBRAL_ENVIO_APROX.ToString("N0"))</strong>
                        <div style="margin:0.3rem 0 0.5rem 0;">
                            El precio nuevo cambia de régimen: MeLi te empieza (o deja) a cobrar el envío gratis (~$50k+). El masivo no calcula bien estos casos.
                            <strong>Trabajálas de a una desde la ficha.</strong>
                        </div>
                        <button class="btn btn-sm" @onclick="DestildarCrucesUmbral"
                                style="background:#dc2626; color:white; border:1px solid #991b1b; font-weight:600;">
                            🚫 Destildar las @preview.CruzanUmbral que cruzan
                        </button>
                    </div>
                }

                <div style="background:#f3f4f6; border-radius:6px; padding:0.5rem 0.75rem; margin-bottom:0.5rem; font-size:0.85rem;">
                    <strong>@vanACambiar</strong> se van a modificar
                    @if (saltadasPI > 0)
                    {
                        <span style="color:#9a3412;"> · <strong>@saltadasPI</strong> se saltan por precio independiente</span>
                    }
                    @if (preview.SinCosto > 0)
                    {
                        <span style="color:#dc2626;"> · <strong>@preview.SinCosto</strong> sin costo cargado (se saltan)</span>
                    }
                    <span style="color:#6b7280;"> · Total tildadas: @totalTildadas</span>
                </div>

                @if (preview.Filas.Count > 0)
                {
                    <div style="max-height:340px; overflow-y:auto; border:1px solid #e5e7eb; border-radius:6px;">
                        <table style="width:100%; font-size:0.82rem; border-collapse:collapse;">
                            <thead style="background:#f9fafb; position:sticky; top:0;">
                                <tr>
                                    <th style="text-align:left; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Publicación</th>
                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Costo</th>
                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Precio ahora</th>
                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Precio nuevo</th>
                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Ganancia $</th>
                                    <th style="text-align:right; padding:0.4rem 0.6rem; border-bottom:1px solid #e5e7eb;">Margen</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in preview.Filas)
                                {
                                    var rowBg = row.SinCosto ? "background:#fef3c7;" : (row.CruzaUmbral ? "background:#fef2f2;" : "");
                                    <tr style="border-bottom:1px solid #f3f4f6; @rowBg">
                                        <td style="padding:0.35rem 0.6rem;">
                                            @if (row.CruzaUmbral)
                                            {
                                                <span style="margin-right:0.35rem; color:#dc2626; font-weight:700;" title="Cruza el umbral $@UMBRAL_ENVIO_APROX.ToString("N0") — hay que trabajarla individual">⚠</span>
                                            }
                                            @if (row.SinCosto)
                                            {
                                                <span style="margin-right:0.35rem; color:#92400e; font-weight:700;" title="Sin costo cargado en el sistema — no puedo calcular">⚠</span>
                                            }
                                            @Truncate(row.Titulo, 45)
                                        </td>
                                        <td style="padding:0.35rem 0.6rem; text-align:right; color:#6b7280;">@(row.Costo.HasValue ? "$" + row.Costo.Value.ToString("N0") : "—")</td>
                                        <td style="padding:0.35rem 0.6rem; text-align:right; color:#6b7280;">$@row.PrecioAhora.ToString("N0")</td>
                                        <td style="padding:0.35rem 0.6rem; text-align:right; font-weight:700;">@(row.PrecioNuevo.HasValue ? "$" + row.PrecioNuevo.Value.ToString("N0") : "—")</td>
                                        <td style="padding:0.35rem 0.6rem; text-align:right; font-weight:600; color:#16a34a;">@(row.Ganancia.HasValue ? "$" + row.Ganancia.Value.ToString("N0") : "—")</td>
                                        <td style="padding:0.35rem 0.6rem; text-align:right; font-weight:700; color:@(row.MargenPct.HasValue && row.MargenPct.Value >= 15 ? "#16a34a" : row.MargenPct.HasValue && row.MargenPct.Value >= 0 ? "#f97316" : "#dc2626");">
                                            @(row.MargenPct.HasValue ? row.MargenPct.Value.ToString("0.#") + "%" : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (vanACambiar > preview.Filas.Count)
                        {
                            <div style="padding:0.4rem 0.6rem; text-align:center; color:#6b7280; font-size:0.78rem; background:#f9fafb;">
                                Mostrando las primeras @preview.Filas.Count de @vanACambiar
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding:1rem; text-align:center; color:#6b7280; font-size:0.85rem; background:#f9fafb; border-radius:6px;">
                        Ingresá una ganancia > 0 para ver el preview.
                    </div>
                }
            </div>
            <div class="modal-footer" style="display:flex; justify-content:space-between; gap:0.5rem; flex-wrap:wrap;">
                <button class="btn btn-sm" @onclick="BorrarBulkAjuste" disabled="@bulkGuardando"
                        style="background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; font-weight:600;"
                        title="Vaciar los 3 campos de ajuste (%/$/redondeo) de las publis tildadas">
                    🗑 Borrar ajuste de las @selectedItems.Count
                </button>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarBulkAjusteModal" disabled="@bulkGuardando">Cancelar</button>
                    <button class="btn btn-sm" @onclick="() => GuardarBulkAjuste(publicarEnMeli: false)" disabled="@(bulkGuardando || !PuedeGuardarBulk() || preview.CruzanUmbral > 0)"
                            style="background:#16a34a; color:white; border:1px solid #15803d; font-weight:600;"
                            title="@(preview.CruzanUmbral > 0 ? "Destildá primero las que cruzan el umbral (botón rojo arriba)" : "Guarda el ajuste en tu base. MeLi sigue con los precios viejos hasta que decidas publicarlos.")">
                        @(bulkGuardando && !bulkPublicarEnMeli ? "Guardando..." : "Solo guardar")
                    </button>
                    <button class="btn btn-sm" @onclick="() => GuardarBulkAjuste(publicarEnMeli: true)" disabled="@(bulkGuardando || !PuedeGuardarBulk() || preview.CruzanUmbral > 0)"
                            style="background:#ea580c; color:white; border:1px solid #c2410c; font-weight:600;"
                            title="@(preview.CruzanUmbral > 0 ? "Destildá primero las que cruzan el umbral (botón rojo arriba)" : "Guarda el ajuste Y lo publica en MercadoLibre. Los precios cambian ya para los compradores.")">
                        @(bulkGuardando && bulkPublicarEnMeli ? "Publicando en MeLi..." : "🚀 Guardar y publicar en MeLi")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showCreateProductModal && createProductItem is not null)
{
    <div class="modal-overlay" @onclick="CloseCreateProductModal">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin:0; font-size:1rem;">Crear Producto desde Publicacion</h3>
                <button class="modal-close" @onclick="CloseCreateProductModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.8rem; color: #6b7280; margin-bottom: 1rem;">
                    Publicacion: <strong>@createProductItem.MeliItemId</strong> - @Truncate(createProductItem.Title, 60)
                </p>
                @if (isLoadingDetails)
                {
                    <p style="font-size: 0.8rem; color: #3b82f6; margin-bottom: 0.5rem;">Cargando imagenes y descripcion de MercadoLibre...</p>
                }
                @if (!string.IsNullOrEmpty(newProductPhoto1) || !string.IsNullOrEmpty(newProductPhoto2) || !string.IsNullOrEmpty(newProductPhoto3))
                {
                    <div class="create-product-images">
                        @if (!string.IsNullOrEmpty(newProductPhoto1))
                        {
                            <img src="@newProductPhoto1" alt="Foto 1" class="create-product-img" />
                        }
                        @if (!string.IsNullOrEmpty(newProductPhoto2))
                        {
                            <img src="@newProductPhoto2" alt="Foto 2" class="create-product-img" />
                        }
                        @if (!string.IsNullOrEmpty(newProductPhoto3))
                        {
                            <img src="@newProductPhoto3" alt="Foto 3" class="create-product-img" />
                        }
                    </div>
                }
                <div class="form-group">
                    <label class="form-label">Titulo *</label>
                    <input type="text" class="form-input" @bind="newProductTitle" />
                </div>
                <div class="form-group">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-input" rows="3" @bind="newProductDescription"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">SKU</label>
                        <input type="text" class="form-input" @bind="newProductSku" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Marca</label>
                        <input type="text" class="form-input" @bind="newProductBrand" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Modelo</label>
                        <input type="text" class="form-input" @bind="newProductModel" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Precio de Costo</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #333;">$</span>
                            <input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px;" value="@newProductCostPriceFormatted" @oninput="OnCostPriceInput" inputmode="decimal" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">PVP</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #333;">$</span>
                            <input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px;" value="@newProductRetailPriceFormatted" @oninput="OnRetailPriceInput" inputmode="decimal" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock</label>
                        <input type="number" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right;" @bind="newProductStock" min="0" />
