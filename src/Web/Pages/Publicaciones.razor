    // Encabezado de columnas de la lista.
    private RenderFragment RenderListHead() => @<div class="plist-head">
        <div @onclick:stopPropagation="true"><input type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected()" title="Seleccionar todos" /></div>
        <div></div>
        <div>Producto</div>
        <div>Precio · margen</div>
        <div style="text-align:right;">Stock</div>
        <div>Estado</div>
        <div></div>
    </div>;

    // Fila de UNA publicación (colapsada) + su panel de edición. Reutilizada por Lista (items sueltos),
    // Por Familia y Por Producto. Usa los mismos sub-fragmentos, así el look es idéntico en las 3 vistas.
    private RenderFragment RenderPubRow(MeliItemDto item) => @<text>
        @{
            var isEditOpen = expandedEditKey == item.Id;
            var stockShow = item.AvailableQuantity;
        }
        <div class="plist-row @(selectedItems.Contains(item.Id) ? "sel" : "") @(isEditOpen ? "open" : "")" style="@CatalogRowStyle(item)" @onclick="() => OpenItemModal(item)">
            <div @onclick:stopPropagation="true"><input type="checkbox" checked="@selectedItems.Contains(item.Id)" @onchange="() => ToggleSelectItem(item.Id)" /></div>
            <div>@RenderThumb(item)</div>
            <div style="min-width:0;">
                <div class="plist-title" title="@item.Title">@item.Title</div>
                <div class="plist-meta">
                    @RenderSkuMla(item)
                    <span> · @item.AccountNickname </span>
                    @RenderLinkedTag(item)
                </div>
                <div>@RenderTipoCuotas(item)</div>
            </div>
            <div style="min-width:0;">@RenderPriceMargin(item)</div>
            <div class="plist-stk @(stockShow == 0 ? "zero" : "")"><div class="n">@stockShow</div><div class="u">@(stockShow == 0 ? "sin stock" : "unid.")</div></div>
            <div>@RenderEstadoItem(item, true)</div>
            <div @onclick:stopPropagation="true"><button class="plist-chev @(isEditOpen ? "open" : "")" @onclick="() => ToggleEditPanel(item.Id)" aria-expanded="@isEditOpen" title="Editar precio y sincronización">@(isEditOpen ? "⌃" : "⌄")</button></div>
        </div>
        @if (isEditOpen)
        {
            @RenderEditPanel(item)
        }
    </text>;

    // Vista "Por Familia": secciones por familia, cada item con el look nuevo.
    private RenderFragment RenderFamilyView() => @<div>
        @RenderSearchBar()
        <div class="plist">
            @RenderListHead()
            @foreach (var family in GetFamilyGroups())
            {
                <div class="plist-section">@(family.FamilyName ?? "Sin familia") <span class="cnt">(@family.Items.Count)</span></div>
                @foreach (var item in family.Items)
                {
                    @RenderPubRow(item)
                }
            }
        </div>
    </div>;

    // Vista "Por Producto": secciones por producto (solo si tiene >1 variación), cada item con el look nuevo.
    private RenderFragment RenderProductView() => @<div>
        @RenderSearchBar()
        <div class="plist">
            @RenderListHead()
            @foreach (var product in GetProductGroups())
            {
                @if (product.Items.Count > 1)
                {
                    <div class="plist-section">@Truncate(product.Title, 60) <span class="cnt">(@product.Items.Count variaciones)</span></div>
                    @foreach (var item in product.Items)
                    {
                        @RenderPubRow(item)
                    }
                }
                else
                {
                    @RenderPubRow(product.Items[0])
                }
            }
        </div>
    </div>;

    private RenderFragment RenderFlatList() => @<div>
