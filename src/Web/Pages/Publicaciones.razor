    private RenderFragment ControlesFila(MeliItemDto item) =>
    @<span style="display:inline-flex; gap:0.5rem; flex-wrap:wrap; align-items:center; margin-top:0.25rem;">
        @if (item.CafeProductoId.HasValue || item.ComponentMappingsCount > 0)
        {
            var objVal = _objInput.TryGetValue(item.Id, out var ov) ? ov : (item.GananciaObjetivoPct?.ToString("0.#", argCulture) ?? "");
            var savingO = _savingObjFila.Contains(item.Id);
            <span style="display:inline-flex; align-items:center; gap:2px;" @onclick:stopPropagation="true">
                <span title="Objetivo de ganancia %" style="font-size:0.7rem;">🎯</span>
                <input value="@objVal" @onchange="(e) => _objInput[item.Id] = e.Value?.ToString() ?? string.Empty"
                       style="width:38px; padding:0.1rem 0.25rem; font-size:0.7rem; text-align:right; border:1px solid #cbd5e1; border-radius:4px;" />
                <span style="font-size:0.7rem; color:#6b7280;">%</span>
                <button @onclick:stopPropagation="true" @onclick="() => AplicarObjetivoFila(item)" disabled="@savingO"
                        title="Guardar el objetivo y aplicarlo (mantiene el % solo)"
                        style="padding:0.1rem 0.4rem; font-size:0.68rem; font-weight:700; background:#1e40af; color:white; border:none; border-radius:4px; cursor:pointer;">
                    @(savingO ? "…" : "Aplicar")
                </button>
            </span>
            var precioVal = _precioInput.TryGetValue(item.Id, out var pv) ? pv : "";
            var savingP = _savingPrecioFila.Contains(item.Id);
            <span style="display:inline-flex; align-items:center; gap:2px;" @onclick:stopPropagation="true">
                <span title="Precio a mano" style="font-size:0.7rem;">💵</span>
                <input value="@precioVal" placeholder="precio" @onchange="(e) => _precioInput[item.Id] = e.Value?.ToString() ?? string.Empty"
                       style="width:62px; padding:0.1rem 0.25rem; font-size:0.7rem; text-align:right; border:1px solid #cbd5e1; border-radius:4px;" />
                <button @onclick:stopPropagation="true" @onclick="() => AplicarPrecioFila(item)" disabled="@savingP"
                        title="Empujar este precio exacto a MeLi"
                        style="padding:0.1rem 0.4rem; font-size:0.68rem; font-weight:700; background:#b45309; color:white; border:none; border-radius:4px; cursor:pointer;">
                    @(savingP ? "…" : "Push")
                </button>
            </span>
        }
    </span>;

    private async Task AplicarObjetivoFila(MeliItemDto item)
    {
        if (_savingObjFila.Contains(item.Id)) return;
        _objInput.TryGetValue(item.Id, out var raw);
        if (!decimal.TryParse((raw ?? "").Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out var pct) || pct <= 0)
        { ToastService.Error("Poné un % de objetivo válido"); return; }
        _savingObjFila.Add(item.Id);
        StateHasChanged();
        try
        {
            var (res, err) = await Api.SetObjetivoGananciaAsync(item.MeliItemId, pct, aplicar: true, redondeo: "99");
            if (err is null && res is not null)
            {
                item.GananciaObjetivoPct = res.ObjetivoPct;
                item.GananciaObjetivoAt = DateTime.UtcNow;
                item.SyncPrecio = res.SyncPrecio;
                if (res.PrecioNuevo.HasValue) item.Price = res.PrecioNuevo.Value;
                _objInput.Remove(item.Id);
                InvalidateFilterCache();
                if (!string.IsNullOrEmpty(res.PushError))
                    ToastService.Warning($"🎯 Objetivo {pct.ToString("0.#", argCulture)}% guardado. (No se pudo pushear ahora: {res.PushError})");
                else
                    ToastService.Success($"🎯 Objetivo {pct.ToString("0.#", argCulture)}% aplicado" + (res.PrecioNuevo.HasValue ? $" → ${res.PrecioNuevo.Value.ToString("N0", argCulture)}" : ""));
            }
            else ToastService.Error("No se pudo: " + (err ?? "error"));
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { _savingObjFila.Remove(item.Id); StateHasChanged(); }
    }

    private async Task AplicarPrecioFila(MeliItemDto item)
    {
        if (_savingPrecioFila.Contains(item.Id)) return;
        _precioInput.TryGetValue(item.Id, out var raw);
        var precio = ParseFormattedPrice(raw ?? "");
        if (precio <= 0) { ToastService.Error("Poné un precio válido"); return; }
        _savingPrecioFila.Add(item.Id);
        StateHasChanged();
        try
        {
            var (res, err) = await Api.PushPrecioAMeliAsync(item.MeliItemId, precio, null);
            if (err is null)
            {
                item.Price = precio;
                var sib = GetCatalogSibling(item);
                if (sib is not null) sib.Price = precio;
                _precioInput.Remove(item.Id);
                InvalidateFilterCache();
                ToastService.Success($"✔ Precio ${precio.ToString("N0", argCulture)} pusheado a MeLi");
            }
            else ToastService.Error("No se pudo pushear: " + err);
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { _savingPrecioFila.Remove(item.Id); StateHasChanged(); }
    }

    private RenderFragment SincroToggle(MeliItemDto item) =>
    @<span style="display:inline-flex; gap:0.3rem; flex-wrap:wrap; align-items:center;">
        @if (item.CafeProductoId.HasValue || item.ComponentMappingsCount > 0)
        {
            var savingP = _savingSincroPrecio.Contains(item.Id);
            var savingS = _savingSincroStock.Contains(item.Id);
            <button @onclick:stopPropagation="true" @onclick="() => ToggleSincroPrecio(item)" disabled="@savingP"
                    title="@(item.SyncPrecio ? "Precio sincronizado: se mantiene con tu objetivo (o el piso sugerido). Click para desactivar." : "Precio manual. Click para ACTIVAR: el sistema mantiene el precio de esta publicación.")"
                    style="margin-top:0.2rem; padding:0.1rem 0.5rem; border-radius:10px; border:none; cursor:pointer; font-size:0.68rem; font-weight:700; background:@(item.SyncPrecio ? "#16a34a" : "#e5e7eb"); color:@(item.SyncPrecio ? "white" : "#4b5563");">
                @(savingP ? "…" : item.SyncPrecio ? "🏷 Precio ON" : "🏷 Precio")
            </button>
            <button @onclick:stopPropagation="true" @onclick="() => ToggleSincroStock(item)" disabled="@savingS"
                    title="@(item.SyncStock ? "Stock sincronizado: se mantiene con el stock del sistema. Click para desactivar." : "Stock manual. Click para ACTIVAR: el sistema mantiene el stock de esta publicación.")"
                    style="margin-top:0.2rem; padding:0.1rem 0.5rem; border-radius:10px; border:none; cursor:pointer; font-size:0.68rem; font-weight:700; background:@(item.SyncStock ? "#0ea5e9" : "#e5e7eb"); color:@(item.SyncStock ? "white" : "#4b5563");">
                @(savingS ? "…" : item.SyncStock ? "📦 Stock ON" : "📦 Stock")
            </button>
        }
    </span>;

    private async Task ToggleSincroPrecio(MeliItemDto item)
    {
        if (_savingSincroPrecio.Contains(item.Id)) return;
        var nuevo = !item.SyncPrecio;
        _savingSincroPrecio.Add(item.Id);
        StateHasChanged();
        try
        {
            var (cfg, err) = await Api.ActualizarSyncConfigAsync(item.MeliItemId, new UpdateSyncConfigRequest
            {
                SyncStock = item.SyncStock,   // no tocar el otro tilde
                SyncPrecio = nuevo,
                AjustePct = item.AjustePct,
                AjusteFijo = item.AjusteFijo,
                AjusteRedondeo = item.AjusteRedondeo
            });
            if (err is null)
            {
                item.SyncPrecio = nuevo;
                InvalidateFilterCache();
                ToastService.Success(nuevo ? "🏷 Sincro de PRECIO activada en esta publicación" : "Sincro de precio desactivada (queda manual)");
            }
            else ToastService.Error("No se pudo guardar: " + err);
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { _savingSincroPrecio.Remove(item.Id); StateHasChanged(); }
    }

