    private async Task AplicarPrecioCalculado()
    {
        var precio = CalcPrecioFinal();
        if (precio is null || selectedItem is null || isPushingCalcPrecio) return;
        isPushingCalcPrecio = true;
        StateHasChanged();
        try
        {
            // 2026-07-02: si el modo es %, mandamos el objetivo para que quede grabado.
            // Si el modo es $, derivamos el % equivalente sobre el costo.
            decimal? objetivoPct = null;
            if (itemProductCost is not null && itemProductCost.TotalCost > 0)
            {
                if (calcGananciaModo == "%") objetivoPct = calcGananciaValor;
                else if (calcGananciaModo == "$") objetivoPct = Math.Round(calcGananciaValor / itemProductCost.TotalCost * 100m, 2);
            }

            var (res, err) = await Api.PushPrecioAMeliAsync(selectedItem.MeliItemId, precio.Value, objetivoPct);
            if (err is null)
            {
                // Mensaje con verificacion del objetivo, cuando aplique.
                string msg = $"✔ Precio ${precio.Value.ToString("N2", argCulture)} pusheado a MeLi";
                if (res?.ObjetivoPct.HasValue == true && res.MargenRealPct.HasValue)
                {
                    var obj = res.ObjetivoPct.Value.ToString("0.#", argCulture);
                    var real = res.MargenRealPct.Value.ToString("0.#", argCulture);
                    if (res.DentroDelUmbral == true)
                        ToastService.Success($"{msg}. 🎯 Objetivo {obj}% cumplido — quedó en {real}%.");
                    else
                        ToastService.Warning($"{msg}. ⚠ Objetivo {obj}% NO cumplido — quedó en {real}% (revisá).");
                }
                else
                {
                    ToastService.Success(msg);
                }
                selectedItem.Price = precio.Value;
                if (objetivoPct.HasValue)
                {
                    selectedItem.GananciaObjetivoPct = objetivoPct.Value;
                    selectedItem.GananciaObjetivoAt = DateTime.UtcNow;
                }
                // 2026-07-02: el backend refrescó SaleFeeAmountReal con el precio nuevo (lo hace GetListingCostsAsync).
                // Actualizo el DTO en memoria para que el chip 🎯 de la grilla se pinte en verde/ámbar sin recargar.
                if (res is not null && res.ComisionTotal > 0)
                {
                    selectedItem.SaleFeeAmountReal = res.ComisionTotal;
                    selectedItem.SaleFeePriceSnapshot = precio.Value;
                    selectedItem.SaleFeeCapturedAt = DateTime.UtcNow;
                }
                var sib = GetCatalogSibling(selectedItem);
                if (sib is not null) sib.Price = precio.Value; // hermanada — MeLi la actualiza sola
                // Refrescar el simulador con el precio nuevo
                isLoadingCosts = true;
                StateHasChanged();
                try { itemCosts = await Api.GetItemCostsAsync(selectedItem.MeliItemId); }
                catch { }
                isLoadingCosts = false;
            }
            else
            {
                ToastService.Error("No se pudo pushear: " + err);
            }
        }
        finally
        {
            isPushingCalcPrecio = false;
            StateHasChanged();
        }
    }

    // 2026-07-13: guarda el % como OBJETIVO de la publicación, prende el tilde de precio y pushea
    // (respetando el piso sugerido). De ahí en más la sincro lo mantiene solo.
    private async Task GuardarObjetivoYMantener()
    {
        if (selectedItem is null || isGuardandoObjetivo || calcGananciaModo != "%") return;
        isGuardandoObjetivo = true;
        StateHasChanged();
        try
        {
            var (res, err) = await Api.SetObjetivoGananciaAsync(selectedItem.MeliItemId, calcGananciaValor, aplicar: true, redondeo: calcRedondeo);
            if (err is null && res is not null)
            {
                selectedItem.GananciaObjetivoPct = res.ObjetivoPct;
                selectedItem.GananciaObjetivoAt = DateTime.UtcNow;
                selectedItem.SyncPrecio = res.SyncPrecio;
                if (res.PrecioNuevo.HasValue) selectedItem.Price = res.PrecioNuevo.Value;
                InvalidateFilterCache();

                if (!string.IsNullOrEmpty(res.PushError))
                    ToastService.Warning($"🎯 Objetivo {calcGananciaValor.ToString("0.#", argCulture)}% guardado y tilde Precio prendido. El precio se mantendrá solo. (No se pudo pushear ahora: {res.PushError})");
                else if (res.PrecioNuevo.HasValue)
                    ToastService.Success($"🎯 Objetivo {calcGananciaValor.ToString("0.#", argCulture)}% guardado. Precio quedó en ${res.PrecioNuevo.Value.ToString("N0", argCulture)} y se mantiene solo.");
                else
                    ToastService.Success($"🎯 Objetivo {calcGananciaValor.ToString("0.#", argCulture)}% guardado. Se mantiene solo.");

                isLoadingCosts = true;
                StateHasChanged();
                try { itemCosts = await Api.GetItemCostsAsync(selectedItem.MeliItemId); }
                catch { }
                isLoadingCosts = false;
            }
            else ToastService.Error("No se pudo guardar el objetivo: " + (err ?? "error"));
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally
        {
            isGuardandoObjetivo = false;
            StateHasChanged();
        }
    }

    private async Task OnTaxPercentageChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        raw = raw.Replace('.', ',');
        if (decimal.TryParse(raw, NumberStyles.Any, argCulture, out var pct))
        {
            taxPercentage = Math.Max(0, Math.Min(100, pct));
        }
        else if (string.IsNullOrWhiteSpace(raw))
        {
            taxPercentage = 0;
        }
        // Save to localStorage per MeLi account
        if (selectedItem is not null)
        {
            var key = $"meli_tax_pct_{selectedItem.MeliAccountId}";
            await JS.InvokeVoidAsync("localStorage.setItem", key, taxPercentage.ToString(CultureInfo.InvariantCulture));
        }
    }

