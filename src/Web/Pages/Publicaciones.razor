@if (showLinkProductModal && linkProductItem is not null)
{
    <div class="modal-overlay" @onclick="CloseLinkProductModal">
        <div class="modal-card" style="max-width: 480px;" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin:0; font-size:1rem;">Vincular a Producto o Combo</h3>
                <button class="modal-close" @onclick="CloseLinkProductModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.8rem; color: #6b7280; margin-bottom: 0.7rem;">
                    Publicacion: <strong>@linkProductItem.MeliItemId</strong>
                </p>

                @* Tabs: Producto / Combo *@
                <div style="display:flex; gap:0.4rem; margin-bottom: 0.8rem;">
                    <button class="btn @(linkTab == "product" ? "btn-primary" : "btn-secondary")" style="font-size:0.85rem; padding:0.4rem 0.8rem;"
                            @onclick='() => linkTab = "product"'>
                        📦 Producto
                    </button>
                    <button class="btn @(linkTab == "combo" ? "btn-primary" : "btn-secondary")" style="font-size:0.85rem; padding:0.4rem 0.8rem;"
                            @onclick='() => linkTab = "combo"'>
                        🎁 Combo
                    </button>
                </div>

                @if (linkTab == "product")
                {
                    @if (allProducts is null || !allProducts.Any())
                    {
                        <p class="text-muted">No hay productos creados. Primero crea un producto.</p>
                    }
                    else
                    {
                        <div class="form-group">
                            <label class="form-label">Buscar producto</label>
                            <input type="text" class="form-input" placeholder="Escribi para filtrar..." @oninput="OnLinkSearchInput" />
                        </div>
                        <div class="link-product-list">
                            @foreach (var scored in GetFilteredProducts())
                            {
                                var prod = scored.Product;
                                var matchType = scored.MatchTag;
                                <button class="link-product-option @(matchType != null ? "link-product-highlighted" : "")" @onclick="() => LinkToProduct(prod.Id)">
                                    <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                                        <span class="link-product-title">@Truncate(prod.Title, 38)</span>
                                        @if (matchType != null)
                                        {
                                            <span class="link-match-tag">@matchType</span>
                                        }
                                    </div>
                                    <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                                        <span class="link-product-meta">$@prod.RetailPrice.ToString("N2") | Stock: @prod.Stock</span>
                                        @if (!string.IsNullOrEmpty(prod.Sku))
                                        {
                                            <span class="link-product-sku">SKU: @prod.Sku</span>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    @* Tab combos *@
                    @if (allCombos is null || !allCombos.Any())
                    {
                        <p class="text-muted">No hay combos creados. Primero crea uno desde la sección Combos.</p>
                    }
                    else
                    {
                        <div class="form-group">
                            <label class="form-label">Buscar combo</label>
                            <input type="text" class="form-input" placeholder="Escribi nombre o SKU..." @oninput="OnLinkComboSearchInput" />
                        </div>
                        <div class="link-product-list">
                            @foreach (var combo in GetFilteredCombos())
                            {
                                <button class="link-product-option" @onclick="() => LinkToCombo(combo.Id)">
                                    <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                                        <span class="link-product-title">@Truncate(combo.Name, 38)</span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                                        <span class="link-product-meta">@combo.Items.Count item(s)</span>
                                        @if (!string.IsNullOrEmpty(combo.Sku))
                                        {
                                            <span class="link-product-sku">SKU: @combo.Sku</span>
                                        }
                                    </div>
