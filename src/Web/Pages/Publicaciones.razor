        bulkGuardando = true;
        bulkPublicarEnMeli = publicarEnMeli;
        StateHasChanged();

        string? redondeo = string.IsNullOrEmpty(bulkAjusteRedondeoOpt) ? null : bulkAjusteRedondeoOpt;

        var req = new ApiClient.BulkPrecioPorGananciaRequest(
            selectedItems.ToList(),
