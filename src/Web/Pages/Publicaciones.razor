    private List<ComboDto> GetFilteredCombos()
    {
        if (allCombos is null) return new();
        var search = linkComboSearch.Trim().ToLowerInvariant();
        var itemSku = linkProductItem?.Sku?.Trim().ToLowerInvariant() ?? "";
        IEnumerable<ComboDto> combos = allCombos;
        if (!string.IsNullOrEmpty(search))
        {
            combos = combos.Where(c =>
                (c.Name ?? "").ToLowerInvariant().Contains(search) ||
                (c.Sku ?? "").ToLowerInvariant().Contains(search));
        }
        else if (!string.IsNullOrEmpty(itemSku))
        {
            // Sin busqueda: priorizar match exacto por SKU del item arriba
            combos = combos.OrderByDescending(c => (c.Sku ?? "").ToLowerInvariant() == itemSku);
        }
        return combos.Take(50).ToList();
    }

    private async Task LinkToCombo(int comboId)
    {
        if (linkProductItem is null) return;
        try
        {
            var updated = await Api.LinkItemToComboAsync(linkProductItem.MeliItemId, comboId);
            if (updated is not null && items is not null)
            {
                var idx = items.FindIndex(i => i.Id == linkProductItem.Id);
                if (idx >= 0) items[idx] = updated;
                InvalidateFilterCache();
            }
            ToastService.Success("Publicacion vinculada al combo");
            CloseLinkProductModal();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
    }

    private record ScoredProduct(ProductDto Product, int Score, string? MatchTag);

    private List<ScoredProduct> GetFilteredProducts()
    {
        if (allProducts is null) return new();

        var itemTitle = linkProductItem?.Title ?? "";
        var itemSku = linkProductItem?.Sku?.Trim();
        var itemUserProductId = linkProductItem?.UserProductId?.Trim();
        var searchTerm = linkSearchTerm?.Trim() ?? "";

        // Palabras del titulo de la publicacion (ignorar palabras cortas)
        var titleWords = itemTitle
            .Split(new[] { ' ', '-', '/', '|', ',', '(', ')' }, StringSplitOptions.RemoveEmptyEntries)
            .Where(w => w.Length >= 3)
            .Select(w => w.ToLowerInvariant())
            .Distinct()
            .ToList();

        var results = new List<ScoredProduct>();

        foreach (var p in allProducts)
        {
            int score = 0;
            string? matchTag = null;

            // 1. SKU exacto de la publicacion coincide con SKU del producto (maximo peso)
            if (!string.IsNullOrEmpty(itemSku) && !string.IsNullOrEmpty(p.Sku)
                && string.Equals(itemSku, p.Sku.Trim(), StringComparison.OrdinalIgnoreCase))
            {
                score += 1000;
                matchTag = "SKU exacto";
            }

            // 2. UserProductId coincide con SKU del producto
            if (!string.IsNullOrEmpty(itemUserProductId) && !string.IsNullOrEmpty(p.Sku)
                && string.Equals(itemUserProductId, p.Sku.Trim(), StringComparison.OrdinalIgnoreCase))
            {
                score += 800;
                matchTag ??= "ID producto";
            }

            // 3. SKU parcial (uno contiene al otro)
            if (!string.IsNullOrEmpty(itemSku) && !string.IsNullOrEmpty(p.Sku))
            {
                var pSku = p.Sku.Trim();
                if (pSku.Contains(itemSku, StringComparison.OrdinalIgnoreCase)
                    || itemSku.Contains(pSku, StringComparison.OrdinalIgnoreCase))
                {
                    score += 500;
                    matchTag ??= "SKU similar";
                }
            }

            // 4. Coincidencia de palabras del titulo
            var pTitle = p.Title.ToLowerInvariant();
            int wordMatches = titleWords.Count(w => pTitle.Contains(w));
            if (wordMatches > 0)
            {
                score += wordMatches * 50;
                if (wordMatches >= 3 && matchTag is null)
                    matchTag = $"{wordMatches} palabras";
            }

            // 5. Coincidencia con marca/modelo
            if (!string.IsNullOrEmpty(p.Brand) && itemTitle.Contains(p.Brand, StringComparison.OrdinalIgnoreCase))
                score += 100;
            if (!string.IsNullOrEmpty(p.Model) && itemTitle.Contains(p.Model, StringComparison.OrdinalIgnoreCase))
                score += 100;

            // Filtro por texto de busqueda manual
            if (!string.IsNullOrEmpty(searchTerm))
            {
                bool matchesSearch = p.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                    || (p.Brand ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                    || (p.Model ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                    || (p.Sku ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase);
                if (!matchesSearch) continue;
            }

            results.Add(new ScoredProduct(p, score, matchTag));
        }

        return results.OrderByDescending(r => r.Score).ThenBy(r => r.Product.Title).ToList();
    }

