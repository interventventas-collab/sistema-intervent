    private bool isPropagandoFicha;

    private async Task PropagarAjusteDesdeFicha()
    {
        if (selectedItem is null || isPropagandoFicha) return;
        isPropagandoFicha = true;
        StateHasChanged();
        try
        {
            var cantidad = await Api.PropagarAjusteAFamiliaAsync(selectedItem.Id);
