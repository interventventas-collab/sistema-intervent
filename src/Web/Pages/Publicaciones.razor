    // Modelo de comisión para la vista previa local (mismo criterio que CalcMargenPct: usa el sale_fee real cacheado
    // si el precio no se movió, si no cae al 30% estimado). Así el preview coincide con el margen que muestra la fila.
    private (decimal commPct, decimal shipping, bool exact) FeeModelPreview(MeliItemDto item)
    {
        if (item.SaleFeeAmountReal.HasValue && item.SaleFeeAmountReal.Value > 0
            && item.SaleFeePriceSnapshot.HasValue && item.SaleFeePriceSnapshot.Value > 0)
        {
            var commPct = item.SaleFeeAmountReal.Value / item.SaleFeePriceSnapshot.Value;
            return (commPct, item.SaleFeeShippingCost ?? 0m, true);
        }
        return (0.30m, 0m, false);
    }

    // Margen % que daría este item a un precio dado (para el preview del modo "Por precio $").
    private decimal? PreviewMarginPctAt(MeliItemDto item, decimal price)
    {
        if (!item.ProductCost.HasValue || item.ProductCost.Value <= 0 || price <= 0) return null;
        var (commPct, shipping, _) = FeeModelPreview(item);
        var netoConIva = price * (1m - commPct) - shipping;
        var netoSinIva = netoConIva / (1m + IvaAlicuota);
        return (netoSinIva - item.ProductCost.Value) / item.ProductCost.Value * 100m;
    }

    // Precio que haría falta para lograr un margen objetivo (para el preview del modo "Por margen %").
    private decimal? PreviewPriceForMargin(MeliItemDto item, decimal targetPct)
    {
        if (!item.ProductCost.HasValue || item.ProductCost.Value <= 0) return null;
        var (commPct, shipping, _) = FeeModelPreview(item);
        if (commPct >= 1m) return null;
        var netoSinIva = item.ProductCost.Value * (1m + targetPct / 100m);
        var netoConIva = netoSinIva * (1m + IvaAlicuota);
        return (netoConIva + shipping) / (1m - commPct);
    }

    // Color del badge de margen en la vista Lista: verde >=50%, ámbar 20-49%, rojo <20% (criterio del rediseño).
    private (string bg, string fg) BadgeMargenColor(decimal pct)
    {
        if (pct >= 50m) return ("#dcfce7", "#166534");
        if (pct >= 20m) return ("#fef3c7", "#92400e");
        return ("#fee2e2", "#991b1b");
    }
    // Color vivo (para la barrita) y emoji de estado del margen.
    private string MargenColorSolid(decimal pct) => pct >= 50m ? "#16a34a" : pct >= 20m ? "#f59e0b" : "#dc2626";
    private string MargenEstadoEmoji(decimal pct) => pct >= 50m ? "🟢" : pct >= 20m ? "🟡" : "🔴";
    // Ancho de la barrita (0-100%): 80% de margen = barra llena; mínimo 5% para que siempre se vea algo.
    private string MargenMeterWidth(decimal pct)
    {
        var w = pct <= 0m ? 5m : Math.Min(100m, Math.Max(5m, pct / 80m * 100m));
        return w.ToString("0", CultureInfo.InvariantCulture);
    }

    private async Task CambiarStatus(string? nuevoStatus)
    {
        if (statusFilter == nuevoStatus) return;
        statusFilter = nuevoStatus;
        InvalidateFilterCache();
        await LoadItems();
    }
    // 2026-06-01: filtros de margen (peor primero, para arreglarlas)
    private bool filterMargenPerdida = false;          // 🔴 margen ≤ 0% (pérdida)
    private bool filterMargenBajo = false;             // 🟠 margen 0-15% (bajo)
    // 2026-07-18: filtro por rango de margen a elección (Osmar). Vacío = sin filtro.
    private string filterMargenDesde = "";
    private string filterMargenHasta = "";
    private decimal? ParseMargenFiltro(string s) =>
        decimal.TryParse((s ?? "").Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out var v) ? v : (decimal?)null;
    private bool FilterMargenRangoActivo() => ParseMargenFiltro(filterMargenDesde).HasValue || ParseMargenFiltro(filterMargenHasta).HasValue;

    // 2026-07-18: "no sacar del listado lo que arreglo". Con un filtro activo, las publicaciones que ya se
    // mostraron quedan pinneadas y siguen visibles aunque un cambio (arreglar margen, etc.) las saque del
    // filtro. Se limpian al CAMBIAR el filtro o al recargar la página (el estado vive en el componente).
    private readonly HashSet<int> _pinnedInView = new();
