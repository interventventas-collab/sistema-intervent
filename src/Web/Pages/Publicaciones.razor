        return (aj.DeltaPct.HasValue && aj.DeltaPct.Value != 0)
            || (aj.DeltaPesos.HasValue && aj.DeltaPesos.Value != 0)
            || !string.IsNullOrEmpty(aj.Redondeo);
    }

