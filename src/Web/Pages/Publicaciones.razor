    // Arma un texto legible del desglose de infracciones por tipo (filter_subgroup de MeLi).
    private static string DesgloseInfracciones(Dictionary<string, int> breakdown)
    {
        if (breakdown is null || breakdown.Count == 0) return "sin detalle";
        static string Etiqueta(string sub) => sub.ToUpperInvariant() switch
        {
            "CATALOG" => "Catálogo",
            "QUALITY" => "Calidad",
            "PRICING" or "PRICE" => "Precios",
            "LISTING" => "Publicación",
            _ => sub
        };
        return string.Join(", ", breakdown.OrderByDescending(kv => kv.Value).Select(kv => $"{Etiqueta(kv.Key)}: {kv.Value}"));
    }

    private async Task DiagnosticarFotos(MeliItemDto item)
    {
        photosDiagnosing = true;
        StateHasChanged();
        try
        {
            foreach (var p in photosEdit)
            {
                // Solo se pueden diagnosticar fotos que ya están en MeLi (Id) o tienen URL pública (Source).
                var pref = !string.IsNullOrEmpty(p.Id) ? p.Id : (!string.IsNullOrEmpty(p.Source) ? p.Source : null);
                if (pref is null) { p.Problem = null; continue; }
                try
                {
                    var diag = await Api.DiagnosePictureAsync(item.MeliItemId, pref);
                    p.Problem = (diag is not null && diag.HasIssues) ? string.Join(" · ", diag.Issues) : null;
                }
                catch { p.Problem = null; }
                StateHasChanged();
            }
        }
        finally
        {
            photosDiagnosing = false;
            StateHasChanged();
            var conProblema = photosEdit.Count(x => !string.IsNullOrEmpty(x.Problem));
            if (conProblema > 0) ToastService.Warning($"⚠️ {conProblema} foto(s) con problemas. Las marqué en rojo con el motivo.");
