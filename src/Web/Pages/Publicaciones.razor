    // ─────────────────────────────────────────────────────────────────────
    // Ajustes de precio por fila (Contabilium-style). Inputs independientes:
    //   - DeltaPct (%):    suma/resta porcentaje sobre el precio base
    //   - DeltaPesos ($):  suma/resta pesos directos
    //   - Redondeo:        terminación al redondear hacia arriba (— / 99 / 999 / 000)
    // Si se llenan los 2, se aplican AMBOS efectos (igual que Contabilium).
    // Orden: base → +pct → +pesos → redondeo.
    // ─────────────────────────────────────────────────────────────────────
    public class AjustePrecio
    {
        public decimal? DeltaPct { get; set; }      // ej: 10 = +10%
        public decimal? DeltaPesos { get; set; }    // ej: 315 = +$315 (puede ser negativo)
        public string Redondeo { get; set; } = "";  // "" / "99" / "999" / "000"
    }

    private Dictionary<int, AjustePrecio> ajustesPrecio = new();

    /// <summary>Devuelve el ajuste de la fila. Si todavía no está en memoria, lo hidrata desde
    /// los campos del DTO (que ya vienen poblados desde MeliItem_SyncConfig).
    /// 2026-05-29: ahora lee de los campos unificados AjustePct/AjusteFijo/AjusteRedondeo.</summary>
    private AjustePrecio GetAjuste(MeliItemDto item)
    {
        if (!ajustesPrecio.TryGetValue(item.Id, out var a))
        {
            a = new AjustePrecio
            {
                DeltaPct = item.AjustePct != 0 ? item.AjustePct : (decimal?)null,
                DeltaPesos = item.AjusteFijo != 0 ? item.AjusteFijo : (decimal?)null,
                Redondeo = item.AjusteRedondeo ?? ""
            };
            ajustesPrecio[item.Id] = a;
        }
        return a;
    }

    /// <summary>2026-05-29: persistir el ajuste en MeliItem_SyncConfig (tabla unificada).
    /// Usa el endpoint Sincro existente (ActualizarSyncConfigAsync), respetando SyncStock/SyncPrecio actuales.</summary>
    private async Task SaveAjusteToDb(MeliItemDto item)
    {
        var aj = GetAjuste(item);
        try
        {
            var (cfg, err) = await Api.ActualizarSyncConfigAsync(item.MeliItemId, new UpdateSyncConfigRequest
            {
                SyncStock = item.SyncStock,
                SyncPrecio = item.SyncPrecio,
                AjustePct = aj.DeltaPct ?? 0m,
                AjusteFijo = aj.DeltaPesos ?? 0m,
                AjusteRedondeo = string.IsNullOrEmpty(aj.Redondeo) ? null : aj.Redondeo
            });
            if (cfg is null)
            {
                ToastService.Error("No se pudo guardar el ajuste: " + (err ?? "Error"));
                return;
            }
            // Refrescar el DTO en memoria con lo que devolvió el server (para que siga consistente al re-render).
            item.AjustePct = cfg.AjustePct;
            item.AjusteFijo = cfg.AjusteFijo;
            item.AjusteRedondeo = cfg.AjusteRedondeo;
            item.SyncStock = cfg.SyncStock;
            item.SyncPrecio = cfg.SyncPrecio;
        }
        catch (Exception ex)
        {
            ToastService.Error($"No se pudo guardar el ajuste: {ex.Message}");
        }
    }

    /// <summary>Calcula el precio final que debería ir a MeLi aplicando %, $ y redondeo.
    /// Devuelve null si NO hay ningún ajuste cargado (backend usa el precio del sistema).</summary>
    private decimal? CalcularPrecioConAjuste(MeliItemDto item)
    {
        var aj = GetAjuste(item);
        bool hayPct = aj.DeltaPct.HasValue && aj.DeltaPct.Value != 0;
        bool hayPesos = aj.DeltaPesos.HasValue && aj.DeltaPesos.Value != 0;
        bool hayRedondeo = !string.IsNullOrEmpty(aj.Redondeo);
        if (!hayPct && !hayPesos && !hayRedondeo) return null;

        // 2026-05-29: preferimos PrecioOtroConIvaCalc (sistema) sobre item.Price (cache MeLi)
        // para que el preview cuadre con el cálculo del backend al pushear.
        decimal baseP = item.PrecioOtroConIvaCalc ?? item.Price;
        if (baseP <= 0) return null;

        // 1) Aplicar % sobre el base
        decimal conPct = baseP;
        if (hayPct) conPct = baseP * (1m + aj.DeltaPct!.Value / 100m);

        // 2) Aplicar $ encima del resultado
        decimal conPesos = conPct;
        if (hayPesos) conPesos = conPct + aj.DeltaPesos!.Value;

        // 3) Aplicar redondeo (siempre hacia arriba — no le baja al usuario sin querer)
        decimal final = conPesos;
        if (hayRedondeo)
        {
            int term = aj.Redondeo switch { "99" => 99, "999" => 999, "000" => 0, _ => -1 };
            int step = aj.Redondeo switch { "99" => 100, "999" => 1000, "000" => 1000, _ => 1 };
            if (step > 1)
            {
                int conPesosInt = (int)Math.Ceiling(conPesos);
                // Buscar el siguiente número >= conPesos que cumpla "termina en term" módulo step.
                int siguiente;
                if (conPesosInt % step == term && conPesosInt >= conPesos)
                    siguiente = conPesosInt;
                else
                {
                    siguiente = ((conPesosInt - term + step - 1) / step) * step + term;
                    if (siguiente < conPesos) siguiente += step;
                }
                final = siguiente;
            }
        }
        return Math.Round(final, 2, MidpointRounding.AwayFromZero);
    }

    private string PreviewPrecioAjustado(MeliItemDto item)
