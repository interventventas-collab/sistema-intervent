@* Sync Progress Modal *@
@if (SyncProgress.State.IsActive && SyncProgress.State.ShowModal)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <div class="modal-header">
                <h3><i class="fa-solid fa-arrows-rotate"></i> Sincronizando publicaciones</h3>
            </div>
            <div class="modal-body">
                @if (SyncProgress.State.Status == "running")
                {
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                            <span style="font-weight: 600;">@SyncProgress.State.CurrentStep</span>
                            <span style="color: #666;">@SyncProgress.State.Percentage%</span>
                        </div>
                        <div class="sync-progress-bar-container">
                            <div class="sync-progress-bar-fill" style="width: @(SyncProgress.State.Percentage)%"></div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(SyncProgress.State.CurrentAccount))
                    {
                        <div class="sync-progress-detail">
                            <div class="sync-detail-row">
                                <span><i class="fa-solid fa-user"></i> Cuenta:</span>
                                <strong>@SyncProgress.State.CurrentAccount</strong>
                                @if (SyncProgress.State.TotalAccounts > 0)
                                {
                                    <span class="sync-detail-badge">@SyncProgress.State.AccountIndex / @SyncProgress.State.TotalAccounts</span>
                                }
                            </div>
                        </div>
                    }
                    <div class="sync-progress-detail">
                        <div class="sync-detail-row">
                            <span><i class="fa-solid fa-box"></i> Publicaciones encontradas:</span>
                            <strong>@SyncProgress.State.TotalItemsFound</strong>
                        </div>
                        <div class="sync-detail-row">
                            <span><i class="fa-solid fa-circle-check"></i> Sincronizadas:</span>
                            <strong>@SyncProgress.State.ItemsSynced</strong>
                        </div>
                        @if (SyncProgress.State.TotalErrors > 0)
                        {
                            <div class="sync-detail-row" style="color: #dc3545;">
                                <span><i class="fa-solid fa-circle-xmark"></i> Errores:</span>
                                <strong>@SyncProgress.State.TotalErrors</strong>
                            </div>
                        }
                    </div>
                }
                else if (SyncProgress.State.Status == "completed")
                {
                    <div style="text-align: center; padding: 1rem 0;">
                        <div style="font-size: 2.5rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-circle-check"></i></div>
                        <h4 style="margin: 0 0 0.5rem;">Sincronizacion completada</h4>
                        <p style="color: #666; margin: 0;">
                            @SyncProgress.State.ItemsSynced publicaciones sincronizadas
                            @if (SyncProgress.State.TotalErrors > 0)
                            {
                                <span style="color: #dc3545;"> con @SyncProgress.State.TotalErrors errores</span>
                            }
                        </p>
                    </div>
                }
                else if (SyncProgress.State.Status == "error")
                {
                    <div style="text-align: center; padding: 1rem 0;">
                        <div style="font-size: 2.5rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-circle-xmark"></i></div>
                        <h4 style="margin: 0 0 0.5rem;">Error en la sincronizacion</h4>
                        <p style="color: #dc3545; margin: 0;">@SyncProgress.State.CurrentStep</p>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (SyncProgress.State.Status == "running")
                {
                    <button class="btn btn-secondary" @onclick="SendSyncToBackground">
                        Ejecutar en segundo plano
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="CloseSyncProgressModal">
                        Cerrar
                    </button>
                }
            </div>
        </div>
    </div>
}

@* Modal de confirmacion para Push a MeLi *@
@if (showPushModal && pushItem is not null)
{
    <div class="modal-overlay" @onclick="ClosePushModal">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #fef3c7;">
                <h3 style="margin: 0;">📤 Push a MercadoLibre</h3>
                <button class="btn-close" @onclick="ClosePushModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; margin: 0 0 0.7rem;">
                    Vas a actualizar la publicación <strong>@pushItem.MeliItemId</strong> con los datos del @(pushItem.ComboId.HasValue ? "combo" : "producto") vinculado.
                </p>
                @if (pushItem.ComboId.HasValue)
                {
                    <div style="background:#fef3c7; border:1px solid #fbbf24; border-radius:6px; padding:0.7rem; margin-bottom:0.7rem;">
                        <div style="font-size:0.8rem; color:#92400e; margin-bottom:0.3rem;">🎁 Combo vinculado:</div>
                        <div style="font-weight:700;">@pushItem.ComboName</div>
                        <div style="font-size:0.8rem; color:#374151;">SKU: <strong>@pushItem.ComboSku</strong></div>
                        <div style="font-size:0.75rem; color:#6b7280; margin-top:0.3rem;">
                            El precio se calcula segun el modo del combo (manual / auto / ajuste %) y el stock es el minimo disponible considerando los items.
                        </div>
                    </div>
                }
                @if (pushItemProduct is not null)
                {
                    <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; padding:0.7rem; margin-bottom:0.7rem;">
                        <div style="font-size:0.8rem; color:#6b7280; margin-bottom:0.3rem;">Producto vinculado:</div>
                        <div style="font-weight:700;">@pushItemProduct.Title</div>
                        <div style="font-size:0.8rem; color:#374151;">SKU: <strong>@pushItemProduct.Sku</strong></div>
                    </div>

                    <div class="form-group">
                        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-weight:600;">
                            <input type="checkbox" @bind="pushFlagPrice" style="width:18px; height:18px;" />
                            Actualizar precio
                        </label>
                        @if (pushFlagPrice)
                        {
                            var rate = pushItemProduct.VatRate ?? 0m;
                            var pvpConIva = rate > 0m
                                ? Math.Round(pushItemProduct.RetailPrice * (1m + rate / 100m), 2)
                                : pushItemProduct.RetailPrice;
                            <div style="margin-left: 1.7rem; font-size:0.82rem; color:#374151;">
                                Antes en MeLi: <strong>$@pushItem.Price.ToString("N2")</strong> →
                                Ahora: <strong style="color:#15803d;">$@pvpConIva.ToString("N2")</strong>
                                (PVP s/IVA $@pushItemProduct.RetailPrice.ToString("N2") + IVA @(rate.ToString("0.##"))%)
                            </div>
                        }
                    </div>

                    <div class="form-group" style="margin-top: 0.6rem;">
                        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-weight:600;">
                            <input type="checkbox" @bind="pushFlagStock" style="width:18px; height:18px;" />
                            Actualizar stock
                        </label>
                        @if (pushFlagStock)
                        {
                            <div style="margin-left: 1.7rem; font-size:0.82rem; color:#374151;">
                                Antes en MeLi: <strong>@pushItem.AvailableQuantity</strong> →
                                Ahora: <strong style="color:#15803d;">@pushItemProduct.Stock</strong>
                            </div>
                        }
                    </div>
                }
                @if (pushItem.ComboId.HasValue)
                {
                    @* Para combos no precalculamos el preview en el front. El backend calcula precio + stock. *@
                    <div class="form-group">
                        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-weight:600;">
                            <input type="checkbox" @bind="pushFlagPrice" style="width:18px; height:18px;" />
                            Actualizar precio del combo
                        </label>
                    </div>
                    <div class="form-group" style="margin-top: 0.6rem;">
                        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-weight:600;">
                            <input type="checkbox" @bind="pushFlagStock" style="width:18px; height:18px;" />
                            Actualizar stock del combo
                        </label>
                        <div style="margin-left: 1.7rem; font-size:0.78rem; color:#6b7280;">
                            Stock del combo = mínimo de (stock_item / cantidad_necesaria) entre los items.
                        </div>
                    </div>
                }
                <p style="font-size: 0.75rem; color: #6b7280; margin-top: 0.7rem; margin-bottom: 0;">
                    El cambio puede tardar unos segundos en reflejarse en la publicación pública de MeLi.
                </p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="ClosePushModal" disabled="@isPushing">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmPush" disabled="@(isPushing || (!pushFlagPrice && !pushFlagStock))"
                        style="background:#f59e0b; border-color:#f59e0b;">
                    @(isPushing ? "Enviando..." : "📤 Push a MeLi")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<MeliItemDto>? items;
    private bool isLoading = true;
    private bool isSyncing;
    private int totalItems;
    private List<MeliItemDto>? _cachedFiltered;
    private bool _filterDirty = true;
    private string syncingLabel = "Sincronizando...";

    // Sync dropdown
    private bool showSyncMenu;
    private List<MeliAccountDto>? meliAccounts;

    // Sync by ID modal
    private bool showSyncByIdModal;
    private string syncByIdInput = string.Empty;
    private string? syncByIdError;
    private bool isSyncingById;
    private MeliItemSyncByIdBatchResult? syncByIdResults;

    // View mode
    private string viewMode = "flat";
    private bool filterPromo = false;
    private bool filterNoProduct = false;
    private bool showMoreFilters = false;

    // Selection & bulk actions
    private HashSet<int> selectedItems = new();
    private bool showDeleteModal;
    private bool isDeleting;

    // Bulk create products
    private bool showBulkCreateModal;
    private bool isBulkCreating;
    private int bulkCreateTotal;
    private int bulkCreateCurrent;
    private int bulkCreateCreated;
    private int bulkCreateSkipped;
    private List<string> bulkCreateErrors = new();

    // Product linking
    private bool showCreateProductModal;
    private MeliItemDto? createProductItem;

    // Push a MeLi: confirmacion + flags
    private bool showPushModal;
    private MeliItemDto? pushItem;
    private ProductDto? pushItemProduct; // Producto vinculado, para mostrar en preview
    private bool pushFlagPrice = true;
    private bool pushFlagStock = true;
    private bool isPushing;
    private string newProductTitle = "";
    private string newProductDescription = "";
    private string newProductBrand = "";
    private string newProductModel = "";
    private decimal newProductCostPrice;
    private decimal newProductRetailPrice;
    private int newProductStock;
    private bool isCreatingProduct;
    private string newProductSku = "";
    private string newProductPhoto1 = "";
    private string newProductPhoto2 = "";
    private string newProductPhoto3 = "";
    private bool isLoadingDetails;
    private string newProductCostPriceFormatted = "";
    private string newProductRetailPriceFormatted = "";
    private bool showLinkProductModal;
    private MeliItemDto? linkProductItem;
    private List<ProductDto>? allProducts;
    // Modal de vincular ahora soporta Productos y Combos
    private string linkTab = "product"; // "product" o "combo"
    private List<ComboDto>? allCombos;
    private string linkComboSearch = "";
    private string linkSearchTerm = "";

    private void TogglePromoFilter()
    {
        filterPromo = !filterPromo;
        InvalidateFilterCache();
    }

    private void ToggleNoProductFilter()
    {
        filterNoProduct = !filterNoProduct;
        InvalidateFilterCache();
    }

    private void ToggleMoreFilters() { showMoreFilters = !showMoreFilters; }

    private int GetActiveFilterCount()
    {
        int count = 0;
        if (filterPromo) count++;
        if (filterNoProduct) count++;
        return count;
    }

    // Sort state
    private string? sortColumn;
    private bool sortAsc = true;

    // Text filter state
    private Dictionary<string, string> textFilters = new();

    // Checkbox filter state
    private string? activeFilterColumn;
    private Dictionary<string, HashSet<string>> checkboxFilters = new()
    {
        ["estado"] = new HashSet<string> { "Activa" }
    };

    protected override async Task OnInitializedAsync()
    {
        SyncProgress.OnChange += OnSyncProgressChanged;
        await LoadItems();
        try { meliAccounts = await Api.GetMeliAccountsAsync(); } catch { }
    }

    private bool _syncReloaded;

    private void OnSyncProgressChanged()
    {
        InvokeAsync(async () =>
        {
            // Auto-reload items once when sync finishes
            if (!_syncReloaded && (SyncProgress.State.Status == "completed" || SyncProgress.State.Status == "error"))
            {
                _syncReloaded = true;
                await LoadItems();
                StateHasChanged();
            }
            else
            {
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        SyncProgress.OnChange -= OnSyncProgressChanged;
    }

    private async Task LoadItems()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Api.GetMeliItemsAsync();
            if (response is not null)
            {
                items = response.Items;
                totalItems = response.Total;
                InvalidateFilterCache();
            }
        }
        catch
        {
            ToastService.Error("Error al cargar las publicaciones");
            items = new();
        }

        isLoading = false;
        StateHasChanged();
    }

    private void ToggleSyncMenu()
    {
        showSyncMenu = !showSyncMenu;
    }

    private async Task SyncItems(string? status, int? accountId)
    {
        showSyncMenu = false;
        isSyncing = true;

        // Build descriptive label
        string description;
        if (status is not null)
        {
            syncingLabel = $"Sincronizando {GetStatusLabel(status)}s...";
            description = $"Sincronizando publicaciones {GetStatusLabel(status)}s";
        }
        else if (accountId.HasValue && meliAccounts is not null)
        {
            var acc = meliAccounts.FirstOrDefault(a => a.Id == accountId.Value);
            syncingLabel = $"Sincronizando {acc?.Nickname ?? "cuenta"}...";
            description = $"Sincronizando publicaciones de {acc?.Nickname ?? "cuenta"}";
        }
        else
        {
            syncingLabel = "Sincronizando todo...";
            description = "Sincronizando todas las publicaciones";
        }

        StateHasChanged();

        try
        {
            var result = await Api.SyncMeliItemsAsync(status, accountId);
            if (result is not null && !string.IsNullOrEmpty(result.ProgressId))
            {
                // Start progress tracking - sync runs in background on API
                _syncReloaded = false;
                SyncProgress.StartTracking(result.ProgressId, description);
            }
            else
            {
                ToastService.Error("No se pudo iniciar la sincronizacion");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al sincronizar: " + ex.Message);
        }

        isSyncing = false;
    }

    private void OpenSyncByIdModal()
    {
        showSyncMenu = false;
        syncByIdInput = string.Empty;
        syncByIdError = null;
        syncByIdResults = null;
        showSyncByIdModal = true;
    }

    private void CloseSyncByIdModal()
    {
        if (isSyncingById) return;
        showSyncByIdModal = false;
        syncByIdInput = string.Empty;
        syncByIdError = null;
        syncByIdResults = null;
    }

    private async Task ConfirmSyncById()
    {
        var input = (syncByIdInput ?? "").Trim();
        if (string.IsNullOrEmpty(input))
        {
            syncByIdError = "Ingresa al menos un ID.";
            return;
        }

        isSyncingById = true;
        syncByIdError = null;
        syncByIdResults = null;
        StateHasChanged();

        var (result, error) = await Api.SyncMeliItemByIdAsync(input);

        isSyncingById = false;

        if (result is not null)
        {
            syncByIdResults = result;
            if (result.TotalSynced > 0)
            {
                var msg = result.TotalErrors == 0
                    ? $"{result.TotalSynced} publicacion(es) traidas correctamente."
                    : $"{result.TotalSynced} traidas, {result.TotalErrors} con error.";
                ToastService.Success(msg);
                await LoadItems();
            }
            else
            {
                ToastService.Error($"Ninguna publicacion pudo traerse ({result.TotalErrors} error(es)).");
            }
            StateHasChanged();
        }
        else
        {
            syncByIdError = error ?? "No se pudieron traer las publicaciones.";
            StateHasChanged();
        }
    }

    private void SendSyncToBackground()
    {
        SyncProgress.SendToBackground();
    }

    private async Task CloseSyncProgressModal()
    {
        SyncProgress.Dismiss();
        await LoadItems();
    }

    // --- Sort ---
    private void ToggleSort(string column)
    {
        activeFilterColumn = null; // Cerrar dropdown de filtro al ordenar
        if (sortColumn == column)
