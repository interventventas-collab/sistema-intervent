            photoInfractions = res.Items.Where(x => x.PhotoRelated)
                                        .GroupBy(x => x.MeliItemId)
                                        .ToDictionary(g => g.Key, g => g.First());
            InvalidateFilterCache();
            if (photoInfractions.Count > 0)
