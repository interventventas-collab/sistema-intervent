    private static decimal? ParseNumericOrNull(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        var clean = value.Replace(",", ".");
        return decimal.TryParse(clean, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : null;
    }

    /// <summary>2026-06-03: toggle del checkbox de una variante hija para el push masivo.</summary>
    private void ToggleSelectFamilyChild(int itemId)
    {
        if (selectedFamilyPush.Contains(itemId)) selectedFamilyPush.Remove(itemId);
        else selectedFamilyPush.Add(itemId);
        StateHasChanged();
    }

    /// <summary>2026-06-03: tildar/destildar todas las variantes de una familia de una vez.</summary>
    private void ToggleSelectAllFamilyChildren(GroupedRow grp, bool all)
    {
        if (all)
        {
            foreach (var v in grp.Variants) selectedFamilyPush.Add(v.Id);
        }
        else
        {
            foreach (var v in grp.Variants) selectedFamilyPush.Remove(v.Id);
        }
        StateHasChanged();
    }

    /// <summary>2026-06-03: pushea precio a MeLi de todas las variantes tildadas de la familia.
    /// Las hace en serie (no paralelo) para no saturar la API de MeLi. Toast con el resumen al final.</summary>
    private async Task PushPrecioSeleccionadas(GroupedRow grp)
    {
        var ids = grp.Variants.Where(v => selectedFamilyPush.Contains(v.Id)).Select(v => v.Id).ToList();
        if (ids.Count == 0) return;
        pushingSeleccionadas = true;
        StateHasChanged();
        int ok = 0, err = 0;
        var errores = new List<string>();
        foreach (var id in ids)
        {
            try
            {
                var r = await Api.PushPrecioAjustadoAsync(id);
                if (r?.Success == true) ok++;
                else { err++; errores.Add(r?.Message ?? "Error"); }
            }
            catch (Exception ex) { err++; errores.Add(ex.Message); }
        }
        pushingSeleccionadas = false;
        // Sacar las que se pushearon con exito del set de seleccionadas (para que el contador baje)
        if (ok > 0)
        {
            foreach (var v in grp.Variants.Where(v => selectedFamilyPush.Contains(v.Id)).ToList())
                selectedFamilyPush.Remove(v.Id);
        }
        if (err == 0) ToastService.Success($"✅ {ok} publicaciones pusheadas a MeLi");
        else ToastService.Error($"{ok} OK, {err} fallaron. Primer error: {errores.FirstOrDefault()}");
        StateHasChanged();
    }

    /// <summary>2026-06-03: copia el ajuste actual de la publicacion padre (% / $ / redondeo) a TODAS
    /// las MLAs hermanas que comparten el mismo FamilyId. No hace push — solo guarda en DB.
    /// El usuario despues pushea cada una individualmente con el boton 💵.</summary>
    private async Task PropagarAjusteAFamilia(MeliItemDto item, GroupedRow grp)
    {
        try
        {
            var cantidad = await Api.PropagarAjusteAFamiliaAsync(item.Id);
            ToastService.Success($"Ajuste copiado a {cantidad} publicaciones hermanas de la familia. Pusheá cada una con 💵 cuando quieras.");
            // Actualizar el DTO local de las variantes para que reflejen el nuevo ajuste (sin recargar todo)
            var aj = GetAjuste(item);
            foreach (var v in grp.Variants)
            {
                if (v.Id == item.Id) continue;
                v.AjustePct = aj.DeltaPct ?? 0m;
                v.AjusteFijo = aj.DeltaPesos ?? 0m;
                v.AjusteRedondeo = string.IsNullOrEmpty(aj.Redondeo) ? null : aj.Redondeo;
                // Refrescar el cache de ajustes para que la UI muestre el nuevo valor cuando se expanda la fila
                if (ajustesPrecio.ContainsKey(v.Id)) ajustesPrecio.Remove(v.Id);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.Error("No se pudo propagar: " + ex.Message);
        }
    }

    private async Task DoQuickPush(MeliItemDto item, bool pushPrice, bool pushStock, string what, decimal? overridePrice = null)
    {
        if (item.ProductId is null && item.ComboId is null && item.CafeProductoId is null && item.ComponentMappingsCount == 0)
        {
            ToastService.Error("Esta publicación no tiene producto vinculado.");
            return;
        }
        try
        {
            var result = await Api.PushMeliItemFromProductAsync(item.Id, pushPrice, pushStock, overridePrice);
            if (result is not null && result.Success)
            {
                ToastService.Success($"✓ {what} actualizado en MeLi: {result.Message}");
                // Refrescar la fila al toque con el nuevo valor
                if (items is not null)
                {
                    var idx = items.FindIndex(i => i.Id == item.Id);
                    if (idx >= 0)
                    {
                        if (pushPrice && result.PushedPrice.HasValue) items[idx].Price = result.PushedPrice.Value;
                        if (pushStock && result.PushedStock.HasValue) items[idx].AvailableQuantity = result.PushedStock.Value;
                    }
                }
            }
            else
            {
                ToastService.Error(result?.Message ?? $"Error al pushear {what}");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error($"Error pusheando {what}: " + ex.Message);
        }
    }

    private async Task OpenPushModal(MeliItemDto item)
    {
        if (item.ProductId is null && item.ComboId is null)
        {
            ToastService.Error("Esta publicación no tiene producto ni combo vinculado.");
            return;
        }
        pushItem = item;
        pushFlagPrice = true;
        pushFlagStock = true;
        pushItemProduct = null;
        // Cargar el producto vinculado (solo aplica si es producto)
        if (item.ProductId.HasValue)
        {
            try
            {
                var products = await Api.GetProductsAsync();
                pushItemProduct = products?.FirstOrDefault(p => p.Id == item.ProductId.Value);
            }
            catch { pushItemProduct = null; }
        }
        showPushModal = true;
    }

    private void ClosePushModal()
    {
        if (isPushing) return;
        showPushModal = false;
        pushItem = null;
        pushItemProduct = null;
    }

    private async Task ConfirmPush()
    {
        if (pushItem is null) return;
        isPushing = true;
        try
        {
            var result = await Api.PushMeliItemFromProductAsync(pushItem.Id, pushFlagPrice, pushFlagStock);
            if (result is not null && result.Success)
            {
                ToastService.Success(result.Message);
                // Refrescar el item localmente con los nuevos valores
                if (items is not null)
                {
                    var idx = items.FindIndex(i => i.Id == pushItem.Id);
                    if (idx >= 0)
                    {
                        if (result.PushedPrice.HasValue) items[idx].Price = result.PushedPrice.Value;
                        if (result.PushedStock.HasValue) items[idx].AvailableQuantity = result.PushedStock.Value;
                    }
                }
                showPushModal = false;
                pushItem = null;
                pushItemProduct = null;
            }
            else
            {
                ToastService.Error(result?.Message ?? "Error al enviar a MeLi");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isPushing = false; }
    }

    // 2026-06-11: handlers PrecioIndependiente
    private async Task MarcarIndepPub(MeliItemDto item)
    {
        try
        {
            var resp = await Api.MarcarPrecioIndependienteAsync(item.MeliItemId);
            if (resp.IsSuccessStatusCode)
            {
                var json = await resp.Content.ReadAsStringAsync();
                using var doc = System.Text.Json.JsonDocument.Parse(json);
                item.PrecioIndependiente = true;
                if (doc.RootElement.TryGetProperty("factor", out var fE)) item.PrecioFactor = fE.GetDecimal();
                if (doc.RootElement.TryGetProperty("precioBase", out var bE)) item.PrecioBaseRef = bE.GetDecimal();
                ToastService.Success($"Marcada · Factor × {item.PrecioFactor:F4}");
                _cachedFiltered = null;
                StateHasChanged();
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                ToastService.Error("Error: " + err);
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DesmarcarIndepPub(MeliItemDto item)
    {
        try
        {
            var resp = await Api.DesmarcarPrecioIndependienteAsync(item.MeliItemId);
            if (resp.IsSuccessStatusCode)
            {
                item.PrecioIndependiente = false;
                item.PrecioFactor = null;
                item.PrecioBaseRef = null;
                ToastService.Success("Desmarcada. Vuelve al modo normal de push.");
                _cachedFiltered = null;
                StateHasChanged();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task RecalcularFactorPub(MeliItemDto item)
