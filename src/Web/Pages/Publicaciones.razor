            var msg = $"✅ Listo: quité la foto en infracción en {res.Ok} publicación(es).";
            if (res.Error > 0) msg += $" {res.Error} con error (revisá esas a mano).";
            ToastService.Success(msg);
            // Sacar del listado en memoria las que se arreglaron para que no queden con 🚩.
            foreach (var it in fixPreview.Items.Where(x => x.Accion == "quitar"))
                photoInfractions.Remove(it.MeliItemId);
            InvalidateFilterCache();
            showFixModal = false;
        }
        catch (Exception ex) { ToastService.Error("Error al aplicar: " + ex.Message); }
        finally { fixApplying = false; StateHasChanged(); }
