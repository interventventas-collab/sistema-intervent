    // --- Filtered + Sorted ---
    private List<MeliItemDto> GetFilteredAndSortedItems()
    {
        if (items is null) return new();

        var filtered = items.AsEnumerable();

        // Promo filter
        if (filterPromo)
            filtered = filtered.Where(i => i.OriginalPrice.HasValue && i.OriginalPrice.Value > 0 && i.OriginalPrice.Value != i.Price);

        // 2026-06-12: solo publicaciones de catálogo (las de fondo amarillo)
        if (filterCatalogo)
            filtered = filtered.Where(IsCatalogListing);

        // Sin producto vinculado
        if (filterNoProduct)
            filtered = filtered.Where(i => !i.ProductId.HasValue);

        // ── Filtros nuevos de linkeo ──
        if (filterLinkeadoCafe)
            filtered = filtered.Where(i => i.CafeProductoId.HasValue);
        if (filterLinkeadoComponentes)
            filtered = filtered.Where(i => i.ComponentMappingsCount > 0);
        if (filterSinLinkear)
            filtered = filtered.Where(i => !i.TieneLinkeo);
        if (filterFull)
            filtered = filtered.Where(i => string.Equals(i.LogisticType, "fulfillment", StringComparison.OrdinalIgnoreCase));
        if (filterNoFull)
            filtered = filtered.Where(i => !string.Equals(i.LogisticType, "fulfillment", StringComparison.OrdinalIgnoreCase));

        // ── Filtros de estado de push de stock ──
        var sieteDias = DateTime.UtcNow.AddDays(-7);
        if (filterStockPushNunca)
            filtered = filtered.Where(i => !i.LastStockPushedToMeli.HasValue);
        if (filterStockPushOk)
            filtered = filtered.Where(i => i.LastStockPushedToMeli.HasValue && i.LastStockPushedToMeli.Value >= sieteDias);
        if (filterStockPushViejo)
            filtered = filtered.Where(i => i.LastStockPushedToMeli.HasValue && i.LastStockPushedToMeli.Value < sieteDias);

        // 🚨 Filtro URGENTE: stock=0 OR pausada (las que urgen reponer / reactivar).
        // Pedido del operario: detectar al toque las publicaciones críticas que necesitan atención.
        if (filterUrgente)
            filtered = filtered.Where(i =>
                i.AvailableQuantity <= 0 ||
                string.Equals(i.Status, "paused", StringComparison.OrdinalIgnoreCase));

        // 2026-07-01: filtros por ajuste cargado — para separar las que ya toqué del resto
        if (filterConAjuste)
            filtered = filtered.Where(HasAjuste);
        if (filterSinAjuste)
            filtered = filtered.Where(i => !HasAjuste(i));

        // 2026-06-01: Filtros por margen — para detectar publicaciones perdiendo plata
        if (filterMargenPerdida)
            filtered = filtered.Where(i =>
            {
                var m = CalcMargenPct(i);
                return m.HasValue && m.Value <= 0m;
            });
        if (filterMargenBajo)
            filtered = filtered.Where(i =>
            {
                var m = CalcMargenPct(i);
                return m.HasValue && m.Value < 15m;
            });

        // Text filters
        foreach (var kv in textFilters.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            var search = kv.Value;
            filtered = kv.Key switch
            {
                "titulo" => filtered.Where(i =>
                    i.Title.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    i.MeliItemId.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (i.FamilyId ?? "").Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (i.UserProductId ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)),
                "sku" => filtered.Where(i => (i.Sku ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)),
                "producto" => filtered.Where(i => (i.ProductTitle ?? "").Contains(search, StringComparison.OrdinalIgnoreCase)),
                _ => filtered
            };
        }

        // Checkbox filters
        foreach (var kv in checkboxFilters.Where(f => f.Value.Count > 0))
        {
            var values = kv.Value;
            filtered = kv.Key switch
            {
                "estado" => filtered.Where(i => values.Contains(GetStatusLabel(i.Status))),
                "tipo" => filtered.Where(i => values.Contains(GetListingTypeLabel(i.ListingTypeId))),
                "cuenta" => filtered.Where(i => values.Contains(i.AccountNickname)),
                _ => filtered
            };
        }

        var list = filtered.ToList();

        // Sort
        if (sortColumn is not null)
        {
            list = sortColumn switch
            {
                "titulo" => sortAsc ? list.OrderBy(i => i.Title).ToList() : list.OrderByDescending(i => i.Title).ToList(),
                "sku" => sortAsc ? list.OrderBy(i => i.Sku).ToList() : list.OrderByDescending(i => i.Sku).ToList(),
                "precio" => sortAsc ? list.OrderBy(i => i.Price).ToList() : list.OrderByDescending(i => i.Price).ToList(),
                "stock" => sortAsc ? list.OrderBy(i => i.AvailableQuantity).ToList() : list.OrderByDescending(i => i.AvailableQuantity).ToList(),
                "vendidos" => sortAsc ? list.OrderBy(i => i.SoldQuantity).ToList() : list.OrderByDescending(i => i.SoldQuantity).ToList(),
                "estado" => sortAsc ? list.OrderBy(i => i.Status).ToList() : list.OrderByDescending(i => i.Status).ToList(),
                "tipo" => sortAsc ? list.OrderBy(i => i.ListingTypeId).ToList() : list.OrderByDescending(i => i.ListingTypeId).ToList(),
                "cuenta" => sortAsc ? list.OrderBy(i => i.AccountNickname).ToList() : list.OrderByDescending(i => i.AccountNickname).ToList(),
                _ => list
            };
        }

        return list;
    }

    private List<MeliItemDto> GetCachedFilteredItems()
    {
        if (_filterDirty || _cachedFiltered is null)
        {
            _cachedFiltered = GetFilteredAndSortedItems();
            _filterDirty = false;
        }
        return _cachedFiltered;
    }

    /// <summary>Grupo de filas a renderizar. Puede ser:
    ///  • Una FAMILIA (FamilyId con varios MLAs distintos — agrupa publicaciones individuales)
    ///  • Un MLA único (con o sin variantes de color/talle/etc.)
    /// La distincion entre ambos cambia el render: en familia, las sub-filas son MLAs;
    /// en un MLA con variantes, las sub-filas son variantes de la misma publicacion.</summary>
    public class GroupedRow
    {
        public MeliItemDto Item { get; set; } = default!;
        public List<MeliItemDto> Variants { get; set; } = new();
        /// <summary>True si el grupo agrupa una FAMILIA (varios MLAs del mismo catalogo MeLi).</summary>
        public bool IsFamily { get; set; }
        /// <summary>Cantidad de MLAs distintos en el grupo.</summary>
        public int DistinctMLAs => Variants.Select(v => v.MeliItemId).Distinct().Count();
        /// <summary>True si hay que mostrar el boton de expandir (mas de 1 MLA o mas de 1 variante).</summary>
        public bool HasMultiple => Variants.Count > 1;
        /// <summary>2026-05-30 — Stock total del grupo SIN duplicar publicaciones que comparten
        /// UserProductId. Caso típico: catálogo MeLi publica el mismo item como "normal" + "catálogo"
        /// (2 MLAs, mismo UserProductId, mismo stock). Sumarlos daba 155 cuando real era 77.</summary>
        public int TotalStock => Variants
            .GroupBy(v => string.IsNullOrEmpty(v.UserProductId)
                ? $"MLA|{v.MeliItemId}|{v.VariationId}"
                : $"UPG|{v.UserProductId}")
            .Sum(g => g.First().AvailableQuantity);
        public int TotalSold => Variants.Sum(v => v.SoldQuantity);
        /// <summary>Clave de agrupacion: FamilyId o MeliItemId.</summary>
        public string Key { get; set; } = "";
    }

    /// <summary>HashSet con las claves de grupos expandidos (FamilyId o MeliItemId).</summary>
    private HashSet<string> expandedGroups = new();

    private void ToggleGroupExpand(string key)
    {
        if (!expandedGroups.Remove(key))
            expandedGroups.Add(key);
        StateHasChanged();
    }

    /// <summary>Agrupa los items filtrados primero por FamilyId (si la familia tiene varios MLAs distintos)
    /// y sino por MeliItemId. Asi replica el comportamiento de MeLi UI que muestra "1 publicacion con N
    /// variantes" cuando varias publicaciones distintas comparten el mismo catalogo (FamilyId).</summary>
    private List<GroupedRow> GetGroupedRows()
    {
        var filtered = GetCachedFilteredItems();
        // Paso 1: contar cuantos MLAs distintos hay por FamilyId
        var mlasPorFamilia = filtered.Where(it => !string.IsNullOrEmpty(it.FamilyId))
            .GroupBy(it => it.FamilyId!)
            .ToDictionary(g => g.Key, g => g.Select(x => x.MeliItemId).Distinct().Count());

        var groups = new List<GroupedRow>();
        var seen = new Dictionary<string, GroupedRow>();
        foreach (var it in filtered)
        {
            // Si el toggle "Agrupar familias" está OFF, cada MLA va como su propia fila (= conteo MLA suelto de MeLi web).
            bool agruparPorFamilia = agruparFamilias
                && !string.IsNullOrEmpty(it.FamilyId)
                && mlasPorFamilia.GetValueOrDefault(it.FamilyId!, 0) > 1;
            string key = agruparPorFamilia ? $"FAM_{it.FamilyId}" : $"MLA_{it.MeliItemId}";
            if (!seen.TryGetValue(key, out var grp))
            {
                grp = new GroupedRow { Item = it, IsFamily = agruparPorFamilia, Key = key };
                seen[key] = grp;
                groups.Add(grp);
            }
            grp.Variants.Add(it);
        }
        return groups;
    }

    private void InvalidateFilterCache()
    {
        _filterDirty = true;
        // 2026-06-02: Al cambiar filtros, volver a la primera página (sino quedás "perdido" en página 8 de 2).
        currentPage = 1;
    }

    /// <summary>2026-06-02: Aplica paginación client-side sobre GetGroupedRows().
    /// Solo afecta el render, no el conteo total. Permite navegar 9k publicaciones sin matar el browser.</summary>
    private List<GroupedRow> GetPagedGroupedRows()
    {
        var all = GetGroupedRows();
        var total = all.Count;
        var totalPages = Math.Max(1, (int)Math.Ceiling((double)total / pageSize));
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;
        return all.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    }

    private int GetTotalPages()
    {
        var total = GetGroupedRows().Count;
        return Math.Max(1, (int)Math.Ceiling((double)total / pageSize));
    }

    private void GoToPage(int page)
    {
        var totalPages = GetTotalPages();
        if (page < 1) page = 1;
        if (page > totalPages) page = totalPages;
        currentPage = page;
        StateHasChanged();
    }

    private void ChangePageSize(int newSize)
    {
        pageSize = newSize;
        currentPage = 1;
        StateHasChanged();
    }

    // --- Grouping ---
    private List<FamilyGroup> GetFamilyGroups()
    {
        var filtered = GetFilteredAndSortedItems();
        return filtered
            .GroupBy(i => i.FamilyId ?? "__none__")
            .Select(g => new FamilyGroup
            {
                FamilyId = g.Key,
                FamilyName = g.First().FamilyName ?? "Sin familia",
                Items = g.ToList()
            })
            .OrderBy(g => g.FamilyName == "Sin familia" ? 1 : 0)
            .ThenBy(g => g.FamilyName)
            .ToList();
