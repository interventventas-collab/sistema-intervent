          .Append(mostrarEliminadas).Append(IsCuentaMe1Filtered()).Append('|')
          .Append(filterMargenDesde).Append('|').Append(filterMargenHasta).Append('|');
        foreach (var kv in textFilters) sb.Append(kv.Key).Append('=').Append(kv.Value).Append(';');
        foreach (var kv in checkboxFilters) sb.Append(kv.Key).Append('=').Append(string.Join(",", kv.Value)).Append(';');
        return sb.ToString();
    }
