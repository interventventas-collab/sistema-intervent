    private async Task ConfirmarArreglarMasivo()
    {
        if (fixPreview is null) return;
        var quitar = fixPreview.Items.Where(x => x.Accion == "quitar")
            .Select(x => (object)new { meliItemId = x.MeliItemId, keepPictureIds = x.KeepPictureIds })
            .ToList();
        if (quitar.Count == 0) return;
        fixApplying = true; StateHasChanged();
        try
        {
            var res = await Api.ApplyFixInfractionsAsync(quitar);
