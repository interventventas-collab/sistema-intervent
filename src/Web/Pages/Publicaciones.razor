    private async Task CreateProductFromItem()
    {
        if (createProductItem is null || string.IsNullOrWhiteSpace(newProductTitle)) return;
        isCreatingProduct = true;

        try
        {
            var request = new CreateProductRequest
            {
                Title = newProductTitle,
                Description = string.IsNullOrWhiteSpace(newProductDescription) ? null : newProductDescription,
                Brand = string.IsNullOrWhiteSpace(newProductBrand) ? null : newProductBrand,
                Model = string.IsNullOrWhiteSpace(newProductModel) ? null : newProductModel,
                Sku = string.IsNullOrWhiteSpace(newProductSku) ? null : newProductSku,
                Photo1 = string.IsNullOrWhiteSpace(newProductPhoto1) ? null : newProductPhoto1,
                Photo2 = string.IsNullOrWhiteSpace(newProductPhoto2) ? null : newProductPhoto2,
                Photo3 = string.IsNullOrWhiteSpace(newProductPhoto3) ? null : newProductPhoto3,
                CostPrice = newProductCostPrice,
                RetailPrice = newProductRetailPrice,
                Stock = newProductStock
            };

            var product = await Api.CreateProductAsync(request);
            if (product is not null)
            {
                var updated = await Api.LinkItemToProductAsync(createProductItem.MeliItemId, product.Id);
                if (updated is not null && items is not null)
                {
                    var idx = items.FindIndex(i => i.Id == createProductItem.Id);
                    if (idx >= 0) items[idx] = updated;
                    InvalidateFilterCache();
                }
                ToastService.Success("Producto creado y vinculado");
            }
            showCreateProductModal = false;
            createProductItem = null;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
        finally
        {
            isCreatingProduct = false;
        }
    }

