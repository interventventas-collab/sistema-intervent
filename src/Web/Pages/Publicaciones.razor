        ToastService.Success("✅ Fotos actualizadas en MercadoLibre.");
        if (res.Pictures.Count > 0) item.Thumbnail = res.Pictures[0].Url;  // refresca la miniatura en la grilla
        photosEdit = res.Pictures.Select(p => new PhotoEdit { Id = p.Id, PreviewUrl = p.Url }).ToList();
        StateHasChanged();
    }

