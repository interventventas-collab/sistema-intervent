        var (resp, err) = await Api.BulkPrecioPorGananciaAsync(req);
        bulkGuardando = false;

        if (resp is null)
        {
            ToastService.Error("No se pudo aplicar: " + (err ?? "Error"));
            StateHasChanged();
            return;
        }

        // Construir mensaje resumen (se mantiene la selección para poder seguir trabajando).
