    // 2026-06-01: helpers visor de margen
    // 2026-07-01: ganancia se calcula SIN IVA (el recibís que trae MeLi tiene IVA adentro, el costo del sistema
    // está sin IVA). Antes el número aparecía inflado ~21%. Ahora dividimos el recibís por 1,21.
    // Usamos 21% fijo — 99% de los productos MeLi son 21%; los pocos con 10,5% se ignoran (impacto marginal).
    private const decimal IvaAlicuota = 0.21m;

    /// <summary>Recibís del simulador MeLi (con IVA adentro) dividido por 1,21 para compararlo con el costo del sistema (sin IVA).</summary>
    private decimal RecibisSinIva()
    {
        if (itemCosts is null) return 0;
        return CalculateNetAmount() / (1m + IvaAlicuota);
    }

    private decimal MarginGanancia()
    {
        if (itemProductCost is null || itemCosts is null) return 0;
        return RecibisSinIva() - itemProductCost.TotalCost;
    }
    private decimal MarginPctSobreCosto()
    {
        if (itemProductCost is null || itemProductCost.TotalCost <= 0) return 0;
        return MarginGanancia() / itemProductCost.TotalCost * 100m;
    }
    private string MarginColor()
    {
        var p = MarginPctSobreCosto();
        if (p >= 30) return "#16a34a";    // verde
        if (p >= 15) return "#eab308";    // amarillo
        if (p > 0)   return "#f97316";    // naranja
        return "#dc2626";                  // rojo
    }
    private string MarginLabel()
    {
        var p = MarginPctSobreCosto();
        if (p >= 30) return "🟢 Buenísimo";
        if (p >= 15) return "🟡 Aceptable";
        if (p > 0)   return "🟠 Bajo";
        return "🔴 Pérdida";
    }

    private string FormatTaxPct() => taxPercentage == 0 ? "0" : taxPercentage.ToString("0.##", CultureInfo.InvariantCulture);

    private decimal CalculateTaxAmount()
    {
        if (itemCosts is null) return 0;
        return Math.Round(itemCosts.Price * taxPercentage / 100m, 2);
    }

    private decimal CalculateNetAmount()
    {
        if (itemCosts is null) return 0;
        var taxes = CalculateTaxAmount();
        return Math.Round(itemCosts.Price - itemCosts.SaleFeeAmount - itemCosts.ListingFeeAmount - itemCosts.ShippingCost - taxes, 2);
    }

