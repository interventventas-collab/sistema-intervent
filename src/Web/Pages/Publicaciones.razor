    private async Task GuardarBulkAjuste(bool publicarEnMeli)
    {
        if (!PuedeGuardarBulk() || bulkGuardando) return;
        bulkGuardando = true;
        bulkPublicarEnMeli = publicarEnMeli;
        StateHasChanged();

        string? redondeo = string.IsNullOrEmpty(bulkAjusteRedondeoOpt) ? null : bulkAjusteRedondeoOpt;

        var req = new ApiClient.BulkPrecioPorGananciaRequest(
            selectedItems.ToList(),
            bulkGananciaPct,
            redondeo,
            bulkIncluirPrecioIndep,
            publicarEnMeli);

        var (resp, err) = await Api.BulkPrecioPorGananciaAsync(req);
        bulkGuardando = false;

        if (resp is null)
        {
            ToastService.Error("No se pudo aplicar: " + (err ?? "Error"));
            StateHasChanged();
            return;
        }

        // Construir mensaje resumen (se mantiene la selección para poder seguir trabajando).
        var parts = new List<string>();
        if (publicarEnMeli)
            parts.Add($"✅ {resp.Pusheados} precios publicados en MeLi");
        else
            parts.Add($"✓ {resp.Guardados} publis actualizadas en tu base (sin tocar MeLi)");

        if (resp.SinCosto > 0) parts.Add($"⚠ {resp.SinCosto} sin costo (saltadas)");
        if (resp.SaltadosPrecioIndep > 0) parts.Add($"{resp.SaltadosPrecioIndep} con precio independiente");
        if (resp.Errores > 0) parts.Add($"❌ {resp.Errores} con error");

        var msg = string.Join(" · ", parts);
        if (resp.Errores > 0) ToastService.Warning(msg);
        else ToastService.Success(msg);

        showBulkAjusteModal = false;
        ajustesPrecio.Clear();
        await LoadItems();
