                <div @onclick:stopPropagation="true"><input type="checkbox" checked="@checkedThisRow" @onchange="() => ToggleSelectRow(grp)" /></div>
                <div>@RenderThumb(item)</div>
                <div style="min-width:0;">
                    <div class="plist-title" title="@item.Title">@item.Title</div>
                    <div class="plist-meta">
                        @RenderSkuMla(item)
