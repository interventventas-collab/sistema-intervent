    // 2026-06-01: Calcula margen (s/costo) para el chip debajo del precio en la grilla.
    // 2026-07-01a: dividimos el neto por 1,21 para descontar el IVA — el precio incluye IVA, el costo no.
    // 2026-07-01b: si tenemos el sale_fee REAL de MeLi cacheado (botón 💰 Refrescar comisiones) y el precio
    // no se movió más del 5% desde que se calculó, usamos ese número — coincide con el margen que muestra la
    // ficha. Solo caemos al 30% estimado si no hay sale_fee real (publis viejas o que nunca se refrescaron).
    private decimal? CalcMargenPct(MeliItemDto item)
    {
        if (!item.ProductCost.HasValue || item.ProductCost.Value <= 0) return null;
        var precio = item.Price;
        if (precio <= 0) return null;

        decimal netoConIva;
        if (item.SaleFeeAmountReal.HasValue && item.SaleFeeAmountReal.Value > 0
            && item.SaleFeePriceSnapshot.HasValue
            && Math.Abs(precio - item.SaleFeePriceSnapshot.Value) / Math.Max(precio, 1m) < 0.05m)
        {
            // 2026-07-14: neto real = precio - comisión (SaleFeeAmount) - ENVÍO a cargo del vendedor.
            // Antes NO se restaba el envío → en productos grandes el margen salía inflado. Ahora coincide con la ficha.
            netoConIva = precio - item.SaleFeeAmountReal.Value - (item.SaleFeeShippingCost ?? 0m);
        }
        else
        {
            // Fallback: 30% estimado (25% comisión + 5% aprox envío/cuotas).
            netoConIva = precio * (1m - 0.30m);
        }

        var netoSinIva = netoConIva / (1m + IvaAlicuota);
        var ganancia = netoSinIva - item.ProductCost.Value;
        return ganancia / item.ProductCost.Value * 100m;
    }

    private (string color, string label, string textColor) MargenChipStyle(decimal pct)
    {
        if (pct >= 30m)  return ("#16a34a", $"+{pct.ToString("0", argCulture)}%", "white");
        if (pct >= 15m)  return ("#eab308", $"+{pct.ToString("0", argCulture)}%", "white");
        if (pct > 0m)    return ("#f97316", $"+{pct.ToString("0", argCulture)}%", "white");
        return ("#dc2626", $"{pct.ToString("0", argCulture)}%", "white");
    }

    /// <summary>2026-06-01: chip de margen estimado (sobre costo) debajo del precio.
    /// Solo se muestra si el item tiene producto linkeado con costo cargado.</summary>
    // 2026-07-14 (Etapa 2): línea chica con la cuenta resumida (publicado − MeLi − envío − IVA − costo).
    // Solo se muestra si tenemos la comisión REAL fresca (mismo criterio que el margen), para no mostrar estimados.
    private RenderFragment CuentaResumidaLinea(MeliItemDto item) => @<text>
        @if (item.ProductCost.HasValue && item.ProductCost.Value > 0
             && item.SaleFeeAmountReal.HasValue && item.SaleFeeAmountReal.Value > 0
             && item.SaleFeePriceSnapshot.HasValue
             && Math.Abs(item.Price - item.SaleFeePriceSnapshot.Value) / Math.Max(item.Price, 1m) < 0.05m)
        {
            var _comision = item.SaleFeeAmountReal.Value;
            var _comPct = item.Price > 0 ? _comision / item.Price * 100m : 0m;
            var _envio = item.SaleFeeShippingCost ?? 0m;
            var _neto = item.Price - _comision - _envio;
            var _iva = _neto - _neto / 1.21m;
            <div style="font-size:0.62rem; color:#9ca3af; margin-top:2px; line-height:1.45; white-space:nowrap;">
                pub <strong style="color:#6b7280;">$@item.Price.ToString("N0", argCulture)</strong>
                · MeLi <span style="color:#b91c1c;">−$@_comision.ToString("N0", argCulture)</span> (@_comPct.ToString("0.#", argCulture)%)
                @if (_envio > 0) { <span> · envío <span style="color:#b91c1c;">−$@_envio.ToString("N0", argCulture)</span></span> }
                · IVA <span style="color:#b91c1c;">−$@_iva.ToString("N0", argCulture)</span>
                · costo <span style="color:#b91c1c;">−$@item.ProductCost.Value.ToString("N0", argCulture)</span>
            </div>
        }
    </text>;

    private RenderFragment MargenChipPrecio(MeliItemDto item) => __builder =>
    {
        var pct = CalcMargenPct(item);
        if (pct == null) return;
        var (bg, label, fg) = MargenChipStyle(pct.Value);
        // 2026-07-14: el margen YA cuenta el envío (SaleFeeShippingCost, restado en CalcMargenPct). Pero si esta
        // publicación paga envío y todavía NO tenemos el envío cacheado, el margen saldría inflado → marcamos
        // "falta envío" hasta que se refresquen las comisiones (ahí se carga el envío y aparece el margen real).
        var faltaEnvio = item.FreeShipping && item.Price >= 33000m && !item.SaleFeeShippingCost.HasValue;
        // 2026-07-11: mostrar también el IMPORTE de ganancia real ($), no solo el %. Consistente con el % mostrado.
        var ganImporte = pct.Value / 100m * item.ProductCost!.Value;
        var tooltip = faltaEnvio
            ? $"⚠ Falta cargar el costo de envío de esta publicación (lo paga el vendedor).\n" +
              $"Refrescá las comisiones (o abrí la ficha) para ver el margen REAL con envío incluido.\n" +
              $"Costo: $ {item.ProductCost!.Value.ToString("N0", argCulture)} · Precio: $ {item.Price.ToString("N0", argCulture)}"
            : $"Ganancia real: $ {ganImporte.ToString("N0", argCulture)} ({label} sobre costo)" +
              (item.SaleFeeShippingCost is decimal env && env > 0 ? $"\n(envío ya descontado: $ {env.ToString("N0", argCulture)})" : "") +
              $"\nCosto: $ {item.ProductCost!.Value.ToString("N0", argCulture)} · Precio: $ {item.Price.ToString("N0", argCulture)}";
        if (faltaEnvio) { bg = "#e5e7eb"; fg = "#6b7280"; }
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "style", $"display: inline-block; background:{bg}; color:{fg}; padding:0.1rem 0.45rem; border-radius:10px; font-size:0.7rem; font-weight:700; margin-top:0.15rem;");
        __builder.AddAttribute(2, "title", tooltip);
        __builder.AddContent(3, faltaEnvio ? $"📊 {label} · ⚠ falta envío" : $"📊 {label} · $ {ganImporte.ToString("N0", argCulture)}");
        __builder.CloseElement();

        // 2026-07-02: chip 🎯 objetivo — si tiene objetivo cargado, compara vs real (±2 pt).
        // Si el sale_fee real esta cacheado y fresco → verde/ambar (dato exacto, coincide con ficha).
        // Si caimos al estimado 30% → gris "aprox" (no queremos dar falso positivo).
        if (item.GananciaObjetivoPct.HasValue && item.ProductCost.HasValue && item.ProductCost.Value > 0)
        {
            var obj = item.GananciaObjetivoPct.Value;
            var real = pct.Value;
            var esExacto = item.SaleFeeAmountReal.HasValue && item.SaleFeeAmountReal.Value > 0
                && item.SaleFeePriceSnapshot.HasValue
                && Math.Abs(item.Price - item.SaleFeePriceSnapshot.Value) / Math.Max(item.Price, 1m) < 0.05m
                && !faltaEnvio; // si falta cargar el envío, la comparación de la lista todavía no es fiable

            string objBg, objFg, objIcon, objTip;
            if (!esExacto)
            {
                // Aprox: no refrescamos las comisiones, el precio se movió, o falta cargar el envío → gris, sin comparar.
                objBg = "#e5e7eb"; objFg = "#4b5563"; objIcon = "?";
                objTip = faltaEnvio
                    ? $"Objetivo: {obj:0.#}%. Falta cargar el envío de esta publicación — refrescá las comisiones para comparar con el margen real."
                    : $"Objetivo: {obj:0.#}%. Comisiones desactualizadas — refrescá para saber exacto (abrí la ficha o botón 💰 Refrescar comisiones).";
            }
            else
            {
                var desv = real - obj;
                var ok = Math.Abs(desv) <= 2m;
                objBg = ok ? "#dcfce7" : "#fef3c7";
                objFg = ok ? "#166534" : "#92400e";
                objIcon = ok ? "✓" : "⚠";
                objTip = ok
                    ? $"Objetivo cumplido: querías {obj:0.#}%, hoy da {real:0.#}%"
                    : $"Objetivo NO cumplido: querías {obj:0.#}%, hoy da {real:0.#}% (desv {desv:+0.#;-0.#} pt)";
            }
            __builder.OpenElement(10, "div");
            __builder.AddAttribute(11, "style", $"display:inline-block; background:{objBg}; color:{objFg}; padding:0.1rem 0.45rem; border-radius:10px; font-size:0.7rem; font-weight:700; margin-top:0.15rem; margin-left:0.25rem;");
            __builder.AddAttribute(12, "title", objTip);
            __builder.AddContent(13, $"🎯 {obj.ToString("0.#", argCulture)}% {objIcon}");
            __builder.CloseElement();
        }
    };

    /// <summary>2026-05-30 — Renderiza el SKU + el precio del sistema (PrecioOtroConIvaCalc)
    /// abajo en gris chiquito. Si no hay precio (publicación sin linkeo o sin componentes
    /// que aporten precio), muestra solo el SKU como antes.</summary>
