    // === Push a MeLi ===

    private async Task OpenPushModal(MeliItemDto item)
    {
        if (item.ProductId is null && item.ComboId is null)
        {
            ToastService.Error("Esta publicación no tiene producto ni combo vinculado.");
            return;
        }
        pushItem = item;
        pushFlagPrice = true;
        pushFlagStock = true;
        pushItemProduct = null;
        // Cargar el producto vinculado (solo aplica si es producto)
        if (item.ProductId.HasValue)
        {
            try
            {
                var products = await Api.GetProductsAsync();
                pushItemProduct = products?.FirstOrDefault(p => p.Id == item.ProductId.Value);
            }
            catch { pushItemProduct = null; }
        }
        showPushModal = true;
    }

    private void ClosePushModal()
    {
        if (isPushing) return;
        showPushModal = false;
        pushItem = null;
        pushItemProduct = null;
    }

    private async Task ConfirmPush()
    {
        if (pushItem is null) return;
        isPushing = true;
        try
        {
            var result = await Api.PushMeliItemFromProductAsync(pushItem.Id, pushFlagPrice, pushFlagStock);
            if (result is not null && result.Success)
            {
                ToastService.Success(result.Message);
                // Refrescar el item localmente con los nuevos valores
                if (items is not null)
                {
                    var idx = items.FindIndex(i => i.Id == pushItem.Id);
                    if (idx >= 0)
                    {
                        if (result.PushedPrice.HasValue) items[idx].Price = result.PushedPrice.Value;
                        if (result.PushedStock.HasValue) items[idx].AvailableQuantity = result.PushedStock.Value;
                    }
                }
                showPushModal = false;
                pushItem = null;
                pushItemProduct = null;
            }
            else
            {
                ToastService.Error(result?.Message ?? "Error al enviar a MeLi");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isPushing = false; }
    }
