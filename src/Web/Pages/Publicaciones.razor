@page "/publicaciones"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@inject SyncProgressTracker SyncProgress
@implements IDisposable

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Publicaciones de MercadoLibre (@GetCachedFilteredItems().Count de @totalItems)</h3>
        <div class="sync-dropdown-wrapper">
            <button class="btn btn-primary" @onclick="() => SyncItems(null, null)" disabled="@isSyncing" style="border-radius: 6px 0 0 6px;">
                @(isSyncing ? syncingLabel : "Sincronizar")
            </button>
            <button class="btn btn-primary sync-dropdown-toggle" @onclick="ToggleSyncMenu" @onclick:stopPropagation="true" disabled="@isSyncing"
                    style="border-radius: 0 6px 6px 0; border-left: 1px solid rgba(255,255,255,0.3); padding: 0.5rem 0.4rem;">
                <i class="fa-solid fa-caret-down"></i>
            </button>
            @if (showSyncMenu)
            {
                <div class="sync-dropdown-menu">
                    <div class="sync-dropdown-section">Por estado</div>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("active", null)'>
                        <span class="status-dot dot-active"></span> Solo activas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("paused", null)'>
                        <span class="status-dot dot-paused"></span> Solo pausadas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("closed", null)'>
                        <span class="status-dot dot-closed"></span> Solo cerradas
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <div class="sync-dropdown-section">Por cuenta</div>
                    @if (meliAccounts is not null)
                    {
                        @foreach (var acc in meliAccounts)
                        {
                            var a = acc;
                            <button class="sync-dropdown-item" @onclick="() => SyncItems(null, a.Id)">
                                <i class="fa-solid fa-user"></i> @a.Nickname
                            </button>
                        }
                    }
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item" @onclick="OpenSyncByIdModal">
                        <i class="fa-solid fa-magnifying-glass"></i> Traer por ID
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item sync-item-all" @onclick='() => SyncItems(null, null)'>
                        <i class="fa-solid fa-arrows-rotate"></i> Sincronizar todo
                    </button>
                </div>
            }
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando publicaciones...</p>
        }
        else if (items is null || !items.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay publicaciones. Hace clic en "Sincronizar" para traer los items de MercadoLibre.</p>
        }
        else
        {
            <!-- View mode toggle -->
            <div class="view-mode-bar">
                <div style="display: flex; gap: 0.25rem;">
                    <button class="view-mode-btn @(viewMode == "flat" ? "active" : "")" @onclick='() => viewMode = "flat"'>Lista</button>
                    <button class="view-mode-btn @(viewMode == "family" ? "active" : "")" @onclick='() => viewMode = "family"'>Por Familia</button>
                    <button class="view-mode-btn @(viewMode == "product" ? "active" : "")" @onclick='() => viewMode = "product"'>Por Producto</button>
                </div>
                <div class="more-filters-wrapper">
                    <button class="more-filters-btn @(filterPromo || filterNoProduct ? "has-active" : "")" @onclick="ToggleMoreFilters" @onclick:stopPropagation="true">
                        <i class="fa-solid fa-gear"></i> Más Filtros @(GetActiveFilterCount() > 0 ? $"({GetActiveFilterCount()})" : "") <i class="fa-solid fa-caret-down"></i>
                    </button>
                    @if (showMoreFilters)
                    {
                        <div class="more-filters-dropdown">
                            <button class="more-filters-item @(filterPromo ? "active" : "")" @onclick="() => { TogglePromoFilter(); showMoreFilters = false; }">
                                <i class="fa-solid fa-tag"></i> En promocion @(filterPromo ? $"({GetCachedFilteredItems().Count})" : "")
                            </button>
                            <button class="more-filters-item @(filterNoProduct ? "active" : "")" @onclick="() => { ToggleNoProductFilter(); showMoreFilters = false; }">
                                <i class="fa-solid fa-link"></i> Sin producto @(filterNoProduct ? $"({GetCachedFilteredItems().Count})" : "")
                            </button>
                        </div>
                    }
                </div>
            </div>

            @if (selectedItems.Count > 0)
            {
                <div class="bulk-actions-bar">
                    <span><strong>@selectedItems.Count</strong> publicaciones seleccionadas</span>
                    <button class="btn btn-primary btn-sm" @onclick="BulkCreateProducts">
                        <i class="fa-solid fa-box"></i> Crear productos
                    </button>
                    <button class="btn btn-danger btn-sm" @onclick="ShowBulkDeleteModal">
                        <i class="fa-solid fa-trash"></i> Eliminar seleccionadas
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="ClearSelection">
                        Deseleccionar
                    </button>
                </div>
            }

                        <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="th-checkbox"><input type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected()" title="Seleccionar todos" /></th>
                            <!-- Imagen -->
                            <th class="th-img">Img</th>
                            <!-- Titulo: text input -->
                            <th class="th-filterable" style="min-width: 200px;">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("titulo") ? "has-filter" : "")" placeholder="Titulo, ID, Familia..."
                                           value='@GetTextFilter("titulo")' @oninput='(e) => SetTextFilter("titulo", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("titulo")' title="Ordenar">
                                        <span class="@(sortColumn == "titulo" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "titulo" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- SKU: text input -->
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("sku") ? "has-filter" : "")" placeholder="SKU"
                                           value='@GetTextFilter("sku")' @oninput='(e) => SetTextFilter("sku", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("sku")' title="Ordenar">
                                        <span class="@(sortColumn == "sku" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "sku" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Precio: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("precio")'>
                                <div class="th-inner">
                                    <span class="th-label">Precio</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "precio" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "precio" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Stock: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("stock")'>
                                <div class="th-inner">
                                    <span class="th-label">Stock</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "stock" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "stock" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Vendidos: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("vendidos")'>
                                <div class="th-inner">
                                    <span class="th-label">Vendidos</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "vendidos" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "vendidos" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Estado: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "estado" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("estado")'>Estado</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("estado")'>
                                            <span class="@(sortColumn == "estado" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "estado" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("estado") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("estado")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "estado")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("estado"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("estado", v)" @onchange='() => ToggleCheckboxValue("estado", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("estado"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("estado")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Tipo: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "tipo" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("tipo")'>Tipo</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("tipo")'>
                                            <span class="@(sortColumn == "tipo" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "tipo" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("tipo") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("tipo")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "tipo")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("tipo"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("tipo", v)" @onchange='() => ToggleCheckboxValue("tipo", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("tipo"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("tipo")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Cuenta: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "cuenta" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("cuenta")'>Cuenta</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("cuenta")'>
                                            <span class="@(sortColumn == "cuenta" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "cuenta" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("cuenta") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("cuenta")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "cuenta")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("cuenta"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("cuenta", v)" @onchange='() => ToggleCheckboxValue("cuenta", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("cuenta"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("cuenta")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("producto") ? "has-filter" : "")" placeholder="Producto"
                                           value='@GetTextFilter("producto")' @oninput='(e) => SetTextFilter("producto", e.Value?.ToString() ?? "")' />
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (viewMode == "flat")
                        {
                            <Virtualize Items="@GetCachedFilteredItems()" Context="item" OverscanCount="5" ItemSize="50">
                                <tr class="clickable-row @(selectedItems.Contains(item.Id) ? "row-selected" : "")" @onclick="() => OpenItemModal(item)">
                                    <td class="td-checkbox" @onclick:stopPropagation="true"><input type="checkbox" checked="@selectedItems.Contains(item.Id)" @onchange="() => ToggleSelectItem(item.Id)" /></td>
                                    <td style="text-align: center;">
                                        @if (!string.IsNullOrEmpty(item.Thumbnail))
                                        {
                                            <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                        }
                                        else
                                        {
                                            <div class="item-thumb-placeholder">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Permalink))
                                        {
                                            <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                        }
                                        else
                                        {
                                            <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                        }
                                        <div class="item-id">@item.MeliItemId</div>
                                    </td>
                                    <td>@(item.Sku ?? "-")</td>
                                    <td>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                        {
                                            <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                            <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                            <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                        }
                                    </td>
                                    <td style="text-align: center; font-weight: 700;">
                                        @if (item.ProductCriticalStock.HasValue && item.ProductCriticalStock.Value > 0 && item.AvailableQuantity <= item.ProductCriticalStock.Value)
                                        {
                                            <span class="stock-badge @(item.AvailableQuantity < item.ProductCriticalStock.Value ? "stock-critical" : "stock-warning")">@item.AvailableQuantity</span>
                                        }
                                        else if (item.ProductCriticalStock.HasValue && item.ProductCriticalStock.Value > 0 && item.AvailableQuantity > item.ProductCriticalStock.Value)
                                        {
                                            <span class="stock-badge stock-healthy">@item.AvailableQuantity</span>
                                        }
                                        else
                                        {
                                            @item.AvailableQuantity
                                        }
                                    </td>
                                    <td>@item.SoldQuantity</td>
                                    <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                    <td>@GetListingTypeLabel(item.ListingTypeId)</td>
                                    <td>@item.AccountNickname</td>
                                    <td class="td-product" @onclick:stopPropagation="true">
                                        @if (item.ProductId.HasValue)
                                        {
                                            <span class="product-badge" title="@item.ProductTitle">
                                                @Truncate(item.ProductTitle ?? "", 18)
                                                <button class="product-badge-unlink" @onclick="() => UnlinkProduct(item)" title="Desvincular">&times;</button>
                                            </span>
                                            <button class="push-meli-btn" @onclick="() => OpenPushModal(item)" title="Push precio + stock a MeLi">📤</button>
                                        }
                                        else if (item.ComboId.HasValue)
                                        {
                                            <span class="product-badge" style="background:#fef3c7; color:#92400e; border-color:#fbbf24;" title="@item.ComboName">
                                                🎁 @Truncate(item.ComboName ?? "", 16)
                                                <button class="product-badge-unlink" @onclick="() => UnlinkProduct(item)" title="Desvincular">&times;</button>
                                            </span>
                                            <button class="push-meli-btn" @onclick="() => OpenPushModal(item)" title="Push precio + stock a MeLi">📤</button>
                                        }
                                        else
                                        {
                                            <div class="product-actions-inline">
                                                <button class="create-product-btn" @onclick="() => OpenCreateProductFromItem(item)" title="Crear producto">+</button>
                                                <button class="link-product-btn" @onclick="() => OpenLinkProductDropdown(item)" title="Vincular existente">&#128279;</button>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            </Virtualize>
                        }
                        else if (viewMode == "family")
                        {
                            @foreach (var family in GetFamilyGroups())
                            {
                                <tr class="group-header-row">
                                    <td colspan="11">
                                        <strong>@(family.FamilyName ?? "Sin familia")</strong>
                                        <small class="text-muted" style="margin-left: 0.5rem;">(@family.Items.Count items)</small>
                                    </td>
                                </tr>
                                @foreach (var item in family.Items)
                                {
                                    <tr class="group-item-row clickable-row @(selectedItems.Contains(item.Id) ? "row-selected" : "")" @onclick="() => OpenItemModal(item)">
                                        <td class="td-checkbox" @onclick:stopPropagation="true"><input type="checkbox" checked="@selectedItems.Contains(item.Id)" @onchange="() => ToggleSelectItem(item.Id)" /></td>
                                        <td style="text-align: center;">
                                            @if (!string.IsNullOrEmpty(item.Thumbnail))
                                            {
                                                <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                            }
                                            else
                                            {
                                                <div class="item-thumb-placeholder">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Permalink))
                                            {
                                                <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                            }
                                            else
                                            {
                                                <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                            }
                                            <div class="item-id">@item.MeliItemId</div>
                                        </td>
                                        <td>@(item.Sku ?? "-")</td>
                                        <td>
                                        @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                        {
                                            <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                            <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                            <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                        }
                                    </td>
                                        <td style="text-align: center; font-weight: 700;">
                                        @if (item.ProductCriticalStock.HasValue && item.ProductCriticalStock.Value > 0 && item.AvailableQuantity <= item.ProductCriticalStock.Value)
                                        {
                                            <span class="stock-badge @(item.AvailableQuantity < item.ProductCriticalStock.Value ? "stock-critical" : "stock-warning")">@item.AvailableQuantity</span>
                                        }
                                        else if (item.ProductCriticalStock.HasValue && item.ProductCriticalStock.Value > 0 && item.AvailableQuantity > item.ProductCriticalStock.Value)
                                        {
                                            <span class="stock-badge stock-healthy">@item.AvailableQuantity</span>
                                        }
                                        else
                                        {
                                            @item.AvailableQuantity
                                        }
                                    </td>
                                        <td>@item.SoldQuantity</td>
                                        <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                        <td>@GetListingTypeLabel(item.ListingTypeId)</td>
                                        <td>@item.AccountNickname</td>
                                        <td class="td-product" @onclick:stopPropagation="true">
                                            @if (item.ProductId.HasValue)
                                            {
                                                <span class="product-badge" title="@item.ProductTitle">
                                                    @Truncate(item.ProductTitle ?? "", 18)
                                                    <button class="product-badge-unlink" @onclick="() => UnlinkProduct(item)" title="Desvincular">&times;</button>
                                                </span>
                                                <button class="push-meli-btn" @onclick="() => OpenPushModal(item)" title="Push precio + stock a MeLi">📤</button>
                                            }
                                            else
                                            {
                                                <div class="product-actions-inline">
                                                    <button class="create-product-btn" @onclick="() => OpenCreateProductFromItem(item)" title="Crear producto">+</button>
                                                    <button class="link-product-btn" @onclick="() => OpenLinkProductDropdown(item)" title="Vincular existente">&#128279;</button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                        else if (viewMode == "product")
                        {
                            @foreach (var product in GetProductGroups())
                            {
                                @if (product.Items.Count > 1)
                                {
                                    <tr class="group-header-row">
                                        <td colspan="11">
                                            <strong>@Truncate(product.Title, 60)</strong>
                                            <small class="text-muted" style="margin-left: 0.5rem;">(@product.Items.Count variaciones)</small>
                                        </td>
                                    </tr>
                                    @foreach (var item in product.Items)
                                    {
                                        <tr class="group-item-row clickable-row" @onclick="() => OpenItemModal(item)">
                                            <td style="text-align: center;">
                                                @if (!string.IsNullOrEmpty(item.Thumbnail))
                                                {
