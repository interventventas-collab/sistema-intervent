@page "/publicaciones"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject SyncProgressTracker SyncProgress
@implements IDisposable
@using System.IO

@* 2026-07-17: estilos de la vista "Lista" rediseñada (fila resumida + panel de edición). *@
<style>
    .plist-search { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px; align-items:center; }
    .plist-search input { padding:9px 12px; border:1px solid #d1d5db; border-radius:8px; font-size:0.85rem; }
    .plist-search input:focus { outline:none; border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.12); }
    .plist-search input.big { flex:1; min-width:280px; }
    .plist-search .active { border-color:#6366f1; background:#eef2ff; }
    .plist-search .clr { padding:8px 12px; border:1px solid #e5e7eb; border-radius:8px; background:white; color:#6b7280; font-size:0.8rem; cursor:pointer; }
    .plist { border:1px solid #e5e7eb; border-radius:10px; overflow:hidden; background:white; }
    .plist-section { padding:11px 14px; background:#f3f4f6; font-weight:600; font-size:0.82rem; color:#374151; border-bottom:1px solid #e5e7eb; }
    .plist-section .cnt { color:#9ca3af; font-weight:400; font-size:0.72rem; margin-left:6px; }
    .plist-head, .plist-row { display:grid; grid-template-columns: 34px 40px minmax(220px,1.6fr) 210px 90px 150px 40px; align-items:center; gap:10px; padding:16px 14px; }
    .plist-row { min-height:62px; }
    .plist-head { background:#f9fafb; border-bottom:1px solid #e5e7eb; font-size:0.68rem; letter-spacing:.03em; text-transform:uppercase; color:#9ca3af; font-weight:600; padding:11px 14px; }
    .plist-row { border-bottom:1px solid #f1f3f5; cursor:pointer; }
    .plist-row:hover { background:#fafbfc; }
    .plist-row.sel { background:#eff6ff; }
    .plist-row.open { background:#f8fafc; }
    .plist-thumb { width:40px; height:40px; border-radius:7px; object-fit:cover; border:1px solid #e5e7eb; background:#f3f4f6; }
    .plist-thumb-ph { width:40px; height:40px; border-radius:7px; border:1px solid #e5e7eb; background:#f3f4f6; display:flex; align-items:center; justify-content:center; }
    .plist-title { font-weight:600; font-size:0.92rem; color:#111827; line-height:1.3; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .plist-meta { font-size:0.72rem; color:#9ca3af; margin-top:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .plist-price { font-weight:600; font-size:1rem; color:#111827; }
    .plist-price-old { font-size:0.68rem; color:#9ca3af; text-decoration:line-through; margin-left:4px; }
    .plist-mline { margin-top:5px; display:flex; align-items:center; gap:7px; flex-wrap:wrap; }
    .plist-badge { font-size:0.72rem; font-weight:700; padding:2px 9px; border-radius:9px; }
    .mmeter { width:58px; height:6px; border-radius:3px; background:#eef0f2; overflow:hidden; display:inline-block; vertical-align:middle; }
    .mmeter-fill { display:block; height:100%; border-radius:3px; }
    .plist-meta .cp-inline { display:inline-flex; align-items:center; vertical-align:middle; }
    .plist-sku { font-weight:600; color:#374151; }
    .plist-tipo { display:inline-block; font-size:0.66rem; font-weight:600; color:#475569; background:#eef2f7; padding:1px 8px; border-radius:6px; margin-top:5px; white-space:nowrap; }
    .plist-tipo.premium { background:#f3e8ff; color:#7c3aed; }
    .plist-costo { font-size:0.68rem; color:#9ca3af; }
    .plist-chip { font-size:0.64rem; font-weight:700; padding:1px 6px; border-radius:8px; background:#eff6ff; color:#1e40af; }
    .plist-stk { text-align:right; }
    .plist-stk .n { font-weight:700; font-size:0.9rem; }
    .plist-stk .u { font-size:0.6rem; color:#9ca3af; text-transform:uppercase; }
    .plist-stk.zero .n { color:#dc2626; }
    .plist-stk.zero .u { color:#dc2626; }
    .plist-st-badge { font-size:0.64rem; font-weight:700; padding:1px 8px; border-radius:8px; display:inline-block; margin-bottom:4px; }
    .plist-sy { display:flex; align-items:center; gap:5px; font-size:0.66rem; color:#6b7280; line-height:1.5; }
    .plist-dot { width:7px; height:7px; border-radius:50%; display:inline-block; }
    .plist-chev { width:26px; height:26px; border:1px solid #e5e7eb; border-radius:6px; background:white; color:#6b7280; font-size:0.8rem; cursor:pointer; display:flex; align-items:center; justify-content:center; }
    .plist-chev:hover { background:#f3f4f6; }
    .plist-chev.open { background:#eef2ff; border-color:#c7d2fe; color:#4338ca; }
    .plist-vrow { display:grid; grid-template-columns: 34px 40px minmax(220px,1.6fr) 210px 90px 150px 40px; align-items:center; gap:10px; padding:13px 12px; min-height:56px; border-bottom:1px solid #f1f3f5; background:#fbfcfd; font-size:0.82rem; cursor:pointer; }
    .plist-vtag { color:#9ca3af; text-align:right; }
    /* Panel de edición */
    .plist-panel { border-bottom:1px solid #e5e7eb; background:#f8fafc; padding:16px 18px 18px 86px; display:grid; grid-template-columns: 1fr 250px; gap:26px; }
    .pp-label { font-size:0.66rem; text-transform:uppercase; letter-spacing:.03em; color:#9ca3af; font-weight:700; margin-bottom:9px; }
    .pp-seg { display:inline-flex; border:1px solid #d1d5db; border-radius:8px; overflow:hidden; margin-bottom:11px; }
    .pp-seg button { font-size:0.75rem; padding:6px 13px; color:#6b7280; background:white; border:none; cursor:pointer; }
    .pp-seg button.sel { background:#111827; color:white; font-weight:600; }
    .pp-editrow { display:flex; align-items:center; gap:9px; }
    .pp-inp { width:120px; padding:7px 9px; border:1px solid #d1d5db; border-radius:7px; font-size:0.85rem; }
    .pp-sign { font-size:0.8rem; color:#9ca3af; margin-left:-4px; }
    .pp-btn { background:#111827; color:white; border:none; border-radius:7px; padding:8px 15px; font-size:0.78rem; font-weight:600; cursor:pointer; }
    .pp-btn:disabled { opacity:.6; cursor:default; }
    .pp-prev { margin-top:10px; font-size:0.78rem; color:#4b5563; background:white; border:1px solid #e5e7eb; border-radius:7px; padding:8px 10px; display:inline-block; }
    .pp-prev b { color:#111827; }
    .pp-swrow { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:12px; }
    .pp-swtxt .t { font-size:0.8rem; color:#111827; }
    .pp-swtxt .d { font-size:0.68rem; color:#9ca3af; }
    .pp-sw { width:38px; height:21px; border-radius:11px; position:relative; flex:none; border:none; cursor:pointer; padding:0; }
    .pp-sw i { position:absolute; top:2px; width:17px; height:17px; border-radius:50%; background:white; transition:left .12s; }
    .pp-sw.on { background:#16a34a; } .pp-sw.on i { left:19px; }
    .pp-sw.off { background:#d1d5db; } .pp-sw.off i { left:2px; }
    .pp-note { font-size:0.75rem; color:#9ca3af; font-style:italic; }
    @@media (max-width: 820px) {
        .plist-head, .plist-row, .plist-vrow { grid-template-columns: 30px 0px minmax(140px,1.4fr) 150px 60px 0px 34px; }
        .plist-panel { grid-template-columns: 1fr; padding-left:18px; }
    }

    /* 2026-07-21: gestor de fotos (Etapa 1) */
    .plist-photobtn { background:none; border:1px solid transparent; border-radius:6px; cursor:pointer; font-size:0.95rem; padding:2px 5px; line-height:1; opacity:.75; }
    .plist-photobtn:hover { opacity:1; background:#f1f5f9; }
    .plist-photobtn.open { opacity:1; background:#e0e7ff; border-color:#c7d2fe; }
    .plist-photos-panel { background:#f8fafc; border:1px solid #e2e8f0; border-top:none; border-radius:0 0 10px 10px; padding:14px 18px; margin:-4px 0 8px 0; }
    .pp-loading { color:#6b7280; font-size:0.85rem; padding:8px 0; }
    .pp-warn { background:#fef3c7; border:1px solid #fde68a; color:#92400e; font-size:0.78rem; border-radius:8px; padding:8px 10px; margin-bottom:10px; }
    .pp-strip { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:12px; }
    .pp-thumb { position:relative; width:96px; height:96px; border-radius:8px; overflow:hidden; border:1px solid #cbd5e1; background:#fff; }
    .pp-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
    .pp-badge { position:absolute; top:0; left:0; background:#4338ca; color:#fff; font-size:0.6rem; font-weight:700; padding:1px 5px; border-radius:0 0 6px 0; }
    .pp-actions { position:absolute; bottom:0; left:0; right:0; display:flex; justify-content:space-between; background:rgba(15,23,42,.72); }
    .pp-actions button { flex:1; background:none; border:none; color:#fff; cursor:pointer; font-size:0.72rem; padding:3px 0; }
    .pp-actions button:disabled { opacity:.3; cursor:default; }
    .pp-actions button.pp-del:hover { background:#dc2626; }
    .pp-empty { color:#9ca3af; font-size:0.82rem; font-style:italic; padding:6px 0; }
    .pp-add { display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:12px; }
    .pp-add input { flex:1; min-width:220px; padding:8px 11px; border:1px solid #d1d5db; border-radius:8px; font-size:0.82rem; }
    .pp-btn { background:#eef2ff; border:1px solid #c7d2fe; color:#3730a3; border-radius:8px; padding:8px 12px; font-size:0.8rem; font-weight:600; cursor:pointer; white-space:nowrap; }
    .pp-btn:hover { background:#e0e7ff; }
    .pp-file { display:inline-flex; align-items:center; }
    .pp-foot { display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:8px; border-top:1px solid #e2e8f0; padding-top:10px; }
    .pp-count { font-size:0.76rem; color:#6b7280; }
    .pp-save { background:#16a34a; color:#fff; border:none; border-radius:8px; padding:9px 16px; font-size:0.83rem; font-weight:700; cursor:pointer; }
    .pp-save:hover { background:#15803d; }
    .pp-save:disabled { background:#94a3b8; cursor:default; }

    /* 2026-07-21: detección de fotos en infracción */
    .plist-thumb-wrap { position:relative; display:inline-block; line-height:0; }
    .plist-flag { position:absolute; top:-6px; right:-6px; font-size:0.85rem; background:#fff; border-radius:50%; box-shadow:0 0 0 1px #ea580c; padding:1px 2px; cursor:help; }
    .pp-infr { background:#ffedd5; border:1px solid #fb923c; color:#9a3412; font-size:0.8rem; border-radius:8px; padding:9px 11px; margin-bottom:10px; line-height:1.4; }
    .pp-thumb.bad { border-color:#dc2626; box-shadow:0 0 0 2px #fecaca; }
    .pp-problem { position:absolute; top:0; right:0; left:0; background:#dc2626; color:#fff; font-size:0.6rem; font-weight:700; padding:2px 4px; text-align:center; line-height:1.15; max-height:2.4em; overflow:hidden; }

    /* Modal arreglo masivo */
    .fixm-overlay { position:fixed; inset:0; background:rgba(15,23,42,.5); z-index:1000; display:flex; align-items:center; justify-content:center; padding:16px; }
    .fixm-box { background:#fff; border-radius:14px; width:min(720px, 96vw); max-height:88vh; display:flex; flex-direction:column; box-shadow:0 20px 60px rgba(0,0,0,.3); }
    .fixm-head { display:flex; align-items:center; justify-content:space-between; padding:14px 18px; border-bottom:1px solid #e5e7eb; font-weight:800; font-size:0.95rem; color:#1e293b; }
    .fixm-x { background:none; border:none; font-size:1.1rem; cursor:pointer; color:#64748b; }
    .fixm-body { padding:16px 18px; overflow-y:auto; }
    .fixm-summary { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:14px; }
    .fixm-card { flex:1; min-width:120px; border-radius:10px; padding:10px 12px; text-align:center; }
    .fixm-card b { display:block; font-size:1.5rem; line-height:1; }
    .fixm-card span { font-size:0.72rem; }
    .fixm-card.ok { background:#dcfce7; color:#15803d; }
    .fixm-card.warn { background:#ffedd5; color:#9a3412; }
    .fixm-card.gray { background:#f1f5f9; color:#64748b; }
    .fixm-section-title { font-size:0.82rem; font-weight:700; color:#334155; margin:12px 0 6px; }
    .fixm-list { display:flex; flex-direction:column; gap:4px; }
    .fixm-row { display:flex; align-items:center; justify-content:space-between; gap:8px; font-size:0.8rem; padding:5px 8px; background:#f8fafc; border-radius:6px; }
    .fixm-title { min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .fixm-tag { white-space:nowrap; font-size:0.72rem; font-weight:600; padding:1px 6px; border-radius:5px; }
    .fixm-tag.ok { background:#dcfce7; color:#15803d; }
    .fixm-tag.warn { background:#fef3c7; color:#92400e; }
    .fixm-foot { display:flex; justify-content:flex-end; gap:10px; padding:12px 18px; border-top:1px solid #e5e7eb; }
    .fixm-cancel { background:#f1f5f9; border:1px solid #cbd5e1; color:#334155; border-radius:8px; padding:9px 14px; font-size:0.83rem; font-weight:600; cursor:pointer; }
    .fixm-go { background:#b45309; color:#fff; border:none; border-radius:8px; padding:9px 16px; font-size:0.83rem; font-weight:700; cursor:pointer; }
    .fixm-go:disabled { background:#94a3b8; cursor:default; }
</style>

<div class="card card-publicaciones">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Publicaciones de MercadoLibre (@GetGroupedRows().Count publicaciones · @GetCachedFilteredItems().Count filas)</h3>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/publicaciones/auditoria")' title="Comparar lista de MLAs entre MeLi y el sistema">
            <i class="fa-solid fa-magnifying-glass"></i> Auditar vs MeLi
        </button>
        @* 2026-07-21: escanea las infracciones de la cuenta y marca las publicaciones con foto en infracción (🚩). *@
        <button class="btn" style="background:#ea580c; color:white; font-weight:700;"
                @onclick="BuscarInfraccionesFoto" disabled="@scanningInfractions"
                title="Revisa las infracciones de tu cuenta en MercadoLibre y marca con 🚩 las publicaciones cuyo problema es de fotos, para que las arregles.">
            @if (scanningInfractions) { <span>⏳ Escaneando...</span> } else { <span>🚩 Buscar fotos en infracción</span> }
        </button>
        @* 2026-07-21: arreglo masivo — quita la foto en infracción donde es seguro, aparta las de portada. *@
        <button class="btn" style="background:#b45309; color:white; font-weight:700;"
                @onclick="AbrirArreglarMasivo" disabled="@(fixLoading || fixApplying)"
                title="Analiza todas las publicaciones con foto en infracción y te muestra una vista previa: quita sola la foto mala donde es seguro (no es portada y quedan varias fotos) y aparta las de portada para que las reemplaces a mano.">
            @if (fixLoading) { <span>⏳ Analizando...</span> } else { <span>🧹 Quitar en infracción (masivo)</span> }
        </button>
        @* 2026-06-19: Refrescar comisiones reales de MeLi via API listing_prices.
           Tarda 10-15 min en background. Despues los netos del listado coinciden al peso con MeLi. *@
        <button class="btn" style="background:#7c3aed; color:white; font-weight:700;"
                @onclick="RefrescarComisionesMeLi" disabled="@refrescandoComisiones"
                title="Trae la comision REAL que MeLi cobra por cada publicacion via su API. Reemplaza el calculo estimado (-32%) por el numero exacto. Tarda 10-15 min para 3650 publicaciones. Una vez cacheado, el listado muestra netos exactos.">
            @if (refrescandoComisiones) { <span>⏳ Refrescando...</span> } else { <span>💰 Refrescar comisiones MeLi</span> }
        </button>
        @* 2026-06-01: Boton de push masivo agresivo. Pushea stock a TODAS las publicaciones con SyncStock=ON.
           Confirma 2 veces antes de ejecutar. Resultado vuelve a las tablas MeliPushSnapshot_*_pre/post para cotejo. *@
        <button class="btn" style="background:#dc2626; color:white; font-weight:700; border:2px solid #991b1b;"
                @onclick="DispararPushMasivoAgresivo" disabled="@pushMasivoEnCurso"
                title="Pushea stock a TODAS las publicaciones MeLi. MeLi pausa las de stock 0 y activa las con stock. Despues hay que revisar el cotejo.">
            @if (pushMasivoEnCurso) { <span>⏳ Pusheando...</span> } else { <span>🚀 PUSHEAR STOCK DE TODO A MELI</span> }
        </button>
        <div class="sync-dropdown-wrapper">
            <button class="btn btn-primary" @onclick="() => SyncItems(null, null)" disabled="@isSyncing" style="border-radius: 6px 0 0 6px;">
                @(isSyncing ? syncingLabel : "Sincronizar")
            </button>
            <button class="btn btn-primary sync-dropdown-toggle" @onclick="ToggleSyncMenu" @onclick:stopPropagation="true" disabled="@isSyncing"
                    style="border-radius: 0 6px 6px 0; border-left: 1px solid rgba(255,255,255,0.3); padding: 0.5rem 0.4rem;">
                <i class="fa-solid fa-caret-down"></i>
            </button>
            @if (showSyncMenu)
            {
                <div class="sync-dropdown-menu">
                    <div class="sync-dropdown-section">Por estado</div>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("active", null)'>
                        <span class="status-dot dot-active"></span> Solo activas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("paused", null)'>
                        <span class="status-dot dot-paused"></span> Solo pausadas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("closed", null)'>
                        <span class="status-dot dot-closed"></span> Solo cerradas
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <div class="sync-dropdown-section">Por cuenta</div>
                    @if (meliAccounts is not null)
                    {
                        @foreach (var acc in meliAccounts)
                        {
                            var a = acc;
                            <button class="sync-dropdown-item" @onclick="() => SyncItems(null, a.Id)">
                                <i class="fa-solid fa-user"></i> @a.Nickname
                            </button>
                        }
                    }
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item" @onclick="OpenSyncByIdModal">
                        <i class="fa-solid fa-magnifying-glass"></i> Traer por ID
                    </button>
                    <button class="sync-dropdown-item" @onclick="OpenSyncFamilyModal">
                        <i class="fa-solid fa-layer-group"></i> Traer familia completa
                    </button>
                    <button class="sync-dropdown-item" @onclick="() => TraerTodasLasFamilias()">
                        <i class="fa-solid fa-layer-group"></i> Traer TODAS las familias completas
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item sync-item-all" @onclick='() => SyncItems(null, null)'>
                        <i class="fa-solid fa-arrows-rotate"></i> Sincronizar todo
                    </button>
                </div>
            }
        </div>
        </div>
    </div>

    @* 2026-07-13: cartel de confirmación de sincronización (doble check) *@
    @if (showSyncConfirm)
    {
        <div style="position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:3000; display:flex; align-items:center; justify-content:center; padding:1rem;" @onclick="CancelarSync">
            <div style="background:white; border-radius:12px; max-width:460px; width:100%; padding:1.5rem; box-shadow:0 10px 40px rgba(0,0,0,0.3);" @onclick:stopPropagation="true">
                <div style="display:flex; align-items:center; gap:0.6rem; margin-bottom:0.75rem;">
                    <span style="font-size:1.8rem;">⚠️</span>
                    <h3 style="margin:0; font-size:1.15rem; font-weight:800; color:#b45309;">¿Confirmás la sincronización?</h3>
                </div>
                <p style="margin:0 0 1.25rem; color:#374151; font-size:0.95rem; line-height:1.5;">@syncConfirmText</p>
                <div style="display:flex; gap:0.6rem; justify-content:flex-end;">
                    <button @onclick="CancelarSync"
                            style="padding:0.6rem 1.1rem; border:1px solid #d1d5db; background:white; color:#374151; border-radius:8px; font-weight:700; cursor:pointer;">
                        Cancelar
                    </button>
                    <button @onclick="ConfirmarSyncAsync"
                            style="padding:0.6rem 1.1rem; border:none; background:#2563eb; color:white; border-radius:8px; font-weight:700; cursor:pointer;">
                        Sí, sincronizar
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showFixModal)
    {
        <div class="fixm-overlay" @onclick="() => { if (!fixApplying) showFixModal = false; }">
            <div class="fixm-box" @onclick:stopPropagation="true">
                <div class="fixm-head">
                    <span>🧹 Quitar fotos en infracción — vista previa</span>
                    <button class="fixm-x" @onclick="() => showFixModal = false" disabled="@fixApplying">✕</button>
                </div>
                @if (fixLoading)
                {
                    <div class="fixm-body"><p>⏳ Analizando tus publicaciones con foto en infracción… (puede tardar unos segundos)</p></div>
                }
                else if (fixPreview is null)
                {
                    <div class="fixm-body"><p>No se pudo analizar. Cerrá y probá de nuevo.</p></div>
                }
                else
                {
                    <div class="fixm-body">
                        <div class="fixm-summary">
                            <div class="fixm-card ok"><b>@fixPreview.Quitar</b><span>se pueden quitar solas</span></div>
                            <div class="fixm-card warn"><b>@fixPreview.Apartar</b><span>apartadas (portada / pocas fotos)</span></div>
                            <div class="fixm-card gray"><b>@fixPreview.YaOk</b><span>ya arregladas</span></div>
                        </div>

                        @if (fixPreview.Quitar > 0)
                        {
                            <div class="fixm-section-title">✅ Voy a quitar la foto mala en estas (quedan con varias fotos):</div>
                            <div class="fixm-list">
                                @foreach (var it in fixPreview.Items.Where(x => x.Accion == "quitar"))
                                {
                                    <div class="fixm-row"><span class="fixm-title">@it.Title</span><span class="fixm-tag ok">quita @it.RemoveCount · quedan @it.RemainingCount</span></div>
                                }
                            </div>
                        }

                        @if (fixPreview.Apartar > 0)
                        {
                            <div class="fixm-section-title">⚠️ Estas las dejo para que las revises/reemplaces a mano (la foto mala es la portada o quedarían muy pocas):</div>
                            <div class="fixm-list">
                                @foreach (var it in fixPreview.Items.Where(x => x.Accion == "apartar"))
                                {
                                    <div class="fixm-row"><span class="fixm-title">@it.Title</span><span class="fixm-tag warn">@it.Reason</span></div>
                                }
                            </div>
                        }

                        @if (fixPreview.Quitar == 0 && fixPreview.Apartar == 0)
                        {
                            <p style="color:#16a34a; font-weight:600;">✅ No hay nada para quitar: o ya están arregladas, o todas necesitan reemplazo a mano.</p>
                        }
                    </div>
                    <div class="fixm-foot">
                        <button class="fixm-cancel" @onclick="() => showFixModal = false" disabled="@fixApplying">Cancelar</button>
                        <button class="fixm-go" disabled="@(fixApplying || fixPreview.Quitar == 0)" @onclick="ConfirmarArreglarMasivo">
                            @(fixApplying ? "Quitando…" : $"Quitar la foto en las {fixPreview.Quitar} seguras")
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando publicaciones...</p>
        }
        else if (items is null || !items.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay publicaciones. Hace clic en "Sincronizar" para traer los items de MercadoLibre.</p>
        }
        else
        {
            <!-- View mode toggle -->
            <div class="view-mode-bar">
                <div style="display: flex; gap: 0.25rem;">
                    <button class="view-mode-btn @(viewMode == "flat" ? "active" : "")" @onclick='() => viewMode = "flat"'>Lista</button>
                    <button class="view-mode-btn @(viewMode == "family" ? "active" : "")" @onclick='() => viewMode = "family"'>Por Familia</button>
                    <button class="view-mode-btn @(viewMode == "product" ? "active" : "")" @onclick='() => viewMode = "product"'>Por Producto</button>
                    <button class="view-mode-btn @(viewMode == "sincro" ? "active" : "")" @onclick='() => viewMode = "sincro"'>💰 Sincro precio + stock</button>
                    @* 2026-06-16: toggle de status (Activas / Pausadas / Todas) — antes solo cargaba active y no se podian ver paused *@
                    <div style="display:inline-flex; gap:0.15rem; margin-left:0.5rem; padding:0.15rem; background:#f3f4f6; border-radius:6px;">
                        <button class="view-mode-btn @(statusFilter == "active" ? "active" : "")" style="background:@(statusFilter == "active" ? "#16a34a" : "transparent"); color:@(statusFilter == "active" ? "white" : "#374151");"
                                @onclick='@(() => CambiarStatus("active"))'>✅ Activas</button>
                        <button class="view-mode-btn @(statusFilter == "paused" ? "active" : "")" style="background:@(statusFilter == "paused" ? "#f59e0b" : "transparent"); color:@(statusFilter == "paused" ? "white" : "#374151");"
                                @onclick='@(() => CambiarStatus("paused"))'>⏸ Pausadas</button>
                        <button class="view-mode-btn @(statusFilter == null ? "active" : "")" style="background:@(statusFilter == null ? "#1d4ed8" : "transparent"); color:@(statusFilter == null ? "white" : "#374151");"
                                @onclick='@(() => CambiarStatus(null))'>📋 Todas</button>
                    </div>
                    @* 2026-07-10: filtro Tipo/Cuotas ARRIBA (visible, no escondido en el embudo de columna). Opciones dinámicas desde los datos. *@
                    <div style="position:relative; display:inline-block; margin-left:0.5rem;">
                        <button class="view-mode-btn @(TipoCuotasFilterCount > 0 ? "active" : "")"
                                style="background:@(TipoCuotasFilterCount > 0 ? "#7c3aed" : "transparent"); color:@(TipoCuotasFilterCount > 0 ? "white" : "#374151");"
                                @onclick="() => showTipoCuotasFilter = !showTipoCuotasFilter" @onclick:stopPropagation="true">
                            🏷️ Tipo / cuotas @(TipoCuotasFilterCount > 0 ? $"({TipoCuotasFilterCount})" : "") <i class="fa-solid fa-caret-down"></i>
                        </button>
                        @if (showTipoCuotasFilter)
                        {
                            <div class="column-filter-dropdown" @onclick:stopPropagation="true" style="position:absolute; left:0; top:100%; z-index:50;">
                                <div style="font-size:0.72rem; color:#6b7280; font-weight:600; text-transform:uppercase; padding:0.35rem 0.6rem 0.15rem;">Tipo de publicación</div>
                                <div class="filter-checkbox-list">
                                    @foreach (var val in GetUniqueValues("tipo"))
                                    {
                                        var v = val;
                                        <label class="filter-checkbox-item">
                                            <input type="checkbox" checked="@IsCheckboxChecked("tipo", v)" @onchange='() => ToggleCheckboxValue("tipo", v)' /> @v
                                        </label>
                                    }
                                </div>
                                <div style="font-size:0.72rem; color:#6b7280; font-weight:600; text-transform:uppercase; padding:0.35rem 0.6rem 0.15rem; border-top:1px solid #e5e7eb; margin-top:0.25rem;">Cuotas</div>
                                <div class="filter-checkbox-list">
                                    @foreach (var val in GetUniqueValues("cuotas"))
                                    {
                                        var v = val;
                                        <label class="filter-checkbox-item">
                                            <input type="checkbox" checked="@IsCheckboxChecked("cuotas", v)" @onchange='() => ToggleCheckboxValue("cuotas", v)' /> @v
                                        </label>
                                    }
                                </div>
                                @if (TipoCuotasFilterCount > 0)
                                {
                                    <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => { ClearCheckboxFilter("tipo"); ClearCheckboxFilter("cuotas"); }'>Limpiar</button></div>
                                }
                            </div>
                        }
                    </div>
                    @if (viewMode == "flat")
                    {
                        <label title="ON: agrupa familias (FamilyId con varios MLAs) en 1 sola fila — vista catálogo de MeLi. OFF: cada MLA es 1 fila — coincide con el conteo de publicaciones de MeLi web."
                               style="display:inline-flex; align-items:center; gap:0.35rem; padding:0.35rem 0.7rem; margin-left:0.5rem; background:@(agruparFamilias ? "#dbeafe" : "#f3f4f6"); border:1px solid @(agruparFamilias ? "#3b82f6" : "#e5e7eb"); border-radius:6px; cursor:pointer; font-size:0.82rem; color:#374151; user-select:none;">
                            <input type="checkbox" @bind="agruparFamilias" @bind:after="StateHasChanged" />
                            <span>📦 Agrupar familias @(agruparFamilias ? "(ON)" : "(OFF — cada MLA suelto)")</span>
                        </label>
                    }
                    @* 2026-07-17: por defecto se ocultan las "Eliminada" (ya no existen en MeLi). Botón para verlas. *@
                    <button title="Por defecto se ocultan las publicaciones eliminadas (ya no existen en MeLi, quedan solo de historial). Tocá para verlas u ocultarlas."
                            @onclick="() => { mostrarEliminadas = !mostrarEliminadas; InvalidateFilterCache(); }"
                            style="display:inline-flex; align-items:center; gap:0.35rem; padding:0.35rem 0.7rem; margin-left:0.5rem; background:@(mostrarEliminadas ? "#fee2e2" : "#f3f4f6"); border:1px solid @(mostrarEliminadas ? "#dc2626" : "#e5e7eb"); border-radius:6px; cursor:pointer; font-size:0.82rem; color:@(mostrarEliminadas ? "#991b1b" : "#374151"); user-select:none; font-weight:600;">
                        🗑️ @(mostrarEliminadas ? "Ocultar eliminadas" : "Ver eliminadas")
                    </button>
                    @* 2026-07-21: chip de filtro por foto en infracción (aparece solo si el escaneo encontró alguna). *@
                    @if (photoInfractions.Count > 0)
                    {
                        <button title="Mostrar solo las publicaciones con foto en infracción detectadas en el último escaneo."
                                @onclick="() => { filterInfraccionFoto = !filterInfraccionFoto; InvalidateFilterCache(); }"
                                style="display:inline-flex; align-items:center; gap:0.35rem; padding:0.35rem 0.7rem; margin-left:0.5rem; background:@(filterInfraccionFoto ? "#ffedd5" : "#f3f4f6"); border:1px solid @(filterInfraccionFoto ? "#ea580c" : "#e5e7eb"); border-radius:6px; cursor:pointer; font-size:0.82rem; color:@(filterInfraccionFoto ? "#9a3412" : "#374151"); user-select:none; font-weight:600;">
                            🚩 Infracción foto (@photoInfractions.Count)
                        </button>
                    }
                </div>
                <div class="more-filters-wrapper">
                    <button class="more-filters-btn @(GetActiveFilterCount() > 0 ? "has-active" : "")" @onclick="ToggleMoreFilters" @onclick:stopPropagation="true">
                        <i class="fa-solid fa-gear"></i> Más Filtros @(GetActiveFilterCount() > 0 ? $"({GetActiveFilterCount()})" : "") <i class="fa-solid fa-caret-down"></i>
                    </button>
                    @if (showMoreFilters)
                    {
                        @* 2026-06-02: dropdown limpiado — 13 filtros → 5 botones + 2 selectores agrupados. *@
                        <div class="more-filters-dropdown">
                            @* === Los 5 filtros que de verdad usás === *@
                            <button class="more-filters-item @(filterUrgente ? "active" : "")" @onclick="() => { filterUrgente = !filterUrgente; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterUrgente ? "#fee2e2" : "transparent"); color:@(filterUrgente ? "#991b1b" : "inherit"); font-weight:700;">
                                🚨 URGENTE: agotadas (stock 0) o pausadas
                            </button>
                            <button class="more-filters-item @(filterMargenPerdida ? "active" : "")" @onclick="() => { filterMargenPerdida = !filterMargenPerdida; if (filterMargenPerdida) filterMargenBajo = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterMargenPerdida ? "#fee2e2" : "transparent"); color:@(filterMargenPerdida ? "#991b1b" : "inherit"); font-weight:700;">
                                🔴 PÉRDIDA: margen ≤ 0% (vendés bajo costo)
                            </button>
                            <button class="more-filters-item @(filterMargenBajo ? "active" : "")" @onclick="() => { filterMargenBajo = !filterMargenBajo; if (filterMargenBajo) filterMargenPerdida = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterMargenBajo ? "#fed7aa" : "transparent"); color:@(filterMargenBajo ? "#9a3412" : "inherit"); font-weight:700;">
                                🟠 BAJO: margen menor a 15% (revisar)
                            </button>
                            @* 2026-07-18: filtro por rango de margen a elección *@
                            <div class="more-filters-item" @onclick:stopPropagation="true"
                                 style="display:flex; align-items:center; gap:6px; flex-wrap:wrap; @(FilterMargenRangoActivo() ? "background:#e0e7ff; color:#3730a3; font-weight:700;" : "")">
                                <span>📊 Margen entre</span>
                                <input value="@filterMargenDesde" @onchange="(e) => { filterMargenDesde = e.Value?.ToString() ?? string.Empty; InvalidateFilterCache(); }"
                                       placeholder="—" style="width:46px; padding:2px 5px; border:1px solid #cbd5e1; border-radius:4px; text-align:right; font-size:0.82rem;" />
                                <span>% y</span>
                                <input value="@filterMargenHasta" @onchange="(e) => { filterMargenHasta = e.Value?.ToString() ?? string.Empty; InvalidateFilterCache(); }"
                                       placeholder="—" style="width:46px; padding:2px 5px; border:1px solid #cbd5e1; border-radius:4px; text-align:right; font-size:0.82rem;" />
                                <span>%</span>
                                @if (FilterMargenRangoActivo())
                                {
                                    <button @onclick="() => { filterMargenDesde = string.Empty; filterMargenHasta = string.Empty; InvalidateFilterCache(); }"
                                            style="padding:2px 7px; border:1px solid #c7d2fe; border-radius:4px; background:white; color:#3730a3; font-size:0.75rem; cursor:pointer;">✕ Limpiar</button>
                                }
                            </div>
                            <button class="more-filters-item @(filterSinLinkear ? "active" : "")" @onclick="() => { filterSinLinkear = !filterSinLinkear; InvalidateFilterCache(); showMoreFilters = false; }">
                                ⚠ Sin linkear (ningún tipo)
                            </button>
                            @* 2026-07-01: filtros para ajuste masivo — separar las que ya toqué vs vírgenes *@
                            <button class="more-filters-item @(filterConAjuste ? "active" : "")" @onclick="() => { filterConAjuste = !filterConAjuste; if (filterConAjuste) filterSinAjuste = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterConAjuste ? "#d1fae5" : "transparent"); color:@(filterConAjuste ? "#065f46" : "inherit"); font-weight:700;">
                                💵 Con ajuste cargado (% o $)
                            </button>
                            <button class="more-filters-item @(filterSinAjuste ? "active" : "")" @onclick="() => { filterSinAjuste = !filterSinAjuste; if (filterSinAjuste) filterConAjuste = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterSinAjuste ? "#f3f4f6" : "transparent"); color:@(filterSinAjuste ? "#374151" : "inherit"); font-weight:700;">
                                ○ Sin ajuste (vírgenes)
                            </button>
                            @* 2026-07-02: publis con objetivo cargado y ganancia real fuera de ±2 pt *@
                            <button class="more-filters-item @(filterDesviadaObjetivo ? "active" : "")" @onclick="() => { filterDesviadaObjetivo = !filterDesviadaObjetivo; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterDesviadaObjetivo ? "#fef3c7" : "transparent"); color:@(filterDesviadaObjetivo ? "#92400e" : "inherit"); font-weight:700;">
                                🎯 Desviadas del objetivo (±2 pt)
                            </button>
                            <button class="more-filters-item @(filterPromo ? "active" : "")" @onclick="() => { TogglePromoFilter(); showMoreFilters = false; }">
                                <i class="fa-solid fa-tag"></i> En promoción
                            </button>
                            <button class="more-filters-item @(IsCuentaMe1Filtered() ? "active" : "")" @onclick="() => { ToggleCuentaMe1Filter(); showMoreFilters = false; }"
                                    style="background:@(IsCuentaMe1Filtered() ? "#dbeafe" : "transparent"); color:@(IsCuentaMe1Filtered() ? "#1e40af" : "inherit"); font-weight:700;">
                                🛒 Solo cuenta me1
                            </button>
                            <button class="more-filters-item @(filterCatalogo ? "active" : "")" @onclick="() => { filterCatalogo = !filterCatalogo; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterCatalogo ? "#fef9c3" : "transparent"); color:@(filterCatalogo ? "#854d0e" : "inherit"); font-weight:700;">
                                📋 Solo catálogo (las amarillas)
                            </button>

                            @* === Selector: Tipo de envío === *@
                            <div style="border-top: 1px solid #e5e7eb; margin: 0.5rem 0 0.25rem 0; padding: 0.5rem 0.75rem 0.25rem 0.75rem; font-size: 0.75rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">📦 Tipo de envío</div>
                            <div style="display:flex; gap:0.25rem; padding: 0 0.5rem 0.5rem 0.5rem;">
                                <button class="@(!filterFull && !filterNoFull ? "active" : "")" @onclick="() => { filterFull = false; filterNoFull = false; InvalidateFilterCache(); }"
                                        style="flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(!filterFull && !filterNoFull ? "#dbeafe" : "white"); color:@(!filterFull && !filterNoFull ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Todo</button>
                                <button class="@(filterFull ? "active" : "")" @onclick="() => { filterFull = true; filterNoFull = false; InvalidateFilterCache(); }"
                                        style="flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterFull ? "#dbeafe" : "white"); color:@(filterFull ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Solo Full</button>
                                <button class="@(filterNoFull ? "active" : "")" @onclick="() => { filterNoFull = true; filterFull = false; InvalidateFilterCache(); }"
                                        style="flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterNoFull ? "#dbeafe" : "white"); color:@(filterNoFull ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Solo NO Full</button>
                            </div>

                            @* === 2026-06-12: Ordenar por (precio / vendidos) === *@
                            <div style="border-top: 1px solid #e5e7eb; margin: 0.25rem 0 0.25rem 0; padding: 0.5rem 0.75rem 0.25rem 0.75rem; font-size: 0.75rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">↕ Ordenar por</div>
                            <div style="display:flex; gap:0.25rem; padding: 0 0.5rem 0.5rem 0.5rem; flex-wrap:wrap;">
                                <button @onclick="() => { sortColumn = null; InvalidateFilterCache(); showMoreFilters = false; }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn is null ? "#dbeafe" : "white"); color:@(sortColumn is null ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Por defecto</button>
                                <button @onclick='() => { sortColumn = "precio"; sortAsc = true; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "precio" && sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "precio" && sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">💲 Menor precio</button>
                                <button @onclick='() => { sortColumn = "precio"; sortAsc = false; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "precio" && !sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "precio" && !sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">💲 Mayor precio</button>
                                <button @onclick='() => { sortColumn = "vendidos"; sortAsc = false; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "vendidos" && !sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "vendidos" && !sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">🔥 Más vendido</button>
                                <button @onclick='() => { sortColumn = "vendidos"; sortAsc = true; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "vendidos" && sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "vendidos" && sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">❄ Menos vendido</button>
                            </div>

                            @* === Selector: Estado de push de stock === *@
                            <div style="border-top: 1px solid #e5e7eb; margin: 0.25rem 0 0.25rem 0; padding: 0.5rem 0.75rem 0.25rem 0.75rem; font-size: 0.75rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">🔄 Estado de push de stock</div>
                            <div style="display:flex; gap:0.25rem; padding: 0 0.5rem 0.5rem 0.5rem; flex-wrap:wrap;">
                                <button @onclick="() => { filterStockPushNunca = false; filterStockPushOk = false; filterStockPushViejo = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(!filterStockPushNunca && !filterStockPushOk && !filterStockPushViejo ? "#dbeafe" : "white"); color:@(!filterStockPushNunca && !filterStockPushOk && !filterStockPushViejo ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Todo</button>
                                <button @onclick="() => { filterStockPushNunca = true; filterStockPushOk = false; filterStockPushViejo = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterStockPushNunca ? "#fee2e2" : "white"); color:@(filterStockPushNunca ? "#991b1b" : "#374151"); font-size:0.8125rem; cursor:pointer;">🔴 Nunca</button>
                                <button @onclick="() => { filterStockPushOk = true; filterStockPushNunca = false; filterStockPushViejo = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterStockPushOk ? "#d1fae5" : "white"); color:@(filterStockPushOk ? "#065f46" : "#374151"); font-size:0.8125rem; cursor:pointer;">🟢 Reciente (≤7d)</button>
                                <button @onclick="() => { filterStockPushViejo = true; filterStockPushNunca = false; filterStockPushOk = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterStockPushViejo ? "#fef3c7" : "white"); color:@(filterStockPushViejo ? "#92400e" : "#374151"); font-size:0.8125rem; cursor:pointer;">🟡 Viejo (+7d)</button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (selectedItems.Count > 0)
            {
                <div class="bulk-actions-bar">
                    <span><strong>@selectedItems.Count</strong> publicaciones seleccionadas</span>
                    @* 2026-07-01: modal unificado (Fase B + C). Al pie 2 botones: solo guardar o guardar+publicar. *@
                    <button class="btn btn-sm" @onclick="AbrirBulkAjusteModal"
                            style="background:#16a34a; color:white; border:1px solid #15803d; font-weight:600;"
                            title="Modificar precios de las publis tildadas: ver preview y elegir si solo guardás o publicás en MeLi ya">
                        💵 Ajustar precios en lote
                    </button>
                    @* 2026-07-02: refresh de comisiones SELECTIVO (sin esperar el bulk de 3h). *@
                    <button class="btn btn-sm" @onclick="RefrescarComisionesSeleccionadas" disabled="@refrescandoSeleccion"
                            style="background:#7c3aed; color:white; border:1px solid #6d28d9; font-weight:600;"
                            title="Actualiza las comisiones reales de MeLi solo para las publis tildadas (rápido)">
                        @(refrescandoSeleccion ? "⏳ Refrescando..." : "💰 Refrescar comisiones (tildadas)")
                    </button>
                    <button class="btn btn-primary btn-sm" @onclick="BulkCreateProducts">
                        <i class="fa-solid fa-box"></i> Crear productos
                    </button>
                    <button class="btn btn-danger btn-sm" @onclick="ShowBulkDeleteModal">
                        <i class="fa-solid fa-trash"></i> Eliminar seleccionadas
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="ClearSelection">
                        Deseleccionar
                    </button>
                </div>
            }

            @if (viewMode == "sincro")
            {
                <div style="margin-top:1rem;">
                    <SincroMeliPanel />
                </div>
            }
            else
            {
                @* 2026-06-02: Controles de paginación arriba (solo vista "flat") *@
                @if (viewMode == "flat")
                {
                    var totalRows = GetGroupedRows().Count;
                    var totalPages = GetTotalPages();
                    var rangoDesde = totalRows == 0 ? 0 : (currentPage - 1) * pageSize + 1;
                    var rangoHasta = Math.Min(currentPage * pageSize, totalRows);
                    <div class="pagination-bar" style="display:flex; align-items:center; gap:0.75rem; padding:0.5rem 0.75rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; margin:0.5rem 0; flex-wrap:wrap; font-size:0.875rem;">
                        <span style="font-weight:500; color:#374151;">
