    private async Task AbrirPiso50(GroupedRow grp)
    {
        piso50ItemIds = grp.Variants.Select(v => v.Id).Distinct().ToList();
        piso50FamilyName = grp.Variants.FirstOrDefault()?.FamilyName ?? grp.Variants.FirstOrDefault()?.Title ?? "familia";
        piso50Detalles = new();
        showPiso50Modal = true; piso50Loading = true;
        StateHasChanged();
        try
        {
            var (resp, err) = await Api.BulkPrecioPorGananciaAsync(new ApiClient.BulkPrecioPorGananciaRequest(
                piso50ItemIds, Piso50Pct, "99", false, false, SoloPiso: true, DryRun: true));
            if (err != null) ToastService.Error(err);
            else piso50Detalles = resp?.Detalles ?? new();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { piso50Loading = false; StateHasChanged(); }
    }

    private async Task AplicarPiso50()
    {
        if (piso50Aplicando) return;
        piso50Aplicando = true; StateHasChanged();
        try
        {
            var (resp, err) = await Api.BulkPrecioPorGananciaAsync(new ApiClient.BulkPrecioPorGananciaRequest(
                piso50ItemIds, Piso50Pct, "99", false, PublicarEnMeli: true, SoloPiso: true, DryRun: false));
            if (err != null) { ToastService.Error(err); }
            else
            {
                ToastService.Success($"Piso 50% aplicado: {resp?.Guardados ?? 0} actualizadas, {resp?.Pusheados ?? 0} pusheadas a MeLi.");
                showPiso50Modal = false;
                await LoadItems();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { piso50Aplicando = false; StateHasChanged(); }
    }

