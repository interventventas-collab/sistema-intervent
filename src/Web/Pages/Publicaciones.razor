    private void BulkCreateProducts()
    {
        if (!selectedItems.Any()) return;
        bulkCreateTotal = selectedItems.Count;
        bulkCreateCurrent = 0;
        bulkCreateCreated = 0;
        bulkCreateSkipped = 0;
        bulkCreateErrors.Clear();
        showBulkCreateModal = true;
    }

    private void CloseBulkCreateModal()
    {
        showBulkCreateModal = false;
        if (bulkCreateCurrent > 0)
        {
            selectedItems.Clear();
            _ = LoadItems();
        }
    }

    private async Task ConfirmBulkCreate()
    {
        isBulkCreating = true;
        StateHasChanged();

        var ids = selectedItems.ToList();
        foreach (var id in ids)
        {
            try
            {
                var result = await Api.CreateProductFromItemAsync(id);
                if (result != null)
                {
                    bulkCreateCreated += result.Created;
                    bulkCreateSkipped += result.Skipped;
                    foreach (var msg in result.SkippedMessages)
                        bulkCreateErrors.Add(msg);
                }
            }
            catch (Exception ex)
            {
                bulkCreateErrors.Add($"Error: {ex.Message}");
            }

            bulkCreateCurrent++;
            StateHasChanged();
            await Task.Delay(50); // Small delay for UI update
        }

        isBulkCreating = false;
        StateHasChanged();

        if (bulkCreateCreated > 0)
            ToastService.Success($"Se crearon {bulkCreateCreated} productos");
    }

