    private async Task ToggleSyncStockFicha()
    {
        if (selectedItem is null || isSavingSyncStock) return;
        isSavingSyncStock = true;
        StateHasChanged();
        try
        {
            var nuevo = !selectedItem.SyncStock;
            // Mandamos la config completa actual para no pisar los otros campos
            var (cfg, err) = await Api.ActualizarSyncConfigAsync(selectedItem.MeliItemId, new UpdateSyncConfigRequest
            {
                SyncStock = nuevo,
                SyncPrecio = selectedItem.SyncPrecio,
                AjustePct = selectedItem.AjustePct,
                AjusteFijo = selectedItem.AjusteFijo,
                AjusteRedondeo = selectedItem.AjusteRedondeo
