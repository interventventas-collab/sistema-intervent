    private bool showAnalisisMargen;
    private bool analisisMargenLoading;
    private string? analisisMargenError;
    private string? analisisMargenFamilyIdActivo;
    private decimal analisisMargenComisionCat = 13m;
    private decimal analisisMargenEnvioCosto = 7470m;
    private AnalisisMargenFamiliaDto? analisisMargenData;

    private async Task AbrirAnalisisMargen(string familyId)
    {
        analisisMargenFamilyIdActivo = familyId;
        showAnalisisMargen = true;
        await CargarAnalisisMargen();
    }

    private void CerrarAnalisisMargen()
    {
        showAnalisisMargen = false;
        analisisMargenData = null;
        analisisMargenError = null;
        analisisMargenFamilyIdActivo = null;
    }

    private async Task CargarAnalisisMargen()
    {
        if (string.IsNullOrEmpty(analisisMargenFamilyIdActivo)) return;
        analisisMargenLoading = true;
        analisisMargenError = null;
        StateHasChanged();
        try
        {
            var resp = await Api.GetAnalisisMargenFamiliaAsync(
                analisisMargenFamilyIdActivo,
                comisionCategoriaPct: analisisMargenComisionCat,
                envioGratisCostoEstimado: analisisMargenEnvioCosto);
            if (resp.IsSuccessStatusCode)
            {
                analisisMargenData = await resp.Content.ReadFromJsonAsync<AnalisisMargenFamiliaDto>();
            }
            else
            {
                analisisMargenError = "No se pudo cargar el análisis: " + await resp.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex) { analisisMargenError = ex.Message; }
        finally { analisisMargenLoading = false; StateHasChanged(); }
    }

