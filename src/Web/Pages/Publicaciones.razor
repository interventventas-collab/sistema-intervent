                StateHasChanged();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    // 2026-06-11: helpers de comisiones MeLi para mostrar tipo/cuotas/neto en filas hijas
    // (mismos valores que usa el backend MeliComisionHelper.cs)
    private const decimal COMISION_CATEGORIA_DEFAULT_PCT = 13m;
    private const decimal COSTO_ENVIO_GRATIS_ESTIMADO = 7470m;
    private const decimal CARGO_FIJO_UMBRAL = 30000m;
    private const decimal CARGO_FIJO_MONTO = 2500m;

    private static decimal GetCargoFijoMla(decimal precioMeLi)
        => precioMeLi < CARGO_FIJO_UMBRAL ? CARGO_FIJO_MONTO : 0m;

    private static decimal GetFinanciacionPct(string? installmentTag)
    {
        if (string.IsNullOrWhiteSpace(installmentTag)) return 0m;
        var l = installmentTag.ToLowerInvariant();
        if (l.Contains("12x_campaign")) return 19.2m;
        if (l.Contains("9x_campaign")) return 15.7m;
        if (l.Contains("6x_campaign")) return 12.3m;
        if (l.Contains("3x_campaign")) return 8.4m;
        if (l.Contains("co-funded")) return 5m;
        return 0m;
    }

    private static decimal CalcularComisionTotalPct(string? installmentTag)
        => COMISION_CATEGORIA_DEFAULT_PCT + GetFinanciacionPct(installmentTag);

    private static decimal CalcularNetoMla(MeliItemDto v)
    {
        // 2026-06-19: si tenemos sale_fee real de la API de MeLi (cacheado) y el precio
        // no se movio mucho desde que se calculo, usamos eso — es la verdad oficial.
        // Sino, fallback a la formula estimada (comision % + cargo fijo).
        if (v.SaleFeeAmountReal.HasValue && v.SaleFeeAmountReal.Value > 0
            && v.SaleFeePriceSnapshot.HasValue
            && Math.Abs(v.Price - v.SaleFeePriceSnapshot.Value) / Math.Max(v.Price, 1m) < 0.05m)
        {
            // Aplicamos el sale_fee REAL. El shipping del vendedor (envio gratis) ya esta
            // dentro del sale_fee en la API listing_prices, asi que NO se vuelve a restar.
            return Math.Round(v.Price - v.SaleFeeAmountReal.Value, 0);
        }
        // Fallback: formula vieja (estimacion).
        var totalPct = CalcularComisionTotalPct(v.InstallmentTag);
        var comision = Math.Round(v.Price * totalPct / 100m, 2);
        var cargoFijo = GetCargoFijoMla(v.Price);
        var shipping = v.FreeShipping ? COSTO_ENVIO_GRATIS_ESTIMADO : 0m;
        return Math.Round(v.Price - comision - cargoFijo - shipping, 0);
    }

    /// <summary>2026-06-11: ganancia real = neto MeLi (lo que te depositan) - costo del producto.
    /// Si no hay costo cargado en el sistema, devuelve null.
    /// 2026-07-01: dividimos el neto por 1,21 para descontar el IVA (que después le pasás a AFIP).
    /// El costo del sistema está sin IVA, ahora se compara con el mismo mundo.</summary>
    private static decimal? CalcularGananciaRealMla(MeliItemDto v)
    {
        if (!v.ProductCost.HasValue || v.ProductCost.Value <= 0m) return null;
        var netoConIva = CalcularNetoMla(v);
        var netoSinIva = netoConIva / (1m + IvaAlicuota);
        return Math.Round(netoSinIva - v.ProductCost.Value, 0);
    }

    /// <summary>2026-06-11: margen % sobre el costo. Ej: gano $6.000 / costo $10.000 = 60%</summary>
    private static decimal? CalcularMargenPctMla(MeliItemDto v)
    {
        if (!v.ProductCost.HasValue || v.ProductCost.Value <= 0m) return null;
        var ganancia = CalcularGananciaRealMla(v);
        if (!ganancia.HasValue) return null;
        return Math.Round(ganancia.Value / v.ProductCost.Value * 100m, 1);
    }

    // 2026-07-01: Premium (gold_pro) por default = 6 cuotas al mismo precio. Si el InstallmentTag no
    // está cacheado, asumimos ese default (coincide con la ficha individual y con MeLi web).
    private static string GetCuotasLabel(string? installmentTag, string? listingTypeId = null)
    {
        if (string.IsNullOrWhiteSpace(installmentTag))
            return listingTypeId == "gold_pro" ? "6 cuotas" : "Sin cuotas";
        var l = installmentTag.ToLowerInvariant();
        if (l.Contains("12x_campaign")) return "12 cuotas";
        if (l.Contains("9x_campaign")) return "9 cuotas";
        if (l.Contains("6x_campaign")) return "6 cuotas";
        if (l.Contains("3x_campaign")) return "3 cuotas";
        if (l.Contains("co-funded")) return "3-12 c/int bajo";
        return listingTypeId == "gold_pro" ? "6 cuotas" : "Sin cuotas";
    }

    // ==================================================
    // 2026-06-11: Análisis de margen por familia (modal reutilizable)
    // ==================================================
    private bool showAnalisisMargen;
    private bool analisisMargenLoading;
    private string? analisisMargenError;
    private string? analisisMargenFamilyIdActivo;
    private decimal analisisMargenComisionCat = 13m;
    private decimal analisisMargenEnvioCosto = 7470m;
    private AnalisisMargenFamiliaDto? analisisMargenData;

    private async Task AbrirAnalisisMargen(string familyId)
    {
        analisisMargenFamilyIdActivo = familyId;
        showAnalisisMargen = true;
        await CargarAnalisisMargen();
    }

    private void CerrarAnalisisMargen()
    {
        showAnalisisMargen = false;
        analisisMargenData = null;
        analisisMargenError = null;
        analisisMargenFamilyIdActivo = null;
    }

    private async Task CargarAnalisisMargen()
    {
        if (string.IsNullOrEmpty(analisisMargenFamilyIdActivo)) return;
        analisisMargenLoading = true;
        analisisMargenError = null;
        StateHasChanged();
        try
        {
            var resp = await Api.GetAnalisisMargenFamiliaAsync(
                analisisMargenFamilyIdActivo,
                comisionCategoriaPct: analisisMargenComisionCat,
                envioGratisCostoEstimado: analisisMargenEnvioCosto);
            if (resp.IsSuccessStatusCode)
            {
                analisisMargenData = await resp.Content.ReadFromJsonAsync<AnalisisMargenFamiliaDto>();
            }
            else
            {
                analisisMargenError = "No se pudo cargar el análisis: " + await resp.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex) { analisisMargenError = ex.Message; }
        finally { analisisMargenLoading = false; StateHasChanged(); }
    }

    private async Task OnCambioComision(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            analisisMargenComisionCat = v;
            await CargarAnalisisMargen();
        }
    }

    private async Task OnCambioEnvio(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            analisisMargenEnvioCosto = v;
            await CargarAnalisisMargen();
        }
    }

    private async Task CambiarOverrideCuotas(string mlaId, string? nuevoTag)
    {
        try
        {
            var resp = await Api.OverrideCuotasMlaAsync(mlaId, nuevoTag);
            if (resp.IsSuccessStatusCode)
            {
                await CargarAnalisisMargen();
                ToastService.Success("Cuotas actualizadas — neto recalculado.");
            }
            else
            {
                ToastService.Error("No se pudo guardar: " + await resp.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

