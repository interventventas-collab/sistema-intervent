@if (showBulkCreateModal)
{
    <div class="modal-overlay">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h4 style="margin: 0;">Crear productos</h4>
                @if (!isBulkCreating)
                {
                    <button class="btn-close" @onclick="CloseBulkCreateModal">&times;</button>
                }
            </div>
            <div class="modal-body">
                @if (!isBulkCreating && bulkCreateCurrent == 0)
                {
                    <p>Se van a crear productos para <strong>@selectedItems.Count</strong> publicaciones seleccionadas.</p>
                    <p style="color: #6b7280; font-size: 0.85rem;">Si ya existe un producto con el mismo SKU, se vincula automaticamente.</p>
                }
                else
                {
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.85rem;">
                            <span>@(isBulkCreating ? "Procesando..." : "Completado")</span>
                            <span>@bulkCreateCurrent / @bulkCreateTotal</span>
                        </div>
                        <div style="background: #e5e7eb; border-radius: 8px; height: 8px; overflow: hidden;">
                            <div style="background: #6366f1; height: 100%; border-radius: 8px; transition: width 0.3s; width: @(bulkCreateTotal > 0 ? (bulkCreateCurrent * 100 / bulkCreateTotal) : 0)%;"></div>
                        </div>
                    </div>

                    <div style="display: flex; gap: 1.5rem; font-size: 0.9rem; margin-bottom: 0.5rem;">
                        <span style="color: #059669;">@bulkCreateCreated creados</span>
                        <span style="color: #d97706;">@bulkCreateSkipped omitidos</span>
                        @if (bulkCreateErrors.Any())
                        {
                            <span style="color: #dc2626;">@bulkCreateErrors.Count errores</span>
                        }
                    </div>

                    @if (bulkCreateErrors.Any() && !isBulkCreating)
                    {
                        <div style="max-height: 120px; overflow-y: auto; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 0.8rem; color: #991b1b; margin-top: 0.5rem;">
                            @foreach (var err in bulkCreateErrors)
                            {
                                <div>@err</div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                @if (!isBulkCreating && bulkCreateCurrent == 0)
                {
                    <button class="btn btn-secondary" @onclick="CloseBulkCreateModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ConfirmBulkCreate">Confirmar</button>
                }
                else if (!isBulkCreating)
                {
                    <button class="btn btn-primary" @onclick="CloseBulkCreateModal">Cerrar</button>
                }
            </div>
        </div>
    </div>
}

@if (showPiso50Modal)
{
    <div class="modal-overlay" @onclick="() => { if(!piso50Aplicando) showPiso50Modal = false; }">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 760px;">
            <div class="modal-header" style="background:#16a34a; color:white;">
                <h3 style="margin:0;">🛡️ Poner piso de 50% — @piso50FamilyName</h3>
                <button class="btn-close" @onclick="() => { if(!piso50Aplicando) showPiso50Modal = false; }" style="color:white;">&times;</button>
            </div>
            <div class="modal-body">
                @if (piso50Loading)
                {
                    <p class="text-muted">Calculando la vista previa (usa la cuenta real: comisión + cuotas + envío + IVA)...</p>
                }
                else
                {
                    <div style="background:#eff6ff; border:1px solid #2563eb; border-radius:8px; padding:0.7rem; margin-bottom:0.7rem; font-size:0.85rem;">
                        <b>@Piso50Cambian.Count</b> van a SUBIR a 50% · <b>@Piso50YaOk.Count</b> ya están en 50% o más (no se tocan)@(Piso50Problemas.Count > 0 ? $" · {Piso50Problemas.Count} sin costo/problema" : "")
                        <div style="font-size:0.78rem; color:#4b5563; margin-top:0.3rem;">Todavía NO se aplicó nada. Mirá y confirmá.</div>
                    </div>
                    @if (Piso50Cambian.Count > 0)
                    {
                        <div style="max-height:300px; overflow:auto; border:1px solid #e5e7eb; border-radius:8px;">
                            <table class="data-table" style="font-size:0.8rem;">
                                <thead><tr><th>Publicación</th><th style="text-align:right;">Precio hoy</th><th></th><th style="text-align:right;">Precio nuevo</th><th style="text-align:right;">Margen</th></tr></thead>
                                <tbody>
                                    @foreach (var d in Piso50Cambian)
                                    {
                                        <tr>
                                            <td style="max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@d.Titulo</td>
                                            <td style="text-align:right; color:#9ca3af; text-decoration:line-through;">$@((d.PrecioActual ?? 0).ToString("N0"))</td>
                                            <td style="text-align:center;">→</td>
                                            <td style="text-align:right; font-weight:700; color:#15803d;">$@((d.PrecioNuevo ?? 0).ToString("N0"))</td>
                                            <td style="text-align:right; color:#15803d;">@((d.MargenPct ?? 0).ToString("0.#"))%</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Ninguna está por debajo del 50% — no hay nada que subir. 🎉</p>
                    }
                    @if (Piso50Problemas.Count > 0)
                    {
                        <p style="font-size:0.78rem; color:#b45309; margin-top:0.5rem;">⚠ @Piso50Problemas.Count sin costo cargado o con problema — esas no se pueden calcular (revisá el costo del producto).</p>
                    }
                    <p style="font-size:0.78rem; color:#991b1b; margin-top:0.6rem;">Al confirmar, se cambia el precio REAL en MercadoLibre de las que suben.</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showPiso50Modal = false" disabled="@piso50Aplicando">Cancelar</button>
                <button class="btn" style="background:#16a34a; color:white; border:none;" @onclick="AplicarPiso50" disabled="@(piso50Aplicando || piso50Loading || Piso50Cambian.Count == 0)">
                    @(piso50Aplicando ? "Aplicando y pusheando..." : $"✓ Confirmar y pushear ({Piso50Cambian.Count})")
                </button>
            </div>
        </div>
    </div>
}

