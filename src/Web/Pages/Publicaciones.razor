    protected override async Task OnInitializedAsync()
    {
        SyncProgress.OnChange += OnSyncProgressChanged;
        if (!string.IsNullOrWhiteSpace(BuscarQuery))
            textFilters["titulo"] = BuscarQuery.Trim();
        await LoadItems();
        try { meliAccounts = await Api.GetMeliAccountsAsync(); } catch { }
        // Cargar productos OTROS del sistema para matchear variantes huerfanas por SKU
        try
        {
            var cafeProds = await Api.GetCafeProductosAsync("OTROS") ?? new();
            cafeProdsBySku = cafeProds
                .Where(p => !string.IsNullOrWhiteSpace(p.Sku))
                .GroupBy(p => p.Sku!.ToUpperInvariant())
                .ToDictionary(g => g.Key, g => g.First());
        }
        catch { cafeProdsBySku = new(); }
    }

    /// <summary>Catalogo de productos OTROS del sistema indexado por SKU (uppercase).
    /// Usado para mostrar el match de SKU en filas variante que no tienen CafeProductoId.</summary>
    private Dictionary<string, CafeProductoDto> cafeProdsBySku = new();

    /// <summary>Busca el producto del sistema cuyo SKU matchea el de la variante.</summary>
    private CafeProductoDto? FindMatchByVariantSku(string? sku)
    {
        if (string.IsNullOrWhiteSpace(sku)) return null;
        return cafeProdsBySku.GetValueOrDefault(sku.Trim().ToUpperInvariant());
    }

    private bool _syncReloaded;

    private void OnSyncProgressChanged()
    {
        InvokeAsync(async () =>
        {
            // Auto-reload items once when sync finishes
            if (!_syncReloaded && (SyncProgress.State.Status == "completed" || SyncProgress.State.Status == "error"))
            {
                _syncReloaded = true;
                await LoadItems();
                StateHasChanged();
            }
            else
            {
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        SyncProgress.OnChange -= OnSyncProgressChanged;
    }

