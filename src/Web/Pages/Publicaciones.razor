    private async Task OpenCreateProductFromItem(MeliItemDto item)
    {
        createProductItem = item;
        newProductTitle = item.Title;
        newProductDescription = "";
        newProductBrand = "";
        newProductModel = "";
        newProductSku = item.Sku ?? "";
        newProductCostPrice = 0;
        newProductRetailPrice = item.OriginalPrice ?? item.Price;
        newProductStock = item.AvailableQuantity;
        newProductCostPriceFormatted = FormatPrice(newProductCostPrice);
        newProductRetailPriceFormatted = FormatPrice(newProductRetailPrice);
        newProductPhoto1 = "";
        newProductPhoto2 = "";
        newProductPhoto3 = "";
        showCreateProductModal = true;
        isLoadingDetails = true;
        StateHasChanged();

        try
        {
            var details = await Api.GetMeliItemDetailsAsync(item.MeliItemId);
            if (details is not null)
            {
                if (!string.IsNullOrWhiteSpace(details.Description))
                    newProductDescription = details.Description;
                if (details.Pictures.Count > 0) newProductPhoto1 = details.Pictures[0];
                if (details.Pictures.Count > 1) newProductPhoto2 = details.Pictures[1];
                if (details.Pictures.Count > 2) newProductPhoto3 = details.Pictures[2];
            }
        }
        catch { /* details fetch failed, continue with basic data */ }
        finally
        {
            isLoadingDetails = false;
            StateHasChanged();
        }
    }

