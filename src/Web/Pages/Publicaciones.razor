@if (showBulkCreateModal)
{
    <div class="modal-overlay">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h4 style="margin: 0;">Crear productos</h4>
                @if (!isBulkCreating)
                {
                    <button class="btn-close" @onclick="CloseBulkCreateModal">&times;</button>
                }
            </div>
            <div class="modal-body">
                @if (!isBulkCreating && bulkCreateCurrent == 0)
                {
                    <p>Se van a crear productos para <strong>@selectedItems.Count</strong> publicaciones seleccionadas.</p>
                    <p style="color: #6b7280; font-size: 0.85rem;">Si ya existe un producto con el mismo SKU, se vincula automaticamente.</p>
                }
                else
                {
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.85rem;">
                            <span>@(isBulkCreating ? "Procesando..." : "Completado")</span>
                            <span>@bulkCreateCurrent / @bulkCreateTotal</span>
                        </div>
                        <div style="background: #e5e7eb; border-radius: 8px; height: 8px; overflow: hidden;">
                            <div style="background: #6366f1; height: 100%; border-radius: 8px; transition: width 0.3s; width: @(bulkCreateTotal > 0 ? (bulkCreateCurrent * 100 / bulkCreateTotal) : 0)%;"></div>
                        </div>
                    </div>

                    <div style="display: flex; gap: 1.5rem; font-size: 0.9rem; margin-bottom: 0.5rem;">
                        <span style="color: #059669;">@bulkCreateCreated creados</span>
                        <span style="color: #d97706;">@bulkCreateSkipped omitidos</span>
                        @if (bulkCreateErrors.Any())
                        {
                            <span style="color: #dc2626;">@bulkCreateErrors.Count errores</span>
                        }
                    </div>

                    @if (bulkCreateErrors.Any() && !isBulkCreating)
                    {
                        <div style="max-height: 120px; overflow-y: auto; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 0.8rem; color: #991b1b; margin-top: 0.5rem;">
                            @foreach (var err in bulkCreateErrors)
                            {
                                <div>@err</div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                @if (!isBulkCreating && bulkCreateCurrent == 0)
                {
                    <button class="btn btn-secondary" @onclick="CloseBulkCreateModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ConfirmBulkCreate">Confirmar</button>
                }
                else if (!isBulkCreating)
                {
                    <button class="btn btn-primary" @onclick="CloseBulkCreateModal">Cerrar</button>
                }
            </div>
        </div>
    </div>
}

@if (showSyncByIdModal)
{
    <div class="modal-overlay" @onclick="CloseSyncByIdModal">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h4 style="margin: 0;">Traer publicaciones por ID</h4>
                <button class="btn-close" @onclick="CloseSyncByIdModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #6b7280; margin-bottom: 0.75rem;">
                    Ingresa uno o varios IDs separados por coma (solo el numero).<br/>
                    Ejemplo: <strong>123456789, 987654321, 555444333</strong>
                </p>
                <div class="form-group">
                    <textarea class="form-control" rows="3" placeholder="123456789, 987654321, ..."
                              @bind="syncByIdInput" @bind:event="oninput"
                              disabled="@isSyncingById"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(syncByIdError))
                {
                    <p style="color: #dc3545; font-size: 0.85rem; margin: 0;">@syncByIdError</p>
                }
                @if (syncByIdResults is not null)
                {
                    <div style="margin-top: 0.75rem; padding: 0.6rem 0.75rem; border-radius: 6px; background: #f3f4f6; font-size: 0.85rem;">
                        <strong>@syncByIdResults.TotalSynced</strong> traidas, <strong style="color:@(syncByIdResults.TotalErrors > 0 ? "#dc3545" : "#374151")">@syncByIdResults.TotalErrors</strong> con error (de @syncByIdResults.TotalRequested solicitados).
                    </div>
                    @if (syncByIdResults.Results.Any(r => !string.IsNullOrEmpty(r.Error)))
                    {
                        <div style="margin-top: 0.5rem; max-height: 180px; overflow-y: auto; font-size: 0.8rem;">
                            @foreach (var r in syncByIdResults.Results.Where(x => !string.IsNullOrEmpty(x.Error)))
                            {
                                <div style="padding: 0.3rem 0.5rem; border-bottom: 1px solid #e5e7eb;">
                                    <strong>@r.MeliItemId</strong>: <span style="color:#dc3545;">@r.Error</span>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseSyncByIdModal" disabled="@isSyncingById">@(syncByIdResults is not null ? "Cerrar" : "Cancelar")</button>
                <button class="btn btn-primary" @onclick="ConfirmSyncById" disabled="@(isSyncingById || string.IsNullOrWhiteSpace(syncByIdInput))">
                    @(isSyncingById ? "Trayendo..." : "Traer")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar publicaciones</h4>
                <button class="btn-close" @onclick="CloseDeleteModal" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>¿Estas seguro de eliminar <strong>@selectedItems.Count</strong> publicaciones de la base de datos?</p>
                <div style="background: #d4edda; border: 1px solid #28a745; border-radius: 8px; padding: 0.75rem; margin-top: 0.75rem;">
                    <span style="color: #155724;"><strong>Importante:</strong> Solo se eliminan de esta aplicacion. NO se eliminan de MercadoLibre.</span>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseDeleteModal" disabled="@isDeleting">Cancelar</button>
                <button class="btn btn-danger" @onclick="ConfirmBulkDelete" disabled="@isDeleting">
                    @(isDeleting ? "Eliminando..." : "Eliminar")
                </button>
            </div>
        </div>
    </div>
}


@if (showCreateProductModal && createProductItem is not null)
{
    <div class="modal-overlay" @onclick="CloseCreateProductModal">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin:0; font-size:1rem;">Crear Producto desde Publicacion</h3>
                <button class="modal-close" @onclick="CloseCreateProductModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.8rem; color: #6b7280; margin-bottom: 1rem;">
                    Publicacion: <strong>@createProductItem.MeliItemId</strong> - @Truncate(createProductItem.Title, 60)
                </p>
                @if (isLoadingDetails)
                {
                    <p style="font-size: 0.8rem; color: #3b82f6; margin-bottom: 0.5rem;">Cargando imagenes y descripcion de MercadoLibre...</p>
                }
                @if (!string.IsNullOrEmpty(newProductPhoto1) || !string.IsNullOrEmpty(newProductPhoto2) || !string.IsNullOrEmpty(newProductPhoto3))
                {
                    <div class="create-product-images">
                        @if (!string.IsNullOrEmpty(newProductPhoto1))
                        {
                            <img src="@newProductPhoto1" alt="Foto 1" class="create-product-img" />
                        }
                        @if (!string.IsNullOrEmpty(newProductPhoto2))
                        {
                            <img src="@newProductPhoto2" alt="Foto 2" class="create-product-img" />
                        }
                        @if (!string.IsNullOrEmpty(newProductPhoto3))
                        {
                            <img src="@newProductPhoto3" alt="Foto 3" class="create-product-img" />
                        }
                    </div>
                }
                <div class="form-group">
                    <label class="form-label">Titulo *</label>
                    <input type="text" class="form-input" @bind="newProductTitle" />
                </div>
                <div class="form-group">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-input" rows="3" @bind="newProductDescription"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">SKU</label>
                        <input type="text" class="form-input" @bind="newProductSku" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Marca</label>
                        <input type="text" class="form-input" @bind="newProductBrand" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Modelo</label>
                        <input type="text" class="form-input" @bind="newProductModel" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Precio de Costo</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #333;">$</span>
                            <input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px;" value="@newProductCostPriceFormatted" @oninput="OnCostPriceInput" inputmode="decimal" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">PVP</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 1.1rem; font-weight: 700; color: #333;">$</span>
                            <input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right; padding-left: 28px;" value="@newProductRetailPriceFormatted" @oninput="OnRetailPriceInput" inputmode="decimal" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock</label>
                        <input type="number" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right;" @bind="newProductStock" min="0" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseCreateProductModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="CreateProductFromItem" disabled="@isCreatingProduct">
                    @(isCreatingProduct ? "Creando..." : "Crear y Vincular")
                </button>
            </div>
        </div>
    </div>
}

@if (showLinkProductModal && linkProductItem is not null)
{
    <div class="modal-overlay" @onclick="CloseLinkProductModal">
        <div class="modal-card" style="max-width: 480px;" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin:0; font-size:1rem;">Vincular a Producto o Combo</h3>
                <button class="modal-close" @onclick="CloseLinkProductModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.8rem; color: #6b7280; margin-bottom: 0.7rem;">
                    Publicacion: <strong>@linkProductItem.MeliItemId</strong>
                </p>

                @* Tabs: Producto / Combo *@
                <div style="display:flex; gap:0.4rem; margin-bottom: 0.8rem;">
                    <button class="btn @(linkTab == "product" ? "btn-primary" : "btn-secondary")" style="font-size:0.85rem; padding:0.4rem 0.8rem;"
                            @onclick='() => linkTab = "product"'>
                        📦 Producto
                    </button>
                    <button class="btn @(linkTab == "combo" ? "btn-primary" : "btn-secondary")" style="font-size:0.85rem; padding:0.4rem 0.8rem;"
                            @onclick='() => linkTab = "combo"'>
                        🎁 Combo
                    </button>
                </div>

                @if (linkTab == "product")
                {
                    @if (allProducts is null || !allProducts.Any())
                    {
                        <p class="text-muted">No hay productos creados. Primero crea un producto.</p>
                    }
                    else
                    {
                        <div class="form-group">
                            <label class="form-label">Buscar producto</label>
                            <input type="text" class="form-input" placeholder="Escribi para filtrar..." @oninput="OnLinkSearchInput" />
