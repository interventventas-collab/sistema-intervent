    /// <summary>Preview client-side: precio actual en MeLi vs precio con ajuste cargado. Solo publis con ajuste.</summary>
    private BulkPushPreviewResult GetBulkPushPreview()
    {
        var filas = new List<BulkPushPreviewRow>();
        int conAjuste = 0, sinAjuste = 0;
        decimal deltaTotal = 0m;
        if (items is null) return new BulkPushPreviewResult(filas, 0, 0, 0m);

        foreach (var id in selectedItems)
        {
            var it = items.FirstOrDefault(x => x.Id == id);
            if (it is null) continue;
            if (!HasAjuste(it))
            {
                sinAjuste++;
                continue;
            }
            var precioNuevo = CalcularPrecioConAjuste(it);
            if (!precioNuevo.HasValue) continue;
            conAjuste++;
            var delta = precioNuevo.Value - it.Price;
            deltaTotal += delta;
            if (filas.Count < 20)
            {
                filas.Add(new BulkPushPreviewRow(
                    it.Title,
                    Math.Round(it.Price, 0),
                    Math.Round(precioNuevo.Value, 0),
                    Math.Round(delta, 0)));
            }
        }
        return new BulkPushPreviewResult(filas, conAjuste, sinAjuste, Math.Round(deltaTotal, 0));
    }

