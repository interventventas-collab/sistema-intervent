        else
        {
            var ago = DateTime.UtcNow - last.Value;
            var localDate = last.Value.ToArTime();
            string ageStr = ago.TotalMinutes < 60 ? $"{(int)ago.TotalMinutes}m"
                : ago.TotalHours < 24 ? $"{(int)ago.TotalHours}h"
                : ago.TotalDays < 30 ? $"{(int)ago.TotalDays}d"
                : $"{(int)(ago.TotalDays / 30)}mes";
            if (ago.TotalDays > 7)
            {
                emoji = "🟡"; color = "#92400e"; bg = "#fef3c7";
                label = $"hace {ageStr}";
