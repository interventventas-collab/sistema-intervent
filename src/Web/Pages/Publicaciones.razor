    // ── 2026-07-17: edición a nivel FAMILIA (aplica a todas las variantes de una) desde el panel de la vista Lista ──
    private readonly Dictionary<string, string> _objInputFam = new();
    private readonly HashSet<string> _savingFamObj = new();
    private readonly HashSet<string> _savingFamSincroP = new();
    private readonly HashSet<string> _savingFamSincroS = new();

    private async Task AplicarObjetivoFamilia(GroupedRow grp)
    {
        if (_savingFamObj.Contains(grp.Key)) return;
        _objInputFam.TryGetValue(grp.Key, out var raw);
        if (!decimal.TryParse((raw ?? "").Replace(',', '.'), NumberStyles.Any, CultureInfo.InvariantCulture, out var pct) || pct <= 0)
        { ToastService.Error("Poné un % de objetivo válido"); return; }
        var linkeadas = grp.Variants.Where(v => v.CafeProductoId.HasValue || v.ComponentMappingsCount > 0).ToList();
        if (linkeadas.Count == 0) { ToastService.Error("Ninguna variante de la familia está linkeada a un producto"); return; }
        _savingFamObj.Add(grp.Key);
        StateHasChanged();
        int ok = 0, fail = 0;
        try
        {
            foreach (var v in linkeadas)
            {
                try
                {
                    var (res, err) = await Api.SetObjetivoGananciaAsync(v.MeliItemId, pct, aplicar: true, redondeo: "99");
                    if (err is null && res is not null)
                    {
                        v.GananciaObjetivoPct = res.ObjetivoPct;
                        v.GananciaObjetivoAt = DateTime.UtcNow;
                        v.SyncPrecio = res.SyncPrecio;
                        if (res.PrecioNuevo.HasValue) v.Price = res.PrecioNuevo.Value;
                        ok++;
                    }
                    else fail++;
                }
                catch { fail++; }
            }
            _objInputFam.Remove(grp.Key);
            InvalidateFilterCache();
            if (ok > 0 && fail == 0) ToastService.Success($"🎯 Objetivo {pct.ToString("0.#", argCulture)}% aplicado a {ok} publicaciones de la familia");
            else if (ok > 0) ToastService.Warning($"🎯 Aplicado a {ok}. Fallaron {fail}.");
            else ToastService.Error("No se pudo aplicar a ninguna publicación de la familia");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { _savingFamObj.Remove(grp.Key); StateHasChanged(); }
    }

    private async Task ToggleSincroPrecioFamilia(GroupedRow grp)
    {
        if (_savingFamSincroP.Contains(grp.Key)) return;
        var linkeadas = grp.Variants.Where(v => v.CafeProductoId.HasValue || v.ComponentMappingsCount > 0).ToList();
        if (linkeadas.Count == 0) { ToastService.Error("Ninguna variante está linkeada"); return; }
        var nuevo = !linkeadas.All(v => v.SyncPrecio);
        _savingFamSincroP.Add(grp.Key);
        StateHasChanged();
        int ok = 0, fail = 0;
        try
        {
            foreach (var v in linkeadas)
            {
                try
                {
                    var (cfg, err) = await Api.ActualizarSyncConfigAsync(v.MeliItemId, new UpdateSyncConfigRequest
                    { SyncStock = v.SyncStock, SyncPrecio = nuevo, AjustePct = v.AjustePct, AjusteFijo = v.AjusteFijo, AjusteRedondeo = v.AjusteRedondeo });
                    if (err is null) { v.SyncPrecio = nuevo; ok++; } else fail++;
                }
                catch { fail++; }
            }
            InvalidateFilterCache();
            ToastService.Success($"🏷 Sincro de PRECIO {(nuevo ? "activada" : "desactivada")} en {ok} publicaciones" + (fail > 0 ? $" ({fail} fallaron)" : ""));
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { _savingFamSincroP.Remove(grp.Key); StateHasChanged(); }
    }

    private async Task ToggleSincroStockFamilia(GroupedRow grp)
    {
        if (_savingFamSincroS.Contains(grp.Key)) return;
        var linkeadas = grp.Variants.Where(v => v.CafeProductoId.HasValue || v.ComponentMappingsCount > 0).ToList();
        if (linkeadas.Count == 0) { ToastService.Error("Ninguna variante está linkeada"); return; }
        var nuevo = !linkeadas.All(v => v.SyncStock);
        _savingFamSincroS.Add(grp.Key);
        StateHasChanged();
        int ok = 0, fail = 0;
        try
        {
            foreach (var v in linkeadas)
            {
                try
                {
                    var (cfg, err) = await Api.ActualizarSyncConfigAsync(v.MeliItemId, new UpdateSyncConfigRequest
                    { SyncStock = nuevo, SyncPrecio = v.SyncPrecio, AjustePct = v.AjustePct, AjusteFijo = v.AjusteFijo, AjusteRedondeo = v.AjusteRedondeo });
                    if (err is null) { v.SyncStock = nuevo; ok++; } else fail++;
                }
                catch { fail++; }
            }
            InvalidateFilterCache();
            ToastService.Success($"📦 Sincro de STOCK {(nuevo ? "activada" : "desactivada")} en {ok} publicaciones" + (fail > 0 ? $" ({fail} fallaron)" : ""));
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { _savingFamSincroS.Remove(grp.Key); StateHasChanged(); }
    }

