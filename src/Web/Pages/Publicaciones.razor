    // 2026-07-02: refresh de comisiones solo para las publis tildadas — sin esperar el bulk masivo.
    private bool refrescandoSeleccion;
    private async Task RefrescarComisionesSeleccionadas()
    {
        if (refrescandoSeleccion || selectedItems.Count == 0) return;
        if (selectedItems.Count > 200)
        {
            ToastService.Warning($"Máximo 200 publicaciones por refresh selectivo. Tildaste {selectedItems.Count}.");
            return;
        }
        refrescandoSeleccion = true;
        StateHasChanged();
        var (resp, err) = await Api.RefreshSaleFeeSelectedAsync(selectedItems.ToList());
        refrescandoSeleccion = false;
        if (resp is null)
        {
            ToastService.Error("No se pudo refrescar: " + (err ?? "Error"));
        }
        else
        {
            string msg = $"✅ {resp.Ok} comisiones refrescadas";
            if (resp.Fail > 0) msg += $" · ⚠ {resp.Fail} con error";
            ToastService.Success(msg);
            ajustesPrecio.Clear();
            // 2026-07-02: destildar al terminar — igual que el masivo, deja limpio para otro lote.
            selectedItems.Clear();
            await LoadItems();
        }
        StateHasChanged();
    }

    /// <summary>2026-07-01: tildar el checkbox de un padre familia = tildar todas las variantes hijas
    /// (antes solo se tildaba la variante representante y las hermanas quedaban sin ajuste).</summary>
    private void ToggleSelectRow(GroupedRow grp)
    {
        if (grp.IsFamily && grp.Variants.Count > 0)
        {
            bool allTildadas = grp.Variants.All(v => selectedItems.Contains(v.Id));
            if (allTildadas)
                foreach (var v in grp.Variants) selectedItems.Remove(v.Id);
            else
                foreach (var v in grp.Variants) selectedItems.Add(v.Id);
        }
        else
        {
            ToggleSelectItem(grp.Item.Id);
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // 2026-07-01: Fase B — Ajuste masivo (%/$/redondeo) para publis tildadas.
    // Solo guarda en MeliItem_SyncConfig — NO pushea a MeLi.
    // ═══════════════════════════════════════════════════════════════════════════

    private void AbrirBulkAjusteModal()
    {
        if (!selectedItems.Any()) return;
        // Reset estado: no arrastrar valores del último masivo.
        bulkGananciaPct = 30m;
        bulkAjusteRedondeoOpt = "99";
        bulkIncluirPrecioIndep = false;
        showBulkAjusteModal = true;
    }

    private void CerrarBulkAjusteModal()
    {
        if (bulkGuardando) return;
        showBulkAjusteModal = false;
    }

    /// <summary>True si la ganancia es válida (>0).</summary>
    private bool PuedeGuardarBulk() => bulkGananciaPct > 0m;

    /// <summary>Calcula el preview de las primeras 20 publis tildadas: precio actual (con ajuste
    /// actual) vs precio nuevo (con ajuste hipotético del modal). Todo client-side sobre `items`.</summary>
    /// <summary>2026-07-01: preview del masivo por GANANCIA. Para cada publi tildada calcula:
    /// precio necesario = (costo × (1 + gan%/100) × 1.21) / (1 - comisión%)
    /// Todo client-side con los datos del DTO (ProductCost, SaleFeeAmountReal, Price, FreeShipping).
    /// El backend recalcula con datos frescos al guardar/pushear.</summary>
    private BulkPreviewResult GetBulkPreview()
    {
        var filas = new List<BulkPreviewRow>();
        var idsQueCruzan = new List<int>();
        int vanACambiar = 0, saltadasPI = 0, sinCosto = 0, cruzan = 0;
        if (items is null || !PuedeGuardarBulk())
            return new BulkPreviewResult(filas, 0, 0, 0, 0, idsQueCruzan);

        string? redondeo = string.IsNullOrEmpty(bulkAjusteRedondeoOpt) ? null : bulkAjusteRedondeoOpt;

        foreach (var id in selectedItems)
        {
            var it = items.FirstOrDefault(x => x.Id == id);
            if (it is null) continue;

            if (it.PrecioIndependiente && !bulkIncluirPrecioIndep)
            {
                saltadasPI++;
                continue;
            }

            decimal? costo = it.ProductCost;
            if (!costo.HasValue || costo.Value <= 0)
            {
                sinCosto++;
                if (filas.Count < 20)
                    filas.Add(new BulkPreviewRow(it.Title, null, it.Price, null, null, null, false, true));
                continue;
            }
            vanACambiar++;

            // Comisión desglosada: parte % + cargo FIJO. Prioridad al desglose real (SaleFeePercentageFee
            // + SaleFeeFixedFee), fallback al SaleFeeAmount total como % puro, y último recurso 30%.
            decimal pctPart, fixedPart;
            if (it.SaleFeePercentageFee.HasValue && it.SaleFeePercentageFee.Value > 0)
            {
                pctPart = it.SaleFeePercentageFee.Value / 100m;
                fixedPart = it.SaleFeeFixedFee ?? 0m;
            }
            else if (it.SaleFeeAmountReal.HasValue && it.SaleFeeAmountReal.Value > 0 && it.Price > 0)
            {
                pctPart = it.SaleFeeAmountReal.Value / it.Price;
                fixedPart = 0m;
            }
            else
            {
                pctPart = 0.30m;
                fixedPart = 0m;
            }

            decimal netoSinIvaNec = costo.Value * (1m + bulkGananciaPct / 100m);
            decimal netoConIvaNec = netoSinIvaNec * (1m + IvaAlicuota);
            decimal denom = 1m - pctPart;
            if (denom <= 0.05m)
            {
                if (filas.Count < 20)
                    filas.Add(new BulkPreviewRow(it.Title, costo, it.Price, null, null, null, false, false));
                continue;
            }
            decimal precioNuevo = (netoConIvaNec + fixedPart) / denom;
            if (!string.IsNullOrEmpty(redondeo))
                precioNuevo = AplicarRedondeoUp(precioNuevo, redondeo);
            precioNuevo = Math.Round(precioNuevo, 0);

            // 2026-07-02: cruce del umbral aplica a CUALQUIER publi cuyo envío maneje MeLi
            // (Full / Flex / cross_docking / drop_off). Solo se excluyen las ME1 (LogisticType=custom)
            // donde el cliente paga el envío directo, sin importar el precio.
            // Antes: solo alertaba si YA tenía envío gratis — bug. Ahora también alerta cuando
            // pasa de "sin envío gratis" a "con envío gratis obligatorio" (cruzando $33k).
            bool esME1 = string.Equals(it.LogisticType, "custom", StringComparison.OrdinalIgnoreCase);
            bool cruzaUmbral = !esME1
                && (it.Price < UMBRAL_ENVIO_APROX) != (precioNuevo < UMBRAL_ENVIO_APROX)
                && Math.Abs(precioNuevo - it.Price) > 0.5m;
            if (cruzaUmbral) { cruzan++; idsQueCruzan.Add(id); }

            // Ganancia y margen resultantes con el precio final (aplica la misma fórmula desglosada).
            decimal netoConIvaResult = precioNuevo * (1m - pctPart) - fixedPart;
            decimal netoSinIvaResult = netoConIvaResult / (1m + IvaAlicuota);
            decimal gananciaResult = Math.Round(netoSinIvaResult - costo.Value, 0);
            decimal margenPctResult = costo.Value > 0 ? Math.Round(gananciaResult / costo.Value * 100m, 1) : 0m;

            if (filas.Count < 20)
                filas.Add(new BulkPreviewRow(it.Title, costo, it.Price, precioNuevo, gananciaResult, margenPctResult, cruzaUmbral, false));
        }
        return new BulkPreviewResult(filas, vanACambiar, saltadasPI, sinCosto, cruzan, idsQueCruzan);
    }

