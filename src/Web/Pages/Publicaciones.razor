    // Chip visual del estado de push de stock de un item MeLi.
    // Devuelve un MarkupString con un <span> de color (verde/amarillo/rojo) según LastStockPushedToMeli.
    private MarkupString StockPushChip(MeliItemDto item)
    {
        // Solo aplicar a publicaciones con linkeo (sin linkeo no tiene sentido pushear)
        bool tieneLink = item.CafeProductoId.HasValue || item.ComponentMappingsCount > 0;
        if (!tieneLink) return new MarkupString("");

        var last = item.LastStockPushedToMeli;
        string emoji, color, bg, tooltip, label;
        if (!last.HasValue)
        {
            emoji = "🔴"; color = "#991b1b"; bg = "#fee2e2";
            label = "Nunca pusheado";
            tooltip = "Stock NUNCA pusheado a MeLi";
        }
        else
        {
            var ago = DateTime.UtcNow - last.Value;
            var localDate = last.Value.ToArTime();
            string ageStr = ago.TotalMinutes < 60 ? $"{(int)ago.TotalMinutes}m"
                : ago.TotalHours < 24 ? $"{(int)ago.TotalHours}h"
                : ago.TotalDays < 30 ? $"{(int)ago.TotalDays}d"
                : $"{(int)(ago.TotalDays / 30)}mes";
            if (ago.TotalDays > 7)
            {
                emoji = "🟡"; color = "#92400e"; bg = "#fef3c7";
                label = $"hace {ageStr}";
                tooltip = $"Stock pusheado a MeLi hace {ageStr} ({localDate:yyyy-MM-dd HH:mm}). Considera re-pushear.";
            }
            else
            {
                emoji = "🟢"; color = "#166534"; bg = "#dcfce7";
                label = $"hace {ageStr}";
                tooltip = $"Stock pusheado a MeLi hace {ageStr} ({localDate:yyyy-MM-dd HH:mm}).";
            }
        }
        var html = $"<span title=\"{tooltip}\" style=\"display:inline-block;background:{bg};color:{color};padding:0.05rem 0.4rem;border-radius:4px;font-size:0.65rem;font-weight:600;margin-left:0.3rem;\">{emoji} {label}</span>";
        return new MarkupString(html);
    }

    /// <summary>2026-05-30 — Chip que indica si esta publicación tiene PUSH DE PRECIO automático activo.
    /// "🔄 Sync" verde si está claimed (SyncPrecio=true): cualquier cambio de precio del sistema se
    /// propaga automáticamente. "✋ Manual" gris si nunca se pusheó: hay que hacerlo a mano.</summary>
    private MarkupString PrecioSyncChip(MeliItemDto item)
    {
        bool tieneLink = item.CafeProductoId.HasValue || item.ComponentMappingsCount > 0;
        if (!tieneLink) return new MarkupString("");

        string emoji, color, bg, tooltip, label;
        if (item.SyncPrecio)
        {
            emoji = "🔄"; color = "#166534"; bg = "#dcfce7";
            label = "Sync";
            tooltip = "Push de precio AUTOMÁTICO activo. Cuando cambies el precio del sistema, se propaga solo a MeLi (con el ajuste configurado).";
        }
        else
        {
            emoji = "✋"; color = "#6b7280"; bg = "#f3f4f6";
            label = "Manual";
            tooltip = "Push de precio MANUAL. Cambios en el sistema NO se propagan a MeLi hasta que apretés el botón 💵. El primer push manual la activa en modo Sync.";
        }
        var html = $"<span title=\"{tooltip}\" style=\"display:inline-block;background:{bg};color:{color};padding:0.05rem 0.4rem;border-radius:4px;font-size:0.65rem;font-weight:600;margin-left:0.3rem;\">{emoji} {label}</span>";
        return new MarkupString(html);
    }

