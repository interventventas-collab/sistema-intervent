@page "/publicaciones"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject SyncProgressTracker SyncProgress
@implements IDisposable

<div class="card card-publicaciones">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Publicaciones de MercadoLibre (@GetGroupedRows().Count publicaciones · @GetCachedFilteredItems().Count filas)</h3>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
        <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/publicaciones/auditoria")' title="Comparar lista de MLAs entre MeLi y el sistema">
            <i class="fa-solid fa-magnifying-glass"></i> Auditar vs MeLi
        </button>
        @* 2026-06-19: Refrescar comisiones reales de MeLi via API listing_prices.
           Tarda 10-15 min en background. Despues los netos del listado coinciden al peso con MeLi. *@
        <button class="btn" style="background:#7c3aed; color:white; font-weight:700;"
                @onclick="RefrescarComisionesMeLi" disabled="@refrescandoComisiones"
                title="Trae la comision REAL que MeLi cobra por cada publicacion via su API. Reemplaza el calculo estimado (-32%) por el numero exacto. Tarda 10-15 min para 3650 publicaciones. Una vez cacheado, el listado muestra netos exactos.">
            @if (refrescandoComisiones) { <span>⏳ Refrescando...</span> } else { <span>💰 Refrescar comisiones MeLi</span> }
        </button>
        @* 2026-06-01: Boton de push masivo agresivo. Pushea stock a TODAS las publicaciones con SyncStock=ON.
           Confirma 2 veces antes de ejecutar. Resultado vuelve a las tablas MeliPushSnapshot_*_pre/post para cotejo. *@
        <button class="btn" style="background:#dc2626; color:white; font-weight:700; border:2px solid #991b1b;"
                @onclick="DispararPushMasivoAgresivo" disabled="@pushMasivoEnCurso"
                title="Pushea stock a TODAS las publicaciones MeLi. MeLi pausa las de stock 0 y activa las con stock. Despues hay que revisar el cotejo.">
            @if (pushMasivoEnCurso) { <span>⏳ Pusheando...</span> } else { <span>🚀 PUSHEAR STOCK DE TODO A MELI</span> }
        </button>
        <div class="sync-dropdown-wrapper">
            <button class="btn btn-primary" @onclick="() => SyncItems(null, null)" disabled="@isSyncing" style="border-radius: 6px 0 0 6px;">
                @(isSyncing ? syncingLabel : "Sincronizar")
            </button>
            <button class="btn btn-primary sync-dropdown-toggle" @onclick="ToggleSyncMenu" @onclick:stopPropagation="true" disabled="@isSyncing"
                    style="border-radius: 0 6px 6px 0; border-left: 1px solid rgba(255,255,255,0.3); padding: 0.5rem 0.4rem;">
                <i class="fa-solid fa-caret-down"></i>
            </button>
            @if (showSyncMenu)
            {
                <div class="sync-dropdown-menu">
                    <div class="sync-dropdown-section">Por estado</div>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("active", null)'>
                        <span class="status-dot dot-active"></span> Solo activas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("paused", null)'>
                        <span class="status-dot dot-paused"></span> Solo pausadas
                    </button>
                    <button class="sync-dropdown-item" @onclick='() => SyncItems("closed", null)'>
                        <span class="status-dot dot-closed"></span> Solo cerradas
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <div class="sync-dropdown-section">Por cuenta</div>
                    @if (meliAccounts is not null)
                    {
                        @foreach (var acc in meliAccounts)
                        {
                            var a = acc;
                            <button class="sync-dropdown-item" @onclick="() => SyncItems(null, a.Id)">
                                <i class="fa-solid fa-user"></i> @a.Nickname
                            </button>
                        }
                    }
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item" @onclick="OpenSyncByIdModal">
                        <i class="fa-solid fa-magnifying-glass"></i> Traer por ID
                    </button>
                    <div class="sync-dropdown-divider"></div>
                    <button class="sync-dropdown-item sync-item-all" @onclick='() => SyncItems(null, null)'>
                        <i class="fa-solid fa-arrows-rotate"></i> Sincronizar todo
                    </button>
                </div>
            }
        </div>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando publicaciones...</p>
        }
        else if (items is null || !items.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay publicaciones. Hace clic en "Sincronizar" para traer los items de MercadoLibre.</p>
        }
        else
        {
            <!-- View mode toggle -->
            <div class="view-mode-bar">
                <div style="display: flex; gap: 0.25rem;">
                    <button class="view-mode-btn @(viewMode == "flat" ? "active" : "")" @onclick='() => viewMode = "flat"'>Lista</button>
                    <button class="view-mode-btn @(viewMode == "family" ? "active" : "")" @onclick='() => viewMode = "family"'>Por Familia</button>
                    <button class="view-mode-btn @(viewMode == "product" ? "active" : "")" @onclick='() => viewMode = "product"'>Por Producto</button>
                    <button class="view-mode-btn @(viewMode == "sincro" ? "active" : "")" @onclick='() => viewMode = "sincro"'>💰 Sincro precio + stock</button>
                    @* 2026-06-16: toggle de status (Activas / Pausadas / Todas) — antes solo cargaba active y no se podian ver paused *@
                    <div style="display:inline-flex; gap:0.15rem; margin-left:0.5rem; padding:0.15rem; background:#f3f4f6; border-radius:6px;">
                        <button class="view-mode-btn @(statusFilter == "active" ? "active" : "")" style="background:@(statusFilter == "active" ? "#16a34a" : "transparent"); color:@(statusFilter == "active" ? "white" : "#374151");"
                                @onclick='@(() => CambiarStatus("active"))'>✅ Activas</button>
                        <button class="view-mode-btn @(statusFilter == "paused" ? "active" : "")" style="background:@(statusFilter == "paused" ? "#f59e0b" : "transparent"); color:@(statusFilter == "paused" ? "white" : "#374151");"
                                @onclick='@(() => CambiarStatus("paused"))'>⏸ Pausadas</button>
                        <button class="view-mode-btn @(statusFilter == null ? "active" : "")" style="background:@(statusFilter == null ? "#1d4ed8" : "transparent"); color:@(statusFilter == null ? "white" : "#374151");"
                                @onclick='@(() => CambiarStatus(null))'>📋 Todas</button>
                    </div>
                    @if (viewMode == "flat")
                    {
                        <label title="ON: agrupa familias (FamilyId con varios MLAs) en 1 sola fila — vista catálogo de MeLi. OFF: cada MLA es 1 fila — coincide con el conteo de publicaciones de MeLi web."
                               style="display:inline-flex; align-items:center; gap:0.35rem; padding:0.35rem 0.7rem; margin-left:0.5rem; background:@(agruparFamilias ? "#dbeafe" : "#f3f4f6"); border:1px solid @(agruparFamilias ? "#3b82f6" : "#e5e7eb"); border-radius:6px; cursor:pointer; font-size:0.82rem; color:#374151; user-select:none;">
                            <input type="checkbox" @bind="agruparFamilias" @bind:after="StateHasChanged" />
                            <span>📦 Agrupar familias @(agruparFamilias ? "(ON)" : "(OFF — cada MLA suelto)")</span>
                        </label>
                    }
                </div>
                <div class="more-filters-wrapper">
                    <button class="more-filters-btn @(GetActiveFilterCount() > 0 ? "has-active" : "")" @onclick="ToggleMoreFilters" @onclick:stopPropagation="true">
                        <i class="fa-solid fa-gear"></i> Más Filtros @(GetActiveFilterCount() > 0 ? $"({GetActiveFilterCount()})" : "") <i class="fa-solid fa-caret-down"></i>
                    </button>
                    @if (showMoreFilters)
                    {
                        @* 2026-06-02: dropdown limpiado — 13 filtros → 5 botones + 2 selectores agrupados. *@
                        <div class="more-filters-dropdown">
                            @* === Los 5 filtros que de verdad usás === *@
                            <button class="more-filters-item @(filterUrgente ? "active" : "")" @onclick="() => { filterUrgente = !filterUrgente; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterUrgente ? "#fee2e2" : "transparent"); color:@(filterUrgente ? "#991b1b" : "inherit"); font-weight:700;">
                                🚨 URGENTE: agotadas (stock 0) o pausadas
                            </button>
                            <button class="more-filters-item @(filterMargenPerdida ? "active" : "")" @onclick="() => { filterMargenPerdida = !filterMargenPerdida; if (filterMargenPerdida) filterMargenBajo = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterMargenPerdida ? "#fee2e2" : "transparent"); color:@(filterMargenPerdida ? "#991b1b" : "inherit"); font-weight:700;">
                                🔴 PÉRDIDA: margen ≤ 0% (vendés bajo costo)
                            </button>
                            <button class="more-filters-item @(filterMargenBajo ? "active" : "")" @onclick="() => { filterMargenBajo = !filterMargenBajo; if (filterMargenBajo) filterMargenPerdida = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterMargenBajo ? "#fed7aa" : "transparent"); color:@(filterMargenBajo ? "#9a3412" : "inherit"); font-weight:700;">
                                🟠 BAJO: margen menor a 15% (revisar)
                            </button>
                            <button class="more-filters-item @(filterSinLinkear ? "active" : "")" @onclick="() => { filterSinLinkear = !filterSinLinkear; InvalidateFilterCache(); showMoreFilters = false; }">
                                ⚠ Sin linkear (ningún tipo)
                            </button>
                            @* 2026-07-01: filtros para ajuste masivo — separar las que ya toqué vs vírgenes *@
                            <button class="more-filters-item @(filterConAjuste ? "active" : "")" @onclick="() => { filterConAjuste = !filterConAjuste; if (filterConAjuste) filterSinAjuste = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterConAjuste ? "#d1fae5" : "transparent"); color:@(filterConAjuste ? "#065f46" : "inherit"); font-weight:700;">
                                💵 Con ajuste cargado (% o $)
                            </button>
                            <button class="more-filters-item @(filterSinAjuste ? "active" : "")" @onclick="() => { filterSinAjuste = !filterSinAjuste; if (filterSinAjuste) filterConAjuste = false; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterSinAjuste ? "#f3f4f6" : "transparent"); color:@(filterSinAjuste ? "#374151" : "inherit"); font-weight:700;">
                                ○ Sin ajuste (vírgenes)
                            </button>
                            <button class="more-filters-item @(filterPromo ? "active" : "")" @onclick="() => { TogglePromoFilter(); showMoreFilters = false; }">
                                <i class="fa-solid fa-tag"></i> En promoción
                            </button>
                            <button class="more-filters-item @(IsCuentaMe1Filtered() ? "active" : "")" @onclick="() => { ToggleCuentaMe1Filter(); showMoreFilters = false; }"
                                    style="background:@(IsCuentaMe1Filtered() ? "#dbeafe" : "transparent"); color:@(IsCuentaMe1Filtered() ? "#1e40af" : "inherit"); font-weight:700;">
                                🛒 Solo cuenta me1
                            </button>
                            <button class="more-filters-item @(filterCatalogo ? "active" : "")" @onclick="() => { filterCatalogo = !filterCatalogo; InvalidateFilterCache(); showMoreFilters = false; }"
                                    style="background:@(filterCatalogo ? "#fef9c3" : "transparent"); color:@(filterCatalogo ? "#854d0e" : "inherit"); font-weight:700;">
                                📋 Solo catálogo (las amarillas)
                            </button>

                            @* === Selector: Tipo de envío === *@
                            <div style="border-top: 1px solid #e5e7eb; margin: 0.5rem 0 0.25rem 0; padding: 0.5rem 0.75rem 0.25rem 0.75rem; font-size: 0.75rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">📦 Tipo de envío</div>
                            <div style="display:flex; gap:0.25rem; padding: 0 0.5rem 0.5rem 0.5rem;">
                                <button class="@(!filterFull && !filterNoFull ? "active" : "")" @onclick="() => { filterFull = false; filterNoFull = false; InvalidateFilterCache(); }"
                                        style="flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(!filterFull && !filterNoFull ? "#dbeafe" : "white"); color:@(!filterFull && !filterNoFull ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Todo</button>
                                <button class="@(filterFull ? "active" : "")" @onclick="() => { filterFull = true; filterNoFull = false; InvalidateFilterCache(); }"
                                        style="flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterFull ? "#dbeafe" : "white"); color:@(filterFull ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Solo Full</button>
                                <button class="@(filterNoFull ? "active" : "")" @onclick="() => { filterNoFull = true; filterFull = false; InvalidateFilterCache(); }"
                                        style="flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterNoFull ? "#dbeafe" : "white"); color:@(filterNoFull ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Solo NO Full</button>
                            </div>

                            @* === 2026-06-12: Ordenar por (precio / vendidos) === *@
                            <div style="border-top: 1px solid #e5e7eb; margin: 0.25rem 0 0.25rem 0; padding: 0.5rem 0.75rem 0.25rem 0.75rem; font-size: 0.75rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">↕ Ordenar por</div>
                            <div style="display:flex; gap:0.25rem; padding: 0 0.5rem 0.5rem 0.5rem; flex-wrap:wrap;">
                                <button @onclick="() => { sortColumn = null; InvalidateFilterCache(); showMoreFilters = false; }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn is null ? "#dbeafe" : "white"); color:@(sortColumn is null ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Por defecto</button>
                                <button @onclick='() => { sortColumn = "precio"; sortAsc = true; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "precio" && sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "precio" && sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">💲 Menor precio</button>
                                <button @onclick='() => { sortColumn = "precio"; sortAsc = false; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "precio" && !sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "precio" && !sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">💲 Mayor precio</button>
                                <button @onclick='() => { sortColumn = "vendidos"; sortAsc = false; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "vendidos" && !sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "vendidos" && !sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">🔥 Más vendido</button>
                                <button @onclick='() => { sortColumn = "vendidos"; sortAsc = true; InvalidateFilterCache(); showMoreFilters = false; }'
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(sortColumn == "vendidos" && sortAsc ? "#dbeafe" : "white"); color:@(sortColumn == "vendidos" && sortAsc ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">❄ Menos vendido</button>
                            </div>

                            @* === Selector: Estado de push de stock === *@
                            <div style="border-top: 1px solid #e5e7eb; margin: 0.25rem 0 0.25rem 0; padding: 0.5rem 0.75rem 0.25rem 0.75rem; font-size: 0.75rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">🔄 Estado de push de stock</div>
                            <div style="display:flex; gap:0.25rem; padding: 0 0.5rem 0.5rem 0.5rem; flex-wrap:wrap;">
                                <button @onclick="() => { filterStockPushNunca = false; filterStockPushOk = false; filterStockPushViejo = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(!filterStockPushNunca && !filterStockPushOk && !filterStockPushViejo ? "#dbeafe" : "white"); color:@(!filterStockPushNunca && !filterStockPushOk && !filterStockPushViejo ? "#1e40af" : "#374151"); font-size:0.8125rem; cursor:pointer;">Todo</button>
                                <button @onclick="() => { filterStockPushNunca = true; filterStockPushOk = false; filterStockPushViejo = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterStockPushNunca ? "#fee2e2" : "white"); color:@(filterStockPushNunca ? "#991b1b" : "#374151"); font-size:0.8125rem; cursor:pointer;">🔴 Nunca</button>
                                <button @onclick="() => { filterStockPushOk = true; filterStockPushNunca = false; filterStockPushViejo = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterStockPushOk ? "#d1fae5" : "white"); color:@(filterStockPushOk ? "#065f46" : "#374151"); font-size:0.8125rem; cursor:pointer;">🟢 Reciente (≤7d)</button>
                                <button @onclick="() => { filterStockPushViejo = true; filterStockPushNunca = false; filterStockPushOk = false; InvalidateFilterCache(); }"
                                        style="flex:1 1 45%; padding:0.35rem; border:1px solid #d1d5db; border-radius:4px; background:@(filterStockPushViejo ? "#fef3c7" : "white"); color:@(filterStockPushViejo ? "#92400e" : "#374151"); font-size:0.8125rem; cursor:pointer;">🟡 Viejo (+7d)</button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (selectedItems.Count > 0)
            {
                <div class="bulk-actions-bar">
                    <span><strong>@selectedItems.Count</strong> publicaciones seleccionadas</span>
                    @* 2026-07-01: modal unificado (Fase B + C). Al pie 2 botones: solo guardar o guardar+publicar. *@
                    <button class="btn btn-sm" @onclick="AbrirBulkAjusteModal"
                            style="background:#16a34a; color:white; border:1px solid #15803d; font-weight:600;"
                            title="Modificar precios de las publis tildadas: ver preview y elegir si solo guardás o publicás en MeLi ya">
                        💵 Ajustar precios en lote
                    </button>
                    <button class="btn btn-primary btn-sm" @onclick="BulkCreateProducts">
                        <i class="fa-solid fa-box"></i> Crear productos
                    </button>
                    <button class="btn btn-danger btn-sm" @onclick="ShowBulkDeleteModal">
                        <i class="fa-solid fa-trash"></i> Eliminar seleccionadas
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="ClearSelection">
                        Deseleccionar
                    </button>
                </div>
            }

            @if (viewMode == "sincro")
            {
                <div style="margin-top:1rem;">
                    <SincroMeliPanel />
                </div>
            }
            else
            {
                @* 2026-06-02: Controles de paginación arriba (solo vista "flat") *@
                @if (viewMode == "flat")
                {
                    var totalRows = GetGroupedRows().Count;
                    var totalPages = GetTotalPages();
                    var rangoDesde = totalRows == 0 ? 0 : (currentPage - 1) * pageSize + 1;
                    var rangoHasta = Math.Min(currentPage * pageSize, totalRows);
                    <div class="pagination-bar" style="display:flex; align-items:center; gap:0.75rem; padding:0.5rem 0.75rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; margin:0.5rem 0; flex-wrap:wrap; font-size:0.875rem;">
                        <span style="font-weight:500; color:#374151;">
                            Mostrando <strong>@rangoDesde – @rangoHasta</strong> de <strong>@totalRows</strong> publicaciones
                        </span>
                        <div style="display:flex; align-items:center; gap:0.25rem; margin-left:auto;">
                            <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(1)" disabled="@(currentPage == 1)" title="Primera">⏮</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(currentPage - 1)" disabled="@(currentPage == 1)" title="Anterior">◀</button>
                            <span style="padding:0 0.5rem;">Página <strong>@currentPage</strong> de <strong>@totalPages</strong></span>
                            <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(currentPage + 1)" disabled="@(currentPage >= totalPages)" title="Siguiente">▶</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => GoToPage(totalPages)" disabled="@(currentPage >= totalPages)" title="Última">⏭</button>
                        </div>
                        <div style="display:flex; align-items:center; gap:0.25rem;">
                            <label style="font-size:0.8125rem; color:#6b7280;">Por página:</label>
                            <select @onchange="@((ChangeEventArgs e) => ChangePageSize(int.Parse(e.Value?.ToString() ?? "100")))" style="padding:0.25rem 0.5rem; border:1px solid #d1d5db; border-radius:4px;">
                                <option value="50" selected="@(pageSize == 50)">50</option>
                                <option value="100" selected="@(pageSize == 100)">100</option>
                                <option value="200" selected="@(pageSize == 200)">200</option>
                                <option value="500" selected="@(pageSize == 500)">500</option>
                            </select>
                        </div>
                    </div>
                }
                        <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="th-checkbox"><input type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected()" title="Seleccionar todos" /></th>
                            <!-- Imagen -->
                            <th class="th-img">Img</th>
                            <!-- Titulo: text input -->
                            <th class="th-filterable" style="min-width: 200px;">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("titulo") ? "has-filter" : "")" placeholder="Titulo, ID, Familia..."
                                           value='@GetTextFilter("titulo")' @oninput='(e) => SetTextFilter("titulo", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("titulo")' title="Ordenar">
                                        <span class="@(sortColumn == "titulo" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "titulo" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- SKU: text input -->
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("sku") ? "has-filter" : "")" placeholder="SKU"
                                           value='@GetTextFilter("sku")' @oninput='(e) => SetTextFilter("sku", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("sku")' title="Ordenar">
                                        <span class="@(sortColumn == "sku" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "sku" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Precio: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("precio")'>
                                <div class="th-inner">
                                    <span class="th-label">Precio</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "precio" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "precio" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Stock: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("stock")'>
                                <div class="th-inner">
                                    <span class="th-label">Stock</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "stock" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "stock" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Vendidos: sort only -->
                            <!-- 2026-05-29: VENDIDOS sale como columna y pasa a sub-texto en el título.
                                 Razón: liberar ancho para la nueva columna AJUSTE y que los botones 📦/💵 vuelvan a verse sin scroll. -->
                            <!-- Estado: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "estado" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("estado")'>Estado</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("estado")'>
                                            <span class="@(sortColumn == "estado" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "estado" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("estado") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("estado")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "estado")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("estado"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("estado", v)" @onchange='() => ToggleCheckboxValue("estado", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("estado"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("estado")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Tipo: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "tipo" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("tipo")'>Tipo</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("tipo")'>
                                            <span class="@(sortColumn == "tipo" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "tipo" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("tipo") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("tipo")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "tipo")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("tipo"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("tipo", v)" @onchange='() => ToggleCheckboxValue("tipo", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("tipo"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("tipo")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Cuenta: checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "cuenta" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("cuenta")'>Cuenta</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("cuenta")'>
                                            <span class="@(sortColumn == "cuenta" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "cuenta" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("cuenta") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("cuenta")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "cuenta")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("cuenta"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("cuenta", v)" @onchange='() => ToggleCheckboxValue("cuenta", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("cuenta"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("cuenta")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- AJUSTE: 3 mini controles para modificar el precio al pushear (Δ + tipo $/% + redondeo) -->
                            <th class="th-ajuste" style="min-width: 165px;">
                                <div class="th-inner">
                                    <span class="th-label" title="Ajuste de precio al pushear con 💵: delta + tipo ($ o %) + redondeo">Ajuste 💵</span>
                                </div>
                            </th>
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("producto") ? "has-filter" : "")" placeholder="Producto"
                                           value='@GetTextFilter("producto")' @oninput='(e) => SetTextFilter("producto", e.Value?.ToString() ?? "")' />
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (viewMode == "flat")
                        {
                            @* Agrupamos por MeliItemId: 1 fila por publicacion. Si tiene variantes,
                               la fila representante muestra stock+sold totales y un boton ▼ para
                               expandir las variantes individuales.
                               2026-06-02: paginación client-side (GetPagedGroupedRows) para no renderizar 9k filas. *@
                            @foreach (var grp in GetPagedGroupedRows())
                            {
                                var item = grp.Item;
                                var isExpanded = expandedGroups.Contains(grp.Key);
                                @* 2026-07-01: click en padre de familia expande/colapsa en vez de abrir ficha
                                   — el padre es un contenedor visual, las variantes hijas tienen la info operable. *@
                                @* 2026-07-01: padre familia tildado = todas las hijas tildadas. Antes solo se tildaba
                                   la variante representante y las hermanas quedaban sin ajuste — bug de UX. *@
                                var checkedThisRow = grp.IsFamily
                                    ? grp.Variants.Count > 0 && grp.Variants.All(v => selectedItems.Contains(v.Id))
                                    : selectedItems.Contains(item.Id);
                                <tr class="clickable-row @(checkedThisRow ? "row-selected" : "")" style="@CatalogRowStyle(item)"
                                    @onclick="() => { if (grp.IsFamily) ToggleGroupExpand(grp.Key); else OpenItemModal(item); }"
                                    title="@(grp.IsFamily ? "Click para ver las variantes de la familia" : "Click para abrir la ficha")">
                                    <td class="td-checkbox" @onclick:stopPropagation="true"><input type="checkbox" checked="@checkedThisRow" @onchange="() => ToggleSelectRow(grp)" /></td>
                                    <td style="text-align: center;">
                                        @if (!string.IsNullOrEmpty(item.Thumbnail))
                                        {
                                            <img src="@item.Thumbnail" alt="" class="item-thumbnail" />
                                        }
                                        else
                                        {
                                            <div class="item-thumb-placeholder">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Permalink))
                                        {
                                            <a href="@item.Permalink" target="_blank" class="item-link" title="@item.MeliItemId">@Truncate(item.Title, 50)</a>
                                        }
                                        else
                                        {
                                            <span title="@item.MeliItemId">@Truncate(item.Title, 50)</span>
                                        }
                                        @if (IsCatalogListing(item))
                                        {
                                            <span style="margin-left:0.4rem; background:#f59e0b; color:white; padding:0.05rem 0.35rem; border-radius:4px; font-size:0.65rem; font-weight:700;" title="Publicación del catálogo de MeLi — el precio puede cambiar automáticamente según otros vendedores">📋 CATÁLOGO</span>
                                        }
                                        <div class="item-id">
                                            @if (grp.IsFamily)
                                            {
                                                <span style="background:#fef3c7; color:#92400e; padding:0.05rem 0.3rem; border-radius:3px; font-size:0.7rem; font-weight:700;" title="Catálogo MeLi @item.FamilyId">📦 FAMILIA</span>
                                                <span style="margin-left:0.3rem;">@(item.FamilyId ?? item.MeliItemId)</span>
                                                <CopyButton Text="@(item.FamilyId ?? item.MeliItemId)" />
                                                @* 2026-06-11: boton para abrir analisis de margen por familia *@
                                                @if (!string.IsNullOrEmpty(item.FamilyId))
                                                {
                                                    <button @onclick:stopPropagation="true" @onclick="@(() => AbrirAnalisisMargen(item.FamilyId!))"
                                                            style="margin-left:0.3rem; padding:0.05rem 0.4rem; background:#7c3aed; color:white; border:none; border-radius:3px; font-size:0.7rem; font-weight:700; cursor:pointer;"
                                                            title="Análisis de margen: ver el neto que te queda por cada MLA y balancear">
                                                        📊 Margen
                                                    </button>
                                                }
                                                @StockPushChip(item)
                                                @PrecioSyncChip(item)
                                            }
                                            else
                                            {
                                                @item.MeliItemId
                                                <CopyButton Text="@item.MeliItemId" />
                                                @StockPushChip(item)
                                                @PrecioSyncChip(item)
                                            }
                                            @if (grp.HasMultiple)
                                            {
                                                <button @onclick:stopPropagation="true" @onclick="() => ToggleGroupExpand(grp.Key)"
                                                        style="margin-left:0.4rem; padding:0 0.4rem; background:#dbeafe; color:#1e40af; border:1px solid #3b82f6; border-radius:8px; font-size:0.7rem; font-weight:600; cursor:pointer;">
                                                    @(isExpanded ? "▲" : "▼")
                                                    @if (grp.IsFamily)
                                                    {
                                                        @($"{grp.DistinctMLAs} publicaciones")
                                                    }
                                                    else
                                                    {
                                                        @($"{grp.Variants.Count} variantes")
                                                    }
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @if (grp.HasMultiple)
                                        {
                                            @* 2026-06-01: en familia/grupo multi-publicacion mostrar conteo en lugar del SKU
                                               de una variante puntual — antes mostraba "C9172BEI" en el padre y confundia. *@
                                            var multiCount = grp.IsFamily ? grp.DistinctMLAs : grp.Variants.Count;
                                            var multiLabel = grp.IsFamily
                                                ? (multiCount == 1 ? "publicación" : "publicaciones")
                                                : (multiCount == 1 ? "variante" : "variantes");
                                            <div style="color:#6b7280; font-style:italic; font-size:0.85rem;">— @multiCount @multiLabel</div>
                                            @if (item.PrecioOtroConIvaCalc.HasValue && item.PrecioOtroConIvaCalc.Value > 0)
                                            {
                                                var fmt = item.PrecioOtroConIvaCalc.Value.ToString("N0", new System.Globalization.CultureInfo("es-AR"));
                                                <div style="font-size:0.7rem; color:#6b7280; font-weight:600; margin-top:2px;"
                                                     title="Precio sistema de una variante (las otras pueden tener otro)">
                                                    $ @fmt
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            @SkuConPrecioSistema(item)
                                        }
                                    </td>
                                    <td>
                                        @* 2026-07-01: padre familia = contenedor visual, sin precio ni chips. Cada variante tiene su realidad. *@
                                        @if (!grp.IsFamily)
                                        {
                                            @if (item.OriginalPrice.HasValue && item.OriginalPrice.Value > 0 && item.OriginalPrice.Value != item.Price)
                                            {
                                                <span class="price-sale">@item.CurrencyId @item.Price.ToString("N2")</span>
                                                <span class="price-original">@item.CurrencyId @item.OriginalPrice.Value.ToString("N2")</span>
                                                <span class="price-discount-pct">-@(((item.OriginalPrice.Value - item.Price) / item.OriginalPrice.Value * 100).ToString("N0"))%</span>
                                            }
                                            else
                                            {
                                                <span>@item.CurrencyId @item.Price.ToString("N2")</span>
                                            }
                                            @AjusteChipPrecio(item)
                                            @MargenChipPrecio(item)
                                        }
                                        else
                                        {
                                            <span style="color:#9ca3af; font-size:0.8rem; font-style:italic;">— ver variantes ↓</span>
                                        }
                                    </td>
                                    <td style="text-align: center; font-weight: 700;">
                                        @{ var stockShow = grp.HasMultiple ? grp.TotalStock : item.AvailableQuantity; }
                                        @if (item.ProductCriticalStock.HasValue && item.ProductCriticalStock.Value > 0 && stockShow <= item.ProductCriticalStock.Value)
                                        {
                                            <span class="stock-badge @(stockShow < item.ProductCriticalStock.Value ? "stock-critical" : "stock-warning")">@stockShow</span>
                                        }
                                        else if (item.ProductCriticalStock.HasValue && item.ProductCriticalStock.Value > 0 && stockShow > item.ProductCriticalStock.Value)
                                        {
                                            <span class="stock-badge stock-healthy">@stockShow</span>
                                        }
                                        else
                                        {
                                            @stockShow
                                        }
                                    </td>
                                    <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span></td>
                                    <td>
                                        @if (!grp.IsFamily)
                                        {
                                            @GetListingTypeLabel(item.ListingTypeId)
                                            <div style="font-size:0.68rem; color:#6b7280; margin-top:0.1rem; font-weight:500;">@GetCuotasLabel(item.InstallmentTag, item.ListingTypeId)</div>
                                        }
                                        else
                                        {
                                            <span style="color:#9ca3af; font-size:0.8rem;">—</span>
                                        }
                                    </td>
                                    <td>@item.AccountNickname</td>
                                    <td class="td-ajuste" @onclick:stopPropagation="true">
                                        @* 2026-07-01: en padre familia el ajuste vive en cada variante — vacío acá. *@
                                        @if (grp.IsFamily)
                                        {
                                            <span style="color:#d1d5db; font-size:0.8rem;">—</span>
                                        }
                                        else
                                        {
                                            var prev1 = PreviewPrecioAjustado(item);
                                            <div style="cursor:pointer; line-height:1.3;" @onclick="() => OpenItemModal(item)" title="Click para editar el ajuste desde la ficha">
                                                @if (item.PrecioIndependiente && item.PrecioFactor.HasValue)
                                                {
                                                    <span style="display:inline-block; padding:0.1rem 0.4rem; background:#dbeafe; color:#1d4ed8; border-radius:0.3rem; font-size:0.7rem; font-weight:600; margin-bottom:0.15rem;">🔒 INDEP × @item.PrecioFactor.Value.ToString("F2")</span>
                                                }
                                                @if (HasAjuste(item))
                                                {
                                                    <div style="display:inline-block; padding:0.2rem 0.55rem 0.25rem; background:white; border:1px solid #e5e7eb; border-left:3px solid #f59e0b; border-radius:0.35rem;">
                                                        @if (!string.IsNullOrEmpty(prev1))
                                                        {
                                                            <div style="font-size:0.8rem; font-weight:700; color:#92400e; white-space:nowrap;">$@prev1</div>
                                                            <div style="font-size:0.6rem; color:#9ca3af; white-space:nowrap;">@AjusteResumen(item)</div>
                                                        }
                                                        else
                                                        {
                                                            <div style="font-size:0.72rem; font-weight:600; color:#92400e; white-space:nowrap;">@AjusteResumen(item)</div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span style="color:#d1d5db; font-size:0.8rem;">—</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="td-product" @onclick:stopPropagation="true">
                                        @if (item.ProductId.HasValue)
                                        {
                                            <span class="product-badge" title="@item.ProductTitle">
                                                @Truncate(item.ProductTitle ?? "", 18)
                                                <button class="product-badge-unlink" @onclick="() => UnlinkProduct(item)" title="Desvincular">&times;</button>
                                            </span>
                                            <button class="push-meli-btn push-stock" @onclick="() => QuickPushStock(item)" title="Pushear SOLO stock a MeLi (usa el del sistema)">📦</button>
                                            
                                        }
                                        else if (item.ComboId.HasValue)
                                        {
                                            <span class="product-badge" style="background:#fef3c7; color:#92400e; border-color:#fbbf24;" title="@item.ComboName">
                                                🎁 @Truncate(item.ComboName ?? "", 16)
                                                <button class="product-badge-unlink" @onclick="() => UnlinkProduct(item)" title="Desvincular">&times;</button>
                                            </span>
                                            <button class="push-meli-btn push-stock" @onclick="() => QuickPushStock(item)" title="Pushear SOLO stock a MeLi (usa el del sistema)">📦</button>
                                            
                                        }
                                        else if (item.CafeProductoId.HasValue)
                                        {
                                            <span class="product-badge" style="background:#dcfce7; color:#15803d; border-color:#22c55e;" title="@($"{item.CafeProductoSku} - {item.CafeProductoNombre} ({item.CafeFormato})")">
                                                ☕ @item.CafeProductoSku
                                                <span style="opacity:0.7; margin-left:0.2rem;">@item.CafeFormato</span>
                                            </span>
                                            <button class="push-meli-btn push-stock" @onclick="() => QuickPushStock(item)" title="Pushear SOLO stock a MeLi (usa el del sistema)">📦</button>
                                            
                                        }
                                        else if (item.ComponentMappingsCount > 0)
                                        {
                                            <span class="product-badge" style="background:#dbeafe; color:#1e40af; border-color:#3b82f6; cursor: help;"
                                                  title="@(string.IsNullOrEmpty(item.ComponentMappingsSummary) ? $"Linkeado a {item.ComponentMappingsCount} producto(s) del sistema" : $"Cuando se vende, descuenta:\n{item.ComponentMappingsSummary}")">
                                                ✅ Linkeado (@item.ComponentMappingsCount)
                                            </span>
                                            <button class="push-meli-btn push-stock" @onclick="() => QuickPushStock(item)" title="Pushear SOLO stock a MeLi (usa el del sistema)">📦</button>
                                            
                                        }
                                        else
                                        {
                                            <div class="product-actions-inline">
                                                <button class="create-product-btn" @onclick="() => OpenCreateProductFromItem(item)" title="Crear producto">+</button>
                                                <button class="link-product-btn" @onclick="() => OpenLinkProductDropdown(item)" title="Vincular existente">&#128279;</button>
                                            </div>
                                        }
                                        @if (string.Equals(item.LogisticType, "fulfillment", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span style="display:inline-block; margin-left:0.25rem; padding:0 0.3rem; background:#fee2e2; color:#991b1b; border-radius:4px; font-size:0.62rem; font-weight:700; letter-spacing:0.5px;" title="Mercado Envíos Full — el stock lo administra MeLi, no se puede editar por API">FULL</span>
                                        }
                                    </td>
                                </tr>
                                @* Filas hijas (subfilas indentadas). Si IsFamily: cada hija es un MLA distinto.
                                   Si NO es Family pero tiene variantes: cada hija es una variante color/talle. *@
                                @if (grp.HasMultiple && isExpanded)
                                {
                                    @foreach (var v in grp.Variants)
                                    {
                                        <tr style="background:#f9fafb; font-size:0.85rem;@CatalogRowStyle(v)" @onclick="() => OpenItemModal(v)">
                                            @* 2026-06-03: checkbox para multi-seleccion + push de precio en lote *@
                                            <td class="td-checkbox" @onclick:stopPropagation="true">
                                                <input type="checkbox" checked="@selectedFamilyPush.Contains(v.Id)"
                                                       @onchange="() => ToggleSelectFamilyChild(v.Id)" />
                                            </td>
                                            <td style="text-align:right; color:#6b7280;">↳</td>
                                            <td style="padding-left:1.2rem;">
                                                @if (grp.IsFamily)
                                                {
                                                    <span style="color:#111;">@Truncate(v.Title, 50)</span>
                                                    <div class="item-id" style="font-size:0.7rem;">@v.MeliItemId <CopyButton Text="@v.MeliItemId" /></div>
                                                }
                                                else
                                                {
                                                    <span style="color:#6b7280;">@(v.VariationAttributes ?? "(variante)")</span>
                                                    <div class="item-id" style="font-size:0.7rem;">var. @v.VariationId <CopyButton Text="@(v.VariationId ?? "")" /></div>
                                                }
                                            </td>
                                            <td>@SkuConPrecioSistema(v)</td>
                                            <td>@v.CurrencyId @v.Price.ToString("N2")</td>
                                            <td style="text-align:center;">@v.AvailableQuantity</td>
                                            <td><span class="status-badge @GetStatusClass(v.Status)" style="font-size:0.7rem;">@GetStatusLabel(v.Status)</span></td>
                                            @* 2026-06-11: en hijas de familia mostrar Tipo + Cuotas + NETO calculado en vivo *@
                                            <td style="font-size:0.78rem;">
                                                @if (grp.IsFamily)
                                                {
                                                    <strong style="color:@(GetListingTypeLabel(v.ListingTypeId) == "Premium" ? "#7c3aed" : "#1d4ed8");">@GetListingTypeLabel(v.ListingTypeId)</strong>
                                                }
                                            </td>
                                            <td style="font-size:0.78rem;">
                                                @if (grp.IsFamily)
                                                {
                                                    var label = GetCuotasLabel(v.InstallmentTag, v.ListingTypeId);
                                                    <span style="background:#f3f4f6; padding:0.1rem 0.4rem; border-radius:3px;">@label</span>
                                                    @if (v.FreeShipping)
                                                    {
                                                        <span title="Envío gratis" style="margin-left:0.2rem;">🚚</span>
                                                    }
                                                }
                                            </td>
                                            <td style="font-size:0.82rem; text-align:right;">
                                                @if (grp.IsFamily)
                                                {
                                                    var neto = CalcularNetoMla(v);
                                                    var ganancia = CalcularGananciaRealMla(v);
                                                    var margenPct = CalcularMargenPctMla(v);
                                                    // 2026-07-01: mostrar el % REAL total que MeLi te cobra (incluye comisión + cuotas + envío + cargo fijo),
                                                    // no solo la comisión base estimada. Solo cuando tenemos SaleFeeAmountReal cacheado y el precio no se movió.
                                                    decimal comisionRealPct;
                                                    if (v.SaleFeeAmountReal.HasValue && v.SaleFeeAmountReal.Value > 0
                                                        && v.SaleFeePriceSnapshot.HasValue
                                                        && Math.Abs(v.Price - v.SaleFeePriceSnapshot.Value) / Math.Max(v.Price, 1m) < 0.05m)
                                                    {
                                                        comisionRealPct = v.SaleFeeAmountReal.Value / v.Price * 100m;
                                                    }
                                                    else
                                                    {
                                                        comisionRealPct = CalcularComisionTotalPct(v.InstallmentTag);
                                                    }
                                                    var pctText = $"{comisionRealPct:F1}%";
                                                    var pctLabel = (v.SaleFeeAmountReal.HasValue && v.SaleFeeAmountReal.Value > 0) ? "MeLi -" : "estim.";
                                                    @if (ganancia.HasValue)
                                                    {
                                                        <div style="display:flex; align-items:center; justify-content:flex-end; gap:0.6rem; line-height:1.15;">
                                                            <div style="text-align:right;">
                                                                <div style="font-size:0.7rem; color:#6b7280;">
                                                                    @(margenPct?.ToString("F1"))% margen
                                                                </div>
                                                                <div style="font-size:0.65rem; color:#9ca3af;" title="MeLi te paga este monto antes de descontar costo. El % es lo que MeLi te descuenta en total (comisión + envío gratis + cargo fijo + cuotas).">
                                                                    neto $@neto.ToString("N0") · @pctLabel@pctText
                                                                </div>
                                                            </div>
                                                            <strong style="color:#16a34a; font-size:1.05rem; min-width:5rem; text-align:right;" title="Ganancia real = lo que MeLi te deposita ($@neto.ToString("N0")) − costo del producto ($@v.ProductCost!.Value.ToString("N0"))">
                                                                $@ganancia.Value.ToString("N0")
                                                            </strong>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div style="display:flex; align-items:center; justify-content:flex-end; gap:0.6rem; line-height:1.15;">
                                                            <div style="text-align:right;">
                                                                <div style="font-size:0.7rem; color:#6b7280;">neto · @pctLabel@pctText</div>
                                                                <div style="font-size:0.65rem; color:#dc2626;" title="No hay costo cargado en el producto del sistema">
                                                                    ⚠ sin costo en sistema
                                                                </div>
                                                            </div>
                                                            <strong style="color:#16a34a; font-size:1.05rem; min-width:5rem; text-align:right;">$@neto.ToString("N0")</strong>
                                                        </div>
                                                    }
                                                }
