    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var filtered = GetCachedFilteredItems();
        if (filtered == null) return;

        var allSelected = IsAllSelected();
        if (allSelected)
            selectedItems.Clear();
        else
        {
            foreach (var item in filtered)
                selectedItems.Add(item.Id);
