    private async Task SaveItem()
    {
        if (selectedItem is null) return;

        isSaving = true;
        StateHasChanged();

        try
        {
            // Build request with only changed fields
            var request = new UpdateMeliItemRequest();
            bool hasChanges = false;

            if (editTitle != selectedItem.Title)
            {
                request.Title = editTitle;
                hasChanges = true;
            }
            if (editPrice != selectedItem.Price)
            {
                request.Price = editPrice;
                hasChanges = true;
            }
            if (editStock != selectedItem.AvailableQuantity)
            {
                request.AvailableQuantity = editStock;
                hasChanges = true;
            }
            if (editStatus != selectedItem.Status)
            {
                request.Status = editStatus;
                hasChanges = true;
            }

            if (!hasChanges)
            {
                ToastService.Info("No hay cambios para guardar");
                isSaving = false;
                return;
            }

            var updated = await Api.UpdateMeliItemAsync(selectedItem.MeliItemId, request);
            if (updated is not null && items is not null)
            {
                // Replace item in local list
                var idx = items.FindIndex(i => i.MeliItemId == selectedItem.MeliItemId);
                if (idx >= 0)
                    items[idx] = updated;

                selectedItem = updated;
                editTitle = updated.Title;
                editPrice = updated.Price;
                editPriceFormatted = FormatPrice(editPrice);
                editStock = updated.AvailableQuantity;
                editStatus = updated.Status;

                ToastService.Success("Publicacion actualizada");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar: " + ex.Message);
        }

        isSaving = false;
    }

