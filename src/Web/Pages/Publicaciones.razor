    // 2026-06-01: helpers visor de margen
    // 2026-07-01: ganancia se calcula SIN IVA (el recibís que trae MeLi tiene IVA adentro, el costo del sistema
    // está sin IVA). Antes el número aparecía inflado ~21%. Ahora dividimos el recibís por 1,21.
    // Usamos 21% fijo — 99% de los productos MeLi son 21%; los pocos con 10,5% se ignoran (impacto marginal).
    private const decimal IvaAlicuota = 0.21m;

    /// <summary>Recibís del simulador MeLi (con IVA adentro) dividido por 1,21 para compararlo con el costo del sistema (sin IVA).</summary>
    private decimal RecibisSinIva()
    {
        if (itemCosts is null) return 0;
        return CalculateNetAmount() / (1m + IvaAlicuota);
    }

    private decimal MarginGanancia()
    {
        if (itemProductCost is null || itemCosts is null) return 0;
        return RecibisSinIva() - itemProductCost.TotalCost;
    }
    private decimal MarginPctSobreCosto()
    {
        if (itemProductCost is null || itemProductCost.TotalCost <= 0) return 0;
        return MarginGanancia() / itemProductCost.TotalCost * 100m;
    }
    private string MarginColor()
    {
        var p = MarginPctSobreCosto();
        if (p >= 30) return "#16a34a";    // verde
        if (p >= 15) return "#eab308";    // amarillo
        if (p > 0)   return "#f97316";    // naranja
        return "#dc2626";                  // rojo
    }
    private string MarginLabel()
    {
        var p = MarginPctSobreCosto();
        if (p >= 30) return "🟢 Buenísimo";
        if (p >= 15) return "🟡 Aceptable";
        if (p > 0)   return "🟠 Bajo";
        return "🔴 Pérdida";
    }

    private string FormatTaxPct() => taxPercentage == 0 ? "0" : taxPercentage.ToString("0.##", CultureInfo.InvariantCulture);

    private decimal CalculateTaxAmount()
    {
        if (itemCosts is null) return 0;
        return Math.Round(itemCosts.Price * taxPercentage / 100m, 2);
    }

    private decimal CalculateNetAmount()
    {
        if (itemCosts is null) return 0;
        var taxes = CalculateTaxAmount();
        return Math.Round(itemCosts.Price - itemCosts.SaleFeeAmount - itemCosts.ListingFeeAmount - itemCosts.ShippingCost - taxes, 2);
    }

    // ════════════════════════════════════════════════════════════════════════
    // 2026-06-12: Calcular precio desde costo (camino inverso del simulador)
    // ════════════════════════════════════════════════════════════════════════
    private string calcGananciaModo = "%";   // "%" sobre costo | "$" fijos
    private decimal calcGananciaValor = 50m;
    private string calcRedondeo = "99";      // exacto | 99 | 999
    private bool isPushingCalcPrecio;

    /// <summary>Precio crudo que cubre costo + ganancia + todos los costos MeLi.
    /// neto(P) = P − P·comis% − cargoFijo − envío − P·retenciones% ⇒ despejamos P.
    /// El cargo fijo depende del precio (umbral $30.000): probamos las dos hipótesis.
    /// 2026-07-01: el usuario quiere ganar % SIN IVA sobre costo (sin IVA). El neto que da MeLi es CON IVA,
    /// así que multiplicamos por 1,21 para llegar al neto con IVA que necesitamos.</summary>
    private decimal? CalcPrecioCrudo()
    {
        if (itemCosts is null || itemProductCost is null || itemProductCost.TotalCost <= 0) return null;
        if (calcGananciaValor <= 0) return null;
        var costo = itemProductCost.TotalCost;
        var ganancia = calcGananciaModo == "%" ? costo * calcGananciaValor / 100m : calcGananciaValor;
        var netoNecesarioSinIva = costo + ganancia;
        var netoNecesarioConIva = netoNecesarioSinIva * (1m + IvaAlicuota);

        var price = itemCosts.Price;
        if (price <= 0) return null;
        // % que escalan con el precio: comisión (sin el fijo) + financiación + retenciones del input
        var pctEscalable = (itemCosts.SaleFeeAmount - itemCosts.FixedFee + itemCosts.FinancingFee) / price
                           + taxPercentage / 100m;
        var denom = 1m - pctEscalable;
        if (denom <= 0.05m) return null; // los costos se comen todo — no hay precio posible

        var envio = itemCosts.ShippingCost + itemCosts.ListingFeeAmount;
        var fijoActual = itemCosts.FixedFee;

        // Hipótesis B: precio >= $30.000 → sin cargo fijo
        var pSinFijo = (netoNecesarioConIva + envio) / denom;
        if (pSinFijo >= 30000m) return Math.Round(pSinFijo, 2);
        // Hipótesis A: precio < $30.000 → usamos el cargo fijo actual como estimación
        var pConFijo = (netoNecesarioConIva + envio + fijoActual) / denom;
        return Math.Round(pConFijo, 2);
    }

    private decimal? CalcPrecioFinal()
    {
        var crudo = CalcPrecioCrudo();
        if (crudo is null) return null;
        return calcRedondeo switch
        {
            "99" => Math.Ceiling(crudo.Value / 100m) * 100m - 1m,
            "999" => Math.Ceiling(crudo.Value / 1000m) * 1000m - 1m,
            _ => crudo.Value
        };
    }

    /// <summary>Neto SIN IVA estimado si publicamos al precio P (misma fórmula del simulador, escalada).
    /// 2026-07-01: dividimos por 1,21 al final para descontar el IVA — comparable con el costo del sistema.</summary>
    private decimal CalcNetoAtPrecio(decimal p)
    {
        if (itemCosts is null || itemCosts.Price <= 0) return 0;
        var price = itemCosts.Price;
        var pctEscalable = (itemCosts.SaleFeeAmount - itemCosts.FixedFee + itemCosts.FinancingFee) / price
                           + taxPercentage / 100m;
        var fijo = p >= 30000m ? 0m : itemCosts.FixedFee;
        var envio = itemCosts.ShippingCost + itemCosts.ListingFeeAmount;
        var netoConIva = p * (1m - pctEscalable) - fijo - envio;
        return Math.Round(netoConIva / (1m + IvaAlicuota), 2);
    }

    /// <summary>Par de catálogo: misma familia + mismo SKU + una es catálogo y la otra no.
    /// MeLi hermana el precio de las dos — cambiar una cambia la otra.</summary>
    private MeliItemDto? GetCatalogSibling(MeliItemDto? v)
    {
        if (v is null || items is null || string.IsNullOrEmpty(v.FamilyId) || string.IsNullOrEmpty(v.Sku)) return null;
        return items.FirstOrDefault(i =>
            i.MeliItemId != v.MeliItemId &&
            i.FamilyId == v.FamilyId &&
            i.Sku == v.Sku &&
            IsCatalogListing(i) != IsCatalogListing(v));
    }

    // Texto compacto de la receta del ajuste para el chip de la grilla: "+1% · +$100 · red.99"
    private string AjusteResumen(MeliItemDto item)
    {
        var parts = new List<string>();
        if (item.AjustePct != 0) parts.Add($"+{item.AjustePct:0.##}%");
        if (item.AjusteFijo != 0) parts.Add($"+${item.AjusteFijo:N0}");
        if (!string.IsNullOrEmpty(item.AjusteRedondeo)) parts.Add($"red.{item.AjusteRedondeo}");
        return string.Join(" · ", parts);
    }

