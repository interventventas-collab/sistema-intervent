@page "/cafe/cotejo"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>🔎 Cotejo MercadoLibre &harr; Contabilium</h3>
        <div style="display: flex; gap: 0.5rem;">
            <button class="btn btn-secondary" @onclick="LoadResumen" disabled="@isBusy">Refrescar</button>
            <button class="btn btn-secondary" @onclick="VincularOems" disabled="@isBusy" title="Detecta y vincula OEMs en productos sin OEM (ej: C8733NEG -> OEM 8733)">
                🔗 Vincular OEMs
            </button>
            <button class="btn btn-primary" @onclick="ImportarStaging" disabled="@isBusy">
                @(isBusy ? "Cargando..." : "Cargar Excels de Contabilium")
            </button>
        </div>
    </div>
    <div class="card-body">
        @if (resumen is null)
        {
            <p style="color:#6b7280;">Tocá <b>"Cargar Excels de Contabilium"</b> la primera vez. Eso lee los archivos de la carpeta <code>base de datos contabilium</code> y los guarda para cotejarlos contra MercadoLibre.</p>
        }
        else
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 0.7rem; margin-bottom: 1rem;">
                <div class="stat-mini" style="--c:#1e3a8a;">
                    <div class="stat-mini-num">@resumen.TotalPublicaciones</div>
                    <div class="stat-mini-lbl">Publicaciones MeLi</div>
                </div>
                <div class="stat-mini" style="--c:#0e7490;">
                    <div class="stat-mini-num">@resumen.Producto</div>
                    <div class="stat-mini-lbl">Productos</div>
                </div>
                <div class="stat-mini" style="--c:#7c3aed;">
                    <div class="stat-mini-num">@resumen.Combo</div>
                    <div class="stat-mini-lbl">Combos</div>
                </div>
                <div class="stat-mini" style="--c:#b91c1c;">
                    <div class="stat-mini-num">@resumen.Huerfano</div>
                    <div class="stat-mini-lbl">Huérfanos</div>
                </div>
                <div class="stat-mini" style="--c:#9ca3af;">
                    <div class="stat-mini-num">@resumen.SinSku</div>
                    <div class="stat-mini-lbl">Sin SKU</div>
                </div>
                <div class="stat-mini" style="--c:#d97706;">
                    <div class="stat-mini-num">@resumen.CombosConComponentesFaltantes</div>
                    <div class="stat-mini-lbl">Combos con componentes faltantes</div>
                </div>
            </div>

            @* Barra de progreso de vinculacion *@
            <div style="margin-bottom: 1rem; padding: 0.8rem 1rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px;">
                <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.4rem;">
                    <div style="font-weight:700; color:#374151;">
                        🚀 Progreso del cotejo
                        <span style="font-size:0.78rem; color:#6b7280; font-weight:500; margin-left:0.4rem;">
                            (productos + combos vinculables, sin contar huérfanos ni sin SKU)
                        </span>
                    </div>
                    <div style="font-size:1.25rem; font-weight:800; color:@(resumen.PorcentajeVinculado >= 100 ? "#15803d" : "#1e3a8a");">
                        @resumen.PorcentajeVinculado%
                    </div>
                </div>
                <div style="height:10px; background:#e5e7eb; border-radius:5px; overflow:hidden;">
                    <div style="height:100%; width:@(resumen.PorcentajeVinculado)%; background:linear-gradient(90deg,#3b82f6,#10b981); transition:width 0.3s;"></div>
                </div>
                <div style="margin-top:0.4rem; font-size:0.82rem; color:#6b7280; display:flex; gap:1rem; flex-wrap:wrap;">
                    <span><b>@resumen.VinculadosTotal</b> de @resumen.VinculablesTotal vinculados</span>
                    <span style="color:#0e7490;">Productos: @resumen.ProductoVinculados / @resumen.Producto</span>
                    <span style="color:#7c3aed;">Combos: @resumen.ComboVinculados / @resumen.Combo</span>
                    @if (resumen.PorcentajeVinculado >= 100)
                    {
                        <span style="color:#15803d; font-weight:700;">🎉 ¡Todo vinculado!</span>
                    }
                </div>
            </div>

            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; margin-bottom: 0.7rem;">
                <select class="form-input" @bind="categoria" @bind:after="LoadListado" style="max-width: 180px;">
                    <option value="todos">Todas las filas</option>
                    <option value="producto">Solo Productos</option>
                    <option value="combo">Solo Combos</option>
                    <option value="huerfano">Solo Huérfanos</option>
                    <option value="sin_sku">Solo sin SKU</option>
                </select>
                <select class="form-input" @bind="filtroVinculacion" @bind:after="LoadListado" style="max-width: 180px;">
                    <option value="">Vinculación: todos</option>
                    <option value="sin_vincular">⏳ Sin vincular</option>
                    <option value="vinculados">✓ Ya vinculados</option>
                </select>
                <input class="form-input" placeholder="Buscar (SKU / titulo / MLA)"
                       value="@buscar" @oninput="@(e => buscar = e.Value?.ToString() ?? "")"
                       @onkeydown="OnFilterKey"
                       style="flex: 1; min-width: 220px;" />
                <input class="form-input" placeholder="Filtrar por marca de Contab"
                       value="@filtroMarcaContab" @oninput="@(e => filtroMarcaContab = e.Value?.ToString() ?? "")"
                       @onkeydown="OnFilterKey"
                       style="max-width: 240px;" />
                <button class="btn btn-primary" @onclick="LoadListado" disabled="@isBusy">Aplicar filtros</button>
                <button class="btn btn-secondary" @onclick="LimpiarFiltros" disabled="@isBusy">Limpiar</button>
            </div>

            @if (listado is null)
            {
                <p style="color:#6b7280;">Cargando listado...</p>
            }
            else if (listado.Count == 0)
            {
                <p style="color:#6b7280;">Sin resultados con esos filtros.</p>
            }
            else
            {
                <!-- Barra de seleccion masiva -->
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center; margin-bottom:0.7rem; padding:0.6rem 0.7rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px;">
                    <span style="font-weight:700; color:#374151;">
                        @SeleccionadosCount seleccionado(s) — @SelProductosCount productos · @SelKitsCount kits
                    </span>
                    <span style="flex:1;"></span>

                    <select class="form-input" @bind="categoriaACrear" style="max-width:130px;">
                        <option value="OTROS">Categoria: OTROS</option>
                        <option value="CAFE">Categoria: CAFE</option>
                    </select>

                    <select class="form-input" @bind="marcaIdACrear" style="max-width:240px;">
                        <option value="">— Sin marca —</option>
                        @if (marcas is not null)
                        {
                            @foreach (var m in marcas.OrderBy(x => x.Nombre))
                            {
                                <option value="@m.Id">@m.Nombre</option>
                            }
                        }
                    </select>

                    <button class="btn btn-primary" @onclick="CrearProductosSeleccionados"
                            disabled="@(SelProductosCount == 0 || isBusy)" title="Solo crea filas tipo 'producto'">
                        @(isBusy ? "Creando..." : $"Crear {SelProductosCount} producto(s)")
                    </button>
                    <button class="btn btn-primary" @onclick="CrearKitsSeleccionados"
                            disabled="@(SelKitsCount == 0 || isBusy)" title="Solo crea filas tipo 'combo' (= kit en el ERP)">
                        @(isBusy ? "Creando..." : $"Crear {SelKitsCount} kit(s)")
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="data-table" style="font-size: 0.85rem;">
                        <thead>
                            <tr>
                                <th style="width:32px;">
                                    <input type="checkbox" @onchange="ToggleAll" checked="@AllSelected" disabled="@(ListadoCreables == 0)" />
                                </th>
                                <th style="width:80px;">Tipo</th>
                                <th style="width:120px;">SKU MeLi</th>
                                <th>Publicación MeLi</th>
                                <th style="width:80px;">Stock MeLi</th>
                                <th>Match en Contabilium</th>
                                <th style="width:160px;">Marca Contab</th>
                                <th style="width:110px;">Precio Contab</th>
                                <th style="width:90px;">Stock Contab</th>
                                <th style="width:80px;">Vinculado</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var f in listado)
                        {
                            var creable = EsCreable(f);
                            <tr style="@(f.ComboTieneFaltantes ? "background:#fef3c7;" : "")">
                                <td>
                                    @if (creable)
                                    {
                                        <input type="checkbox" checked="@(seleccion.Contains(f.Sku!))"
                                               @onchange="@(e => Toggle(f.Sku!, (bool)e.Value!))" />
                                    }
                                </td>
                                <td>
                                    @if (f.Categoria == "producto")
                                    {
                                        <span class="badge" style="background:#dbeafe;color:#1e40af;">Producto</span>
                                    }
                                    else if (f.Categoria == "combo")
                                    {
                                        <span class="badge" style="background:#ede9fe;color:#6d28d9;">Combo</span>
                                        @if (f.ComboTieneFaltantes)
                                        {
                                            <span title="Algun componente del combo no esta en productos de Contabilium" style="color:#b45309;font-weight:700;">⚠</span>
                                        }
                                    }
                                    else if (f.Categoria == "huerfano")
                                    {
                                        <span class="badge" style="background:#fee2e2;color:#b91c1c;">Huérfano</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#f3f4f6;color:#4b5563;">Sin SKU</span>
                                    }
                                </td>
                                <td><code style="font-size:0.82rem;">@(f.Sku ?? "—")</code></td>
                                <td>
                                    <a href="https://articulo.mercadolibre.com.ar/@(f.MeliItemId.Replace("MLA","MLA-"))" target="_blank" style="color:#1e40af;">@f.Title</a>
                                    @if (!string.IsNullOrEmpty(f.VariationAttributes))
                                    {
                                        <div style="font-size:0.75rem;color:#6b7280;">↳ @f.VariationAttributes</div>
                                    }
                                </td>
                                <td>@f.AvailableQuantity</td>
                                <td>@(f.ContabNombre ?? "—")</td>
                                <td style="font-size:0.78rem;color:#6b7280;">@(f.MarcaContab ?? "—")</td>
                                <td>@(f.ContabPrecioFinal.HasValue ? $"$ {f.ContabPrecioFinal:N2}" : "—")</td>
                                <td>@(f.ContabStock.HasValue ? f.ContabStock.Value.ToString("N0") : "—")</td>
                                <td>
                                    @if (f.CafeProductoIdVinculado.HasValue || f.CafeComboIdVinculado.HasValue || f.CafeKitIdVinculado.HasValue)
                                    {
                                        <span title="Vinculado al modulo Cafe" style="color:#16a34a;font-weight:700;">✓</span>
                                    }
                                    else if (f.ProductIdVinculado.HasValue || f.ComboIdVinculado.HasValue)
                                    {
                                        <span title="Vinculado al sistema legacy" style="color:#9ca3af;">≈</span>
                                    }
                                    else
                                    {
                                        <span style="color:#9ca3af;">—</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
                <p style="font-size:0.8rem;color:#6b7280;margin-top:0.4rem;">
                    Mostrando @listado.Count fila(s). Subi el límite con un buscador específico para ver más.
                    <span style="margin-left:0.6rem; color:#9ca3af;">"Marca Contab" es solo informativo (es el "Proveedor" del Excel) — la marca real se asigna desde el dropdown de arriba.</span>
                </p>
            }
        }
    </div>
</div>

<style>
    .stat-mini { background: white; border: 1px solid var(--c, #e5e7eb); border-left: 4px solid var(--c, #1e3a8a); border-radius: 6px; padding: 0.6rem 0.8rem; }
    .stat-mini-num { font-size: 1.45rem; font-weight: 800; color: var(--c, #1e3a8a); line-height: 1; }
    .stat-mini-lbl { font-size: 0.78rem; color: #6b7280; margin-top: 0.2rem; }
    .badge { padding: 0.15rem 0.45rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700; }
</style>

@code {
    private CotejoResumenDto? resumen;
    private List<CotejoFilaDto>? listado;
    private List<CafeMarcaDto>? marcas;
    private string categoria = "todos";
    private string buscar = "";
    private string filtroMarcaContab = "";
    private string filtroVinculacion = "";
    private bool isBusy;

    // Seleccion masiva
    private HashSet<string> seleccion = new(StringComparer.OrdinalIgnoreCase);
    private string categoriaACrear = "OTROS";
    private string marcaIdACrear = ""; // string para bind del select

    private int SeleccionadosCount => seleccion.Count;
    private int ListadoCreables => listado?.Count(EsCreable) ?? 0;
    private bool AllSelected => listado is not null && ListadoCreables > 0
        && listado.Where(EsCreable).All(f => seleccion.Contains(f.Sku!));

    private int SelProductosCount => listado is null ? 0
        : listado.Count(f => seleccion.Contains(f.Sku ?? "") && f.Categoria == "producto");
    private int SelKitsCount => listado is null ? 0
        : listado.Count(f => seleccion.Contains(f.Sku ?? "") && f.Categoria == "combo");

    // Es creable: producto sin vincular a CafeProducto, o combo sin vincular a CafeKit.
    private bool EsCreable(CotejoFilaDto f)
        => !string.IsNullOrEmpty(f.Sku)
           && (
                (f.Categoria == "producto" && !f.CafeProductoIdVinculado.HasValue)
                || (f.Categoria == "combo" && !f.CafeKitIdVinculado.HasValue)
              );

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadResumen(), LoadMarcas());
    }

    private async Task LoadMarcas()
    {
        try { marcas = await Api.GetCafeMarcasAsync(activos: true); }
        catch (Exception ex) { ToastService.Error("Error cargando marcas: " + ex.Message); }
    }

    private async Task LoadResumen()
    {
        try
        {
            resumen = await Api.GetCotejoResumenAsync();
            if (resumen is not null && resumen.ProductosCargados > 0)
                await LoadListado();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task LoadListado()
    {
        try
        {
            listado = await Api.GetCotejoListadoAsync(
                categoria,
                string.IsNullOrWhiteSpace(buscar) ? null : buscar,
                marcaContab: string.IsNullOrWhiteSpace(filtroMarcaContab) ? null : filtroMarcaContab,
                vinculacion: string.IsNullOrWhiteSpace(filtroVinculacion) ? null : filtroVinculacion);
            // Limpiamos seleccion de SKUs que ya no estan en la vista actual.
            if (listado is not null)
            {
                var visibles = listado.Where(EsCreable).Select(f => f.Sku!).ToHashSet(StringComparer.OrdinalIgnoreCase);
                seleccion.IntersectWith(visibles);
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private void Toggle(string sku, bool on)
    {
        if (on) seleccion.Add(sku);
        else seleccion.Remove(sku);
    }

    private void ToggleAll(ChangeEventArgs e)
    {
        var on = (bool)(e.Value ?? false);
        if (listado is null) return;
        foreach (var f in listado.Where(EsCreable))
        {
            if (on) seleccion.Add(f.Sku!);
            else seleccion.Remove(f.Sku!);
        }
    }

    private async Task OnFilterKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadListado();
    }

    private async Task LimpiarFiltros()
    {
        categoria = "todos";
        buscar = "";
        filtroMarcaContab = "";
        filtroVinculacion = "";
        await LoadListado();
    }

    private async Task VincularOems()
    {
        isBusy = true;
        try
        {
            var r = await Api.VincularOemsAutomaticoAsync();
            if (r is not null)
                ToastService.Success($"OEMs vinculados: {r.Vinculados} de {r.Procesados} productos sin OEM.");
            await LoadListado();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isBusy = false; }
    }

    private async Task ImportarStaging()
    {
        isBusy = true;
        try
        {
            var r = await Api.ImportContabiliumStagingAsync();
            if (r is not null)
            {
                ToastService.Success($"Cargado: {r.Productos} productos, {r.Combos} combos, {r.ComboItems} componentes.");
                if (r.Warnings.Count > 0) ToastService.Error(string.Join(" / ", r.Warnings));
            }
            await LoadResumen();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isBusy = false; }
    }

    private async Task CrearProductosSeleccionados()
    {
        if (listado is null) return;
        var skusProductos = listado
            .Where(f => seleccion.Contains(f.Sku ?? "") && f.Categoria == "producto")
            .Select(f => f.Sku!).Distinct().ToList();
        if (skusProductos.Count == 0) return;
        isBusy = true;
        try
        {
            int? marcaId = null;
            if (int.TryParse(marcaIdACrear, out var mid)) marcaId = mid;

            var req = new CrearProductosCotejoRequest
            {
                Skus = skusProductos,
                MarcaId = marcaId,
                Categoria = categoriaACrear
            };
            var r = await Api.CrearProductosCotejoAsync(req);
            if (r is not null)
            {
                ToastService.Success($"Productos creados: {r.Creados} · Vinculados: {r.Vinculados} · Omitidos: {r.Omitidos}");
                foreach (var s in skusProductos) seleccion.Remove(s);
                await Task.WhenAll(LoadResumen(), LoadListado());
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isBusy = false; }
    }

    private async Task CrearKitsSeleccionados()
    {
        if (listado is null) return;
        var skusCombos = listado
            .Where(f => seleccion.Contains(f.Sku ?? "") && f.Categoria == "combo")
            .Select(f => f.Sku!).Distinct().ToList();
        if (skusCombos.Count == 0) return;
        isBusy = true;
        try
        {
            int? marcaId = null;
            if (int.TryParse(marcaIdACrear, out var mid)) marcaId = mid;

            var req = new CrearKitsCotejoRequest
            {
                Skus = skusCombos,
                MarcaId = marcaId,
                Categoria = categoriaACrear
            };
            var r = await Api.CrearKitsCotejoAsync(req);
            if (r is not null)
            {
                ToastService.Success(
                    $"Kits creados: {r.KitsCreados} · Componentes nuevos: {r.ComponentesCreados} · " +
                    $"Vinculados a MeLi: {r.VinculadosMeli} · Omitidos: {r.Omitidos}");
                foreach (var s in skusCombos) seleccion.Remove(s);
                await Task.WhenAll(LoadResumen(), LoadListado());
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isBusy = false; }
    }
}
