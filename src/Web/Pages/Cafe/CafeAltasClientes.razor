@page "/cafe/altas-clientes"
@attribute [Authorize]
@using Web.Models
@inject ApiClient Api
@inject ToastService ToastService
@inject OperatorService Operator
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Altas de clientes cargadas por el propio cliente desde el enlace público.
   El operador ve el enlace para compartir + la lista de altas pendientes, y con un
   botón las convierte en clientes reales. Pedido de Osmar 2026-07-20. *@

<div class="card" style="margin-bottom: 1rem;">
    <div class="card-header">
        <h3>🔗 Enlace para que el cliente cargue sus datos</h3>
    </div>
    <div class="card-body">
        <p style="color:#4b5563; font-size:0.9rem; margin-top:0;">
            Mandale este enlace al cliente por WhatsApp o mail. Él completa sus datos solo
            (sin usuario ni clave) y te aparecen acá abajo para que lo des de alta.
        </p>
        @if (link is not null)
        {
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                <input readonly value="@LinkCompleto" style="flex:1; min-width:240px; padding:0.55rem 0.7rem; border:1.5px solid #d1d5db; border-radius:8px; font-size:0.85rem; background:#f9fafb; color:#111827;" />
                <button class="btn btn-primary" @onclick="CopiarLink">📋 Copiar</button>
                <button class="btn btn-secondary" @onclick="RegenerarLink" title="Genera un enlace nuevo; el anterior deja de funcionar">🔄 Nuevo enlace</button>
            </div>
        }
        else
        {
            <p style="color:#9ca3af;">Cargando enlace…</p>
        }
    </div>
</div>

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h3>🆕 Altas pendientes @(pendientes is { Count: > 0 } ? $"({pendientes.Count})" : "")</h3>
        <button class="btn btn-secondary btn-sm" @onclick="Cargar">↻ Actualizar</button>
    </div>
    <div class="card-body">
        @if (cargando)
        {
            <p style="color:#9ca3af;">Cargando…</p>
        }
        else if (pendientes is null || pendientes.Count == 0)
        {
            <div style="text-align:center; padding:2rem 1rem; color:#9ca3af;">
                <div style="font-size:2.5rem;">📭</div>
                <p>No hay altas pendientes por ahora.</p>
            </div>
        }
        else
        {
            @foreach (var a in pendientes)
            {
                <div class="alta-item">
                    <div class="alta-main">
                        <div class="alta-nombre">🏪 @a.NombreFantasia</div>
                        <div class="alta-datos">
                            @if (!string.IsNullOrWhiteSpace(a.RazonSocial)) { <span>📄 @a.RazonSocial</span> }
                            @if (!string.IsNullOrWhiteSpace(a.Cuit)) { <span>🧾 @a.Cuit</span> }
                            @if (!string.IsNullOrWhiteSpace(a.CondicionIva)) { <span>@IvaLabel(a.CondicionIva)</span> }
                            <span>📞 @a.Telefono</span>
                            @if (!string.IsNullOrWhiteSpace(a.ContactoNombre)) { <span>👤 @a.ContactoNombre</span> }
                            @if (!string.IsNullOrWhiteSpace(a.Email)) { <span>✉️ @a.Email</span> }
                            @if (!string.IsNullOrWhiteSpace(a.Direccion)) { <span>📍 @a.Direccion@(string.IsNullOrWhiteSpace(a.Localidad) ? "" : $", {a.Localidad}")</span> }
                            @if (!string.IsNullOrWhiteSpace(a.EntreCalles)) { <span>↔️ @a.EntreCalles</span> }
                            @if (!string.IsNullOrWhiteSpace(a.MapeoLink)) { <span>🗺️ <a href="@a.MapeoLink" target="_blank">ubicación</a></span> }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(a.Comentarios))
                        {
                            <div class="alta-coment">💬 @a.Comentarios</div>
                        }
                        <div class="alta-fecha">Enviado @a.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="alta-acciones">
                        <label class="alta-tipo">
                            Tipo:
                            <select value="@(tipos.TryGetValue(a.Id, out var tv) ? tv : "OTRO")"
                                    @onchange="(e) => SetTipo(a.Id, e)">
                                <option value="OTRO">Otro</option>
                                <option value="BAR">Bar</option>
                            </select>
                        </label>
                        <button class="btn btn-success btn-sm" @onclick="() => Aprobar(a)" disabled="@procesando">✅ Dar de alta</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => Rechazar(a)" disabled="@procesando">🗑️ Descartar</button>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .alta-item { border:1px solid #e5e7eb; border-radius:12px; padding:0.9rem 1rem; margin-bottom:0.8rem;
                 display:flex; gap:1rem; flex-wrap:wrap; justify-content:space-between; align-items:flex-start; background:#fff; }
    .alta-main { flex:1; min-width:240px; }
    .alta-nombre { font-weight:800; font-size:1.05rem; color:#111827; margin-bottom:0.35rem; }
    .alta-datos { display:flex; flex-wrap:wrap; gap:0.35rem 0.9rem; font-size:0.83rem; color:#374151; }
    .alta-coment { margin-top:0.45rem; font-size:0.83rem; color:#6b7280; font-style:italic; background:#f9fafb; padding:0.4rem 0.6rem; border-radius:7px; }
    .alta-fecha { margin-top:0.4rem; font-size:0.72rem; color:#9ca3af; }
    .alta-acciones { display:flex; flex-direction:column; gap:0.4rem; align-items:stretch; min-width:150px; }
    .alta-tipo { font-size:0.78rem; color:#6b7280; display:flex; align-items:center; gap:0.35rem; }
    .alta-tipo select { flex:1; padding:0.35rem; border:1px solid #d1d5db; border-radius:6px; }
</style>

@code {
    private AltaLinkDto? link;
    private List<CafeClienteAltaDto>? pendientes;
    private bool cargando = true;
    private bool procesando = false;
    private Dictionary<int, string> tipos = new();

    private string LinkCompleto => link is null ? "" : Nav.BaseUri.TrimEnd('/') + link.Ruta;

    protected override async Task OnInitializedAsync()
    {
        try { link = await Api.GetAltaClientesLinkAsync(); } catch { }
        await Cargar();
    }

    private async Task Cargar()
    {
        cargando = true;
        try { pendientes = await Api.GetAltasClientesPendientesAsync(); }
        catch { ToastService.Error("No se pudieron cargar las altas."); }
        finally { cargando = false; }
    }

    private void SetTipo(int id, ChangeEventArgs e)
        => tipos[id] = e.Value?.ToString() ?? "OTRO";

    private async Task CopiarLink()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", LinkCompleto); ToastService.Success("Enlace copiado ✔"); }
        catch { ToastService.Info("Copialo manualmente: " + LinkCompleto); }
    }

    private async Task RegenerarLink()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Generar un enlace nuevo? El enlace anterior dejará de funcionar."))
            return;
        try { link = await Api.RegenerarAltaClientesLinkAsync(); ToastService.Success("Enlace nuevo generado."); }
        catch { ToastService.Error("No se pudo generar el enlace."); }
    }

    private async Task Aprobar(CafeClienteAltaDto a)
    {
        procesando = true;
        try
        {
            var req = new AprobarAltaClienteRequest
            {
                NombreFantasia = a.NombreFantasia,
                RazonSocial = a.RazonSocial,
                Cuit = a.Cuit,
                CondicionIva = a.CondicionIva,
                ContactoNombre = a.ContactoNombre,
                Telefono = a.Telefono,
                Email = a.Email,
                Direccion = a.Direccion,
                EntreCalles = a.EntreCalles,
                Localidad = a.Localidad,
                MapeoLink = a.MapeoLink,
                Comentarios = a.Comentarios,
                Tipo = tipos.TryGetValue(a.Id, out var t) ? t : "OTRO",
                Operador = Operator.Current
            };
            var r = await Api.AprobarAltaClienteAsync(a.Id, req);
            if (r?.Ok == true)
            {
                ToastService.Success($"Cliente dado de alta (código {r.Codigo}) ✔");
                pendientes?.Remove(a);
            }
            else { ToastService.Error("No se pudo dar de alta."); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { procesando = false; }
    }

    private async Task Rechazar(CafeClienteAltaDto a)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Descartar la solicitud de '{a.NombreFantasia}'?"))
            return;
        procesando = true;
        try
        {
            var ok = await Api.RechazarAltaClienteAsync(a.Id, null, Operator.Current);
            if (ok) { ToastService.Success("Solicitud descartada."); pendientes?.Remove(a); }
            else { ToastService.Error("No se pudo descartar."); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { procesando = false; }
    }

    private static string IvaLabel(string? iva) => iva switch
    {
        "RI" => "Resp. Inscripto",
        "MO" => "Monotributo",
        "EX" => "Exento",
        "CF" => "Cons. Final",
        _ => iva ?? ""
    };
}
