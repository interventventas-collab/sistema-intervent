@page "/cafe/meli-push"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject ToastService ToastService
@using Web.Services

<div class="card" style="max-width: 1400px; margin: 1rem auto;">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>☕ Push de precios y stock de café a MercadoLibre</h3>
        <button class="btn btn-secondary" @onclick="Recargar" disabled="@loading">@(loading ? "..." : "🔄 Recalcular preview")</button>
    </div>
    <div class="card-body">

        <div style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; padding: 0.7rem 1rem; margin-bottom: 1rem; font-size: 0.88rem;">
            ⚠ <strong>Importante:</strong> el precio nuevo se calcula como:
            <code>Precio_NETO_sistema × 1.21 (IVA) × Ratio_de_publicación</code>.
            El <strong>ratio</strong> de cada publicación captura: cuotas + envío gratis + comisión MeLi + margen. Se midió la primera vez que linkeamos los items.
            Si el precio sistema sube/baja, MeLi se mueve proporcionalmente respetando cada ratio.
        </div>

        @if (loading)
        {
            <p style="text-align: center; padding: 2rem; color: #6b7280;">⏳ Cargando preview...</p>
        }
        else if (rows is null || rows.Count == 0)
        {
            <p>Sin datos para mostrar.</p>
        }
        else
        {
            <p style="font-size: 0.88rem; color: #4b5563; margin-bottom: 0.6rem;">
                <strong>@rows.Count publicaciones</strong> listas para actualizar. Filas en <span style="background: #fee2e2; padding: 0.05rem 0.3rem;">rojo</span> = diferencia importante (precio baja o sube > 5%).
            </p>

            @* Buscador para filtrar por SKU o por MeLi ID — útil cuando hay muchas publicaciones del mismo café *@
            <div style="margin-bottom: 0.6rem; display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
                <input class="form-input" style="max-width: 400px; padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       placeholder="🔍 Buscar por SKU, MeLi ID o producto..." @bind="busqueda" @bind:event="oninput" />
                @if (!string.IsNullOrWhiteSpace(busqueda))
                {
                    <button class="btn btn-secondary" style="font-size: 0.78rem; padding: 0.25rem 0.6rem;"
                            @onclick="@(() => busqueda = "")">✕ Limpiar</button>
                }
                <span style="font-size: 0.78rem; color: #6b7280;">
                    @FilteredRows().Count() de @rows.Count
                </span>
            </div>

            <div class="table-responsive" style="max-height: 60vh; overflow-y: auto;">
                <table class="data-table" style="font-size: 0.82rem;">
                    <thead style="position: sticky; top: 0; background: white; z-index: 5;">
                        <tr>
                            <th>SKU</th>
                            <th>MeLi ID</th>
                            <th>Producto</th>
                            <th>Fmt</th>
                            <th class="num">Ratio</th>
                            <th class="num">Precio Actual</th>
                            <th class="num">Precio Nuevo</th>
                            <th class="num">Δ Precio</th>
                            <th class="num">Stock Actual</th>
                            <th class="num">Stock Nuevo</th>
                            <th style="width: 80px; text-align: center;">Push</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in FilteredRows().OrderBy(x => x.ProductoSku).ThenBy(x => x.Formato).ThenBy(x => x.MeliItemId))
                        {
                            var diffP = r.PrecioNuevoMeLi - r.PrecioActualMeLi;
                            var diffPct = r.PrecioActualMeLi > 0 ? Math.Round(diffP * 100 / r.PrecioActualMeLi, 1) : 0;
                            var rowClass = Math.Abs(diffPct) > 5 ? "background:#fee2e2;" : "";
                            var rowMeliId = r.MeliItemId;
                            <tr style="@rowClass">
                                <td style="font-family: monospace;">@r.MeliSku</td>
                                <td style="font-family: monospace; font-size: 0.72rem; color: #1d4ed8;">
                                    <a href="https://articulo.mercadolibre.com.ar/@r.MeliItemId" target="_blank" style="text-decoration:none; color:inherit;" title="Abrir en MeLi">@r.MeliItemId</a>
                                </td>
                                <td>@r.ProductoNombre</td>
                                <td>@r.Formato</td>
                                <td class="num">@r.Ratio.ToString("0.000")</td>
                                <td class="num">$ @FormatM(r.PrecioActualMeLi)</td>
                                <td class="num"><strong>$ @FormatM(r.PrecioNuevoMeLi)</strong></td>
                                <td class="num" style="color:@(diffP > 0 ? "#15803d" : diffP < 0 ? "#b91c1c" : "#6b7280");">
                                    @(diffP > 0 ? "+" : "")@FormatM(diffP) (@(diffPct > 0 ? "+" : "")@diffPct%)
                                </td>
                                <td class="num">@r.StockActualMeLi</td>
                                <td class="num"><strong>@r.StockNuevoMeLi</strong></td>
                                <td style="text-align: center;">
                                    @if (pushingOneId == rowMeliId)
                                    {
                                        <span style="color: #1d4ed8; font-size: 0.78rem;">⏳</span>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary" style="padding: 0.2rem 0.5rem; font-size: 0.75rem;"
                                                disabled="@(!string.IsNullOrEmpty(pushingOneId) || pushing)"
                                                @onclick="() => PushOne(rowMeliId)" title="Pushear solo esta publicación a MeLi">
                                            🚀
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="margin-top: 1rem; padding: 0.8rem; background: #f3f4f6; border-radius: 8px; display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                @if (pushing)
                {
                    <strong style="color: #1d4ed8;">⏳ Push en curso. No cierres la pestaña.</strong>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="DoPush" disabled="@(rows.Count == 0)">
                        🚀 Pushear @rows.Count publicaciones a MercadoLibre
                    </button>
                    <span style="font-size: 0.78rem; color: #6b7280;">
                        Esto va a tardar ~@(rows.Count * 2 / 60 + 1) min (rate limit defensivo).
                    </span>
                }
            </div>

            @if (!string.IsNullOrEmpty(pushMessage))
            {
                <div style="margin-top: 0.8rem; padding: 0.6rem 0.9rem; background: @(pushOk ? "#dcfce7" : "#fee2e2"); border: 1px solid @(pushOk ? "#16a34a" : "#dc2626"); border-radius: 6px; color: @(pushOk ? "#14532d" : "#991b1b"); white-space: pre-wrap;">
                    @pushMessage
                </div>
            }
        }
    </div>
</div>

<style>
    .data-table .num { text-align: right; font-variant-numeric: tabular-nums; font-family: monospace; }
</style>

@code {
    private bool loading = true;
    private bool pushing;
    private string? pushingOneId; // MeliItemId que se está pusheando ahora (botón individual)
    private List<ApiClient.CafePushPreviewRowDto>? rows;
    private string? pushMessage;
    private bool pushOk;
    private string busqueda = ""; // filtro por SKU / MeLi ID / nombre

    private IEnumerable<ApiClient.CafePushPreviewRowDto> FilteredRows()
    {
        if (rows is null) return Enumerable.Empty<ApiClient.CafePushPreviewRowDto>();
        var q = (busqueda ?? "").Trim();
        if (string.IsNullOrEmpty(q)) return rows;
        return rows.Where(r =>
            (r.MeliSku ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
            || (r.MeliItemId ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
            || (r.ProductoSku ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
            || (r.ProductoNombre ?? "").Contains(q, StringComparison.OrdinalIgnoreCase));
    }
    private System.Threading.Timer? statusTimer;

    protected override async Task OnInitializedAsync()
    {
        await Recargar();
        // Si hay un push en curso, retomar polling.
        try
        {
            var s = await Api.GetCafePushStatusAsync();
            if (s?.Running == true)
            {
                pushing = true;
                pushMessage = "⏳ Hay un push en curso. Esperando...";
                statusTimer = new System.Threading.Timer(async _ => await InvokeAsync(CheckStatus), null,
                    TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
            }
        }
        catch { }
    }

    private async Task Recargar()
    {
        loading = true;
        try
        {
            var r = await Api.GetCafePushPreviewAsync();
            rows = r?.Rows ?? new();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { loading = false; }
    }

    /// <summary>Pushea una sola publicación a MeLi. Es sincrónico (no background) porque es 1 sola.</summary>
    private async Task PushOne(string meliItemId)
    {
        if (!string.IsNullOrEmpty(pushingOneId) || pushing) return;
        pushingOneId = meliItemId;
        pushMessage = null;
        try
        {
            var r = await Api.RunCafePushOneAsync(meliItemId);
            if (r is null)
            {
                pushOk = false;
                pushMessage = $"❌ {meliItemId}: no se pudo ejecutar.";
            }
            else if (r.Ok > 0)
            {
                pushOk = true;
                pushMessage = $"✅ Pusheado OK: {string.Join("\n", r.Mensajes)}";
                ToastService.Success("Publicación pusheada");
                await Recargar();
            }
            else
            {
                pushOk = false;
                pushMessage = $"❌ Falló: {string.Join("\n", r.Mensajes)}";
                ToastService.Error("Error pushing");
            }
        }
        catch (Exception ex)
        {
            pushOk = false;
            pushMessage = "❌ " + ex.Message;
        }
        finally { pushingOneId = null; }
    }

    private async Task DoPush()
    {
        pushMessage = null;
        pushing = true;
        try
        {
            var r = await Api.RunCafePushAsync();
            if (r is null)
            {
                pushing = false;
                pushOk = false;
                pushMessage = "❌ No se pudo iniciar el push.";
                return;
            }
            pushOk = true;
            pushMessage = "⏳ Push iniciado en background. Podés cerrar la pestaña.\nEl estado se actualiza cada 10 segundos abajo.";
            ToastService.Success("Push iniciado");
            statusTimer = new System.Threading.Timer(async _ => await InvokeAsync(CheckStatus), null,
                TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
        }
        catch (Exception ex) { pushOk = false; pushMessage = "❌ " + ex.Message; pushing = false; }
    }

    private async Task CheckStatus()
    {
        try
        {
            var s = await Api.GetCafePushStatusAsync();
            if (s is null) return;
            if (s.Running)
            {
                var seg = s.StartedAt.HasValue ? (int)(DateTime.UtcNow - s.StartedAt.Value).TotalSeconds : 0;
                pushMessage = $"⏳ Pusheando... ({seg / 60} min {seg % 60} seg). No cierres la pestaña.";
            }
            else
            {
                statusTimer?.Dispose();
                statusTimer = null;
                pushing = false;
                if (!string.IsNullOrEmpty(s.Error))
                {
                    pushOk = false;
                    pushMessage = "❌ Error: " + s.Error;
                }
                else if (s.Result is not null)
                {
                    pushOk = true;
                    pushMessage = "✅ Push terminado:\n" + System.Text.Json.JsonSerializer.Serialize(s.Result, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                    await Recargar();
                }
            }
            StateHasChanged();
        }
        catch { }
    }

    private static string FormatM(decimal v) => v.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    public void Dispose() { try { statusTimer?.Dispose(); } catch { } }
}
