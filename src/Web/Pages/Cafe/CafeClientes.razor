    protected override async Task OnInitializedAsync()
    {
        // Cargar provincias para el datalist (una sola vez por sesion, esta cacheado en CpService)
        provincias = await CpService.GetProvinciasAsync();
        await Load();

        // 2026-06-18: si vinimos como popup desde Nueva Venta con ?edit={id} o ?new={nombre},
        // auto-abrir el modal correspondiente. Al guardar, el postMessage avisa a la venta.
        try
        {
            var uri = new Uri(Nav.Uri);
            var qs = (uri.Query ?? "").TrimStart('?');
            string? editStr = null, newStr = null;
            foreach (var kv in qs.Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var eq = kv.IndexOf('=');
                var k = eq >= 0 ? kv.Substring(0, eq) : kv;
                var v = eq >= 0 ? Uri.UnescapeDataString(kv.Substring(eq + 1)) : "";
                if (k == "edit") editStr = v;
                else if (k == "new") newStr = v;
            }
            if (!string.IsNullOrEmpty(editStr) && int.TryParse(editStr, out var editId) && editId > 0)
            {
                var ci = clientes.FirstOrDefault(c => c.Id == editId);
                if (ci is not null) await ShowEdit(ci);
            }
            else if (newStr is not null)
            {
                await ShowCreate();
                formNombre = newStr.Trim();
            }
        }
        catch { /* sin query params, comportamiento normal */ }
    }

    private async Task Load()
    {
        loading = true;
