@page "/cafe/clientes"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject CpService CpService
@inject NavigationManager Nav

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>👥 Clientes <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(visibles.Count) de @(clientes?.Count ?? 0))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <input class="form-input" style="min-width: 280px; font-size: 0.9rem;"
                   @bind="filtro" @bind:event="oninput"
                   placeholder="🔍 Buscar por código, nombre, CUIT, tel, email, dirección, localidad, CP..." />
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo Cliente</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (clientes is null || clientes.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay clientes cargados.</p>
        }
        else if (visibles.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                Sin resultados para "<strong>@filtro</strong>". Probá con otra búsqueda.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 80px;">Código</th>
                            <th>Nombre</th>
                            <th>Tipo</th>
                            <th>CUIT/DNI</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th>Dirección</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in visibles.Take(maxVisibles))
                        {
                            <tr>
                                <td style="font-family: monospace; font-weight: 700; color: #1d4ed8;">@(c.Codigo ?? "—")</td>
                                <td><strong>@c.Nombre</strong></td>
                                <td>
                                    @if (c.Tipo == "BAR")
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dbeafe; color:#1e40af; border-radius:999px; font-size:0.72rem; font-weight:700;">🍺 BAR</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dcfce7; color:#166534; border-radius:999px; font-size:0.72rem; font-weight:700;">🏢 Comercial</span>
                                    }
                                </td>
                                <td style="font-family: monospace; font-size: 0.85rem;">@(c.Cuit ?? "—")</td>
                                <td>@(c.Telefono ?? "—")</td>
                                <td style="font-size: 0.85rem;">@(c.Email ?? "—")</td>
                                <td style="font-size: 0.85rem; color: #6b7280;">@(c.Direccion ?? "—")</td>
                                <td>
                                    <span class="status-badge @(c.IsActive ? "status-active" : "status-inactive")">@(c.IsActive ? "Activo" : "Inactivo")</span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(c)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon" @onclick='() => Nav.NavigateTo($"/cafe/clientes/{c.Id}/estado-cuenta")' title="Estado de cuenta">📒</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(c)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (visibles.Count > maxVisibles)
                {
                    <div style="padding: 0.7rem; text-align: center; background: #f9fafb; border-top: 1px solid #e5e7eb;">
                        <span style="color: #6b7280; font-size: 0.85rem; margin-right: 0.5rem;">
                            Mostrando @maxVisibles de @visibles.Count resultados
                        </span>
                        <button class="btn btn-secondary" @onclick="() => maxVisibles += 200" style="font-size: 0.85rem;">
                            Mostrar 200 más
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar cliente" : "Nuevo cliente")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }
                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre fantasía *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Bar Don Pepe" autofocus />
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Nombre comercial / cómo lo conocés.</p>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Tipo *</label>
                        <select class="form-input" @bind="formTipo">
                            <option value="BAR">🍺 BAR</option>
                            <option value="OTRO">🏢 Comercial</option>
                        </select>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                            Define qué descuento aplica según las reglas de precios.
                        </p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Razón social (legal)</label>
                    <input class="form-input" @bind="formRazonSocial" placeholder="Ej: PEPITO Y CIA. S.A." />
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Si se carga, aparece en facturas y proformas. Si está vacío, se usa el nombre fantasía.</p>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">CUIT / DNI</label>
                        <div style="display: flex; gap: 0.4rem; align-items: stretch;">
                            <input class="form-input" @bind="formCuit" placeholder="Ej: 30123456789"
                                   style="flex: 1 1 auto; min-width: 0;" />
                            <button type="button" class="btn btn-secondary" @onclick="BuscarPorCuit" disabled="@buscandoCuit"
                                    title="Trae automáticamente Razón Social, Dirección y Condición IVA"
                                    style="flex: 0 0 auto; white-space: nowrap; font-size: 0.8rem; padding: 0.4rem 0.7rem;">
                                @if (buscandoCuit) { <span>⏳</span> } else { <span>🔍 ARCA</span> }
                            </button>
                        </div>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                            Cargá el CUIT (11 dígitos) y apretá <strong>🔍 ARCA</strong> — completa Razón Social, Dirección y Condición IVA.
                        </p>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Email</label>
                        <input class="form-input" type="email" @bind="formEmail" placeholder="email@ejemplo.com" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Teléfono</label>
                        <input class="form-input" @bind="formTelefono" placeholder="Ej: 5491141234567" />
                        <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                            💡 Para que el link de WhatsApp del comprobante funcione, cargá el número en <strong>formato internacional sin el +</strong>
                            (ej: <code>5491141234567</code> = 54 + 9 + 11 + número). El icono 📱 que aparece en el PDF abre WhatsApp directo a este número.
                        </p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Dirección fiscal</label>
                    <input class="form-input" @bind="formDireccion" placeholder="Calle, número, barrio..." />
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Domicilio fiscal del cliente (la dirección legal).</p>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">CP</label>
                        <input class="form-input" value="@formCp"
                               @oninput="@(e => OnFormCpInput(e.Value?.ToString()))"
                               maxlength="4" placeholder="1900" />
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">4 dígitos. Auto-completa.</p>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Localidad</label>
                        <input class="form-input" list="datalist-localidades" @bind="formLocalidad" @bind:event="oninput" placeholder="Ej: La Plata" />
                        <datalist id="datalist-localidades">
                            @foreach (var loc in localidadesSugeridas)
                            {
                                <option value="@loc"></option>
                            }
                        </datalist>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Sugerencias segun la provincia. Podes tipear libre si no esta.</p>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Provincia</label>
                        <input class="form-input" list="datalist-provincias" value="@formCiudad" @oninput="@(e => OnProvinciaInput(e.Value?.ToString()))" placeholder="Ej: Buenos Aires" />
                        <datalist id="datalist-provincias">
                            @foreach (var p in provincias)
                            {
                                <option value="@p"></option>
                            }
                        </datalist>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Elegi de la lista para unificar nombres.</p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Condición frente al IVA</label>
                    <select class="form-input" @bind="formCondicionIvaDefault">
                        <option value="">— Sin especificar —</option>
                        <option value="RI">Responsable Inscripto</option>
                        <option value="MO">Monotributo</option>
                        <option value="EX">Exento</option>
                        <option value="CF">Consumidor Final</option>
                    </select>
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Default que se sugiere al emitir comprobantes para este cliente.</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Domicilio de entrega</label>
                    <input class="form-input" @bind="formDomicilioEntrega" placeholder="Donde se entregan los pedidos (si difiere del fiscal)" />
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Si está vacío, se usa la dirección fiscal.</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Notas internas</label>
                    <textarea class="form-input" @bind="formNotas" rows="2" placeholder="Notas que solo ves vos (no aparecen en comprobante)"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Comentarios para comprobante</label>
                    <textarea class="form-input" @bind="formComentariosComprobante" rows="2"
                              placeholder="Ej: Entregar antes de las 11 hs · Solicitar firma del recepcionista"></textarea>
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                        Estos comentarios <strong>aparecen en TODOS los comprobantes</strong> de este cliente.
                    </p>
                </div>
                @* ─── Vinculación a Mapeo (campo enlace siempre disponible; código interno solo al editar) ─── *@
                <div style="background: #eff6ff; border: 1px solid #3b82f6; border-radius: 6px; padding: 0.6rem 0.8rem; margin-top: 0.5rem;">
                    @if (isEditing && editingId.HasValue)
                    {
                        <div class="form-group" style="margin-bottom: 0.5rem;">
                            <label class="form-label" style="font-size: 0.78rem; color: #1e40af;">🆔 Código interno (uso interno)</label>
                            @if (formCodigoInterno.HasValue)
                            {
                                <div style="display: flex; gap: 0.4rem; align-items: center;">
                                    <span style="font-family: monospace; font-weight: 700; font-size: 1.1rem; color: #1e40af;">@formCodigoInterno</span>
                                    <button type="button" class="btn btn-secondary" @onclick="QuitarCodigoInterno"
                                            style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">🗑 Quitar</button>
                                </div>
                            }
                            else
                            {
                                <div style="display: flex; gap: 0.4rem; align-items: center;">
                                    <span style="font-size: 0.85rem; color: #6b7280;">— sin asignar —</span>
                                    <button type="button" class="btn btn-secondary" @onclick="AsignarCodigoInterno"
                                            disabled="@asignandoCodigo"
                                            style="font-size: 0.78rem; padding: 0.3rem 0.6rem;">
                                        @(asignandoCodigo ? "⏳..." : "🎯 Asignar código")
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0 0 0.5rem;">
                            💡 El <strong>código interno</strong> se asigna después de guardar el cliente (con un botón en la edición).
                        </p>
                    }
                    <div class="form-group" style="margin-bottom: 0;">
                        <label class="form-label" style="font-size: 0.78rem; color: #1e40af;">🗺 Enlace Google Maps (corto)</label>
                        <input class="form-input" @bind="formMapeoLink"
                               placeholder="https://maps.app.goo.gl/..." />
                        @if (formMapeoLat.HasValue && formMapeoLng.HasValue)
                        {
                            <p style="font-size: 0.7rem; color: #15803d; margin: 0.2rem 0 0;">
                                ✓ Coordenadas extraídas: <strong>@formMapeoLat?.ToString("0.######"), @formMapeoLng?.ToString("0.######")</strong>
                            </p>
                        }
                        else if (!string.IsNullOrEmpty(formMapeoLink) && isEditing)
                        {
                            <p style="font-size: 0.7rem; color: #d97706; margin: 0.2rem 0 0; display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
                                ⚠ No se pudieron extraer coordenadas todavía.
                                <button type="button" class="btn btn-secondary"
                                        @onclick="ReExtraerCoords" disabled="@reExtrayendo"
                                        style="font-size: 0.7rem; padding: 0.2rem 0.4rem;">
                                    @(reExtrayendo ? "⏳..." : "🔄 Re-extraer")
                                </button>
                            </p>
                        }
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                            Pegá el enlace corto que sale al compartir la ubicación desde Google Maps en el celular.
                            Al guardar, el sistema extrae automáticamente las coordenadas para usarlas en el mapa.
                        </p>
                    </div>
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">@(saving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))</button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && toDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar cliente</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body"><p>Estas seguro que queres eliminar <strong>@toDelete.Nombre</strong>?</p></div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeClienteDto>? clientes;
    private bool loading = true;
    private string filtro = "";
    private int maxVisibles = 100;
    private bool showForm, isEditing, saving;

    /// <summary>Lista filtrada por el buscador (codigo / nombre / cuit / telefono / email).</summary>
    private List<CafeClienteDto> visibles
    {
        get
        {
            if (clientes is null) return new();
            if (string.IsNullOrWhiteSpace(filtro)) return clientes;
            var f = filtro.Trim();
            // Comparacion case-insensitive sin acentos sería mas fuerte; arrancamos con Contains simple.
            bool match(CafeClienteDto c, string q)
            {
                bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(q, StringComparison.OrdinalIgnoreCase);
                return h(c.Codigo) || h(c.Nombre) || h(c.RazonSocial) || h(c.Cuit)
                    || h(c.Telefono) || h(c.Email)
                    || h(c.Direccion) || h(c.Localidad) || h(c.Ciudad) || h(c.Cp)
                    || h(c.DomicilioEntrega);
            }
            return clientes.Where(c => match(c, f)).ToList();
        }
    }
    private string? formError;
    private int? editingId;
    private string formNombre = "", formTipo = "OTRO", formCuit = "", formTelefono = "", formEmail = "", formDireccion = "", formNotas = "";
    private string formRazonSocial = "", formDomicilioEntrega = "", formComentariosComprobante = "";
    private int? formCodigoInterno;
    private string formMapeoLink = "";
    private decimal? formMapeoLat;
    private decimal? formMapeoLng;
    private bool asignandoCodigo;
    private bool reExtrayendo;
    private string formLocalidad = "", formCiudad = "", formCp = "", formCondicionIvaDefault = "";

    // Listas para los datalists (provincia/localidad). Se cargan en OnInitialized.
    private List<string> provincias = new();
    private List<string> localidadesSugeridas = new();

    private async Task OnFormCpInput(string? value)
    {
        var v = (value ?? "").Trim();
        if (v.Length > 4) v = v.Substring(0, 4);
        formCp = v;
        if (v.Length == 4 && v.All(char.IsDigit))
        {
            var hit = await CpService.LookupAsync(v);
            if (hit is not null)
            {
                formLocalidad = hit.l;
                formCiudad = hit.p;
                // Refrescar localidades sugeridas a la provincia recien seteada
                localidadesSugeridas = await CpService.GetLocalidadesAsync(hit.p);
            }
        }
    }

    /// <summary>Cuando el usuario tipea/elige una provincia, refresca la lista de localidades sugeridas.</summary>
    private async Task OnProvinciaInput(string? value)
    {
        formCiudad = (value ?? "").Trim();
        localidadesSugeridas = await CpService.GetLocalidadesAsync(formCiudad);
    }

    private bool buscandoCuit;

    /// <summary>
    /// Busca los datos fiscales del CUIT y autocompleta el formulario.
    /// Estrategia:
    ///   1. Consulta el padrón oficial ARCA (ws_sr_padron_a13) — trae datos completos
    ///      (razón social, domicilio fiscal, CP, localidad, provincia, condición IVA).
    ///   2. Si el padrón falla (cert ARCA no cargado o servicio sin autorizar), cae al
    ///      scraping de cuitonline.com como fallback.
    /// Sobre-escribe sin preguntar los valores actuales del formulario.
    /// </summary>
    private async Task BuscarPorCuit()
    {
        var clean = new string((formCuit ?? "").Where(char.IsDigit).ToArray());
        if (clean.Length != 11)
        {
            ToastService.Error("El CUIT debe tener 11 dígitos.");
            return;
        }
        buscandoCuit = true;
        StateHasChanged();
        try
        {
            // 1) Padrón oficial ARCA
            var padron = await Api.ConsultarPadronArcaAsync(clean);
            if (padron is not null && padron.Found)
            {
                if (!string.IsNullOrWhiteSpace(padron.RazonSocial))
                {
                    formRazonSocial = padron.RazonSocial!.Trim();
                    if (string.IsNullOrWhiteSpace(formNombre))
                        formNombre = padron.RazonSocial!.Trim();
                }
                if (!string.IsNullOrWhiteSpace(padron.Direccion))
                    formDireccion = padron.Direccion!.Trim();
                if (!string.IsNullOrWhiteSpace(padron.CodPostal))
                {
                    formCp = padron.CodPostal!.Trim();
                }
                if (!string.IsNullOrWhiteSpace(padron.Localidad))
                    formLocalidad = padron.Localidad!.Trim();
                if (!string.IsNullOrWhiteSpace(padron.Provincia))
                    formCiudad = padron.Provincia!.Trim();
                if (!string.IsNullOrWhiteSpace(padron.CondicionIva))
                    formCondicionIvaDefault = padron.CondicionIva!;
                ToastService.Success($"Padrón ARCA: {padron.RazonSocial}");
                return;
            }

            // 2) Fallback a cuitonline.com (gratis, datos parciales)
            var fallback = await Api.LookupCuitAsync(clean);
            if (fallback is null || !fallback.Found)
            {
                var detalle = padron?.Error ?? fallback?.Error ?? "No se encontraron datos para ese CUIT.";
                ToastService.Error(detalle);
                return;
            }
            if (!string.IsNullOrWhiteSpace(fallback.Name))
            {
                formRazonSocial = fallback.Name!.Trim();
                if (string.IsNullOrWhiteSpace(formNombre))
                    formNombre = fallback.Name!.Trim();
            }
            if (!string.IsNullOrWhiteSpace(fallback.Address))
                formDireccion = fallback.Address!.Trim();
            if (!string.IsNullOrWhiteSpace(fallback.IvaCondition))
            {
                var t = fallback.IvaCondition!.Trim().ToUpperInvariant();
                if (t.Contains("RESPONSABLE INSCRIPTO") || t == "RI")
                    formCondicionIvaDefault = "RI";
                else if (t.Contains("MONOTRIBUT"))
                    formCondicionIvaDefault = "MO";
                else if (t.Contains("EXENTO"))
                    formCondicionIvaDefault = "EX";
                else if (t.Contains("CONSUMIDOR FINAL") || t == "CF")
                    formCondicionIvaDefault = "CF";
            }
            ToastService.Success($"Datos parciales (cuitonline): {fallback.Name}");
        }
        catch (Exception ex)
        {
            ToastService.Error("Error consultando el CUIT: " + ex.Message);
        }
        finally
        {
            buscandoCuit = false;
            StateHasChanged();
        }
    }

    private bool formIsActive = true;
    private bool showDeleteConfirm;
    private CafeClienteDto? toDelete;

    protected override async Task OnInitializedAsync()
    {
        // Cargar provincias para el datalist (una sola vez por sesion, esta cacheado en CpService)
        provincias = await CpService.GetProvinciasAsync();
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        try { clientes = await Api.GetCafeClientesAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar clientes"); clientes = new(); }
        loading = false;
    }

    private async Task ShowCreate()
    {
        isEditing = false; editingId = null;
        formNombre = ""; formTipo = "OTRO"; formCuit = ""; formTelefono = ""; formEmail = ""; formDireccion = ""; formNotas = "";
        formRazonSocial = ""; formDomicilioEntrega = ""; formComentariosComprobante = "";
        formLocalidad = ""; formCiudad = ""; formCp = ""; formCondicionIvaDefault = "";
        formCodigoInterno = null; formMapeoLink = "";
        formMapeoLat = null; formMapeoLng = null;
        localidadesSugeridas = new();
        formIsActive = true; formError = null; showForm = true;
        await Task.CompletedTask;
    }

    private async Task ShowEdit(CafeClienteDto c)
    {
        isEditing = true; editingId = c.Id;
        formNombre = c.Nombre; formTipo = c.Tipo;
        formCuit = c.Cuit ?? ""; formTelefono = c.Telefono ?? ""; formEmail = c.Email ?? "";
        formDireccion = c.Direccion ?? ""; formNotas = c.Notas ?? "";
        formRazonSocial = c.RazonSocial ?? "";
        formDomicilioEntrega = c.DomicilioEntrega ?? "";
        formComentariosComprobante = c.ComentariosComprobante ?? "";
        formLocalidad = c.Localidad ?? ""; formCiudad = c.Ciudad ?? "";
        formCp = c.Cp ?? ""; formCondicionIvaDefault = c.CondicionIvaDefault ?? "";
        formCodigoInterno = c.CodigoInterno;
        formMapeoLink = c.MapeoLink ?? "";
        formMapeoLat = c.MapeoLat;
        formMapeoLng = c.MapeoLng;
        // Pre-cargar localidades sugeridas segun la provincia del cliente
        localidadesSugeridas = await CpService.GetLocalidadesAsync(formCiudad);
        formIsActive = c.IsActive; formError = null; showForm = true;
    }

    private async Task ReExtraerCoords()
    {
        if (!editingId.HasValue) return;
        // Guardamos primero por si el usuario cambió el link y no apretó guardar todavía
        // (sino el backend resuelve el link viejo). Reuso el handler de guardar después.
        reExtrayendo = true;
        try
        {
            var updated = await Api.ReExtraerCoordsAsync(editingId.Value);
            if (updated is not null)
            {
                formMapeoLat = updated.MapeoLat;
                formMapeoLng = updated.MapeoLng;
                if (formMapeoLat.HasValue) ToastService.Success($"Coordenadas extraídas: {formMapeoLat?.ToString("0.####")}, {formMapeoLng?.ToString("0.####")}");
                await Load();
            }
            else
            {
                ToastService.Error("No se pudo extraer las coordenadas. Probá con otro link.");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
        finally { reExtrayendo = false; }
    }

    private async Task AsignarCodigoInterno()
    {
        if (!editingId.HasValue) return;
        asignandoCodigo = true;
        try
        {
            var updated = await Api.AsignarCodigoInternoAsync(editingId.Value);
            if (updated is not null)
            {
                formCodigoInterno = updated.CodigoInterno;
                ToastService.Success($"Código interno asignado: {updated.CodigoInterno}");
                await Load();   // refresca el listado
            }
            else { ToastService.Error("No se pudo asignar el código"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { asignandoCodigo = false; }
    }

    private async Task QuitarCodigoInterno()
    {
        if (!editingId.HasValue) return;
        try
        {
            var updated = await Api.QuitarCodigoInternoAsync(editingId.Value);
            if (updated is not null)
            {
                formCodigoInterno = null;
                ToastService.Success("Código interno quitado");
                await Load();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        saving = true;
        try
        {
            if (isEditing && editingId.HasValue)
            {
                var mapeoLinkClean = (formMapeoLink ?? "").Trim();
                var u = await Api.UpdateCafeClienteAsync(editingId.Value, new UpdateCafeClienteRequest
                {
                    Nombre = formNombre, RazonSocial = formRazonSocial, Tipo = formTipo,
                    Cuit = formCuit, Telefono = formTelefono, Email = formEmail,
                    Direccion = formDireccion, DomicilioEntrega = formDomicilioEntrega,
                    Localidad = formLocalidad, Ciudad = formCiudad, Cp = formCp,
                    CondicionIvaDefault = formCondicionIvaDefault,
                    Notas = formNotas, ComentariosComprobante = formComentariosComprobante,
                    IsActive = formIsActive,
                    MapeoLink = string.IsNullOrEmpty(mapeoLinkClean) ? null : mapeoLinkClean,
                    ClearMapeoLink = string.IsNullOrEmpty(mapeoLinkClean)
                });
                if (u is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Cliente actualizado");
            }
            else
            {
                var mapeoLinkClean = (formMapeoLink ?? "").Trim();
                var c = await Api.CreateCafeClienteAsync(new CreateCafeClienteRequest
                {
                    Nombre = formNombre, RazonSocial = formRazonSocial, Tipo = formTipo,
                    Cuit = formCuit, Telefono = formTelefono, Email = formEmail,
                    Direccion = formDireccion, DomicilioEntrega = formDomicilioEntrega,
                    Localidad = formLocalidad, Ciudad = formCiudad, Cp = formCp,
                    CondicionIvaDefault = formCondicionIvaDefault,
                    Notas = formNotas, ComentariosComprobante = formComentariosComprobante,
                    MapeoLink = string.IsNullOrEmpty(mapeoLinkClean) ? null : mapeoLinkClean
                });
                if (c is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Cliente creado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private void ConfirmDelete(CafeClienteDto c) { toDelete = c; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (toDelete is null) return;
        try
        {
            var ok = await Api.DeleteCafeClienteAsync(toDelete.Id);
            if (ok) { ToastService.Success("Cliente eliminado"); await Load(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; toDelete = null; }
    }
}
