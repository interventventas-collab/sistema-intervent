    private async Task GuardarInlineAsync(CafeClienteDto c, string campo, string? valor)
    {
        var nuevo = (valor ?? "").Trim();
        // Si no cambió, no llamar al backend
        if (campo == "tel" && (c.Telefono ?? "") == nuevo) return;
        if (campo == "mail" && (c.Email ?? "") == nuevo) return;
        if (campo == "maps" && (c.MapeoLink ?? "") == nuevo) return;

        var req = new UpdateCafeClienteRequest();
        if (campo == "tel") req.Telefono = nuevo;
        else if (campo == "mail") req.Email = nuevo;
        else if (campo == "maps")
        {
            req.MapeoLink = string.IsNullOrEmpty(nuevo) ? null : nuevo;
            req.ClearMapeoLink = string.IsNullOrEmpty(nuevo);
        }
        var updated = await Api.UpdateCafeClienteAsync(c.Id, req);
        if (updated is not null)
        {
            if (campo == "tel") c.Telefono = updated.Telefono;
            else if (campo == "mail") c.Email = updated.Email;
            else if (campo == "maps") c.MapeoLink = updated.MapeoLink;
            var label = campo switch { "tel" => "teléfono", "mail" => "email", "maps" => "Maps", _ => campo };
            ToastService.Success($"{c.Nombre} · {label} actualizado");
        }
        else { ToastService.Error("Error al guardar"); }
    }

    /// <summary>Lista filtrada por el buscador (codigo / nombre / cuit / telefono / email).
    /// ORDEN: primero los clientes con CodigoInterno cargado (los que el usuario marcó como
    /// "suyos") ordenados por el código, después el resto por nombre.</summary>
    private List<CafeClienteDto> visibles
    {
        get
        {
            if (clientes is null) return new();
            IEnumerable<CafeClienteDto> baseList = clientes;
            if (!string.IsNullOrWhiteSpace(filtro))
            {
                var f = filtro.Trim();
                bool match(CafeClienteDto c, string q)
                {
                    bool h(string? s) => s.MatchesSearch(q);
                    return h(c.Codigo) || h(c.Nombre) || h(c.RazonSocial) || h(c.Cuit)
                        || h(c.Telefono) || h(c.Email)
                        || h(c.Direccion) || h(c.Localidad) || h(c.Ciudad) || h(c.Cp)
                        || h(c.DomicilioEntrega);
                }
                baseList = clientes.Where(c => match(c, f));
            }
            // Prioridad de orden:
            //   1) Con CodigoInterno asignado → primero, ordenados por el código (1, 2, 3, ...)
            //   2) Sin CodigoInterno → después, ordenados por nombre
            return baseList
                .OrderBy(c => c.CodigoInterno.HasValue ? 0 : 1)
                .ThenBy(c => c.CodigoInterno ?? int.MaxValue)
                .ThenBy(c => c.Nombre ?? "")
                .ToList();
        }
    }
