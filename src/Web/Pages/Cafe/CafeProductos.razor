    /// <summary>Devuelve el % de descuento que aplica la matriz para (BAR, categoría del form).
    /// Si no hay regla, asume 0%. La regla general es la que tiene MarcaId = null.</summary>
    private decimal GetBarDescuentoPct()
    {
        var regla = reglasPrecios.FirstOrDefault(r =>
            r.TipoCliente == "BAR" && r.Categoria == formCategoria && r.MarcaId == null);
        return regla?.DescuentoPct ?? 0m;
    }

    /// <summary>PVP sugerido auto-calculado para que el "PVP BARES" del catálogo coincida con
    /// el precio que termina cobrando la venta a un cliente BAR. Fórmula:
    ///     Pvp2 = costo × (1 + BarPct%) / (1 − descuentoMatriz_BAR/100)
    /// Solo aplica si hay costo > 0 y BarPct cargado. Si no hay descuento en la matriz, devuelve
    /// costo × (1 + BarPct%) (no hay nada que compensar).</summary>
    private decimal? GetPvp2Sugerido()
    {
        if (formCosto <= 0 || !formBarPct.HasValue) return null;
        var bar = formBarPct.Value;
        var desc = GetBarDescuentoPct();
        var basePrecio = formCosto * (1m + bar / 100m);
        if (desc >= 100m) return null; // no se puede dividir por 0
        var pvp = basePrecio / (1m - desc / 100m);
        return Math.Round(pvp, 2, MidpointRounding.AwayFromZero);
    }

    private async Task AplicarPvp2Sugerido()
    {
        var sug = GetPvp2Sugerido();
        if (sug.HasValue) { formPvp2 = sug.Value; await Task.Yield(); }
    }

