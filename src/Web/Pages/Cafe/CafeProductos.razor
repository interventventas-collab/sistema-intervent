    private void ShowEdit(CafeProductoDto p)
    {
        isEditing = true; editingId = p.Id;
        formNombre = p.Nombre; formSku = p.Sku ?? ""; formBarcode = p.Barcode ?? "";
        formCategoria = p.Categoria; formMarca = p.Marca ?? "";
        formCosto = p.Costo; formPvp1 = p.Pvp1; formPvp2 = p.Pvp2;
        formIvaPctStr = p.IvaPct == 10.5m ? "10.5" : "21";
        formBarPct = p.BarPctSobreCosto;
        // Modelo NUEVO de precios. Si NO están cargados (producto migrado del modelo viejo),
        // sugerimos valores iniciales calculados desde los datos legacy.
        formPrecioOtro = p.PrecioOtro ?? p.Pvp2 ?? p.Pvp1;
        formPrecioBar = p.PrecioBar
            ?? (p.BarPctSobreCosto.HasValue && p.Costo > 0
                ? Math.Round(p.Costo * (1m + p.BarPctSobreCosto.Value / 100m), 2)
                : (decimal?)null);
        // Default razonable si los precios quedan en null y hay costo: usar costo × 2 (margen 100%).
        // Solo aplica a productos OTROS — para CAFE estos campos no se usan.
        if (p.Categoria == "OTROS" && p.Costo > 0)
        {
            if (!formPrecioBar.HasValue) formPrecioBar = Math.Round(p.Costo * 2m, 2);
            if (!formPrecioOtro.HasValue) formPrecioOtro = Math.Round(p.Costo * 2m, 2);
        }
        // Calculamos los márgenes iniciales (sincronizado con los precios pre-cargados)
        formMargenBar = formPrecioBar.HasValue && p.Costo > 0
            ? Math.Round((formPrecioBar.Value / p.Costo - 1m) * 100m, 2, MidpointRounding.AwayFromZero)
            : (decimal?)null;
        formMargenOtro = formPrecioOtro.HasValue && p.Costo > 0
            ? Math.Round((formPrecioOtro.Value / p.Costo - 1m) * 100m, 2, MidpointRounding.AwayFromZero)
            : (decimal?)null;
        formUxB = p.UxB;
        formPrecioBulto = p.PrecioBulto;
        formPrecioBultoOtro = p.PrecioBultoOtro;
        formOemId = p.OemId ?? 0; oemSearch = ""; oemSearchOpen = false;
        formStockGramos = p.StockGramos; formStockUnidades = p.StockUnidades;
        formStockKg = Math.Round(p.StockGramos / 1000m, 3, MidpointRounding.AwayFromZero);
        formNotas = p.Notas ?? ""; formIsActive = p.IsActive;
        formError = null; showForm = true;
    }

