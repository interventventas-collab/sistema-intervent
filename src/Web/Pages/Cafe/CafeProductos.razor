    /// <summary>Pisa costo, PVP, UxB y barcode del producto con los del OEM origen.
    /// Lo pueden tocar despues a mano.</summary>
    private void AutocompletarDesdeOem()
    {
        if (formOemId <= 0) return;
        var o = oems?.FirstOrDefault(x => x.Id == formOemId);
        if (o is null) return;
        formCosto = o.Costo;
        // OEM guarda PVP con IVA — convertimos a sin IVA para alinear con la convencion del producto.
        if (o.PvpConIva.HasValue)
        {
            var iva = o.IvaPct ?? 21m;
            formPvp2 = iva > 0 ? Math.Round(o.PvpConIva.Value / (1 + iva / 100m), 2) : o.PvpConIva.Value;
            formIvaPctStr = iva == 10.5m ? "10.5" : "21";
        }
        if (o.UxB.HasValue) formUxB = o.UxB.Value;
        if (!string.IsNullOrWhiteSpace(o.Barcode)) formBarcode = o.Barcode;
    }

