    private MarkupString RenderDelta(decimal? anterior, decimal? nuevo)
    {
        if (anterior == nuevo)
            return new MarkupString(nuevo.HasValue ? $"$ {FormatMoney(nuevo.Value)}" : "—");
        var ant = anterior.HasValue ? $"$ {FormatMoney(anterior.Value)}" : "—";
        var nue = nuevo.HasValue ? $"$ {FormatMoney(nuevo.Value)}" : "—";
        var color = (nuevo ?? 0m) > (anterior ?? 0m) ? "#15803d" : "#b91c1c";
        return new MarkupString($"<span style=\"color:#9ca3af; text-decoration:line-through;\">{ant}</span> → <b style=\"color:{color};\">{nue}</b>");
    }

