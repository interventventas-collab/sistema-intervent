@if (showHistorial && histProducto is not null)
{
    <div class="modal-overlay" @onclick="CerrarHistorial">
        <div class="modal-card" style="max-width: 720px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>📈 Historial de precios — @histProducto.Nombre</h3>
                <button class="btn-close" @onclick="CerrarHistorial">×</button>
            </div>
            <div class="modal-body">
                <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:0.7rem; margin-bottom:0.8rem;">
                    <div style="font-size:0.78rem; color:#6b7280; margin-bottom:0.2rem;">Precio actual</div>
                    <div style="display:flex; gap:1.2rem; flex-wrap:wrap;">
                        <div><b>Costo:</b> $@FormatMoney(histProducto.Costo)</div>
                        @if (histProducto.Pvp1.HasValue)
                        {
                            <div><b>BARES:</b> $@FormatMoney(histProducto.Pvp1.Value)</div>
                        }
                        @if (histProducto.Pvp2.HasValue)
                        {
                            <div><b>SUGERIDO:</b> $@FormatMoney(histProducto.Pvp2.Value)</div>
                        }
                        <div><b>IVA:</b> @histProducto.IvaPct%</div>
                    </div>
                </div>

                @if (historial is null)
                {
                    <p style="color:#6b7280;">Cargando...</p>
                }
                else if (historial.Count == 0)
                {
                    <p style="color:#6b7280;">Aún no hay cambios registrados para este producto.</p>
                }
                else
                {
                    <table class="data-table" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>BARES</th>
                                <th>SUGERIDO</th>
                                <th>Costo</th>
                                <th>IVA</th>
                                <th>Por</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var h in historial)
                        {
                            <tr>
                                <td style="white-space:nowrap;">@h.ChangedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@RenderDelta(h.Pvp1Anterior, h.Pvp1Nuevo)</td>
                                <td>@RenderDelta(h.Pvp2Anterior, h.Pvp2Nuevo)</td>
                                <td>@RenderDelta(h.CostoAnterior, h.CostoNuevo)</td>
                                <td style="font-size:0.8rem; color:#6b7280;">
                                    @if (h.IvaPctAnterior != h.IvaPctNuevo) { <span>@h.IvaPctAnterior% → <b>@h.IvaPctNuevo%</b></span> }
                                    else { <span>@h.IvaPctNuevo%</span> }
                                </td>
                                <td style="font-size:0.8rem; color:#6b7280;">@(h.ChangedBy ?? "—")</td>
                                <td style="font-size:0.78rem; color:#6b7280;">@(h.Motivo ?? "—")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarHistorial">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showMeliSync && meliSyncProducto is not null)
{
    <div class="modal-overlay" @onclick="CerrarMeliSync">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 1100px; max-height: 90vh; display:flex; flex-direction:column;">
            <div class="modal-header" style="background:#dbeafe;">
                <h3 style="margin:0;">📤 Sincronizar a MercadoLibre — @meliSyncProducto.Sku · @meliSyncProducto.Nombre</h3>
                <button class="btn-close" @onclick="CerrarMeliSync">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y:auto;">
                @if (meliPreviewLoading)
                {
                    <p class="text-muted">Cargando publicaciones vinculadas...</p>
                }
                else if (meliPreview is null || meliPreview.Publicaciones.Count == 0)
                {
                    <p style="color:#6b7280;">Este café no tiene publicaciones vinculadas en MercadoLibre todavía.</p>
                }
                else
                {
                    <div style="background:#f9fafb; border:1px solid #e5e7eb; padding:0.6rem; border-radius:6px; margin-bottom:0.7rem; font-size:0.85rem; display:flex; justify-content:space-between; align-items:center; gap:0.6rem;">
                        <div>
                            <strong>Stock disponible (gramos):</strong> @meliPreview.Cafe.StockGramos.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))g
                            · <strong>Pvp1 sin IVA:</strong> $@FormatMoney(meliPreview.Cafe.Pvp1 ?? 0)
                            · <strong>IVA:</strong> @meliPreview.Cafe.IvaPct.ToString("0.##")%
                        </div>
                        <button class="btn btn-secondary" style="font-size:0.78rem; padding:0.3rem 0.6rem;" @onclick="DetectarLogisticType" disabled="@meliRefreshingLogistic">
                            @(meliRefreshingLogistic ? "Detectando..." : "🔍 Detectar Full / Propio")
                        </button>
                    </div>
                    @if (meliPreview.Publicaciones.Any(p => string.IsNullOrEmpty(p.LogisticType)))
                    {
                        <div style="background:#fee2e2; border-left:3px solid #b91c1c; padding:0.5rem 0.7rem; margin-bottom:0.7rem; font-size:0.78rem; color:#7f1d1d;">
                            ⚠ Hay publicaciones sin tipo de logística cargado. Tocá <strong>"🔍 Detectar Full / Propio"</strong> antes de sincronizar para que el sistema sepa cuáles son Full (no pushea stock a Full).
                        </div>
                    }
                    <table class="data-table" style="font-size:0.85rem;">
                        <thead>
                            <tr>
                                <th></th>
                                <th>MLA / Cuenta</th>
                                <th>Título</th>
                                <th>SKU MeLi</th>
                                <th>Formato</th>
                                <th>Logística</th>
                                <th style="text-align:right;">Stock MeLi</th>
                                <th style="text-align:right;">Stock nuevo</th>
                                <th style="text-align:right;">Precio MeLi</th>
                                <th style="text-align:right;">Precio nuevo</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var r in meliPreview.Publicaciones)
                        {
                            <tr style="background:@(r.Cambia ? "#fef3c7" : "white");">
                                <td>
                                    <input type="checkbox" checked="@meliSyncSeleccion.Contains(r.MeliItemId)"
                                           @onchange="@(e => ToggleMeliRow(r.MeliItemId, (bool)(e.Value ?? false)))" />
                                </td>
                                <td>
                                    <div style="font-family:monospace; font-weight:700;">@r.MeliItemId</div>
                                    <div style="font-size:0.72rem; color:#6b7280;">@r.Cuenta</div>
                                </td>
                                <td style="max-width:280px; font-size:0.78rem;">@r.Title</td>
                                <td>
                                    @{ var skuOk = string.Equals(r.SkuMeli, meliPreview!.Cafe.Sku, StringComparison.OrdinalIgnoreCase); }
                                    <span style="font-family:monospace; font-weight:700; color:@(skuOk ? "#16a34a" : "#b45309");" title="@(skuOk ? "Coincide con SKU del café" : $"Cafe es '{meliPreview.Cafe.Sku}' — habría que renombrar")">@(r.SkuMeli ?? "—")</span>
                                </td>
                                <td><span style="display:inline-block; padding:0.1rem 0.4rem; background:#e5e7eb; border-radius:4px; font-size:0.7rem; font-weight:700;">@r.Formato</span></td>
                                <td>
                                    @if (r.EsFull)
                                    { <span style="display:inline-block; padding:0.1rem 0.4rem; background:#fef3c7; border:1px solid #d97706; border-radius:4px; font-size:0.7rem; font-weight:700; color:#92400e;" title="Mercado Envíos Full — el stock lo administra MeLi, no se puede pushear stock desde acá">🏢 FULL</span> }
                                    else if (string.IsNullOrEmpty(r.LogisticType))
                                    { <span style="font-size:0.7rem; color:#9ca3af;">— sin detectar —</span> }
                                    else
                                    { <span style="display:inline-block; padding:0.1rem 0.4rem; background:#dcfce7; border:1px solid #16a34a; border-radius:4px; font-size:0.7rem; font-weight:700; color:#166534;" title="@r.LogisticType">🚚 Propio</span> }
                                </td>
                                <td style="text-align:right;">@r.StockMeli</td>
                                <td style="text-align:right; font-weight:700; color:@(r.EsFull ? "#9ca3af" : (r.StockDelta == 0 ? "#6b7280" : (r.StockDelta > 0 ? "#15803d" : "#b91c1c")));">
                                    @if (r.EsFull)
                                    { <span style="text-decoration:line-through; font-size:0.78rem;">@r.StockNuevo</span> <span style="font-size:0.65rem; color:#92400e;"> (Full)</span> }
                                    else
                                    {
                                        @r.StockNuevo
                                        @if (r.StockDelta != 0) { <span style="font-size:0.7rem;"> (@(r.StockDelta > 0 ? "+" : "")@r.StockDelta)</span> }
                                    }
                                </td>
                                <td style="text-align:right;">$@FormatMoney(r.PrecioMeli)</td>
                                <td style="text-align:right; font-weight:700; color:@(r.PrecioDelta == 0 ? "#6b7280" : (r.PrecioDelta > 0 ? "#15803d" : "#b91c1c"));">
                                    $@FormatMoney(r.PrecioNuevo)
                                    @if (r.PrecioDelta != 0) { <div style="font-size:0.7rem;">@(r.PrecioDelta > 0 ? "+" : "")$@FormatMoney(r.PrecioDelta)</div> }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                    <div style="margin-top:0.8rem; padding:0.6rem; background:#fef3c7; border-left:3px solid #d97706; border-radius:4px; font-size:0.8rem;">
                        ⚠ Lo que apretes "Sincronizar" se manda a MercadoLibre y queda público al instante. Revisá los valores antes.
                    </div>
                    @if (meliPushResults is not null && meliPushResults.Results.Count > 0)
                    {
                        <div style="margin-top:0.7rem; padding:0.7rem; background:#ecfdf5; border-left:3px solid #10b981; border-radius:4px; font-size:0.85rem;">
                            <strong>✅ @meliPushResults.Ok / @meliPushResults.Total publicaciones actualizadas correctamente</strong>
                            @foreach (var rr in meliPushResults.Results.Where(x => !x.Success))
                            {
                                <div style="color:#b91c1c; margin-top:0.2rem; font-size:0.78rem;">❌ @rr.MeliItemId: @rr.Message</div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.85rem; margin-right:auto;">
                    <input type="checkbox" @bind="meliPushPrice" /> Pushear precio
                </label>
                <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.85rem; margin-right:auto;">
                    <input type="checkbox" @bind="meliPushStock" /> Pushear stock
                </label>
                @if (meliPreview is not null && !string.IsNullOrEmpty(meliPreview.Cafe.Sku))
                {
                    var faltanRenombrar = meliPreview.Publicaciones.Count(r => meliSyncSeleccion.Contains(r.MeliItemId)
                        && !string.Equals(r.SkuMeli, meliPreview.Cafe.Sku, StringComparison.OrdinalIgnoreCase));
                    <button class="btn btn-secondary" style="font-size:0.85rem;"
                            @onclick="DoRenameMeliSku" disabled="@(meliRenamingSku || meliSyncSeleccion.Count == 0 || faltanRenombrar == 0)"
                            title="Aplica el SKU del café (@meliPreview.Cafe.Sku) a las publicaciones seleccionadas en MercadoLibre.">
                        @(meliRenamingSku ? "Renombrando..." : $"🏷️ Renombrar SKU MeLi a '{meliPreview.Cafe.Sku}' ({faltanRenombrar})")
                    </button>
                }
                <button class="btn btn-secondary" @onclick="CerrarMeliSync" disabled="@meliPushing">Cerrar</button>
                <button class="btn btn-primary" @onclick="DoMeliSync" disabled="@(meliPushing || meliSyncSeleccion.Count == 0 || (!meliPushPrice && !meliPushStock))">
                    @(meliPushing ? "Sincronizando..." : $"📤 Sincronizar {meliSyncSeleccion.Count} seleccionada(s)")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .precio-clickeable { cursor: pointer; }
    .precio-clickeable:hover { background: #f0f9ff; }
</style>

@code {
    private List<CafeProductoDto>? productos;
    private bool loading = true;
    private bool modoEdicion;
    private HashSet<int> selProductos = new();
    private string bulkMarcaIdStr = "";
    private bool isBusyBulk;

    private bool TodosVisiblesSeleccionados =>
        productosVisibles.Count > 0 && productosVisibles.All(p => selProductos.Contains(p.Id));

    private void ToggleProducto(int id, bool on)
    {
        if (on) selProductos.Add(id); else selProductos.Remove(id);
    }

    private void ToggleAllVisibles(ChangeEventArgs e)
    {
        var on = (bool)(e.Value ?? false);
        if (on) foreach (var p in productosVisibles) selProductos.Add(p.Id);
        else foreach (var p in productosVisibles) selProductos.Remove(p.Id);
    }

    private void SeleccionarTodosVisibles()
    {
        foreach (var p in productosVisibles) selProductos.Add(p.Id);
    }

    private void LimpiarSeleccion() => selProductos.Clear();

    private async Task AplicarMarcaABulk()
    {
        if (selProductos.Count == 0) return;
        int? newMarcaId = null;
        if (int.TryParse(bulkMarcaIdStr, out var mid)) newMarcaId = mid;

        var ids = selProductos.ToList();
        isBusyBulk = true;
        int ok = 0, fail = 0;
        try
        {
            foreach (var id in ids)
            {
                try
                {
                    await Api.UpdateCafeProductoAsync(id, new UpdateCafeProductoRequest
                    {
                        MarcaId = newMarcaId,
                        ClearMarcaId = newMarcaId is null
                    });
                    ok++;
                }
                catch { fail++; }
            }
            ToastService.Success($"Marca aplicada — OK: {ok} · Fallidos: {fail}");
            selProductos.Clear();
            await Load();
        }
        finally { isBusyBulk = false; }
    }

