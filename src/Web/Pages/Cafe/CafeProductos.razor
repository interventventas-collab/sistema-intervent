    /// <summary>Lista filtrada por marca + texto (categoría ya viene filtrada del backend).</summary>
    private List<CafeProductoDto> productosVisibles
    {
        get
        {
            if (productos is null) return new();
            IEnumerable<CafeProductoDto> q = productos;
            if (filtroMarca == "__sin__")
                q = q.Where(p => string.IsNullOrWhiteSpace(p.Marca) && !p.MarcaId.HasValue);
            else if (!string.IsNullOrEmpty(filtroMarca))
                q = q.Where(p => string.Equals(p.Marca, filtroMarca, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(filtroTexto))
            {
                var t = filtroTexto.Trim();
                bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
                q = q.Where(p => h(p.Sku) || h(p.Barcode) || h(p.Nombre) || h(p.Marca));
            }
            return q.ToList();
        }
    }
