    private async Task DoMeliSync()
    {
        if (meliSyncProducto is null || meliPreview is null) return;
        // Mapear meliItemIds (string MLA) a Ids internos de MeliItems → necesitamos los Ids.
        // El preview no devuelve Ids internos, asi que usamos el endpoint sin filtro y el backend
        // pushea TODAS las vinculadas. Para filtrar, hacemos otra llamada.
        // Atajo: pasamos null y backend pushea todas.
        // Mejora futura: devolver Ids internos en el preview.
        meliPushing = true;
        meliPushResults = null;
        try
        {
            // El backend filtra por MeliItem.Id (int), no por MeliItemId string. Para filtrar sin
            // refactor adicional, mandamos null = todas las vinculadas. Si el usuario deselecciono
            // algunas, le avisamos.
            var seleccionadasMLA = meliSyncSeleccion.ToHashSet();
            var todasLasMLA = meliPreview.Publicaciones.Select(r => r.MeliItemId).ToHashSet();
            if (seleccionadasMLA.Count != todasLasMLA.Count)
            {
                ToastService.Info("Por ahora pusheo todas las vinculadas (la seleccion granular se agregara en el proximo commit). Si no querias eso, cancelá.");
                if (!await ConfirmAsync("Pushear todas las publicaciones vinculadas?")) { meliPushing = false; return; }
            }
            meliPushResults = await Api.PushCafeToMeliAsync(meliSyncProducto.Id, null, meliPushPrice, meliPushStock);
            if (meliPushResults is not null)
            {
                ToastService.Success($"{meliPushResults.Ok} de {meliPushResults.Total} publicaciones actualizadas");
                // Recargar preview para ver el estado nuevo
                meliPreview = await Api.GetCafeMeliPreviewAsync(meliSyncProducto.Id);
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { meliPushing = false; }
    }

