    // Sincronización bidireccional entre Precio y Margen. Cada método se llama via @bind:after
    // del input correspondiente, así Blazor ya hizo el bind y solo recalculamos el "espejo".

    private void RecalcularMargenesDesdeCosto()
    {
        // Cambió el costo. Los precios YA cargados quedan iguales (no se pisan automáticamente —
        // para eso está el botón "🔄 Refrescar precios"). Los márgenes se recalculan contra el costo nuevo.
        // EXCEPCIÓN: si un precio está vacío y la categoría es OTROS, lo autocompletamos con costo×2.
        if (formCategoria == "OTROS" && formCosto > 0)
        {
            if (!formPrecioBar.HasValue) formPrecioBar = Math.Round(formCosto * 2m, 2);
            if (!formPrecioOtro.HasValue) formPrecioOtro = Math.Round(formCosto * 2m, 2);
        }
        formMargenBar = (formPrecioBar.HasValue && formCosto > 0)
            ? Math.Round((formPrecioBar.Value / formCosto - 1m) * 100m, 2, MidpointRounding.AwayFromZero)
            : (decimal?)null;
        formMargenOtro = (formPrecioOtro.HasValue && formCosto > 0)
            ? Math.Round((formPrecioOtro.Value / formCosto - 1m) * 100m, 2, MidpointRounding.AwayFromZero)
            : (decimal?)null;
    }

    /// <summary>Refresca AMBOS precios manteniendo los márgenes actuales contra el costo actual.
    /// Útil cuando subió el costo y querés que los precios se ajusten para no perder margen.</summary>
    private void RefrescarPreciosAlCostoActual()
    {
        if (formCosto <= 0) return;
        if (formMargenBar.HasValue)
            formPrecioBar = Math.Round(formCosto * (1m + formMargenBar.Value / 100m), 2, MidpointRounding.AwayFromZero);
        if (formMargenOtro.HasValue)
            formPrecioOtro = Math.Round(formCosto * (1m + formMargenOtro.Value / 100m), 2, MidpointRounding.AwayFromZero);
    }
    private void RecalcMargenBarDesdePrecio()
    {
        formMargenBar = (formPrecioBar.HasValue && formCosto > 0)
            ? Math.Round((formPrecioBar.Value / formCosto - 1m) * 100m, 2, MidpointRounding.AwayFromZero)
            : (decimal?)null;
    }
    private void RecalcMargenOtroDesdePrecio()
    {
        formMargenOtro = (formPrecioOtro.HasValue && formCosto > 0)
            ? Math.Round((formPrecioOtro.Value / formCosto - 1m) * 100m, 2, MidpointRounding.AwayFromZero)
            : (decimal?)null;
    }
    private void RecalcPrecioBarDesdeMargen()
    {
        if (formCosto > 0 && formMargenBar.HasValue)
            formPrecioBar = Math.Round(formCosto * (1m + formMargenBar.Value / 100m), 2, MidpointRounding.AwayFromZero);
    }
    private void RecalcPrecioOtroDesdeMargen()
    {
        if (formCosto > 0 && formMargenOtro.HasValue)
            formPrecioOtro = Math.Round(formCosto * (1m + formMargenOtro.Value / 100m), 2, MidpointRounding.AwayFromZero);
    }

    // Helpers para los botones "🎯 ×2"
    private void SetPrecioBar(decimal precio)
    {
        formPrecioBar = Math.Round(precio, 2, MidpointRounding.AwayFromZero);
        RecalcMargenBarDesdePrecio();
    }
    private void SetPrecioOtro(decimal precio)
    {
        formPrecioOtro = Math.Round(precio, 2, MidpointRounding.AwayFromZero);
        RecalcMargenOtroDesdePrecio();
    }
