    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        if (formCosto < 0) { formError = "El costo no puede ser negativo"; return; }
        if (formCategoria == "OTROS")
        {
            // Acepta modelo NUEVO (PrecioBar/PrecioOtro) o modelo legacy (Pvp2).
            var tieneModeloNuevo = (formPrecioBar.HasValue && formPrecioBar.Value > 0)
                                || (formPrecioOtro.HasValue && formPrecioOtro.Value > 0);
            var tienePvpLegacy = formPvp2.HasValue && formPvp2.Value > 0;
            if (!tieneModeloNuevo && !tienePvpLegacy)
            {
                formError = "Para OTROS hay que cargar al menos un precio: BAR u OTRO";
                return;
            }
        }
        saving = true;
        try
        {
            // Para OTROS: si formBarPct tiene valor, lo usamos; si esta vacio, BAR paga lo mismo que OTRO.
            decimal? barPctFinal = null;
            int? uxBFinal = null;
            int? oemIdFinal = null;
            bool clearBarPct = false;
            bool clearUxB = false;
            bool clearOemId = false;
            if (formCategoria == "OTROS")
            {
                barPctFinal = formBarPct;
                clearBarPct = !formBarPct.HasValue;
                uxBFinal = formUxB;
                clearUxB = !formUxB.HasValue;
                oemIdFinal = formOemId > 0 ? formOemId : null;
                clearOemId = formOemId <= 0;
            }
            else
            {
                // CAFE no usa estos campos: vaciarlos siempre.
                clearBarPct = true;
                clearUxB = true;
                clearOemId = true;
            }

            if (isEditing && editingId.HasValue)
            {
                // UX: el usuario carga CAFE en kg → convertimos a gramos para guardar.
                var stockGramosFinal = formCategoria == "CAFE"
                    ? Math.Round(formStockKg * 1000m, 3, MidpointRounding.AwayFromZero)
                    : 0m;
                var u = await Api.UpdateCafeProductoAsync(editingId.Value, new UpdateCafeProductoRequest
                {
                    Sku = formSku, Barcode = formBarcode,
                    Nombre = formNombre, Categoria = formCategoria, Marca = formMarca,
                    Costo = formCosto, Pvp1 = formPvp1, Pvp2 = formPvp2,
                    BarPctSobreCosto = barPctFinal, ClearBarPctSobreCosto = clearBarPct,
                    UxB = uxBFinal, ClearUxB = clearUxB,
                    OemId = oemIdFinal, ClearOemId = clearOemId,
                    StockGramos = stockGramosFinal,
                    StockUnidades = formCategoria == "OTROS" ? formStockUnidades : 0,
                    Notas = formNotas, IsActive = formIsActive,
                    IvaPct = formIvaPct,
                    // Modelo NUEVO de precios (solo OTROS):
                    PrecioOtro = formCategoria == "OTROS" ? formPrecioOtro : null,
                    PrecioBar = formCategoria == "OTROS" ? formPrecioBar : null,
                    ClearPrecioOtro = formCategoria == "OTROS" && !formPrecioOtro.HasValue,
                    ClearPrecioBar = formCategoria == "OTROS" && !formPrecioBar.HasValue,
                    // Precio del bulto (descuento por volumen, SOLO OTROS):
                    PrecioBulto = formCategoria == "OTROS" ? formPrecioBulto : null,
                    PrecioBultoOtro = formCategoria == "OTROS" ? formPrecioBultoOtro : null,
                    ClearPrecioBulto = formCategoria == "OTROS" && !formPrecioBulto.HasValue,
                    ClearPrecioBultoOtro = formCategoria == "OTROS" && !formPrecioBultoOtro.HasValue,
                });
                if (u is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Producto actualizado");
            }
            else
            {
                var stockGramosFinal = formCategoria == "CAFE"
                    ? Math.Round(formStockKg * 1000m, 3, MidpointRounding.AwayFromZero)
                    : 0m;
                var c = await Api.CreateCafeProductoAsync(new CreateCafeProductoRequest
                {
                    Sku = formSku, Barcode = formBarcode,
                    Nombre = formNombre, Categoria = formCategoria, Marca = formMarca,
                    Costo = formCosto, Pvp1 = formPvp1, Pvp2 = formPvp2,
                    BarPctSobreCosto = barPctFinal,
                    UxB = uxBFinal,
                    OemId = oemIdFinal,
                    StockGramos = stockGramosFinal,
                    StockUnidades = formCategoria == "OTROS" ? formStockUnidades : 0,
                    Notas = formNotas,
                    IvaPct = formIvaPct,
                    // Modelo NUEVO de precios (solo OTROS):
                    PrecioOtro = formCategoria == "OTROS" ? formPrecioOtro : null,
                    PrecioBar = formCategoria == "OTROS" ? formPrecioBar : null,
                    // Precio del bulto (descuento por volumen, SOLO OTROS):
                    PrecioBulto = formCategoria == "OTROS" ? formPrecioBulto : null,
                    PrecioBultoOtro = formCategoria == "OTROS" ? formPrecioBultoOtro : null,
                });
                if (c is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Producto creado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private void ConfirmDelete(CafeProductoDto p) { toDelete = p; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (toDelete is null) return;
        try
        {
            var ok = await Api.DeleteCafeProductoAsync(toDelete.Id);
            if (ok) { ToastService.Success("Producto eliminado"); await Load(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; toDelete = null; }
    }

    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    /// <summary>UX: siempre mostramos stock de cafe en kg con 2 decimales (regla del usuario).
    /// Internamente almacenamos en gramos pero NO se exponen al usuario.</summary>
    private static string FormatGramos(decimal g)
        => $"{(g / 1000m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))} kg";
}
