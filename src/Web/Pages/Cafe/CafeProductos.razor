    private async Task DoRenameMeliSku()
    {
        if (meliSyncProducto is null || meliPreview is null) return;
        if (string.IsNullOrEmpty(meliPreview.Cafe.Sku)) { ToastService.Error("El café no tiene SKU cargado."); return; }
        var newSku = meliPreview.Cafe.Sku;
        var seleccionadas = meliSyncSeleccion.Count;
        if (!await ConfirmAsync($"Vas a renombrar el SKU de {seleccionadas} publicación(es) a '{newSku}' en MercadoLibre. ¿Confirmás?")) return;

        meliRenamingSku = true;
        try
        {
            // No tenemos los IDs internos en el preview — pasamos null para que el backend renombre TODAS las vinculadas.
            // Si el usuario seleccionó subset, le advertimos.
            if (seleccionadas != meliPreview.Publicaciones.Count)
                ToastService.Info("Por simplicidad se renombran TODAS las publicaciones vinculadas (no solo las marcadas). Si querias selectivo, cancela.");
            var r = await Api.RenameMeliSkuAsync(meliSyncProducto.Id, null);
            if (r is not null)
            {
                ToastService.Success($"{r.Ok} de {r.Total} publicaciones renombradas a '{r.NewSku}'");
                meliPreview = await Api.GetCafeMeliPreviewAsync(meliSyncProducto.Id);
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { meliRenamingSku = false; }
    }

