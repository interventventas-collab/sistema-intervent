@page "/cafe/productos"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>☕ Productos <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(productosVisibles.Count))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroCategoria" @bind:after="Load">
                <option value="">Todas las categorías</option>
                <option value="CAFE">☕ Café</option>
                <option value="OTROS">📦 Otros / insumos</option>
            </select>
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroMarca">
                <option value="">Todas las marcas</option>
                @foreach (var m in marcasExistentes) { <option value="@m">@m</option> }
            </select>
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo Producto</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (productos is null || productos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay productos cargados. Tocá <strong>"+ Nuevo Producto"</strong> para empezar.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Marca</th>
                            <th style="text-align: right;">Costo</th>
                            <th style="text-align: right;">PVP1 (BAR)</th>
                            <th style="text-align: right;">PVP2 (OTRO)</th>
                            <th style="text-align: right;">Stock</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in productosVisibles)
                        {
                            var esCafe = p.Categoria == "CAFE";
                            <tr>
                                <td>
                                    <strong>@p.Nombre</strong>
                                    @if (!string.IsNullOrEmpty(p.Notas))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">@p.Notas</div>
                                    }
                                </td>
                                <td>
                                    @if (esCafe)
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#fef3c7; color:#92400e; border-radius:999px; font-size:0.72rem; font-weight:700;">☕ CAFÉ</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#e0e7ff; color:#3730a3; border-radius:999px; font-size:0.72rem; font-weight:700;">📦 OTROS</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.Marca))
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#f3f4f6; color:#374151; border-radius:999px; font-size:0.72rem; font-weight:700;">@p.Marca</span>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">—</span>
                                    }
                                </td>
                                <td style="text-align: right;">$@FormatMoney(p.Costo)</td>
                                <td style="text-align: right; font-weight: 700; color: #1d4ed8;">@(p.Pvp1.HasValue ? "$" + FormatMoney(p.Pvp1.Value) : "—")</td>
                                <td style="text-align: right; font-weight: 700; color: #15803d;">@(p.Pvp2.HasValue ? "$" + FormatMoney(p.Pvp2.Value) : "—")</td>
                                <td style="text-align: right; font-weight: 700;">
                                    @if (esCafe)
                                    {
                                        <span>@FormatGramos(p.StockGramos)</span>
                                    }
                                    else
                                    {
                                        <span>@p.StockUnidades u.</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(p.IsActive ? "status-active" : "status-inactive")">
                                        @(p.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(p)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(p)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 700px;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar producto" : "Nuevo producto")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Café Brasil" autofocus />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Categoría</label>
                        <select class="form-input" @bind="formCategoria">
                            <option value="CAFE">☕ Café</option>
                            <option value="OTROS">📦 Otros / insumos</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Marca</label>
                        <input class="form-input" @bind="formMarca" placeholder="Ej: La Virginia, Frikaf, Colombraro..." list="cafe-marcas" />
                        <datalist id="cafe-marcas">
                            @foreach (var m in marcasExistentes) { <option value="@m" /> }
                        </datalist>
                        <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                            💡 Si ya cargaste otros productos con la misma marca, te aparece como sugerencia.
                        </p>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Costo ($)</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="formCosto" />
                    </div>
                </div>

                @if (formCategoria == "CAFE")
                {
                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">☕ Precios por kg</h4>
                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP 1 — clientes BAR ($/kg)</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp1" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP 2 — otros clientes ($/kg)</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp2" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock (gramos)</label>
                        <input class="form-input" type="number" step="1" min="0" @bind="formStockGramos" />
                        <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">@FormatGramos(formStockGramos)</p>
                    </div>
                }
                else
                {
                    <p style="font-size: 0.78rem; color: #6b7280; padding: 0.4rem 0.6rem; background: #f3f4f6; border-radius: 4px;">
                        Los precios de los productos OTROS se calculan automáticamente con el margen configurado en <strong>Configuración</strong>:
                        <strong>costo × (1 + margen%)</strong>.
                    </p>
                    <div class="form-group">
                        <label class="form-label">Stock (unidades)</label>
                        <input class="form-input" type="number" step="1" min="0" @bind="formStockUnidades" />
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <input class="form-input" @bind="formNotas" placeholder="Notas internas (opcional)" />
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && toDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar producto</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar <strong>@toDelete.Nombre</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeProductoDto>? productos;
    private bool loading = true;
    private string filtroCategoria = "";
    private string filtroMarca = "";
    private bool showForm;
    private bool isEditing;
    private bool saving;
    private string? formError;
    private int? editingId;
    private string formNombre = "";
    private string formCategoria = "CAFE";
    private string formMarca = "";
    private decimal formCosto;
    private decimal? formPvp1;
    private decimal? formPvp2;
    private decimal formStockGramos;
    private int formStockUnidades;
    private string formNotas = "";
    private bool formIsActive = true;

    /// <summary>Marcas existentes (de productos ya cargados), ordenadas alfabéticamente, para el datalist y el filtro.</summary>
    private List<string> marcasExistentes => productos is null
        ? new()
        : productos.Where(p => !string.IsNullOrWhiteSpace(p.Marca))
                   .Select(p => p.Marca!.Trim())
                   .Distinct(StringComparer.OrdinalIgnoreCase)
                   .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                   .ToList();

    /// <summary>Lista filtrada por marca (la categoría ya viene filtrada del backend).</summary>
    private List<CafeProductoDto> productosVisibles => productos is null
        ? new()
        : (string.IsNullOrEmpty(filtroMarca)
            ? productos
            : productos.Where(p => string.Equals(p.Marca, filtroMarca, StringComparison.OrdinalIgnoreCase)).ToList());
    private bool showDeleteConfirm;
    private CafeProductoDto? toDelete;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        try
        {
            var cat = string.IsNullOrEmpty(filtroCategoria) ? null : filtroCategoria;
            productos = await Api.GetCafeProductosAsync(cat) ?? new();
        }
        catch { ToastService.Error("Error al cargar productos"); productos = new(); }
        loading = false;
    }

    private void ShowCreate()
    {
        isEditing = false; editingId = null;
        formNombre = ""; formCategoria = "CAFE"; formMarca = "";
        formCosto = 0; formPvp1 = null; formPvp2 = null;
        formStockGramos = 0; formStockUnidades = 0;
        formNotas = ""; formIsActive = true;
        formError = null; showForm = true;
    }

    private void ShowEdit(CafeProductoDto p)
    {
        isEditing = true; editingId = p.Id;
        formNombre = p.Nombre; formCategoria = p.Categoria; formMarca = p.Marca ?? "";
        formCosto = p.Costo; formPvp1 = p.Pvp1; formPvp2 = p.Pvp2;
        formStockGramos = p.StockGramos; formStockUnidades = p.StockUnidades;
        formNotas = p.Notas ?? ""; formIsActive = p.IsActive;
        formError = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        if (formCosto < 0) { formError = "El costo no puede ser negativo"; return; }
        saving = true;
        try
        {
            if (isEditing && editingId.HasValue)
            {
                var u = await Api.UpdateCafeProductoAsync(editingId.Value, new UpdateCafeProductoRequest
                {
                    Nombre = formNombre, Categoria = formCategoria, Marca = formMarca,
                    Costo = formCosto, Pvp1 = formPvp1, Pvp2 = formPvp2,
                    StockGramos = formStockGramos, StockUnidades = formStockUnidades,
                    Notas = formNotas, IsActive = formIsActive
                });
                if (u is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Producto actualizado");
            }
            else
            {
                var c = await Api.CreateCafeProductoAsync(new CreateCafeProductoRequest
                {
                    Nombre = formNombre, Categoria = formCategoria, Marca = formMarca,
                    Costo = formCosto, Pvp1 = formPvp1, Pvp2 = formPvp2,
                    StockGramos = formCategoria == "CAFE" ? formStockGramos : 0,
                    StockUnidades = formCategoria == "OTROS" ? formStockUnidades : 0,
                    Notas = formNotas
                });
                if (c is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Producto creado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private void ConfirmDelete(CafeProductoDto p) { toDelete = p; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (toDelete is null) return;
        try
        {
            var ok = await Api.DeleteCafeProductoAsync(toDelete.Id);
            if (ok) { ToastService.Success("Producto eliminado"); await Load(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; toDelete = null; }
    }

    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    private static string FormatGramos(decimal g)
    {
        if (g >= 1000m) return $"{(g / 1000m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))} kg";
        return $"{g:0} g";
    }
}
