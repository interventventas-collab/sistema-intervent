@page "/cafe/productos"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<style>
    .cli-pick-row:hover { background: #f0f9ff; }
</style>

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>☕ Productos <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(productosVisibles.Count))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <input class="form-input" style="min-width: 240px; font-size: 0.85rem;"
                   @bind="filtroTexto" @bind:event="oninput"
                   placeholder="🔍 SKU, código de barras, nombre..." />
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroCategoria" @bind:after="Load">
                <option value="">Todas las categorías</option>
                <option value="CAFE">☕ Café</option>
                <option value="OTROS">📦 Otros / insumos</option>
            </select>
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroMarca">
                <option value="">Todas las marcas</option>
                <option value="__sin__">— Sin marca —</option>
                @foreach (var m in marcasExistentes) { <option value="@m">@m</option> }
            </select>
            <button class="btn @(modoEdicion ? "btn-warning" : "btn-secondary")"
                    @onclick="() => modoEdicion = !modoEdicion" title="Edicion rapida de marca y nombre">
                @(modoEdicion ? "🔓 Edicion ON" : "🔒 Edicion OFF")
            </button>
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo Producto</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (productos is null || productos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay productos cargados. Tocá <strong>"+ Nuevo Producto"</strong> para empezar.
            </p>
        }
        else
        {
            @if (modoEdicion)
            {
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center; padding:0.6rem 0.7rem; background:#fef3c7; border:1px solid #f59e0b; border-radius:6px; margin:0.5rem;">
                    <span style="font-weight:700; color:#78350f;">
                        🔓 Edición ON · @selProductos.Count seleccionado(s) de @productosVisibles.Count visible(s)
                    </span>
                    <span style="flex:1;"></span>

                    <button class="btn btn-secondary" style="padding:0.2rem 0.5rem; font-size:0.78rem;"
                            @onclick="SeleccionarTodosVisibles" disabled="@(productosVisibles.Count == 0)">Seleccionar visibles</button>
                    <button class="btn btn-secondary" style="padding:0.2rem 0.5rem; font-size:0.78rem;"
                            @onclick="LimpiarSeleccion" disabled="@(selProductos.Count == 0)">Limpiar</button>

                    <select class="form-input" @bind="bulkMarcaIdStr" style="max-width:240px; font-size:0.85rem;">
                        <option value="">— Sin marca —</option>
                        @if (marcasCatalog is not null)
                        {
                            @foreach (var m in marcasCatalog.OrderBy(x => x.Nombre))
                            {
                                <option value="@m.Id">@m.Nombre</option>
                            }
                        }
                    </select>
                    <button class="btn btn-primary" @onclick="AplicarMarcaABulk"
                            disabled="@(selProductos.Count == 0 || isBusyBulk)">
                        @(isBusyBulk ? "Aplicando..." : $"Aplicar marca a {selProductos.Count}")
                    </button>
                </div>
            }
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            @if (modoEdicion)
                            {
                                <th style="width:32px;">
                                    <input type="checkbox" @onchange="ToggleAllVisibles" checked="@TodosVisiblesSeleccionados" />
                                </th>
                            }
                            <th style="width: 100px;">SKU</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Marca</th>
                            <th style="text-align: right;" title="Sin IVA">Costo s/IVA</th>
                            <th style="text-align: right;">PVP BARES</th>
                            <th style="text-align: right;">PVP SUGERIDO</th>
                            <th style="text-align: right; width: 70px;">UxB</th>
                            <th style="text-align: right;">Stock</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in productosVisibles)
                        {
                            var esCafe = p.Categoria == "CAFE";
                            var capturado = p;
                            <tr>
                                @if (modoEdicion)
                                {
                                    <td>
                                        <input type="checkbox"
                                               checked="@selProductos.Contains(capturado.Id)"
                                               @onchange="@((ChangeEventArgs e) => ToggleProducto(capturado.Id, (bool)e.Value!))" />
                                    </td>
                                }
                                <td style="font-family: monospace; font-weight: 700; color: #1d4ed8;">
                                    @(p.Sku ?? "—")
                                    @if (!string.IsNullOrEmpty(p.OemCodigo))
                                    {
                                        <div style="font-size: 0.66rem; color: #15803d; font-weight: 700; margin-top: 0.15rem;" title="OEM origen">
                                            <span style="background: #dcfce7; padding: 0.05rem 0.4rem; border-radius: 4px;">OEM @p.OemCodigo</span>
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (modoEdicion)
                                    {
                                        <input class="form-input" style="font-size:0.85rem;"
                                               value="@p.Nombre"
                                               @onchange="@(async (e) => await GuardarNombreProducto(p, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        <strong>@p.Nombre</strong>
                                    }
                                    @if (!string.IsNullOrEmpty(p.Barcode))
                                    {
                                        <div style="font-size: 0.7rem; color: #9ca3af; font-family: monospace;">cod: @p.Barcode</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.Notas))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">@p.Notas</div>
                                    }
                                </td>
                                <td>
                                    @if (esCafe)
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#fef3c7; color:#92400e; border-radius:999px; font-size:0.72rem; font-weight:700;">☕ CAFÉ</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#e0e7ff; color:#3730a3; border-radius:999px; font-size:0.72rem; font-weight:700;">📦 OTROS</span>
                                    }
                                </td>
                                <td>
                                    @if (modoEdicion)
                                    {
                                        <select class="form-input" style="font-size:0.82rem;"
                                                value="@(p.MarcaId?.ToString() ?? "")"
                                                @onchange="@(async (e) => await GuardarMarcaProducto(p, e.Value?.ToString()))">
                                            <option value="">— Sin marca —</option>
                                            @if (marcasCatalog is not null)
                                            {
                                                @foreach (var m in marcasCatalog.OrderBy(x => x.Nombre))
                                                {
                                                    <option value="@m.Id">@m.Nombre</option>
                                                }
                                            }
                                        </select>
                                    }
                                    else if (!string.IsNullOrEmpty(p.Marca))
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#f3f4f6; color:#374151; border-radius:999px; font-size:0.72rem; font-weight:700;">@p.Marca</span>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">—</span>
                                    }
                                </td>
                                <td style="text-align: right;" class="precio-clickeable" title="Ver historial" @onclick="() => ShowHistorial(p)">$@FormatMoney(p.Costo)</td>
                                @if (esCafe)
                                {
                                    <td style="text-align: right; font-weight: 700; color: #1d4ed8;" class="precio-clickeable" title="Ver historial" @onclick="() => ShowHistorial(p)">
                                        @if (p.Pvp1.HasValue)
                                        {
                                            <div>$@FormatMoney(p.Pvp1.Value)/kg</div>
                                            <div style="font-size: 0.7rem; color: #6b7280; font-weight: 500;">c/IVA $@FormatMoney(p.Pvp1ConIva!.Value)</div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                    <td style="text-align: right; font-weight: 700; color: #15803d;" class="precio-clickeable" title="Ver historial" @onclick="() => ShowHistorial(p)">
                                        @if (p.Pvp2.HasValue)
                                        {
                                            <div>$@FormatMoney(p.Pvp2.Value)/kg</div>
                                            <div style="font-size: 0.7rem; color: #6b7280; font-weight: 500;">c/IVA $@FormatMoney(p.Pvp2ConIva!.Value)</div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                }
                                else
                                {
                                    @* PVP BARES: costo × (1 + (BarPctSobreCosto ?? 100)/100). Default 100% si no hay margen específico. *@
                                    <td style="text-align: right; font-weight: 700; color: #1d4ed8;" class="precio-clickeable" title="Ver historial" @onclick="() => ShowHistorial(p)">
                                        @if (p.Costo > 0)
                                        {
                                            var pctBar = p.BarPctSobreCosto ?? 100m;
                                            var precioBar = Math.Round(p.Costo * (1m + pctBar / 100m), 2);
                                            var precioBarConIva = Math.Round(precioBar * (1 + p.IvaPct / 100m), 2);
                                            <div>$@FormatMoney(precioBar)</div>
                                            <div style="font-size: 0.66rem; color: #6b7280; font-weight: 500;">
                                                +@pctBar.ToString("0.##")%@(p.BarPctSobreCosto.HasValue ? "" : " (default)") · c/IVA $@FormatMoney(precioBarConIva)
                                            </div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                    @* PVP SUGERIDO: del OEM si está vinculado (lo "real"); fallback al Pvp2 cargado en el producto. *@
                                    <td style="text-align: right; font-weight: 700; color: #15803d;" class="precio-clickeable" title="Ver historial" @onclick="() => ShowHistorial(p)">
                                        @if (p.OemPvpConIva.HasValue)
                                        {
                                            <div>$@FormatMoney(p.OemPvpSinIva!.Value)</div>
                                            <div style="font-size: 0.7rem; color: #6b7280; font-weight: 500;">del OEM · c/IVA $@FormatMoney(p.OemPvpConIva.Value)</div>
                                        }
                                        else if (p.Pvp2.HasValue)
                                        {
                                            <div>$@FormatMoney(p.Pvp2.Value)</div>
                                            <div style="font-size: 0.7rem; color: #9ca3af; font-weight: 500;">sin OEM · c/IVA $@FormatMoney(p.Pvp2ConIva!.Value)</div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                }
                                <td style="text-align: right; color: #6b7280; font-size: 0.85rem;">@(esCafe ? "—" : (p.UxB?.ToString() ?? "—"))</td>
                                <td style="text-align: right; font-weight: 700;">
                                    @if (esCafe)
                                    {
                                        <span>@FormatGramos(p.StockGramos)</span>
                                    }
                                    else
                                    {
                                        <span>@p.StockUnidades u.</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(p.IsActive ? "status-active" : "status-inactive")">
                                        @(p.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(p)" title="Editar">@SvgIcons.Edit</button>
                                    @if (esCafe)
                                    {
                                        <button class="btn-icon" style="color:#1d4ed8;" @onclick="() => ShowMeliSync(p)" title="Sincronizar a MercadoLibre">📤</button>
                                    }
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(p)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 700px;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar producto" : "Nuevo producto")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">SKU</label>
                        <input class="form-input" @bind="formSku" placeholder="Ej: F1" style="font-family: monospace; text-transform: uppercase;" />
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Código de barras</label>
                        <input class="form-input" @bind="formBarcode" placeholder="Opcional, ej: 7791234567890" style="font-family: monospace;" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Café Brasil" autofocus />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Categoría</label>
                        <select class="form-input" @bind="formCategoria">
                            <option value="CAFE">☕ Café</option>
                            <option value="OTROS">📦 Otros / insumos</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Marca</label>
                        <input class="form-input" @bind="formMarca" placeholder="Ej: La Virginia, Frikaf, Colombraro..." list="cafe-marcas-list" />
                        <datalist id="cafe-marcas-list">
                            @if (marcasCatalog is not null)
                            {
                                @foreach (var m in marcasCatalog.Where(x => x.IsActive).OrderBy(x => x.Nombre))
                                {
                                    <option value="@m.Nombre" />
                                }
                            }
                        </datalist>
                        @{
                            var matched = !string.IsNullOrWhiteSpace(formMarca)
                                ? marcasCatalog?.FirstOrDefault(x => string.Equals(x.Nombre, formMarca?.Trim(), StringComparison.OrdinalIgnoreCase))
                                : null;
                        }
                        @if (matched is not null)
                        {
                            <p style="font-size: 0.72rem; color: #15803d; margin: 0.2rem 0 0; font-weight: 600;">
                                ✓ Marca existente — proveedor: <strong>@(matched.ProveedorNombre ?? "(sin asignar)")</strong>
                            </p>
                        }
                        else if (!string.IsNullOrWhiteSpace(formMarca))
                        {
                            <p style="font-size: 0.72rem; color: #d97706; margin: 0.2rem 0 0;">
                                ⚠ Marca nueva — se va a crear al guardar. Después podés asignar proveedor desde <strong>Marcas</strong>.
                            </p>
                        }
                        else
                        {
                            <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                                💡 Empezá a tipear, te aparece la lista de marcas existentes.
                            </p>
                        }
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Costo (sin IVA) ($)</label>
                        <input class="form-input" type="number" step="0.01" min="0"
                               @bind="formCosto" @bind:event="oninput" @bind:after="RecalcularMargenesDesdeCosto" />
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Costo interno del producto, sin IVA.</p>
                    </div>
                </div>

                @if (formCategoria == "CAFE")
                {
                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">☕ Precios por kg</h4>
                    <div class="form-row">
                        <div class="form-group" style="flex: 0 0 130px;">
                            <label class="form-label">IVA %</label>
                            <select class="form-input" @bind="formIvaPctStr">
                                <option value="21">21%</option>
                                <option value="10.5">10.5%</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP 1 — clientes BAR (sin IVA, $/kg)</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp1" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                                @if (formPvp1.HasValue)
                                {
                                    <span>Con IVA: <b>$@FormatMoney(Math.Round(formPvp1.Value * (1 + formIvaPct / 100m), 2))</b>/kg</span>
                                }
                                else { <span>Precio por kg, sin IVA. El con IVA se calcula automáticamente.</span> }
                            </p>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP 2 — otros clientes (sin IVA, $/kg)</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp2" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                                @if (formPvp2.HasValue)
                                {
                                    <span>Con IVA: <b>$@FormatMoney(Math.Round(formPvp2.Value * (1 + formIvaPct / 100m), 2))</b>/kg</span>
                                }
                                else { <span>Precio por kg, sin IVA. El con IVA se calcula automáticamente.</span> }
                            </p>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock (kg)</label>
                        <input class="form-input" type="number" step="0.001" min="0" @bind="formStockKg" />
                    </div>
                }
                else
                {
                    @* OEM origen *@
                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">📋 OEM origen (proveedor)</h4>
                    <div class="form-group" style="position: relative;">
                        @if (formOemId > 0)
                        {
                            var oSel = oems?.FirstOrDefault(x => x.Id == formOemId);
                            <div style="display: flex; gap: 0.3rem; align-items: center;">
                                <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                    <span style="background:#16a34a; color:white; padding:0.15rem 0.45rem; border-radius:6px; font-weight:800; font-family:monospace;">@(oSel?.Codigo ?? "?")</span>
                                    <strong>@(oSel?.Descripcion ?? "—")</strong>
                                    @if (oSel is not null)
                                    {
                                        @if (!string.IsNullOrEmpty(oSel.Marca))
                                        {
                                            <span style="font-size: 0.72rem; color: #6b7280;">· @oSel.Marca</span>
                                        }
                                        <span style="font-size: 0.72rem; color: #6b7280;" title="Sin IVA">· costo s/IVA $@FormatMoney(oSel.Costo)</span>
                                        @if (oSel.PvpConIva.HasValue)
                                        {
                                            <span style="font-size: 0.72rem; color: #15803d;" title="Con IVA">· PVP c/IVA $@FormatMoney(oSel.PvpConIva.Value)</span>
                                        }
                                    }
                                </div>
                                <button class="btn btn-secondary" type="button" @onclick="ClearOem" title="Quitar OEM">×</button>
                                <button class="btn btn-secondary" type="button" @onclick="AutocompletarDesdeOem" title="Pisar costo y PVP con datos del OEM">⟳ Aplicar precios</button>
                            </div>
                        }
                        else
                        {
                            <input class="form-input" @bind="oemSearch" @bind:event="oninput"
                                   @onfocus="() => oemSearchOpen = true"
                                   placeholder="🔍 Buscar OEM por código, descripción, marca, barcode..." />
                            @if (oemSearchOpen && !string.IsNullOrWhiteSpace(oemSearch))
                            {
                                var matches = OemsMatching(oemSearch).Take(20).ToList();
                                <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                    @if (matches.Count == 0)
                                    {
                                        <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados. Cargá OEMs en <strong>OEMs</strong>.</div>
                                    }
                                    else
                                    {
                                        @foreach (var o in matches)
                                        {
                                            var oId = o.Id;
                                            <div class="cli-pick-row" @onclick="() => SelectOem(oId)"
                                                 style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                                <span style="background:#16a34a; color:white; padding:0.1rem 0.4rem; border-radius:4px; font-weight:700; font-family:monospace; margin-right:0.4rem;">@o.Codigo</span>
                                                <strong>@(o.Descripcion ?? "")</strong>
                                                @if (!string.IsNullOrEmpty(o.Marca))
                                                {
                                                    <span style="color:#6b7280; font-size:0.78rem;"> · @o.Marca</span>
                                                }
                                                <span style="color:#6b7280; font-size:0.78rem;" title="Sin IVA"> · costo s/IVA $@FormatMoney(o.Costo)</span>
                                                @if (o.PvpConIva.HasValue)
                                                {
                                                    <span style="color:#15803d; font-size:0.78rem;" title="Con IVA"> · PVP c/IVA $@FormatMoney(o.PvpConIva.Value)</span>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Opcional. Vincula este producto a un OEM del proveedor para heredar costo + PVP.</p>
                        }
                    </div>

                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">📦 Precios</h4>
                    <div class="form-row">
                        <div class="form-group" style="flex: 0 0 130px;">
                            <label class="form-label">IVA %</label>
                            <select class="form-input" @bind="formIvaPctStr">
                                <option value="21">21%</option>
                                <option value="10.5">10.5%</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">UxB</label>
                            <input class="form-input" type="number" step="1" min="0" @bind="formUxB" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Unidades por bulto (informativo)</p>
                        </div>
                    </div>
                    @* ════════════ Modelo NUEVO: 2 precios directos por producto ════════════ *@
                    <div style="background: #f0fdf4; border: 1px solid #16a34a; border-radius: 6px; padding: 0.6rem 0.8rem; margin-top: 0.5rem;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin: 0 0 0.5rem;">
                            <h4 style="margin: 0; font-size: 0.85rem; color: #166534;">💰 Precios de venta (sin IVA)</h4>
                            @if (formCosto > 0 && (formMargenBar.HasValue || formMargenOtro.HasValue))
                            {
                                <button type="button" class="btn btn-secondary" @onclick="RefrescarPreciosAlCostoActual"
                                        style="font-size: 0.7rem; padding: 0.25rem 0.5rem;"
                                        title="Recalcula los precios manteniendo los márgenes actuales contra el costo. Útil cuando subió el costo y querés mantener el margen.">
                                    🔄 Refrescar al costo
                                </button>
                            }
                        </div>
                        <div class="form-row" style="margin-bottom: 0.3rem;">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Precio BAR (mayorista)</label>
                                <div style="display: flex; gap: 0.3rem; align-items: stretch;">
                                    <input class="form-input" type="number" step="0.01" min="0"
                                           @bind="formPrecioBar" @bind:event="oninput" @bind:after="RecalcMargenBarDesdePrecio"
                                           placeholder="0,00" style="flex: 1 1 auto; min-width: 0;" />
                                    @if (formCosto > 0)
                                    {
                                        <button type="button" class="btn btn-secondary" @onclick="@(() => SetPrecioBar(Math.Round(formCosto * 2m, 2)))"
                                                style="white-space: nowrap; font-size: 0.75rem; padding: 0.3rem 0.5rem;"
                                                title="Sugerir: costo × 2 (margen 100%)">🎯 ×2</button>
                                    }
                                </div>
                                @* Margen editable: si lo cambias, se recalcula el precio. *@
                                @if (formCosto > 0)
                                {
                                    <div style="display: flex; gap: 0.3rem; align-items: center; margin-top: 0.25rem;">
                                        <label style="font-size: 0.7rem; color: #166534; font-weight: 600; white-space: nowrap;">Margen %:</label>
                                        <input class="form-input" type="number" step="0.1" min="0"
                                               @bind="formMargenBar" @bind:event="oninput" @bind:after="RecalcPrecioBarDesdeMargen"
                                               placeholder="100"
                                               style="flex: 1 1 auto; min-width: 0; padding: 0.2rem 0.4rem; font-size: 0.8rem;" />
                                    </div>
                                }
                                <p style="font-size: 0.7rem; color: #166534; margin: 0.2rem 0 0;">
                                    @if (formPrecioBar.HasValue && formPrecioBar.Value > 0)
                                    {
                                        var ivaBar = Math.Round(formPrecioBar.Value * (1 + formIvaPct / 100m), 2);
                                        <span>Con IVA: <b>$@FormatMoney(ivaBar)</b></span>
                                    }
                                    else { <span>Lo que cobrás al bar / mayorista.</span> }
                                </p>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Precio OTRO (consumidor final / venta x fuera)</label>
                                <div style="display: flex; gap: 0.3rem; align-items: stretch;">
                                    <input class="form-input" type="number" step="0.01" min="0"
                                           @bind="formPrecioOtro" @bind:event="oninput" @bind:after="RecalcMargenOtroDesdePrecio"
                                           placeholder="0,00" style="flex: 1 1 auto; min-width: 0;" />
                                    @if (formCosto > 0)
                                    {
                                        <button type="button" class="btn btn-secondary" @onclick="@(() => SetPrecioOtro(Math.Round(formCosto * 2m, 2)))"
                                                style="white-space: nowrap; font-size: 0.75rem; padding: 0.3rem 0.5rem;"
                                                title="Sugerir: costo × 2 (margen 100%)">🎯 ×2</button>
                                    }
                                </div>
                                @if (formCosto > 0)
                                {
                                    <div style="display: flex; gap: 0.3rem; align-items: center; margin-top: 0.25rem;">
                                        <label style="font-size: 0.7rem; color: #166534; font-weight: 600; white-space: nowrap;">Margen %:</label>
                                        <input class="form-input" type="number" step="0.1" min="0"
                                               @bind="formMargenOtro" @bind:event="oninput" @bind:after="RecalcPrecioOtroDesdeMargen"
                                               placeholder="100"
                                               style="flex: 1 1 auto; min-width: 0; padding: 0.2rem 0.4rem; font-size: 0.8rem;" />
                                    </div>
                                }
                                <p style="font-size: 0.7rem; color: #166534; margin: 0.2rem 0 0;">
                                    @if (formPrecioOtro.HasValue && formPrecioOtro.Value > 0)
                                    {
                                        var ivaOtro = Math.Round(formPrecioOtro.Value * (1 + formIvaPct / 100m), 2);
                                        <span>Con IVA: <b>$@FormatMoney(ivaOtro)</b></span>
                                    }
                                    else { <span>Lo que paga el consumidor final / venta por fuera.</span> }
                                </p>
                            </div>
                        </div>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.3rem 0 0;">
                            💡 Estos precios son directos: el sistema usa el que corresponde según el tipo de cliente (BAR u OTRO), sin matriz de descuentos.
                        </p>
                    </div>
                    @* ════════════ Precio del bulto (descuento por volumen) ════════════ *@
                    <div style="background: #fef3c7; border: 1px solid #d97706; border-radius: 6px; padding: 0.6rem 0.8rem; margin-top: 0.5rem;">
                        <h4 style="margin: 0 0 0.5rem; font-size: 0.85rem; color: #92400e;">📦 Precio del bulto (descuento por volumen) — opcional</h4>
                        <p style="font-size: 0.7rem; color: #92400e; margin: 0 0 0.5rem;">
                            Si el cliente lleva @(formUxB.HasValue && formUxB.Value > 0 ? formUxB.Value.ToString() : "UxB") o más, se le cobra el precio del bulto en vez del unitario. Sin bulto cargado: siempre cantidad × precio unitario.
                        </p>
                        <div class="form-row" style="margin: 0;">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Precio bulto BAR</label>
                                <input class="form-input" type="number" step="0.01" min="0"
                                       @bind="formPrecioBulto"
                                       placeholder="@(formPrecioBar.HasValue && formUxB.HasValue ? (formPrecioBar.Value * formUxB.Value).ToString("0.##") : "0,00")" />
                                <p style="font-size: 0.7rem; color: #92400e; margin: 0.2rem 0 0;">
                                    @if (formPrecioBulto.HasValue && formPrecioBulto.Value > 0 && formUxB.HasValue && formUxB.Value > 0)
                                    {
                                        var unit = Math.Round(formPrecioBulto.Value / formUxB.Value, 2);
                                        <span>= $@FormatMoney(unit) c/u</span>
                                    }
                                    else { <span>Vacío = no aplica descuento por bulto.</span> }
                                </p>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Precio bulto OTRO</label>
                                <input class="form-input" type="number" step="0.01" min="0"
                                       @bind="formPrecioBultoOtro"
                                       placeholder="@(formPrecioBulto.HasValue ? (formPrecioBulto.Value * 1.2m).ToString("0.##") : "0,00")" />
                                <p style="font-size: 0.7rem; color: #92400e; margin: 0.2rem 0 0;">
                                    @if (formPrecioBultoOtro.HasValue && formPrecioBultoOtro.Value > 0 && formUxB.HasValue && formUxB.Value > 0)
                                    {
                                        var unit = Math.Round(formPrecioBultoOtro.Value / formUxB.Value, 2);
                                        <span>= $@FormatMoney(unit) c/u</span>
                                    }
                                    else { <span>Sugerido: bulto BAR × 1,2.</span> }
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock (unidades)</label>
                        <input class="form-input" type="number" step="1" min="0" @bind="formStockUnidades" />
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <input class="form-input" @bind="formNotas" placeholder="Notas internas (opcional)" />
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && toDelete is not null)
{
