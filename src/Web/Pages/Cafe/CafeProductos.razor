@page "/cafe/productos"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<style>
    .cli-pick-row:hover { background: #f0f9ff; }
</style>

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>☕ Productos <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(productosVisibles.Count))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <input class="form-input" style="min-width: 240px; font-size: 0.85rem;"
                   @bind="filtroTexto" @bind:event="oninput"
                   placeholder="🔍 SKU, código de barras, nombre..." />
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroCategoria" @bind:after="Load">
                <option value="">Todas las categorías</option>
                <option value="CAFE">☕ Café</option>
                <option value="OTROS">📦 Otros / insumos</option>
            </select>
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroMarca">
                <option value="">Todas las marcas</option>
                @foreach (var m in marcasExistentes) { <option value="@m">@m</option> }
            </select>
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo Producto</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (productos is null || productos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay productos cargados. Tocá <strong>"+ Nuevo Producto"</strong> para empezar.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 100px;">SKU</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Marca</th>
                            <th style="text-align: right;" title="Sin IVA">Costo s/IVA</th>
                            <th style="text-align: right;" title="Con IVA">PVP BAR c/IVA</th>
                            <th style="text-align: right;" title="Con IVA">PVP OTRO c/IVA</th>
                            <th style="text-align: right; width: 70px;">UxB</th>
                            <th style="text-align: right;">Stock</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in productosVisibles)
                        {
                            var esCafe = p.Categoria == "CAFE";
                            <tr>
                                <td style="font-family: monospace; font-weight: 700; color: #1d4ed8;">
                                    @(p.Sku ?? "—")
                                    @if (!string.IsNullOrEmpty(p.OemCodigo))
                                    {
                                        <div style="font-size: 0.66rem; color: #15803d; font-weight: 700; margin-top: 0.15rem;" title="OEM origen">
                                            <span style="background: #dcfce7; padding: 0.05rem 0.4rem; border-radius: 4px;">OEM @p.OemCodigo</span>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@p.Nombre</strong>
                                    @if (!string.IsNullOrEmpty(p.Barcode))
                                    {
                                        <div style="font-size: 0.7rem; color: #9ca3af; font-family: monospace;">cod: @p.Barcode</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.Notas))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">@p.Notas</div>
                                    }
                                </td>
                                <td>
                                    @if (esCafe)
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#fef3c7; color:#92400e; border-radius:999px; font-size:0.72rem; font-weight:700;">☕ CAFÉ</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#e0e7ff; color:#3730a3; border-radius:999px; font-size:0.72rem; font-weight:700;">📦 OTROS</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.Marca))
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#f3f4f6; color:#374151; border-radius:999px; font-size:0.72rem; font-weight:700;">@p.Marca</span>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">—</span>
                                    }
                                </td>
                                <td style="text-align: right;">$@FormatMoney(p.Costo)</td>
                                @if (esCafe)
                                {
                                    <td style="text-align: right; font-weight: 700; color: #1d4ed8;">
                                        @if (p.Pvp1.HasValue)
                                        {
                                            <div>$@FormatMoney(p.Pvp1.Value)/kg</div>
                                            <div style="font-size: 0.7rem; color: #6b7280; font-weight: 500;">c/IVA $@FormatMoney(p.Pvp1ConIva!.Value)</div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                    <td style="text-align: right; font-weight: 700; color: #15803d;">
                                        @if (p.Pvp2.HasValue)
                                        {
                                            <div>$@FormatMoney(p.Pvp2.Value)/kg</div>
                                            <div style="font-size: 0.7rem; color: #6b7280; font-weight: 500;">c/IVA $@FormatMoney(p.Pvp2ConIva!.Value)</div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                }
                                else
                                {
                                    <td style="text-align: right; font-weight: 700; color: #1d4ed8;">
                                        @if (p.BarPctSobreCosto.HasValue)
                                        {
                                            var precioBar = p.Costo * (1m + p.BarPctSobreCosto.Value / 100m);
                                            var precioBarConIva = Math.Round(precioBar * (1 + p.IvaPct / 100m), 2);
                                            <div>$@FormatMoney(precioBar)</div>
                                            <div style="font-size: 0.66rem; color: #6b7280; font-weight: 500;">+@p.BarPctSobreCosto.Value.ToString("0.##")% · c/IVA $@FormatMoney(precioBarConIva)</div>
                                        }
                                        else if (p.Pvp2.HasValue)
                                        {
                                            <div style="color: #6b7280;">$@FormatMoney(p.Pvp2.Value)</div>
                                            <div style="font-size: 0.66rem; color: #9ca3af; font-weight: 500;">igual a OTRO · c/IVA $@FormatMoney(p.Pvp2ConIva!.Value)</div>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td style="text-align: right; font-weight: 700; color: #15803d;">
                                        @if (p.Pvp2.HasValue)
                                        {
                                            <div>$@FormatMoney(p.Pvp2.Value)</div>
                                            <div style="font-size: 0.7rem; color: #6b7280; font-weight: 500;">c/IVA $@FormatMoney(p.Pvp2ConIva!.Value)</div>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                }
                                <td style="text-align: right; color: #6b7280; font-size: 0.85rem;">@(esCafe ? "—" : (p.UxB?.ToString() ?? "—"))</td>
                                <td style="text-align: right; font-weight: 700;">
                                    @if (esCafe)
                                    {
                                        <span>@FormatGramos(p.StockGramos)</span>
                                    }
                                    else
                                    {
                                        <span>@p.StockUnidades u.</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(p.IsActive ? "status-active" : "status-inactive")">
                                        @(p.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(p)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(p)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 700px;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar producto" : "Nuevo producto")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">SKU</label>
                        <input class="form-input" @bind="formSku" placeholder="Ej: F1" style="font-family: monospace; text-transform: uppercase;" />
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Código de barras</label>
                        <input class="form-input" @bind="formBarcode" placeholder="Opcional, ej: 7791234567890" style="font-family: monospace;" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Café Brasil" autofocus />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Categoría</label>
                        <select class="form-input" @bind="formCategoria">
                            <option value="CAFE">☕ Café</option>
                            <option value="OTROS">📦 Otros / insumos</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Marca</label>
                        <input class="form-input" @bind="formMarca" placeholder="Ej: La Virginia, Frikaf, Colombraro..." list="cafe-marcas-list" />
                        <datalist id="cafe-marcas-list">
                            @if (marcasCatalog is not null)
                            {
                                @foreach (var m in marcasCatalog.Where(x => x.IsActive).OrderBy(x => x.Nombre))
                                {
                                    <option value="@m.Nombre" />
                                }
                            }
                        </datalist>
                        @{
                            var matched = !string.IsNullOrWhiteSpace(formMarca)
                                ? marcasCatalog?.FirstOrDefault(x => string.Equals(x.Nombre, formMarca?.Trim(), StringComparison.OrdinalIgnoreCase))
                                : null;
                        }
                        @if (matched is not null)
                        {
                            <p style="font-size: 0.72rem; color: #15803d; margin: 0.2rem 0 0; font-weight: 600;">
                                ✓ Marca existente — proveedor: <strong>@(matched.ProveedorNombre ?? "(sin asignar)")</strong>
                            </p>
                        }
                        else if (!string.IsNullOrWhiteSpace(formMarca))
                        {
                            <p style="font-size: 0.72rem; color: #d97706; margin: 0.2rem 0 0;">
                                ⚠ Marca nueva — se va a crear al guardar. Después podés asignar proveedor desde <strong>Marcas</strong>.
                            </p>
                        }
                        else
                        {
                            <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                                💡 Empezá a tipear, te aparece la lista de marcas existentes.
                            </p>
                        }
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Costo (sin IVA) ($)</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="formCosto" />
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Costo interno del producto, sin IVA.</p>
                    </div>
                </div>

                @if (formCategoria == "CAFE")
                {
                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">☕ Precios por kg</h4>
                    <div class="form-row">
                        <div class="form-group" style="flex: 0 0 130px;">
                            <label class="form-label">IVA %</label>
                            <select class="form-input" @bind="formIvaPct">
                                <option value="21">21%</option>
                                <option value="10.5">10.5%</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP 1 — clientes BAR (sin IVA, $/kg)</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp1" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                                @if (formPvp1.HasValue)
                                {
                                    <span>Con IVA: <b>$@FormatMoney(Math.Round(formPvp1.Value * (1 + formIvaPct / 100m), 2))</b>/kg</span>
                                }
                                else { <span>Precio por kg, sin IVA. El con IVA se calcula automáticamente.</span> }
                            </p>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP 2 — otros clientes (sin IVA, $/kg)</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp2" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                                @if (formPvp2.HasValue)
                                {
                                    <span>Con IVA: <b>$@FormatMoney(Math.Round(formPvp2.Value * (1 + formIvaPct / 100m), 2))</b>/kg</span>
                                }
                                else { <span>Precio por kg, sin IVA. El con IVA se calcula automáticamente.</span> }
                            </p>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock (kg)</label>
                        <input class="form-input" type="number" step="0.001" min="0" @bind="formStockKg" />
                    </div>
                }
                else
                {
                    @* OEM origen *@
                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">📋 OEM origen (proveedor)</h4>
                    <div class="form-group" style="position: relative;">
                        @if (formOemId > 0)
                        {
                            var oSel = oems?.FirstOrDefault(x => x.Id == formOemId);
                            <div style="display: flex; gap: 0.3rem; align-items: center;">
                                <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                    <span style="background:#16a34a; color:white; padding:0.15rem 0.45rem; border-radius:6px; font-weight:800; font-family:monospace;">@(oSel?.Codigo ?? "?")</span>
                                    <strong>@(oSel?.Descripcion ?? "—")</strong>
                                    @if (oSel is not null)
                                    {
                                        @if (!string.IsNullOrEmpty(oSel.Marca))
                                        {
                                            <span style="font-size: 0.72rem; color: #6b7280;">· @oSel.Marca</span>
                                        }
                                        <span style="font-size: 0.72rem; color: #6b7280;" title="Sin IVA">· costo s/IVA $@FormatMoney(oSel.Costo)</span>
                                        @if (oSel.PvpConIva.HasValue)
                                        {
                                            <span style="font-size: 0.72rem; color: #15803d;" title="Con IVA">· PVP c/IVA $@FormatMoney(oSel.PvpConIva.Value)</span>
                                        }
                                    }
                                </div>
                                <button class="btn btn-secondary" type="button" @onclick="ClearOem" title="Quitar OEM">×</button>
                                <button class="btn btn-secondary" type="button" @onclick="AutocompletarDesdeOem" title="Pisar costo y PVP con datos del OEM">⟳ Aplicar precios</button>
                            </div>
                        }
                        else
                        {
                            <input class="form-input" @bind="oemSearch" @bind:event="oninput"
                                   @onfocus="() => oemSearchOpen = true"
                                   placeholder="🔍 Buscar OEM por código, descripción, marca, barcode..." />
                            @if (oemSearchOpen && !string.IsNullOrWhiteSpace(oemSearch))
                            {
                                var matches = OemsMatching(oemSearch).Take(20).ToList();
                                <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                    @if (matches.Count == 0)
                                    {
                                        <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados. Cargá OEMs en <strong>OEMs</strong>.</div>
                                    }
                                    else
                                    {
                                        @foreach (var o in matches)
                                        {
                                            var oId = o.Id;
                                            <div class="cli-pick-row" @onclick="() => SelectOem(oId)"
                                                 style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                                <span style="background:#16a34a; color:white; padding:0.1rem 0.4rem; border-radius:4px; font-weight:700; font-family:monospace; margin-right:0.4rem;">@o.Codigo</span>
                                                <strong>@(o.Descripcion ?? "")</strong>
                                                @if (!string.IsNullOrEmpty(o.Marca))
                                                {
                                                    <span style="color:#6b7280; font-size:0.78rem;"> · @o.Marca</span>
                                                }
                                                <span style="color:#6b7280; font-size:0.78rem;" title="Sin IVA"> · costo s/IVA $@FormatMoney(o.Costo)</span>
                                                @if (o.PvpConIva.HasValue)
                                                {
                                                    <span style="color:#15803d; font-size:0.78rem;" title="Con IVA"> · PVP c/IVA $@FormatMoney(o.PvpConIva.Value)</span>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Opcional. Vincula este producto a un OEM del proveedor para heredar costo + PVP.</p>
                        }
                    </div>

                    <h4 style="margin: 1rem 0 0.5rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">📦 Precios</h4>
                    <div class="form-row">
                        <div class="form-group" style="flex: 0 0 130px;">
                            <label class="form-label">IVA %</label>
                            <select class="form-input" @bind="formIvaPct">
                                <option value="21">21%</option>
                                <option value="10.5">10.5%</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">PVP SUGERIDO POR PROVEEDOR (sin IVA, $) *</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="formPvp2" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                                @if (formPvp2.HasValue)
                                {
                                    <span>Con IVA: <b>$@FormatMoney(Math.Round(formPvp2.Value * (1 + formIvaPct / 100m), 2))</b></span>
                                }
                                else { <span>Precio de lista sin IVA. Obligatorio. Lo paga el cliente OTRO.</span> }
                            </p>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">UxB</label>
                            <input class="form-input" type="number" step="1" min="0" @bind="formUxB" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Unidades por bulto (informativo)</p>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">PVP % SOBRE EL COSTO (BAR / mayorista)</label>
                            <input class="form-input" type="number" step="0.01" @bind="formBarPct" placeholder="100" />
                            @if (formCosto > 0 && formBarPct.HasValue)
                            {
                                var precioBar = formCosto * (1m + formBarPct.Value / 100m);
                                <p style="font-size: 0.72rem; color: #1d4ed8; margin: 0.2rem 0 0; font-weight: 600;">
                                    → BAR paga $@FormatMoney(precioBar)
                                </p>
                            }
                            else if (formCosto > 0)
                            {
                                <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                                    Vacío = BAR paga lo mismo que OTRO ($@FormatMoney(formPvp2 ?? 0)).
                                </p>
                            }
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stock (unidades)</label>
                        <input class="form-input" type="number" step="1" min="0" @bind="formStockUnidades" />
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <input class="form-input" @bind="formNotas" placeholder="Notas internas (opcional)" />
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && toDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar producto</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar <strong>@toDelete.Nombre</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeProductoDto>? productos;
    private bool loading = true;
    private string filtroCategoria = "";
    private string filtroMarca = "";
    private string filtroTexto = "";
    private bool showForm;
    private bool isEditing;
    private bool saving;
    private string? formError;
    private int? editingId;
    private string formNombre = "";
    private string formSku = "";
    private string formBarcode = "";
    private string formCategoria = "CAFE";
    private string formMarca = "";
    private decimal formCosto;
    private decimal? formPvp1;
    private decimal? formPvp2;
    private decimal formIvaPct = 21m;
    private decimal? formBarPct;     // % sobre costo (solo OTROS); null = BAR paga PVP
    private int? formUxB;             // unidades por bulto (solo OTROS)
    /// <summary>UX: el usuario SIEMPRE carga stock de cafe en kg. Internamente guardamos gramos.</summary>
    private decimal formStockKg;
    private int formOemId;            // 0 = sin OEM origen
    private string oemSearch = "";
    private bool oemSearchOpen;
    private decimal formStockGramos;
    private int formStockUnidades;
    private string formNotas = "";
    private bool formIsActive = true;

    // Catalogo de OEMs (cargado una sola vez al abrir la pagina)
    private List<CafeOemDto>? oems;
    /// <summary>Catalogo de marcas (Cafe_Marcas). Alimenta el datalist del form. Se actualiza al refrescar.</summary>
    private List<CafeMarcaDto>? marcasCatalog;

    /// <summary>Marcas existentes (de productos ya cargados), ordenadas alfabéticamente, para el datalist y el filtro.</summary>
    private List<string> marcasExistentes => productos is null
        ? new()
        : productos.Where(p => !string.IsNullOrWhiteSpace(p.Marca))
                   .Select(p => p.Marca!.Trim())
                   .Distinct(StringComparer.OrdinalIgnoreCase)
                   .OrderBy(s => s, StringComparer.OrdinalIgnoreCase)
                   .ToList();

    /// <summary>Lista filtrada por marca + texto (categoría ya viene filtrada del backend).</summary>
    private List<CafeProductoDto> productosVisibles
    {
        get
        {
            if (productos is null) return new();
            IEnumerable<CafeProductoDto> q = productos;
            if (!string.IsNullOrEmpty(filtroMarca))
                q = q.Where(p => string.Equals(p.Marca, filtroMarca, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(filtroTexto))
            {
                var t = filtroTexto.Trim();
                bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
                q = q.Where(p => h(p.Sku) || h(p.Barcode) || h(p.Nombre) || h(p.Marca));
            }
            return q.ToList();
        }
    }
    private bool showDeleteConfirm;
    private CafeProductoDto? toDelete;

    protected override async Task OnInitializedAsync()
    {
        // Cargo OEMs y catalogo de marcas en paralelo a productos
        var loadOems = LoadOems();
        var loadMarcas = LoadMarcasCatalog();
        await Load();
        await loadOems;
        await loadMarcas;
    }

    private async Task LoadMarcasCatalog()
    {
        try { marcasCatalog = await Api.GetCafeMarcasAsync() ?? new(); }
        catch { marcasCatalog = new(); }
    }

    private async Task Load()
    {
        loading = true;
        try
        {
            var cat = string.IsNullOrEmpty(filtroCategoria) ? null : filtroCategoria;
            productos = await Api.GetCafeProductosAsync(cat) ?? new();
        }
        catch { ToastService.Error("Error al cargar productos"); productos = new(); }
        loading = false;
    }

    private async Task LoadOems()
    {
        try { oems = await Api.GetCafeOemsAsync() ?? new(); }
        catch { oems = new(); }
    }

    private IEnumerable<CafeOemDto> OemsMatching(string s)
    {
        if (oems is null) return Enumerable.Empty<CafeOemDto>();
        var t = s.Trim();
        bool h(string? str) => !string.IsNullOrEmpty(str) && str.Contains(t, StringComparison.OrdinalIgnoreCase);
        return oems.Where(o => h(o.Codigo) || h(o.Descripcion) || h(o.Marca) || h(o.Barcode));
    }

    private void SelectOem(int id)
    {
        formOemId = id;
        oemSearch = "";
        oemSearchOpen = false;
        AutocompletarDesdeOem();
    }

    private void ClearOem()
    {
        formOemId = 0;
        oemSearch = "";
    }

    /// <summary>Pisa costo, PVP, UxB y barcode del producto con los del OEM origen.
    /// Lo pueden tocar despues a mano.</summary>
    private void AutocompletarDesdeOem()
    {
        if (formOemId <= 0) return;
        var o = oems?.FirstOrDefault(x => x.Id == formOemId);
        if (o is null) return;
        formCosto = o.Costo;
        // OEM guarda PVP con IVA — convertimos a sin IVA para alinear con la convencion del producto.
        if (o.PvpConIva.HasValue)
        {
            var iva = o.IvaPct ?? 21m;
            formPvp2 = iva > 0 ? Math.Round(o.PvpConIva.Value / (1 + iva / 100m), 2) : o.PvpConIva.Value;
            formIvaPct = iva == 10.5m ? 10.5m : 21m;
        }
        if (o.UxB.HasValue) formUxB = o.UxB.Value;
        if (!string.IsNullOrWhiteSpace(o.Barcode)) formBarcode = o.Barcode;
    }

    private void ShowCreate()
    {
        isEditing = false; editingId = null;
        formNombre = ""; formSku = ""; formBarcode = "";
        formCategoria = "CAFE"; formMarca = "";
        formCosto = 0; formPvp1 = null; formPvp2 = null;
        formIvaPct = 21m;
        formBarPct = 100m; formUxB = null;
        formOemId = 0; oemSearch = ""; oemSearchOpen = false;
        formStockGramos = 0; formStockUnidades = 0;
        formStockKg = 0;
        formNotas = ""; formIsActive = true;
        formError = null; showForm = true;
    }

    private void ShowEdit(CafeProductoDto p)
    {
        isEditing = true; editingId = p.Id;
        formNombre = p.Nombre; formSku = p.Sku ?? ""; formBarcode = p.Barcode ?? "";
        formCategoria = p.Categoria; formMarca = p.Marca ?? "";
        formCosto = p.Costo; formPvp1 = p.Pvp1; formPvp2 = p.Pvp2;
        formIvaPct = p.IvaPct == 10.5m ? 10.5m : 21m;
        formBarPct = p.BarPctSobreCosto;
        formUxB = p.UxB;
        formOemId = p.OemId ?? 0; oemSearch = ""; oemSearchOpen = false;
        formStockGramos = p.StockGramos; formStockUnidades = p.StockUnidades;
        formStockKg = Math.Round(p.StockGramos / 1000m, 3, MidpointRounding.AwayFromZero);
        formNotas = p.Notas ?? ""; formIsActive = p.IsActive;
        formError = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        if (formCosto < 0) { formError = "El costo no puede ser negativo"; return; }
        if (formCategoria == "OTROS")
        {
            if (!formPvp2.HasValue || formPvp2.Value < 0) { formError = "Para OTROS el PVP es obligatorio"; return; }
        }
        saving = true;
        try
        {
            // Para OTROS: si formBarPct tiene valor, lo usamos; si esta vacio, BAR paga lo mismo que OTRO.
            decimal? barPctFinal = null;
            int? uxBFinal = null;
            int? oemIdFinal = null;
            bool clearBarPct = false;
            bool clearUxB = false;
            bool clearOemId = false;
            if (formCategoria == "OTROS")
            {
                barPctFinal = formBarPct;
                clearBarPct = !formBarPct.HasValue;
                uxBFinal = formUxB;
                clearUxB = !formUxB.HasValue;
                oemIdFinal = formOemId > 0 ? formOemId : null;
                clearOemId = formOemId <= 0;
            }
            else
            {
                // CAFE no usa estos campos: vaciarlos siempre.
                clearBarPct = true;
                clearUxB = true;
                clearOemId = true;
            }

            if (isEditing && editingId.HasValue)
            {
                // UX: el usuario carga CAFE en kg → convertimos a gramos para guardar.
                var stockGramosFinal = formCategoria == "CAFE"
                    ? Math.Round(formStockKg * 1000m, 3, MidpointRounding.AwayFromZero)
                    : 0m;
                var u = await Api.UpdateCafeProductoAsync(editingId.Value, new UpdateCafeProductoRequest
                {
                    Sku = formSku, Barcode = formBarcode,
                    Nombre = formNombre, Categoria = formCategoria, Marca = formMarca,
                    Costo = formCosto, Pvp1 = formPvp1, Pvp2 = formPvp2,
                    BarPctSobreCosto = barPctFinal, ClearBarPctSobreCosto = clearBarPct,
                    UxB = uxBFinal, ClearUxB = clearUxB,
                    OemId = oemIdFinal, ClearOemId = clearOemId,
                    StockGramos = stockGramosFinal,
                    StockUnidades = formCategoria == "OTROS" ? formStockUnidades : 0,
                    Notas = formNotas, IsActive = formIsActive,
                    IvaPct = formIvaPct
                });
                if (u is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Producto actualizado");
            }
            else
            {
                var stockGramosFinal = formCategoria == "CAFE"
                    ? Math.Round(formStockKg * 1000m, 3, MidpointRounding.AwayFromZero)
                    : 0m;
                var c = await Api.CreateCafeProductoAsync(new CreateCafeProductoRequest
                {
                    Sku = formSku, Barcode = formBarcode,
                    Nombre = formNombre, Categoria = formCategoria, Marca = formMarca,
                    Costo = formCosto, Pvp1 = formPvp1, Pvp2 = formPvp2,
                    BarPctSobreCosto = barPctFinal,
                    UxB = uxBFinal,
                    OemId = oemIdFinal,
                    StockGramos = stockGramosFinal,
                    StockUnidades = formCategoria == "OTROS" ? formStockUnidades : 0,
                    Notas = formNotas,
                    IvaPct = formIvaPct
                });
                if (c is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Producto creado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private void ConfirmDelete(CafeProductoDto p) { toDelete = p; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (toDelete is null) return;
        try
        {
            var ok = await Api.DeleteCafeProductoAsync(toDelete.Id);
            if (ok) { ToastService.Success("Producto eliminado"); await Load(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; toDelete = null; }
    }

    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    /// <summary>UX: siempre mostramos stock de cafe en kg con 2 decimales (regla del usuario).
    /// Internamente almacenamos en gramos pero NO se exponen al usuario.</summary>
    private static string FormatGramos(decimal g)
        => $"{(g / 1000m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))} kg";
}
