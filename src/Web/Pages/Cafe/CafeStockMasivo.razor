@page "/cafe/stock-masivo"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject HttpClient Http
@inject NavigationManager Nav

@* === Bloque QR superior ===
   2 entradas mobile (pedido del usuario 2026-05-25):
   - Stock móvil: QR fijo, siempre visible, para carga rápida diaria desde el celular.
   - Auditoría: QR desplegable (oculto por default), abre el mismo link pero en modo audit
     (=conteo masivo del depósito, marca productos ya stockeados para no repetir).
*@
<div class="card" style="margin-bottom:0.8rem;">
    <div class="card-body" style="padding:1rem;">
        <div style="display:flex; gap:1rem; align-items:flex-start; flex-wrap:wrap;">
            <div style="display:flex; gap:0.8rem; align-items:center; flex:1; min-width:280px;">
                <img src="@QrMovilUrl" alt="QR Stock móvil" style="width:120px; height:120px; border:2px solid #1d4ed8; border-radius:8px; padding:4px; background:white;" />
                <div>
                    <h4 style="margin:0 0 0.3rem; color:#1f2937;">📱 Stock móvil</h4>
                    <p style="margin:0 0 0.5rem; font-size:0.85rem; color:#6b7280;">Escaneá con el celular para cargar stock de a uno (ajustes diarios, roturas, recepciones).</p>
                    <a href="@LinkMovil" target="_blank" class="btn btn-secondary" style="font-size:0.78rem; padding:0.3rem 0.6rem;">Abrir en pestaña nueva ↗</a>
                </div>
            </div>
            <div style="flex:1; min-width:280px; border-left:1px solid #e5e7eb; padding-left:1rem;">
                <button class="btn @(showAuditoriaQr ? "btn-warning" : "btn-secondary")" style="font-size:0.85rem;"
                        @onclick="() => showAuditoriaQr = !showAuditoriaQr">
                    @(showAuditoriaQr ? "▼ Ocultar QR Auditoría" : "▶ Mostrar QR Auditoría (conteo masivo)")
                </button>
                @if (showAuditoriaQr)
                {
                    <div style="display:flex; gap:0.8rem; align-items:center; margin-top:0.7rem;">
                        <img src="@QrAuditoriaUrl" alt="QR Auditoría stock" style="width:120px; height:120px; border:2px solid #b45309; border-radius:8px; padding:4px; background:white;" />
                        <div>
                            <h4 style="margin:0 0 0.3rem; color:#b45309;">📋 Modo auditoría</h4>
                            <p style="margin:0 0 0.5rem; font-size:0.82rem; color:#6b7280;">Recorré el depósito marcando lo contado. Los que ya stockeaste se ven en verde, los pendientes en gris. Ideal para inventario mensual.</p>
                            <a href="@LinkAuditoria" target="_blank" class="btn btn-warning" style="font-size:0.78rem; padding:0.3rem 0.6rem;">Abrir auditoría ↗</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* 2026-06-02: Toggle de modo. Por default arranca en "Cargar pedido" (estilo Contabilium)
   que es la forma rapida de cargar mercaderia: buscar, sumar, agregar, guardar todo junto.
   "Lista completa" es la vista clasica (editar uno por uno en la lista entera). *@
<div class="card" style="margin-bottom:0.8rem;">
    <div class="card-body" style="padding:0.6rem 1rem; display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
        <strong style="font-size:0.85rem; color:#374151;">Modo:</strong>
        <button class="@(modoCarga == "pedido" ? "btn btn-primary" : "btn btn-secondary")" style="font-size:0.85rem;"
                @onclick='() => modoCarga = "pedido"'>🛒 Cargar pedido (rápido)</button>
        <button class="@(modoCarga == "lista" ? "btn btn-primary" : "btn btn-secondary")" style="font-size:0.85rem;"
                @onclick='() => modoCarga = "lista"'>📋 Lista completa</button>
        <span style="font-size:0.78rem; color:#6b7280; margin-left:0.5rem;">
            @(modoCarga == "pedido"
                ? "Buscás producto → sumás cantidad → agregás a la lista → al final 1 click guarda todo."
                : "Ves toda la lista de productos del depósito y editás stock final de cada uno.")
        </span>
    </div>
</div>

@if (modoCarga == "pedido")
{
    @* === Vista: Cargar pedido (estilo Contabilium) === *@
    <div class="card" style="margin-bottom:0.8rem;">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
            <h3 style="margin:0;">🛒 Cargar pedido — agregá productos uno por uno</h3>
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <label style="font-size:0.85rem;">Depósito:</label>
                <select class="form-input" style="width:auto;" @bind="depositoIdSeleccionado" @bind:after="CambiarDepositoCarrito">
                    @if (depositos is not null)
                    {
                        @foreach (var d in depositos.Where(x => x.IsActive).OrderBy(x => x.Orden))
                        {
                            <option value="@d.Id">@d.Nombre</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="card-body" style="padding:1rem;">
            @if (EsDepositoFull)
            {
                <div style="background:#fef3c7; border-left:4px solid #d97706; padding:0.7rem; border-radius:6px;">
                    ⚠ El depósito <b>Full MeLi</b> es solo lectura — se sincroniza desde MeLi. Cambiá de depósito para cargar pedido.
                </div>
            }
            else
            {
                @* Formulario: buscar + modo + cantidad + agregar *@
                <div style="display:flex; gap:0.6rem; align-items:flex-end; flex-wrap:wrap; margin-bottom:0.8rem;">
                    <div style="flex:2; min-width:280px; position:relative;">
                        <label class="form-label" style="font-size:0.78rem; font-weight:600;">🔍 Producto (código o nombre)</label>
                        <input class="form-input" placeholder="Ej: C949NEG o cesto negro..." @bind="cargaSearch" @bind:event="oninput"
                               @onfocus="() => cargaSearchOpen = true"
                               @onkeydown="OnKeyDownBuscadorCarga" />
                        @if (cargaSearchOpen && !string.IsNullOrWhiteSpace(cargaSearch))
                        {
                            var matches = ProductosMatchingCarga(cargaSearch).Take(15).ToList();
                            <div style="position:absolute; top:100%; left:0; right:0; background:white; border:1px solid #d1d5db; border-radius:6px; max-height:300px; overflow-y:auto; z-index:100; box-shadow:0 4px 14px rgba(0,0,0,0.12); margin-top:0.2rem;">
                                @if (matches.Count == 0)
                                {
                                    <div style="padding:0.6rem; color:#6b7280; font-size:0.85rem;">Sin resultados.</div>
                                }
                                else
                                {
                                    @foreach (var p in matches)
                                    {
                                        var pid = p.ProductoId;
                                        var stockTxt = p.Categoria == "CAFE" ? $"{(p.StockGramos/1000m):N2} kg" : $"{p.StockUnidades} u.";
                                        <div @onclick="() => SeleccionarProductoCarga(pid)"
                                             style="padding:0.5rem 0.7rem; cursor:pointer; border-bottom:1px solid #f3f4f6;">
                                            <span style="font-family:monospace; color:#1d4ed8; font-weight:700; font-size:0.85rem;">@p.Codigo</span>
                                            <strong style="margin-left:0.4rem;">@p.Nombre</strong>
                                            <span style="color:#6b7280; font-size:0.78rem; margin-left:0.4rem;">· Stock actual: @stockTxt</span>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                    <div>
                        <label class="form-label" style="font-size:0.78rem; font-weight:600;">Modo</label>
                        <div style="display:flex; gap:0.3rem;">
                            <label style="display:flex; align-items:center; gap:0.2rem; cursor:pointer; padding:0.35rem 0.6rem; border:1px solid #d1d5db; border-radius:6px; background:@(cargaModo == "modificar" ? "#dbeafe" : "white"); font-size:0.85rem;">
                                <input type="radio" name="cargaModo" checked="@(cargaModo == "modificar")" @onchange='() => cargaModo = "modificar"' />
                                <span>➕ Sumar/Restar</span>
                            </label>
                            <label style="display:flex; align-items:center; gap:0.2rem; cursor:pointer; padding:0.35rem 0.6rem; border:1px solid #d1d5db; border-radius:6px; background:@(cargaModo == "reemplazar" ? "#dbeafe" : "white"); font-size:0.85rem;">
                                <input type="radio" name="cargaModo" checked="@(cargaModo == "reemplazar")" @onchange='() => cargaModo = "reemplazar"' />
                                <span>🎯 Reemplazar</span>
                            </label>
                        </div>
                    </div>
                    <div>
                        <label class="form-label" style="font-size:0.78rem; font-weight:600;">Stock actual</label>
                        <input class="form-input" readonly value="@cargaStockActualTxt" style="width:100px; background:#f9fafb; text-align:right;" />
                    </div>
                    <div>
                        <label class="form-label" style="font-size:0.78rem; font-weight:600;">@(cargaModo == "modificar" ? "Cantidad (+/−)" : "Stock final")</label>
                        <input class="form-input" type="number" step="@(cargaProdSel?.Categoria == "CAFE" ? "0.001" : "1")"
                               @bind="cargaValor" style="width:130px; text-align:right; font-weight:700;"
                               @onkeydown="OnKeyDownCantidad"
                               disabled="@(cargaProdSel is null)" />
                    </div>
                    <button class="btn btn-primary" @onclick="AgregarAlCarrito" disabled="@(cargaProdSel is null || cargaValor == 0)">
                        ➕ Agregar a la lista
                    </button>
                </div>

                @* Carrito acumulado *@
                @if (carrito.Count == 0)
                {
                    <div style="padding:1.5rem; text-align:center; color:#6b7280; background:#f9fafb; border-radius:8px;">
                        Sin productos en la lista. Buscá uno arriba y agregalo.
                    </div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table class="table table-compact" style="width:100%;">
                            <thead style="background:#f3f4f6;">
                                <tr>
                                    <th style="width:40px;">#</th>
                                    <th style="width:100px;">Código</th>
                                    <th>Producto</th>
                                    <th style="width:120px;">Tipo</th>
                                    <th style="width:110px; text-align:right;">Valor</th>
                                    <th style="width:110px; text-align:right;">Stock actual</th>
                                    <th style="width:110px; text-align:right;">Stock nuevo</th>
                                    <th style="width:60px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int idx = 0; }
                                @foreach (var c in carrito)
                                {
                                    idx++;
                                    var unidad = c.Categoria == "CAFE" ? "kg" : "u.";
                                    var stockActualMostrar = c.Categoria == "CAFE" ? (c.StockActualG/1000m).ToString("N3") : c.StockActualU.ToString();
                                    var stockNuevoMostrar = c.Categoria == "CAFE" ? (c.StockNuevoG/1000m).ToString("N3") : c.StockNuevoU.ToString();
                                    var valorMostrar = c.Modo == "modificar"
                                        ? (c.ValorIngresado >= 0 ? "+" : "") + c.ValorIngresado.ToString(c.Categoria == "CAFE" ? "N3" : "0")
                                        : c.ValorIngresado.ToString(c.Categoria == "CAFE" ? "N3" : "0");
                                    <tr>
                                        <td style="color:#6b7280;">@idx</td>
                                        <td style="font-family:monospace; font-size:0.82rem;">@c.Codigo</td>
                                        <td><strong>@c.Nombre</strong></td>
                                        <td>
                                            <span style="background:@(c.Modo == "modificar" ? "#dbeafe" : "#fef3c7"); color:@(c.Modo == "modificar" ? "#1e40af" : "#92400e"); padding:0.15rem 0.4rem; border-radius:4px; font-size:0.78rem; font-weight:700;">
                                                @(c.Modo == "modificar" ? "MODIFICAR" : "REEMPLAZAR")
                                            </span>
                                        </td>
                                        <td style="text-align:right; font-family:monospace; font-weight:700; color:@(c.Modo == "modificar" && c.ValorIngresado < 0 ? "#b91c1c" : "#1f2937");">
                                            @valorMostrar @unidad
                                        </td>
                                        <td style="text-align:right; color:#6b7280;">@stockActualMostrar @unidad</td>
                                        <td style="text-align:right; font-weight:700; color:#15803d;">@stockNuevoMostrar @unidad</td>
                                        <td>
                                            <button @onclick="() => carrito.Remove(c)" style="background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5; border-radius:4px; padding:0.2rem 0.5rem; cursor:pointer; font-size:0.85rem;" title="Quitar">🗑</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1rem; padding-top:1rem; border-top:2px solid #e5e7eb;">
                        <div style="font-size:0.95rem;">
                            <strong>@carrito.Count</strong> productos en la lista
                        </div>
                        <div style="display:flex; gap:0.5rem;">
                            <button class="btn btn-secondary" @onclick="() => carrito.Clear()" disabled="@guardando">🗑 Vaciar lista</button>
                            <button class="btn btn-primary" style="font-size:1rem; padding:0.6rem 1.2rem;" @onclick="GuardarCarrito" disabled="@guardando">
                                @(guardando ? "Guardando..." : $"💾 Guardar {carrito.Count} cambios")
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}
else
{
<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3 style="margin:0;">📊 Stock masivo</h3>
        <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
            <label style="font-size:0.85rem;">Depósito:</label>
            <select class="form-input" style="width:auto;" @bind="depositoIdSeleccionado" @bind:after="CambiarDeposito">
                @if (depositos is not null)
                {
                    @foreach (var d in depositos.Where(x => x.IsActive).OrderBy(x => x.Orden))
                    {
                        <option value="@d.Id">@d.Nombre</option>
                    }
                }
            </select>
            <input class="form-input" style="width:240px;" placeholder="🔍 Buscar producto..."
                   @bind="filtroTexto" @bind:event="oninput" />
            <select class="form-input" style="width:auto;" @bind="filtroCategoria">
                <option value="">Todas</option>
                <option value="CAFE">CAFE</option>
                <option value="OTROS">OTROS</option>
            </select>
            <button class="btn btn-primary" @onclick="Guardar" disabled="@(!HayCambios || guardando || EsDepositoFull)">
                @(guardando ? "..." : EsDepositoFull ? "(solo lectura)" : $"💾 Guardar {CountCambios} cambios")
            </button>
            @if (EsDepositoFull)
            {
                <button class="btn btn-warning" @onclick="SincronizarFullAhora" disabled="@sincronizandoFull"
                        title="Trae stock de Full desde MeLi (todas las publicaciones Full linkeadas)">
                    @(sincronizandoFull ? "Sincronizando..." : "🔄 Sincronizar Full desde MeLi")
                </button>
            }
            <a href="/stock" class="btn btn-secondary" title="Operadores + Auditorías + historial de cargas móviles"
               style="background:#1f2937; color:white; border:none;">
                📋 Operadores y auditorías
            </a>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        @if (loading) { <p class="text-muted" style="padding:1rem;">Cargando...</p> }
        else if (rows is null || rows.Count == 0)
        {
            <p class="text-muted" style="padding:1rem;">Sin productos.</p>
        }
        else
        {
            <div style="max-height: 70vh; overflow-y:auto;">
                <table class="table table-compact">
                    <thead style="position:sticky; top:0; background:#f3f4f6; z-index:1;">
                        <tr>
                            <th style="width:90px;">Código</th>
                            <th>Producto</th>
                            <th style="width:80px;">Cat.</th>
                            <th style="text-align:right; width:130px;">Stock actual</th>
                            <th style="text-align:right; width:200px;">
                                <span style="display:inline-flex; align-items:center; gap:0.3rem; justify-content:flex-end;">
                                    @(EsDepositoFull ? "Stock Full (solo lectura)" : "Stock nuevo")
                                    @if (!EsDepositoFull)
                                    {
                                        <button @onclick="() => edicionHabilitada = !edicionHabilitada"
                                                title="@(edicionHabilitada ? "Bloquear edición" : "Desbloquear para editar")"
                                                style="background:@(edicionHabilitada ? "#fef3c7" : "#f3f4f6"); border:1px solid #d1d5db; border-radius:4px; padding:0.1rem 0.4rem; cursor:pointer; font-size:0.85rem;">
                                            @(edicionHabilitada ? "🔓" : "🔒")
                                        </button>
                                    }
                                    else
                                    {
                                        <span title="Este depósito se sincroniza desde MeLi automáticamente" style="font-size:0.85rem;">🔒</span>
                                    }
                                </span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Filtrados())
                        {
                            var modificado = HaModificado(r);
                            <tr style="@(modificado ? "background:#fef3c7;" : "")">
                                <td style="font-family:monospace; font-size:0.78rem;">@r.Codigo</td>
                                <td><b>@r.Nombre</b></td>
                                <td><span class="badge badge-secondary" style="font-size:0.7rem;">@r.Categoria</span></td>
                                <td style="text-align:right;">
                                    @if (r.Categoria == "CAFE")
                                    {
                                        <span>@((r.StockGramos/1000m).ToString("N2")) kg</span>
                                    }
                                    else
                                    {
                                        <span>@r.StockUnidades u.</span>
                                    }
                                </td>
                                <td style="text-align:right;">
                                    @if (r.Categoria == "CAFE")
                                    {
                                        var kgNuevo = nuevoStockKg.TryGetValue(r.ProductoId, out var kg) ? kg : Math.Round(r.StockGramos / 1000m, 3);
                                        <input class="form-input" type="number" step="0.001" style="width:120px; text-align:right; display:inline-block; @(edicionHabilitada ? "" : "background:#f9fafb; color:#9ca3af;")"
                                               value="@kgNuevo"
                                               disabled="@(!edicionHabilitada)"
                                               @onchange="@(e => OnStockKgChange(r.ProductoId, e.Value?.ToString()))" /> <span style="font-size:0.78rem;">kg</span>
                                    }
                                    else
                                    {
                                        var uNuevo = nuevoStockUnidades.TryGetValue(r.ProductoId, out var u) ? u : r.StockUnidades;
                                        <input class="form-input" type="number" step="1" style="width:120px; text-align:right; display:inline-block; @(edicionHabilitada ? "" : "background:#f9fafb; color:#9ca3af;")"
                                               value="@uNuevo"
                                               disabled="@(!edicionHabilitada)"
                                               @onchange="@(e => OnStockUnidadesChange(r.ProductoId, e.Value?.ToString()))" /> <span style="font-size:0.78rem;">u.</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

}

@code {
    private List<CafeDepositoDto>? depositos;
    private List<StockProductoDto>? rows;
    private bool loading = true;
    private bool guardando;
    private bool edicionHabilitada = false;
    private int depositoIdSeleccionado;
    private string filtroTexto = "";
    private string filtroCategoria = "";
    // Cambios pendientes: solo se guardan en estos diccionarios hasta que toques "Guardar"
    private Dictionary<int, decimal> nuevoStockKg = new();
    private Dictionary<int, int> nuevoStockUnidades = new();

    // ─── 2026-06-02: Modo "Cargar pedido" estilo Contabilium ───
    private string modoCarga = "pedido"; // "pedido" | "lista"
    private string cargaSearch = "";
    private bool cargaSearchOpen = false;
    private string cargaModo = "modificar"; // "modificar" (sumar/restar) | "reemplazar" (stock final)
    private decimal cargaValor;
    private StockProductoDto? cargaProdSel;
    private string cargaStockActualTxt = "—";
    private List<CarritoItem> carrito = new();

    public class CarritoItem
    {
        public int ProductoId { get; set; }
        public string Codigo { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string Categoria { get; set; } = "";
        public string Modo { get; set; } = "modificar";  // modificar | reemplazar
        public decimal ValorIngresado { get; set; }     // lo que escribio el usuario (con signo)
        public decimal StockActualG { get; set; }
        public int StockActualU { get; set; }
        public decimal StockNuevoG { get; set; }
        public int StockNuevoU { get; set; }
    }

    private IEnumerable<StockProductoDto> ProductosMatchingCarga(string q)
    {
        if (rows is null) return Enumerable.Empty<StockProductoDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return rows.Take(10);
        return rows.Where(r =>
            (r.Codigo?.Contains(t, StringComparison.OrdinalIgnoreCase) ?? false)
            || r.Nombre.Contains(t, StringComparison.OrdinalIgnoreCase));
    }

    private void SeleccionarProductoCarga(int productoId)
    {
        var p = rows?.FirstOrDefault(r => r.ProductoId == productoId);
        if (p is null) return;
        cargaProdSel = p;
        cargaSearch = $"{p.Codigo} — {p.Nombre}";
        cargaSearchOpen = false;
        cargaStockActualTxt = p.Categoria == "CAFE"
            ? $"{(p.StockGramos/1000m):N3} kg"
            : $"{p.StockUnidades} u.";
        cargaValor = 0;
    }

    private async Task CambiarDepositoCarrito()
    {
        // al cambiar de depósito, vaciamos carrito (para no aplicar cambios al deposito equivocado)
        if (carrito.Count > 0)
        {
            ToastService.Info($"Lista de {carrito.Count} productos vaciada al cambiar de depósito");
            carrito.Clear();
        }
        cargaProdSel = null; cargaSearch = ""; cargaStockActualTxt = "—"; cargaValor = 0;
        await CargarStock();
    }

    private void OnKeyDownBuscadorCarga(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Auto-seleccionar el primer match si solo hay 1
            var matches = ProductosMatchingCarga(cargaSearch).Take(2).ToList();
            if (matches.Count == 1) SeleccionarProductoCarga(matches[0].ProductoId);
        }
        else if (e.Key == "Escape")
        {
            cargaSearchOpen = false;
        }
    }

    private void OnKeyDownCantidad(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AgregarAlCarrito();
    }

    private void AgregarAlCarrito()
    {
        if (cargaProdSel is null || cargaValor == 0) return;
        var p = cargaProdSel;
        decimal nuevoG = p.StockGramos;
        int nuevoU = p.StockUnidades;
        if (cargaModo == "modificar")
        {
            if (p.Categoria == "CAFE") nuevoG = Math.Max(0m, p.StockGramos + cargaValor * 1000m);
            else nuevoU = Math.Max(0, p.StockUnidades + (int)cargaValor);
        }
        else // reemplazar
        {
            if (p.Categoria == "CAFE") nuevoG = Math.Max(0m, cargaValor * 1000m);
            else nuevoU = Math.Max(0, (int)cargaValor);
        }
        // Si el producto ya estaba en el carrito, lo quitamos y reemplazamos por la entrada nueva
        // (asi siempre vemos el ultimo cambio del usuario, no se acumulan duplicados).
        var existente = carrito.FirstOrDefault(c => c.ProductoId == p.ProductoId);
        if (existente is not null) carrito.Remove(existente);
        carrito.Add(new CarritoItem
        {
            ProductoId = p.ProductoId,
            Codigo = p.Codigo ?? "",
            Nombre = p.Nombre,
            Categoria = p.Categoria,
            Modo = cargaModo,
            ValorIngresado = cargaValor,
            StockActualG = p.StockGramos,
            StockActualU = p.StockUnidades,
            StockNuevoG = nuevoG,
            StockNuevoU = nuevoU
        });
        // Reset para el siguiente producto. El foco vuelve al buscador automáticamente al borrar.
        cargaProdSel = null;
        cargaSearch = "";
        cargaStockActualTxt = "—";
        cargaValor = 0;
    }

    private async Task GuardarCarrito()
    {
        if (carrito.Count == 0) { ToastService.Info("Sin productos en la lista"); return; }
        guardando = true;
        try
        {
            var items = carrito.Select(c => new ApiClient.StockMasivoItemReq(c.ProductoId, c.StockNuevoG, c.StockNuevoU)).ToList();
            await Api.ActualizarStockMasivoAsync(depositoIdSeleccionado, items);
            ToastService.Success($"✓ {carrito.Count} productos actualizados. Push a MeLi disparado automático.");
            carrito.Clear();
            await CargarStock();
        }
        catch (Exception ex) { ToastService.Error("Error al guardar: " + ex.Message); }
        finally { guardando = false; }
    }

    [Parameter, SupplyParameterFromQuery(Name = "dep")] public int? PreDepositoId { get; set; }

    // === Detectar depósito Full (solo lectura, se sincroniza desde MeLi) ===
    private bool EsDepositoFull => depositos?.FirstOrDefault(d => d.Id == depositoIdSeleccionado)?.Nombre == "Full MeLi";
    private bool sincronizandoFull = false;

    // === Bloque QR (token + URLs derivadas) ===
    private string token = "";
    private bool showAuditoriaQr = false;
    private string Origin => new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);
    private string LinkMovil => string.IsNullOrEmpty(token) ? "#" : $"{Origin}/stock/{token}";
    private string LinkAuditoria => string.IsNullOrEmpty(token) ? "#" : $"{Origin}/stock/{token}?modo=auditoria";
    private string QrMovilUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(LinkMovil)}";
    private string QrAuditoriaUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(LinkAuditoria)}";

    private int CountCambios =>
        rows is null ? 0 :
        rows.Count(r => HaModificado(r));

    private bool HayCambios => CountCambios > 0;

    protected override async Task OnInitializedAsync()
    {
        depositos = await Api.GetCafeDepositosAsync() ?? new();
        depositoIdSeleccionado = PreDepositoId
            ?? depositos.FirstOrDefault(d => d.IsDefault)?.Id
            ?? depositos.FirstOrDefault()?.Id ?? 0;
        // Cargar token del link público de stock (para los QR del header)
        try
        {
            var tk = await Http.GetFromJsonAsync<TokenDto>("api/stock/admin/token");
            token = tk?.token ?? "";
        }
        catch { token = ""; }
        await CargarStock();
    }

    private record TokenDto(string token);

    private async Task CambiarDeposito()
    {
        nuevoStockKg = new(); nuevoStockUnidades = new();
        await CargarStock();
    }

    private async Task CargarStock()
    {
        if (depositoIdSeleccionado <= 0) { rows = new(); loading = false; return; }
        loading = true;
        try { rows = await Api.GetStockEnDepositoAsync(depositoIdSeleccionado) ?? new(); }
        catch { ToastService.Error("Error al cargar"); rows = new(); }
        loading = false;
    }

    private IEnumerable<StockProductoDto> Filtrados()
    {
        if (rows is null) return Enumerable.Empty<StockProductoDto>();
        var t = filtroTexto?.Trim() ?? "";
        return rows.Where(r =>
            (string.IsNullOrEmpty(filtroCategoria) || r.Categoria == filtroCategoria) &&
            (string.IsNullOrEmpty(t)
                || (r.Codigo?.Contains(t, StringComparison.OrdinalIgnoreCase) ?? false)
                || r.Nombre.Contains(t, StringComparison.OrdinalIgnoreCase)));
    }

    private bool HaModificado(StockProductoDto r)
    {
        if (r.Categoria == "CAFE")
        {
            if (!nuevoStockKg.TryGetValue(r.ProductoId, out var kg)) return false;
            return Math.Abs(kg * 1000m - r.StockGramos) > 0.001m;
        }
        else
        {
            if (!nuevoStockUnidades.TryGetValue(r.ProductoId, out var u)) return false;
            return u != r.StockUnidades;
        }
    }

    private void OnStockKgChange(int productoId, string? value)
    {
        if (!decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var kg))
            decimal.TryParse(value, out kg);
        nuevoStockKg[productoId] = kg;
    }

    private void OnStockUnidadesChange(int productoId, string? value)
    {
        int.TryParse(value, out var u);
        nuevoStockUnidades[productoId] = u;
    }

    private async Task Guardar()
    {
        if (rows is null) return;
        var items = new List<ApiClient.StockMasivoItemReq>();
        foreach (var r in rows)
        {
            if (!HaModificado(r)) continue;
            decimal stockG = r.Categoria == "CAFE"
                ? (nuevoStockKg.TryGetValue(r.ProductoId, out var kg) ? kg * 1000m : r.StockGramos)
                : r.StockGramos;
            int stockU = r.Categoria == "CAFE"
                ? r.StockUnidades
                : (nuevoStockUnidades.TryGetValue(r.ProductoId, out var u) ? u : r.StockUnidades);
            items.Add(new ApiClient.StockMasivoItemReq(r.ProductoId, stockG, stockU));
        }
        if (items.Count == 0) { ToastService.Info("Sin cambios"); return; }

        guardando = true;
        try
        {
            await Api.ActualizarStockMasivoAsync(depositoIdSeleccionado, items);
            ToastService.Success($"Stock actualizado en {items.Count} productos");
            nuevoStockKg = new(); nuevoStockUnidades = new();
            await CargarStock();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { guardando = false; }
    }

    /// <summary>Dispara el sync de stock Full desde MeLi (lee meli_facility de todos los UPGs
    /// linkeados y los guarda en Cafe_StockPorDeposito[Full MeLi]).</summary>
    private async Task SincronizarFullAhora()
    {
        sincronizandoFull = true;
        try
        {
            var resp = await Http.PostAsync("/api/meli/full-stock-sync", null);
            if (resp.IsSuccessStatusCode)
            {
                var r = await resp.Content.ReadFromJsonAsync<FullSyncResp>();
                ToastService.Success($"✓ Full sync: {r?.upgsConFull} pubs Full · {r?.productosActualizados} productos actualizados");
                if (EsDepositoFull) await CargarStock();
            }
            else { ToastService.Error("Error al sincronizar Full"); }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { sincronizandoFull = false; }
    }

    private record FullSyncResp(int upgsProcesados, int upgsConFull, int productosActualizados, int errores);
}
