@page "/cafe/stock-masivo"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject HttpClient Http
@inject NavigationManager Nav

@* === Bloque QR superior ===
   2 entradas mobile (pedido del usuario 2026-05-25):
   - Stock móvil: QR fijo, siempre visible, para carga rápida diaria desde el celular.
   - Auditoría: QR desplegable (oculto por default), abre el mismo link pero en modo audit
     (=conteo masivo del depósito, marca productos ya stockeados para no repetir).
*@
<div class="card" style="margin-bottom:0.8rem;">
    <div class="card-body" style="padding:1rem;">
        <div style="display:flex; gap:1rem; align-items:flex-start; flex-wrap:wrap;">
            <div style="display:flex; gap:0.8rem; align-items:center; flex:1; min-width:280px;">
                <img src="@QrMovilUrl" alt="QR Stock móvil" style="width:120px; height:120px; border:2px solid #1d4ed8; border-radius:8px; padding:4px; background:white;" />
                <div>
                    <h4 style="margin:0 0 0.3rem; color:#1f2937;">📱 Stock móvil</h4>
                    <p style="margin:0 0 0.5rem; font-size:0.85rem; color:#6b7280;">Escaneá con el celular para cargar stock de a uno (ajustes diarios, roturas, recepciones).</p>
                    <a href="@LinkMovil" target="_blank" class="btn btn-secondary" style="font-size:0.78rem; padding:0.3rem 0.6rem;">Abrir en pestaña nueva ↗</a>
                </div>
            </div>
            <div style="flex:1; min-width:280px; border-left:1px solid #e5e7eb; padding-left:1rem;">
                <button class="btn @(showAuditoriaQr ? "btn-warning" : "btn-secondary")" style="font-size:0.85rem;"
                        @onclick="() => showAuditoriaQr = !showAuditoriaQr">
                    @(showAuditoriaQr ? "▼ Ocultar QR Auditoría" : "▶ Mostrar QR Auditoría (conteo masivo)")
                </button>
                @if (showAuditoriaQr)
                {
                    <div style="display:flex; gap:0.8rem; align-items:center; margin-top:0.7rem;">
                        <img src="@QrAuditoriaUrl" alt="QR Auditoría stock" style="width:120px; height:120px; border:2px solid #b45309; border-radius:8px; padding:4px; background:white;" />
                        <div>
                            <h4 style="margin:0 0 0.3rem; color:#b45309;">📋 Modo auditoría</h4>
                            <p style="margin:0 0 0.5rem; font-size:0.82rem; color:#6b7280;">Recorré el depósito marcando lo contado. Los que ya stockeaste se ven en verde, los pendientes en gris. Ideal para inventario mensual.</p>
                            <a href="@LinkAuditoria" target="_blank" class="btn btn-warning" style="font-size:0.78rem; padding:0.3rem 0.6rem;">Abrir auditoría ↗</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3 style="margin:0;">📊 Stock masivo</h3>
        <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
            <label style="font-size:0.85rem;">Depósito:</label>
            <select class="form-input" style="width:auto;" @bind="depositoIdSeleccionado" @bind:after="CambiarDeposito">
                @if (depositos is not null)
                {
                    @foreach (var d in depositos.Where(x => x.IsActive).OrderBy(x => x.Orden))
                    {
                        <option value="@d.Id">@d.Nombre</option>
                    }
                }
            </select>
            <input class="form-input" style="width:240px;" placeholder="🔍 Buscar producto..."
                   @bind="filtroTexto" @bind:event="oninput" />
            <select class="form-input" style="width:auto;" @bind="filtroCategoria">
                <option value="">Todas</option>
                <option value="CAFE">CAFE</option>
                <option value="OTROS">OTROS</option>
            </select>
            <button class="btn btn-primary" @onclick="Guardar" disabled="@(!HayCambios || guardando || EsDepositoFull)">
                @(guardando ? "..." : EsDepositoFull ? "(solo lectura)" : $"💾 Guardar {CountCambios} cambios")
            </button>
            @if (EsDepositoFull)
            {
                <button class="btn btn-warning" @onclick="SincronizarFullAhora" disabled="@sincronizandoFull"
                        title="Trae stock de Full desde MeLi (todas las publicaciones Full linkeadas)">
                    @(sincronizandoFull ? "Sincronizando..." : "🔄 Sincronizar Full desde MeLi")
                </button>
            }
            <a href="/stock" class="btn btn-secondary" title="Operadores + Auditorías + historial de cargas móviles"
               style="background:#1f2937; color:white; border:none;">
                📋 Operadores y auditorías
            </a>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        @if (loading) { <p class="text-muted" style="padding:1rem;">Cargando...</p> }
        else if (rows is null || rows.Count == 0)
        {
            <p class="text-muted" style="padding:1rem;">Sin productos.</p>
        }
        else
        {
            <div style="max-height: 70vh; overflow-y:auto;">
                <table class="table table-compact">
                    <thead style="position:sticky; top:0; background:#f3f4f6; z-index:1;">
                        <tr>
                            <th style="width:90px;">Código</th>
                            <th>Producto</th>
                            <th style="width:80px;">Cat.</th>
                            <th style="text-align:right; width:130px;">Stock actual</th>
                            <th style="text-align:right; width:200px;">
                                <span style="display:inline-flex; align-items:center; gap:0.3rem; justify-content:flex-end;">
                                    @(EsDepositoFull ? "Stock Full (solo lectura)" : "Stock nuevo")
                                    @if (!EsDepositoFull)
                                    {
                                        <button @onclick="() => edicionHabilitada = !edicionHabilitada"
                                                title="@(edicionHabilitada ? "Bloquear edición" : "Desbloquear para editar")"
                                                style="background:@(edicionHabilitada ? "#fef3c7" : "#f3f4f6"); border:1px solid #d1d5db; border-radius:4px; padding:0.1rem 0.4rem; cursor:pointer; font-size:0.85rem;">
                                            @(edicionHabilitada ? "🔓" : "🔒")
                                        </button>
                                    }
                                    else
                                    {
                                        <span title="Este depósito se sincroniza desde MeLi automáticamente" style="font-size:0.85rem;">🔒</span>
                                    }
                                </span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Filtrados())
                        {
                            var modificado = HaModificado(r);
                            <tr style="@(modificado ? "background:#fef3c7;" : "")">
                                <td style="font-family:monospace; font-size:0.78rem;">@r.Codigo</td>
                                <td><b>@r.Nombre</b></td>
                                <td><span class="badge badge-secondary" style="font-size:0.7rem;">@r.Categoria</span></td>
                                <td style="text-align:right;">
                                    @if (r.Categoria == "CAFE")
                                    {
                                        <span>@((r.StockGramos/1000m).ToString("N2")) kg</span>
                                    }
                                    else
                                    {
                                        <span>@r.StockUnidades u.</span>
                                    }
                                </td>
                                <td style="text-align:right;">
                                    @if (r.Categoria == "CAFE")
                                    {
                                        var kgNuevo = nuevoStockKg.TryGetValue(r.ProductoId, out var kg) ? kg : Math.Round(r.StockGramos / 1000m, 3);
                                        <input class="form-input" type="number" step="0.001" style="width:120px; text-align:right; display:inline-block; @(edicionHabilitada ? "" : "background:#f9fafb; color:#9ca3af;")"
                                               value="@kgNuevo"
                                               disabled="@(!edicionHabilitada)"
                                               @onchange="@(e => OnStockKgChange(r.ProductoId, e.Value?.ToString()))" /> <span style="font-size:0.78rem;">kg</span>
                                    }
                                    else
                                    {
                                        var uNuevo = nuevoStockUnidades.TryGetValue(r.ProductoId, out var u) ? u : r.StockUnidades;
                                        <input class="form-input" type="number" step="1" style="width:120px; text-align:right; display:inline-block; @(edicionHabilitada ? "" : "background:#f9fafb; color:#9ca3af;")"
                                               value="@uNuevo"
                                               disabled="@(!edicionHabilitada)"
                                               @onchange="@(e => OnStockUnidadesChange(r.ProductoId, e.Value?.ToString()))" /> <span style="font-size:0.78rem;">u.</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<CafeDepositoDto>? depositos;
    private List<StockProductoDto>? rows;
    private bool loading = true;
    private bool guardando;
    private bool edicionHabilitada = false;
    private int depositoIdSeleccionado;
    private string filtroTexto = "";
    private string filtroCategoria = "";
    // Cambios pendientes: solo se guardan en estos diccionarios hasta que toques "Guardar"
    private Dictionary<int, decimal> nuevoStockKg = new();
    private Dictionary<int, int> nuevoStockUnidades = new();

    [Parameter, SupplyParameterFromQuery(Name = "dep")] public int? PreDepositoId { get; set; }

    // === Detectar depósito Full (solo lectura, se sincroniza desde MeLi) ===
    private bool EsDepositoFull => depositos?.FirstOrDefault(d => d.Id == depositoIdSeleccionado)?.Nombre == "Full MeLi";
    private bool sincronizandoFull = false;

    // === Bloque QR (token + URLs derivadas) ===
    private string token = "";
    private bool showAuditoriaQr = false;
    private string Origin => new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);
    private string LinkMovil => string.IsNullOrEmpty(token) ? "#" : $"{Origin}/stock/{token}";
    private string LinkAuditoria => string.IsNullOrEmpty(token) ? "#" : $"{Origin}/stock/{token}?modo=auditoria";
    private string QrMovilUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(LinkMovil)}";
    private string QrAuditoriaUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(LinkAuditoria)}";

    private int CountCambios =>
        rows is null ? 0 :
        rows.Count(r => HaModificado(r));

    private bool HayCambios => CountCambios > 0;

    protected override async Task OnInitializedAsync()
    {
        depositos = await Api.GetCafeDepositosAsync() ?? new();
        depositoIdSeleccionado = PreDepositoId
            ?? depositos.FirstOrDefault(d => d.IsDefault)?.Id
            ?? depositos.FirstOrDefault()?.Id ?? 0;
        // Cargar token del link público de stock (para los QR del header)
        try
        {
            var tk = await Http.GetFromJsonAsync<TokenDto>("api/stock/admin/token");
            token = tk?.token ?? "";
        }
        catch { token = ""; }
        await CargarStock();
    }

    private record TokenDto(string token);

    private async Task CambiarDeposito()
    {
        nuevoStockKg = new(); nuevoStockUnidades = new();
        await CargarStock();
    }

    private async Task CargarStock()
    {
        if (depositoIdSeleccionado <= 0) { rows = new(); loading = false; return; }
        loading = true;
        try { rows = await Api.GetStockEnDepositoAsync(depositoIdSeleccionado) ?? new(); }
        catch { ToastService.Error("Error al cargar"); rows = new(); }
        loading = false;
    }

    private IEnumerable<StockProductoDto> Filtrados()
    {
        if (rows is null) return Enumerable.Empty<StockProductoDto>();
        var t = filtroTexto?.Trim() ?? "";
        return rows.Where(r =>
            (string.IsNullOrEmpty(filtroCategoria) || r.Categoria == filtroCategoria) &&
            (string.IsNullOrEmpty(t)
                || (r.Codigo?.Contains(t, StringComparison.OrdinalIgnoreCase) ?? false)
                || r.Nombre.Contains(t, StringComparison.OrdinalIgnoreCase)));
    }

    private bool HaModificado(StockProductoDto r)
    {
        if (r.Categoria == "CAFE")
        {
            if (!nuevoStockKg.TryGetValue(r.ProductoId, out var kg)) return false;
            return Math.Abs(kg * 1000m - r.StockGramos) > 0.001m;
        }
        else
        {
            if (!nuevoStockUnidades.TryGetValue(r.ProductoId, out var u)) return false;
            return u != r.StockUnidades;
        }
    }

    private void OnStockKgChange(int productoId, string? value)
    {
        if (!decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var kg))
            decimal.TryParse(value, out kg);
        nuevoStockKg[productoId] = kg;
    }

    private void OnStockUnidadesChange(int productoId, string? value)
    {
        int.TryParse(value, out var u);
        nuevoStockUnidades[productoId] = u;
    }

    private async Task Guardar()
    {
        if (rows is null) return;
        var items = new List<ApiClient.StockMasivoItemReq>();
        foreach (var r in rows)
        {
            if (!HaModificado(r)) continue;
            decimal stockG = r.Categoria == "CAFE"
                ? (nuevoStockKg.TryGetValue(r.ProductoId, out var kg) ? kg * 1000m : r.StockGramos)
                : r.StockGramos;
            int stockU = r.Categoria == "CAFE"
                ? r.StockUnidades
                : (nuevoStockUnidades.TryGetValue(r.ProductoId, out var u) ? u : r.StockUnidades);
            items.Add(new ApiClient.StockMasivoItemReq(r.ProductoId, stockG, stockU));
        }
        if (items.Count == 0) { ToastService.Info("Sin cambios"); return; }

        guardando = true;
        try
        {
            await Api.ActualizarStockMasivoAsync(depositoIdSeleccionado, items);
            ToastService.Success($"Stock actualizado en {items.Count} productos");
            nuevoStockKg = new(); nuevoStockUnidades = new();
            await CargarStock();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { guardando = false; }
    }

    /// <summary>Dispara el sync de stock Full desde MeLi (lee meli_facility de todos los UPGs
    /// linkeados y los guarda en Cafe_StockPorDeposito[Full MeLi]).</summary>
    private async Task SincronizarFullAhora()
    {
        sincronizandoFull = true;
        try
        {
            var resp = await Http.PostAsync("/api/meli/full-stock-sync", null);
            if (resp.IsSuccessStatusCode)
            {
                var r = await resp.Content.ReadFromJsonAsync<FullSyncResp>();
                ToastService.Success($"✓ Full sync: {r?.upgsConFull} pubs Full · {r?.productosActualizados} productos actualizados");
                if (EsDepositoFull) await CargarStock();
            }
            else { ToastService.Error("Error al sincronizar Full"); }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { sincronizandoFull = false; }
    }

    private record FullSyncResp(int upgsProcesados, int upgsConFull, int productosActualizados, int errores);
}
