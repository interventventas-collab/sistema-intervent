    // 2026-05-30 — Pieza 2: Modal "Crear producto"
    private bool showCrearModal;
    private SkuRow? crearSkuRow;
    private string crearNombre = "";
    private int crearOemId;  // 0 = sin OEM
    private decimal crearMultiplicador = 1m;
    private bool crearGuardando;
    private List<OemLite>? oemsLista;
    public record OemLite(int id, string codigo, string? descripcion, decimal? pvpConIva);
    public record CrearProductoResult(int productoId, string sku, string nombre, int pubsLinkeadas);

    protected override async Task OnInitializedAsync()
    {
        await Recargar();
        // Cargar OEMs en background para el modal (no bloquea la pantalla)
        _ = CargarOems();
    }

    private async Task CargarOems()
    {
        try
        {
            var oems = await Http.GetFromJsonAsync<List<System.Text.Json.JsonElement>>("/api/cafe/oems");
            if (oems != null)
            {
                oemsLista = oems.Select(o => new OemLite(
                    o.GetProperty("id").GetInt32(),
                    o.GetProperty("codigo").GetString() ?? "",
                    o.TryGetProperty("descripcion", out var d) && d.ValueKind != System.Text.Json.JsonValueKind.Null ? d.GetString() : null,
                    o.TryGetProperty("pvpConIva", out var p) && p.ValueKind != System.Text.Json.JsonValueKind.Null ? p.GetDecimal() : (decimal?)null
                )).OrderBy(o => o.codigo).ToList();
                StateHasChanged();
            }
        }
        catch { /* silencioso: si no carga, el dropdown muestra solo "Sin OEM" */ }
    }

    private void AbrirModalCrearProducto(SkuRow sku)
    {
        crearSkuRow = sku;
        // Pre-llenar nombre desde combo si existe, sino producto suelto, sino el SKU
        crearNombre = !string.IsNullOrEmpty(sku.comboNombre) ? sku.comboNombre
                     : !string.IsNullOrEmpty(sku.productoSueltoNombre) ? sku.productoSueltoNombre!
                     : sku.sku;
        // Sugerir OEM por patrón: si el SKU es del estilo "C9172ROJ" → quitar "C" prefix y sufijos comunes → buscar OEM
        crearOemId = SugerirOemPorSku(sku.sku);
        crearMultiplicador = 1m;
        showCrearModal = true;
    }

    private int SugerirOemPorSku(string sku)
    {
        if (oemsLista == null || string.IsNullOrEmpty(sku)) return 0;
        var skuU = sku.Trim().ToUpperInvariant();
        // Quitar prefijos comunes ("C")
        var sinC = skuU.StartsWith("C") ? skuU.Substring(1) : skuU;
        // Buscar OEM cuyo Codigo esté contenido al principio del SKU (sin prefijo)
        var match = oemsLista
            .Where(o => !string.IsNullOrEmpty(o.codigo) && sinC.StartsWith(o.codigo.ToUpperInvariant()))
            .OrderByDescending(o => o.codigo.Length) // preferir match más largo (más específico)
            .FirstOrDefault();
        return match?.id ?? 0;
    }

    private void CerrarModalCrearProducto()
    {
        if (crearGuardando) return;
        showCrearModal = false;
        crearSkuRow = null;
    }

    private async Task ConfirmarCrearProducto()
    {
        if (crearSkuRow == null) return;
        if (string.IsNullOrWhiteSpace(crearNombre))
        {
            ToastService.Error("El nombre no puede quedar vacío");
            return;
        }
        crearGuardando = true; StateHasChanged();
        try
        {
            var body = new
            {
                Nombre = crearNombre.Trim(),
                OemId = crearOemId > 0 ? (int?)crearOemId : null,
                MultiplicadorOem = crearOemId > 0 ? (decimal?)crearMultiplicador : null
            };
            var sku = Uri.EscapeDataString(crearSkuRow.sku);
            var resp = await Http.PostAsJsonAsync($"/api/meli/skus-meli/{sku}/crear-producto", body);
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                ToastService.Error("No se pudo crear: " + err);
                return;
            }
            var r = await resp.Content.ReadFromJsonAsync<CrearProductoResult>();
            ToastService.Success($"✅ Producto creado (Id {r?.productoId}) — {r?.pubsLinkeadas} publicación{(r?.pubsLinkeadas == 1 ? "" : "es")} linkeada{(r?.pubsLinkeadas == 1 ? "" : "s")}");
            showCrearModal = false;
            crearSkuRow = null;
            await Recargar();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
        finally
        {
            crearGuardando = false; StateHasChanged();
        }
    }

    private async Task Recargar()
    {
        cargando = true; StateHasChanged();
        try
        {
            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(buscar)) qs.Add($"buscar={Uri.EscapeDataString(buscar.Trim())}");
            if (!string.IsNullOrEmpty(estadoFiltro)) qs.Add($"estado={estadoFiltro}");
            if (!string.IsNullOrEmpty(armableFiltro)) qs.Add($"armableRango={Uri.EscapeDataString(armableFiltro)}");
            if (!string.IsNullOrEmpty(ordenarPor)) qs.Add($"ordenarPor={ordenarPor}");
            var url = "/api/meli/skus-meli" + (qs.Count > 0 ? "?" + string.Join("&", qs) : "");
            response = await Http.GetFromJsonAsync<SkusMeliResponse>(url);
        }
        catch (Exception ex) { ToastService.Error("Error al cargar: " + ex.Message); }
        finally { cargando = false; StateHasChanged(); }
    }

    private int CountEstado(string est) => response?.items.Count(s => s.estado == est) ?? 0;

    private void OnSearchKey(KeyboardEventArgs e)
    {
        debounce?.Dispose();
        debounce = new System.Threading.Timer(async _ => await InvokeAsync(Recargar), null, 400, System.Threading.Timeout.Infinite);
    }

    private void ToggleExpand(string sku)
    {
        if (expandidos.Contains(sku)) expandidos.Remove(sku);
        else { expandidos.Add(sku); if (!pubsCache.ContainsKey(sku)) _ = CargarPubs(sku); }
    }

    private async Task CargarPubs(string sku)
    {
        try
        {
            var pubs = await Http.GetFromJsonAsync<List<PubRow>>($"/api/meli/skus-meli/{Uri.EscapeDataString(sku)}/pubs");
            if (pubs != null) pubsCache[sku] = pubs;
            StateHasChanged();
        }
        catch { /* ignore */ }
    }

    private async Task LinkearAuto(string sku)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Linkear todas las pubs MeLi de SKU '{sku}' al combo del sistema?")) return;
        try
        {
            var resp = await Http.PostAsync($"/api/meli/skus-meli/{Uri.EscapeDataString(sku)}/linkear", null);
            if (resp.IsSuccessStatusCode)
            {
                var result = await resp.Content.ReadFromJsonAsync<LinkResp>();
                ToastService.Success($"✓ Linkeadas {result?.pubsLinkeadas ?? 0} pubs");
                await Recargar();
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                ToastService.Error("Error: " + err);
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }
    private record LinkResp(bool ok, int comboId, int pubsLinkeadas);

