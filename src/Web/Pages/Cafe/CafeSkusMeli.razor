    private void IniciarEdicion(string sku)
    {
        editandoSku = sku;
        addCantidad = 1;
        addBuscarProducto = "";
        resultadosBusqueda = new();
        productoAddSeleccionado = null;
    }

    private void CerrarEdicion(string sku)
    {
        editandoSku = null;
        productoAddSeleccionado = null;
        resultadosBusqueda = new();
    }

    private async Task OnCantidadChange(int componenteId, string? rawValue)
    {
        if (componenteId <= 0) { ToastService.Warning("Este componente no tiene linkeo MeLi — agregalo de nuevo."); return; }
        if (!decimal.TryParse(rawValue, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var cant) || cant <= 0)
        {
            ToastService.Warning("Cantidad inválida");
            return;
        }
        try
        {
            var resp = await Http.PutAsJsonAsync($"/api/meli/componente/{componenteId}", new { cantidad = cant });
            if (resp.IsSuccessStatusCode)
            {
                ToastService.Success("✓ Cantidad actualizada y stock pusheado a MeLi");
                await Recargar();
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                ToastService.Error("Error: " + err);
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private async Task EliminarComponente(int componenteId, string sku)
    {
        if (componenteId <= 0) { ToastService.Warning("Este componente no tiene linkeo MeLi"); return; }
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar este componente del linkeo MeLi? La publicación dejará de descontar este producto al venderse.")) return;
        try
        {
            var resp = await Http.DeleteAsync($"/api/meli/componente/{componenteId}");
            if (resp.IsSuccessStatusCode)
            {
                ToastService.Success("✓ Componente eliminado y stock pusheado");
                await Recargar();
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                ToastService.Error("Error: " + err);
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private void BuscarProductos()
    {
        debounceBuscar?.Dispose();
        debounceBuscar = new System.Threading.Timer(async _ => await InvokeAsync(EjecutarBusqueda), null, 300, System.Threading.Timeout.Infinite);
    }

    private async Task EjecutarBusqueda()
    {
        if (string.IsNullOrWhiteSpace(addBuscarProducto) || addBuscarProducto.Length < 2)
        {
            resultadosBusqueda = new();
            StateHasChanged();
            return;
        }
        try
        {
            var url = $"/api/cafe/productos/search?q={Uri.EscapeDataString(addBuscarProducto.Trim())}&limit=15";
            var raw = await Http.GetFromJsonAsync<List<ProductoBuscadoRow>>(url);
            resultadosBusqueda = raw ?? new();
            StateHasChanged();
        }
        catch { resultadosBusqueda = new(); }
    }

    private void SeleccionarProducto(ProductoBuscadoRow p)
    {
        productoAddSeleccionado = p;
        addBuscarProducto = $"{p.Sku} · {p.Nombre}";
        resultadosBusqueda = new();
    }

    private async Task AgregarComponente(string meliItemId, string sku)
    {
        if (productoAddSeleccionado is null) { ToastService.Warning("Seleccioná un producto primero"); return; }
        if (addCantidad <= 0) { ToastService.Warning("Cantidad inválida"); return; }
        try
        {
            var body = new
            {
                meliItemId = meliItemId,
                cafeProductoId = productoAddSeleccionado.Id,
                cantidad = addCantidad,
                formato = (string?)null,
                meliVariationId = (string?)null
            };
            var resp = await Http.PostAsJsonAsync("/api/meli/componente", body);
            if (resp.IsSuccessStatusCode)
            {
                ToastService.Success($"✓ Agregado {productoAddSeleccionado.Sku} (x{addCantidad}) y pusheado");
                addBuscarProducto = "";
                productoAddSeleccionado = null;
                addCantidad = 1;
                await Recargar();
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                ToastService.Error("Error: " + err);
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }
