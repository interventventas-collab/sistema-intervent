@page "/cafe/proveedores"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject CpService CpService
@inject NavigationManager Nav

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>🏭 Proveedores <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(proveedores?.Count ?? 0))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <input class="form-input" style="min-width: 240px; font-size: 0.85rem;"
                   @bind="filtroTexto" @bind:event="oninput"
                   placeholder="🔍 Buscar nombre, contacto, tel, email..." />
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo proveedor</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (proveedores is null || proveedores.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay proveedores. Tocá <strong>+ Nuevo proveedor</strong>.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th style="width: 130px;">CUIT</th>
                            <th style="width: 60px;">IVA</th>
                            <th>Ubicación</th>
                            <th style="width: 130px;">Teléfono</th>
                            <th>Email</th>
                            <th style="width: 90px; text-align: center;">Compras</th>
                            <th style="text-align: right;">Total comprado</th>
                            <th>Estado</th>
                            <th style="width: 110px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Visibles)
                        {
                            <tr>
                                <td>
                                    <strong>@p.Nombre</strong>
                                    @if (!string.IsNullOrEmpty(p.Contacto))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">👤 @p.Contacto</div>
                                    }
                                    @if (!string.IsNullOrEmpty(p.Notas))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">@p.Notas</div>
                                    }
                                </td>
                                <td style="font-family: monospace; font-size: 0.82rem;">@(p.Cuit ?? "—")</td>
                                <td style="font-size: 0.78rem; color: #6b7280;">@(p.CategoriaImpositiva ?? "—")</td>
                                <td style="font-size: 0.78rem; color: #6b7280;">
                                    @if (!string.IsNullOrEmpty(p.Ciudad) || !string.IsNullOrEmpty(p.Provincia))
                                    {
                                        <span>@p.Ciudad @(string.IsNullOrEmpty(p.Ciudad) || string.IsNullOrEmpty(p.Provincia) ? "" : ",") @p.Provincia</span>
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                </td>
                                <td style="font-family: monospace; font-size: 0.85rem;">
                                    @if (!string.IsNullOrEmpty(p.Telefono))
                                    {
                                        <a href="https://wa.me/@(new string(p.Telefono.Where(char.IsDigit).ToArray()))" target="_blank" style="color: #25D366; text-decoration: none;">📱 @p.Telefono</a>
                                    }
                                    else { <span style="color: #d1d5db;">—</span> }
                                </td>
                                <td style="font-size: 0.85rem;">@(p.Email ?? "—")</td>
                                <td style="text-align: center;">
                                    @if (p.ComprasCount > 0)
                                    {
                                        <span style="background: #dcfce7; color: #15803d; padding: 0.15rem 0.55rem; border-radius: 999px; font-size: 0.78rem; font-weight: 700;">@p.ComprasCount</span>
                                    }
                                    else { <span style="color: #d1d5db;">0</span> }
                                </td>
                                <td style="text-align: right; font-weight: 700;">@(p.TotalComprado > 0 ? "$" + FormatMoney(p.TotalComprado) : "—")</td>
                                <td><span class="status-badge @(p.IsActive ? "status-active" : "status-inactive")">@(p.IsActive ? "Activo" : "Inactivo")</span></td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(p)" title="Editar">✎</button>
                                    <button class="btn-icon" @onclick='() => Nav.NavigateTo($"/cafe/proveedores/{p.Id}/estado-cuenta")' title="Estado de cuenta">📒</button>
                                    <button class="btn-icon" style="color:#059669;" @onclick='() => Nav.NavigateTo($"/cafe/tesoreria/pagos?proveedor={p.Id}")' title="Pagar a este proveedor">💰</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(p)" title="Eliminar / desactivar">🗑</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 600px;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin: 0;">🏭 @(editing is null ? "Nuevo proveedor" : $"Editar — {editing.Nombre}")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError)) { <div class="form-error">@formError</div> }

                @* Identidad *@
                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.6rem 0.75rem; margin-bottom: 0.6rem;">
                    <div style="font-weight: 700; font-size: 0.82rem; color: #6b7280; margin-bottom: 0.4rem; text-transform: uppercase;">Identidad</div>
                    <div class="form-group">
                        <label class="form-label">Razón social / Nombre *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Colombraro Hermanos S.A." />
                    </div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">CUIT</label>
                            <input class="form-input" @bind="formCuit" placeholder="20-12345678-9" />
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Se guarda solo dígitos. Único: si ya existe otro proveedor con ese CUIT, te avisa.</p>
                        </div>
                        <div class="form-group" style="flex: 0 0 180px;">
                            <label class="form-label">Cat. impositiva</label>
                            <select class="form-input" @bind="formCategoriaImpositiva">
                                <option value="">—</option>
                                <option value="RI">RI — Resp. Inscripto</option>
                                <option value="MO">MO — Monotributo</option>
                                <option value="EX">EX — Exento</option>
                                <option value="CF">CF — Consumidor Final</option>
                            </select>
                        </div>
                    </div>
                </div>

                @* Contacto *@
                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.6rem 0.75rem; margin-bottom: 0.6rem;">
                    <div style="font-weight: 700; font-size: 0.82rem; color: #6b7280; margin-bottom: 0.4rem; text-transform: uppercase;">Contacto</div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Persona de contacto</label>
                            <input class="form-input" @bind="formContacto" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Teléfono / WhatsApp</label>
                            <input class="form-input" @bind="formTelefono" placeholder="Ej: 11 1234-5678" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">Email</label>
                            <input class="form-input" type="email" @bind="formEmail" placeholder="ventas@empresa.com" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Web</label>
                            <input class="form-input" @bind="formWeb" placeholder="empresa.com" />
                        </div>
                    </div>
                </div>

                @* Dirección *@
                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.6rem 0.75rem; margin-bottom: 0.6rem;">
                    <div style="font-weight: 700; font-size: 0.82rem; color: #6b7280; margin-bottom: 0.4rem; text-transform: uppercase;">Dirección</div>
                    <div class="form-group">
                        <label class="form-label">Domicilio</label>
                        <input class="form-input" @bind="formDireccion" placeholder="Calle, número, piso/depto" />
                    </div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Ciudad / Localidad</label>
                            <input class="form-input" list="datalist-prov-localidades" @bind="formCiudad" @bind:event="oninput" />
                            <datalist id="datalist-prov-localidades">
                                @foreach (var loc in localidadesSugeridas)
                                {
                                    <option value="@loc"></option>
                                }
                            </datalist>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Provincia</label>
                            <input class="form-input" list="datalist-prov-provincias" value="@formProvincia" @oninput="@(e => OnProvinciaInput(e.Value?.ToString()))" />
                            <datalist id="datalist-prov-provincias">
                                @foreach (var p in provincias)
                                {
                                    <option value="@p"></option>
                                }
                            </datalist>
                        </div>
                        <div class="form-group" style="flex: 0 0 100px;">
                            <label class="form-label">CP</label>
                            <input class="form-input" @bind="formCodigoPostal" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <textarea class="form-input" rows="2" @bind="formNotas"></textarea>
                </div>
                @if (editing is not null)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="DoSave" disabled="@saving">@(saving ? "Guardando..." : "💾 Guardar")</button>
            </div>
        </div>
    </div>
}

@if (toDelete is not null)
{
    <div class="modal-overlay" @onclick="() => toDelete = null">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;"><h4 style="margin: 0;">Eliminar proveedor</h4>
                <button class="btn-close" @onclick="() => toDelete = null" style="color: white;">&times;</button></div>
            <div class="modal-body">
                @if (toDelete.ComprasCount > 0)
                {
                    <p>El proveedor <strong>@toDelete.Nombre</strong> tiene <strong>@toDelete.ComprasCount</strong> compra@(toDelete.ComprasCount == 1 ? "" : "s") asociada@(toDelete.ComprasCount == 1 ? "" : "s").</p>
                    <p style="color: #b45309; font-weight: 600; font-size: 0.85rem;">Por seguridad NO se va a eliminar — se va a <strong>desactivar</strong> para que no aparezca al crear nuevas compras. El historial queda intacto.</p>
                }
                else
                {
                    <p>Vas a eliminar definitivamente <strong>@toDelete.Nombre</strong>.</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => toDelete = null">No</button>
                <button class="btn btn-danger" @onclick="DoDelete">Sí</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeProveedorDto>? proveedores;
    private bool loading = true;
    private string filtroTexto = "";

    private bool showForm, saving;
    private string? formError;
    private CafeProveedorDto? editing;
    private string formNombre = "";
    private string formContacto = "";
    private string formTelefono = "";
    private string formEmail = "";
    private string formNotas = "";
    private string formCuit = "";
    private string formCategoriaImpositiva = "";
    private string formDireccion = "";
    private string formCodigoPostal = "";
    private string formProvincia = "";
    private string formCiudad = "";
    private string formWeb = "";
    private bool formIsActive = true;

    // Datalists para provincia/localidad (cargados desde CpService)
    private List<string> provincias = new();
    private List<string> localidadesSugeridas = new();

    /// <summary>Cuando el usuario tipea/elige una provincia, refresca la lista de localidades sugeridas.</summary>
    private async Task OnProvinciaInput(string? value)
    {
        formProvincia = (value ?? "").Trim();
        localidadesSugeridas = await CpService.GetLocalidadesAsync(formProvincia);
    }

    private CafeProveedorDto? toDelete;

    private List<CafeProveedorDto> Visibles
    {
        get
        {
            if (proveedores is null) return new();
            if (string.IsNullOrWhiteSpace(filtroTexto)) return proveedores;
            var t = filtroTexto.Trim();
            bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
            return proveedores.Where(p => h(p.Nombre) || h(p.Contacto) || h(p.Telefono) || h(p.Email) || h(p.Notas)
                || h(p.Cuit) || h(p.Ciudad) || h(p.Provincia) || h(p.Direccion)).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        provincias = await CpService.GetProvinciasAsync();
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        try { proveedores = await Api.GetCafeProveedoresAsync() ?? new(); }
        catch { proveedores = new(); ToastService.Error("Error al cargar"); }
        loading = false;
    }

    private void ShowCreate()
    {
        editing = null;
        formNombre = ""; formContacto = ""; formTelefono = ""; formEmail = ""; formNotas = "";
        formCuit = ""; formCategoriaImpositiva = ""; formDireccion = "";
        formCodigoPostal = ""; formProvincia = ""; formCiudad = ""; formWeb = "";
        localidadesSugeridas = new();
        formIsActive = true; formError = null; showForm = true;
    }

    private async Task ShowEdit(CafeProveedorDto p)
    {
        editing = p;
        formNombre = p.Nombre; formContacto = p.Contacto ?? ""; formTelefono = p.Telefono ?? "";
        formEmail = p.Email ?? ""; formNotas = p.Notas ?? "";
        formCuit = p.Cuit ?? ""; formCategoriaImpositiva = p.CategoriaImpositiva ?? "";
        formDireccion = p.Direccion ?? ""; formCodigoPostal = p.CodigoPostal ?? "";
        formProvincia = p.Provincia ?? ""; formCiudad = p.Ciudad ?? ""; formWeb = p.Web ?? "";
        localidadesSugeridas = await CpService.GetLocalidadesAsync(formProvincia);
        formIsActive = p.IsActive;
        formError = null; showForm = true;
    }

    private void CloseForm() { if (!saving) showForm = false; }

    private async Task DoSave()
    {
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        formError = null; saving = true;
        try
        {
            if (editing is null)
            {
                await Api.CreateCafeProveedorAsync(new CreateCafeProveedorRequest
                {
                    Nombre = formNombre, Contacto = formContacto, Telefono = formTelefono,
                    Email = formEmail, Notas = formNotas,
                    Cuit = formCuit, CategoriaImpositiva = formCategoriaImpositiva,
                    Direccion = formDireccion, CodigoPostal = formCodigoPostal,
                    Provincia = formProvincia, Ciudad = formCiudad, Web = formWeb
                });
                ToastService.Success("Proveedor creado");
            }
            else
            {
                await Api.UpdateCafeProveedorAsync(editing.Id, new UpdateCafeProveedorRequest
                {
                    Nombre = formNombre, Contacto = formContacto, Telefono = formTelefono,
                    Email = formEmail, Notas = formNotas,
                    Cuit = formCuit, CategoriaImpositiva = formCategoriaImpositiva,
                    Direccion = formDireccion, CodigoPostal = formCodigoPostal,
                    Provincia = formProvincia, Ciudad = formCiudad, Web = formWeb,
                    IsActive = formIsActive
                });
                ToastService.Success("Proveedor actualizado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private void ConfirmDelete(CafeProveedorDto p) => toDelete = p;

    private async Task DoDelete()
    {
        if (toDelete is null) return;
        try
        {
            await Api.DeleteCafeProveedorAsync(toDelete.Id);
            ToastService.Success(toDelete.ComprasCount > 0 ? "Proveedor desactivado (tenía compras)" : "Proveedor eliminado");
            toDelete = null;
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); toDelete = null; }
    }

    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
