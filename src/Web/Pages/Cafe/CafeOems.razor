@code {
    private List<CafeOemDto>? oems;
    private bool loading = true;
    private string filtroTexto = "";
    private string filtroProveedor = "";
    private string filtroMarca = "";

    private List<string> proveedoresExistentes => oems is null ? new() :
        oems.Where(o => !string.IsNullOrWhiteSpace(o.Proveedor))
            .Select(o => o.Proveedor!).Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase).ToList();
    /// <summary>Catalogo de marcas (Cafe_Marcas). Alimenta el datalist del form.</summary>
    private List<CafeMarcaDto>? marcasCatalog;

    private List<string> marcasExistentes => oems is null ? new() :
        oems.Where(o => !string.IsNullOrWhiteSpace(o.Marca))
            .Select(o => o.Marca!).Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(s => s, StringComparer.OrdinalIgnoreCase).ToList();

    private List<CafeOemDto> OemsVisibles
    {
        get
        {
            if (oems is null) return new();
            IEnumerable<CafeOemDto> q = oems;
            if (!string.IsNullOrEmpty(filtroProveedor)) q = q.Where(o => o.Proveedor == filtroProveedor);
            if (!string.IsNullOrEmpty(filtroMarca)) q = q.Where(o => o.Marca == filtroMarca);
            if (!string.IsNullOrWhiteSpace(filtroTexto))
            {
                var t = filtroTexto.Trim();
                bool h(string? s) => s.MatchesSearch(t);
                q = q.Where(o => h(o.Codigo) || h(o.Descripcion) || h(o.Marca) || h(o.Barcode));
            }
            return q.Take(500).ToList();
        }
    }

    // Form
    private bool showForm, saving;
    private string? formError;
    private CafeOemDto? editing;
    private string formCodigo = "";
    private string formDescripcion = "";
    private string formMarca = "";
    private string formProveedor = "COLOMBRARO";
    private string formBarcode = "";
    private decimal formCosto;
    private decimal? formPvpConIva;
    private decimal? formIvaPct = 21m;
    private int? formUxB;
    private string formUrlWeb = ""; // 2026-06-10
    // 2026-06-11: scraping de la web del proveedor
    private bool scrapingNow;
    private string? scrapeError;

    // Import
    private bool showImport;
    private bool isImporting;
    private bool isPreviewing;
    private string? importError;
    private string importProveedor = "COLOMBRARO";
    private IBrowserFile? importFile;
    private byte[]? importBytes;   // 2026-07-10: bytes del archivo leidos una vez (preview + import reusan)
    private CafeOemImportPreviewDto? importPreview;
    private CafeOemImportResultDto? importResult;
    // Filas nuevas o con cambio de precio (lo que le interesa ver al usuario en la previa).
    private List<CafeOemImportCambioDto> CambiosRelevantes =>
        importPreview?.Cambios.Where(c => c.EsNuevo || c.CambiaCosto || c.CambiaPvp).ToList() ?? new();

    // Variantes vinculadas (ver impacto de un cambio de precio)
    private bool showVariantes;
    private CafeOemDto? variantesOem;
    private List<CafeOemVarianteDto>? variantesList;
    private bool loadingVariantes;

    // Delete
    private CafeOemDto? toDelete;

    // 2026-06-11: scrape masivo
    private bool showScrapeMasivoConfirm;
    private bool masivoSoloFaltantes = true;
    private string? masivoStartError;
    private CafeOemScrapeMasivoStatusDto? masivoStatus;
    private System.Threading.Timer? _masivoPollTimer;
    private bool _masivoRefreshOnFinish;

    protected override async Task OnInitializedAsync()
    {
        var loadMarcas = LoadMarcasCatalog();
        await Load();
        await loadMarcas;
        // Si hay un job corriendo cuando entro a la pantalla, prendo el poller
        await RefreshMasivoStatusAsync();
        if (masivoStatus is not null && masivoStatus.running) StartMasivoPoller();
    }

    private void StartMasivoPoller()
    {
        _masivoPollTimer?.Dispose();
        _masivoPollTimer = new System.Threading.Timer(_ =>
        {
            _ = MasivoTickAsync();
        }, null, dueTime: 1500, period: 2500);
    }

    private async Task MasivoTickAsync()
    {
        try
        {
            await RefreshMasivoStatusAsync();
            await InvokeAsync(StateHasChanged);
            if (masivoStatus is not null && !masivoStatus.running)
            {
                _masivoPollTimer?.Dispose();
                _masivoPollTimer = null;
                if (_masivoRefreshOnFinish)
                {
                    _masivoRefreshOnFinish = false;
                    await Load();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch { }
    }

    private async Task RefreshMasivoStatusAsync()
    {
        try { masivoStatus = await Api.GetCafeOemScrapeMasivoStatusAsync(); }
        catch { }
    }

    private async Task DoScrapeMasivoStart()
    {
        masivoStartError = null;
        try
        {
            var proveedor = string.IsNullOrWhiteSpace(filtroProveedor) ? null : filtroProveedor;
            var resp = await Api.StartCafeOemScrapeMasivoAsync(proveedor, masivoSoloFaltantes);
            if (resp.IsSuccessStatusCode || (int)resp.StatusCode == 202)
            {
                showScrapeMasivoConfirm = false;
                _masivoRefreshOnFinish = true;
                await RefreshMasivoStatusAsync();
                StartMasivoPoller();
                ToastService.Success("Sincronización masiva iniciada. Mirá la barra de progreso arriba.");
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                masivoStartError = $"No se pudo iniciar. {err}";
            }
        }
        catch (Exception ex)
        {
            masivoStartError = $"Error: {ex.Message}";
        }
    }

    private void OpenScrapeMasivo()
    {
        masivoStartError = null;
        masivoSoloFaltantes = true;
        showScrapeMasivoConfirm = true;
    }

    public async ValueTask DisposeAsync()
    {
        _masivoPollTimer?.Dispose();
        _masivoPollTimer = null;
        await Task.CompletedTask;
    }

    private async Task LoadMarcasCatalog()
    {
        try { marcasCatalog = await Api.GetCafeMarcasAsync() ?? new(); }
        catch { marcasCatalog = new(); }
    }

    private async Task Load()
    {
        loading = true;
        try { oems = await Api.GetCafeOemsAsync() ?? new(); }
        catch { oems = new(); ToastService.Error("Error al cargar OEMs"); }
        loading = false;
    }

    private void ShowCreate()
    {
        editing = null;
        formCodigo = ""; formDescripcion = ""; formMarca = "";
        formProveedor = "COLOMBRARO"; formBarcode = "";
        formCosto = 0; formPvpConIva = null; formIvaPct = 21m; formUxB = null;
        formUrlWeb = ""; // 2026-06-10
        formError = null;
        showForm = true;
    }

    private void ShowEdit(CafeOemDto o)
    {
        editing = o;
        formCodigo = o.Codigo;
        formDescripcion = o.Descripcion ?? "";
        formMarca = o.Marca ?? "";
        formProveedor = o.Proveedor ?? "";
        formBarcode = o.Barcode ?? "";
        formCosto = o.Costo;
        formPvpConIva = o.PvpConIva;
        formIvaPct = o.IvaPct;
        formUxB = o.UxB;
        formUrlWeb = o.UrlWeb ?? ""; // 2026-06-10
        formError = null;
        showForm = true;
    }

    private void CloseForm() { if (!saving) showForm = false; }

    private async Task DoSave()
    {
        if (string.IsNullOrWhiteSpace(formCodigo)) { formError = "El código es obligatorio"; return; }
        formError = null; saving = true;
        try
        {
            if (editing is null)
            {
                await Api.CreateCafeOemAsync(new CreateCafeOemRequest
                {
                    Codigo = formCodigo,
                    Descripcion = formDescripcion,
                    Marca = formMarca,
                    Proveedor = formProveedor,
                    Barcode = formBarcode,
                    Costo = formCosto,
                    PvpConIva = formPvpConIva,
                    IvaPct = formIvaPct,
                    UxB = formUxB,
                    UrlWeb = string.IsNullOrWhiteSpace(formUrlWeb) ? null : formUrlWeb.Trim() // 2026-06-10
                });
                ToastService.Success("OEM creado");
            }
            else
            {
                var updated = await Api.UpdateCafeOemAsync(editing.Id, new UpdateCafeOemRequest
                {
                    Codigo = formCodigo,
                    Descripcion = formDescripcion,
                    Marca = formMarca,
                    Proveedor = formProveedor,
                    Barcode = formBarcode,
                    Costo = formCosto,
                    PvpConIva = formPvpConIva,
                    IvaPct = formIvaPct,
                    UxB = formUxB,
                    ClearUxB = !formUxB.HasValue,
                    // 2026-06-10
                    UrlWeb = string.IsNullOrWhiteSpace(formUrlWeb) ? null : formUrlWeb.Trim(),
                    ClearUrlWeb = string.IsNullOrWhiteSpace(formUrlWeb)
                });
                if (updated is not null && updated.VariantesCount > 0)
                    ToastService.Success($"OEM actualizado · {updated.VariantesCount} variante{(updated.VariantesCount == 1 ? "" : "s")} propagada{(updated.VariantesCount == 1 ? "" : "s")}");
                else
                    ToastService.Success("OEM actualizado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private void ConfirmDelete(CafeOemDto o) => toDelete = o;

    private async Task DoDelete()
    {
        if (toDelete is null) return;
        try
        {
            await Api.DeleteCafeOemAsync(toDelete.Id);
            ToastService.Success("OEM eliminado");
            toDelete = null;
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); toDelete = null; }
    }

    // ── Descargar plantilla ──
    private async Task DescargarPlantilla()
    {
        try
        {
            var bytes = await Api.DownloadCafeOemTemplateAsync();
            if (bytes is null) { ToastService.Error("No se pudo descargar la plantilla"); return; }
            await JS.InvokeVoidAsync("downloadFile", "plantilla-oems.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    // ── Variantes vinculadas ──
    private async Task OpenVariantes(CafeOemDto o)
    {
        variantesOem = o;
        showVariantes = true;
        loadingVariantes = true;
        variantesList = null;
        try { variantesList = await Api.GetCafeOemVariantesAsync(o.Id); }
        catch (Exception ex) { ToastService.Error("No se pudieron cargar las variantes: " + ex.Message); }
        finally { loadingVariantes = false; }
    }

    private void CloseVariantes()
    {
        showVariantes = false;
        variantesOem = null;
        variantesList = null;
    }

    // ── Import ──
    private void OpenImport()
    {
        showImport = true;
        importFile = null;
        importBytes = null;
        importPreview = null;
        importResult = null;
        importError = null;
        importProveedor = "COLOMBRARO";
    }

    private void CloseImport()
    {
        if (isImporting || isPreviewing) return;
        showImport = false;
        importFile = null;
        importBytes = null;
        importPreview = null;
        importResult = null;
        importError = null;
    }

    private void OnFileChange(InputFileChangeEventArgs e)
    {
        importFile = e.File;
        importBytes = null;
        importPreview = null;
        importError = null;
    }

    private void VolverAElegirArchivo()
    {
        importPreview = null;
        importError = null;
    }

    // Paso 2: genera la vista previa (dry-run). Lee el archivo UNA vez y lo bufferea.
    private async Task DoPreview()
    {
        if (importFile is null) { importError = "Elegí un archivo .xlsx"; return; }
        isPreviewing = true; importError = null;
        try
        {
            if (importBytes is null)
            {
                using var src = importFile.OpenReadStream(maxAllowedSize: 100_000_000);
                using var ms = new MemoryStream();
                await src.CopyToAsync(ms);
                importBytes = ms.ToArray();
            }
            using var stream = new MemoryStream(importBytes);
            importPreview = await Api.PreviewCafeOemsAsync(stream, importFile.Name, importProveedor);
        }
        catch (Exception ex) { importError = ex.Message; }
        finally { isPreviewing = false; }
    }

    // Paso 3: aplica de verdad (reusa los bytes ya leídos).
    private async Task DoImport()
    {
        if (importBytes is null && importFile is null) { importError = "Elegí un archivo .xlsx"; return; }
        isImporting = true; importError = null;
        try
        {
            if (importBytes is null)
            {
                using var src = importFile!.OpenReadStream(maxAllowedSize: 100_000_000);
                using var ms = new MemoryStream();
                await src.CopyToAsync(ms);
                importBytes = ms.ToArray();
            }
            using var stream = new MemoryStream(importBytes);
            importResult = await Api.ImportCafeOemsAsync(stream, importFile?.Name ?? "oems.xlsx", importProveedor);
            var nProp = importResult?.VariantesPropagadas ?? 0;
            var msg = $"✓ {importResult?.Creados ?? 0} nuevos, {importResult?.Actualizados ?? 0} actualizados";
            if (nProp > 0) msg += $" · {nProp} variante{(nProp == 1 ? "" : "s")} con precios propagados";
            ToastService.Success(msg);
            await Load();
        }
        catch (Exception ex) { importError = ex.Message; }
        finally { isImporting = false; }
    }

    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    private static string FormatBytes(long b)
    {
        if (b < 1024) return $"{b} B";
        if (b < 1024 * 1024) return $"{b / 1024.0:F1} KB";
        return $"{b / (1024.0 * 1024.0):F1} MB";
    }

    // 2026-06-11: traer datos de la web del proveedor (scraping)
    private async Task DoScrapeWeb()
    {
        if (editing is null) return;
        if (string.IsNullOrWhiteSpace(formUrlWeb))
        {
            scrapeError = "Cargá primero la URL del producto y guardá el OEM antes de traer datos.";
            return;
        }
        // Si la URL del formulario es diferente a la del OEM en base, exigir guardar primero
        if (!string.Equals(formUrlWeb.Trim(), editing.UrlWeb?.Trim() ?? "", StringComparison.OrdinalIgnoreCase))
        {
            scrapeError = "Guardá primero el OEM con la URL nueva, después tocá 'Traer datos'.";
            return;
        }
        scrapingNow = true;
        scrapeError = null;
        try
        {
            var resp = await Api.ScrapeCafeOemWebAsync(editing.Id);
            if (resp.IsSuccessStatusCode)
            {
                var data = await resp.Content.ReadFromJsonAsync<ScrapeResponseDto>();
                if (data?.oem is not null)
                {
                    editing = data.oem;
                    if (oems is not null)
                    {
                        var idx = oems.FindIndex(x => x.Id == editing.Id);
                        if (idx >= 0) oems[idx] = editing;
                    }
                    ToastService.Success("Datos traídos de la web del proveedor");
                }
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                scrapeError = $"No se pudieron traer los datos. {err}";
            }
        }
        catch (Exception ex)
        {
            scrapeError = $"Error: {ex.Message}";
        }
        finally
        {
            scrapingNow = false;
        }
    }

    // 2026-06-11: parsear el JSON de especificaciones a un diccionario para mostrar en la UI
    private static IEnumerable<KeyValuePair<string, string>> ParseEspecificaciones(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) yield break;
        Dictionary<string, string>? dict = null;
        try { dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json); }
        catch { yield break; }
        if (dict is null) yield break;
        foreach (var kv in dict) yield return kv;
    }

    private class ScrapeResponseDto
    {
        public bool success { get; set; }
        public CafeOemDto? oem { get; set; }
    }
}
