@page "/cafe/oems"
@attribute [Authorize]
@implements IAsyncDisposable
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>📋 OEMs <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(oems?.Count ?? 0))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <input class="form-input" style="min-width: 240px; font-size: 0.85rem;"
                   @bind="filtroTexto" @bind:event="oninput"
                   placeholder="🔍 Buscar por código, descripción, marca, barcode..." />
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroProveedor">
                <option value="">Todos los proveedores</option>
                @foreach (var p in proveedoresExistentes) { <option value="@p">@p</option> }
            </select>
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroMarca">
                <option value="">Todas las marcas</option>
                @foreach (var m in marcasExistentes) { <option value="@m">@m</option> }
            </select>
            <button class="btn" style="background: #0891b2; color: white; border: none;" @onclick="DescargarPlantilla" title="Baja un Excel vacío con las columnas correctas para completar">⬇️ Descargar plantilla</button>
            <button class="btn" style="background: #16a34a; color: white; border: none;" @onclick="OpenImport">📥 Importar Excel</button>
            <button class="btn" style="background: #2563eb; color: white; border: none;" @onclick="OpenScrapeMasivo" title="Trae imagen + descripción + ficha desde la web del proveedor">🌐 Traer info web masiva</button>
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo OEM</button>
        </div>
    </div>

    @* 2026-06-11: progreso del scraping masivo *@
    @if (masivoStatus is not null && (masivoStatus.running || (masivoStatus.finishedAt.HasValue && (DateTime.UtcNow - masivoStatus.finishedAt.Value).TotalMinutes < 5)))
    {
        <div style="padding: 0.8rem; background: @(masivoStatus.running ? "#eff6ff" : "#f0fdf4"); border-bottom: 1px solid #e5e7eb;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.4rem; gap: 0.8rem; flex-wrap: wrap;">
                <strong style="color: @(masivoStatus.running ? "#1d4ed8" : "#15803d");">
                    @if (masivoStatus.running)
                    {
                        <span>⏳ Trayendo info de la web... OEM @masivoStatus.currentCodigo</span>
                    }
                    else
                    {
                        <span>✅ Sincronización masiva finalizada</span>
                    }
                </strong>
                <span style="font-size: 0.85rem; color: #4b5563;">
                    @masivoStatus.procesados / @masivoStatus.total
                    (@(masivoStatus.porcentaje)%)
                    · ✓ @masivoStatus.exitosos
                    @if (masivoStatus.errores > 0) { <span style="color: #dc2626;"> · ✗ @masivoStatus.errores</span> }
                </span>
            </div>
            <div style="height: 8px; background: #e5e7eb; border-radius: 4px; overflow: hidden;">
                <div style="height: 100%; background: @(masivoStatus.running ? "#3b82f6" : "#16a34a"); width: @(masivoStatus.porcentaje)%; transition: width 0.5s ease;"></div>
            </div>
            @if (!string.IsNullOrEmpty(masivoStatus.lastError))
            {
                <p style="font-size: 0.75rem; color: #dc2626; margin: 0.3rem 0 0;">Último error: @masivoStatus.lastError</p>
            }
        </div>
    }
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (oems is null || oems.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay OEMs cargados. Tocá <strong>"📥 Importar Excel"</strong> para subir la lista del proveedor o <strong>"+ Nuevo OEM"</strong> para cargar uno a mano.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">Código</th>
                            <th>Descripción</th>
                            <th style="width: 120px;">Marca</th>
                            <th style="width: 110px;">Proveedor</th>
                            <th style="text-align: right;" title="Sin IVA">Costo s/IVA</th>
                            <th style="text-align: right;" title="Con IVA">PVP c/IVA</th>
                            <th style="width: 70px; text-align: center;">IVA %</th>
                            <th style="width: 70px; text-align: center;">UxB</th>
                            <th style="width: 90px; text-align: center;">Variantes</th>
                            <th style="width: 120px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in OemsVisibles)
                        {
                            <tr>
                                <td>
                                    <span style="background: #16a34a; color: white; padding: 0.2rem 0.55rem; border-radius: 6px; font-weight: 800; font-family: monospace; font-size: 0.85rem;">@o.Codigo</span>
                                </td>
                                <td>
                                    <strong>@(o.Descripcion ?? "—")</strong>
                                    @if (!string.IsNullOrEmpty(o.Barcode))
                                    {
                                        <div style="font-size: 0.7rem; color: #9ca3af; font-family: monospace;">cod: @o.Barcode</div>
                                    }
                                </td>
                                <td style="font-size: 0.85rem; color: #6b7280;">@(o.Marca ?? "—")</td>
                                <td style="font-size: 0.78rem; color: #6b7280;">@(o.Proveedor ?? "—")</td>
                                <td style="text-align: right; font-weight: 700;">$@FormatMoney(o.Costo)</td>
                                <td style="text-align: right; font-weight: 700; color: #15803d;">@(o.PvpConIva.HasValue ? "$" + FormatMoney(o.PvpConIva.Value) : "—")</td>
                                <td style="text-align: center; font-size: 0.8rem; color: #6b7280;">@(o.IvaPct.HasValue ? o.IvaPct.Value.ToString("0.##") + "%" : "—")</td>
                                <td style="text-align: center; font-size: 0.85rem; color: #6b7280;">@(o.UxB?.ToString() ?? "—")</td>
                                <td style="text-align: center;">
                                    @if (o.VariantesCount > 0)
                                    {
                                        <button style="background: #dcfce7; color: #15803d; padding: 0.15rem 0.55rem; border-radius: 999px; font-size: 0.78rem; font-weight: 700; border: none; cursor: pointer;"
                                                title="Ver los productos vinculados a este OEM y su precio" @onclick="() => OpenVariantes(o)">
                                            @o.VariantesCount 👁️
                                        </button>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">0</span>
                                    }
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(o)" title="Editar">✎</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(o)" title="Eliminar">🗑</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 700px;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin: 0;">📋 @(editing is null ? "Nuevo OEM" : $"Editar OEM — {editing.Codigo}")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Código *</label>
                        <input class="form-input" @bind="formCodigo" placeholder="Ej: 8733" />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Proveedor</label>
                        <input class="form-input" @bind="formProveedor" list="oem-proveedores" placeholder="COLOMBRARO" />
                        <datalist id="oem-proveedores">
                            @foreach (var p in proveedoresExistentes) { <option value="@p" /> }
                        </datalist>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Descripción</label>
                    <input class="form-input" @bind="formDescripcion" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Marca</label>
                        <input class="form-input" @bind="formMarca" list="oem-marcas-list" />
                        <datalist id="oem-marcas-list">
                            @if (marcasCatalog is not null)
                            {
                                @foreach (var m in marcasCatalog.Where(x => x.IsActive).OrderBy(x => x.Nombre))
                                {
                                    <option value="@m.Nombre" />
                                }
                            }
                        </datalist>
                        @{
                            var matched = !string.IsNullOrWhiteSpace(formMarca)
                                ? marcasCatalog?.FirstOrDefault(x => string.Equals(x.Nombre, formMarca?.Trim(), StringComparison.OrdinalIgnoreCase))
                                : null;
                        }
                        @if (matched is not null && !string.IsNullOrEmpty(matched.ProveedorNombre))
                        {
                            <p style="font-size: 0.7rem; color: #15803d; margin: 0.2rem 0 0; font-weight: 600;">
                                ✓ Proveedor: @matched.ProveedorNombre
                            </p>
                        }
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Código de barras</label>
                        <input class="form-input" @bind="formBarcode" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Costo (sin IVA)</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="formCosto" />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">PVP (con IVA)</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="formPvpConIva" />
                    </div>
                    <div class="form-group" style="flex: 0 0 100px;">
                        <label class="form-label">IVA %</label>
                        <input class="form-input" type="number" step="0.01" @bind="formIvaPct" />
                    </div>
                    <div class="form-group" style="flex: 0 0 100px;">
                        <label class="form-label">UxB</label>
                        <input class="form-input" type="number" step="1" min="0" @bind="formUxB" />
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">u/bulto</p>
                    </div>
                </div>
                @* 2026-06-10: URL al producto en el sitio del proveedor (ej: colombraro.com.ar) *@
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">🔗 URL del producto en la web del proveedor</label>
                        <input class="form-input" @bind="formUrlWeb" placeholder="https://www.colombraro.com.ar/producto/..." />
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">
                            @if (!string.IsNullOrWhiteSpace(formUrlWeb))
                            {
                                <a href="@formUrlWeb" target="_blank" rel="noopener" style="color:#2563eb; text-decoration:underline;">
                                    🌐 Abrir página del producto
                                </a>
                            }
                            else
                            {
                                <span>Opcional. Lo usás para ver foto, dimensiones y descripción larga.</span>
                            }
                        </p>
                    </div>
                </div>

                @* 2026-06-11: scraping de info de la web del proveedor *@
                @if (editing is not null && !string.IsNullOrWhiteSpace(formUrlWeb))
                {
                    <div style="margin-top: 0.8rem; padding: 0.8rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 0.5rem;">
                        <div style="display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.6rem;">
                            <button type="button" class="btn btn-secondary" @onclick="DoScrapeWeb" disabled="@scrapingNow"
                                style="background: #2563eb; color: white; border: none;">
                                @(scrapingNow ? "⏳ Trayendo datos..." : "🌐 Traer datos de la web")
                            </button>
                            @if (editing.ScrapedAt.HasValue)
                            {
                                <span style="font-size: 0.75rem; color: #6b7280;">
                                    Última actualización: @editing.ScrapedAt.Value.ToArTime().ToString("dd/MM/yyyy HH:mm")
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(scrapeError))
                        {
                            <div style="padding: 0.5rem; background: #fee2e2; color: #991b1b; border-radius: 0.3rem; font-size: 0.8rem; margin-bottom: 0.5rem;">
                                @scrapeError
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(editing.ImagenUrl) || !string.IsNullOrWhiteSpace(editing.DescripcionWeb) || !string.IsNullOrWhiteSpace(editing.EspecificacionesJson))
                        {
                            <div style="display: grid; grid-template-columns: 140px 1fr; gap: 0.8rem; align-items: start;">
                                @if (!string.IsNullOrWhiteSpace(editing.ImagenUrl))
                                {
                                    <img src="@editing.ImagenUrl" alt="@(editing.Descripcion ?? "")" style="width: 140px; height: 140px; object-fit: contain; background: white; border: 1px solid #e5e7eb; border-radius: 0.3rem;" />
                                }
                                else
                                {
                                    <div style="width: 140px; height: 140px; background: #e5e7eb; border-radius: 0.3rem; display: flex; align-items: center; justify-content: center; color: #9ca3af;">Sin imagen</div>
                                }
                                <div style="font-size: 0.8rem;">
                                    @if (!string.IsNullOrWhiteSpace(editing.DescripcionWeb))
                                    {
                                        <div style="color: #374151; margin-bottom: 0.5rem;">@editing.DescripcionWeb</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(editing.EspecificacionesJson))
                                    {
                                        <div style="display: grid; grid-template-columns: auto 1fr; gap: 0.2rem 0.8rem; font-size: 0.75rem;">
                                            @foreach (var kv in ParseEspecificaciones(editing.EspecificacionesJson))
                                            {
                                                <div style="color: #6b7280; font-weight: 500;">@kv.Key:</div>
                                                <div style="color: #111827;">@kv.Value</div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" @onclick="DoSave" disabled="@saving">
                    @(saving ? "Guardando..." : "💾 Guardar")
                </button>
            </div>
        </div>
    </div>
}

@* 2026-06-11: modal de confirmacion para arrancar el scraping masivo *@
@if (showScrapeMasivoConfirm)
{
    <div class="modal-overlay" @onclick="() => showScrapeMasivoConfirm = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 540px;">
            <div class="modal-header" style="background: #2563eb; color: white;">
                <h3 style="margin: 0;">🌐 Traer info de la web del proveedor</h3>
                <button class="btn-close" @onclick="() => showScrapeMasivoConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #374151; margin: 0 0 0.8rem;">
                    Esto recorre <strong>todos los OEMs que tienen URL cargada</strong> y baja la imagen + descripción + ficha técnica de la web del proveedor.
                </p>
                <div class="form-group">
                    <label class="form-label">¿Qué OEMs procesar?</label>
                    <label style="display: flex; gap: 0.4rem; align-items: center; font-size: 0.85rem; padding: 0.4rem 0;">
                        <input type="radio" name="rmas" checked="@masivoSoloFaltantes" @onchange="() => masivoSoloFaltantes = true" />
                        <span>Solo los <strong>faltantes</strong> (todavía no tienen info de la web) — recomendado</span>
                    </label>
                    <label style="display: flex; gap: 0.4rem; align-items: center; font-size: 0.85rem; padding: 0.4rem 0;">
                        <input type="radio" name="rmas" checked="@(!masivoSoloFaltantes)" @onchange="() => masivoSoloFaltantes = false" />
                        <span><strong>TODOS</strong> los que tengan URL (refresca también los ya descargados)</span>
                    </label>
                </div>
                <p style="font-size: 0.78rem; color: #6b7280; margin: 0.6rem 0 0;">
                    El proceso corre en segundo plano. Vas a ver una barra de progreso arriba. Podés cerrar esta ventana, salir de la pantalla y volver más tarde — sigue corriendo.
                </p>
                @if (!string.IsNullOrEmpty(masivoStartError))
                {
                    <div style="padding: 0.5rem; background: #fee2e2; color: #991b1b; border-radius: 0.3rem; font-size: 0.8rem; margin-top: 0.6rem;">
                        @masivoStartError
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showScrapeMasivoConfirm = false">Cancelar</button>
                <button class="btn" style="background: #2563eb; color: white; border: none;" @onclick="DoScrapeMasivoStart">
                    🌐 Empezar
                </button>
            </div>
        </div>
    </div>
}

@if (showImport)
{
    <div class="modal-overlay" @onclick="CloseImport">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 600px;">
            <div class="modal-header" style="background: #16a34a; color: white;">
                <h3 style="margin: 0;">📥 Importar lista de OEMs</h3>
                <button class="btn-close" @onclick="CloseImport" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                @if (importResult is not null)
                {
                    @* ── Paso 3: resultado final ── *@
                    <div style="background: #dcfce7; border: 1px solid #15803d; border-radius: 8px; padding: 0.8rem; margin-bottom: 0.6rem;">
                        <h4 style="margin: 0 0 0.4rem; color: #15803d;">✓ Importación lista</h4>
                        <ul style="margin: 0; padding-left: 1.2rem; font-size: 0.85rem;">
                            <li><strong>@importResult.Creados</strong> nuevos</li>
                            <li><strong>@importResult.Actualizados</strong> actualizados</li>
                            @if (importResult.Omitidos > 0)
                            {
                                <li><strong>@importResult.Omitidos</strong> omitidos (filas vacías o de ejemplo)</li>
                            }
                            <li>Proveedor: <strong>@importResult.Proveedor</strong></li>
                            @if (importResult.VariantesPropagadas > 0)
                            {
                                <li><strong>@importResult.VariantesPropagadas</strong> variante@(importResult.VariantesPropagadas == 1 ? "" : "s") con precios actualizados (propagación automática)</li>
                            }
                        </ul>
                    </div>
                    @if (importResult.Errores.Count > 0)
                    {
                        <div class="form-error">
                            <strong>Errores:</strong>
                            <ul style="margin: 0.3rem 0 0 1rem;">
                                @foreach (var e in importResult.Errores) { <li>@e</li> }
                            </ul>
                        </div>
                    }
                }
                else if (importPreview is not null)
                {
                    @* ── Paso 2: vista previa (nada aplicado todavía) ── *@
                    <div style="background: #eff6ff; border: 1px solid #2563eb; border-radius: 8px; padding: 0.8rem; margin-bottom: 0.8rem;">
                        <h4 style="margin: 0 0 0.4rem; color: #1d4ed8;">👁️ Vista previa — todavía NO se aplicó nada</h4>
                        <ul style="margin: 0; padding-left: 1.2rem; font-size: 0.85rem;">
                            <li>Se van a <strong>crear</strong> @importPreview.Creados OEM@(importPreview.Creados == 1 ? "" : "s") nuevo@(importPreview.Creados == 1 ? "" : "s")</li>
                            <li>Se van a <strong>actualizar</strong> @importPreview.Actualizados OEM@(importPreview.Actualizados == 1 ? "" : "s") ya existente@(importPreview.Actualizados == 1 ? "" : "s")</li>
                            @if (importPreview.Omitidos > 0)
                            {
                                <li>@importPreview.Omitidos fila@(importPreview.Omitidos == 1 ? "" : "s") omitida@(importPreview.Omitidos == 1 ? "" : "s") (vacías o de ejemplo)</li>
                            }
                        </ul>
                    </div>
                    @if (!importPreview.TieneColumnaCosto && !importPreview.TieneColumnaPvp)
                    {
                        <div style="background: #fef2f2; border: 1px solid #dc2626; border-radius: 8px; padding: 0.7rem; margin-bottom: 0.8rem; font-size: 0.82rem; color: #991b1b;">
                            ⚠️ El Excel no tiene ninguna columna de precio reconocida (<code>precio_costo</code> / <code>precio_venta_con_iva</code>).
                            Se van a tocar códigos y descripciones, pero <strong>los precios NO se van a cambiar</strong>.
                            Si querías actualizar precios, bajá la plantilla y usá esos títulos.
                        </div>
                    }

                    <p style="font-size: 0.82rem; color: #4b5563; margin: 0 0 0.4rem;">
                        <strong>@CambiosRelevantes.Count</strong> fila@(CambiosRelevantes.Count == 1 ? "" : "s") con cambios de precio o nuevas
                        (de @importPreview.Cambios.Count en total):
                    </p>
                    <div style="max-height: 280px; overflow: auto; border: 1px solid #e5e7eb; border-radius: 8px;">
                        <table class="data-table" style="font-size: 0.78rem;">
                            <thead>
                                <tr>
                                    <th>Código</th>
                                    <th>Descripción</th>
                                    <th style="text-align: right;">Costo</th>
                                    <th style="text-align: right;">PVP c/IVA</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in CambiosRelevantes.Take(500))
                                {
                                    <tr>
                                        <td>
                                            <strong>@c.Codigo</strong>
                                            @if (c.EsNuevo) { <span style="background:#16a34a;color:white;border-radius:4px;padding:0 4px;font-size:0.68rem;margin-left:4px;">NUEVO</span> }
                                        </td>
                                        <td style="max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@c.Descripcion</td>
                                        <td style="text-align: right;">
                                            @if (c.CambiaCosto && !c.EsNuevo)
                                            {
                                                <span style="color:#9ca3af;text-decoration:line-through;">$@FormatMoney(c.CostoViejo ?? 0)</span>
                                                <span> → <strong>$@FormatMoney(c.CostoNuevo ?? 0)</strong></span>
                                            }
                                            else if (c.EsNuevo && c.CostoNuevo.HasValue)
                                            {
                                                <strong>$@FormatMoney(c.CostoNuevo.Value)</strong>
                                            }
                                            else { <span style="color:#9ca3af;">=</span> }
                                        </td>
                                        <td style="text-align: right;">
                                            @if (c.CambiaPvp && !c.EsNuevo)
                                            {
                                                <span style="color:#9ca3af;text-decoration:line-through;">$@FormatMoney(c.PvpViejo ?? 0)</span>
                                                <span> → <strong style="color:#15803d;">$@FormatMoney(c.PvpNuevo ?? 0)</strong></span>
                                            }
                                            else if (c.EsNuevo && c.PvpNuevo.HasValue)
                                            {
                                                <strong style="color:#15803d;">$@FormatMoney(c.PvpNuevo.Value)</strong>
                                            }
                                            else { <span style="color:#9ca3af;">=</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (CambiosRelevantes.Count > 500)
                    {
                        <p style="font-size: 0.75rem; color: #6b7280; margin: 0.4rem 0 0;">Mostrando las primeras 500. Al confirmar se aplican todas.</p>
                    }
                    @if (!string.IsNullOrEmpty(importError))
                    {
                        <div class="form-error" style="margin-top: 0.6rem;">@importError</div>
                    }
                }
                else
                {
                    @* ── Paso 1: elegir archivo ── *@
                    <p style="font-size: 0.85rem; color: #4b5563;">
                        Subí el Excel del proveedor (.xlsx). ¿No tenés el formato? Cerrá y tocá
                        <strong>"⬇️ Descargar plantilla"</strong> para bajar el modelo con las columnas correctas.
                    </p>
                    <p style="font-size: 0.78rem; color: #6b7280; margin-bottom: 0.8rem;">
                        <strong>Comportamiento:</strong> Si un código ya existe, se actualiza el costo / PVP / etc.
                        Si no existe, se crea nuevo. <strong>Nada se elimina.</strong> Antes de aplicar vas a ver una vista previa.
                    </p>
                    <div class="form-group">
                        <label class="form-label">Proveedor (etiqueta para esta lista)</label>
                        <input class="form-input" @bind="importProveedor" placeholder="COLOMBRARO" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Archivo .xlsx</label>
                        <InputFile OnChange="OnFileChange" accept=".xlsx" class="form-input" />
                        @if (importFile is not null)
                        {
                            <p style="font-size: 0.78rem; color: #15803d; margin: 0.3rem 0 0;">
                                ✓ @importFile.Name (@(FormatBytes(importFile.Size)))
                            </p>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(importError))
                    {
                        <div class="form-error">@importError</div>
                    }
                }
            </div>
            <div class="modal-footer">
                @if (importResult is not null)
                {
                    <button class="btn btn-primary" @onclick="CloseImport">Cerrar</button>
                }
                else if (importPreview is not null)
                {
                    <button class="btn btn-secondary" @onclick="VolverAElegirArchivo" disabled="@isImporting">← Volver</button>
                    <button class="btn" style="background: #16a34a; color: white; border: none;" @onclick="DoImport" disabled="@isImporting">
                        @(isImporting ? "Aplicando..." : "✓ Confirmar e importar")
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary" @onclick="CloseImport" disabled="@isPreviewing">Cancelar</button>
                    <button class="btn" style="background: #2563eb; color: white; border: none;" @onclick="DoPreview" disabled="@(isPreviewing || importFile is null)">
                        @(isPreviewing ? "Analizando..." : "👁️ Ver vista previa")
                    </button>
                }
            </div>
        </div>
    </div>
}

@if (showVariantes && variantesOem is not null)
{
    <div class="modal-overlay" @onclick="CloseVariantes">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 780px;">
            <div class="modal-header" style="background: #15803d; color: white;">
                <h3 style="margin: 0;">🔗 Productos vinculados al OEM @variantesOem.Codigo</h3>
                <button class="btn-close" @onclick="CloseVariantes" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.82rem; color: #4b5563; margin: 0 0 0.6rem;">
                    @variantesOem.Descripcion
