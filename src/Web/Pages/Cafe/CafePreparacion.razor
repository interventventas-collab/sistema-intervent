@page "/cafe/preparacion"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject ToastService ToastService
@inject OperatorService Operator
@inject NavigationManager Navigation

<style>
    /* Tablero de Preparacion: cards GRANDES con cantidades resaltadas. Estilo
       "ticket de cocina" — los chicos del deposito tienen que poder leerlo de un vistazo. */
    .prep-section {
        margin-bottom: 1.2rem;
    }
    .prep-section-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 0.8rem;
        background: #f9fafb;
        border-left: 4px solid #e5e7eb;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        user-select: none;
    }
    .prep-section-header.armar { border-left-color: #f59e0b; background: #fffbeb; color: #92400e; }
    .prep-section-header.listos { border-left-color: #3b82f6; background: #eff6ff; color: #1e40af; }
    .prep-section-header.entregados { border-left-color: #10b981; background: #f0fdf4; color: #166534; }
    .prep-count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 28px; height: 28px;
        padding: 0 0.5rem;
        background: rgba(0,0,0,0.08);
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 800;
        margin-left: auto;
    }
    .prep-cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
        gap: 1rem;
        padding: 0.8rem 0;
    }
    /* Cards compactas para "Listos y en camino" — caben mas por fila, sin detalle de items */
    .prep-cards-compact {
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 0.7rem;
    }
    .prep-card-compact .prep-card-header { padding: 0.5rem 0.8rem; }
    .prep-card-compact .prep-card-cliente { font-size: 0.95rem; }
    .prep-card-compact-footer {
        padding: 0.4rem 0.7rem;
        background: #fafafa;
        border-top: 1px solid #f3f4f6;
        display: flex;
        gap: 0.4rem;
        align-items: center;
    }
    /* Boton "X" para quitar la venta del tablero — la devuelve a /cafe/ventas como si nunca
       hubiera entrado al flujo. Posicionado arriba a la derecha del header. */
    .prep-btn-quitar {
        position: absolute;
        top: 4px;
        right: 6px;
        width: 22px; height: 22px;
        border: none;
        background: rgba(0, 0, 0, 0.08);
        color: #4b5563;
        border-radius: 50%;
        cursor: pointer;
        font-size: 1.1rem;
        line-height: 1;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s;
    }
    .prep-btn-quitar:hover {
        background: #dc2626;
        color: white;
        transform: scale(1.1);
    }
    .prep-card-header { position: relative; padding-right: 30px; }
    .prep-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        overflow: hidden;
        transition: box-shadow 0.2s;
    }
    .prep-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.08); }
    .prep-card-header {
        padding: 0.7rem 1rem;
        background: #fef3c7;
        border-bottom: 1px solid #fcd34d;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        font-size: 0.9rem;
    }
    .prep-card-header.armar { background: #fef3c7; border-bottom-color: #fcd34d; }
    .prep-card-header.preparando { background: #fed7aa; border-bottom-color: #fb923c; }
    .prep-card-header.listo { background: #dbeafe; border-bottom-color: #93c5fd; }
    .prep-card-header.encamino { background: #e9d5ff; border-bottom-color: #c084fc; }
    .prep-card-numero { font-family: monospace; font-weight: 800; font-size: 0.85rem; color: #374151; }
    .prep-card-cliente { font-weight: 700; font-size: 1rem; color: #111827; }
    .prep-card-meta { font-size: 0.78rem; color: #6b7280; }
    .prep-card-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        padding: 0.15rem 0.45rem;
        border-radius: 999px;
        background: rgba(0,0,0,0.06);
        font-size: 0.72rem;
        font-weight: 600;
        color: #374151;
    }
    .prep-card-body {
        padding: 0.6rem 0;
    }
    .prep-item {
        display: grid;
        grid-template-columns: 32px 60px 1fr;
        gap: 0.6rem;
        padding: 0.55rem 1rem;
        align-items: center;
        border-bottom: 1px dashed #f3f4f6;
    }
    .prep-item:last-child { border-bottom: none; }
    .prep-item.tildado .prep-item-desc,
    .prep-item.tildado .prep-item-cant { text-decoration: line-through; opacity: 0.5; }
    .prep-check {
        width: 28px; height: 28px;
        cursor: pointer;
    }
    .prep-item-cant {
        font-size: 1.8rem;
        font-weight: 800;
        color: #ea580c;
        text-align: right;
        line-height: 1;
    }
    .prep-item-cant .x { font-size: 1.1rem; color: #9ca3af; font-weight: 600; }
    .prep-item-desc-prod {
        font-size: 1.05rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.2;
    }
    .prep-item-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-top: 0.25rem;
    }
    .prep-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
        padding: 0.1rem 0.45rem;
        border-radius: 4px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .prep-tag-formato { background: #f3f4f6; color: #374151; }
    .prep-tag-molienda { background: #fef3c7; color: #92400e; }
    .prep-tag-envase-negro { background: #1f2937; color: #fff; }
    .prep-tag-envase-plateado { background: #e5e7eb; color: #374151; border: 1px solid #9ca3af; }
    .prep-tag-envase-doypack { background: #dcfce7; color: #166534; }
    .prep-card-footer {
        padding: 0.55rem 1rem;
        background: #fafafa;
        border-top: 1px solid #f3f4f6;
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }
    .prep-btn-avanzar {
        flex: 1;
        padding: 0.6rem;
        border-radius: 6px;
        border: none;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.15s;
    }
    .prep-btn-avanzar.armar { background: #f59e0b; color: white; }
    .prep-btn-avanzar.armar:hover { background: #d97706; }
    .prep-btn-avanzar.preparando { background: #3b82f6; color: white; }
    .prep-btn-avanzar.preparando:hover { background: #2563eb; }
    .prep-btn-avanzar.listo { background: #8b5cf6; color: white; }
    .prep-btn-avanzar.listo:hover { background: #7c3aed; }
    .prep-btn-avanzar.encamino { background: #10b981; color: white; }
    .prep-btn-avanzar.encamino:hover { background: #059669; }
    .prep-btn-avanzar.todo-tildado { background: #16a34a !important; animation: pulse-listo 1.5s infinite; }
    @@keyframes pulse-listo { 0%, 100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.5); } 50% { box-shadow: 0 0 0 8px rgba(22, 163, 74, 0); } }
    .prep-btn-retroceder {
        padding: 0.6rem 0.7rem;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        background: white;
        color: #6b7280;
        cursor: pointer;
        font-size: 0.85rem;
    }
    .prep-btn-retroceder:hover { background: #f3f4f6; }
    /* Botones para abrir el PDF del comprobante en Google Drive — full (con texto) y compact (solo logo). */
    .prep-btn-drive-full {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 0.7rem;
        border-radius: 6px;
        border: 1px solid #4285f4;
        background: white;
        color: #1a73e8;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
    }
    .prep-btn-drive-full:hover { background: #e8f0fe; }
    .prep-btn-drive {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.4rem 0.45rem;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        background: white;
        cursor: pointer;
    }
    .prep-btn-drive:hover { background: #f3f4f6; }
    /* Grid de pedidos estilo Drive: cards uniformes y compactas (solo header por default).
       Cuando el armador despliega la composicion, la card crece pero el resto se reordena. */
    .drive-pedidos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 0.7rem;
        align-items: start;
    }
    @@media (max-width: 768px) {
        .drive-pedidos-grid { grid-template-columns: 1fr; }
    }
    /* Boton "Ver composicion" debajo del header, antes del body. Por default cerrado. */
    .prep-btn-ver-comp {
        width: 100%;
        padding: 0.5rem;
        border: none;
        border-top: 1px solid #fde68a;
        background: #fffbeb;
        color: #92400e;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.1s;
    }
    .prep-btn-ver-comp:hover { background: #fef3c7; }
    /* Mini impresora — boton + checkbox en cards de clientes con flag TieneMiniImpresora */
    .prep-mini-impresora-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        flex-shrink: 0;
    }
    .prep-btn-mini-impresora {
        background: #1e40af;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 1.3rem;
        line-height: 1;
        padding: 0.45rem 0.6rem;
        cursor: pointer;
        box-shadow: 0 2px 4px rgba(30,64,175,0.25);
        transition: all 0.1s;
    }
    .prep-btn-mini-impresora:hover { background: #1e3a8a; transform: scale(1.05); }
    .prep-check-print-wrap { display:flex; flex-direction:column; align-items:center; cursor:pointer; }
    .prep-check-print { width: 18px; height: 18px; cursor: pointer; accent-color: #1e40af; }
    .prep-card-pill-impresa { background: #dcfce7 !important; color: #166534 !important; }
    .prep-card.prep-card-selected {
        outline: 3px solid #1e40af;
        outline-offset: -1px;
        background: #eff6ff;
    }
    /* Bar fija con boton "Imprimir N seleccionados" que aparece cuando hay >= 1 card tildada */
    .prep-print-bar {
        position: sticky;
        top: 0;
        z-index: 5;
        background: #1e40af;
        color: white;
        padding: 0.7rem 1rem;
        border-radius: 8px;
        margin-bottom: 0.7rem;
        display: flex;
        align-items: center;
        gap: 0.7rem;
        box-shadow: 0 4px 12px rgba(30,64,175,0.3);
        animation: slide-down-print-bar 0.2s ease-out;
    }
    @@keyframes slide-down-print-bar { from { transform: translateY(-10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .prep-print-bar button {
        background: white;
        color: #1e40af;
        border: none;
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        font-weight: 700;
        cursor: pointer;
        font-size: 0.88rem;
    }
    .prep-print-bar button:hover { background: #dbeafe; }
    .prep-print-bar button.ghost { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); }
    .prep-print-bar button.ghost:hover { background: rgba(255,255,255,0.15); }
    /* Seccion "Ya armados" — header colapsable + grid mini */
    .prep-armados-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 0.8rem;
        background: #f0fdf4;
        border-left: 4px solid #16a34a;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 700;
        color: #166534;
        cursor: pointer;
        user-select: none;
        margin-top: 1.5rem;
    }
    .prep-armado-mini {
        background: white;
        border: 1px solid #d1fae5;
        border-radius: 8px;
        padding: 0.6rem 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.85rem;
    }
    .prep-armado-mini .pdf-icon-mini {
        width: 28px; height: 36px; flex-shrink: 0;
    }
    .prep-armado-mini .check-armado {
        margin-left: auto;
        background: #dcfce7;
        color: #166534;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    /* Icono PDF rojo estilo Drive (caja con esquina doblada). Click → abre en Drive. */
    .prep-drive-icon-link { display:inline-block; text-decoration:none; transition: transform .1s; }
    .prep-drive-icon-link:hover { transform: scale(1.05); }
    .prep-drive-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 60px;
        flex-shrink: 0;
        filter: drop-shadow(0 1px 2px rgba(0,0,0,0.15));
    }
    .prep-entregados-lista {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.6rem;
        margin-top: 0.5rem;
    }
    .prep-entregado-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.4rem 0.5rem;
        border-bottom: 1px solid #f3f4f6;
        font-size: 0.85rem;
    }
    .prep-entregado-row:last-child { border-bottom: none; }
    .prep-empty {
        padding: 1.5rem;
        text-align: center;
        color: #9ca3af;
        font-style: italic;
    }
    .prep-header-toolbar {
        display: flex;
        gap: 0.7rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }
    .prep-refresh-indicator {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.78rem;
        color: #6b7280;
        margin-left: auto;
    }
</style>

<div class="content-container" style="padding: 0.8rem;">
    <div class="prep-header-toolbar">
        <h2 style="margin: 0; display:flex; align-items:center; gap:0.5rem;">
            @* Logo oficial de Google Drive para que el armador asocie visualmente esta pantalla
               con la carpeta de Drive que ya usaba antes ("IMPRIMIR PEDIDOS DE OSMAR"). *@
            <svg width="22" height="20" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg">
                <path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da"/>
                <path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44c-.8 1.4-1.2 2.95-1.2 4.5h27.5z" fill="#00ac47"/>
                <path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z" fill="#ea4335"/>
                <path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d"/>
                <path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc"/>
                <path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00"/>
            </svg>
            IMPRIMIR PEDIDOS DE OSMAR
        </h2>
        <button class="btn btn-secondary" @onclick="Cargar" title="Refrescar manualmente">🔄 Refrescar</button>
        <a class="btn btn-secondary" href="https://drive.google.com/drive/folders/193CHGuunMIQX9LvpsQHyLK3m3IiIXBBH" target="_blank"
           title="Abrir la carpeta IMPRIMIR PEDIDOS DE OSMAR en Google Drive (otra pestaña)"
           style="text-decoration:none;">
            📁 Abrir carpeta en Drive
        </a>
        @if (ParaArmar.Count > 0)
        {
            <button class="btn btn-secondary" @onclick="LimpiarTablero"
                    title="Saca todos los pedidos actuales del tablero. Las ventas y los PDFs en Drive quedan intactos. Los nuevos pedidos que subas a Drive vuelven a aparecer."
                    style="color:#b91c1c; border-color:#fca5a5;">
                🧹 Limpiar tablero
            </button>
        }
        <span class="prep-refresh-indicator">
            Auto-refresh cada 10 s · última: @ultimaActualizacion.ToString("HH:mm:ss")
        </span>
    </div>

    @if (loading && lista is null)
    {
        <p>Cargando...</p>
    }
    else
    {
        @* Bar flotante de impresion multiple (aparece cuando hay >= 1 card tildada) *@
        @if (seleccionadosParaImprimir.Count > 0)
        {
            <div class="prep-print-bar">
                <span style="font-size:1.2rem;">🖨️</span>
                <strong>@seleccionadosParaImprimir.Count pedido@(seleccionadosParaImprimir.Count == 1 ? "" : "s") seleccionado@(seleccionadosParaImprimir.Count == 1 ? "" : "s")</strong>
                <button @onclick="ImprimirSeleccionados">Imprimir todo junto</button>
                <button class="ghost" @onclick="LimpiarSeleccion">Limpiar selección</button>
            </div>
        }

        @* ── PEDIDOS PARA ARMAR (todos los que están subidos a Drive y no están listos) ── *@
        @if (ParaArmar.Count == 0)
        {
            <div class="prep-empty" style="padding:2rem; font-size:1rem;">
                No hay pedidos para armar. ¡Buen trabajo! 🎉
                <div style="margin-top:0.5rem; color:#6b7280; font-size:0.85rem;">
                    Para que aparezcan acá, subí los comprobantes a Drive desde /cafe/ventas.
                </div>
            </div>
        }
        else
        {
            <div class="drive-pedidos-grid">
                @foreach (var v in ParaArmar)
                {
                    <CardPedido Venta="v"
                                SelectedForPrint="seleccionadosParaImprimir.Contains(v.Id)"
                                OnAvanzar="() => Avanzar(v)"
                                OnQuitarDelFlujo="() => QuitarDelFlujo(v)"
                                OnImprimir="() => ImprimirUno(v)"
                                OnToggleSelectForPrint="(sel) => ToggleSeleccion(v.Id, sel)" />
                }
            </div>
        }

        @* ── SECCION COLAPSABLE: YA ARMADOS (historial con rango configurable) ── *@
        <div class="prep-armados-header">
            <span @onclick="ToggleArmados" style="cursor:pointer;">@(armadosExpanded ? "▼" : "▶")</span>
            <span @onclick="ToggleArmados" style="cursor:pointer;">📦 Ya armados (@RangoLabel(rangoArmados))</span>
            @if (armadosExpanded)
            {
                <select value="@rangoArmados" @onchange="OnRangoArmadosChange"
                        @onclick:stopPropagation="true"
                        style="margin-left:0.75rem; padding:0.25rem 0.5rem; border-radius:6px; border:1px solid #d1d5db; font-size:0.85rem; background:white;">
                    <option value="hoy">Hoy</option>
                    <option value="ayer">Ayer</option>
                    <option value="7d">Últimos 7 días</option>
                    <option value="30d">Último mes</option>
                    <option value="todos">Todos</option>
                </select>
            }
            <span style="margin-left:auto; font-weight:600;">@(armados?.Count ?? 0)</span>
        </div>
        @if (armadosExpanded)
        {
            @if (armados is null)
            {
                <p style="padding:0.5rem;">Cargando historial...</p>
            }
            else if (armados.Count == 0)
            {
                <div class="prep-empty">Todavía no hay pedidos marcados como LISTO en este rango.</div>
            }
            else
            {
                <div class="drive-pedidos-grid" style="margin-top:0.5rem;">
                    @foreach (var v in armados)
                    {
                        <div class="prep-armado-mini">
                            @if (v.DriveSubidoAt.HasValue && !string.IsNullOrEmpty(v.DriveFileId))
                            {
                                <a href="https://drive.google.com/file/d/@v.DriveFileId/view" target="_blank" title="Abrir PDF en Drive" style="text-decoration:none;">
                                    <svg class="pdf-icon-mini" viewBox="0 0 24 30" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M14 0H4C1.79 0 0 1.79 0 4v22c0 2.21 1.79 4 4 4h16c2.21 0 4-1.79 4-4V10L14 0z" fill="#ea4335"/>
                                        <text x="12" y="22" text-anchor="middle" fill="white" font-size="6" font-weight="700" font-family="Arial">PDF</text>
                                    </svg>
                                </a>
                            }
                            <div style="flex:1; min-width:0;">
                                <div style="font-family:monospace; font-size:0.78rem; color:#6b7280;">@v.Numero</div>
                                <div style="font-weight:700;">@v.ClienteNombre</div>
                                @if (v.PreparacionUpdatedAt.HasValue)
                                {
                                    <div style="font-size:0.72rem; color:#16a34a;">✅ Armado @HaceCuanto(v.PreparacionUpdatedAt)</div>
                                }
                            </div>
                            <span class="check-armado">@v.EstadoPreparacion</span>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private List<CafePreparacionVentaDto>? lista;
    private List<CafePreparacionVentaDto>? armados;
    private bool armadosExpanded = false;
    private string rangoArmados = "7d";  // hoy / ayer / 7d / 30d / todos

    private static string RangoLabel(string r) => r switch
    {
        "hoy" => "hoy",
        "ayer" => "ayer",
        "30d" => "último mes",
        "todos" => "todos",
        _ => "últimos 7 días"
    };
    private bool loading = true;
    private DateTime ultimaActualizacion = DateTime.Now;
    private System.Threading.Timer? refreshTimer;
    // Seleccion multiple para imprimir varios juntos.
    private HashSet<int> seleccionadosParaImprimir = new();

    // El backend ya filtra por DriveSubidoAt != null + estados no-finalizados, así que mostramos todo lo que viene.
    private List<CafePreparacionVentaDto> ParaArmar => lista ?? new();

    protected override async Task OnInitializedAsync()
    {
        await Operator.LoadAsync();
        await Cargar();
        // Auto-refresh cada 10 segundos
        refreshTimer = new System.Threading.Timer(async _ => await InvokeAsync(Cargar), null, 10000, 10000);
    }

    private async Task Cargar()
    {
        loading = true;
        try
        {
            lista = await Api.GetCafePreparacionAsync(7) ?? new();
            ultimaActualizacion = DateTime.Now;
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar: " + ex.Message);
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task ToggleArmados()
    {
        armadosExpanded = !armadosExpanded;
        if (armadosExpanded && armados is null)
        {
            armados = await Api.GetCafePreparacionArmadosAsync(rangoArmados) ?? new();
        }
        StateHasChanged();
    }

    private async Task OnRangoArmadosChange(ChangeEventArgs e)
    {
        rangoArmados = e.Value?.ToString() ?? "7d";
        armados = null;  // fuerza loading mientras llega
        StateHasChanged();
        armados = await Api.GetCafePreparacionArmadosAsync(rangoArmados) ?? new();
        StateHasChanged();
    }

    private void ToggleSeleccion(int ventaId, bool seleccionar)
    {
        if (seleccionar) seleccionadosParaImprimir.Add(ventaId);
        else seleccionadosParaImprimir.Remove(ventaId);
        StateHasChanged();
    }

    private void LimpiarSeleccion()
    {
        seleccionadosParaImprimir.Clear();
        StateHasChanged();
    }

    /// <summary>Imprimir UN ticket: abre el PDF en pestaña nueva y marca como impresa.</summary>
    private async Task ImprimirUno(CafePreparacionVentaDto v)
    {
        var url = Api.GetImprimirPdfCombinadoUrl(new[] { v.Id });
        // Marcamos como impresa en background y abrimos PDF en pestaña nueva
        // (el endpoint en sí también marca, pero refleja en UI tambien)
        v.ImpresaAt = DateTime.UtcNow;
        v.ImpresaCount = v.ImpresaCount + 1;
        StateHasChanged();
        await JS.InvokeVoidAsync("window.open", url, "_blank");
    }

    /// <summary>Imprimir VARIOS: genera un PDF combinado con todos los seleccionados.</summary>
    private async Task ImprimirSeleccionados()
    {
        if (seleccionadosParaImprimir.Count == 0) return;
        var ids = seleccionadosParaImprimir.ToList();
        var url = Api.GetImprimirPdfCombinadoUrl(ids);
        // Marcamos cada uno como impreso en UI (el endpoint ya los marca en la DB)
        var ahora = DateTime.UtcNow;
        if (lista is not null)
        {
            foreach (var v in lista.Where(x => ids.Contains(x.Id)))
            {
                v.ImpresaAt = ahora;
                v.ImpresaCount = v.ImpresaCount + 1;
            }
        }
        ToastService.Success($"Generando PDF combinado con {ids.Count} ticket{(ids.Count == 1 ? "" : "s")}...");
        await JS.InvokeVoidAsync("window.open", url, "_blank");
        seleccionadosParaImprimir.Clear();
        StateHasChanged();
    }

    private async Task Avanzar(CafePreparacionVentaDto v)
    {
        // 2026-05-28: el flujo se simplifico — un solo click marca como LISTO y la venta sale
        // del tablero (porque el endpoint /preparacion solo trae ventas en estado armado o null).
        const string siguiente = "LISTO";
        var ok = await Api.CambiarEstadoPreparacionAsync(v.Id, new CafeCambiarEstadoPreparacionRequest
        {
            EstadoNuevo = siguiente,
            OperadorNombre = Operator.Current ?? ""
        });
        if (ok)
        {
            // Sacar la venta de la lista local para que desaparezca al toque (sin esperar refresh)
            lista?.RemoveAll(x => x.Id == v.Id);
            ToastService.Success($"{v.Numero} marcado como LISTO ✅");
            StateHasChanged();
        }
        else
        {
            ToastService.Error("No se pudo marcar como LISTO");
        }
    }

    /// <summary>Saca UNA venta del tablero (la oculta). La venta y el PDF en Drive quedan intactos.</summary>
    private async Task QuitarDelFlujo(CafePreparacionVentaDto v)
    {
        var ok = await Api.OcultarPreparacionAsync(v.Id);
        if (ok)
        {
            lista?.RemoveAll(x => x.Id == v.Id);
            ToastService.Info($"{v.Numero} sacado del tablero");
            StateHasChanged();
        }
        else
        {
            ToastService.Error("No se pudo quitar del tablero");
        }
    }

    /// <summary>Saca TODAS las ventas que estan ahora en el tablero. Las nuevas que se suban
    /// a Drive a partir de aca, aparecen de nuevo.</summary>
    private async Task LimpiarTablero()
    {
        var n = await Api.LimpiarTableroPreparacionAsync(7);
        if (n > 0)
        {
            lista = new();
            ToastService.Success($"{n} pedidos sacados del tablero. Los nuevos van a aparecer apenas se suban a Drive ✅");
            StateHasChanged();
        }
        else
        {
            ToastService.Info("No habia nada para limpiar");
        }
    }

    private static string HaceCuanto(DateTime? t)
    {
        if (t is null) return "";
        var diff = DateTime.UtcNow - t.Value;
        if (diff.TotalMinutes < 1) return "hace segundos";
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours} h";
        return $"hace {(int)diff.TotalDays} días";
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}
