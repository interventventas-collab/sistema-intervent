@page "/cafe/clientes-mapeados"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>🗺 Clientes Mapeados <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(mapeados?.Count ?? 0))</span></h3>
        <div style="display: flex; gap: 0.4rem; align-items: center;">
            <input class="form-input" style="min-width: 260px; font-size: 0.9rem;"
                   @bind="filtro" @bind:event="oninput"
                   placeholder="🔍 Buscar por código, nombre, CUIT..." />
        </div>
    </div>
    <div class="card-body">
        @if (loading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else if (mapeados is null || mapeados.Count == 0)
        {
            <div style="padding: 1.5rem; text-align: center; color: #6b7280;">
                <p>📍 No hay clientes con enlace de Google Maps cargado todavía.</p>
                <p style="font-size: 0.85rem;">
                    Para vincular un cliente: andá a <strong>Café → Clientes</strong> → editá un cliente → pegá el enlace corto de Google Maps en el campo <strong>"🗺 Enlace Google Maps"</strong>.
                </p>
            </div>
        }
        else if (visibles.Count == 0)
        {
            <p class="text-muted">No hay resultados para tu búsqueda.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 90px; text-align: center;">🆔 Cód.</th>
                            <th>Cliente</th>
                            <th>Tipo</th>
                            <th>Dirección</th>
                            <th>Localidad</th>
                            <th style="width: 160px;">Google Maps</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in visibles)
                        {
                            <tr>
                                <td style="text-align: center; font-family: monospace; font-weight: 700; color: #1e40af;">
                                    @(c.CodigoInterno?.ToString() ?? "—")
                                </td>
                                <td>
                                    <strong>@c.Nombre</strong>
                                    @if (!string.IsNullOrEmpty(c.Cuit))
                                    {
                                        <div style="font-size: 0.72rem; color: #6b7280;">CUIT: @c.Cuit</div>
                                    }
                                </td>
                                <td>
                                    @if (c.Tipo == "BAR")
                                    {
                                        <span style="display:inline-block; padding:0.1rem 0.45rem; background:#dbeafe; color:#1e40af; border-radius:999px; font-size:0.7rem; font-weight:700;">🍺 BAR</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.1rem 0.45rem; background:#f3f4f6; color:#374151; border-radius:999px; font-size:0.7rem; font-weight:700;">OTRO</span>
                                    }
                                </td>
                                <td style="font-size: 0.85rem;">@(c.Direccion ?? "—")</td>
                                <td style="font-size: 0.85rem;">@(c.Localidad ?? "—")</td>
                                <td>
                                    <a href="@c.MapeoLink" target="_blank" rel="noopener"
                                       class="btn btn-secondary"
                                       style="font-size: 0.78rem; padding: 0.3rem 0.6rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem;">
                                        🗺 Ver en mapa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool loading = true;
    private List<CafeClienteDto> mapeados = new();
    private string filtro = "";

    private List<CafeClienteDto> visibles
    {
        get
        {
            if (mapeados is null) return new();
            if (string.IsNullOrWhiteSpace(filtro)) return mapeados;
            var t = filtro.Trim();
            bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
            return mapeados.Where(c =>
                h(c.Nombre) || h(c.RazonSocial) || h(c.Cuit) || h(c.Codigo)
                || h(c.Direccion) || h(c.Localidad) || h(c.Ciudad)
                || (c.CodigoInterno.HasValue && c.CodigoInterno.Value.ToString().Contains(t, StringComparison.OrdinalIgnoreCase))
            ).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        try
        {
            var todos = await Api.GetCafeClientesAsync() ?? new();
            // Solo los activos que tienen MapeoLink cargado, ordenados por CodigoInterno asc (sin código al final)
            mapeados = todos
                .Where(c => c.IsActive && !string.IsNullOrWhiteSpace(c.MapeoLink))
                .OrderBy(c => c.CodigoInterno ?? int.MaxValue)
                .ThenBy(c => c.Nombre)
                .ToList();
        }
        catch
        {
            ToastService.Error("Error al cargar clientes mapeados");
            mapeados = new();
        }
        loading = false;
    }
}
