@page "/cafe/configuracion"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject CpService CpService

<div class="card">
    <div class="card-header">
        <h3>⚙️ Configuración del módulo Café</h3>
    </div>
    <div class="card-body">
        @if (loading)
        {
            <p class="text-muted">Cargando...</p>
        }
        else
        {
            <h4 style="margin: 0 0 0.6rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">Motor de precios</h4>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Costo de fraccionamiento ($)</label>
                    <input class="form-input" type="number" step="0.01" min="0" @bind="costoFracc" />
                    <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">Se suma al precio del 1/2 kg y 1/4 kg.</p>
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Redondeo (múltiplo)</label>
                    <input class="form-input" type="number" step="1" min="1" @bind="redondeo" />
                    <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">El precio final se redondea hacia arriba a este múltiplo. Default: $1.000.</p>
                </div>
            </div>

            <h4 style="margin: 1rem 0 0.6rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">Margen de productos OTROS</h4>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Margen para clientes BAR (%)</label>
                    <input class="form-input" type="number" step="0.01" min="0" @bind="margenBar" />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Margen para clientes OTRO (%)</label>
                    <input class="form-input" type="number" step="0.01" min="0" @bind="margenOtro" />
                </div>
            </div>

            <h4 style="margin: 1rem 0 0.6rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">Datos del negocio (para comprobantes)</h4>
            <div class="form-row">
                <div class="form-group" style="flex: 2;">
                    <label class="form-label">Nombre fantasía</label>
                    <input class="form-input" @bind="negocioNombre" placeholder="Ej: Frikaf" />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">CUIT</label>
                    <input class="form-input" @bind="negocioCuit" placeholder="Ej: 30-12345678-9" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex: 2;">
                    <label class="form-label">Razón social (legal)</label>
                    <input class="form-input" @bind="negocioRazonSocial" placeholder="Ej: PALANICA HERMANOS S.R.L." />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Condición frente al IVA</label>
                    <select class="form-input" @bind="negocioCondicionIva">
                        <option value="">— Sin especificar —</option>
                        <option value="RI">Responsable Inscripto</option>
                        <option value="MO">Monotributo</option>
                        <option value="EX">Exento</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Ingresos Brutos</label>
                    <input class="form-input" @bind="negocioIngresosBrutos" placeholder="Nro de IIBB" />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Inicio de actividad</label>
                    <input class="form-input" type="date" @bind="negocioInicioActividad" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Teléfono</label>
                    <input class="form-input" @bind="negocioTelefono" />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">WhatsApp (sin 0 ni 15)</label>
                    <input class="form-input" @bind="negocioWhatsapp" placeholder="Ej: 5491141234567" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Dirección fiscal</label>
                <input class="form-input" @bind="negocioDireccion" placeholder="Calle, número, piso/dpto" />
            </div>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">CP</label>
                    <input class="form-input" value="@negocioCp"
                           @oninput="@(e => OnNegocioCpInput(e.Value?.ToString()))"
                           maxlength="4" placeholder="1050" />
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">4 dígitos. Auto-completa localidad y provincia.</p>
                </div>
                <div class="form-group" style="flex: 2;">
                    <label class="form-label">Localidad</label>
                    <input class="form-input" list="datalist-config-localidades" @bind="negocioLocalidad" @bind:event="oninput" placeholder="Ej: La Plata, Buenos Aires" />
                    <datalist id="datalist-config-localidades">
                        @foreach (var loc in localidadesYProvincias)
                        {
                            <option value="@loc"></option>
                        }
                    </datalist>
                    <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">Elegi de la lista o tipea libre.</p>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" @bind="negocioEmail" placeholder="ventas@empresa.com" />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Web</label>
                    <input class="form-input" @bind="negocioWeb" placeholder="empresa.com" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Logo</label>
                <div style="display: flex; gap: 0.4rem; align-items: stretch;">
                    <input class="form-input" style="flex: 1;" @bind="negocioLogoUrl" placeholder="URL de la imagen" />
                    <label class="btn btn-secondary" style="margin: 0; cursor: pointer;">
                        @(isUploadingLogo ? "Subiendo..." : "📤 Subir imagen")
                        <InputFile OnChange="OnLogoFileChange" accept="image/*" style="display: none;" />
                    </label>
                </div>
                <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                    Subí desde tu PC con el botón de la derecha o pegá una URL pública. Aparece en el header de listas de precios y comprobantes.
                </p>
                @if (!string.IsNullOrEmpty(uploadLogoError))
                {
                    <p style="font-size: 0.78rem; color: #b91c1c; margin: 0.3rem 0 0;">⚠ @uploadLogoError</p>
                }
                @if (!string.IsNullOrWhiteSpace(negocioLogoUrl))
                {
                    <div style="margin-top: 0.5rem; padding: 0.5rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; display: inline-block;">
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0 0 0.3rem;">Vista previa:</p>
                        <img src="@negocioLogoUrl" alt="Logo" style="max-height: 80px; max-width: 200px; object-fit: contain;" onerror="this.style.display='none'; this.nextSibling.style.display='block';" />
                        <span style="display:none; color: #b91c1c; font-size: 0.78rem;">⚠ No se pudo cargar la imagen</span>
                    </div>
                }
            </div>

            <h4 style="margin: 1rem 0 0.6rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">📱 Mensajes pre-armados de WhatsApp</h4>
            <p style="font-size: 0.78rem; color: #6b7280; margin: 0 0 0.5rem;">
                Hay <strong>dos mensajes</strong> distintos en el comprobante. Cada uno se completa solo con los datos de la venta usando los placeholders:
                <code style="background: #f3f4f6; padding: 0 0.2rem; border-radius: 3px;">{numero}</code> ·
                <code style="background: #f3f4f6; padding: 0 0.2rem; border-radius: 3px;">{total}</code> ·
                <code style="background: #f3f4f6; padding: 0 0.2rem; border-radius: 3px;">{cliente}</code> ·
                <code style="background: #f3f4f6; padding: 0 0.2rem; border-radius: 3px;">{fecha}</code>
            </p>

            @* ───── Mensaje 1: cliente -> negocio ───── *@
            <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; padding: 0.7rem; margin-bottom: 0.7rem;">
                <strong style="font-size: 0.85rem;">1. Cliente → Negocio</strong>
                <p style="font-size: 0.75rem; color: #6b7280; margin: 0.15rem 0 0.4rem;">
                    Aparece al pie del comprobante en el link <strong>"Contactanos por WhatsApp"</strong>. Lo escribe el <em>cliente</em>, va a tu WhatsApp.
                </p>
                <textarea class="form-input" rows="2" @bind="waTemplate" placeholder="Hola! Te escribo por el comprobante {numero}..."></textarea>
                <div style="background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 4px; padding: 0.4rem 0.6rem; font-size: 0.8rem; color: #065f46; margin-top: 0.4rem;">
                    👁 Vista previa: <em>"@WaPreview"</em>
                </div>
            </div>

            @* ───── Mensaje 2: negocio -> cliente (repartidor) ───── *@
            <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; padding: 0.7rem;">
                <strong style="font-size: 0.85rem;">2. Negocio → Cliente</strong>
                <p style="font-size: 0.75rem; color: #6b7280; margin: 0.15rem 0 0.4rem;">
                    Aparece al lado del teléfono del cliente. Lo escribe <em>vos / el repartidor</em>, va al WhatsApp del cliente.
                </p>
                <textarea class="form-input" rows="2" @bind="waTemplateCliente" placeholder="Hola {cliente}! Te escribo por la entrega del comprobante {numero}..."></textarea>
                <div style="background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 4px; padding: 0.4rem 0.6rem; font-size: 0.8rem; color: #065f46; margin-top: 0.4rem;">
                    👁 Vista previa: <em>"@WaPreviewCliente"</em>
                </div>
                <p style="font-size: 0.72rem; color: #9ca3af; margin: 0.3rem 0 0;">
                    💡 Si dejás este campo vacío, el icono 📱 al lado del teléfono abre WhatsApp <strong>sin texto pre-cargado</strong> (el repartidor escribe lo que necesite del momento).
                </p>
            </div>

            <hr style="margin: 1rem 0;" />
            <h4 style="margin: 0 0 0.6rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">🧮 Vista previa del cálculo</h4>
            <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; padding: 0.7rem; font-size: 0.85rem; font-family: monospace;">
                <div>Si un café tiene <strong>PVP1 = $25.000/kg</strong>, costoFracc <strong>$@costoFracc</strong>, redondeo <strong>$@redondeo</strong>:</div>
                <div>· 1 kg → @FormatMoney(Calc(25000, 1))</div>
                <div>· 1/2 kg → ($25.000/2 + $@costoFracc = $@FormatMoney(25000m/2m + costoFracc) → redondeado: <strong>@FormatMoney(Calc(25000, 0.5m))</strong>)</div>
                <div>· 1/4 kg → ($25.000/4 + $@costoFracc = $@FormatMoney(25000m/4m + costoFracc) → redondeado: <strong>@FormatMoney(Calc(25000, 0.25m))</strong>)</div>
            </div>

            <div style="margin-top: 1.2rem; display: flex; gap: 0.5rem; justify-content: flex-end;">
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? "Guardando..." : "Guardar configuración")
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool loading = true;
    private bool saving;
    private decimal costoFracc = 1000;
    private decimal redondeo = 1000;
    private decimal margenBar = 40;
    private decimal margenOtro = 60;
    private string negocioNombre = "", negocioTelefono = "", negocioWhatsapp = "", negocioDireccion = "", negocioCuit = "";
    private string negocioEmail = "", negocioWeb = "", negocioLogoUrl = "";
    private string negocioRazonSocial = "", negocioCondicionIva = "", negocioIngresosBrutos = "";
    private DateTime? negocioInicioActividad;
    private string negocioLocalidad = "", negocioCp = "";

    // Lista combinada "Localidad, Provincia" para el datalist del campo Localidad
    private List<string> localidadesYProvincias = new();

    private async Task OnNegocioCpInput(string? value)
    {
        var v = (value ?? "").Trim();
        if (v.Length > 4) v = v.Substring(0, 4);
        negocioCp = v;
        if (v.Length == 4 && v.All(char.IsDigit))
        {
            var hit = await CpService.LookupAsync(v);
            if (hit is not null)
                negocioLocalidad = hit.l + (string.IsNullOrEmpty(hit.p) ? "" : ", " + hit.p);
        }
    }
    private bool isUploadingLogo;
    private string? uploadLogoError;
    private string waTemplate = "Hola! Te escribo por el comprobante {numero} (total ${total}). Gracias!";
    private string waTemplateCliente = "Hola {cliente}! Te escribo del negocio por el comprobante {numero}.";

    private string ApplyPreview(string template) =>
        (string.IsNullOrWhiteSpace(template) ? "(sin mensaje pre-cargado)" : template)
            .Replace("{numero}", "CAFE-2026-0001")
            .Replace("{total}", "45.000,00")
            .Replace("{cliente}", "Bar Don Pepe")
            .Replace("{fecha}", DateTime.Today.ToString("dd/MM/yyyy"));

    private string WaPreview => ApplyPreview(waTemplate);
    private string WaPreviewCliente => ApplyPreview(waTemplateCliente);

    protected override async Task OnInitializedAsync()
    {
        // Cargar lista combinada "Localidad, Provincia" para el datalist (cacheado en CpService)
        localidadesYProvincias = await CpService.GetLocalidadConProvinciaAsync();
        try
        {
            var s = await Api.GetCafeSettingsAsync();
            if (s is not null)
            {
                costoFracc = s.CostoFraccionamiento;
                redondeo = s.RedondeoMultiplo;
                margenBar = s.MargenOtrosBarPct;
                margenOtro = s.MargenOtrosNoBarPct;
                negocioNombre = s.NegocioNombre ?? "";
                negocioTelefono = s.NegocioTelefono ?? "";
                negocioWhatsapp = s.NegocioWhatsappNumero ?? "";
                negocioDireccion = s.NegocioDireccion ?? "";
                negocioCuit = s.NegocioCuit ?? "";
                negocioEmail = s.NegocioEmail ?? "";
                negocioWeb = s.NegocioWeb ?? "";
                negocioLogoUrl = s.NegocioLogoUrl ?? "";
                negocioRazonSocial = s.NegocioRazonSocial ?? "";
                negocioCondicionIva = s.NegocioCondicionIva ?? "";
                negocioIngresosBrutos = s.NegocioIngresosBrutos ?? "";
                negocioInicioActividad = s.NegocioInicioActividad;
                negocioLocalidad = s.NegocioLocalidad ?? "";
                negocioCp = s.NegocioCp ?? "";
                if (!string.IsNullOrWhiteSpace(s.WhatsappMensajeTemplate))
                    waTemplate = s.WhatsappMensajeTemplate;
                // Cliente: usar lo guardado tal cual, incluso si esta vacio (significa "sin mensaje").
                waTemplateCliente = s.WhatsappMensajeClienteTemplate ?? "";
            }
        }
        catch { ToastService.Error("Error al cargar la configuración"); }
        loading = false;
    }

    private async Task Save()
    {
        if (redondeo < 1) { ToastService.Error("El redondeo debe ser ≥ 1"); return; }
        saving = true;
        try
        {
            await Api.UpdateCafeSettingsAsync(new UpdateCafeSettingRequest
            {
                CostoFraccionamiento = costoFracc,
                RedondeoMultiplo = redondeo,
                MargenOtrosBarPct = margenBar,
                MargenOtrosNoBarPct = margenOtro,
                NegocioNombre = negocioNombre,
                NegocioTelefono = negocioTelefono,
                NegocioWhatsappNumero = negocioWhatsapp,
                NegocioDireccion = negocioDireccion,
                NegocioCuit = negocioCuit,
                NegocioEmail = negocioEmail,
                NegocioWeb = negocioWeb,
                NegocioLogoUrl = negocioLogoUrl,
                NegocioRazonSocial = negocioRazonSocial,
                NegocioCondicionIva = negocioCondicionIva,
                NegocioIngresosBrutos = negocioIngresosBrutos,
                NegocioInicioActividad = negocioInicioActividad,
                NegocioLocalidad = negocioLocalidad,
                NegocioCp = negocioCp,
                WhatsappMensajeTemplate = waTemplate,
                WhatsappMensajeClienteTemplate = waTemplateCliente
            });
            ToastService.Success("Configuración guardada");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { saving = false; }
    }

    /// <summary>Sube la imagen del logo a /data/files/branding/cafe-logo-{ts}.{ext} y completa el campo
    /// negocioLogoUrl con la URL de descarga interna. El usuario debe apretar Guardar despues
    /// para que persista en Cafe_Settings.</summary>
    private async Task OnLogoFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        if (file.Size > 5 * 1024 * 1024) { uploadLogoError = "El archivo supera los 5 MB."; return; }
        uploadLogoError = null;
        isUploadingLogo = true;
        try
        {
            var ext = System.IO.Path.GetExtension(file.Name);
            if (string.IsNullOrEmpty(ext)) ext = ".png";
            var ts = DateTime.UtcNow.ToString("yyyyMMddHHmmss");
            var serverName = $"cafe-logo-{ts}{ext.ToLowerInvariant()}";
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var result = await Api.UploadFilesAsync("branding", new[] { (serverName, (System.IO.Stream)stream, file.Size) });
            var ok = result?.FirstOrDefault(r => r.Success);
            if (ok is null || string.IsNullOrEmpty(ok.Path))
            {
                uploadLogoError = result?.FirstOrDefault()?.Error ?? "No se pudo subir la imagen.";
                return;
            }
            // ok.Path es algo como "branding/cafe-logo-...png"
            negocioLogoUrl = Api.BuildFilesDownloadUrl(ok.Path);
            ToastService.Success("Logo subido. Tocá Guardar para persistir en Configuración.");
        }
        catch (Exception ex)
        {
            uploadLogoError = ex.Message;
        }
        finally { isUploadingLogo = false; }
    }

    private decimal Calc(decimal precioKg, decimal fraccion)
    {
        var precio = (precioKg * fraccion) + (fraccion < 1m ? costoFracc : 0m);
        if (redondeo > 0 && precio > 0) precio = Math.Ceiling(precio / redondeo) * redondeo;
        return precio;
    }

    private static string FormatMoney(decimal v)
        => "$" + v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
