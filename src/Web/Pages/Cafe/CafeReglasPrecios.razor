@page "/cafe/reglas-precios"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3>📐 Reglas de precios</h3>
        <button class="btn btn-secondary" @onclick="Load" disabled="@isBusy">Refrescar</button>
    </div>
    <div class="card-body">
        <p style="color:#6b7280; font-size:0.9rem;">
            El descuento se aplica sobre el <b>PVP de lista (Pvp1)</b> del producto.
            La regla general aplica a todos los productos de esa categoría.
            Las excepciones por marca <b>pisan</b> la regla general.
        </p>

        @if (data is null)
        {
            <p style="color:#6b7280;">Cargando...</p>
        }
        else
        {
            @* === REGLAS GENERALES === *@
            <h4 style="margin:1rem 0 0.4rem; color:#374151; font-size:1rem;">Reglas generales por categoría</h4>
            <div class="table-responsive">
                <table class="data-table" style="font-size:0.92rem; max-width:600px;">
                    <thead>
                        <tr>
                            <th style="width:200px;">Tipo de cliente</th>
                            @foreach (var cat in data.Categorias)
                            {
                                <th style="text-align:center;">@CategoriaLabel(cat)</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var tipo in data.TiposCliente)
                    {
                        <tr>
                            <td style="font-weight:700;">@TipoLabel(tipo)</td>
                            @foreach (var cat in data.Categorias)
                            {
                                var key = $"{tipo}|{cat}|G";
                                var actual = data.Reglas.FirstOrDefault(r => r.TipoCliente==tipo && r.Categoria==cat && r.MarcaId==null);
                                var valActual = actual?.DescuentoPct ?? 0m;
                                <td style="text-align:center;">
                                    <div style="display:flex; align-items:center; gap:0.25rem; justify-content:center;">
                                        <input class="form-input"
                                               type="number" step="0.01" min="0" max="100"
                                               style="max-width:90px; text-align:right;"
                                               value="@(GetVal(key, valActual))"
                                               @oninput="@(e => SetEdit(key, e.Value?.ToString()))" />
                                        <span style="font-size:0.85rem; color:#6b7280;">%</span>
                                        @if (HasEdit(key))
                                        {
                                            <button class="btn btn-primary" style="padding:0.2rem 0.4rem; font-size:0.78rem;"
                                                    @onclick="() => GuardarGeneral(tipo, cat, key)" disabled="@isBusy">✓</button>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @* === EXCEPCIONES POR MARCA === *@
            <h4 style="margin:1.4rem 0 0.4rem; color:#374151; font-size:1rem;">Excepciones por marca (override)</h4>
            <p style="font-size:0.82rem; color:#6b7280;">
                Si una marca debería tener un descuento distinto al general, agregalo acá.
            </p>

            @{
                var overrides = data.Reglas.Where(r => r.MarcaId.HasValue)
                    .OrderBy(r => r.TipoCliente).ThenBy(r => r.Categoria).ThenBy(r => r.MarcaNombre).ToList();
            }
            @if (overrides.Count == 0)
            {
                <p style="font-size:0.82rem; color:#9ca3af; padding:0.5rem 0;">No hay excepciones cargadas.</p>
            }
            else
            {
                <table class="data-table" style="font-size:0.88rem; max-width:780px;">
                    <thead>
                        <tr>
                            <th>Cliente</th>
                            <th>Categoría</th>
                            <th>Marca</th>
                            <th style="text-align:center;">Descuento %</th>
                            <th style="width:60px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var o in overrides)
                    {
                        var key = $"{o.TipoCliente}|{o.Categoria}|{o.MarcaId}";
                        <tr>
                            <td>@TipoLabel(o.TipoCliente)</td>
                            <td>@CategoriaLabel(o.Categoria)</td>
                            <td>@(o.MarcaNombre ?? "—")</td>
                            <td style="text-align:center;">
                                <div style="display:flex; align-items:center; gap:0.25rem; justify-content:center;">
                                    <input class="form-input"
                                           type="number" step="0.01" min="0" max="100"
                                           style="max-width:90px; text-align:right;"
                                           value="@(GetVal(key, o.DescuentoPct))"
                                           @oninput="@(e => SetEdit(key, e.Value?.ToString()))" />
                                    <span style="font-size:0.85rem; color:#6b7280;">%</span>
                                    @if (HasEdit(key))
                                    {
                                        <button class="btn btn-primary" style="padding:0.2rem 0.4rem; font-size:0.78rem;"
                                                @onclick="() => GuardarOverride(o.TipoCliente, o.Categoria, o.MarcaId, key)" disabled="@isBusy">✓</button>
                                    }
                                </div>
                            </td>
                            <td>
                                <button class="btn btn-danger" style="padding:0.2rem 0.4rem; font-size:0.8rem;"
                                        @onclick="() => Borrar(o.Id)" disabled="@isBusy">×</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }

            @* Form para agregar override *@
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end; margin-top:0.8rem;">
                <select class="form-input" @bind="addTipo" style="max-width:140px;">
                    @foreach (var t in data.TiposCliente) { <option value="@t">@TipoLabel(t)</option> }
                </select>
                <select class="form-input" @bind="addCategoria" style="max-width:140px;">
                    @foreach (var c in data.Categorias) { <option value="@c">@CategoriaLabel(c)</option> }
                </select>
                <select class="form-input" @bind="addMarcaIdStr" style="max-width:240px;">
                    <option value="">— Elegí marca —</option>
                    @if (marcas is not null)
                    {
                        @foreach (var m in marcas.OrderBy(x => x.Nombre))
                        {
                            <option value="@m.Id">@m.Nombre</option>
                        }
                    }
                </select>
                <input class="form-input" type="number" step="0.01" min="0" max="100"
                       @bind="addDescPct" style="max-width:90px; text-align:right;" placeholder="%" />
                <button class="btn btn-primary" @onclick="AgregarOverride"
                        disabled="@(string.IsNullOrEmpty(addMarcaIdStr) || isBusy)">+ Agregar excepción</button>
            </div>
        }
    </div>
</div>

@code {
    private CafeReglasPreciosResponse? data;
    private List<CafeMarcaDto>? marcas;
    private Dictionary<string, string> ediciones = new();
    private bool isBusy;

    private string addTipo = "BAR";
    private string addCategoria = "CAFE";
    private string addMarcaIdStr = "";
    private decimal addDescPct;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(Load(), LoadMarcas());
    }

    private async Task Load()
    {
        try { data = await Api.GetReglasPreciosAsync(); ediciones.Clear(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task LoadMarcas()
    {
        try { marcas = await Api.GetCafeMarcasAsync(activos: true); }
        catch { }
    }

    private string GetVal(string key, decimal valActual)
    {
        if (ediciones.TryGetValue(key, out var v)) return v;
        return valActual.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private void SetEdit(string key, string? newVal) => ediciones[key] = newVal ?? "";
    private bool HasEdit(string key) => ediciones.ContainsKey(key);

    private async Task GuardarGeneral(string tipo, string cat, string key)
    {
        if (!ediciones.TryGetValue(key, out var raw)) return;
        if (!ParseDec(raw, out var pct)) { ToastService.Error("Valor invalido"); return; }
        await UpsertAsync(tipo, cat, null, pct);
    }

    private async Task GuardarOverride(string tipo, string cat, int? marcaId, string key)
    {
        if (!ediciones.TryGetValue(key, out var raw)) return;
        if (!ParseDec(raw, out var pct)) { ToastService.Error("Valor invalido"); return; }
        await UpsertAsync(tipo, cat, marcaId, pct);
    }

    private async Task UpsertAsync(string tipo, string cat, int? marcaId, decimal pct)
    {
        isBusy = true;
        try
        {
            await Api.UpsertReglaPrecioAsync(new UpsertReglaPrecioRequest
            {
                TipoCliente = tipo, Categoria = cat, MarcaId = marcaId, DescuentoPct = pct
            });
            ToastService.Success($"Regla guardada");
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isBusy = false; }
    }

    private async Task AgregarOverride()
    {
        if (!int.TryParse(addMarcaIdStr, out var marcaId) || marcaId <= 0) return;
        await UpsertAsync(addTipo, addCategoria, marcaId, addDescPct);
        addMarcaIdStr = "";
        addDescPct = 0;
    }

    private async Task Borrar(int id)
    {
        try
        {
            await Api.DeleteReglaPrecioAsync(id);
            ToastService.Success("Excepción eliminada");
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private static bool ParseDec(string raw, out decimal v)
    {
        if (decimal.TryParse(raw, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out v)) return true;
        return decimal.TryParse(raw, out v);
    }

    private static string TipoLabel(string t) => t switch
    {
        "BAR" => "🍺 BAR",
        "OTRO" => "🏢 Comercial",
        _ => t
    };

    private static string CategoriaLabel(string c) => c switch
    {
        "CAFE" => "☕ CAFÉ",
        "OTROS" => "📦 OTROS",
        _ => c
    };
}
