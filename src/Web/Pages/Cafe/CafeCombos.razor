    private async Task DoSave()
    {
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        if (formItems.Count == 0) { formError = "Agregá al menos 1 producto"; return; }
        formError = null; saving = true;
        try
        {
            // 2026-06-18: si NO es compuesto, ignoramos OEM (solo aplica a compuestos)
            int? oemIdToSend = formEsCompuesto && formOemId > 0 ? formOemId : null;
            decimal? multToSend = formEsCompuesto && formOemId > 0
                ? (formMultiplicadorOem > 0m ? formMultiplicadorOem : 1m)
                : (decimal?)null;
            if (editing is null)
            {
                await Api.CreateCafeComboAsync(new CreateCafeComboRequest
                {
                    Nombre = formNombre,
                    Descripcion = formDescripcion,
                    Items = formItems,
                    EsCompuesto = formEsCompuesto,
                    OemId = oemIdToSend,
                    MultiplicadorOem = multToSend
                });
                ToastService.Success("Combo creado");
            }
            else
            {
                // Si era compuesto+OEM y ahora se le sacó el OEM (o se destildó EsCompuesto), mandamos ClearOem=true
                bool clearOem = (editing.OemId.HasValue && (!formEsCompuesto || formOemId == 0));
                await Api.UpdateCafeComboAsync(editing.Id, new UpdateCafeComboRequest
                {
                    Nombre = formNombre,
                    Descripcion = formDescripcion,
                    IsActive = formIsActive,
                    Items = formItems,
                    EsCompuesto = formEsCompuesto,
                    OemId = oemIdToSend,
                    MultiplicadorOem = multToSend,
                    ClearOem = clearOem ? true : null
                });
                ToastService.Success("Combo actualizado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    // 2026-06-18: Edicion inline OEM por fila (sin popover)
    private class InlineOemState
    {
        public bool IsLinked { get; set; }
        public bool Editing { get; set; }
        public string SearchText { get; set; } = "";
        public bool Open { get; set; }
        public int SelectedOemId { get; set; }
        public decimal Mult { get; set; } = 1m;
        public bool Saving { get; set; }
    }
    private Dictionary<int, InlineOemState> inlineStates = new();

    private InlineOemState GetInlineState(int comboId, CafeComboDto c)
    {
        if (!inlineStates.TryGetValue(comboId, out var st))
        {
            st = new InlineOemState
            {
                IsLinked = c.OemId.HasValue,
                Editing = !c.OemId.HasValue,
                Mult = c.MultiplicadorOem ?? 1m
            };
            inlineStates[comboId] = st;
        }
        else
        {
            // sync con el DTO actualizado
            st.IsLinked = c.OemId.HasValue;
        }
        return st;
    }

    private void OnInlineOemSearch(int comboId, string? text)
    {
        var st = inlineStates[comboId];
        st.SearchText = text ?? "";
        st.Open = true;
        if (string.IsNullOrWhiteSpace(text)) st.SelectedOemId = 0;
    }

    private void OnInlineOemFocus(int comboId)
    {
        if (inlineStates.TryGetValue(comboId, out var st)) st.Open = true;
    }

    private void SelectInlineOem(int comboId, int oemId, CafeOemDto o)
    {
        var st = inlineStates[comboId];
        st.SelectedOemId = oemId;
        st.SearchText = $"{o.Codigo} - {o.Descripcion}";
        st.Open = false;
    }

    private async Task SaveInlineOem(CafeComboDto c)
    {
        var st = inlineStates[c.Id];
        if (st.SelectedOemId == 0) return;
        st.Saving = true;
        try
        {
            var resp = await Api.UpdateCafeComboAsync(c.Id, new UpdateCafeComboRequest
            {
                OemId = st.SelectedOemId,
                MultiplicadorOem = st.Mult > 0m ? st.Mult : 1m,
                EsCompuesto = true
            });
            if (resp is null) { ToastService.Error("No se pudo guardar"); return; }
            var idx = combos?.FindIndex(x => x.Id == c.Id) ?? -1;
            if (idx >= 0 && combos is not null) combos[idx] = resp;
            st.IsLinked = true;
            st.Editing = false;
            ToastService.Success($"OEM vinculado a {c.Sku}");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { st.Saving = false; }
    }

    private async Task UpdateMultiplicadorInline(CafeComboDto c, string? valor)
    {
        if (!decimal.TryParse(valor, out var nuevo) || nuevo <= 0) return;
        if (Math.Abs(nuevo - (c.MultiplicadorOem ?? 1m)) < 0.0001m) return; // sin cambio real
        try
        {
            var resp = await Api.UpdateCafeComboAsync(c.Id, new UpdateCafeComboRequest
            {
                MultiplicadorOem = nuevo
            });
            if (resp is null) return;
            var idx = combos?.FindIndex(x => x.Id == c.Id) ?? -1;
            if (idx >= 0 && combos is not null) combos[idx] = resp;
            ToastService.Success("Multiplicador actualizado");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DesvincularOemInline(CafeComboDto c)
    {
        try
        {
            var resp = await Api.UpdateCafeComboAsync(c.Id, new UpdateCafeComboRequest { ClearOem = true });
            if (resp is null) return;
            var idx = combos?.FindIndex(x => x.Id == c.Id) ?? -1;
            if (idx >= 0 && combos is not null) combos[idx] = resp;
            if (inlineStates.TryGetValue(c.Id, out var st))
            {
                st.IsLinked = false;
                st.Editing = true;
                st.SelectedOemId = 0;
                st.SearchText = "";
                st.Mult = 1m;
            }
            ToastService.Info("OEM desvinculado — vuelve a sumar componentes");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

