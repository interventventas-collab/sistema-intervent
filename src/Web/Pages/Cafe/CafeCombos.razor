@page "/cafe/combos"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation

<style>
    .cli-pick-row:hover { background: #f0f9ff; }
</style>

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>
            🛒 Combos MeLi
            <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@CombosVisibles.Count)</span>
            <div style="font-size: 0.72rem; font-weight: 400; color: #6b7280; margin-top: 0.2rem;">
                Plomería interna para que las publicaciones MeLi descuenten stock. Los <strong>productos compuestos</strong> (tachos armados, etc.) viven en <a href="/cafe/productos" style="color:#7c3aed; font-weight:600;">/cafe/productos</a>.
            </div>
        </h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <input class="form-input" style="min-width: 240px; font-size: 0.85rem;"
                   @bind="filtroTexto" @bind:event="oninput"
                   placeholder="🔍 Buscar por SKU o nombre..." />
            <select class="form-input" style="max-width: 220px; font-size: 0.85rem;" @bind="filtroTipo">
                <option value="MELI">🟠 Solo Combos MeLi</option>
                <option value="COMPUESTO">🟣 Solo Compuestos</option>
                <option value="COMPUESTO_SIN_OEM">🟡 Compuestos SIN OEM (pendientes)</option>
                <option value="">Todos</option>
            </select>
            <button class="btn @(modoEdicion ? "btn-warning" : "btn-secondary")"
                    @onclick="() => modoEdicion = !modoEdicion" title="Edicion rapida del nombre">
                @(modoEdicion ? "🔓 Edicion ON" : "🔒 Edicion OFF")
            </button>
            <button class="btn" style="background:#7c3aed; color:white; border:none;"
                    @onclick="ConfirmarReclasificar" disabled="@reclasificando"
                    title="Aplica una regla refinada para detectar productos compuestos reales y degrada los falsos positivos a Combos MeLi">
                @(reclasificando ? "Reclasificando..." : "🔧 Reclasificar automático")
            </button>
            @* 2026-06-18: sugeridor masivo OEM — auto-link en bloque por similitud de SKU *@
            <button class="btn" style="background:#16a34a; color:white; border:none;"
                    @onclick="AbrirSugeridorOem" disabled="@sugiriendoOems"
                    title="Detecta OEMs sugeridos para los compuestos sin OEM cargado (matchea por raíz del SKU)">
                @(sugiriendoOems ? "Buscando..." : "🪄 Sugerir OEMs")
            </button>
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo Combo</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (combos is null || combos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay combos cargados. Tocá <strong>"+ Nuevo Combo"</strong> para crear el primero.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Combo</th>
                            <th style="width: 80px; text-align: center;">Items</th>
                            <th style="text-align: right;">PVP BAR</th>
                            <th style="text-align: right;">PVP OTRO</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in CombosVisibles.Skip((paginaActual - 1) * pageSize).Take(pageSize))
                        {
                            <tr>
                                <td>
                                    @* 2026-06-18: chip de tipo + SKU arriba del nombre *@
                                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.2rem;">
                                        @if (c.EsCompuesto)
                                        {
                                            <span style="display:inline-block; padding:0.1rem 0.45rem; background:#EEEDFE; color:#3C3489; border:1px solid #7F77DD; border-radius:999px; font-size:0.65rem; font-weight:800; letter-spacing:0.02em;" title="Producto compuesto — se arma con varias piezas (ej: tacho = cuerpo + tapa)">🟣 COMPUESTO</span>
                                        }
                                        else
                                        {
                                            <span style="display:inline-block; padding:0.1rem 0.45rem; background:#FAEEDA; color:#633806; border:1px solid #BA7517; border-radius:999px; font-size:0.65rem; font-weight:800; letter-spacing:0.02em;" title="Combo MeLi — plomería para descuento de stock de publicaciones MercadoLibre">🟠 COMBO MELI</span>
                                        }
                                        @if (!string.IsNullOrEmpty(c.Sku))
                                        {
                                            <span style="font-family: monospace; font-weight: 700; color: #1d4ed8; font-size: 0.8rem;">@c.Sku</span>
                                        }
                                    </div>
                                    @* 2026-06-18: edicion inline OEM — desplegable + multiplicador + ✓ siempre visibles (sin popover) *@
                                    @if (c.EsCompuesto)
                                    {
                                        var st = GetInlineState(c.Id, c);
                                        <div style="display: flex; gap: 0.3rem; align-items: center; margin: 0.25rem 0; flex-wrap: wrap; position: relative;">
                                            @if (st.IsLinked && !st.Editing)
                                            {
                                                <span style="display:inline-flex; align-items:center; gap:0.3rem; padding:0.15rem 0.5rem; background:#E1F5EE; color:#085041; border:1px solid #5DCAA5; border-radius:6px; font-size:0.75rem; font-weight:700;">
                                                    🔗 OEM @c.OemCodigo
                                                </span>
                                                <span style="font-size: 0.7rem; color: #6b7280;">×</span>
                                                <input type="number" step="0.0001" min="0" value="@(c.MultiplicadorOem ?? 1m)"
                                                       @onchange="@(async (e) => await UpdateMultiplicadorInline(c, e.Value?.ToString()))"
                                                       style="width:65px; padding:0.15rem 0.35rem; font-size:0.78rem; text-align:right; border:1px solid #d1d5db; border-radius:4px;" />
                                                <span style="font-size:0.72rem; color:#085041; font-weight:700; background:#f0fdf4; padding:0.15rem 0.4rem; border-radius:4px;">
                                                    $@FormatMoney((c.OemPvpConIva ?? 0m) * (c.MultiplicadorOem ?? 1m))
                                                </span>
                                                <button type="button" class="btn-icon" style="font-size:0.85rem;" @onclick="() => DesvincularOemInline(c)" title="Desvincular OEM">×</button>
                                            }
                                            else
                                            {
                                                <input class="form-input" style="font-size:0.78rem; padding:0.2rem 0.4rem; min-width:200px; max-width:260px;"
                                                       value="@st.SearchText"
                                                       @oninput="@((e) => OnInlineOemSearch(c.Id, e.Value?.ToString()))"
                                                       @onfocus="() => OnInlineOemFocus(c.Id)"
                                                       placeholder="🔍 OEM por código, descripción..." />
                                                <span style="font-size:0.7rem; color:#6b7280;">×</span>
                                                <input type="number" step="0.0001" min="0" @bind="st.Mult"
                                                       style="width:55px; padding:0.2rem 0.35rem; font-size:0.78rem; text-align:right; border:1px solid #d1d5db; border-radius:4px;" />
                                                @if (st.SelectedOemId > 0)
                                                {
                                                    <button type="button" @onclick="() => SaveInlineOem(c)" disabled="@st.Saving"
                                                            style="background:#16a34a; color:white; border:none; padding:0.2rem 0.5rem; border-radius:4px; cursor:pointer; font-size:0.78rem; font-weight:700;">
                                                        @(st.Saving ? "..." : "✓")
                                                    </button>
                                                }
                                                @if (st.Open && !string.IsNullOrWhiteSpace(st.SearchText))
                                                {
                                                    var matches = OemsMatching(st.SearchText).Take(10).ToList();
                                                    <div style="position:absolute; top:100%; left:0; right:0; background:white; border:1px solid #d1d5db; border-radius:6px; max-height:240px; overflow-y:auto; z-index:50; box-shadow:0 4px 14px rgba(0,0,0,0.12); margin-top:0.15rem; max-width:520px;">
                                                        @if (matches.Count == 0)
                                                        {
                                                            <div style="padding:0.5rem; color:#6b7280; font-size:0.78rem;">Sin resultados</div>
                                                        }
                                                        else
                                                        {
                                                            @foreach (var o in matches)
                                                            {
                                                                var oId = o.Id;
                                                                <div class="cli-pick-row" @onclick="() => SelectInlineOem(c.Id, oId, o)"
                                                                     style="padding:0.35rem 0.55rem; cursor:pointer; border-bottom:1px solid #f3f4f6; font-size:0.78rem;">
                                                                    <span style="background:#16a34a; color:white; padding:0.1rem 0.4rem; border-radius:3px; font-weight:700; font-family:monospace; margin-right:0.4rem;">@o.Codigo</span>
                                                                    <strong>@(o.Descripcion ?? "")</strong>
                                                                    @if (o.PvpConIva.HasValue)
                                                                    {
                                                                        <span style="color:#15803d; font-size:0.72rem; margin-left:0.3rem;">· $@FormatMoney(o.PvpConIva.Value)</span>
                                                                    }
                                                                </div>
                                                            }
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    @if (modoEdicion)
                                    {
                                        <input class="form-input" style="font-size:0.85rem;"
                                               value="@c.Nombre"
                                               @onchange="@(async (e) => await GuardarNombreCombo(c, e.Value?.ToString()))" />
                                    }
                                    else
                                    {
                                        <strong>@c.Nombre</strong>
                                    }
                                    @if (!string.IsNullOrEmpty(c.Descripcion))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">@c.Descripcion</div>
                                    }
                                    @if (c.Items.Count > 0)
                                    {
                                        @* 2026-06-18: mostrar SKU del componente en monospace azul (el usuario conoce los codigos mejor que los nombres) *@
                                        <div style="font-size: 0.72rem; color: #6b7280; margin-top: 0.25rem; display: flex; flex-direction: column; gap: 1px;">
                                            @foreach (var it in c.Items.Take(4))
                                            {
                                                <div>
                                                    <span style="font-weight: 700; color: #374151;">@it.Cantidad×</span>
                                                    @if (!string.IsNullOrEmpty(it.ProductoSku))
                                                    {
                                                        <span style="font-family: monospace; color: #1d4ed8; font-weight: 700;">[@it.ProductoSku]</span>
                                                    }
                                                    <span style="color: #9ca3af;">@it.ProductoNombre · @FormatoLabel(it.Formato)</span>
                                                </div>
                                            }
                                            @if (c.Items.Count > 4)
                                            {
                                                <div style="color: #9ca3af; font-style: italic;">+ @(c.Items.Count - 4) más</div>
                                            }
                                        </div>
                                    }
                                </td>
                                <td style="text-align: center; font-weight: 700;">@c.ItemsCount</td>
                                <td style="text-align: right; font-weight: 700; color: #1d4ed8;">$@FormatMoney(c.PreviewPrecioBar)</td>
                                <td style="text-align: right; font-weight: 700; color: #15803d;">$@FormatMoney(c.PreviewPrecioOtro)</td>
                                <td>
                                    <span class="status-badge @(c.IsActive ? "status-active" : "status-inactive")">
                                        @(c.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    @* 2026-06-18: toggle rapido Compuesto <-> Combo MeLi sin abrir modal *@
                                    <button class="btn-icon" style="color:@(c.EsCompuesto ? "#7c3aed" : "#BA7517");"
                                            @onclick="() => ToggleEsCompuesto(c)"
                                            title="@(c.EsCompuesto ? "Es Compuesto — click para pasarlo a Combo MeLi" : "Es Combo MeLi — click para pasarlo a Compuesto")">
                                        @(c.EsCompuesto ? "🟣" : "🟠")
                                    </button>
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(c)" title="Editar">✎</button>
                                    <button class="btn-icon" style="color:#2563eb;" @onclick="() => PushComboSkuToMeli(c)" disabled="@pushingMeliSku"
                                            title="Mandar el código '@c.Sku' a las publicaciones de MercadoLibre de este producto">📤</button>
                                    <button class="btn-icon" style="color:#7c3aed;" @onclick="() => ShowCreateSimilar(c)" title="Crear similar (duplica este combo y le cambiás los componentes)">📋</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(c)" title="Eliminar">🗑</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @* 2026-06-18: paginacion client-side. Items por pagina = 100 *@
                @if (CombosVisibles.Count > pageSize)
                {
                    <div style="display:flex; align-items:center; justify-content:space-between; padding: 0.7rem 1rem; border-top: 1px solid #e5e7eb; font-size: 0.85rem;">
                        <span style="color:#6b7280;">
                            Mostrando @((paginaActual - 1) * pageSize + 1) - @(Math.Min(paginaActual * pageSize, CombosVisibles.Count)) de @CombosVisibles.Count
                        </span>
                        <div style="display:flex; gap:0.4rem; align-items:center;">
                            <button class="btn btn-secondary" disabled="@(paginaActual <= 1)" @onclick="() => paginaActual = 1" title="Primera">«</button>
                            <button class="btn btn-secondary" disabled="@(paginaActual <= 1)" @onclick="() => paginaActual--" title="Anterior">‹</button>
                            <span style="font-weight: 700;">Página @paginaActual / @TotalPaginas</span>
                            <button class="btn btn-secondary" disabled="@(paginaActual >= TotalPaginas)" @onclick="() => paginaActual++" title="Siguiente">›</button>
                            <button class="btn btn-secondary" disabled="@(paginaActual >= TotalPaginas)" @onclick="() => paginaActual = TotalPaginas" title="Última">»</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (mostrarConfirmReclasif)
{
    <div class="modal-overlay" @onclick="() => mostrarConfirmReclasif = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 540px;">
            <div class="modal-header" style="background:#7c3aed; color:white;">
                <h3 style="margin:0;">🔧 Reclasificar automático</h3>
                <button class="btn-close" style="color:white;" @onclick="() => mostrarConfirmReclasif = false">&times;</button>
            </div>
            <div class="modal-body">
                <p>Voy a aplicar la regla refinada sobre todos los combos marcados como <strong>Compuestos</strong>:</p>
                <ol style="font-size:0.88rem; color:#374151; padding-left:1.2rem;">
                    <li>Todos los componentes tienen <strong>cantidad = 1</strong></li>
                    <li>Ningún componente es a su vez otro combo</li>
                    <li>Los componentes son productos <strong>distintos</strong> (no es combo de variantes)</li>
                </ol>
                <p style="font-size:0.88rem; color:#6b7280;">
                    Los que <strong>no cumplan</strong> pasan a Combo MeLi automáticamente. Podés revertir cualquiera individualmente con el botón 🟣/🟠 de cada fila.
                </p>
                @if (reclasifResult is not null)
                {
                    <div style="background:#f3f4f6; padding:0.8rem; border-radius:6px; margin-top:0.6rem; font-size:0.85rem;">
                        <div style="font-weight:700; margin-bottom:0.3rem;">✅ Listo:</div>
                        <div>Procesados: <strong>@reclasifResult.Total</strong></div>
                        <div style="color:#7c3aed;">🟣 Quedaron compuestos: <strong>@reclasifResult.QuedaronCompuestos</strong></div>
                        <div style="color:#BA7517;">🟠 Pasaron a Combo MeLi: <strong>@reclasifResult.PasaronACombo</strong></div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (reclasifResult is null)
                {
                    <button class="btn btn-secondary" @onclick="() => mostrarConfirmReclasif = false" disabled="@reclasificando">Cancelar</button>
                    <button class="btn" style="background:#7c3aed; color:white;" @onclick="EjecutarReclasificar" disabled="@reclasificando">
                        @(reclasificando ? "Procesando..." : "🔧 Aplicar regla")
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="() => { mostrarConfirmReclasif = false; reclasifResult = null; }">Cerrar</button>
                }
            </div>
        </div>
    </div>
}

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 900px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin: 0;">📦 @(editing is null ? "Nuevo combo" : $"Editar combo — {editing.Nombre}")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y: auto;">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre del combo *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Pack 3 cafés" />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Descripción (opcional)</label>
                    <textarea class="form-input" rows="2" @bind="formDescripcion" placeholder="Texto opcional que se muestra debajo del nombre..."></textarea>
                </div>

                @* ── 2026-06-18: Es Compuesto + OEM ── *@
                <div style="background: @(formEsCompuesto ? "#f5f3ff" : "#fffbeb"); border: 1px solid @(formEsCompuesto ? "#c4b5fd" : "#fde68a"); border-radius: 8px; padding: 0.6rem 0.75rem; margin-bottom: 0.75rem;">
                    <label style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 700;">
                        <input type="checkbox" @bind="formEsCompuesto" />
                        @if (formEsCompuesto)
                        {
                            <span style="color: #6d28d9;">🟣 Producto Compuesto</span>
                            <span style="font-weight: 400; color: #6b7280; font-size: 0.78rem;">(tacho armado, cesto, etc — se ve en /cafe/productos)</span>
                        }
                        else
                        {
                            <span style="color: #92400e;">🟠 Combo MeLi</span>
                            <span style="font-weight: 400; color: #6b7280; font-size: 0.78rem;">(pack importado de Contabilium para descuento de stock)</span>
                        }
                    </label>

                    @if (formEsCompuesto)
                    {
                        <div style="margin-top: 0.6rem; border-top: 1px dashed #c4b5fd; padding-top: 0.6rem;">
                            <label class="form-label" style="font-size: 0.78rem; color: #6d28d9; font-weight: 700; text-transform: uppercase;">📋 OEM del compuesto (opcional)</label>
                            <p style="font-size: 0.7rem; color: #6b7280; margin: 0 0 0.4rem;">Si el fabricante vende este compuesto con su propio código y precio, vinculalo. El sistema cobra <strong>OEM PVP × multiplicador</strong> en vez de sumar los componentes.</p>
                            <div class="form-row" style="align-items: end;">
                                <div class="form-group" style="flex: 2; position: relative; margin-bottom: 0;">
                                    @if (formOemId > 0)
                                    {
                                        var oSel = oems?.FirstOrDefault(x => x.Id == formOemId);
                                        <div style="display: flex; gap: 0.3rem; align-items: center;">
                                            <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                                <span style="background:#16a34a; color:white; padding:0.15rem 0.45rem; border-radius:6px; font-weight:800; font-family:monospace;">@(oSel?.Codigo ?? "?")</span>
                                                <strong>@(oSel?.Descripcion ?? "—")</strong>
                                                @if (oSel?.PvpConIva.HasValue == true)
                                                {
                                                    <span style="font-size: 0.72rem; color: #15803d;">· PVP c/IVA $@FormatMoney(oSel.PvpConIva.Value)</span>
                                                }
                                            </div>
                                            <button class="btn btn-secondary" type="button" @onclick="ClearOemCompuesto" title="Desvincular OEM">×</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <input class="form-input" @bind="oemSearch" @bind:event="oninput"
                                               @onfocus="() => oemSearchOpen = true"
                                               placeholder="🔍 Buscar OEM por código, descripción, marca, barcode..." />
                                        @if (oemSearchOpen && !string.IsNullOrWhiteSpace(oemSearch))
                                        {
                                            var matches = OemsMatching(oemSearch).Take(20).ToList();
                                            <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                                @if (matches.Count == 0)
                                                {
                                                    <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados.</div>
                                                }
                                                else
                                                {
                                                    @foreach (var o in matches)
                                                    {
                                                        var oId = o.Id;
                                                        <div class="cli-pick-row" @onclick="() => SelectOemCompuesto(oId)"
                                                             style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                                            <span style="background:#16a34a; color:white; padding:0.1rem 0.4rem; border-radius:4px; font-weight:700; font-family:monospace; margin-right:0.4rem;">@o.Codigo</span>
                                                            <strong>@(o.Descripcion ?? "")</strong>
                                                            @if (!string.IsNullOrEmpty(o.Marca))
                                                            {
                                                                <span style="color:#6b7280; font-size:0.78rem;"> · @o.Marca</span>
                                                            }
                                                            @if (o.PvpConIva.HasValue)
                                                            {
                                                                <span style="color:#15803d; font-size:0.78rem;"> · PVP c/IVA $@FormatMoney(o.PvpConIva.Value)</span>
                                                            }
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                                <div class="form-group" style="flex: 0 0 130px; margin-bottom: 0;">
                                    <label class="form-label" style="font-size: 0.72rem;">Multiplicador</label>
                                    <input class="form-input" type="number" step="0.0001" min="0" @bind="formMultiplicadorOem"
                                           style="text-align: right;" placeholder="1" />
                                </div>
                            </div>
                            @if (formOemId > 0)
                            {
                                var oSel2 = oems?.FirstOrDefault(x => x.Id == formOemId);
                                var multUsado = formMultiplicadorOem > 0 ? formMultiplicadorOem : 1m;
                                var pvpFinal = (oSel2?.PvpConIva ?? 0m) * multUsado;
                                <div style="margin-top: 0.5rem; padding: 0.4rem 0.6rem; background: white; border: 1px solid #ddd; border-radius: 6px; font-size: 0.85rem;">
                                    Precio del compuesto: <strong style="color: #15803d;">$@FormatMoney(pvpFinal)</strong>
                                    <span style="color: #6b7280; font-size: 0.75rem;">= OEM $@FormatMoney(oSel2?.PvpConIva ?? 0m) × @multUsado.ToString("0.####")</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                @* ── Productos del combo ── *@
                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem; margin-bottom: 0.75rem;">
                    <div style="font-weight: 700; margin-bottom: 0.4rem;">Productos del combo</div>

                    <div class="form-row" style="align-items: end;">
                        <div class="form-group" style="flex: 2; position: relative;">
                            <label class="form-label" style="font-size: 0.75rem;">Producto</label>
                            @if (addProductoId > 0)
                            {
                                var pSel = productos?.FirstOrDefault(x => x.Id == addProductoId);
                                <div style="display: flex; gap: 0.3rem; align-items: center;">
                                    <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                        <span style="font-family: monospace; font-weight: 700; color: #1d4ed8;">@(pSel?.Sku ?? "—")</span>
                                        <strong>@(pSel?.Nombre ?? "?")</strong>
                                        @if (pSel is not null)
                                        {
                                            <span style="font-size: 0.72rem; color: #6b7280;">· @pSel.Categoria</span>
                                        }
                                    </div>
                                    <button class="btn btn-secondary" type="button" @onclick="ClearProducto" title="Quitar">×</button>
                                </div>
                            }
                            else
                            {
                                <input class="form-input" @bind="productoSearch" @bind:event="oninput"
                                       @onfocus="() => productoSearchOpen = true"
                                       placeholder="🔍 SKU, código de barras, nombre, marca..." />
                                @if (productoSearchOpen && !string.IsNullOrWhiteSpace(productoSearch))
                                {
                                    var pmatches = ProductosMatching(productoSearch).Take(20).ToList();
                                    <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                        @if (pmatches.Count == 0)
                                        {
                                            <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados.</div>
                                        }
                                        else
                                        {
                                            @foreach (var p in pmatches)
                                            {
                                                var pId = p.Id;
                                                <div class="cli-pick-row" @onclick="() => SelectProducto(pId)"
                                                     style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                                    <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; margin-right: 0.5rem;">@(p.Sku ?? "—")</span>
                                                    <strong>@p.Nombre</strong>
                                                    @if (p.Categoria == "CAFE")
                                                    {
                                                        <span style="display:inline-block; padding:0.05rem 0.35rem; background:#fef3c7; color:#92400e; border-radius:999px; font-size:0.65rem; font-weight:700; margin-left: 0.4rem;">☕</span>
                                                    }
                                                    else
                                                    {
                                                        <span style="display:inline-block; padding:0.05rem 0.35rem; background:#e0e7ff; color:#3730a3; border-radius:999px; font-size:0.65rem; font-weight:700; margin-left: 0.4rem;">📦</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(p.Marca))
                                                    {
                                                        <span style="color: #6b7280; font-size: 0.78rem;"> · @p.Marca</span>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label" style="font-size: 0.75rem;">Formato</label>
                            <select class="form-input" @bind="addFormato">
                                @if (AddProductoCategoria == "CAFE")
                                {
                                    <option value="1KG">1 kg</option>
                                    <option value="MEDIO">1/2 kg</option>
                                    <option value="CUARTO">1/4 kg</option>
