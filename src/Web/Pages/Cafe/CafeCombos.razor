    private bool sugiriendoOems;
    private SugerirOemsResponse? sugeridorResp;
    private Dictionary<int, bool> sugSeleccionadas = new();
    private bool aplicandoSugerencias;

    private async Task AbrirSugeridorOem()
    {
        sugiriendoOems = true;
        try
        {
            sugeridorResp = await Api.SugerirOemsAsync();
            sugSeleccionadas = sugeridorResp?.Sugerencias.ToDictionary(s => s.ComboId, s => true) ?? new();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { sugiriendoOems = false; }
    }

    private void CerrarSugeridor() { if (!aplicandoSugerencias) { sugeridorResp = null; sugSeleccionadas.Clear(); } }

    private void ToggleTodasSugerencias(bool valor)
    {
        if (sugeridorResp is null) return;
        foreach (var s in sugeridorResp.Sugerencias) sugSeleccionadas[s.ComboId] = valor;
    }

    private async Task AplicarSugerenciasOem()
    {
        if (sugeridorResp is null) return;
        var seleccionadas = sugeridorResp.Sugerencias.Where(s => sugSeleccionadas.TryGetValue(s.ComboId, out var v) && v).ToList();
        if (seleccionadas.Count == 0) { ToastService.Error("No seleccionaste ninguna"); return; }
        aplicandoSugerencias = true;
        try
        {
            var req = new AplicarSugerenciasOemRequest
            {
                Items = seleccionadas.Select(s => new AplicarSugerenciaItem
                {
                    ComboId = s.ComboId,
                    OemId = s.OemId,
                    Multiplicador = 1m
                }).ToList()
            };
            var resp = await Api.AplicarSugerenciasOemAsync(req);
            if (resp is null) { ToastService.Error("No se pudo aplicar"); return; }
            ToastService.Success($"✅ {resp.Aplicadas} OEMs vinculados" + (resp.Fallidas > 0 ? $" ({resp.Fallidas} fallaron)" : ""));
            sugeridorResp = null;
            sugSeleccionadas.Clear();
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { aplicandoSugerencias = false; }
    }

