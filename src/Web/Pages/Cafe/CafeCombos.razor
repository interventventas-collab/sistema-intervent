@* 2026-06-18: Modal sugeridor masivo OEM *@
@if (sugeridorResp is not null)
{
    <div class="modal-overlay" @onclick="CerrarSugeridor">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 1100px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header" style="background: #16a34a; color: white;">
                <h3 style="margin: 0;">🪄 Sugerencias de OEM por similitud de SKU</h3>
                <button class="btn-close" @onclick="CerrarSugeridor" style="color:white;">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y: auto;">
                <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem; padding: 0.6rem 0.8rem; background: #f9fafb; border-radius: 6px;">
                    <span><strong>Total revisados:</strong> @sugeridorResp.Total</span>
                    <span style="color: #15803d;"><strong>Con sugerencia:</strong> @sugeridorResp.ConMatch</span>
                    <span style="color: #b91c1c;"><strong>Sin match:</strong> @sugeridorResp.SinMatch</span>
                </div>
                @if (sugeridorResp.Sugerencias.Count == 0)
                {
                    <p style="text-align: center; color: #6b7280;">No se encontraron sugerencias automáticas. Tendrás que linkear OEMs manualmente desde el listado.</p>
                }
                else
                {
                    <div style="display: flex; gap: 0.5rem; margin-bottom: 0.6rem;">
                        <button class="btn btn-secondary" @onclick="() => ToggleTodasSugerencias(true)">Tildar todas</button>
                        <button class="btn btn-secondary" @onclick="() => ToggleTodasSugerencias(false)">Destildar todas</button>
                        <span style="margin-left: auto; align-self: center; font-size: 0.85rem; color: #6b7280;">
                            Seleccionadas: <strong>@sugSeleccionadas.Count(kv => kv.Value)</strong>
                        </span>
                    </div>
                    <div class="table-responsive">
                        <table class="data-table" style="font-size: 0.85rem;">
                            <thead>
                                <tr>
                                    <th style="width: 40px;"></th>
                                    <th>Compuesto</th>
                                    <th>OEM sugerido</th>
                                    <th style="text-align: right;">PVP OEM</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in sugeridorResp.Sugerencias)
                                {
                                    var sid = s.ComboId;
                                    var tildada = sugSeleccionadas.TryGetValue(sid, out var v) && v;
                                    <tr style="@(tildada ? "" : "opacity: 0.5;")">
                                        <td><input type="checkbox" checked="@tildada"
                                                   @onchange="@((e) => sugSeleccionadas[sid] = (bool)(e.Value ?? false))" /></td>
                                        <td>
                                            <div style="font-family: monospace; color: #1d4ed8; font-weight: 700;">@s.ComboSku</div>
                                            <div style="font-size: 0.75rem; color: #6b7280;">@s.ComboNombre</div>
                                        </td>
                                        <td>
                                            <span style="background:#16a34a; color:white; padding:0.1rem 0.4rem; border-radius:4px; font-weight:700; font-family:monospace; margin-right:0.4rem;">@s.OemCodigo</span>
                                            <strong>@(s.OemDescripcion ?? "")</strong>
                                        </td>
                                        <td style="text-align: right; font-weight: 700; color: #15803d;">
                                            @(s.OemPvpConIva.HasValue ? "$" + FormatMoney(s.OemPvpConIva.Value) : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarSugeridor" disabled="@aplicandoSugerencias">Cancelar</button>
                <button class="btn btn-primary" style="background:#16a34a; border-color:#16a34a;"
                        @onclick="AplicarSugerenciasOem" disabled="@(aplicandoSugerencias || sugSeleccionadas.Count(kv => kv.Value) == 0)">
                    @(aplicandoSugerencias ? "Aplicando..." : $"✅ Aplicar {sugSeleccionadas.Count(kv => kv.Value)} seleccionadas")
                </button>
            </div>
        </div>
    </div>
}

@* 2026-06-18: Mini-popover OEM — edicion rapida sin abrir el modal grande *@
@if (quickOemTarget is not null)
{
    <div class="modal-overlay" @onclick="CloseQuickOem">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 520px;">
            <div class="modal-header" style="background: #f5f3ff; color: #4c1d95;">
                <h4 style="margin: 0;">🟣 OEM de @quickOemTarget.Sku</h4>
                <button class="btn-close" @onclick="CloseQuickOem">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(quickOemError))
                {
                    <div class="form-error" style="margin-bottom: 0.6rem;">@quickOemError</div>
                }
                <p style="font-size: 0.78rem; color: #6b7280; margin: 0 0 0.6rem;">
                    Vincular el OEM hace que el precio del compuesto se calcule como <strong>OEM PVP × Multiplicador</strong> (ignorando la suma de componentes).
                </p>
                <div class="form-group" style="position: relative; margin-bottom: 0.7rem;">
                    <label class="form-label" style="font-size: 0.78rem;">OEM</label>
                    @if (quickOemId > 0)
                    {
                        var oSel = oems?.FirstOrDefault(x => x.Id == quickOemId);
                        <div style="display: flex; gap: 0.3rem; align-items: center;">
                            <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                <span style="background:#16a34a; color:white; padding:0.15rem 0.45rem; border-radius:6px; font-weight:800; font-family:monospace;">@(oSel?.Codigo ?? "?")</span>
                                <strong>@(oSel?.Descripcion ?? "—")</strong>
                                @if (oSel?.PvpConIva.HasValue == true)
                                {
                                    <span style="font-size: 0.72rem; color: #15803d;">· PVP $@FormatMoney(oSel.PvpConIva.Value)</span>
                                }
                            </div>
                            <button class="btn btn-secondary" type="button" @onclick="() => { quickOemId = 0; quickOemSearch = string.Empty; }" title="Quitar OEM">×</button>
                        </div>
                    }
                    else
                    {
                        <input class="form-input" @bind="quickOemSearch" @bind:event="oninput"
                               @onfocus="() => quickOemSearchOpen = true"
                               placeholder="🔍 Buscar por código, descripción, marca, barcode..." />
                        @if (quickOemSearchOpen && !string.IsNullOrWhiteSpace(quickOemSearch))
                        {
                            var matches = OemsMatching(quickOemSearch).Take(15).ToList();
                            <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 240px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                @if (matches.Count == 0)
                                {
                                    <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados.</div>
                                }
                                else
                                {
                                    @foreach (var o in matches)
                                    {
                                        var oId = o.Id;
                                        <div class="cli-pick-row" @onclick="() => SelectQuickOem(oId)"
                                             style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                            <span style="background:#16a34a; color:white; padding:0.1rem 0.4rem; border-radius:4px; font-weight:700; font-family:monospace; margin-right:0.4rem;">@o.Codigo</span>
                                            <strong>@(o.Descripcion ?? "")</strong>
                                            @if (!string.IsNullOrEmpty(o.Marca))
                                            {
                                                <span style="color:#6b7280; font-size:0.78rem;"> · @o.Marca</span>
                                            }
                                            @if (o.PvpConIva.HasValue)
                                            {
                                                <span style="color:#15803d; font-size:0.78rem;"> · PVP $@FormatMoney(o.PvpConIva.Value)</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>

                <div class="form-row" style="margin-bottom: 0.5rem;">
                    <div class="form-group" style="flex: 0 0 130px;">
                        <label class="form-label" style="font-size: 0.78rem;">Multiplicador</label>
                        <input class="form-input" type="number" step="0.0001" min="0" @bind="quickMultiplicador"
                               style="text-align: right;" />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label" style="font-size: 0.78rem;">Precio resultante</label>
                        @{
                            var oSel2 = oems?.FirstOrDefault(x => x.Id == quickOemId);
                            var multUsado = quickMultiplicador > 0 ? quickMultiplicador : 1m;
                            var pvpFinal = (oSel2?.PvpConIva ?? 0m) * multUsado;
                        }
                        <div class="form-input" style="background: #f3f4f6; font-weight: 700; color: #15803d;">
                            $@FormatMoney(pvpFinal)
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseQuickOem" disabled="@quickOemSaving">Cancelar</button>
                @if (quickOemTarget.OemId.HasValue)
                {
                    <button class="btn btn-danger" @onclick="DesvincularQuickOem" disabled="@quickOemSaving" title="Vuelve a calcular precio como suma de componentes">
                        🔗 Desvincular
                    </button>
                }
                <button class="btn btn-primary" @onclick="SaveQuickOem" disabled="@(quickOemSaving || quickOemId == 0)">
                    @(quickOemSaving ? "Guardando..." : "💾 Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeComboDto>? combos;
    private List<CafeProductoDto>? productos;
    private CafeSettingDto? settings;
    private bool loading = true;
    private string filtroTexto = "";
    private bool modoEdicion;
    private bool pushingMeliSku;

    // 2026-07-06: aplica el código de este compuesto a sus publicaciones de MercadoLibre.
    private async Task PushComboSkuToMeli(CafeComboDto c)
    {
        if (pushingMeliSku) return;
        if (string.IsNullOrWhiteSpace(c.Sku)) { ToastService.Error("Este producto no tiene código cargado."); return; }
        pushingMeliSku = true;
        try
        {
            var r = await Api.RenameComboMeliSkuAsync(c.Id);
            if (r is null) { ToastService.Error("No se pudo mandar el código a MeLi."); return; }
            if (r.Value.total == 0)
                ToastService.Info($"'{c.Sku}' no tiene publicaciones de MercadoLibre vinculadas.");
            else if (r.Value.ok == r.Value.total)
                ToastService.Success($"Código '{r.Value.newSku}' aplicado a {r.Value.ok} publicación(es) de MeLi.");
            else
                ToastService.Warning($"Código '{r.Value.newSku}' aplicado a {r.Value.ok} de {r.Value.total}. Revisá las que fallaron.");
        }
        finally { pushingMeliSku = false; }
    }

    private async Task GuardarNombreCombo(CafeComboDto c, string? nuevo)
    {
        if (string.IsNullOrWhiteSpace(nuevo) || nuevo.Trim() == c.Nombre) return;
        try
        {
            var u = await Api.UpdateCafeComboAsync(c.Id, new UpdateCafeComboRequest { Nombre = nuevo.Trim() });
            if (u is not null)
            {
                c.Nombre = u.Nombre;
                ToastService.Success($"Combo actualizado");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    // 2026-06-18: filtro de tipo — "MELI" (default), "COMPUESTO", "" (todos)
    private string filtroTipo = "MELI";
    // 2026-06-18: paginacion + reclasificacion
    private int paginaActual = 1;
    private const int pageSize = 100;
    private int TotalPaginas => Math.Max(1, (int)Math.Ceiling(CombosVisibles.Count / (double)pageSize));
    private bool mostrarConfirmReclasif = false;
    private bool reclasificando = false;
    private ApiClient.ReclasificarComboResult? reclasifResult = null;

    private async Task ToggleEsCompuesto(CafeComboDto c)
    {
        var nuevoValor = !c.EsCompuesto;
        var ok = await Api.SetEsCompuestoAsync(c.Id, nuevoValor);
        if (!ok) { ToastService.Error("No se pudo cambiar el tipo"); return; }
        c.EsCompuesto = nuevoValor;
        ToastService.Success(nuevoValor ? $"{c.Sku} es ahora 🟣 Compuesto" : $"{c.Sku} es ahora 🟠 Combo MeLi");
        StateHasChanged();
    }

    private void ConfirmarReclasificar()
    {
        mostrarConfirmReclasif = true;
        reclasifResult = null;
    }

