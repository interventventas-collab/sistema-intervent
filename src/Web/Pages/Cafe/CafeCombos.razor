    private List<CafeComboDto> CombosVisibles
    {
        get
        {
            if (combos is null) return new();
            IEnumerable<CafeComboDto> q = combos;
            // Filtro por tipo (default: solo Combos MeLi)
            if (filtroTipo == "MELI") q = q.Where(c => !c.EsCompuesto);
            else if (filtroTipo == "COMPUESTO") q = q.Where(c => c.EsCompuesto);
            else if (filtroTipo == "COMPUESTO_SIN_OEM") q = q.Where(c => c.EsCompuesto && !c.OemId.HasValue);
            if (!string.IsNullOrWhiteSpace(filtroTexto))
            {
                var t = filtroTexto.Trim();
                // 2026-06-18: buscador busca tambien por SKU (antes solo nombre+descripcion). Sin esto
                // si vos escribias "C926NEG" no aparecia nada — el SKU no era buscable.
                q = q.Where(c => c.Nombre.MatchesSearch(t) || c.Descripcion.MatchesSearch(t) || c.Sku.MatchesSearch(t));
            }
            return q.ToList();
        }
    }

