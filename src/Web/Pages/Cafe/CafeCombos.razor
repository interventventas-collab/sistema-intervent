    protected override async Task OnInitializedAsync()
    {
        try
        {
            productos = (await Api.GetCafeProductosAsync())?.Where(p => p.IsActive).ToList() ?? new();
            settings = await Api.GetCafeSettingsAsync();
            oems = await Api.GetCafeOemsAsync() ?? new();
        }
        catch { }
        await Load();

        // 2026-06-18: si vinimos con ?edit={id} o ?clone={id} desde /cafe/productos,
        // auto-abrir el modal correspondiente. Asi la unificacion productos+compuestos no requiere
        // duplicar el modal de combos.
        try
        {
            var uri = new Uri(Navigation.Uri);
            var qs = (uri.Query ?? "").TrimStart('?');
            int? editId = null, cloneId = null;
            foreach (var kv in qs.Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var eq = kv.IndexOf('=');
                var k = eq >= 0 ? kv.Substring(0, eq) : kv;
                var v = eq >= 0 ? kv.Substring(eq + 1) : "";
                if (k == "edit" && int.TryParse(v, out var e) && e > 0) editId = e;
                else if (k == "clone" && int.TryParse(v, out var c) && c > 0) cloneId = c;
            }
            // Cuando viene de productos, queremos ver compuestos por default — no MeLi.
            if (editId.HasValue || cloneId.HasValue) filtroTipo = "COMPUESTO";
            if (editId.HasValue)
            {
                var combo = combos.FirstOrDefault(c => c.Id == editId.Value);
                if (combo is not null) ShowEdit(combo);
            }
            else if (cloneId.HasValue)
            {
                var combo = combos.FirstOrDefault(c => c.Id == cloneId.Value);
                if (combo is not null) ShowCreateSimilar(combo);
            }
        }
        catch { }
    }

