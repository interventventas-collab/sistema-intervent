@page "/cafe/pedidos-whatsapp"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Pantalla de pedidos recibidos por WhatsApp.
   - Lista pedidos recibidos (manuales + automáticos vía poller)
   - Config: lista de teléfonos autorizados, trigger, auto-respuesta *@

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.6rem;">
        <h3 style="margin: 0;">💬 Pedidos por WhatsApp</h3>
        <div style="display: flex; gap: 0.4rem;">
            <button class="btn btn-secondary btn-sm" @onclick="ToggleConfig">
                <i class="fa-solid fa-gear"></i> Configuración
            </button>
            <button class="btn btn-secondary btn-sm" @onclick="Refrescar" disabled="@cargando">
                <i class="fa-solid fa-arrows-rotate"></i> Refrescar
            </button>
        </div>
    </div>

    <div class="card-body">
        @if (mostrarConfig)
        {
            <div style="background:#eff6ff; border:1px solid #93c5fd; border-radius:6px; padding:0.85rem 1rem; margin-bottom:1rem;">
                <strong>Configuración general</strong>
                <div style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:6px; padding:0.7rem; margin-top:0.6rem; font-size:0.85rem; color:#0c4a6e;">
                    <strong>📝 Formato de mensajes que reconoce el sistema:</strong>
                    <ul style="margin:0.3rem 0 0 1.2rem; padding:0;">
                        <li><code style="background:#dbeafe; padding:0.05rem 0.3rem; border-radius:3px;">##</code> al inicio del mensaje → pedido <strong>sin cliente</strong> (lo elegís manualmente)</li>
                        <li><code style="background:#dbeafe; padding:0.05rem 0.3rem; border-radius:3px;">#134</code> (un solo # + número) → pedido directo para el cliente con <strong>código interno 134</strong></li>
                    </ul>
                </div>
                <div style="display:flex; flex-direction:column; gap:0.4rem; margin-top:0.6rem;">
                    <label style="display:flex; align-items:center; gap:0.35rem; cursor:pointer; padding:0.4rem 0.8rem; background:@(configPollEnabled ? "#dcfce7" : "#f3f4f6"); border:1px solid @(configPollEnabled ? "#22c55e" : "#d1d5db"); border-radius:6px; font-size:0.88rem; user-select:none;">
                        <input type="checkbox" @bind="configPollEnabled" />
                        <strong>🟢 Lectura automática (cada 45s)</strong>
                    </label>
                    <label style="display:flex; align-items:center; gap:0.35rem; cursor:pointer; padding:0.4rem 0.8rem; background:@(configAutoRespEnabled ? "#dcfce7" : "#f3f4f6"); border:1px solid @(configAutoRespEnabled ? "#22c55e" : "#d1d5db"); border-radius:6px; font-size:0.88rem; user-select:none;">
                        <input type="checkbox" @bind="configAutoRespEnabled" />
                        <strong>✅ Responder automáticamente "PEDIDO RECIBIDO"</strong>
                    </label>
                </div>
                <div style="margin-top:0.7rem; display:flex; gap:0.5rem; justify-content:flex-end;">
                    <button class="btn btn-primary btn-sm" @onclick="GuardarConfig" disabled="@cargando">💾 Guardar config</button>
                </div>

                <hr style="margin:1rem 0;" />

                <strong>Teléfonos autorizados</strong>
                <p style="margin:0.3rem 0 0.6rem 0; font-size:0.78rem; color:#6b7280;">
                    El sistema chequea cada uno de estos números cada 45s buscando mensajes que empiecen con <strong><code>##</code></strong> o <strong><code>#NÚMERO</code></strong>.
                </p>

                <div style="display:grid; grid-template-columns: 1fr 1fr 80px 120px; gap:0.5rem; align-items:end; margin-bottom:0.6rem;">
                    <div>
                        <label style="font-size:0.78rem; color:#6b7280;">Teléfono nuevo (código país, sin +)</label>
                        <input type="text" class="form-control form-control-sm" @bind="nuevoTelefono" placeholder="5491122525458" />
                    </div>
                    <div>
                        <label style="font-size:0.78rem; color:#6b7280;">Etiqueta (opcional)</label>
                        <input type="text" class="form-control form-control-sm" @bind="nuevaEtiqueta" placeholder="Hermano, Yo móvil, etc." />
                    </div>
                    <div></div>
                    <div>
                        <button class="btn btn-success btn-sm" style="width:100%;" @onclick="AgregarTelefono" disabled="@(cargando || string.IsNullOrWhiteSpace(nuevoTelefono))">
                            ➕ Agregar
                        </button>
                    </div>
                </div>

                @if (telefonos is null || telefonos.Count == 0)
                {
                    <div style="background:#fef3c7; padding:0.6rem; border-radius:6px; color:#92400e; font-size:0.85rem;">
                        ⚠ No hay teléfonos cargados. Hasta que agregues al menos uno, el sistema no va a leer ningún pedido automático.
                    </div>
                }
                else
                {
                    <table class="table table-sm" style="margin-bottom:0;">
                        <thead style="background:#f9fafb;">
                            <tr>
                                <th>Activo</th>
                                <th>Teléfono</th>
                                <th>Etiqueta</th>
                                <th>Última lectura</th>
                                <th style="text-align:right;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var t in telefonos)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" checked="@t.Activo" @onchange="@(e => ToggleActivo(t, (bool)(e.Value ?? false)))" />
                                </td>
                                <td style="font-family:monospace;">@t.Telefono</td>
                                <td>@(t.Etiqueta ?? "—")</td>
                                <td style="color:#6b7280; font-size:0.8rem;">
                                    @(t.LastReadAt?.ToArTime().ToString("dd/MM HH:mm:ss") ?? "—")
                                </td>
                                <td style="text-align:right;">
                                    <button class="btn btn-secondary btn-sm" @onclick="() => ResetCursorTelefono(t.Id)" title="Re-leer todo el chat">🔄</button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => BorrarTelefono(t)" title="Borrar">🗑</button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        }

        <div style="background:#fefce8; border:1px solid #fde68a; border-radius:6px; padding:0.85rem 1rem; margin-bottom:1rem;">
            <strong>Pegar pedido manual</strong>
            <p style="margin:0.3rem 0; font-size:0.85rem; color:#854d0e;">
                Pegá el texto del WhatsApp del vendedor. Se guarda como pedido pendiente para que lo cargues en /cafe/ventas.
            </p>
            <textarea class="form-control" rows="6" @bind="textoNuevo" placeholder="#134
25 kg cafe premium
5 culkre sin cargo
1 caja vasos 120
1 mayo
1 mate cocido
fact A, x flete, ctacte" style="font-family: monospace; font-size:0.85rem;"></textarea>
            <div style="display:flex; justify-content:flex-end; gap:0.4rem; margin-top:0.5rem;">
                <input type="text" class="form-control form-control-sm" @bind="telefonoNuevo" placeholder="Teléfono (opcional)" style="width:200px;" />
                <button class="btn btn-primary btn-sm" @onclick="ProcesarTextoNuevo" disabled="@(cargando || string.IsNullOrWhiteSpace(textoNuevo))">
                    @(cargando ? "Guardando..." : "📥 Guardar pedido")
                </button>
            </div>
        </div>

        @if (pedidos is null)
        {
            <p class="text-muted">Cargando...</p>
        }
        else if (pedidos.Count == 0)
        {
            <div style="background:#f9fafb; border:1px dashed #e5e7eb; padding:2rem; text-align:center; border-radius:8px; color:#6b7280;">
                Sin pedidos por ahora. Pegá un texto arriba para empezar.
            </div>
        }
        else
        {
            <h4 style="margin: 1rem 0 0.5rem 0;">📥 Pedidos recibidos (@pedidos.Count)</h4>
            @foreach (var p in pedidos)
            {
                <div class="pedido-card @(p.SeenAt == null ? "pedido-nuevo" : "")">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.6rem; margin-bottom:0.5rem;">
                        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
                            @if (p.SeenAt == null) { <span class="estado-badge" style="background:#fef3c7; color:#92400e;">🟡 NUEVO</span> }
                            @if (p.Estado == "VENTA_CREADA") { <span class="estado-badge" style="background:#dcfce7; color:#14532d;">✅ CARGADO</span> }
                            <span style="color:#6b7280; font-size:0.85rem;">@p.RecibidoAt.ToArTime().ToString("dd/MM HH:mm:ss")</span>
                            @if (!string.IsNullOrEmpty(p.Telefono)) { <span style="color:#6b7280; font-size:0.78rem;">📞 @p.Telefono</span> }
                            <span style="color:#6b7280; font-size:0.78rem;">vía @p.Source</span>
                            @if (p.ClienteId.HasValue && !string.IsNullOrEmpty(p.ClienteNombre))
                            {
                                <span style="background:#dcfce7; color:#14532d; font-size:0.75rem; padding:0.1rem 0.4rem; border-radius:4px; font-weight:600;" title="Cliente detectado automáticamente por #código">
                                    👤 @p.ClienteNombre
                                </span>
                            }
                        </div>
                        <div style="display:flex; gap:0.3rem;">
                            <button class="btn btn-success btn-sm" @onclick="() => IrANuevaVenta(p.Id)" title="Cargar esta venta">
                                <i class="fa-solid fa-cart-shopping"></i> Cargar venta
                            </button>
                            <button class="btn btn-secondary btn-sm" @onclick="() => MarcarVisto(p.Id)" title="Marcar como visto/usado">
                                ✓ Visto
                            </button>
                            <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(p.Id)" title="Eliminar definitivamente">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <pre style="background:#1f2937; color:#e5e7eb; padding:0.7rem 0.9rem; border-radius:6px; font-size:0.9rem; margin:0; white-space:pre-wrap; font-family: 'Menlo', 'Monaco', monospace;">@p.TextoCrudo</pre>
                </div>
            }
        }
    </div>
</div>

<style>
    .pedido-card { border:1px solid #e5e7eb; border-radius:8px; padding:0.85rem; margin-bottom:0.6rem; background:white; }
    .pedido-nuevo { background:#fffbeb; border-color:#fde68a; }
    .estado-badge { font-size:0.72rem; padding:0.1rem 0.5rem; border-radius:4px; font-weight:600; }
</style>

@code {
    private List<ApiClient.WhatsAppPedidoDto>? pedidos;
    private List<ApiClient.WhatsAppPedidoTelefonoDto>? telefonos;
    private bool cargando;
    private string textoNuevo = "";
    private string telefonoNuevo = "";
    private bool mostrarConfig;

    private string configTrigger = "#PED";
    private bool configPollEnabled;
    private bool configAutoRespEnabled = true;

    private string nuevoTelefono = "";
    private string nuevaEtiqueta = "";

    // Auto-refresh para mantener la lista sincronizada con los pedidos que llegan via poller.
    private System.Threading.Timer? autoRefreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await Refrescar();
        await CargarConfig();
        // Cada 15 segundos refrescar la lista en silencio (sin loader visible) para que aparezcan
        // los pedidos nuevos sin que el usuario tenga que tocar "Refrescar".
        autoRefreshTimer = new System.Threading.Timer(async _ => await InvokeAsync(RefrescarSilencioso),
            null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    private async Task RefrescarSilencioso()
    {
        try
        {
            var nueva = await Api.ListarWhatsAppPedidosAsync();
            if (nueva is not null) { pedidos = nueva; StateHasChanged(); }
        }
        catch { /* silencioso */ }
    }

    public void Dispose()
    {
        autoRefreshTimer?.Dispose();
    }

    private async Task Refrescar()
    {
        cargando = true; StateHasChanged();
        try { pedidos = await Api.ListarWhatsAppPedidosAsync(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        cargando = false; StateHasChanged();
    }

    private async Task CargarConfig()
    {
        try
        {
            var cfg = await Api.GetWhatsAppPedidosConfigAsync();
            if (cfg is not null)
            {
                configTrigger = cfg.Trigger;
                configPollEnabled = cfg.PollEnabled;
                configAutoRespEnabled = cfg.AutoResponderEnabled;
                telefonos = cfg.Telefonos;
            }
        }
        catch { }
    }

    private async Task GuardarConfig()
    {
        cargando = true;
        try
        {
            var ok = await Api.SetWhatsAppPedidosConfigAsync(configTrigger, configPollEnabled, configAutoRespEnabled);
            if (ok) ToastService.Success("Configuración guardada");
            else ToastService.Error("No se pudo guardar");
        }
        finally { cargando = false; }
    }

    private async Task AgregarTelefono()
    {
        if (string.IsNullOrWhiteSpace(nuevoTelefono)) return;
        cargando = true;
        try
        {
            var r = await Api.AgregarTelefonoAutorizadoAsync(nuevoTelefono.Trim(), string.IsNullOrWhiteSpace(nuevaEtiqueta) ? null : nuevaEtiqueta.Trim());
            if (r is not null) { ToastService.Success("Teléfono agregado"); nuevoTelefono = ""; nuevaEtiqueta = ""; await CargarConfig(); }
            else ToastService.Error("No se pudo agregar (¿ya existía o teléfono inválido?)");
        }
        finally { cargando = false; }
    }

    private async Task ToggleActivo(ApiClient.WhatsAppPedidoTelefonoDto t, bool activo)
    {
        t.Activo = activo;
        await Api.EditarTelefonoAutorizadoAsync(t.Id, null, null, activo);
    }

    private async Task BorrarTelefono(ApiClient.WhatsAppPedidoTelefonoDto t)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Borrar {t.Telefono}?")) return;
        var ok = await Api.BorrarTelefonoAutorizadoAsync(t.Id);
        if (ok) { ToastService.Success("Borrado"); await CargarConfig(); }
        else ToastService.Error("No se pudo borrar");
    }

    private async Task ResetCursorTelefono(int id)
    {
        var ok = await Api.ResetCursorTelefonoAsync(id);
        if (ok) { ToastService.Success("Cursor reseteado, va a re-leer todo"); await CargarConfig(); }
    }

    private void ToggleConfig() => mostrarConfig = !mostrarConfig;

    private void IrANuevaVenta(int pedidoId)
        => Nav.NavigateTo($"/cafe/ventas?pedidoId={pedidoId}");

    private async Task ProcesarTextoNuevo()
    {
        if (string.IsNullOrWhiteSpace(textoNuevo)) return;
        cargando = true; StateHasChanged();
        try
        {
            var r = await Api.RecibirWhatsAppPedidoAsync(telefonoNuevo, textoNuevo);
            if (r is null) ToastService.Error("Falló el procesamiento");
            else if (!string.IsNullOrEmpty(r.Error)) ToastService.Warning("Procesado con errores: " + r.Error);
            else ToastService.Success("Pedido procesado");
            textoNuevo = ""; telefonoNuevo = "";
            await Refrescar();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { cargando = false; }
    }

    private async Task MarcarVisto(int id)
    {
        try { await Api.MarkWhatsAppPedidoSeenAsync(id); await Refrescar(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task Descartar(int id)
    {
        try { await Api.DescartarWhatsAppPedidoAsync(id); await Refrescar(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task Eliminar(int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "¿Eliminar este pedido definitivamente? No se podrá recuperar.")) return;
        try
        {
            var ok = await Api.EliminarWhatsAppPedidoAsync(id);
            if (ok) { ToastService.Success("Pedido eliminado"); await Refrescar(); }
            else ToastService.Error("No se pudo eliminar");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }
}
