@page "/cafe/pedidos-whatsapp"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Pantalla de pedidos recibidos por WhatsApp.
   Por ahora soporta solo PASTE manual del texto (Fase 1). Próximamente Playwright auto-scraping. *@

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.6rem;">
        <h3 style="margin: 0;">💬 Pedidos por WhatsApp</h3>
        <div style="display: flex; gap: 0.4rem;">
            <button class="btn btn-secondary btn-sm" @onclick="ToggleConfig">
                <i class="fa-solid fa-gear"></i> Configuración
            </button>
            <button class="btn btn-secondary btn-sm" @onclick="Refrescar" disabled="@cargando">
                <i class="fa-solid fa-arrows-rotate"></i> Refrescar
            </button>
        </div>
    </div>

    <div class="card-body">
        @if (mostrarConfig)
        {
            <div style="background:#eff6ff; border:1px solid #93c5fd; border-radius:6px; padding:0.85rem 1rem; margin-bottom:1rem;">
                <strong>Configuración</strong>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.6rem; margin-top:0.6rem; align-items:end;">
                    <div>
                        <label style="font-size:0.78rem; color:#6b7280;">Teléfono del vendedor (con código país, sin espacios)</label>
                        <input type="text" class="form-control form-control-sm" @bind="configTelefono" placeholder="5491122525458" />
                    </div>
                    <div>
                        <label style="font-size:0.78rem; color:#6b7280;">Trigger (al inicio del mensaje)</label>
                        <input type="text" class="form-control form-control-sm" @bind="configTrigger" placeholder="#PED" />
                    </div>
                </div>
                <div style="margin-top:0.7rem; display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
                    <label style="display:flex; align-items:center; gap:0.35rem; cursor:pointer; padding:0.4rem 0.8rem; background:@(configPollEnabled ? "#dcfce7" : "#f3f4f6"); border:1px solid @(configPollEnabled ? "#22c55e" : "#d1d5db"); border-radius:6px; font-size:0.88rem; user-select:none;">
                        <input type="checkbox" @bind="configPollEnabled" />
                        <strong>🟢 Lectura automática de WhatsApp (cada 45s)</strong>
                    </label>
                    @if (!string.IsNullOrEmpty(configLastMessageId))
                    {
                        <span style="font-size:0.75rem; color:#6b7280;">Último msg leído: <span style="font-family:monospace;">@configLastMessageId.Substring(0, Math.Min(40, configLastMessageId.Length))...</span></span>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="ResetCursor" disabled="@cargando">
                        🔄 Resetear cursor
                    </button>
                    <button class="btn btn-primary btn-sm" @onclick="GuardarConfig" disabled="@cargando">
                        💾 Guardar
                    </button>
                </div>
                <p style="margin:0.5rem 0 0 0; font-size:0.78rem; color:#6b7280;">
                    Cuando esté activado, el sistema cada 45s lee mensajes nuevos del chat de ese teléfono. Si empiezan con <strong>@configTrigger</strong>, los procesa con IA.
                </p>
            </div>
        }

        <div style="background:#fefce8; border:1px solid #fde68a; border-radius:6px; padding:0.85rem 1rem; margin-bottom:1rem;">
            <strong>Pegar pedido manual</strong>
            <p style="margin:0.3rem 0; font-size:0.85rem; color:#854d0e;">
                Por ahora pegás el texto del WhatsApp acá. La IA va a detectar productos y armar una venta lista para confirmar.
            </p>
            <textarea class="form-control" rows="5" @bind="textoNuevo" placeholder="#PEDIDO ESC NUCLEO&#10;25 kg cafe premium&#10;5 culkre sin cargo&#10;1 caja vasos 120&#10;1 caja vasos 180&#10;1 mayo&#10;1 mate cocido&#10;fact A, x flete, ctacte" style="font-family: monospace; font-size:0.85rem;"></textarea>
            <div style="display:flex; justify-content:flex-end; gap:0.4rem; margin-top:0.5rem;">
                <input type="text" class="form-control form-control-sm" @bind="telefonoNuevo" placeholder="Teléfono (opcional)" style="width:200px;" />
                <button class="btn btn-primary btn-sm" @onclick="ProcesarTextoNuevo" disabled="@(cargando || string.IsNullOrWhiteSpace(textoNuevo))">
                    @(cargando ? "Procesando..." : "🤖 Procesar con IA")
                </button>
            </div>
        </div>

        @if (pedidos is null)
        {
            <p class="text-muted">Cargando...</p>
        }
        else if (pedidos.Count == 0)
        {
            <div style="background:#f9fafb; border:1px dashed #e5e7eb; padding:2rem; text-align:center; border-radius:8px; color:#6b7280;">
                Sin pedidos por ahora. Pegá un texto arriba para empezar.
            </div>
        }
        else
        {
            <h4 style="margin: 1rem 0 0.5rem 0;">📥 Pedidos recibidos (@pedidos.Count)</h4>
            @foreach (var p in pedidos)
            {
                <div class="pedido-card @(p.SeenAt == null ? "pedido-nuevo" : "")">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.6rem;">
                        <div style="flex:1; min-width:0;">
                            <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
                                <span class="estado-badge @GetEstadoCls(p.Estado)">@p.Estado</span>
                                @if (p.SeenAt == null) { <span class="estado-badge" style="background:#fef3c7; color:#92400e;">NUEVO</span> }
                                <span style="color:#6b7280; font-size:0.8rem;">@p.RecibidoAt.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                @if (!string.IsNullOrEmpty(p.Telefono)) { <span style="color:#6b7280; font-size:0.78rem;">📞 @p.Telefono</span> }
                                <span style="color:#6b7280; font-size:0.78rem;">vía @p.Source</span>
                            </div>
                            @if (!string.IsNullOrEmpty(p.ClienteNombre))
                            {
                                <div style="font-size:0.95rem; font-weight:600; margin-top:0.3rem;">
                                    👤 @p.ClienteNombre
                                    @if (p.ClienteId.HasValue) { <span style="color:#22c55e; font-size:0.78rem;">✓ identificado</span> }
                                    else { <span style="color:#f59e0b; font-size:0.78rem;">⚠ no matchea cliente del sistema</span> }
                                </div>
                            }
                        </div>
                        <div style="display:flex; gap:0.3rem;">
                            @if (p.Estado == "PARSEADO" || p.Estado == "NUEVO")
                            {
                                <button class="btn btn-success btn-sm" @onclick="() => CargarComoVenta(p)" title="Abre /cafe/ventas con productos pre-cargados">
                                    <i class="fa-solid fa-cart-shopping"></i> Cargar venta
                                </button>
                            }
                            @if (p.Estado == "ERROR" || p.Estado == "NUEVO")
                            {
                                <button class="btn btn-secondary btn-sm" @onclick="() => ReParsear(p.Id)" disabled="@cargando">
                                    <i class="fa-solid fa-arrows-rotate"></i> Re-parsear
                                </button>
                            }
                            <button class="btn btn-secondary btn-sm" @onclick="() => Descartar(p.Id)" title="Descartar">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                    </div>

                    <details style="margin-top:0.5rem;">
                        <summary style="cursor:pointer; color:#6b7280; font-size:0.85rem;">Ver texto crudo</summary>
                        <pre style="background:#1f2937; color:#e5e7eb; padding:0.6rem; border-radius:4px; font-size:0.8rem; margin-top:0.3rem; white-space:pre-wrap;">@p.TextoCrudo</pre>
                    </details>

                    @if (!string.IsNullOrEmpty(p.ParseError))
                    {
                        <div style="background:#fee2e2; border:1px solid #fca5a5; padding:0.5rem 0.7rem; margin-top:0.4rem; border-radius:4px; font-size:0.85rem; color:#991b1b;">
                            ❌ Error de parseo: @p.ParseError
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(p.ProductosParseados))
                    {
                        @try
                        {
                            var parsed = System.Text.Json.JsonDocument.Parse(p.ProductosParseados);
                            if (parsed.RootElement.TryGetProperty("productos", out var prods))
                            {
                                <div style="margin-top:0.5rem;">
                                    <strong style="font-size:0.85rem;">Productos detectados (@prods.GetArrayLength()):</strong>
                                    <table class="table table-sm" style="margin-top:0.3rem; font-size:0.85rem;">
                                        <thead>
                                            <tr><th>SKU</th><th>Producto</th><th style="text-align:right;">Cant.</th><th>Formato</th><th style="text-align:right;">Precio</th><th>Confianza</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var prod in prods.EnumerateArray())
                                            {
                                                var sku = prod.TryGetProperty("sku", out var s) && s.ValueKind == System.Text.Json.JsonValueKind.String ? s.GetString() : null;
                                                var nombre = prod.TryGetProperty("nombre", out var nm) && nm.ValueKind == System.Text.Json.JsonValueKind.String ? nm.GetString() : "?";
                                                var cant = prod.TryGetProperty("cantidad", out var c) && c.ValueKind == System.Text.Json.JsonValueKind.Number ? c.GetInt32() : 0;
                                                var fmt = prod.TryGetProperty("formato", out var f) && f.ValueKind == System.Text.Json.JsonValueKind.String ? f.GetString() : "-";
                                                var ovr = prod.TryGetProperty("precioOverride", out var po) && po.ValueKind == System.Text.Json.JsonValueKind.Number ? po.GetDecimal().ToString("N0") : "";
                                                var cf = prod.TryGetProperty("confianza", out var co) && co.ValueKind == System.Text.Json.JsonValueKind.Number ? co.GetDouble() : 0;
                                                <tr>
                                                    <td style="font-family:monospace;">@(sku ?? "?")</td>
                                                    <td>@nombre</td>
                                                    <td style="text-align:right;">@cant</td>
                                                    <td>@fmt</td>
                                                    <td style="text-align:right;">@ovr</td>
                                                    <td>
                                                        <span class="@(cf >= 0.8 ? "confianza-ok" : cf >= 0.5 ? "confianza-medio" : "confianza-bajo")">
                                                            @(cf * 100).ToString("N0")%
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                        catch { }
                    }
                </div>
            }
        }
    </div>
</div>

<style>
    .pedido-card { border:1px solid #e5e7eb; border-radius:8px; padding:0.85rem; margin-bottom:0.6rem; background:white; }
    .pedido-nuevo { background:#fffbeb; border-color:#fde68a; }
    .estado-badge { font-size:0.72rem; padding:0.1rem 0.5rem; border-radius:4px; font-weight:600; }
    .estado-NUEVO { background:#fef3c7; color:#92400e; }
    .estado-PARSEADO { background:#dbeafe; color:#1e40af; }
    .estado-VENTA_CREADA { background:#dcfce7; color:#14532d; }
    .estado-ERROR { background:#fee2e2; color:#991b1b; }
    .estado-DESCARTADO { background:#f3f4f6; color:#6b7280; }
    .confianza-ok { background:#dcfce7; color:#14532d; padding:0.1rem 0.4rem; border-radius:3px; font-size:0.78rem; font-weight:600; }
    .confianza-medio { background:#fef3c7; color:#92400e; padding:0.1rem 0.4rem; border-radius:3px; font-size:0.78rem; font-weight:600; }
    .confianza-bajo { background:#fee2e2; color:#991b1b; padding:0.1rem 0.4rem; border-radius:3px; font-size:0.78rem; font-weight:600; }
</style>

@code {
    private List<ApiClient.WhatsAppPedidoDto>? pedidos;
    private bool cargando;
    private string textoNuevo = "";
    private string telefonoNuevo = "";
    private bool mostrarConfig;
    private string configTelefono = "";
    private string configTrigger = "#PED";
    private bool configPollEnabled;
    private string configLastMessageId = "";

    protected override async Task OnInitializedAsync()
    {
        await Refrescar();
        await CargarConfig();
    }

    private async Task Refrescar()
    {
        cargando = true; StateHasChanged();
        try { pedidos = await Api.ListarWhatsAppPedidosAsync(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        cargando = false; StateHasChanged();
    }

    private async Task CargarConfig()
    {
        try
        {
            var cfg = await Api.GetWhatsAppPedidosConfigAsync();
            if (cfg is not null)
            {
                configTelefono = cfg.Telefono; configTrigger = cfg.Trigger;
                configPollEnabled = cfg.PollEnabled; configLastMessageId = cfg.LastMessageId;
            }
        }
        catch { }
    }

    private async Task GuardarConfig()
    {
        cargando = true;
        try
        {
            var ok = await Api.SetWhatsAppPedidosConfigAsync(configTelefono, configTrigger, configPollEnabled);
            if (ok) ToastService.Success("Configuración guardada");
            else ToastService.Error("No se pudo guardar");
        }
        finally { cargando = false; }
    }

    private async Task ResetCursor()
    {
        cargando = true;
        try
        {
            var ok = await Api.ResetWhatsAppPedidosCursorAsync();
            if (ok) { ToastService.Success("Cursor reseteado"); configLastMessageId = ""; }
            else ToastService.Error("No se pudo resetear");
        }
        finally { cargando = false; StateHasChanged(); }
    }

    private void ToggleConfig() => mostrarConfig = !mostrarConfig;

    private string GetEstadoCls(string e) => "estado-" + e;

    private async Task ProcesarTextoNuevo()
    {
        if (string.IsNullOrWhiteSpace(textoNuevo)) return;
        cargando = true; StateHasChanged();
        try
        {
            var r = await Api.RecibirWhatsAppPedidoAsync(telefonoNuevo, textoNuevo);
            if (r is null) ToastService.Error("Falló el procesamiento");
            else if (!string.IsNullOrEmpty(r.Error)) ToastService.Warning("Procesado con errores: " + r.Error);
            else ToastService.Success("Pedido procesado");
            textoNuevo = ""; telefonoNuevo = "";
            await Refrescar();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { cargando = false; }
    }

    private async Task ReParsear(int id)
    {
        cargando = true; StateHasChanged();
        try { await Api.ReParsearWhatsAppPedidoAsync(id); await Refrescar(); }
        finally { cargando = false; }
    }

    private async Task Descartar(int id)
    {
        try { await Api.DescartarWhatsAppPedidoAsync(id); await Refrescar(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private void CargarComoVenta(ApiClient.WhatsAppPedidoDto p)
    {
        // Navegar a /cafe/ventas con un query param que dispara el preload
        Nav.NavigateTo($"/cafe/ventas?pedidoWhatsApp={p.Id}");
    }
}
