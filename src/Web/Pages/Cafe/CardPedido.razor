@* Tarjeta individual de pedido en el tablero de Preparacion.
   Modo compacto por default (solo header) — el armador despliega la composicion con el boton
   "Ver composicion". Al desplegar aparece la lista de items con checkboxes (visual, no se
   persiste) y el boton "Marcar como LISTO" que saca el pedido del tablero.

   Si el cliente tiene TieneMiniImpresora=true, aparece tambien un boton "🖨️" para imprimir
   el ticket rapido. Y un checkbox para seleccion multiple (imprimir varios juntos). *@

<div class="prep-card @(SelectedForPrint ? "prep-card-selected" : "")">
    @{
        var todoTildado = tildados.Count >= Venta.Items.Count && Venta.Items.Count > 0;
    }
    <div class="prep-card-header armar" style="gap:0.7rem;">
        @* Lado izquierdo: icono PDF rojo gigante estilo Drive con el numero del comprobante.
           Click abre el PDF en Drive (si está subido). *@
        @if (Venta.DriveSubidoAt.HasValue && !string.IsNullOrEmpty(Venta.DriveFileId))
        {
            <a href="https://drive.google.com/file/d/@Venta.DriveFileId/view" target="_blank"
               class="prep-drive-icon-link" title="Abrir PDF en Google Drive">
                <div class="prep-drive-icon">
                    <svg width="38" height="48" viewBox="0 0 24 30" xmlns="http://www.w3.org/2000/svg">
                        <path d="M14 0H4C1.79 0 0 1.79 0 4v22c0 2.21 1.79 4 4 4h16c2.21 0 4-1.79 4-4V10L14 0z" fill="#ea4335"/>
                        <path d="M14 0v8c0 1.1.9 2 2 2h8L14 0z" fill="#fbbc04"/>
                        <text x="12" y="22" text-anchor="middle" fill="white" font-size="6" font-weight="700" font-family="Arial">PDF</text>
                    </svg>
                </div>
            </a>
        }
        else
        {
            <div class="prep-drive-icon" title="Aún no subido a Drive" style="opacity:0.4;">
                <svg width="38" height="48" viewBox="0 0 24 30" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14 0H4C1.79 0 0 1.79 0 4v22c0 2.21 1.79 4 4 4h16c2.21 0 4-1.79 4-4V10L14 0z" fill="#9ca3af"/>
                    <text x="12" y="22" text-anchor="middle" fill="white" font-size="6" font-weight="700" font-family="Arial">PDF</text>
                </svg>
            </div>
        }
        <div style="flex:1; min-width:0;">
            <div style="display:flex; align-items:center; gap:0.4rem; flex-wrap:wrap;">
                <span class="prep-card-numero" style="font-family:monospace;">@Venta.Numero</span>
                @if (!string.IsNullOrEmpty(Venta.WeekDays))
                {
                    <span class="prep-card-pill">📅 @DiasPretty(Venta.WeekDays)</span>
                }
                @if (!string.IsNullOrEmpty(Venta.EntregaPor))
                {
                    <span class="prep-card-pill" style="background:#dbeafe; color:#1e40af;">🚚 @Venta.EntregaPor</span>
                }
                @if (Venta.ImpresaAt.HasValue)
                {
                    <span class="prep-card-pill prep-card-pill-impresa" title="@($"Impreso {Venta.ImpresaCount} ve{(Venta.ImpresaCount == 1 ? "z" : "ces")}")">✅ Impreso @HaceCuanto(Venta.ImpresaAt)</span>
                }
                <button class="prep-btn-quitar" @onclick="OnQuitarDelFlujo" title="Sacar del tablero (la venta y el PDF quedan intactos)" style="margin-left:auto;">×</button>
            </div>
            <div class="prep-card-cliente" style="margin-top:0.25rem;">👤 @Venta.ClienteNombre</div>
            @if (!string.IsNullOrEmpty(Venta.ClienteLocalidad) || !string.IsNullOrEmpty(Venta.ClienteCiudad))
            {
                <div class="prep-card-meta">📍 @(string.Join(" · ", new[] { Venta.ClienteLocalidad, Venta.ClienteCiudad }.Where(s => !string.IsNullOrEmpty(s))))</div>
            }
        </div>
        @* Botones de la derecha: Mini impresora individual + checkbox de seleccion multiple.
           Solo se muestran si el cliente tiene activado el flag TieneMiniImpresora. *@
        @if (Venta.TieneMiniImpresora)
        {
            <div class="prep-mini-impresora-actions">
                <button class="prep-btn-mini-impresora" @onclick="OnImprimir" title="Imprimir este ticket en mini impresora">
                    🖨️
                </button>
                <label class="prep-check-print-wrap" title="Seleccionar para imprimir varios juntos">
                    <input type="checkbox" class="prep-check-print" checked="@SelectedForPrint" @onchange="OnToggleSelect" />
                    <span style="font-size:0.65rem; color:#6b7280;">Sel.</span>
                </label>
            </div>
        }
    </div>

    @* Boton para desplegar la composicion del pedido. Por default cerrado. *@
    <button class="prep-btn-ver-comp" @onclick="() => mostrarComposicion = !mostrarComposicion">
        @if (mostrarComposicion)
        {
            <span>▲ Ocultar composición</span>
        }
        else
        {
            <span>📋 Ver composición (@Venta.Items.Count @(Venta.Items.Count == 1 ? "item" : "items"))</span>
        }
    </button>

    @if (mostrarComposicion)
    {
        <div class="prep-card-body">
            @if (Venta.Items.Count == 0)
            {
                <div class="prep-empty">Sin items.</div>
            }
            else
            {
                @foreach (var it in Venta.Items)
                {
                    var tildado = tildados.Contains(it.Id);
                    <div class="prep-item @(tildado ? "tildado" : "")">
                        <input type="checkbox" class="prep-check" checked="@tildado" @onclick="() => ToggleTildado(it.Id)" />
                        <div class="prep-item-cant"><span class="x">×</span> @it.Cantidad</div>
                        <div>
                            <div class="prep-item-desc-prod prep-item-desc">@it.ProductoNombre</div>
                            <div class="prep-item-tags">
                                <span class="prep-tag prep-tag-formato">@FormatoLabel(it.Formato)</span>
                                @if (!string.IsNullOrEmpty(it.Molienda))
                                {
                                    <span class="prep-tag prep-tag-molienda">@MoliendaIcon(it.Molienda) @it.Molienda</span>
                                }
                                @if (it.EsDoyPack)
                                {
                                    <span class="prep-tag prep-tag-envase-doypack">📦 Doy pack</span>
                                }
                                else if (it.EsEnvasePlateado)
                                {
                                    <span class="prep-tag prep-tag-envase-plateado">⚪ Envase plateado</span>
                                }
                                else if (it.Categoria == "CAFE")
                                {
                                    <span class="prep-tag prep-tag-envase-negro">⚫ Envase negro</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="prep-card-footer">
            <button class="prep-btn-avanzar listo @(todoTildado ? "todo-tildado" : "")" @onclick="OnAvanzar" style="flex:1;">
                ✅ Marcar como LISTO
            </button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CafePreparacionVentaDto Venta { get; set; } = null!;
    [Parameter] public EventCallback OnAvanzar { get; set; }
    [Parameter] public EventCallback OnRetroceder { get; set; }
    [Parameter] public EventCallback OnQuitarDelFlujo { get; set; }
    [Parameter] public EventCallback OnImprimir { get; set; }
    [Parameter] public EventCallback<bool> OnToggleSelectForPrint { get; set; }
    [Parameter] public bool SelectedForPrint { get; set; }

    // Por default la composicion esta colapsada (el armador la despliega cuando va a armar ese pedido).
    private bool mostrarComposicion = false;

    // IDs de items tildados (solo visual, no se persiste).
    private HashSet<int> tildados = new();

    private void ToggleTildado(int itemId)
    {
        if (!tildados.Add(itemId)) tildados.Remove(itemId);
    }

    private async Task OnToggleSelect(ChangeEventArgs e)
    {
        var val = e.Value is bool b ? b : false;
        await OnToggleSelectForPrint.InvokeAsync(val);
    }

    private static string FormatoLabel(string f) => f switch
    {
        "1KG" => "1 kg",
        "MEDIO" => "1/2 kg",
        "CUARTO" => "1/4 kg",
        "UNIT" => "Unidad",
        "BULTO" => "Bulto",
        _ => f
    };

    private static string MoliendaIcon(string m) => m switch
    {
        "EN GRANOS" => "🫘",
        "MOLIDO ESPRESS" => "⚡",
        _ when m.StartsWith("MOLIDO") => "☕",
        "MINI EXPRESS" => "🔸",
        _ => "·"
    };

    private static string DiasPretty(string weekDays)
    {
        var partes = weekDays.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim().ToUpperInvariant())
            .ToArray();
        return string.Join(" ", partes);
    }

    private static string HaceCuanto(DateTime? t)
    {
        if (t is null) return "";
        var diff = DateTime.UtcNow - t.Value;
        if (diff.TotalMinutes < 1) return "ahora";
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes}'";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours}h";
        return $"hace {(int)diff.TotalDays}d";
    }
}
