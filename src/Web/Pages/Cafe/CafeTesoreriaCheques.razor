@page "/cafe/tesoreria/cheques"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@using Web.Models

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3 style="margin:0;">📄 Cheques en cartera (@(cheques?.Count(c => c.Estado == "EN_CARTERA") ?? 0))</h3>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
            <button class="btn btn-success" style="font-size:0.8rem;" @onclick="AbrirNuevo">➕ Nuevo cheque</button>
            <div style="width:1px; height:24px; background:#d1d5db; margin:0 0.25rem;"></div>
            @foreach (var e in estados)
            {
                <button class="btn @(estadoFiltro == e.key ? "btn-primary" : "btn-secondary")" style="font-size:0.8rem;" @onclick="() => SetFiltro(e.key)">@e.label</button>
            }
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        @if (loading)
        {
            <p class="text-muted" style="padding:1rem;">Cargando...</p>
        }
        else if (cheques is null || !ChequesFiltrados.Any())
        {
            <p class="text-muted" style="padding:1rem;">Sin cheques con este filtro.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="table table-compact">
                    <thead>
                        <tr>
                            <th>Banco</th>
                            <th>Número</th>
                            <th>Emisor</th>
                            <th>Cliente origen</th>
                            <th style="text-align:right;">Importe</th>
                            <th>Vence</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in ChequesFiltrados)
                        {
                            <tr>
                                <td>@c.Banco</td>
                                <td><b>@c.Numero</b></td>
                                <td>@(c.Emisor ?? "—")</td>
                                <td>@(c.ClienteOrigenNombre ?? "—")</td>
                                <td style="text-align:right; font-weight:600;">$@c.Importe.ToString("N2")</td>
                                <td>@(c.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td><span class="badge @EstadoClass(c.Estado)">@EstadoLabel(c.Estado)</span></td>
                                <td>
                                    @if (c.Estado == "EN_CARTERA")
                                    {
                                        @if (c.CobranzaOrigenId.HasValue)
                                        {
                                            <span style="color:#059669; font-size:0.72rem; font-weight:600;" title="Cheque aplicado a cobranza @c.CobranzaOrigenId">✓ Cob. #@c.CobranzaOrigenId</span>
                                        }
                                        else
                                        {
                                            <button class="btn-icon" title="Aplicar a cobranza (asociar a venta)" @onclick="() => AbrirAplicar(c)">🔗</button>
                                        }
                                        <button class="btn-icon" title="Depositar al banco" @onclick="() => Depositar(c)">🏦</button>
                                        <button class="btn-icon" title="Cobrar por ventanilla" @onclick="() => CobrarVent(c)">💵</button>
                                        <button class="btn-icon" title="Rechazar (rebotó)" @onclick="() => Rechazar(c)">❌</button>
                                    }
                                    else
                                    {
                                        <span style="color:#6b7280; font-size:0.78rem;">(sin acciones)</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* ════════════ Modal Nuevo cheque ════════════ *@
@if (showNuevo)
{
    <div class="modal-overlay">
        <div class="modal-card" style="max-width: 560px;">
            <div class="modal-header">
                <h3 style="margin:0;">➕ Nuevo cheque (alta manual)</h3>
                <button class="btn-close" @onclick="CerrarNuevo">✕</button>
            </div>
            <div class="modal-body">
                <p style="font-size:0.78rem; color:#6b7280; margin:0 0 0.7rem;">
                    Cargá un cheque físico (papel) que recibiste. Entra a cartera "sin asignar".
                    Cuando lo uses en una cobranza queda asociado al cliente que pagó.
                </p>
                <div class="form-row">
                    <div class="form-group" style="flex:2;">
                        <label class="form-label">Banco *</label>
                        <select class="form-input" @bind="fBancoId">
                            <option value="0">— Elegí un banco —</option>
                            @if (bancos is not null)
                            {
                                @foreach (var b in bancos.OrderBy(x => x.SortOrder).ThenBy(x => x.Display))
                                {
                                    <option value="@b.Id">@b.Display</option>
                                }
                            }
                        </select>
                        <p style="font-size:0.7rem; color:#6b7280; margin:0.2rem 0 0;">
                            ¿Falta el banco?
                            <a href="/cafe/configuracion/bancos" target="_blank" style="color:#2563eb;">Agregalo al catálogo</a>
                            y volvé.
                        </p>
                    </div>
                    <div class="form-group" style="flex:1.2;">
                        <label class="form-label">Número *</label>
                        <input class="form-input" @bind="fNumero" placeholder="Ej: 12345678" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Emisor (libra el cheque) — opcional</label>
                    <input class="form-input" @bind="fEmisor" placeholder="Razón social o nombre del firmante" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Importe *</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="fImporte" />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Fecha cobro / vencimiento</label>
                        <input class="form-input" type="date"
                               value="@(fVenc?.ToString("yyyy-MM-dd"))"
                               @onchange="@(e => fVenc = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Observaciones — opcional</label>
                    <textarea class="form-input" rows="2" @bind="fObs"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div style="background:#fee2e2; color:#991b1b; padding:0.5rem 0.7rem; border-radius:4px; font-size:0.82rem; margin-top:0.5rem;">@formError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarNuevo" disabled="@savingNuevo">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarNuevo" disabled="@savingNuevo">@(savingNuevo ? "Guardando..." : "Guardar cheque")</button>
            </div>
        </div>
    </div>
}

@* ════════════ Modal Aplicar cheque a cobranza ════════════ *@
@if (aplicarOpen && aplicarCheque is not null)
{
    <div class="modal-overlay">
        <div class="modal-card" style="max-width: 760px;">
            <div class="modal-header">
                <h3 style="margin:0;">🔗 Aplicar cheque a cobranza</h3>
                <button class="btn-close" @onclick="CerrarAplicar">✕</button>
            </div>
            <div class="modal-body">
                @{ var ch = aplicarCheque; }
                <div style="background:#f3f4f6; padding:0.6rem 0.8rem; border-radius:6px; margin-bottom:0.7rem; font-size:0.85rem;">
                    <div><strong>Cheque:</strong> @ch.Banco — N° @ch.Numero — <strong>$@ch.Importe.ToString("N2")</strong></div>
                    <div style="font-size:0.78rem; color:#6b7280;">Vence: @(ch.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "—") @(string.IsNullOrEmpty(ch.Emisor) ? "" : $" · Emisor: {ch.Emisor}")</div>
                </div>

                @* Cliente *@
                <div class="form-group">
                    <label class="form-label">Cliente que pagó *</label>
                    @if (clienteAplicar is not null)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center; background:#ecfdf5; border:1px solid #059669; padding:0.5rem 0.7rem; border-radius:6px;">
                            <div>
                                <strong>@(clienteAplicar.CodigoInterno?.ToString() ?? "—") · @clienteAplicar.Nombre</strong>
                                @if (!string.IsNullOrEmpty(clienteAplicar.Cuit))
                                {
                                    <span style="font-size:0.75rem; color:#065f46;"> · CUIT @clienteAplicar.Cuit</span>
                                }
                            </div>
                            <button class="btn-icon" @onclick="QuitarClienteAplicar" title="Cambiar cliente">✕</button>
                        </div>
                    }
                    else
                    {
                        <input class="form-input" @bind="clienteSearchAplicar" @bind:event="oninput" placeholder="Buscar por nombre, código o CUIT..." />
                        @if (!string.IsNullOrWhiteSpace(clienteSearchAplicar) && clientesAplicar is not null)
                        {
                            var matches = clientesAplicar.Where(cc => cc.IsActive &&
                                (cc.Nombre.MatchesSearch(clienteSearchAplicar) ||
                                 (cc.RazonSocial ?? "").MatchesSearch(clienteSearchAplicar) ||
                                 (cc.Cuit ?? "").Contains(clienteSearchAplicar, StringComparison.OrdinalIgnoreCase) ||
                                 (cc.CodigoInterno?.ToString() ?? "").Contains(clienteSearchAplicar)))
                                .Take(10).ToList();
                            <div style="max-height:200px; overflow-y:auto; border:1px solid #e5e7eb; border-radius:4px; margin-top:0.3rem;">
                                @foreach (var cc in matches)
                                {
                                    <div style="padding:0.4rem 0.6rem; cursor:pointer; border-bottom:1px solid #f3f4f6;" @onclick="() => ElegirClienteAplicar(new SugerenciaClienteEcheqDto { Id = cc.Id, Nombre = cc.Nombre, Cuit = cc.Cuit, CodigoInterno = cc.CodigoInterno, RazonSocial = cc.RazonSocial })">
                                        <strong>@(cc.CodigoInterno?.ToString() ?? "—") · @cc.Nombre</strong>
                                        @if (!string.IsNullOrEmpty(cc.Cuit)) { <span style="font-size:0.75rem; color:#6b7280;"> · CUIT @cc.Cuit</span> }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                @* Comprobantes pendientes *@
                @if (clienteAplicar is not null)
                {
                    @if (loadingCompAplicar)
                    {
                        <p class="text-muted">Cargando comprobantes pendientes...</p>
                    }
                    else if (compAplicar is { Count: > 0 })
                    {
                        <div class="form-group">
                            <label class="form-label">Imputar a comprobantes pendientes</label>
                            <p style="font-size:0.72rem; color:#6b7280; margin:0 0 0.4rem;">
                                Tildá los que cubrís con este cheque. Total a imputar: <strong>$@TotalImputarAplicar.ToString("N2")</strong> de <strong>$@ch.Importe.ToString("N2")</strong> @(retencionesAplicar > 0 ? $"(+ ${retencionesAplicar:N2} retenciones)" : "")
                            </p>
                            <table style="width:100%; font-size:0.85rem;">
                                <thead>
                                    <tr style="border-bottom:1px solid #e5e7eb;">
                                        <th style="width:30px;"></th>
                                        <th style="text-align:left;">Comprobante</th>
                                        <th style="text-align:right;">Saldo</th>
                                        <th style="width:130px; text-align:right;">A imputar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < compAplicar.Count; i++)
                                    {
                                        var idx = i;
                                        var comp = compAplicar[idx];
                                        var sel = compSelAplicar[idx];
                                        <tr>
                                            <td><input type="checkbox" checked="@sel.Tildado"
                                                       @onchange="@(e => OnTildarCompAplicar(idx, (bool)e.Value!))" /></td>
                                            <td><strong>@comp.Numero</strong> <span style="color:#6b7280; font-size:0.78rem;">@comp.Fecha.ToString("dd/MM/yyyy")</span></td>
                                            <td style="text-align:right;">$@comp.Saldo.ToString("N2")</td>
                                            <td style="text-align:right;">
                                                <input class="form-input" type="number" step="0.01" min="0" style="text-align:right; padding:0.2rem 0.4rem; font-size:0.85rem;"
                                                       value="@sel.Importe.ToString(System.Globalization.CultureInfo.InvariantCulture)" disabled="@(!sel.Tildado)"
                                                       @onchange="@(e => OnImporteCompAplicar(idx, e.Value?.ToString()))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p style="font-size:0.82rem; color:#6b7280;">Este cliente no tiene comprobantes con saldo. Se va a registrar como "a cuenta".</p>
                    }
                    <div class="form-row">
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Retenciones</label>
                            <input class="form-input" type="number" step="0.01" min="0" @bind="retencionesAplicar" />
                        </div>
                        <div class="form-group" style="flex:2;">
                            <label class="form-label">Observaciones (opcional)</label>
                            <input class="form-input" @bind="observacionesAplicar" placeholder="Notas internas" />
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(aplicarError))
                {
                    <div style="background:#fee2e2; color:#991b1b; padding:0.5rem 0.7rem; border-radius:4px; font-size:0.82rem; margin-top:0.5rem;">@aplicarError</div>
                }
                <div style="background:#dbeafe; color:#1e40af; padding:0.4rem 0.6rem; border-radius:4px; font-size:0.78rem; margin-top:0.5rem;">
                    💡 Al confirmar: se crea una cobranza nueva por <strong>$@ch.Importe.ToString("N2")</strong> y este cheque queda vinculado a ella. El cheque sigue EN_CARTERA — después podés depositarlo, cobrarlo o rechazarlo igual que siempre.
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarAplicar" disabled="@aplicando">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmarAplicar" disabled="@(aplicando || clienteAplicar is null)">@(aplicando ? "Guardando..." : "Confirmar cobranza")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeChequeDto>? cheques;
    private bool loading = true;
    private string estadoFiltro = "EN_CARTERA";

    // ===== Modal Nuevo cheque =====
    private bool showNuevo;
    private bool savingNuevo;
    private string? formError;
    private int fBancoId;
    private string fNumero = "";
    private string fEmisor = "";
    private decimal fImporte;
    private DateTime? fVenc;
    private string fObs = "";
    private List<CafeBancoDto>? bancos;

    private async Task AbrirNuevo()
    {
        fBancoId = 0; fNumero = ""; fEmisor = ""; fImporte = 0; fVenc = null; fObs = "";
        formError = null;
        // Cargar catalogo de bancos en cada apertura (puede haber cambiado en otra pestaña)
        try { bancos = await Api.GetBancosAsync() ?? new(); }
        catch { bancos = new(); }
        showNuevo = true;
    }

    private void CerrarNuevo()
    {
        if (savingNuevo) return;
        showNuevo = false;
    }

    private async Task GuardarNuevo()
    {
        formError = null;
        if (fBancoId <= 0) { formError = "Elegí un banco del catálogo"; return; }
        if (string.IsNullOrWhiteSpace(fNumero)) { formError = "Número obligatorio"; return; }
        if (fImporte <= 0) { formError = "Importe debe ser mayor a 0"; return; }
        savingNuevo = true;
        try
        {
            var (cheque, err) = await Api.CrearChequeAsync(new CreateChequeRequest
            {
                BancoId = fBancoId,
                Numero = fNumero.Trim(),
                Emisor = string.IsNullOrWhiteSpace(fEmisor) ? null : fEmisor.Trim(),
                Importe = fImporte,
                FechaVencimiento = fVenc,
                FechaCobro = fVenc,
                Observaciones = string.IsNullOrWhiteSpace(fObs) ? null : fObs.Trim()
            });
            if (cheque is null) { formError = err ?? "No se pudo guardar"; return; }
            ToastService.Success($"Cheque {cheque.Banco} N° {cheque.Numero} agregado a cartera");
            showNuevo = false;
            await Load();
        }
        finally { savingNuevo = false; }
    }

    private readonly (string key, string label)[] estados = new[]
    {
        ("EN_CARTERA", "En cartera"),
        ("ACREDITADO", "Acreditados"),
        ("COBRADO_VENTANILLA", "Cobrados ventanilla"),
        ("ENDOSADO", "Endosados"),
        ("RECHAZADO", "Rechazados"),
        ("", "Todos")
    };

    private IEnumerable<CafeChequeDto> ChequesFiltrados =>
        cheques?.Where(c => string.IsNullOrEmpty(estadoFiltro) || c.Estado == estadoFiltro) ?? Enumerable.Empty<CafeChequeDto>();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        try { cheques = await Api.GetCafeChequesAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar"); cheques = new(); }
        loading = false;
    }

    private async Task SetFiltro(string k) { estadoFiltro = k; await Task.CompletedTask; }

    private async Task Depositar(CafeChequeDto c)
    {
        try { await Api.DepositarChequeAsync(c.Id); ToastService.Success("Depositado / Acreditado"); await Load(); }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }
    private async Task CobrarVent(CafeChequeDto c)
    {
        try { await Api.CobrarChequeVentanillaAsync(c.Id); ToastService.Success("Cobrado por ventanilla"); await Load(); }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }
    private async Task Rechazar(CafeChequeDto c)
    {
        try { await Api.RechazarChequeAsync(c.Id); ToastService.Success("Rechazado (rebotó)"); await Load(); }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private static string EstadoLabel(string e) => e switch
    {
        "EN_CARTERA" => "📥 En cartera",
        "DEPOSITADO" => "🏦 Depositado",
        "ACREDITADO" => "✅ Acreditado",
        "COBRADO_VENTANILLA" => "💵 Cobrado ventanilla",
        "ENDOSADO" => "➡ Endosado",
        "RECHAZADO" => "❌ Rechazado",
        _ => e
    };
    private static string EstadoClass(string e) => e switch
    {
        "EN_CARTERA" => "badge-warning",
        "ACREDITADO" or "COBRADO_VENTANILLA" => "badge-success",
        "ENDOSADO" => "badge-secondary",
        "RECHAZADO" => "badge-danger",
        _ => "badge-secondary"
    };

    // ═══════════ Aplicar cheque a cobranza ═══════════
    private bool aplicarOpen;
    private bool aplicando;
    private string? aplicarError;
    private CafeChequeDto? aplicarCheque;
    private SugerenciaClienteEcheqDto? clienteAplicar;
    private List<CafeClienteDto>? clientesAplicar;
    private string clienteSearchAplicar = "";
    private List<ComprobantePendienteDto>? compAplicar;
    private bool loadingCompAplicar;
    private decimal retencionesAplicar;
    private string observacionesAplicar = "";

    private class CompSelAplicarState { public bool Tildado; public decimal Importe; }
    private List<CompSelAplicarState> compSelAplicar = new();

    private decimal TotalImputarAplicar => compSelAplicar.Where(s => s.Tildado).Sum(s => s.Importe);

    private async Task AbrirAplicar(CafeChequeDto c)
    {
        aplicarOpen = true;
        aplicarCheque = c;
        clienteAplicar = null;
        clienteSearchAplicar = "";
        compAplicar = null;
        compSelAplicar = new();
        retencionesAplicar = 0m;
        observacionesAplicar = "";
        aplicarError = null;

        try
        {
            if (clientesAplicar is null)
                clientesAplicar = await Api.GetCafeClientesAsync() ?? new();
            // Si el cheque ya tenia un cliente origen (poco comun en imports Excel), preseleccionarlo
            if (c.ClienteOrigenId.HasValue)
            {
                var origen = clientesAplicar.FirstOrDefault(x => x.Id == c.ClienteOrigenId.Value);
                if (origen is not null)
                {
                    await ElegirClienteAplicar(new SugerenciaClienteEcheqDto
                    {
                        Id = origen.Id,
                        Nombre = origen.Nombre,
                        Cuit = origen.Cuit,
                        CodigoInterno = origen.CodigoInterno,
                        RazonSocial = origen.RazonSocial
                    });
                }
            }
        }
        catch (Exception ex) { aplicarError = "Error cargando: " + ex.Message; }
    }

    private void CerrarAplicar()
    {
        if (aplicando) return;
        aplicarOpen = false;
        aplicarCheque = null;
    }

    private async Task ElegirClienteAplicar(SugerenciaClienteEcheqDto c)
    {
        clienteAplicar = c;
        clienteSearchAplicar = "";
        loadingCompAplicar = true;
        try
        {
            compAplicar = await Api.GetComprobantesPendientesAsync(c.Id, true) ?? new();
            compSelAplicar = compAplicar.Select(_ => new CompSelAplicarState()).ToList();
            decimal restante = aplicarCheque!.Importe;
            for (int i = 0; i < compAplicar.Count && restante > 0.01m; i++)
            {
                var aImputar = Math.Min(compAplicar[i].Saldo, restante);
                compSelAplicar[i].Tildado = true;
                compSelAplicar[i].Importe = Math.Round(aImputar, 2);
                restante -= aImputar;
            }
        }
        finally { loadingCompAplicar = false; }
    }

    private void QuitarClienteAplicar()
    {
        clienteAplicar = null;
        compAplicar = null;
        compSelAplicar = new();
    }

    private void OnTildarCompAplicar(int idx, bool tildado)
    {
        compSelAplicar[idx].Tildado = tildado;
        if (tildado && compSelAplicar[idx].Importe <= 0m)
            compSelAplicar[idx].Importe = compAplicar![idx].Saldo;
    }

    private void OnImporteCompAplicar(int idx, string? raw)
    {
        if (decimal.TryParse(raw, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v) && v >= 0)
            compSelAplicar[idx].Importe = Math.Round(v, 2);
    }

    private async Task ConfirmarAplicar()
    {
        aplicarError = null;
        if (aplicarCheque is null || clienteAplicar is null) { aplicarError = "Falta cliente"; return; }
        var sumImputado = TotalImputarAplicar;
        var diferencia = aplicarCheque.Importe + retencionesAplicar - sumImputado;
        var items = compSelAplicar
            .Select((s, i) => new { s, comp = compAplicar![i] })
            .Where(x => x.s.Tildado && x.s.Importe > 0m)
            .Select(x => new ImputarComprobanteItem { VentaId = x.comp.VentaId, Importe = x.s.Importe })
            .ToList();
        if (diferencia > 0.01m)
        {
            items.Add(new ImputarComprobanteItem { VentaId = null, Importe = Math.Round(diferencia, 2) });
        }
        else if (diferencia < -0.01m)
        {
            aplicarError = $"Imputaste ${sumImputado:N2} pero el cheque + retenciones suman ${(aplicarCheque.Importe + retencionesAplicar):N2}. Reducí algún importe.";
            return;
        }
        if (items.Count == 0)
        {
            items.Add(new ImputarComprobanteItem { VentaId = null, Importe = aplicarCheque.Importe + retencionesAplicar });
        }

        aplicando = true;
        try
        {
            var (cobId, numero, err) = await Api.AplicarChequeACobranzaAsync(aplicarCheque.Id, new AsociarECheqRequest
            {
                ClienteId = clienteAplicar.Id,
                Retenciones = retencionesAplicar,
                Observaciones = string.IsNullOrWhiteSpace(observacionesAplicar) ? null : observacionesAplicar.Trim(),
                Comprobantes = items
            });
            if (err is not null) { aplicarError = err; return; }
            ToastService.Success($"✓ Cobranza {numero} creada y cheque aplicado");
            aplicarOpen = false;
            await Load();
        }
        finally { aplicando = false; }
    }
}
