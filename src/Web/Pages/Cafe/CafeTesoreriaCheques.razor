@page "/cafe/tesoreria/cheques"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3 style="margin:0;">📄 Cheques en cartera (@(cheques?.Count(c => c.Estado == "EN_CARTERA") ?? 0))</h3>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
            <button class="btn btn-success" style="font-size:0.8rem;" @onclick="AbrirNuevo">➕ Nuevo cheque</button>
            <div style="width:1px; height:24px; background:#d1d5db; margin:0 0.25rem;"></div>
            @foreach (var e in estados)
            {
                <button class="btn @(estadoFiltro == e.key ? "btn-primary" : "btn-secondary")" style="font-size:0.8rem;" @onclick="() => SetFiltro(e.key)">@e.label</button>
            }
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        @if (loading)
        {
            <p class="text-muted" style="padding:1rem;">Cargando...</p>
        }
        else if (cheques is null || !ChequesFiltrados.Any())
        {
            <p class="text-muted" style="padding:1rem;">Sin cheques con este filtro.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="table table-compact">
                    <thead>
                        <tr>
                            <th>Banco</th>
                            <th>Número</th>
                            <th>Emisor</th>
                            <th>Cliente origen</th>
                            <th style="text-align:right;">Importe</th>
                            <th>Vence</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in ChequesFiltrados)
                        {
                            <tr>
                                <td>@c.Banco</td>
                                <td><b>@c.Numero</b></td>
                                <td>@(c.Emisor ?? "—")</td>
                                <td>@(c.ClienteOrigenNombre ?? "—")</td>
                                <td style="text-align:right; font-weight:600;">$@c.Importe.ToString("N2")</td>
                                <td>@(c.FechaVencimiento?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td><span class="badge @EstadoClass(c.Estado)">@EstadoLabel(c.Estado)</span></td>
                                <td>
                                    @if (c.Estado == "EN_CARTERA")
                                    {
                                        <button class="btn-icon" title="Depositar al banco" @onclick="() => Depositar(c)">🏦</button>
                                        <button class="btn-icon" title="Cobrar por ventanilla" @onclick="() => CobrarVent(c)">💵</button>
                                        <button class="btn-icon" title="Rechazar (rebotó)" @onclick="() => Rechazar(c)">❌</button>
                                    }
                                    else
                                    {
                                        <span style="color:#6b7280; font-size:0.78rem;">(sin acciones)</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* ════════════ Modal Nuevo cheque ════════════ *@
@if (showNuevo)
{
    <div class="modal-overlay">
        <div class="modal-card" style="max-width: 560px;">
            <div class="modal-header">
                <h3 style="margin:0;">➕ Nuevo cheque (alta manual)</h3>
                <button class="btn-close" @onclick="CerrarNuevo">✕</button>
            </div>
            <div class="modal-body">
                <p style="font-size:0.78rem; color:#6b7280; margin:0 0 0.7rem;">
                    Cargá un cheque físico (papel) que recibiste. Entra a cartera "sin asignar".
                    Cuando lo uses en una cobranza queda asociado al cliente que pagó.
                </p>
                <div class="form-row">
                    <div class="form-group" style="flex:2;">
                        <label class="form-label">Banco *</label>
                        <input class="form-input" @bind="fBanco" placeholder="Ej: Galicia, Macro, Santander" />
                    </div>
                    <div class="form-group" style="flex:1.2;">
                        <label class="form-label">Número *</label>
                        <input class="form-input" @bind="fNumero" placeholder="Ej: 12345678" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Emisor (libra el cheque) — opcional</label>
                    <input class="form-input" @bind="fEmisor" placeholder="Razón social o nombre del firmante" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Importe *</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="fImporte" />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Fecha cobro / vencimiento</label>
                        <input class="form-input" type="date"
                               value="@(fVenc?.ToString("yyyy-MM-dd"))"
                               @onchange="@(e => fVenc = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Observaciones — opcional</label>
                    <textarea class="form-input" rows="2" @bind="fObs"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div style="background:#fee2e2; color:#991b1b; padding:0.5rem 0.7rem; border-radius:4px; font-size:0.82rem; margin-top:0.5rem;">@formError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarNuevo" disabled="@savingNuevo">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarNuevo" disabled="@savingNuevo">@(savingNuevo ? "Guardando..." : "Guardar cheque")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeChequeDto>? cheques;
    private bool loading = true;
    private string estadoFiltro = "EN_CARTERA";

    // ===== Modal Nuevo cheque =====
    private bool showNuevo;
    private bool savingNuevo;
    private string? formError;
    private string fBanco = "";
    private string fNumero = "";
    private string fEmisor = "";
    private decimal fImporte;
    private DateTime? fVenc;
    private string fObs = "";

    private void AbrirNuevo()
    {
        fBanco = ""; fNumero = ""; fEmisor = ""; fImporte = 0; fVenc = null; fObs = "";
        formError = null;
        showNuevo = true;
    }

    private void CerrarNuevo()
    {
        if (savingNuevo) return;
        showNuevo = false;
    }

    private async Task GuardarNuevo()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(fBanco)) { formError = "Banco obligatorio"; return; }
        if (string.IsNullOrWhiteSpace(fNumero)) { formError = "Número obligatorio"; return; }
        if (fImporte <= 0) { formError = "Importe debe ser mayor a 0"; return; }
        savingNuevo = true;
        try
        {
            var (cheque, err) = await Api.CrearChequeAsync(new CreateChequeRequest
            {
                Banco = fBanco.Trim(),
                Numero = fNumero.Trim(),
                Emisor = string.IsNullOrWhiteSpace(fEmisor) ? null : fEmisor.Trim(),
                Importe = fImporte,
                FechaVencimiento = fVenc,
                FechaCobro = fVenc, // mismo valor por simplicidad — UI no diferencia
                Observaciones = string.IsNullOrWhiteSpace(fObs) ? null : fObs.Trim()
            });
            if (cheque is null) { formError = err ?? "No se pudo guardar"; return; }
            ToastService.Success($"Cheque {cheque.Banco} N° {cheque.Numero} agregado a cartera");
            showNuevo = false;
            await Load();
        }
        finally { savingNuevo = false; }
    }

    private readonly (string key, string label)[] estados = new[]
    {
        ("EN_CARTERA", "En cartera"),
        ("ACREDITADO", "Acreditados"),
        ("COBRADO_VENTANILLA", "Cobrados ventanilla"),
        ("ENDOSADO", "Endosados"),
        ("RECHAZADO", "Rechazados"),
        ("", "Todos")
    };

    private IEnumerable<CafeChequeDto> ChequesFiltrados =>
        cheques?.Where(c => string.IsNullOrEmpty(estadoFiltro) || c.Estado == estadoFiltro) ?? Enumerable.Empty<CafeChequeDto>();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        try { cheques = await Api.GetCafeChequesAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar"); cheques = new(); }
        loading = false;
    }

    private async Task SetFiltro(string k) { estadoFiltro = k; await Task.CompletedTask; }

    private async Task Depositar(CafeChequeDto c)
    {
        try { await Api.DepositarChequeAsync(c.Id); ToastService.Success("Depositado / Acreditado"); await Load(); }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }
    private async Task CobrarVent(CafeChequeDto c)
    {
        try { await Api.CobrarChequeVentanillaAsync(c.Id); ToastService.Success("Cobrado por ventanilla"); await Load(); }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }
    private async Task Rechazar(CafeChequeDto c)
    {
        try { await Api.RechazarChequeAsync(c.Id); ToastService.Success("Rechazado (rebotó)"); await Load(); }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private static string EstadoLabel(string e) => e switch
    {
        "EN_CARTERA" => "📥 En cartera",
        "DEPOSITADO" => "🏦 Depositado",
        "ACREDITADO" => "✅ Acreditado",
        "COBRADO_VENTANILLA" => "💵 Cobrado ventanilla",
        "ENDOSADO" => "➡ Endosado",
        "RECHAZADO" => "❌ Rechazado",
        _ => e
    };
    private static string EstadoClass(string e) => e switch
    {
        "EN_CARTERA" => "badge-warning",
        "ACREDITADO" or "COBRADO_VENTANILLA" => "badge-success",
        "ENDOSADO" => "badge-secondary",
        "RECHAZADO" => "badge-danger",
        _ => "badge-secondary"
    };
}
