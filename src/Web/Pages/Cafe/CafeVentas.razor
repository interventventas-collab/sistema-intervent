@code {
    private List<CafeVentaDto>? ventas;
    private Dictionary<int, decimal> saldosPorVenta = new();

    // Pin / nota tipo post-it
    private CafeVentaDto? pinningVenta;
    private string pinNotaInput = "";
    private bool savingPin;

    private void AbrirPin(CafeVentaDto v)
    {
        pinningVenta = v;
        pinNotaInput = v.PinNota ?? "";
    }

    private async Task GuardarPinAsync()
    {
        if (pinningVenta is null) return;
        savingPin = true;
        try
        {
            var ok = await Api.UpdateCafeVentaPinNotaAsync(pinningVenta.Id, pinNotaInput);
            if (ok)
            {
                pinningVenta.PinNota = string.IsNullOrWhiteSpace(pinNotaInput) ? null : pinNotaInput.Trim();
                ToastService.Success(string.IsNullOrWhiteSpace(pinNotaInput) ? "Nota borrada" : "Nota guardada");
                pinningVenta = null;
            }
            else { ToastService.Error("No se pudo guardar"); }
        }
        finally { savingPin = false; }
    }

    private async Task BorrarPinAsync()
    {
        pinNotaInput = "";
        await GuardarPinAsync();
    }

    // ===== Filtros del listado =====
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    private string rangoExportPreset = "";
    private bool exportando;

    /// <summary>Aplica un preset rápido de fechas al filtro Desde/Hasta cuando el usuario lo elige
    /// del dropdown junto al botón de exportar.</summary>
    private void AplicarPresetExport()
    {
        var hoy = DateTime.Today;
        switch (rangoExportPreset)
        {
            case "HOY":
                filtroFechaDesde = hoy; filtroFechaHasta = hoy; break;
            case "AYER":
                filtroFechaDesde = hoy.AddDays(-1); filtroFechaHasta = hoy.AddDays(-1); break;
            case "SEMANA":
                // Semana actual: lunes a domingo
                var diff = ((int)hoy.DayOfWeek + 6) % 7;
                filtroFechaDesde = hoy.AddDays(-diff);
                filtroFechaHasta = filtroFechaDesde.Value.AddDays(6);
                break;
            case "MES":
                filtroFechaDesde = new DateTime(hoy.Year, hoy.Month, 1);
                filtroFechaHasta = filtroFechaDesde.Value.AddMonths(1).AddDays(-1);
                break;
            case "MES_PASADO":
                var primDiaEsteMes = new DateTime(hoy.Year, hoy.Month, 1);
                filtroFechaHasta = primDiaEsteMes.AddDays(-1);
                filtroFechaDesde = new DateTime(filtroFechaHasta.Value.Year, filtroFechaHasta.Value.Month, 1);
                break;
        }
        rangoExportPreset = "";  // reset el dropdown
    }

    /// <summary>Descarga un Excel con los productos vendidos en el rango Desde/Hasta del filtro.
    /// Si los filtros están vacíos, exporta TODO el mes actual.</summary>
    private async Task ExportarProductosVendidos()
    {
        exportando = true;
        try
        {
            var hoy = DateTime.Today;
            var d = filtroFechaDesde ?? new DateTime(hoy.Year, hoy.Month, 1);
            var h = filtroFechaHasta ?? hoy;
            var bytes = await Api.ExportCafeProductosVendidosAsync(d, h);
            if (bytes is null || bytes.Length == 0)
            {
                ToastService.Error("No se pudo generar el Excel");
                return;
            }
            var filename = $"productos-vendidos_{d:yyyyMMdd}_{h:yyyyMMdd}.xlsx";
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadBytesAsFile", filename, b64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            ToastService.Success($"Excel descargado ({d:dd/MM} a {h:dd/MM})");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { exportando = false; }
    }
    private string filtroCliente = "";
    private string filtroTipo = "TODOS";       // TODOS | X | PRO | FA | FB | FC
    private string filtroEstado = "TODOS";     // TODOS | emitido | anulado
    private string filtroCae = "TODOS";        // TODOS | CON_CAE | SIN_CAE | PENDIENTE
    private string filtroSaldo = "TODOS";      // TODOS | CON_SALDO | SIN_SALDO

    /// <summary>Ventas pasadas por los filtros del listado. Si todos los filtros están vacíos/TODOS,
    /// devuelve la lista completa. Aplica AND entre filtros activos.</summary>
    private List<CafeVentaDto> VentasFiltradas
    {
        get
        {
            if (ventas is null) return new();
            IEnumerable<CafeVentaDto> q = ventas;
            if (filtroFechaDesde.HasValue) q = q.Where(v => v.Fecha.Date >= filtroFechaDesde.Value.Date);
            if (filtroFechaHasta.HasValue) q = q.Where(v => v.Fecha.Date <= filtroFechaHasta.Value.Date);
            if (!string.IsNullOrWhiteSpace(filtroCliente))
            {
                var t = filtroCliente.Trim();
                bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
                // Construyo un dict por ClienteId para enriquecer la busqueda con campos que NO
                // están en el snapshot de la venta (email, código, código interno).
                var clientesById = clientes?.ToDictionary(c => c.Id, c => c);
                q = q.Where(v =>
                {
                    // Match contra los campos snapshot de la venta (rápido, sin lookup)
                    if (h(v.Numero) || h(v.ClienteNombre) || h(v.ClienteRazonSocial)
                        || h(v.ClienteCuit) || h(v.ClienteDireccion) || h(v.ClienteLocalidad)
                        || h(v.ClienteTelefono) || h(v.ClienteCiudad) || h(v.ClienteCp)
                        || h(v.ClienteDomicilioEntrega)) return true;
                    // Match contra campos del cliente vivo que no están en el snapshot
                    if (v.ClienteId.HasValue && clientesById is not null
                        && clientesById.TryGetValue(v.ClienteId.Value, out var c))
                    {
                        if (h(c.Email) || h(c.Codigo)) return true;
                        if (c.CodigoInterno.HasValue && c.CodigoInterno.Value.ToString().Contains(t)) return true;
                    }
                    return false;
                });
            }
            if (filtroTipo != "TODOS") q = q.Where(v => v.TipoComprobante == filtroTipo);
            if (filtroEstado != "TODOS") q = q.Where(v => v.Estado == filtroEstado);
            if (filtroCae == "CON_CAE") q = q.Where(v => v.ArcaEstado == "autorizado");
            else if (filtroCae == "SIN_CAE") q = q.Where(v => v.ArcaEstado == "no_aplica");
            else if (filtroCae == "PENDIENTE") q = q.Where(v => v.ArcaEstado == "pendiente");
            if (filtroSaldo != "TODOS")
            {
                // Si no tenemos el saldo cargado para una venta, asumimos que NO está pagada
                // (saldo = Total). El usuario puede pisar manualmente con IsPaid pero ese caso
                // queda fuera del filtro por simplicidad — el filtro mira el saldo real.
                q = q.Where(v =>
                {
                    var s = saldosPorVenta.TryGetValue(v.Id, out var x) ? x : v.Total;
                    return filtroSaldo == "CON_SALDO" ? s > 0.01m : s <= 0.01m;
                });
            }
            return q.ToList();
        }
    }

    private bool HayFiltrosActivos =>
        filtroFechaDesde.HasValue || filtroFechaHasta.HasValue
        || !string.IsNullOrWhiteSpace(filtroCliente)
        || filtroTipo != "TODOS" || filtroEstado != "TODOS" || filtroCae != "TODOS"
        || filtroSaldo != "TODOS";

    private void LimpiarFiltros()
    {
        filtroFechaDesde = null; filtroFechaHasta = null;
        filtroCliente = ""; filtroTipo = "TODOS"; filtroEstado = "TODOS"; filtroCae = "TODOS";
        filtroSaldo = "TODOS";
    }
    private List<CafeClienteDto>? clientes;
    private List<CafeProductoDto>? productos;
    private CafeSettingDto? settings;
    private bool loading = true;

    // Form state
    private bool showForm, saving, previewLoading;
    private bool showConfirmEmision; // doble-check antes de emitir contra ARCA
    private string? formError;
    private int formClienteId;
    private string clienteSearch = "";
    private bool clienteSearchOpen;
    private string formClienteTipo = "OTRO";
    private DateTime formFecha = DateTime.Today;
    private decimal formDescuento;
    private string formObservaciones = "";
    private string formTipoComprobante = "X";
    private string formCondicionIva = "CF";
    private string formCondicionPago = "EFECTIVO";
    private List<CafeCotizarItemRequest> formItems = new();
    private CafeCotizadoDto? cotizacion;
    private HashSet<string> formWeekDays = new();
    private bool formIsPaid;

    // ── Panel "Enviar al cliente al emitir" ──
    // 3 canales de envio (paralelos, no mutuamente excluyentes). El operador tilda los
    // que quiera y al apretar "Emitir comprobante" se manda al cliente por esos canales.
    private bool envioEmail;
    private bool envioWhatsappWeb;
    private bool envioWhatsappInterno;
    // Destinatarios: se autocompletan desde el cliente si tiene email/telefono.
    // Si no tiene, el operador puede tipear el numero/mail a mano.
    private string envioEmailTo = "";
    private string envioWhatsappPhone = "";

    private static readonly string[] AllWeekDays = { "LUN", "MAR", "MIE", "JUE", "VIE", "SAB", "DOM" };

    // Add item state
    private int addProductoId;
    private string addFormato = "1KG";
    private int addCantidad = 1;
    private string productoSearch = "";
    private bool productoSearchOpen;

    // Combo picker
    private string addMode = "PRODUCTO";  // "PRODUCTO" | "COMBO" | "LIBRE"
    // Inputs del tab "Concepto libre"
    private string addLibreDescripcion = "";
    private decimal addLibrePrecio = 0m;
    private int addLibreCantidad = 1;

    /// <summary>Agrega un item "concepto libre" (sin producto del catálogo) a formItems
    /// con la descripción + precio + cantidad cargados a mano. No descuenta stock.</summary>
    private async Task AddItemLibre()
    {
        var desc = (addLibreDescripcion ?? "").Trim();
        if (string.IsNullOrWhiteSpace(desc)) { ToastService.Error("Cargá una descripción"); return; }
        if (addLibrePrecio <= 0m) { ToastService.Error("El precio debe ser mayor a 0"); return; }
        if (addLibreCantidad < 1) { ToastService.Error("La cantidad debe ser >= 1"); return; }

        formItems.Add(new CafeCotizarItemRequest
        {
            ProductoId = 0,
            EsConceptoLibre = true,
            DescripcionLibre = desc,
            Formato = "UNIT",
            Cantidad = addLibreCantidad,
            PrecioUnitarioOverride = addLibrePrecio,
            DescuentoPct = 0m,
            EsDoyPack = false,
            Molienda = null
        });
        // Reset inputs para el siguiente
        addLibreDescripcion = "";
        addLibrePrecio = 0m;
        addLibreCantidad = 1;
        await Cotizar();
    }
    private List<CafeComboDto>? combos;
    private int addComboId;
    private int addComboCantidad = 1;
    private string comboSearch = "";
    private bool comboSearchOpen;

    private string AddProductoCategoria => productos?.FirstOrDefault(x => x.Id == addProductoId)?.Categoria ?? "CAFE";

    /// <summary>True si el producto seleccionado es OTROS con UxB + algun PrecioBulto cargado.
    /// Habilita la opcion "Bulto" en el dropdown de formato.</summary>
    private bool AddProductoTieneBulto
    {
        get
        {
            var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
            if (p is null || p.Categoria != "OTROS") return false;
            if (!p.UxB.HasValue || p.UxB.Value <= 0) return false;
            return p.PrecioBulto.HasValue || p.PrecioBultoOtro.HasValue;
        }
    }

    /// <summary>Etiqueta para la opcion BULTO en el dropdown: "Bulto x 1000".</summary>
    private string AddProductoBultoLabel
    {
        get
        {
            var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
            var uxb = p?.UxB ?? 0;
            return $"Bulto x {uxb}";
        }
    }

    /// <summary>Aviso suave para el operador: si carga Suelto con cantidad >= UxB y el producto
    /// tiene precio de bulto, le sugiere cambiar a Bulto y le muestra cuánto le ahorraría al cliente.
    /// null = no mostrar aviso.</summary>
    private string? AvisoBultoConviene
    {
        get
        {
            if (!AddProductoTieneBulto) return null;
            if (addFormato != "UNIT") return null;
            var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
            if (p is null) return null;
            var uxb = p.UxB ?? 0;
            if (uxb <= 0 || addCantidad < uxb) return null;

            // Calculo precio suelto vs precio bulto segun tipo de cliente actual.
            var tipo = ClienteTipoActual();
            var precioUnit = tipo == "BAR"
                ? (p.PrecioBar ?? p.PrecioOtro ?? p.Pvp1 ?? 0m)
                : (p.PrecioOtro ?? p.PrecioBar ?? p.Pvp2 ?? 0m);
            var precioBulto = tipo == "BAR"
                ? (p.PrecioBulto ?? p.PrecioBultoOtro)
                : (p.PrecioBultoOtro ?? p.PrecioBulto);
            if (!precioBulto.HasValue || precioBulto.Value <= 0 || precioUnit <= 0) return null;

            var bultosCompletos = addCantidad / uxb;        // div entera
            var sueltas = addCantidad - (bultosCompletos * uxb);
            var costoComoSuelto = precioUnit * addCantidad;
            var costoComoBulto = (bultosCompletos * precioBulto.Value) + (sueltas * precioUnit);
            var ahorro = costoComoSuelto - costoComoBulto;
            if (ahorro <= 0) return null;

            return $"Conviene venderlo como Bulto: cobrás ${costoComoBulto:N0} en vez de ${costoComoSuelto:N0} (ahorra ${ahorro:N0} al cliente).";
        }
    }

    /// <summary>Determina el tipo de cliente actual de la venta en curso (BAR / OTRO).</summary>
    private string ClienteTipoActual()
    {
        if (!string.IsNullOrWhiteSpace(formClienteTipo))
            return formClienteTipo.ToUpperInvariant() == "BAR" ? "BAR" : "OTRO";
        return "OTRO";
    }

    /// <summary>Cambia el formato del item en carga a BULTO y ajusta la cantidad a "1 bulto"
    /// (cantidad ÷ UxB redondeado hacia abajo). Click handler del botón "Cambiar a Bulto".</summary>
    private void CambiarABulto()
    {
        var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
        var uxb = p?.UxB ?? 0;
        if (uxb <= 0) return;
        var nuevosBultos = addCantidad / uxb;       // div entera = bultos completos
        if (nuevosBultos < 1) return;
        addFormato = "BULTO";
        addCantidad = nuevosBultos;
    }

