    protected override async Task OnInitializedAsync()
    {
        await Operator.LoadAsync();
        Operator.OnChange += OnOperatorChange;
        Navigation.LocationChanged += OnLocationChanged;
        NuevaVentaSignal.OnRequest += OnNuevaVentaSignal;
        try { deleteSettings = await Api.GetCafeDeleteSettingsAsync(); }
        catch { deleteSettings = new DeleteCafeVentaSettingsDto(); }
        // Si la URL es /cafe/presupuestos, pre-filtrar por PRO
        if (ModoPresupuestos) { filtroTipo = "PRO"; }
        await LoadCatalogos();
        await Load();
        // Si veníamos del FAB con ?nueva=..., abrir el modal automáticamente
        TryHandleNuevaVentaShortcut();
        // Si veníamos de "Convertir preventa" con ?preventa=ID, cargar la preventa pre-poblada
        await TryHandleConvertirPreventaAsync();
        // Si veníamos de /cafe/pedidos-whatsapp con ?pedidoId=X, abrir el modal con sub-ventana
        await TryHandleConvertirPedidoWAAsync();
        // Cargar count de pedidos pendientes para mostrar en el botón
        await RefrescarPedidoWACount();
    }

    private void OnOperatorChange() => InvokeAsync(StateHasChanged);

    /// <summary>Cuando el FAB navega con un nuevo timestamp en ?nueva=...,
    /// estando ya en /cafe/ventas, Blazor NO re-ejecuta OnInitializedAsync.
    /// Por eso suscribimos LocationChanged para detectar el cambio y abrir el modal.</summary>
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(async () =>
        {
            // Si navegamos entre /cafe/ventas y /cafe/presupuestos, re-aplicar filtroTipo
            if (ModoPresupuestos && filtroTipo != "PRO") { filtroTipo = "PRO"; StateHasChanged(); }
            else if (!ModoPresupuestos && filtroTipo == "PRO" && e.Location.Contains("/cafe/ventas", StringComparison.OrdinalIgnoreCase))
            { filtroTipo = "TODOS"; StateHasChanged(); }
            TryHandleNuevaVentaShortcut();
            await TryHandleConvertirPreventaAsync();
            await TryHandleConvertirPedidoWAAsync();
        });
    }

