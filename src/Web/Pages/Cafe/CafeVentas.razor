                </button>
            </div>
        </div>
    </div>
}

@* (El modal de edición vive ahora dentro del modal Nueva Venta — mismo form, branchea por editingVentaId) *@

@code {
    private List<CafeVentaDto>? ventas;
    private List<CafeClienteDto>? clientes;
    private List<CafeProductoDto>? productos;
    private CafeSettingDto? settings;
    private bool loading = true;

    // Form state
    private bool showForm, saving;
    private string? formError;
    private int formClienteId;
    private string clienteSearch = "";
    private bool clienteSearchOpen;
    private string formClienteTipo = "OTRO";
    private DateTime formFecha = DateTime.Today;
    private decimal formDescuento;
    private string formObservaciones = "";
    private string formTipoComprobante = "X";
    private string formCondicionIva = "CF";
    private string formCondicionPago = "EFECTIVO";
    private List<CafeCotizarItemRequest> formItems = new();
    private CafeCotizadoDto? cotizacion;
    private HashSet<string> formWeekDays = new();
    private bool formIsPaid;

    private static readonly string[] AllWeekDays = { "LUN", "MAR", "MIE", "JUE", "VIE", "SAB", "DOM" };

    // Add item state
    private int addProductoId;
    private string addFormato = "1KG";
    private int addCantidad = 1;
    private string productoSearch = "";
    private bool productoSearchOpen;

    // Combo picker
    private string addMode = "PRODUCTO";  // "PRODUCTO" | "COMBO"
    private List<CafeComboDto>? combos;
    private int addComboId;
    private int addComboCantidad = 1;
    private string comboSearch = "";
    private bool comboSearchOpen;

    private string AddProductoCategoria => productos?.FirstOrDefault(x => x.Id == addProductoId)?.Categoria ?? "CAFE";

    // Print
    private CafeVentaDto? printVenta;

    private bool HasWhatsapp => !string.IsNullOrWhiteSpace(settings?.NegocioWhatsappNumero);

    /// <summary>Default si el usuario nunca configuró un template propio.</summary>
    private const string WaTemplateDefault = "Hola! Te escribo por el comprobante {numero} (total ${total}). Gracias!";

    /// <summary>Reemplaza placeholders de un template con los datos de la venta actual.</summary>
    private string ApplyWaTemplate(string template)
    {
        if (printVenta is null) return template;
        var totalStr = printVenta.Total.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
        return template
            .Replace("{numero}", printVenta.Numero ?? "")
            .Replace("{total}", totalStr)
            .Replace("{cliente}", printVenta.ClienteNombre ?? "")
            .Replace("{fecha}", printVenta.Fecha.ToString("dd/MM/yyyy"));
    }

    private string WhatsappLink
    {
        get
        {
            if (!HasWhatsapp || printVenta is null) return "#";
            var num = new string((settings!.NegocioWhatsappNumero ?? "").Where(char.IsDigit).ToArray());
            var template = string.IsNullOrWhiteSpace(settings.WhatsappMensajeTemplate)
                ? WaTemplateDefault
                : settings.WhatsappMensajeTemplate!;
            var msg = Uri.EscapeDataString(ApplyWaTemplate(template));
            return $"https://wa.me/{num}?text={msg}";
        }
    }

    /// <summary>Link wa.me del telefono del cliente. Usa el template "Negocio → Cliente" si está configurado.</summary>
    private string BuildClienteWhatsappLink(string? telefono)
    {
        if (string.IsNullOrWhiteSpace(telefono)) return "#";
        var num = new string(telefono.Where(char.IsDigit).ToArray());
        if (string.IsNullOrEmpty(num)) return "#";
        var template = settings?.WhatsappMensajeClienteTemplate;
        if (string.IsNullOrWhiteSpace(template))
            return $"https://wa.me/{num}";  // sin texto pre-cargado
        var msg = Uri.EscapeDataString(ApplyWaTemplate(template));
        return $"https://wa.me/{num}?text={msg}";
    }

    // Anular
    private bool showAnularConfirm;
    private CafeVentaDto? toAnular;

    // Multi-select
    private HashSet<int> selectedIds = new();
    private bool AllVisibleSelected =>
        ventas is not null && ventas.Count > 0 && ventas.All(v => selectedIds.Contains(v.Id));

    // Eliminar (con clave)
    private CafeVentaDto? toDelete;
    private string deletePassword = "";
    private string? deleteError;
    private bool isDeleting;
    private DeleteCafeVentaSettingsDto? deleteSettings;
    private bool CanDelete =>
        deleteSettings is not null &&
        !string.IsNullOrWhiteSpace(Operator.Current) &&
        string.Equals(Operator.Current, deleteSettings.AllowedOperator, StringComparison.OrdinalIgnoreCase);

    // Bulk delete
    private bool showBulkDeleteModal;
    private string bulkDeletePassword = "";
    private string? bulkDeleteError;
    private bool isBulkDeleting;

    // Edit (reusa el form de Nueva Venta — branchea por editingVentaId)
    private int? editingVentaId;
    private string editingVentaNumero = "";

    // Saldo anterior (comprobantes impagos del cliente actual del form)
    private List<CafeVentaDto> unpaidPrevSales = new();
    private decimal UnpaidPrevTotal => unpaidPrevSales.Sum(s => s.Total);
    private bool includePrevBalanceInNotes = true;

    // Top productos comprados por el cliente actual del form
    private List<CafeTopProductoClienteDto> topProductsForClient = new();

    protected override async Task OnInitializedAsync()
    {
        await Operator.LoadAsync();
        Operator.OnChange += OnOperatorChange;
        try { deleteSettings = await Api.GetCafeDeleteSettingsAsync(); }
        catch { deleteSettings = new DeleteCafeVentaSettingsDto(); }
        await LoadCatalogos();
        await Load();
    }

    private void OnOperatorChange() => InvokeAsync(StateHasChanged);

    public void Dispose() { Operator.OnChange -= OnOperatorChange; }

    private async Task LoadCatalogos()
    {
        try
        {
            clientes = (await Api.GetCafeClientesAsync())?.Where(c => c.IsActive).ToList() ?? new();
            productos = (await Api.GetCafeProductosAsync())?.Where(p => p.IsActive).ToList() ?? new();
            combos = (await Api.GetCafeCombosAsync(activos: true)) ?? new();
            settings = await Api.GetCafeSettingsAsync();
        }
        catch { }
    }

    private async Task Load()
    {
        loading = true;
        try { ventas = await Api.GetCafeVentasAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar ventas"); ventas = new(); }
        loading = false;
    }

    private void ShowCreate()
    {
        editingVentaId = null; editingVentaNumero = "";
        unpaidPrevSales = new(); topProductsForClient = new(); includePrevBalanceInNotes = true;
        formClienteId = 0; formClienteTipo = "OTRO";
        clienteSearch = ""; clienteSearchOpen = false;
        formFecha = DateTime.Today; formDescuento = 0; formObservaciones = "";
        formTipoComprobante = "X"; formCondicionIva = "CF"; formCondicionPago = "EFECTIVO";
        formItems = new(); cotizacion = null;
        addProductoId = 0; addFormato = "1KG"; addCantidad = 1;
        productoSearch = ""; productoSearchOpen = false;
        addMode = "PRODUCTO";
        addComboId = 0; addComboCantidad = 1;
        comboSearch = ""; comboSearchOpen = false;
        formWeekDays = new(); formIsPaid = false;
        formError = null; showForm = true;
    }

    private void ToggleFormDay(string d)
    {
        if (!formWeekDays.Add(d)) formWeekDays.Remove(d);
    }

    private void CloseForm() { showForm = false; formError = null; editingVentaId = null; editingVentaNumero = ""; }

    private async Task OnClienteChanged()
    {
        if (formClienteId > 0)
        {
            var c = clientes?.FirstOrDefault(x => x.Id == formClienteId);
            if (c is not null) formClienteTipo = c.Tipo;
        }
        RecomputeUnpaidPrevSales();
        await LoadTopProductsForClient();
        await Cotizar();
    }

    /// <summary>Recalcula los comprobantes impagos del cliente actual (excluye anulados, pagados,
    /// y la propia venta cuando se esta editando).</summary>
    private void RecomputeUnpaidPrevSales()
    {
        if (ventas is null || formClienteId <= 0)
        {
            unpaidPrevSales = new();
            return;
        }
        unpaidPrevSales = ventas
            .Where(v => v.ClienteId == formClienteId
                        && v.Estado == "emitido"
                        && !v.IsPaid
                        && (editingVentaId == null || v.Id != editingVentaId))
            .OrderBy(v => v.Fecha)
            .ThenBy(v => v.Id)
            .ToList();
    }

    private async Task LoadTopProductsForClient()
    {
        if (formClienteId <= 0) { topProductsForClient = new(); return; }
        try { topProductsForClient = await Api.GetCafeTopProductosByClienteAsync(formClienteId, 10) ?? new(); }
        catch { topProductsForClient = new(); }
    }

    /// <summary>Agrega un producto sugerido (top productos del cliente) al carrito con cantidad 1.
    /// Si ya existia ese (Producto, Formato, Molienda, DoyPack), suma 1 a la cantidad.</summary>
    private async Task AddTopProduct(int productoId, string formato)
    {
        var existing = formItems.FirstOrDefault(i => i.ProductoId == productoId
            && i.Formato == formato
            && string.IsNullOrEmpty(i.Molienda)
            && !i.EsDoyPack);
        if (existing is not null) existing.Cantidad += 1;
        else formItems.Add(new CafeCotizarItemRequest { ProductoId = productoId, Formato = formato, Cantidad = 1 });
        await Cotizar();
    }

    /// <summary>Selecciona un cliente del dropdown filtrable.</summary>
    private async Task SelectCliente(int id)
    {
        formClienteId = id;
        clienteSearch = "";
        clienteSearchOpen = false;
        await OnClienteChanged();
    }

    /// <summary>Vuelve a "consumidor final" (sin cliente).</summary>
    private async Task ClearCliente()
    {
        formClienteId = 0;
        clienteSearch = "";
        clienteSearchOpen = false;
        await OnClienteChanged();
    }

    /// <summary>Filtra clientes por código / nombre / cuit / telefono / email.</summary>
    private IEnumerable<CafeClienteDto> ClientesMatching(string q)
    {
        if (clientes is null) return Enumerable.Empty<CafeClienteDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return clientes;
        bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
        return clientes.Where(c => c.IsActive && (h(c.Codigo) || h(c.Nombre) || h(c.Cuit) || h(c.Telefono) || h(c.Email)));
    }

    private void OnAddProductoChanged()
    {
        if (addProductoId > 0)
        {
            var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
            if (p is not null) addFormato = p.Categoria == "CAFE" ? "1KG" : "UNIT";
        }
    }

    /// <summary>Selecciona un producto desde el dropdown filtrable.</summary>
    private void SelectProducto(int id)
    {
        addProductoId = id;
        productoSearch = "";
        productoSearchOpen = false;
        OnAddProductoChanged();
    }

    /// <summary>Vuelve a "sin producto seleccionado" para elegir otro.</summary>
    private void ClearProducto()
    {
        addProductoId = 0;
        productoSearch = "";
        productoSearchOpen = false;
    }

    /// <summary>Filtra productos activos por SKU / código de barras / nombre / marca.</summary>
    private IEnumerable<CafeProductoDto> ProductosMatching(string q)
    {
        if (productos is null) return Enumerable.Empty<CafeProductoDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return productos.Where(p => p.IsActive);
        bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
        return productos.Where(p => p.IsActive && (h(p.Sku) || h(p.Barcode) || h(p.Nombre) || h(p.Marca)));
    }

    private async Task AddItem()
    {
        if (addProductoId <= 0 || addCantidad <= 0) return;
        var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
        if (p is null) return;

        // Si ya existe el mismo prod+formato, sumamos cantidades.
        var existing = formItems.FirstOrDefault(i => i.ProductoId == addProductoId && i.Formato == addFormato);
        if (existing is not null) existing.Cantidad += addCantidad;
        else formItems.Add(new CafeCotizarItemRequest { ProductoId = addProductoId, Formato = addFormato, Cantidad = addCantidad });

        addProductoId = 0; addFormato = "1KG"; addCantidad = 1;
        productoSearch = ""; productoSearchOpen = false;
        await Cotizar();
    }

    // ── Combo: seleccionar y expandir ──
    private void SelectCombo(int id)
    {
        addComboId = id;
        comboSearch = "";
        comboSearchOpen = false;
    }

    private void ClearCombo()
    {
        addComboId = 0;
        addComboCantidad = 1;
    }

    /// <summary>Expande el combo en N items (uno por linea del combo, multiplicados por addComboCantidad).
    /// Si el mismo prod+formato+molienda ya existe, suma cantidades.</summary>
    private async Task AddCombo()
    {
        if (addComboId <= 0 || addComboCantidad <= 0) return;
        var combo = combos?.FirstOrDefault(c => c.Id == addComboId);
        if (combo is null || combo.Items.Count == 0) return;

        foreach (var ci in combo.Items)
        {
            var qty = ci.Cantidad * addComboCantidad;
            var existing = formItems.FirstOrDefault(i =>
                i.ProductoId == ci.ProductoId &&
                i.Formato == ci.Formato &&
                (i.Molienda ?? "") == (ci.Molienda ?? "") &&
                i.EsDoyPack == ci.EsDoyPack);
            if (existing is not null)
            {
                existing.Cantidad += qty;
            }
            else
            {
                formItems.Add(new CafeCotizarItemRequest
                {
                    ProductoId = ci.ProductoId,
                    Formato = ci.Formato,
                    Cantidad = qty,
                    Molienda = ci.Molienda,
                    EsDoyPack = ci.EsDoyPack
                });
            }
        }

        ToastService.Success($"Combo '{combo.Nombre}' agregado ({combo.Items.Count} producto{(combo.Items.Count == 1 ? "" : "s")})");
        addComboId = 0; addComboCantidad = 1;
        comboSearch = ""; comboSearchOpen = false;
        await Cotizar();
    }

    private async Task RemoveItem(int idx)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        formItems.RemoveAt(idx);
        await Cotizar();
    }

    private async Task OnItemMoliendaChanged(int idx, string? molienda)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        formItems[idx].Molienda = string.IsNullOrEmpty(molienda) ? null : molienda;
        await Cotizar();
    }

    private async Task OnItemDescuentoChanged(int idx, string? value)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        decimal d = 0m;
        if (!string.IsNullOrWhiteSpace(value))
        {
            decimal.TryParse(value.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out d);
        }
        formItems[idx].DescuentoPct = Math.Clamp(d, 0m, 100m);
        await Cotizar();
    }

    private async Task ToggleItemDoyPack(int idx)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        formItems[idx].EsDoyPack = !formItems[idx].EsDoyPack;
        await Cotizar();
    }

    private async Task Cotizar()
    {
        if (formItems.Count == 0) { cotizacion = null; return; }
        try
        {
            cotizacion = await Api.CotizarCafeAsync(new CafeCotizarRequest
            {
                ClienteId = formClienteId > 0 ? formClienteId : null,
                ClienteTipo = formClienteTipo,
                Items = formItems,
                Descuento = formDescuento
            });
        }
        catch (Exception ex) { ToastService.Error("Error al cotizar: " + ex.Message); }
    }

    private async Task Save()
    {
        formError = null;
        if (formItems.Count == 0) { formError = "Agregá al menos un producto"; return; }
        if (cotizacion?.TodoOk != true) { formError = "Hay items con stock insuficiente o inválidos"; return; }
        saving = true;
        try
        {
            var weekCsv = formWeekDays.Count > 0
                ? string.Join(",", AllWeekDays.Where(d => formWeekDays.Contains(d)))
                : null;

            // Inyectar saldo anterior en las observaciones si esta tildado y el cliente tiene impagos.
            var notesToSave = formObservaciones ?? "";
            if (includePrevBalanceInNotes
                && unpaidPrevSales.Count > 0
                && !notesToSave.Contains("Saldo anterior", StringComparison.OrdinalIgnoreCase))
            {
                var nums = string.Join(", ", unpaidPrevSales.Select(s => s.Numero));
                var prevLine = $"Saldo anterior: ${FormatMoney(UnpaidPrevTotal)} (comprobantes: {nums})";
                notesToSave = string.IsNullOrWhiteSpace(notesToSave)
                    ? prevLine
                    : prevLine + "\n" + notesToSave;
            }

            CafeVentaDto? v;
            if (editingVentaId.HasValue)
            {
                v = await Api.UpdateCafeVentaAsync(editingVentaId.Value, new UpdateCafeVentaRequest
                {
                    Fecha = formFecha,
                    ClienteId = formClienteId > 0 ? formClienteId : 0,
                    ClienteTipoOverride = formClienteId > 0 ? null : formClienteTipo,
                    Items = formItems,
                    Descuento = formDescuento,
                    Observaciones = notesToSave,
                    WeekDays = weekCsv ?? "",
                    IsPaid = formIsPaid,
                    TipoComprobante = formTipoComprobante,
                    CondicionIva = formCondicionIva,
                    CondicionPago = formCondicionPago
                });
                if (v is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success($"Comprobante {v.Numero} actualizado");
            }
            else
            {
                v = await Api.CreateCafeVentaAsync(new CreateCafeVentaRequest
                {
                    Fecha = formFecha,
                    ClienteId = formClienteId > 0 ? formClienteId : null,
                    ClienteTipoOverride = formClienteTipo,
                    Items = formItems,
                    Descuento = formDescuento,
                    Observaciones = notesToSave,
                    WeekDays = weekCsv,
                    IsPaid = formIsPaid,
                    TipoComprobante = formTipoComprobante,
                    CondicionIva = formCondicionIva,
                    CondicionPago = formCondicionPago
                });
                if (v is null) { formError = "No se pudo crear"; return; }
                ToastService.Success($"Venta {v.Numero} emitida — Total ${v.Total:N2}");
            }

            var wasEditing = editingVentaId.HasValue;
            showForm = false;
            editingVentaId = null;
            editingVentaNumero = "";
            await LoadCatalogos();
            await Load();
            // Si se editó, no abrir el viewer automáticamente; si era nueva venta, sí.
            if (!wasEditing) printVenta = v;
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    private async Task ShowPrint(CafeVentaDto v)
    {
        // Refrescar settings por si cambiaron datos del negocio
        try { settings = await Api.GetCafeSettingsAsync(); } catch { }
        var fresh = await Api.GetCafeVentaAsync(v.Id);
        printVenta = fresh ?? v;
    }

    private void ClosePrint() => printVenta = null;

    private async Task TogglePaid(ChangeEventArgs e)
    {
        if (printVenta is null) return;
        var paid = e.Value is bool b ? b : false;
        try
        {
            var updated = await Api.UpdateCafeVentaFlagsAsync(printVenta.Id, new UpdateCafeVentaFlagsRequest { IsPaid = paid });
            if (updated is not null) printVenta = updated;
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task ToggleViewerDay(string d)
    {
        if (printVenta is null) return;
        var current = (printVenta.WeekDays ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim().ToUpperInvariant())
            .ToHashSet();
        if (!current.Add(d)) current.Remove(d);
        var csv = current.Count > 0 ? string.Join(",", AllWeekDays.Where(x => current.Contains(x))) : "";
        try
        {
            var updated = await Api.UpdateCafeVentaFlagsAsync(printVenta.Id, new UpdateCafeVentaFlagsRequest { WeekDays = csv });
            if (updated is not null) printVenta = updated;
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DoPrint()
    {
        try { await JS.InvokeVoidAsync("printElement", "cafe-print", $"Comprobante {printVenta?.Numero}"); }
        catch { ToastService.Error("No se pudo abrir la ventana de impresión"); }
    }

    private void ConfirmAnular(CafeVentaDto v) { toAnular = v; showAnularConfirm = true; }
    private async Task DoAnular()
    {
        if (toAnular is null) return;
        try
        {
            await Api.AnularCafeVentaAsync(toAnular.Id);
            ToastService.Success("Venta anulada — stock devuelto");
            await Load();
