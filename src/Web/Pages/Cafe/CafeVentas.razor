@code {
    // 2026-06-06: estado del modal de cobro ocasional (venta sin cliente del catálogo)
    private CafeVentaDto? cobroOcasionalVenta;
    private decimal cobroOcasionalSaldo;
    private decimal cobroOcasionalMonto;
    private int cobroOcasionalCajaId;
    private DateTime cobroOcasionalFecha = DateTime.Today;
    private string cobroOcasionalNota = "";
    private bool cobroOcasionalGuardando;
    private List<CafeCajaDto>? cobroOcasionalCajas;

    private async Task AbrirCobroOcasional(CafeVentaDto v, decimal saldo)
    {
        cobroOcasionalVenta = v;
        cobroOcasionalSaldo = saldo;
        cobroOcasionalMonto = saldo;
        cobroOcasionalCajaId = 0;
        cobroOcasionalFecha = DateTime.Today;
        cobroOcasionalNota = "";
        cobroOcasionalGuardando = false;
        if (cobroOcasionalCajas is null)
        {
            try { cobroOcasionalCajas = await Api.GetCafeCajasAsync() ?? new(); } catch { cobroOcasionalCajas = new(); }
        }
        // Preseleccionar Efectivo si existe
        var ef = cobroOcasionalCajas?.FirstOrDefault(c => c.IsActive && c.Tipo == "EFECTIVO");
        if (ef is not null) cobroOcasionalCajaId = ef.Id;
        StateHasChanged();
    }

    private void CerrarCobroOcasional()
    {
        cobroOcasionalVenta = null;
    }

    private async Task ConfirmarCobroOcasional()
    {
        if (cobroOcasionalVenta is null) return;
        if (cobroOcasionalMonto <= 0) { ToastService.Error("El monto debe ser mayor a 0"); return; }
        if (cobroOcasionalMonto > cobroOcasionalSaldo + 0.01m) { ToastService.Error($"El monto supera el saldo de la venta ($ {FormatMoney(cobroOcasionalSaldo)})"); return; }
        if (cobroOcasionalCajaId <= 0) { ToastService.Error("Elegí forma de cobro"); return; }

        cobroOcasionalGuardando = true;
        try
        {
            var comps = new List<ApiClient.CrearComprobanteItemRequest>
            {
                new ApiClient.CrearComprobanteItemRequest(cobroOcasionalVenta.Id, cobroOcasionalMonto)
            };
            var medios = new List<ApiClient.CrearMedioItemRequest>
            {
                new ApiClient.CrearMedioItemRequest(cobroOcasionalCajaId, cobroOcasionalMonto,
                    string.IsNullOrWhiteSpace(cobroOcasionalNota) ? null : cobroOcasionalNota, null)
            };
            // 2026-06-06: ClienteId null = cobranza de venta ocasional
            var r = await Api.CrearCafeCobranzaAsync(null, 0m, Operator.Current, cobroOcasionalNota, comps, medios);
            if (r is null) { ToastService.Error("Error al crear cobranza"); return; }
            ToastService.Success($"Cobranza {r.Numero} creada ✓");
            cobroOcasionalVenta = null;
            // Recargar lista para reflejar el cambio en saldos / chip
            await Load();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error: " + ex.Message);
        }
        finally
        {
            cobroOcasionalGuardando = false;
        }
    }

    // 2026-06-05: estado del modal de reasignar repartidor
    private bool mostrarReasignar;
    private bool guardandoReasignar;
    private CafeVentaDto? ventaReasignar;
    private int nuevoRepartidorId = 0;
    private List<RepartidorDto> repartidoresLista = new();

    private async Task AbrirReasignar(CafeVentaDto v)
    {
        ventaReasignar = v;
        nuevoRepartidorId = 0;
        if (repartidoresLista.Count == 0)
        {
            try { repartidoresLista = await Api.GetRepartidoresAsync() ?? new(); } catch { }
        }
        mostrarReasignar = true;
    }

    // 2026-06-05: desmarcar entrega (admin) — para pruebas o correcciones
    private async Task PedirDesmarcarEntrega(CafeVentaDto v)
    {
        var msg = $"¿Desmarcar la entrega de {v.Numero} ({v.EntregadoPorRepartidorNombre})?\n\nLa venta vuelve a estado 'pendiente de armar' y se borra el registro de entrega.";
        if (!await JS.InvokeAsync<bool>("confirm", msg)) return;
        try
        {
            var ok = await Api.DesmarcarEntregaAsync(v.Id);
            if (ok)
            {
                ToastService.Success("✓ Entrega desmarcada");
                await Load();
            }
            else { ToastService.Error("No se pudo desmarcar"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task ConfirmarReasignar()
    {
        if (ventaReasignar is null) return;
        guardandoReasignar = true;
        try
        {
            int? destinoId = nuevoRepartidorId > 0 ? nuevoRepartidorId : (int?)null;
            var ok = await Api.ReasignarEscaneoAsync(ventaReasignar.Id, destinoId);
            if (ok)
            {
                ToastService.Success(destinoId.HasValue ? "✓ Reasignado" : "✓ Desvinculado");
                mostrarReasignar = false;
                await Load();
            }
            else { ToastService.Error("No se pudo reasignar"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { guardandoReasignar = false; }
    }

    private List<CafeVentaDto>? ventas;
    private Dictionary<int, decimal> saldosPorVenta = new();

    // Pin / nota tipo post-it
    private CafeVentaDto? pinningVenta;
    private string pinNotaInput = "";
    private bool savingPin;

    private void AbrirPin(CafeVentaDto v)
    {
        pinningVenta = v;
        pinNotaInput = v.PinNota ?? "";
    }

    private async Task GuardarPinAsync()
    {
        if (pinningVenta is null) return;
        savingPin = true;
        try
        {
            var ok = await Api.UpdateCafeVentaPinNotaAsync(pinningVenta.Id, pinNotaInput);
            if (ok)
            {
                pinningVenta.PinNota = string.IsNullOrWhiteSpace(pinNotaInput) ? null : pinNotaInput.Trim();
                ToastService.Success(string.IsNullOrWhiteSpace(pinNotaInput) ? "Nota borrada" : "Nota guardada");
                pinningVenta = null;
            }
            else { ToastService.Error("No se pudo guardar"); }
        }
        finally { savingPin = false; }
    }

    private async Task BorrarPinAsync()
    {
        pinNotaInput = "";
        await GuardarPinAsync();
    }

    // ===== Filtros del listado =====
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    private string rangoExportPreset = "";
    private bool exportando;

    /// <summary>Aplica un preset rápido de fechas al filtro Desde/Hasta cuando el usuario lo elige
    /// del dropdown junto al botón de exportar.</summary>
    private void AplicarPresetExport()
    {
        var hoy = DateTime.Today;
        switch (rangoExportPreset)
        {
            case "HOY":
                filtroFechaDesde = hoy; filtroFechaHasta = hoy; break;
            case "AYER":
                filtroFechaDesde = hoy.AddDays(-1); filtroFechaHasta = hoy.AddDays(-1); break;
            case "SEMANA":
                // Semana actual: lunes a domingo
                var diff = ((int)hoy.DayOfWeek + 6) % 7;
                filtroFechaDesde = hoy.AddDays(-diff);
                filtroFechaHasta = filtroFechaDesde.Value.AddDays(6);
                break;
            case "MES":
                filtroFechaDesde = new DateTime(hoy.Year, hoy.Month, 1);
                filtroFechaHasta = filtroFechaDesde.Value.AddMonths(1).AddDays(-1);
                break;
            case "MES_PASADO":
                var primDiaEsteMes = new DateTime(hoy.Year, hoy.Month, 1);
                filtroFechaHasta = primDiaEsteMes.AddDays(-1);
                filtroFechaDesde = new DateTime(filtroFechaHasta.Value.Year, filtroFechaHasta.Value.Month, 1);
                break;
        }
        rangoExportPreset = "";  // reset el dropdown
    }

    /// <summary>Descarga un Excel con los productos vendidos en el rango Desde/Hasta del filtro.
    /// Si los filtros están vacíos, exporta TODO el mes actual.</summary>
    private async Task ExportarProductosVendidos()
    {
        exportando = true;
        try
        {
            var hoy = DateTime.Today;
            var d = filtroFechaDesde ?? new DateTime(hoy.Year, hoy.Month, 1);
            var h = filtroFechaHasta ?? hoy;
            var bytes = await Api.ExportCafeProductosVendidosAsync(d, h);
            if (bytes is null || bytes.Length == 0)
            {
                ToastService.Error("No se pudo generar el Excel");
                return;
            }
            var filename = $"productos-vendidos_{d:yyyyMMdd}_{h:yyyyMMdd}.xlsx";
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadBytesAsFile", filename, b64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            ToastService.Success($"Excel descargado ({d:dd/MM} a {h:dd/MM})");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { exportando = false; }
    }
