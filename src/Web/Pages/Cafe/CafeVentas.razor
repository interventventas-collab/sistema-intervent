    /// <summary>Si la URL trae ?pedidoId=X, abre el modal de Nueva Venta y muestra el pedido en la sub-ventana flotante.</summary>
    private async Task TryHandleConvertirPedidoWAAsync()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var idStr = query["pedidoId"];
        if (string.IsNullOrEmpty(idStr)) return;
        if (!int.TryParse(idStr, out var pedidoId)) return;
        if (lastPedidoWAQuery == pedidoId) return;
        lastPedidoWAQuery = pedidoId;

        // Traer el pedido específico (lo busco en la lista de disponibles)
        var lista = await Api.ListarPedidosDisponiblesParaVentaAsync();
        var pedido = lista?.FirstOrDefault(p => p.Id == pedidoId);
        if (pedido is null) { ToastService.Warning("Ese pedido ya no está disponible (¿se cargó o se descartó?)"); return; }

        // Abrir el modal de Nueva Venta si no está abierto
        if (!showForm) ShowCreate();

        // Mostrar la sub-ventana flotante
        pedidoWASeleccionado = pedido;
        convirtiendoPedidoWAId = pedido.Id;
        subventanaWAMin = false;
        StateHasChanged();
    }

    /// <summary>Si la URL trae ?preventa=ID, abre el modal de Nueva Venta con los items pre-cargados
    /// desde la preventa (cliente, items del catálogo o concepto libre, notas).</summary>
    private int? convirtiendoPreventaId;
    private int? lastPreventaQuery;
    private async Task TryHandleConvertirPreventaAsync()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var preventaStr = query["preventa"];
        if (string.IsNullOrEmpty(preventaStr)) return;
        if (!int.TryParse(preventaStr, out var preventaId)) return;
        if (lastPreventaQuery == preventaId) return; // ya lo procesamos
        lastPreventaQuery = preventaId;
        if (showForm) return; // ya hay un modal abierto, no pisar

        // Traer detalle de la preventa
        var pv = await Api.GetCafePreventaDetalleAsync(preventaId);
        if (pv is null)
        {
            ToastService.Error("No se encontró la preventa");
            return;
        }

        // Abrir modal de Nueva Venta y resetear todo
        ShowCreate();
        convirtiendoPreventaId = preventaId;

        // Pre-cargar cliente del catálogo si lo había
        if (pv.ClienteId.HasValue) formClienteId = pv.ClienteId.Value;

        // Pre-cargar observaciones (incluir nombre del cliente libre si no era del catálogo + notas)
        var obsParts = new List<string>();
        if (!pv.ClienteId.HasValue && !string.IsNullOrWhiteSpace(pv.ClienteNombreLibre))
            obsParts.Add($"Cliente (preventa): {pv.ClienteNombreLibre}");
        if (!string.IsNullOrWhiteSpace(pv.ClienteTelefono))
            obsParts.Add($"Tel: {pv.ClienteTelefono}");
        if (!string.IsNullOrWhiteSpace(pv.Notas))
            obsParts.Add(pv.Notas);
        obsParts.Add($"(convertido desde preventa {pv.Numero})");
        formObservaciones = string.Join(" · ", obsParts);

        // Pre-cargar items
        foreach (var it in pv.Items)
        {
            if (it.ProductoId.HasValue && it.ProductoId.Value > 0)
            {
                // Item del catálogo — determinar formato según categoría
                var prod = productos?.FirstOrDefault(p => p.Id == it.ProductoId.Value);
                var formato = prod?.Categoria == "CAFE" ? "1KG" : "UNIT";
                formItems.Add(new CafeCotizarItemRequest
                {
                    ProductoId = it.ProductoId.Value,
                    Formato = formato,
                    Cantidad = (int)Math.Max(1, Math.Round(it.Cantidad)),
                    PrecioUnitarioOverride = it.PrecioSugerido,
                    DescuentoPct = 0m,
                    EsConceptoLibre = false
                });
            }
            else
            {
                // Texto libre — agregar como concepto libre con precio 0 para que Osmar lo edite
                formItems.Add(new CafeCotizarItemRequest
                {
                    ProductoId = 0,
                    EsConceptoLibre = true,
                    DescripcionLibre = it.DescripcionLibre ?? "(sin descripción)",
                    Formato = "UNIT",
                    Cantidad = (int)Math.Max(1, Math.Round(it.Cantidad)),
                    PrecioUnitarioOverride = it.PrecioSugerido ?? 0m,
                    DescuentoPct = 0m,
                    EsDoyPack = false,
                    EsEnvasePlateado = false
                });
            }
        }

        // Recalcular cotización ahora que tenemos items
        await Cotizar();
        ToastService.Success($"Preventa {pv.Numero} cargada. Ajustá precios y emití la venta.");
    }

    /// <summary>Si la URL actual tiene ?nueva=<algo>, abre el modal de Nueva Venta.
    /// Se usa para el FAB del MainLayout — un click en cualquier pantalla navega acá con
    /// el query y se dispara el modal sin pasos extra.</summary>
    private string? lastNuevaQuery;
    private void TryHandleNuevaVentaShortcut()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var nueva = query["nueva"];
        if (string.IsNullOrEmpty(nueva)) return;
        if (nueva == lastNuevaQuery) return; // ya lo procesamos
        lastNuevaQuery = nueva;
        // No abrir si ya hay un modal abierto (evitar pisar trabajo en curso)
        if (showForm) return;
        ShowCreate();
    }

