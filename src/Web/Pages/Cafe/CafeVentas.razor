    /// <summary>Si el formato es "PACK_N", devuelve N. Sino null.</summary>
    private static int? ParsePackUnidades(string? formato)
    {
        if (string.IsNullOrEmpty(formato) || !formato.StartsWith("PACK_")) return null;
        return int.TryParse(formato.AsSpan("PACK_".Length), out var n) && n > 0 ? n : (int?)null;
    }

    private static string FormatoLabel(string formato)
    {
        var packN = ParsePackUnidades(formato);
        if (packN.HasValue) return $"Pack x {packN.Value}";
        return formato switch
        {
            "1KG" => "1 kg",
            "MEDIO" => "1/2 kg",
            "CUARTO" => "1/4 kg",
            "UNIT" => "Unidad",
            "BULTO" => "Bulto",
            _ => formato
        };
    }

    /// <summary>Cantidad a mostrar en el ticket: si el item es BULTO o PACK_N, expande cantidad
    /// × unidades_reales para que el empleado de deposito vea el TOTAL de unidades a armar. Sino
    /// devuelve la cantidad tal cual. Pedido del usuario el 15/05/2026.</summary>
    private int CantidadParaMostrar(int productoId, string formato, int cantidad)
    {
        var packN = ParsePackUnidades(formato);
        if (packN.HasValue) return cantidad * packN.Value;
        if (formato != "BULTO") return cantidad;
        var uxb = productos?.FirstOrDefault(p => p.Id == productoId)?.UxB ?? 0;
        if (uxb <= 1) return cantidad;
        return cantidad * uxb;
    }

    /// <summary>Etiqueta de formato para mostrar en el ticket. BULTO/PACK_N agregan "× N"
    /// para que quede claro cuantas unidades trae cada uno.</summary>
    private string FormatoParaMostrar(int productoId, string formato)
    {
        var packN = ParsePackUnidades(formato);
        if (packN.HasValue) return $"Pack × {packN.Value}";
        if (formato != "BULTO") return FormatoLabel(formato);
        var uxb = productos?.FirstOrDefault(p => p.Id == productoId)?.UxB ?? 0;
        return uxb > 1 ? $"Bulto × {uxb}" : "Bulto";
    }

    /// <summary>Precio unitario EFECTIVO para mostrar (subtotal / unidades_reales). Si el item es
    /// BULTO o PACK_N, el precio almacenado es por bulto/pack entero; dividimos por las unidades
    /// reales para que la matematica del ticket cierre a ojo.</summary>
    private decimal PrecioUnitarioParaMostrar(int productoId, string formato, decimal precioUnitario)
    {
        var packN = ParsePackUnidades(formato);
        if (packN.HasValue && packN.Value > 1)
            return Math.Round(precioUnitario / packN.Value, 2, MidpointRounding.AwayFromZero);
        if (formato != "BULTO") return precioUnitario;
        var uxb = productos?.FirstOrDefault(p => p.Id == productoId)?.UxB ?? 0;
        if (uxb <= 1) return precioUnitario;
        return Math.Round(precioUnitario / uxb, 2, MidpointRounding.AwayFromZero);
    }

