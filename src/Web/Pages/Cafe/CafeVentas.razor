    private async Task OnItemCantidadChanged(int idx, string? value)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        int q = 1;
        if (!string.IsNullOrWhiteSpace(value)) int.TryParse(value, out q);
        formItems[idx].Cantidad = Math.Max(1, q);
