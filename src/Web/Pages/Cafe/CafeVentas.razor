        formTransporteDestino = v.TransporteDestino ?? "";
        formIsPaid = v.IsPaid;
        formEntregaPor = v.EntregaPor ?? "";
        formComentarioArmado = v.ComentarioArmado ?? "";
        // Items: convertir a CafeCotizarItemRequest para que el form los muestre y los pueda editar.
        formItems = v.Items.Select(i => new CafeCotizarItemRequest
        {
            ProductoId = i.ProductoId ?? 0,
            EsConceptoLibre = i.EsConceptoLibre,
            DescripcionLibre = i.EsConceptoLibre ? i.ProductoNombre : null,
            Formato = i.Formato,
            Cantidad = i.Cantidad,
            Molienda = i.Molienda,
            EsDoyPack = i.EsDoyPack,
            DescuentoPct = i.DescuentoPct,
            // Preservamos el PrecioUnitario guardado en el item:
            //   - Concepto libre: es la ÚNICA fuente del precio (no hay producto del catálogo).
            //   - Producto del catálogo: preservamos el precio histórico del comprobante.
            //     Si el catálogo cambió desde la emisión, queremos respetar el precio original
            //     al editar — no recalcularlo. El usuario puede pisarlo desde el input si quiere.
            PrecioUnitarioOverride = i.PrecioUnitario
        }).ToList();
        addProductoId = 0; addFormato = "1KG"; addCantidad = 1;
        addMolienda = "EN GRANOS"; addEnvase = "NEGRO";
        productoSearch = ""; productoSearchOpen = false;
        addMode = "PRODUCTO";
        addComboId = 0; addComboCantidad = 1;
        comboSearch = ""; comboSearchOpen = false;
        formError = null;
        includePrevBalanceInNotes = false;  // al editar no quiero injerir saldo retroactivamente
        // 2026-05-30: solo OSMAR arranca con "Enviar a IMPRIMIR PEDIDOS" tildado.
        envioDrive = string.Equals(Operator.Current ?? "", "OSMAR", StringComparison.OrdinalIgnoreCase);
        // 2026-06-03: el checkbox de re-subir desde EDIT arranca tildado si ya estaba en Drive,
        // o si el operador es OSMAR. Si la venta nunca se subio + el operador no es OSMAR, queda OFF.
        editingVentaTieneDrive = v.DriveSubidoAt.HasValue;
        envioDriveEdit = editingVentaTieneDrive || string.Equals(Operator.Current ?? "", "OSMAR", StringComparison.OrdinalIgnoreCase);
        showForm = true;
        // Refrescar saldo anterior + sugerencias del cliente y cotizar precios.
        RecomputeUnpaidPrevSales();
        await LoadTopProductsForClient();
        await Cotizar();
    }

