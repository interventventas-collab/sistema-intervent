        vrNombre = vrRazonSocial = vrCuit = vrDireccion = vrLocalidad = vrCiudad = vrCp = vrTelefono = vrDomicilioEntrega = "";
    }

    /// <summary>Recalcula los comprobantes con saldo pendiente del cliente actual.
    /// Usa el dictionary `saldosPorVenta` (calculado desde cobranzas reales) en vez del flag legacy IsPaid.
    /// Excluye anulados, totalmente pagados y la venta que se esta editando.</summary>
    private void RecomputeUnpaidPrevSales()
    {
        if (ventas is null || formClienteId <= 0)
        {
            unpaidPrevSales = new();
            return;
        }
        unpaidPrevSales = ventas
            .Where(v => v.ClienteId == formClienteId
                        && v.Estado == "emitido"
                        && (saldosPorVenta.TryGetValue(v.Id, out var sld) ? sld > 0.01m : !v.IsPaid)
                        && (editingVentaId == null || v.Id != editingVentaId))
            .OrderBy(v => v.Fecha)
            .ThenBy(v => v.Id)
            .ToList();
    }

    private async Task LoadTopProductsForClient()
    {
        if (formClienteId <= 0) { topProductsForClient = new(); topProductosDescartadosCount = 0; topProductsExpanded = false; return; }
        try { topProductsForClient = await Api.GetCafeTopProductosByClienteAsync(formClienteId, 10) ?? new(); }
        catch { topProductsForClient = new(); }
        // 2026-06-08: traer contador de descartados para mostrar botón "🔄 Restaurar N"
        try { topProductosDescartadosCount = (await Api.GetCafeTopProductosDescartadosAsync(formClienteId))?.Count ?? 0; }
        catch { topProductosDescartadosCount = 0; }
        topProductsExpanded = false;
    }

    /// <summary>2026-06-08: Descarta un producto de las sugerencias del cliente actual.
    /// El producto deja de aparecer hasta que el cliente lo vuelva a comprar.</summary>
    private async Task DescartarTopProduct(int productoId)
    {
        if (formClienteId <= 0 || productoId <= 0) return;
        // Optimismo: sacamos de la lista local para feedback inmediato
        var t = topProductsForClient.FirstOrDefault(x => x.ProductoId == productoId);
        try
        {
            var ok = await Api.DescartarTopProductoClienteAsync(formClienteId, productoId);
            if (!ok) { ToastService.Error("No se pudo descartar el producto."); return; }
            if (t is not null) topProductsForClient.Remove(t);
            topProductosDescartadosCount++;
            ToastService.Info($"Producto descartado. Va a volver a aparecer cuando el cliente lo compre de nuevo.");
            StateHasChanged();
        }
        catch (Exception ex) { ToastService.Error("Error al descartar: " + ex.Message); }
    }

    /// <summary>2026-06-08: Restaura TODOS los productos descartados del cliente actual.</summary>
    private async Task RestaurarTopProductosDescartados()
    {
        if (formClienteId <= 0) return;
        try
        {
            var ok = await Api.RestaurarTopProductoClienteAsync(formClienteId, 0);
            if (!ok) { ToastService.Error("No se pudo restaurar."); return; }
            topProductosDescartadosCount = 0;
            await LoadTopProductsForClient();
            ToastService.Success("Productos descartados restaurados. Vuelven a aparecer en sugerencias.");
            StateHasChanged();
        }
        catch (Exception ex) { ToastService.Error("Error al restaurar: " + ex.Message); }
    }

    /// <summary>Default de molienda al agregar un item: 'EN GRANOS' para CAFE, null para OTROS.</summary>
    private string? DefaultMolienda(int productoId)
    {
        var p = productos?.FirstOrDefault(x => x.Id == productoId);
        return p?.Categoria == "CAFE" ? "EN GRANOS" : null;
    }

    /// <summary>Agrega un producto sugerido (top productos del cliente) al carrito con cantidad 1.
    /// Si ya existia ese (Producto, Formato, Molienda, DoyPack), suma 1 a la cantidad.</summary>
    private async Task AddTopProduct(int productoId, string formato)
    {
        var def = DefaultMolienda(productoId);
        // 2026-06-11: el "+1" del sugerido siempre es envase negro (default).
        // Antes el filtro no chequeaba EsEnvasePlateado, asi que si ya habia un item
        // con envase plateado del mismo SKU, el "+1" se sumaba a el por error.
        var existing = formItems.FirstOrDefault(i => i.ProductoId == productoId
            && i.Formato == formato
            && (i.Molienda ?? "") == (def ?? "")
            && !i.EsDoyPack
            && !i.EsEnvasePlateado);
        if (existing is not null) existing.Cantidad += 1;
        else formItems.Add(new CafeCotizarItemRequest
        {
            ProductoId = productoId,
            Formato = formato,
            Cantidad = 1,
            Molienda = def,
            EsDoyPack = false,
            EsEnvasePlateado = false
        });
        await Cotizar();
    }

