    /// <summary>Genera un PDF de PREVIEW con los datos del modal sin guardar la venta.
    /// Lo abre en una pestaña nueva para que el operador vea cómo va a quedar.</summary>
    private async Task PreviewPdf()
    {
        if (formItems.Count == 0) { ToastService.Error("Agregá al menos un producto antes de previsualizar"); return; }
        if (cotizacion?.TodoOk != true) { ToastService.Error("Resolvé los items con stock insuficiente o inválidos primero"); return; }
        previewLoading = true;
        try
        {
            var weekCsv = formWeekDays.Count == 0 ? null : string.Join(",", formWeekDays);
            var (bytes, error) = await Api.PreviewCafeVentaPdfAsync(new CreateCafeVentaRequest
            {
                Fecha = DateTime.SpecifyKind(formFecha, DateTimeKind.Unspecified), // Kind=Unspecified asi System.Text.Json no agrega TZ — el server toma Y/M/D tal cual.
                ClienteId = formClienteId > 0 ? formClienteId : null,
                ClienteTipoOverride = formClienteTipo,
                Items = formItems,
                Descuento = formDescuento,
                Observaciones = formObservaciones,
                WeekDays = weekCsv,
                IsPaid = formIsPaid,
                TipoComprobante = formTipoComprobante,
                CondicionIva = formCondicionIva,
                CondicionPago = formCondicionPago
            });
            if (bytes is null)
            {
                ToastService.Error("No se pudo generar el preview: " + (error ?? "error desconocido"));
                return;
            }
            var b64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("openPdfInNewTab", b64);
