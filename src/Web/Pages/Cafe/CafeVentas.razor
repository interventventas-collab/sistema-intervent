    // ── Multi-select ──
    private void ToggleSelect(int id, bool isChecked)
    {
        if (isChecked) selectedIds.Add(id);
        else selectedIds.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (ventas is null) return;
        var check = (bool)(e.Value ?? false);
        if (check) foreach (var v in ventas) selectedIds.Add(v.Id);
        else selectedIds.Clear();
    }

    private void ClearSelection() => selectedIds.Clear();

    // ── Eliminar UNA (con clave) ──
    private void OpenDeleteModal(CafeVentaDto v)
    {
        if (!CanDelete)
        {
            ToastService.Error($"Solo {(deleteSettings?.AllowedOperator ?? "OSMAR")} puede eliminar comprobantes.");
            return;
        }
        toDelete = v;
        deletePassword = "";
        deleteError = null;
    }

    private void CloseDeleteModal()
    {
        if (isDeleting) return;
        toDelete = null;
        deletePassword = "";
        deleteError = null;
    }

    private async Task OnDeletePasswordKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(deletePassword) && !isDeleting)
            await DoDelete();
    }

    private async Task DoDelete()
    {
        if (toDelete is null) return;
        if (string.IsNullOrEmpty(deletePassword)) { deleteError = "Ingresá la clave"; return; }
        deleteError = null; isDeleting = true;
        try
        {
            await Api.DeleteCafeVentaAsync(toDelete.Id, deletePassword);
            ToastService.Success("Venta eliminada");
            selectedIds.Remove(toDelete.Id);
            toDelete = null;
            deletePassword = "";
            await Load();
            await LoadCatalogos();
        }
        catch (Exception ex) { deleteError = ex.Message; }
        finally { isDeleting = false; }
    }

    // ── Eliminar masivo (con clave) ──
    private void OpenBulkDeleteModal()
    {
        if (!CanDelete)
        {
            ToastService.Error($"Solo {(deleteSettings?.AllowedOperator ?? "OSMAR")} puede eliminar comprobantes.");
            return;
        }
        if (selectedIds.Count == 0) return;
        showBulkDeleteModal = true;
        bulkDeletePassword = "";
        bulkDeleteError = null;
    }

    private void CloseBulkDeleteModal()
    {
        if (isBulkDeleting) return;
        showBulkDeleteModal = false;
        bulkDeletePassword = "";
        bulkDeleteError = null;
    }

    private async Task OnBulkDeletePasswordKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(bulkDeletePassword) && !isBulkDeleting)
            await DoBulkDelete();
    }

    private async Task DoBulkDelete()
    {
        if (string.IsNullOrEmpty(bulkDeletePassword)) { bulkDeleteError = "Ingresá la clave"; return; }
        if (selectedIds.Count == 0) return;
        bulkDeleteError = null; isBulkDeleting = true;
        try
        {
            var ids = selectedIds.ToList();
            var deleted = await Api.BulkDeleteCafeVentasAsync(ids, bulkDeletePassword);
            ToastService.Success($"✓ {deleted} venta{(deleted == 1 ? "" : "s")} eliminada{(deleted == 1 ? "" : "s")}");
            selectedIds.Clear();
            showBulkDeleteModal = false;
            bulkDeletePassword = "";
            await Load();
            await LoadCatalogos();
        }
        catch (Exception ex) { bulkDeleteError = ex.Message; }
        finally { isBulkDeleting = false; }
    }

    // ── Editar comprobante: precarga el form de Nueva Venta con los datos del comprobante existente ──
    private async Task OpenEditModal(CafeVentaDto v)
    {
        editingVentaId = v.Id;
        editingVentaNumero = v.Numero;
        formClienteId = v.ClienteId ?? 0;
        formClienteTipo = string.IsNullOrWhiteSpace(v.ClienteTipo) ? "OTRO" : v.ClienteTipo!;
        clienteSearch = ""; clienteSearchOpen = false;
        formFecha = v.Fecha;
        formDescuento = v.Descuento;
        formObservaciones = v.Observaciones ?? "";
        formTipoComprobante = string.IsNullOrWhiteSpace(v.TipoComprobante) ? "X" : v.TipoComprobante;
        formCondicionIva = string.IsNullOrWhiteSpace(v.CondicionIva) ? "CF" : v.CondicionIva;
        formCondicionPago = string.IsNullOrWhiteSpace(v.CondicionPago) ? "EFECTIVO" : v.CondicionPago;
        formWeekDays = string.IsNullOrWhiteSpace(v.WeekDays)
            ? new HashSet<string>()
            : v.WeekDays.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim().ToUpperInvariant()).ToHashSet();
        formIsPaid = v.IsPaid;
        // Items: convertir a CafeCotizarItemRequest para que el form los muestre y los pueda editar.
        formItems = v.Items.Select(i => new CafeCotizarItemRequest
        {
            ProductoId = i.ProductoId,
            Formato = i.Formato,
            Cantidad = i.Cantidad,
            Molienda = i.Molienda,
            EsDoyPack = i.EsDoyPack,
            DescuentoPct = i.DescuentoPct
        }).ToList();
        addProductoId = 0; addFormato = "1KG"; addCantidad = 1;
        productoSearch = ""; productoSearchOpen = false;
        addMode = "PRODUCTO";
        addComboId = 0; addComboCantidad = 1;
        comboSearch = ""; comboSearchOpen = false;
        formError = null;
        includePrevBalanceInNotes = false;  // al editar no quiero injerir saldo retroactivamente
        showForm = true;
        // Refrescar saldo anterior + sugerencias del cliente y cotizar precios.
        RecomputeUnpaidPrevSales();
        await LoadTopProductsForClient();
        await Cotizar();
    }

    // ── Helpers ──
    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    private static string FormatGramos(decimal g)
    {
        if (g >= 1000m) return $"{(g / 1000m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))} kg";
        return $"{g:0} g";
    }

    private static string FormatoLabel(string formato) => formato switch
    {
        "1KG" => "1 kg",
        "MEDIO" => "1/2 kg",
        "CUARTO" => "1/4 kg",
        "UNIT" => "u.",
        _ => formato
    };

    private static string TipoComprobanteCorto(string t) => t switch
    {
        "FA" => "A", "FB" => "B", "FC" => "C", _ => "X"
    };
    private static string TipoComprobanteLargo(string t) => t switch
    {
        "FA" => "FACTURA",
        "FB" => "FACTURA",
        "FC" => "FACTURA",
        _ => "COMPROBANTE"
    };
    private static string CondicionIvaLabel(string c) => c switch
    {
        "RI" => "Responsable Inscripto",
        "MO" => "Monotributo",
        "EX" => "Exento",
        _ => "Consumidor final"
    };
    private static string CondicionPagoLabel(string c) => c switch
    {
        "TRANSFERENCIA" => "Transferencia",
        "DEBITO" => "Tarjeta de débito",
        "CREDITO" => "Tarjeta de crédito",
        "CTA_CORRIENTE" => "Cuenta corriente",
        "CHEQUE" => "Cheque",
        "V_PRIVADO" => "*V********",
        _ => "Efectivo"
    };
