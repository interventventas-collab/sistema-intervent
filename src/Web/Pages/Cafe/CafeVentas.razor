    /// <summary>Doble-check antes de emitir: si es FA/FB/FC (genera CAE irreversible) muestra
    /// un modal de confirmación con resumen. Si es X o PRO (interno, sin ARCA) o si está editando
    /// una venta existente, salta el modal y guarda directo.</summary>
    private void ConfirmarEmision()
    {
        if (formItems.Count == 0) { formError = "Agregá al menos un producto"; return; }
        if (cotizacion?.TodoOk != true) { formError = "Hay items con stock insuficiente o inválidos"; return; }
        // Editando una venta existente o tipo interno (X / PRO) → no requiere doble-check.
        var esArcaReal = formTipoComprobante is "FA" or "FB" or "FC";
        if (editingVentaId.HasValue || !esArcaReal)
        {
            _ = Save();
            return;
        }
        showConfirmEmision = true;
    }

    /// <summary>Confirma la emisión desde el modal de doble-check y dispara la emisión real.</summary>
    private async Task ConfirmarYEmitir()
    {
        showConfirmEmision = false;
        await Save();
    }

    /// <summary>Nombre legible del cliente para mostrar en el modal de confirmación.</summary>
    private string NombreClienteConfirmacion()
    {
        if (formClienteId > 0)
        {
            var c = clientes?.FirstOrDefault(x => x.Id == formClienteId);
            if (c is not null) return c.Nombre ?? c.RazonSocial ?? "(sin nombre)";
        }
        return "Consumidor final";
    }

    private async Task Save()
    {
        formError = null;
        if (formItems.Count == 0) { formError = "Agregá al menos un producto"; return; }
        if (cotizacion?.TodoOk != true) { formError = "Hay items con stock insuficiente o inválidos"; return; }
        saving = true;
        try
        {
            var weekCsv = formWeekDays.Count > 0
                ? string.Join(",", AllWeekDays.Where(d => formWeekDays.Contains(d)))
                : null;

            // Inyectar saldo anterior en las observaciones si esta tildado y el cliente tiene impagos.
            var notesToSave = formObservaciones ?? "";
            if (includePrevBalanceInNotes
                && unpaidPrevSales.Count > 0
                && !notesToSave.Contains("Saldo anterior", StringComparison.OrdinalIgnoreCase))
            {
                var nums = string.Join(", ", unpaidPrevSales.Select(s => s.Numero));
                var prevLine = $"Saldo anterior: ${FormatMoney(UnpaidPrevTotal)} (comprobantes: {nums})";
                notesToSave = string.IsNullOrWhiteSpace(notesToSave)
                    ? prevLine
                    : prevLine + "\n" + notesToSave;
            }

            CafeVentaDto? v;
            if (editingVentaId.HasValue)
            {
                v = await Api.UpdateCafeVentaAsync(editingVentaId.Value, new UpdateCafeVentaRequest
                {
                    Fecha = DateTime.SpecifyKind(formFecha, DateTimeKind.Unspecified), // Kind=Unspecified asi System.Text.Json no agrega TZ — el server toma Y/M/D tal cual.
                    ClienteId = formClienteId > 0 ? formClienteId : 0,
                    ClienteTipoOverride = formClienteId > 0 ? null : formClienteTipo,
                    Items = formItems,
                    Descuento = formDescuento,
                    Observaciones = notesToSave,
                    WeekDays = weekCsv ?? "",
                    EnRadar = formEnRadar,
                Retira = formRetira,
                PorTransporte = formPorTransporte,
                TransporteEmpresa = formPorTransporte ? formTransporteEmpresa : null,
                TransporteDestino = formPorTransporte ? formTransporteDestino : null,
                    IsPaid = formIsPaid,
                    TipoComprobante = formTipoComprobante,
                    CondicionIva = formCondicionIva,
                    CondicionPago = formCondicionPago,
                    EntregaPor = formEntregaPor,
                    ComentarioArmado = formComentarioArmado
                });
                if (v is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success($"Comprobante {v.Numero} actualizado");

                // 2026-06-03: si el checkbox de re-subir Drive esta tildado, disparamos la subida en background.
                // Si la venta ya estaba en LISTO/EN_CAMINO/ENTREGADO, el backend la revive con flag "MODIFICADO".
                if (envioDriveEdit)
                {
                    var ventaIdParaDrive = v.Id;
                    var numeroParaToast = v.Numero;
                    var eraResubida = editingVentaTieneDrive;
                    _ = Task.Run(async () =>
                    {
                        try
                        {
                            var (fileId, _, _) = await Api.SubirVentaADriveAsync(ventaIdParaDrive);
                            if (!string.IsNullOrEmpty(fileId))
                            {
                                var msg = eraResubida
                                    ? $"{numeroParaToast} re-subido a IMPRIMIR PEDIDOS DE OSMAR ✅ (con chip MODIFICADO)"
                                    : $"{numeroParaToast} enviado a IMPRIMIR PEDIDOS DE OSMAR ✅";
                                await InvokeAsync(() => ToastService.Success(msg));
                            }
                        }
                        catch (Exception driveEx)
                        {
                            await InvokeAsync(() => ToastService.Error("No se pudo subir a Drive: " + driveEx.Message));
                        }
                    });
                }

                // Auto-reintentar ARCA si la edicion venia del boton "Editar y reintentar"
                // del cartel naranja de Factura PENDIENTE. Asi en un solo paso el operador
                // edita los datos que hicieron rebotar la factura + se reintenta solo.
                if (autoRetryArcaPostEdit && v.TipoComprobante is "FA" or "FB" or "FC")
                {
                    autoRetryArcaPostEdit = false;
                    try
                    {
                        var reintentada = await Api.RetryArcaCafeVentaAsync(v.Id);
                        if (reintentada is not null)
                        {
                            v = reintentada;
                            if (reintentada.ArcaEstado == "autorizado")
                                ToastService.Success($"✓ Autorizada por ARCA — CAE {reintentada.ArcaCae}");
                            else
                                ToastService.Error($"ARCA sigue rechazando: {reintentada.ArcaError}");
                        }
                    }
                    catch (Exception ex) { ToastService.Error("Error reintentando ARCA: " + ex.Message); }
                }
            }
            else
            {
                v = await Api.CreateCafeVentaAsync(new CreateCafeVentaRequest
                {
                    Fecha = DateTime.SpecifyKind(formFecha, DateTimeKind.Unspecified), // Kind=Unspecified asi System.Text.Json no agrega TZ — el server toma Y/M/D tal cual.
                    ClienteId = formClienteId > 0 ? formClienteId : null,
                    ClienteNombreOverride = modoVentaRapida ? (string.IsNullOrWhiteSpace(vrNombre) ? "Consumidor final" : vrNombre) : null,
                    ClienteTipoOverride = formClienteTipo,
                    ClienteRazonSocialOverride = modoVentaRapida ? vrRazonSocial : null,
                    ClienteCuitOverride = modoVentaRapida ? vrCuit : null,
                    ClienteDireccionOverride = modoVentaRapida ? vrDireccion : null,
                    ClienteLocalidadOverride = modoVentaRapida ? vrLocalidad : null,
                    ClienteCiudadOverride = modoVentaRapida ? vrCiudad : null,
                    ClienteCpOverride = modoVentaRapida ? vrCp : null,
                    ClienteTelefonoOverride = modoVentaRapida ? vrTelefono : null,
                    ClienteDomicilioEntregaOverride = modoVentaRapida ? vrDomicilioEntrega : null,
                    Items = formItems,
                    Descuento = formDescuento,
                    Observaciones = notesToSave,
                    WeekDays = weekCsv,
                    EnRadar = formEnRadar,
                Retira = formRetira,
                PorTransporte = formPorTransporte,
                TransporteEmpresa = formPorTransporte ? formTransporteEmpresa : null,
                TransporteDestino = formPorTransporte ? formTransporteDestino : null,
                    IsPaid = false,  // NUNCA marcar pagado al crear — el flag se sincroniza por la cobranza
                    TipoComprobante = formTipoComprobante,
                    CondicionIva = formCondicionIva,
                    CondicionPago = formCondicionPago,
                    EntregaPor = formEntregaPor,
                    ComentarioArmado = formComentarioArmado
                });
                if (v is null) { formError = "No se pudo crear"; return; }
                ToastService.Success($"Venta {v.Numero} emitida — Total ${v.Total:N2}");
                // Emisión exitosa → borramos el auto-borrador
                await DiscardBorradorAsync();

                // Si veníamos de convertir una preventa, vincularla a la venta nueva
                if (convirtiendoPreventaId.HasValue)
                {
                    try
                    {
                        await Api.VincularPreventaVentaAsync(convirtiendoPreventaId.Value, v.Id);
                        ToastService.Success($"✓ Preventa marcada como procesada");
                    }
                    catch { /* la venta ya se creó, no romper si falla el vincular */ }
                    convirtiendoPreventaId = null;
                    lastPreventaQuery = null;
                }

                // Si veníamos de un pedido de WhatsApp, vincularlo y marcarlo como cargado
                if (convirtiendoPedidoWAId.HasValue)
                {
                    try
                    {
                        await Api.VincularPedidoAVentaAsync(convirtiendoPedidoWAId.Value, v.Id);
                        ToastService.Success("✓ Pedido WhatsApp marcado como cargado");
                    }
                    catch { /* no romper si falla el vincular */ }
                    convirtiendoPedidoWAId = null;
                    lastPedidoWAQuery = null;
                    pedidoWASeleccionado = null;
                    await RefrescarPedidoWACount();
                }
            }

            var wasEditing = editingVentaId.HasValue;
            // Si en una venta NUEVA el operador tildo "Marcar como PAGADO al guardar",
            // redirigimos al modal de Cobranzas precargado para que registre la cobranza real.
            var redirigirACobranza = !wasEditing && formIsPaid && v.ClienteId.HasValue;

            // ════════ CERRAR EL MODAL INMEDIATAMENTE ════════
            // Apenas el server confirma OK, cerramos el form y liberamos el boton
            // "Emitiendo...". El Load() de la lista (que puede tardar varios segundos
            // en produccion) corre despues — el usuario ya tiene el feedback de exito.
            showForm = false;
            editingVentaId = null;
            editingVentaNumero = "";
            saving = false;
            StateHasChanged();

            if (redirigirACobranza)
            {
                ToastService.Success("Cargá ahora la cobranza para registrar el pago");
                Navigation.NavigateTo($"/cafe/tesoreria/cobranzas?cliente={v.ClienteId!.Value}&venta={v.Id}");
                return;
            }

            // ════════ ABRIR EL PDF EN UNA PESTAÑA NUEVA ════════
            // Si era una venta nueva (no edicion), abrimos directamente la URL publica
            // del PDF en otra pestaña. Usamos la URL publica (con token) para que cuando
            // el usuario haga 'Guardar como' desde el visor del navegador, el filename
            // sugerido sea el del Content-Disposition del server ('Factura A - Cliente
            // - Direccion - Fecha.pdf') y no un blob UUID random. La via privada con
            // cookie funciona tambien, pero la publica es identica y mas portable.
            if (!wasEditing)
            {
                try
                {
                    var token = await Api.EnsurePublicTokenAsync(v.Id);
                    if (!string.IsNullOrEmpty(token))
                    {
                        var url = $"{Navigation.BaseUri.TrimEnd('/')}/api/cafe/ventas/publica/{token}/pdf";
                        await JS.InvokeVoidAsync("openInNewTab", url);
                    }
                    else
                    {
                        ToastService.Error("Comprobante emitido pero no se pudo obtener el link al PDF.");
                    }
                }
                catch (Exception pdfEx)
                {
                    // No romper el flujo si el PDF falla — la venta ya esta guardada.
                    ToastService.Error("Comprobante emitido pero falló al abrir el PDF: " + pdfEx.Message);
                }

                // ════════ DISPARAR LOS CANALES DE ENVIO TILDADOS ════════
                // Email + WhatsApp Web (manual via wa.me) + WhatsApp Interno (con PDF).
                // Corre en paralelo y avisa con toasts. No bloquea el resto del flujo.
                if (envioEmail || envioWhatsappWeb || envioWhatsappInterno)
                {
                    await DispararCanalesDeEnvioAsync(v.Id, v.Numero);
                }

                // 2026-05-28: si "Enviar a IMPRIMIR PEDIDOS DE OSMAR" estaba tildado,
                // subir el PDF a Drive en background — no bloqueamos el flujo de la venta.
                if (envioDrive)
                {
                    var ventaIdParaDrive = v.Id;
                    var numeroParaToast = v.Numero;
                    _ = Task.Run(async () =>
                    {
                        try
                        {
                            var (fileId, _, _) = await Api.SubirVentaADriveAsync(ventaIdParaDrive);
                            if (!string.IsNullOrEmpty(fileId))
                            {
                                await InvokeAsync(() => ToastService.Success($"{numeroParaToast} enviado a IMPRIMIR PEDIDOS DE OSMAR ✅"));
                            }
                        }
                        catch (Exception driveEx)
                        {
                            await InvokeAsync(() => ToastService.Error("No se pudo subir a Drive: " + driveEx.Message));
                        }
                    });
                }
            }

            // Recargar listado y catalogos en segundo plano (la UI ya cerro el modal).
            await LoadCatalogos();
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { saving = false; }
    }

    /// <summary>URL del PDF embebido en el modal de "Ver / imprimir / PDF". Se carga desde
    /// el endpoint /api/cafe/ventas/{id}/pdf y se muestra en un <embed>. Asi lo que ve el
    /// usuario en pantalla es EXACTAMENTE el PDF que descarga (no un render HTML aproximado).</summary>
    private string? printPdfUrl;

    private async Task ShowPrint(CafeVentaDto v)
    {
        await RevocarPrintPdfAsync();
        // Refrescar settings por si cambiaron datos del negocio
        try { settings = await Api.GetCafeSettingsAsync(); } catch { }
        var fresh = await Api.GetCafeVentaAsync(v.Id);
        printVenta = fresh ?? v;
        // Pedir el PDF al backend y embeberlo como Blob URL.
        try
        {
            var (bytes, err) = await Api.GetCafeVentaPdfAsync(printVenta.Id);
            if (bytes is not null && bytes.Length > 0)
            {
                var b64 = Convert.ToBase64String(bytes);
                printPdfUrl = await JS.InvokeAsync<string>("createBlobUrl", b64, "application/pdf");
            }
            else if (!string.IsNullOrEmpty(err))
            {
                ToastService.Error("No se pudo generar el PDF: " + err);
            }
        }
        catch { /* la vista muestra "Cargando..." si printPdfUrl quedo null */ }
    }

    private async Task ClosePrint()
    {
        await RevocarPrintPdfAsync();
        printVenta = null;
    }

    private async Task RevocarPrintPdfAsync()
    {
        if (!string.IsNullOrEmpty(printPdfUrl))
        {
            try { await JS.InvokeVoidAsync("revokeBlobUrl", printPdfUrl); } catch { }
            printPdfUrl = null;
        }
    }

    private async Task TogglePaid(ChangeEventArgs e)
    {
        if (printVenta is null) return;
        var paid = e.Value is bool b ? b : false;
        try
        {
            var updated = await Api.UpdateCafeVentaFlagsAsync(printVenta.Id, new UpdateCafeVentaFlagsRequest { IsPaid = paid });
            if (updated is not null) printVenta = updated;
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private bool subiendoDrive;
    /// <summary>Sube el PDF de la venta a Google Drive y actualiza el printVenta para
    /// que el botón cambie a "Ver en Drive". Si Drive no está configurado o falla,
    /// muestra el error en un toast.</summary>
    private async Task SubirADrive(CafeVentaDto v)
    {
        if (subiendoDrive) return;
        subiendoDrive = true;
        try
        {
            var (fileId, link, subidoAt) = await Api.SubirVentaADriveAsync(v.Id);
            if (!string.IsNullOrEmpty(fileId))
            {
                // 2026-05-28: NO recargamos toda la lista (eso congelaba la UI varios segundos).
                // En su lugar actualizamos SOLO esta venta en la lista local — instantáneo.
                v.DriveFileId = fileId;
                v.DriveSubidoAt = subidoAt ?? DateTime.UtcNow;
                v.DriveSubidasCount = v.DriveSubidasCount + 1;
                if (printVenta is not null && printVenta.Id == v.Id)
                {
                    printVenta.DriveFileId = fileId;
                    printVenta.DriveSubidoAt = subidoAt ?? DateTime.UtcNow;
                }
                ToastService.Success("Comprobante subido a Drive");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al subir a Drive: " + ex.Message);
        }
        finally
        {
            subiendoDrive = false;
        }
    }

    private bool arcaRetrying;
    /// <summary>Abre el modal de edición de la venta actual + setea un flag para que,
    /// cuando el usuario guarde la edición, automaticamente se reintente la emisión
    /// contra ARCA con los datos nuevos. Asi en un solo paso edita + reintenta.</summary>
    private async Task EditarYReintentar()
    {
        if (printVenta is null) return;
        var v = printVenta;
        // Marcar para auto-retry post-save
        autoRetryArcaPostEdit = true;
        // Cerrar el viewer y abrir el form de edicion con los datos precargados
        await RevocarPrintPdfAsync();
        printVenta = null;
        await OpenEditModal(v);
    }

    /// <summary>Si se activo desde EditarYReintentar, despues de guardar la edicion
    /// disparamos un retry de ARCA automaticamente. Reset despues de usarlo.</summary>
    private bool autoRetryArcaPostEdit;

    private async Task RetryArca()
    {
        if (printVenta is null || arcaRetrying) return;
        arcaRetrying = true;
        try
        {
            var updated = await Api.RetryArcaCafeVentaAsync(printVenta.Id);
            if (updated is not null)
            {
                printVenta = updated;
                if (updated.ArcaEstado == "autorizado")
                    ToastService.Success($"Factura autorizada — CAE {updated.ArcaCae}");
                else
                    ToastService.Error("ARCA: " + (updated.ArcaError ?? "sigue pendiente"));
            }
            await Load();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { arcaRetrying = false; }
    }

    private async Task ToggleViewerDay(string d)
    {
        if (printVenta is null) return;
        var current = (printVenta.WeekDays ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim().ToUpperInvariant())
            .ToHashSet();
        if (!current.Add(d)) current.Remove(d);
        var csv = current.Count > 0 ? string.Join(",", AllWeekDays.Where(x => current.Contains(x))) : "";
        try
        {
            var updated = await Api.UpdateCafeVentaFlagsAsync(printVenta.Id, new UpdateCafeVentaFlagsRequest { WeekDays = csv });
            if (updated is not null) printVenta = updated;
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DoPrint()
    {
        if (printVenta is null) return;
        try
        {
            // Abrimos directamente la URL publica del PDF en pestaña nueva. Ventaja:
            // cuando el usuario hace 'Guardar como' desde el visor del navegador, el
            // nombre sugerido es el del Content-Disposition del server ('Factura A -
            // Cliente - Direccion - Fecha.pdf') en vez de un blob UUID random.
            var token = await Api.EnsurePublicTokenAsync(printVenta.Id);
            if (string.IsNullOrEmpty(token))
            {
                ToastService.Error("No se pudo obtener el link al PDF");
                return;
            }
            var url = $"{Navigation.BaseUri.TrimEnd('/')}/api/cafe/ventas/publica/{token}/pdf";
            await JS.InvokeVoidAsync("openInNewTab", url);
        }
        catch (Exception ex)
        {
            ToastService.Error("Error generando PDF: " + ex.Message);
        }
    }

