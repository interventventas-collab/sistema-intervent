@page "/cafe/ventas"
@page "/cafe/presupuestos"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@inject OperatorService Operator
@inject NuevaVentaSignal NuevaVentaSignal
@inject NavigationManager Navigation

<style>
    /* Tooltip en la celda Cliente: detalle del comprobante al hacer hover. */
    .cell-cliente-hover .venta-tooltip {
        display: none;
        position: absolute;
        top: calc(100% + 2px);
        left: 0;
        z-index: 100;
        background: white;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
        padding: 0.7rem 0.85rem;
        min-width: 380px;
        max-width: 520px;
    }
    .cell-cliente-hover:hover .venta-tooltip { display: block; }

    /* Pildoritas de días — siempre disponibles (form de carga + viewer) */
    .cafe-day-pill {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0.18rem 0.45rem;
        border: 1px solid #d1d5db;
        background: white;
        color: #374151;
        border-radius: 4px;
        font-weight: 700;
        font-size: 0.72rem;
        cursor: pointer;
        min-width: 32px;
        user-select: none;
        transition: background 0.1s, color 0.1s;
    }
    .cafe-day-pill:hover { background: #f3f4f6; }
    .cafe-day-pill.on {
        background: #1f2937; color: white; border-color: #1f2937;
        -webkit-print-color-adjust: exact; print-color-adjust: exact;
    }
    .cli-pick-row:hover { background: #f0f9ff; }

    /* Pin / post-it para anotar ventas */
    .pin-icon {
        display: inline-block;
        cursor: pointer;
        opacity: 0.25;
        font-size: 0.85rem;
        margin-right: 0.2rem;
        user-select: none;
        transition: opacity 0.1s, transform 0.1s;
    }
    .pin-icon:hover { opacity: 1; transform: scale(1.2); }
    .pin-icon.active { opacity: 1; filter: drop-shadow(0 0 1px #d97706); }
    /* Post-it amarillo que aparece al hover de la fila o del pin */
    .pin-postit {
        position: absolute;
        top: 100%;
        left: 0;
        z-index: 50;
        background: #fef3c7;
        border: 1px solid #d97706;
        border-radius: 6px;
        padding: 0.4rem 0.6rem;
        font-family: inherit;
        font-size: 0.78rem;
        font-weight: 500;
        color: #78350f;
        max-width: 260px;
        min-width: 140px;
        box-shadow: 0 3px 8px rgba(0,0,0,0.15);
        white-space: pre-wrap;
        word-break: break-word;
        display: none;
        pointer-events: none;
    }
    /* Mostrar el post-it al hacer hover sobre la celda (el TD contenedor) */
    td:hover > .pin-postit { display: block; }
</style>

@* overflow:visible para que el tooltip de la celda Cliente no quede recortado por el wrapper .card
   (que tiene overflow:hidden en el CSS global). *@
<div class="card" style="overflow: visible;">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>@(ModoPresupuestos ? "📋 Presupuestos" : "🧾 Ventas")
            <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">
                (@VentasFiltradas.Count@(HayFiltrosActivos ? $" de {ventas?.Count ?? 0}" : ""))
            </span>
            @if (ModoPresupuestos)
            {
                <span style="margin-left: 0.6rem; font-size: 0.75rem; color: #6b7280; font-weight: 500;">
                    — proforma con IVA, no descuenta stock
                </span>
            }
        </h3>
        @* El boton "+ Nueva Venta" vive en el topbar (siempre visible). El de esta pantalla
           se saco el 2026-05-19 porque era duplicado y solo funcionaba el del topbar. *@
    </div>
    @* ─── Barra de filtros ─── *@
    @if (ventas is not null && ventas.Count > 0)
    {
        <div style="background: #f9fafb; border-bottom: 1px solid #e5e7eb; padding: 0.6rem 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: end;">
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 130px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Desde</label>
                <input type="date" class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       value="@(filtroFechaDesde?.ToString("yyyy-MM-dd"))"
                       @onchange="@(e => filtroFechaDesde = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 130px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Hasta</label>
                <input type="date" class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       value="@(filtroFechaHasta?.ToString("yyyy-MM-dd"))"
                       @onchange="@(e => filtroFechaHasta = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 200px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Buscar venta</label>
                <input class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       @bind="filtroCliente" @bind:event="oninput"
                       placeholder="🔍 Nº venta, código, nombre, CUIT, tel, email, dirección, localidad, CP..." />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 120px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Tipo</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroTipo">
                    <option value="TODOS">Todos</option>
                    <option value="X">Cotización (X)</option>
                    <option value="PRO">Proforma</option>
                    <option value="FA">Factura A</option>
                    <option value="FB">Factura B</option>
                    <option value="FC">Factura C</option>
                </select>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 110px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Estado</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroEstado">
                    <option value="TODOS">Todos</option>
                    <option value="emitido">Emitida</option>
                    <option value="anulado">Anulada</option>
                </select>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 130px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">CAE</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroCae">
                    <option value="TODOS">Todas</option>
                    <option value="CON_CAE">📜 Con CAE</option>
                    <option value="SIN_CAE">Sin CAE (X / PRO)</option>
                    <option value="PENDIENTE">⚠ ARCA pendiente</option>
                </select>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 150px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Saldo</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroSaldo">
                    <option value="TODOS">Todas</option>
                    <option value="CON_SALDO">⏳ Con saldo pendiente</option>
                    <option value="SIN_SALDO">✅ Sin saldo (pagadas)</option>
                </select>
            </div>
            @* 2026-06-08: filtro por repartidor (quien la tiene o quien la entregó) *@
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 160px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Repartidor</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroRepartidor">
                    <option value="TODOS">Todos</option>
                    <option value="__SIN_ASIGNAR__">— Sin asignar —</option>
                    @foreach (var r in RepartidoresEnVentas)
                    {
                        <option value="@r">🚚 @r</option>
                    }
                </select>
            </div>
            @if (HayFiltrosActivos)
            {
                <button class="btn btn-secondary" @onclick="LimpiarFiltros"
                        style="padding: 0.35rem 0.7rem; font-size: 0.8rem;"
                        title="Limpiar todos los filtros">✕ Limpiar</button>
            }
            <div style="margin-left: auto; display: flex; gap: 0.3rem; align-items: center;">
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.8rem;" @bind="rangoExportPreset" @bind:after="AplicarPresetExport"
                        title="Atajos rápidos de fecha para exportar">
                    <option value="">📅 Rango exportar...</option>
                    <option value="HOY">Hoy</option>
                    <option value="AYER">Ayer</option>
                    <option value="SEMANA">Esta semana</option>
                    <option value="MES">Este mes</option>
                    <option value="MES_PASADO">Mes pasado</option>
                </select>
                <button class="btn btn-primary" style="padding: 0.35rem 0.7rem; font-size: 0.8rem; background: #16a34a; border-color: #15803d;"
                        @onclick="ExportarProductosVendidos"
                        disabled="@exportando"
                        title="Descarga un Excel con todos los productos vendidos en el rango Desde/Hasta">
                    @(exportando ? "Generando..." : "📊 Excel productos")
                </button>
            </div>
        </div>
    }
    <div class="card-body" style="padding: 0;">
        @if (loading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (ventas is null || ventas.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay ventas. Tocá <strong>"+ Nueva Venta"</strong> para emitir la primera.
            </p>
        }
        else
        {
            @* Barra de acciones masivas — solo visible cuando hay seleccionadas *@
            @if (selectedIds.Count > 0)
            {
                <div style="background: #1e3a8a; color: white; padding: 0.6rem 1rem; display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap;">
                    <div style="font-weight: 700;">
                        ☑ <strong>@selectedIds.Count</strong> venta@(selectedIds.Count == 1 ? "" : "s") seleccionada@(selectedIds.Count == 1 ? "" : "s")
                        <span style="font-weight: 400; font-size: 0.82rem; margin-left: 0.5rem; opacity: 0.85;">
                            Total: <strong>$@FormatMoney(ventas.Where(x => selectedIds.Contains(x.Id)).Sum(x => x.Total))</strong>
                        </span>
                    </div>
                    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                        @if (CanDelete)
                        {
                            <button class="btn" style="background: #b91c1c; color: white; border: none; font-weight: 700;"
                                    @onclick="OpenBulkDeleteModal">
                                🗑 Eliminar @selectedIds.Count
                            </button>
                        }
                        else
                        {
                            <span style="font-size: 0.78rem; opacity: 0.85;">
                                Solo @(deleteSettings?.AllowedOperator ?? "OSMAR") puede eliminar.
                            </span>
                        }
                        <button class="btn" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.3);"
                                @onclick="ClearSelection">
                            Cancelar
                        </button>
                    </div>
                </div>
            }
            @* overflow:visible + max-height:none → permite que el tooltip de la celda Cliente se
               muestre completo aunque haya pocas filas (con `overflow:auto` del default, el tooltip
               quedaba recortado por el contenedor cuando la tabla era chica). *@
            <div class="table-responsive" style="overflow: visible; max-height: none;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 36px; text-align: center;">
                                <input type="checkbox" title="Seleccionar todas"
                                       checked="@AllVisibleSelected"
                                       @onchange="ToggleSelectAll" />
                            </th>
                            <th style="width: 130px;">Número</th>
                            <th style="width: 95px;">Fecha</th>
                            <th style="width: 280px;">Cliente</th>
                            <th style="width: 95px;">Tipo</th>
                            <th style="text-align: right; width: 130px;">Total</th>
                            <th style="text-align: right; width: 110px;">Margen</th>
                            <th style="width: 110px;">Estado</th>
                            <th style="width: 210px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in VentasFiltradas)
                        {
                            var anulada = v.Estado == "anulado";
                            var sel = selectedIds.Contains(v.Id);
                            var pendienteArca = v.ArcaEstado == "pendiente";
                            // Comprobantes con CAE de ARCA no se pueden borrar ni anular —
                            // están en el libro IVA Ventas de ARCA. Solo se revierten con NC.
                            var tieneCae = v.ArcaEstado == "autorizado";
                            <tr style="@(anulada ? "opacity: 0.55;" : "") @(sel ? "background:#eff6ff;" : (pendienteArca ? "background:#fff7ed;" : ""))">
                                <td style="text-align: center;">
                                    <input type="checkbox"
                                           checked="@sel"
                                           disabled="@tieneCae"
                                           title="@(tieneCae ? "Comprobante con CAE de ARCA — no se puede eliminar. Generá una Nota de Crédito." : "")"
                                           @onchange="@(e => ToggleSelect(v.Id, (bool)(e.Value ?? false)))" />
                                </td>
                                <td style="font-family: monospace; font-weight: 700; position:relative;">
                                    @{
                                        var tienePin = !string.IsNullOrEmpty(v.PinNota);
                                    }
                                    <span class="pin-icon @(tienePin ? "active" : "")" @onclick="@(() => AbrirPin(v))"
                                          title="@(tienePin ? v.PinNota : "Agregar nota a esta venta")">
                                        📌
                                    </span>
                                    @v.Numero
                                    @* 2026-06-16: si la venta tiene CAE de ARCA, mostrar abajo el numero oficial (PtoVta-CbteNro). *@
                                    @if (v.ArcaCbteNro.HasValue)
                                    {
                                        <div style="font-family:monospace; font-size:0.72rem; color:#1e40af; margin-top:0.15rem; font-weight:600;" title="Número oficial asignado por ARCA">
                                            📜 @($"{(v.ArcaPtoVta ?? 0):00000}-{v.ArcaCbteNro.Value:00000000}")
                                        </div>
                                    }
                                    @* 2026-06-05: chip con inicial del operador que cargo la venta *@
                                    @if (!string.IsNullOrWhiteSpace(v.CreadoPorOperador))
                                    {
                                        var op = v.CreadoPorOperador!;
                                        var bg = OperatorService.ShortBgColor(op);
                                        var ini = OperatorService.ShortLabel(op);
                                        <span title="@($"Cargada por {op}")"
                                              style="display:inline-block; margin-left:0.35rem; padding:0.05rem 0.32rem; background:@bg; color:white; border-radius:4px; font-size:0.62rem; font-weight:800; letter-spacing:0.5px; vertical-align:middle;">
                                            @ini
                                        </span>
                                    }
                                    @if (tienePin)
                                    {
                                        <div class="pin-postit">@v.PinNota</div>
                                    }
                                    @if (v.EsSaldoMigracion)
                                    {
                                        <div style="margin-top:0.15rem;"><span title="Esta venta fue creada como saldo de migración del sistema anterior" style="display:inline-block; padding:0.05rem 0.35rem; background:#fef3c7; color:#92400e; border-radius:4px; font-size:0.62rem; font-weight:800; letter-spacing:0.5px; font-family:inherit;">🔄 MIGRACIÓN</span></div>
                                    }
                                </td>
                                <td>@v.Fecha.ToString("dd/MM/yyyy")</td>
                                <td style="line-height: 1.1; position: relative;" class="cell-cliente-hover">
                                    <strong>@(v.ClienteNombre ?? "—")</strong>@if (v.ClienteCodigoInterno.HasValue) {<span style="color:#6b7280; font-weight:600; margin-left:0.3rem; font-size:0.85rem;">(#@v.ClienteCodigoInterno.Value)</span>}
                                    @{
                                        var dir = !string.IsNullOrWhiteSpace(v.ClienteDomicilioEntrega) ? v.ClienteDomicilioEntrega : v.ClienteDireccion;
                                    }
                                    @if (!string.IsNullOrWhiteSpace(dir))
                                    {
                                        <div style="font-size: 0.82rem; color: #9ca3af; margin-top: 0.05rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 360px;" title="@dir">📍 @dir</div>
                                    }
                                    @* Tooltip con detalle del comprobante. Aparece al hacer hover. *@
                                    <div class="venta-tooltip">
                                        <div style="font-weight: 700; color: #1f2937; margin-bottom: 0.4rem; padding-bottom: 0.3rem; border-bottom: 1px solid #e5e7eb;">
                                            @v.Numero — @(v.ClienteNombre ?? "Sin cliente")
                                        </div>
                                        @if (v.Items is not null && v.Items.Count > 0)
                                        {
                                            <div style="font-size: 0.7rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.2rem;">Productos</div>
                                            <table style="width: 100%; font-size: 0.82rem; border-collapse: collapse;">
                                                <thead>
                                                    <tr style="border-bottom: 1px solid #e5e7eb;">
                                                        <th style="text-align: left; padding: 0.2rem; font-weight: 600; color: #6b7280;">Producto</th>
                                                        <th style="text-align: center; padding: 0.2rem; font-weight: 600; color: #6b7280;">Cant</th>
                                                        <th style="text-align: right; padding: 0.2rem; font-weight: 600; color: #6b7280;">Subtot</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                @foreach (var it in v.Items)
                                                {
                                                    <tr>
                                                        <td style="padding: 0.2rem; line-height: 1.2;">@it.ProductoNombre <span style="color: #9ca3af; font-size: 0.72rem;">@FormatoLabel(it.Formato)</span></td>
                                                        <td style="text-align: center; padding: 0.2rem; font-family: monospace;">@it.Cantidad</td>
                                                        <td style="text-align: right; padding: 0.2rem; font-family: monospace;">$@FormatMoney(it.Subtotal)</td>
                                                    </tr>
                                                }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <div style="color: #9ca3af; font-style: italic; font-size: 0.8rem;">Sin items</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(v.Observaciones))
                                        {
                                            <div style="margin-top: 0.5rem; padding-top: 0.3rem; border-top: 1px solid #e5e7eb;">
                                                <div style="font-size: 0.7rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em;">Observaciones</div>
                                                <div style="font-size: 0.78rem; color: #4b5563; white-space: pre-wrap;">@v.Observaciones</div>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (v.ClienteTipo == "BAR")
                                    {
                                        <span style="display:inline-block; padding:0.1rem 0.45rem; background:#dbeafe; color:#1e40af; border-radius:999px; font-size:0.7rem; font-weight:700;">🍺 BAR</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.1rem 0.45rem; background:#dcfce7; color:#166534; border-radius:999px; font-size:0.7rem; font-weight:700;">🏢 Comercial</span>
                                    }
                                </td>
                                <td style="text-align: right; font-weight: 800;">
                                    @{
                                        // Total cobrable: si la factura tiene CAE, usamos el total CON IVA (ArcaImpTotal).
                                        // Sino el Total neto (cotizaciones y proformas sin IVA discriminado).
                                        var totalCobrable = (v.ArcaImpTotal.HasValue && v.ArcaImpTotal.Value > 0m) ? v.ArcaImpTotal.Value : v.Total;
                                        var hayIva = totalCobrable > v.Total + 0.01m;
                                        var saldo = saldosPorVenta.TryGetValue(v.Id, out var s) ? s : totalCobrable;
                                        var pagado = totalCobrable - saldo;
                                    }
                                    <div style="font-size:1rem;">$@FormatMoney(totalCobrable)</div>
                                    @if (hayIva)
                                    {
                                        <div style="font-size:0.65rem; color:#6b7280; font-weight:500; margin-top:-0.1rem;" title="Neto sin IVA: $@FormatMoney(v.Total)">neto: $@FormatMoney(v.Total)</div>
                                    }
                                    @if (!anulada)
                                    {
                                        @if (saldo <= 0.01m)
                                        {
                                            <div style="font-size:0.7rem; color:#16a34a; font-weight:700; margin-top:0.15rem;">✅ Pagada</div>
                                        }
                                        else if (pagado > 0.01m)
                                        {
                                            <div style="font-size:0.7rem; color:#b45309; font-weight:700; margin-top:0.15rem;" title="Pagó $@FormatMoney(pagado) hasta ahora">⚠ Debe $@FormatMoney(saldo)</div>
                                        }
                                        else
                                        {
                                            <div style="font-size:0.7rem; color:#dc2626; font-weight:700; margin-top:0.15rem;">⏳ Pendiente</div>
                                        }
                                    }
                                </td>
                                <td style="text-align: right; color: @(v.Margen >= 0 ? "#15803d" : "#b91c1c");">$@FormatMoney(v.Margen)</td>
                                <td>
                                    @if (anulada)
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#fee2e2; color:#991b1b; border-radius:999px; font-size:0.7rem; font-weight:700;">❌ ANULADA</span>
                                    }
                                    else
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dcfce7; color:#166534; border-radius:999px; font-size:0.7rem; font-weight:700;">✅ EMITIDA</span>
                                    }
                                    @if (v.ArcaEstado == "autorizado")
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dbeafe; color:#1e40af; border-radius:999px; font-size:0.7rem; font-weight:700; margin-left:0.2rem;" title="@($"CAE {v.ArcaCae} · {(v.ArcaPtoVta ?? 0):00000}-{(v.ArcaCbteNro ?? 0):00000000}")">📜 CAE ✓</span>
                                    }
                                    else if (v.ArcaEstado == "pendiente")
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#fed7aa; color:#9a3412; border-radius:999px; font-size:0.7rem; font-weight:700; margin-left:0.2rem;" title="@v.ArcaError">⚠ ARCA pendiente</span>
                                    }
                                    @if (!string.IsNullOrEmpty(v.EstadoPreparacion))
                                    {
                                        var (icon, bg, fg, label) = PreparacionChip(v.EstadoPreparacion);
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:@bg; color:@fg; border-radius:999px; font-size:0.7rem; font-weight:700; margin-left:0.2rem;" title="Estado en el tablero de Preparación">@icon @label</span>
                                    }
                                    @if (!string.IsNullOrEmpty(v.EntregadoPorRepartidorNombre))
                                    {
                                        @* 2026-06-08: mostrar hora exacta de entrega al lado del nombre *@
                                        var horaEntrega = v.EntregadoAt?.ToLocalTime().ToString("HH:mm");
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dcfce7; color:#166534; border-radius:999px; font-size:0.7rem; font-weight:700; margin-left:0.2rem; cursor:pointer;"
                                              title="Entregado el @(v.EntregadoAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")). Tocá para desmarcar (admin)."
                                              @onclick="@(() => PedirDesmarcarEntrega(v))">
                                            ✅ Entregó @v.EntregadoPorRepartidorNombre@(horaEntrega is null ? "" : $" a las {horaEntrega} hs") ▼
                                        </span>
                                    }
                                    else if (!string.IsNullOrEmpty(v.EscaneadoPorRepartidorNombre))
                                    {
                                        @* 2026-06-05: chip "Lo tiene X" clickeable — click abre modal para reasignar o desvincular *@
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dbeafe; color:#1e40af; border-radius:999px; font-size:0.7rem; font-weight:700; margin-left:0.2rem; cursor:pointer;"
                                              title="Tocá para cambiar de repartidor o desvincular"
                                              @onclick="@(() => AbrirReasignar(v))">
                                            🚚 Lo tiene @v.EscaneadoPorRepartidorNombre ▼
                                        </span>
                                    }
                                    else if (!anulada)
                                    {
                                        @* 2026-06-05: chip "Asignar" gris cuando no hay nadie — click abre el mismo modal *@
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#f3f4f6; color:#6b7280; border-radius:999px; font-size:0.7rem; font-weight:700; margin-left:0.2rem; cursor:pointer; border:1px dashed #9ca3af;"
                                              title="Tocá para asignar a un repartidor"
                                              @onclick="@(() => AbrirReasignar(v))">
                                            🚚 Asignar ▼
                                        </span>
                                    }
                                    @* 2026-06-05: chip TRANSPORTE *@
                                    @if (v.PorTransporte)
                                    {
                                        var trTitle = string.IsNullOrWhiteSpace(v.TransporteEmpresa) && string.IsNullOrWhiteSpace(v.TransporteDestino)
                                            ? "Despacho por transporte"
                                            : $"Transporte: {v.TransporteEmpresa} · {v.TransporteDestino}".Trim().TrimEnd('·').Trim();
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#fed7aa; color:#9a3412; border-radius:999px; font-size:0.7rem; font-weight:800; margin-left:0.2rem;"
                                              title="@trTitle">
                                            🚛 TRANSPORTE
                                        </span>
                                    }
                                </td>
                                <td class="actions-cell">
                                    @{
                                        var saldoVenta = saldosPorVenta.TryGetValue(v.Id, out var sV) ? sV : v.Total;
                                        // 2026-06-06: ahora se puede cobrar venta sin cliente (ocasional). El backend acepta cobranza con
                                        // ClienteId null si la venta apuntada tampoco tiene cliente. Si la venta SI tiene cliente, va al
                                        // flujo normal de cobranzas; si NO, abre modal rápido inline.
                                        var puedeCobrar = !anulada && saldoVenta > 0.01m;
                                    }
                                    @* 3 botones siempre visibles: imprimir, cobrar, editar *@
                                    <button class="btn-icon" style="color: #1d4ed8;" @onclick="() => ShowPrint(v)" title="Ver / imprimir / PDF">🖨</button>
                                    @if (puedeCobrar)
                                    {
                                        @if (v.ClienteId.HasValue)
                                        {
                                            <button class="btn-icon" style="color: #059669;" @onclick='() => Navigation.NavigateTo($"/cafe/tesoreria/cobranzas?cliente={v.ClienteId!.Value}&venta={v.Id}")' title="Cobrar esta venta">💰</button>
                                        }
                                        else
                                        {
                                            <button class="btn-icon" style="color: #059669;" @onclick="() => AbrirCobroOcasional(v, saldoVenta)" title="Cobrar venta ocasional (sin cliente)">💰</button>
                                        }
                                    }
                                    else
                                    {
                                        <button class="btn-icon" style="color: #9ca3af; cursor: not-allowed;" disabled title="Sin saldo para cobrar">💰</button>
                                    }
                                    <button class="btn-icon btn-edit" @onclick="() => OpenEditModal(v)" title="Editar comprobante">✎</button>

                                    @* Boton subir/re-subir a Drive. Usa el logo OFICIAL de Drive (SVG inline).
                                       Color del icono segun cuantas veces se subio (DriveSubidasCount):
                                         - 0 (nunca subido):     logo en GRISES (apagado)
                                         - 1 (subido normal):    logo con sus COLORES NORMALES (azul/verde/amarillo)
                                         - 2+ (re-subido):       logo color normal + BADGE NARANJA con el numero arriba *@
                                    <button class="btn-icon"
                                            @onclick="() => SubirADrive(v)" disabled="@subiendoDrive"
                                            title="@(v.DriveSubidasCount == 0 ? "Subir a Drive" : v.DriveSubidasCount == 1 ? $"Re-subir a Drive (subido {v.DriveSubidoAt:dd/MM HH:mm})" : $"Re-subir a Drive ({v.DriveSubidasCount} subidas, último {v.DriveSubidoAt:dd/MM HH:mm})")"
                                            style="position:relative; padding:0.3rem;">
                                        <svg width="18" height="16" viewBox="0 0 87.3 78" xmlns="http://www.w3.org/2000/svg" style="@(v.DriveSubidasCount == 0 ? "filter: grayscale(100%); opacity: 0.45;" : "")">
                                            <path d="m6.6 66.85 3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3l13.75-23.8h-27.5c0 1.55.4 3.1 1.2 4.5z" fill="#0066da"/>
                                            <path d="m43.65 25-13.75-23.8c-1.35.8-2.5 1.9-3.3 3.3l-25.4 44c-.8 1.4-1.2 2.95-1.2 4.5h27.5z" fill="#00ac47"/>
                                            <path d="m73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5h-27.502l5.852 11.5z" fill="#ea4335"/>
                                            <path d="m43.65 25 13.75-23.8c-1.35-.8-2.9-1.2-4.5-1.2h-18.5c-1.6 0-3.15.45-4.5 1.2z" fill="#00832d"/>
                                            <path d="m59.8 53h-32.3l-13.75 23.8c1.35.8 2.9 1.2 4.5 1.2h50.8c1.6 0 3.15-.45 4.5-1.2z" fill="#2684fc"/>
                                            <path d="m73.4 26.5-12.7-22c-.8-1.4-1.95-2.5-3.3-3.3l-13.75 23.8 16.15 28h27.45c0-1.55-.4-3.1-1.2-4.5z" fill="#ffba00"/>
                                        </svg>
                                        @if (v.DriveSubidasCount >= 2)
                                        {
                                            <span style="position:absolute; top:-2px; right:-2px; background:#f97316; color:white; font-size:9px; font-weight:700; padding:1px 4px; border-radius:9px; line-height:1; min-width:14px; text-align:center;">@v.DriveSubidasCount</span>
                                        }
                                    </button>

                                    @* Boton "+" abre dropdown con el resto de las acciones *@
                                    <button id="@($"act-btn-{v.Id}")" class="btn-icon" style="color: #4b5563;"
                                            @onclick="() => ToggleActionsMenu(v.Id)" title="Más acciones">+</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* ═══════════════ POPUP "+" — RESTO DE LAS ACCIONES ═══════════════ *@
@if (actionsMenuOpenForVentaId.HasValue)
{
    var vMenu = VentasFiltradas.FirstOrDefault(x => x.Id == actionsMenuOpenForVentaId.Value);
    if (vMenu is not null)
    {
        var anuladaM = vMenu.Estado == "anulado";
        var tieneCaeM = !string.IsNullOrEmpty(vMenu.ArcaCae);
        var saldoM = saldosPorVenta.TryGetValue(vMenu.Id, out var sM) ? sM : 0m;
        <div class="actions-popup-overlay" @onclick="CloseActionsMenu"></div>
        <div id="@($"act-menu-{vMenu.Id}")" class="actions-popup" @onclick:stopPropagation="true">
            @if (!anuladaM && saldoM > 0.01m)
            {
                <button class="actions-popup-item" @onclick="() => { CloseActionsMenu(); DescargarReciboVisita(vMenu); }">
                    <span class="ic" style="color:#d97706;">🚪</span><span>Recibo de visita por cobranza</span>
                </button>
            }
            @if (string.IsNullOrEmpty(vMenu.EstadoPreparacion) && !anuladaM)
            {
                <button class="actions-popup-item" @onclick="() => { CloseActionsMenu(); EnviarAPreparacion(vMenu); }">
                    <span class="ic" style="color:#f59e0b;">📦</span><span>Enviar a Preparación</span>
                </button>
            }
            <button class="actions-popup-item" @onclick="() => { CloseActionsMenu(); DuplicarComprobante(vMenu); }">
                <span class="ic" style="color:#16a34a;">📋</span><span>Duplicar comprobante</span>
            </button>
            @if ((vMenu.TipoComprobante == "PRO" || vMenu.TipoComprobante == "X") && !vMenu.FacturadaComoVentaId.HasValue && vMenu.Estado != "anulado")
            {
                <button class="actions-popup-item" @onclick="() => { CloseActionsMenu(); OpenConvertirAFacturaModal(vMenu); }">
                    <span class="ic" style="color:#7c3aed;">📈</span><span>Convertir a factura (CAE ARCA)</span>
                </button>
            }
            else if (vMenu.FacturadaComoVentaId.HasValue)
            {
                <button class="actions-popup-item" disabled title="Ya convertida a factura #@vMenu.FacturadaComoVentaId">
                    <span class="ic" style="color:#16a34a;">✓</span><span>Ya convertida a factura</span>
                </button>
            }
            @if (!anuladaM && !tieneCaeM)
            {
                <button class="actions-popup-item" @onclick="() => { CloseActionsMenu(); ConfirmAnular(vMenu); }">
                    <span class="ic" style="color:#b45309;">⊘</span><span>Anular venta</span>
                </button>
            }
            else if (!anuladaM && tieneCaeM)
            {
                <button class="actions-popup-item" disabled title="Tiene CAE de ARCA — generá una Nota de Crédito.">
                    <span class="ic">⊘</span><span>Anular (no se puede con CAE)</span>
                </button>
                @* 2026-06-09: Emitir NC total — solo para facturas con CAE *@
                @if (vMenu.TipoComprobante is "FA" or "FB" or "FC")
                {
                    <button class="actions-popup-item" @onclick="() => { CloseActionsMenu(); EmitirNotaCredito(vMenu); }">
                        <span class="ic" style="color:#dc2626;">➖</span><span>Emitir Nota de Crédito (total)</span>
                    </button>
                }
            }
            else if (anuladaM)
            {
                <button class="actions-popup-item" style="color:#15803d;" @onclick="() => { CloseActionsMenu(); OpenRecuperarModal(vMenu); }">
                    <span class="ic" style="color:#15803d;">↺</span><span>@(CanDelete ? "Recuperar venta" : $"Recuperar (solo {(deleteSettings?.AllowedOperator ?? "OSMAR")})")</span>
                </button>
            }
            @if (!tieneCaeM)
            {
                <button class="actions-popup-item" style="color:#b91c1c;" @onclick="() => { CloseActionsMenu(); OpenDeleteModal(vMenu); }">
                    <span class="ic">🗑</span><span>@(CanDelete ? "Eliminar definitivamente" : $"Eliminar (solo {(deleteSettings?.AllowedOperator ?? "OSMAR")})")</span>
                </button>
            }
            else
            {
                <button class="actions-popup-item" disabled title="Tiene CAE de ARCA — generá una Nota de Crédito.">
                    <span class="ic">🗑</span><span>Eliminar (no se puede con CAE)</span>
                </button>
            }
        </div>
    }
}

@* ═══════════════ MODAL SELECCIÓN PEDIDO WHATSAPP ═══════════════ *@
@if (mostrarSelectorPedidoWA)
{
    <div class="modal-overlay" @onclick="CerrarSelectorPedidoWA" style="z-index: 9500 !important;">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 720px; width: 90vw; max-height: 85vh; display: flex; flex-direction: column;">
            <div class="modal-header" style="background:#25D366; color:white;">
                <h3 style="margin: 0;">💬 Pedidos de WhatsApp pendientes</h3>
                <button class="btn-close" @onclick="CerrarSelectorPedidoWA" style="color:white;">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y:auto;">
                @if (pedidosWADisponibles is null)
                {
                    <p class="text-muted">Cargando...</p>
                }
                else if (pedidosWADisponibles.Count == 0)
                {
                    <div style="text-align:center; padding:2rem; color:#6b7280;">
                        No hay pedidos pendientes.
                    </div>
                }
                else
                {
                    <p style="margin:0 0 0.6rem; font-size:0.85rem; color:#6b7280;">Click en uno para traerlo a la venta:</p>
                    @foreach (var p in pedidosWADisponibles)
                    {
                        <div class="pedido-wa-card"
                             @onclick="() => SeleccionarPedidoWA(p)">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.3rem;">
                                <strong style="font-size:0.88rem;">📞 @p.Telefono</strong>
                                <span style="color:#6b7280; font-size:0.78rem;">@p.RecibidoAt.ToLocalTime().ToString("dd/MM HH:mm")</span>
                            </div>
                            <pre style="background:#f9fafb; padding:0.5rem; border-radius:4px; font-size:0.82rem; margin:0; max-height:300px; overflow:auto; white-space:pre-wrap; word-wrap:break-word; font-family:'Menlo','Monaco',monospace;">@p.TextoCrudo</pre>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@* ═══════════════ SUB-VENTANA FLOTANTE WhatsApp ═══════════════ *@
@if (pedidoWASeleccionado is not null)
{
    <div id="cafe-wa-floating" class="cafe-wa-floating"
         style="left:@(pedidoWAPosX)px; top:@(pedidoWAPosY)px; width:@(pedidoWAWidth)px; height:@(pedidoWAHeight)px;">
        <div class="cafe-wa-floating-header" id="cafe-wa-floating-header">
            <span>💬 Pedido WhatsApp · 📞 @pedidoWASeleccionado.Telefono</span>
            <div style="display:flex; gap:0.3rem;">
                <button class="cafe-wa-floating-btn" @onclick="MinimizarSubventanaWA" title="@(subventanaWAMin ? "Restaurar" : "Minimizar")">
                    @(subventanaWAMin ? "▢" : "—")
                </button>
                <button class="cafe-wa-floating-btn" @onclick="CerrarSubventanaWA" title="Cerrar">✕</button>
            </div>
        </div>
        @if (!subventanaWAMin)
        {
            <div class="cafe-wa-floating-body">
                <pre style="background:transparent; color:#111827; padding:0; margin:0; font-family:'Menlo','Monaco',monospace; font-size:0.88rem; white-space:pre-wrap; word-wrap:break-word;">@pedidoWASeleccionado.TextoCrudo</pre>
            </div>
        }
    </div>
    <style>
        .cafe-wa-floating {
            position: fixed; z-index: 9400;
            background: #fefce8; border:2px solid #fde68a; border-radius:10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.25);
            display: flex; flex-direction: column;
            overflow: hidden; resize: both;
            min-width: 280px; min-height: 80px;
        }
        .cafe-wa-floating-header {
            background:#25D366; color:white; padding:0.45rem 0.7rem;
            font-weight:600; font-size:0.85rem;
            display:flex; justify-content:space-between; align-items:center;
            cursor:move; user-select:none;
        }
        .cafe-wa-floating-btn {
            background:transparent; border:none; color:white;
            cursor:pointer; padding:0.1rem 0.4rem; font-size:0.95rem; line-height:1;
        }
        .cafe-wa-floating-btn:hover { background:rgba(0,0,0,0.15); border-radius:3px; }
        .cafe-wa-floating-body {
            flex:1 1 auto; overflow:auto; padding:0.7rem 0.9rem;
        }
        /* Cards del selector de pedidos pendientes */
        .pedido-wa-card {
            border:1px solid #e5e7eb; border-radius:8px;
            padding:0.7rem; margin-bottom:0.5rem; cursor:pointer; background:white;
            transition: background 0.12s, border-color 0.12s, box-shadow 0.12s;
        }
        .pedido-wa-card:hover {
            background:#f0fdf4; border-color:#86efac;
            box-shadow:0 2px 8px rgba(34,197,94,0.15);
        }
    </style>
}

@* ═══════════════ MODAL NUEVA / EDITAR VENTA ═══════════════ *@
@if (showForm)
{
    @* IMPORTANTE: el modal-overlay NO cierra el form al clickear fuera.
       Antes tenía @onclick="CloseForm" y perdíamos cargas enteras al tocar accidentalmente fuera del card.
       Para cerrar: el ✕ del header o el botón Cancelar.
       2026-06-17: 3 modos — MAXIMIZADO (default, full screen menos sidebar), NORMAL (ventana 1280px),
       MINIMIZADO (chip flotante abajo a la derecha). *@
    @if (formModalMode != "MINIMIZADO")
    {
    <div class="modal-overlay" style="@(formModalMode == "MAXIMIZADO" ? "left: var(--sidebar-width, 220px); background: rgba(0,0,0,0.25);" : "")">
        <div class="modal-card" @onclick:stopPropagation="true" style="@(formModalMode == "MAXIMIZADO" ? "max-width: none; width: 100%; height: 100vh; max-height: 100vh; margin: 0; border-radius: 0; display: flex; flex-direction: column;" : "max-width: min(1280px, 96vw); width: 96vw; max-height: 94vh; display: flex; flex-direction: column;")">
            <div class="modal-header" style="background: @(editingVentaId.HasValue ? "#1d4ed8" : "whitesmoke"); color: @(editingVentaId.HasValue ? "white" : "inherit");">
                <h3 style="margin: 0;">
                    @if (editingVentaId.HasValue)
                    {
                        <span>✎ Editar comprobante @editingVentaNumero</span>
                    }
                    else if (!string.IsNullOrEmpty(duplicadoDeNumero))
                    {
                        <span>📋 Nueva Venta <span style="font-weight: 400; font-size: 0.85rem; color: #6b7280;">— duplicado de <strong style="color: #16a34a;">@duplicadoDeNumero</strong></span></span>
                    }
                    else
                    {
                        <span>🧾 Nueva Venta</span>
                    }
                </h3>
                <div style="display:flex; gap:0.4rem; align-items:center;">
                    @if (!editingVentaId.HasValue)
                    {
                        <button class="btn btn-secondary btn-sm" @onclick="AbrirSelectorPedidoWhatsApp"
                                style="background:#25D366; border-color:#25D366; color:white; font-weight:600;"
                                title="Traer un pedido recibido por WhatsApp y verlo en una ventana flotante mientras cargás la venta">
                            💬 Traer pedido WhatsApp@(pedidoWhatsAppCount > 0 ? $" ({pedidoWhatsAppCount})" : "")
                        </button>
                    }
                    @* 2026-06-17: controles de ventana — minimizar, maximizar/restaurar, cerrar *@
                    <button class="btn-close" @onclick="MinimizarModal" title="Minimizar (queda como chip flotante)"
                            style="@(editingVentaId.HasValue ? "color: white;" : "") font-size: 1.1rem;">─</button>
                    <button class="btn-close" @onclick="ToggleMaximizarModal"
                            title="@(formModalMode == "MAXIMIZADO" ? "Restaurar a ventana" : "Maximizar (pantalla completa)")"
                            style="@(editingVentaId.HasValue ? "color: white;" : "") font-size: 0.95rem;">
                        @(formModalMode == "MAXIMIZADO" ? "▢" : "□")
                    </button>
                    <button class="btn-close" @onclick="CloseForm" style="@(editingVentaId.HasValue ? "color: white;" : "")">&times;</button>
                </div>
            </div>
            <div class="modal-body" style="overflow-y: auto;">
                @* 2026-06-17 v3: el grid se rompia por un </div> huerfano dentro de la columna izq que cerraba
                   prematuramente al wrapper. Como hace dificil identificar el div faltante, usamos position absolute
                   para el panel derecho — la columna izq lleva padding-right para que no se solape. *@
                <div style="position: relative;">
                <div style="min-width: 0; padding-right: 360px;">
                @* Banner de borrador pendiente — aparece sólo si hay un auto-guardado de sesión previa *@
                @if (borradorBannerVisible && pendingBorrador is not null && !editingVentaId.HasValue)
                {
                    <div style="background:#fffbeb; border:2px solid #f59e0b; border-radius:8px; padding:0.7rem 1rem; margin-bottom:0.8rem; display:flex; align-items:center; gap:0.8rem; flex-wrap:wrap;">
                        <div style="font-size:1.4rem;">💾</div>
                        <div style="flex:1; min-width: 220px;">
                            <div style="font-weight:700; color:#78350f;">Tenés un borrador guardado</div>
                            <div style="font-size:0.82rem; color:#78350f;">
                                @if (!string.IsNullOrWhiteSpace(pendingBorrador.ClienteNombreSnap))
                                {
                                    <span><strong>@pendingBorrador.ClienteNombreSnap</strong> · </span>
                                }
                                <span>@pendingBorrador.ItemsCount producto@(pendingBorrador.ItemsCount == 1 ? "" : "s")</span>
                                @if (pendingBorrador.TotalCalc > 0)
                                {
                                    <span> · Total: $@pendingBorrador.TotalCalc.ToString("N2")</span>
                                }
                                <span> · Guardado @(((int)(DateTime.UtcNow - pendingBorrador.SavedAt).TotalMinutes)) min atrás</span>
                            </div>
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="CargarBorradorAsync">📂 Cargar borrador</button>
                        <button class="btn btn-secondary btn-sm" @onclick="DiscardBorradorAsync" style="background:#fee2e2; color:#991b1b; border-color:#fca5a5;">🗑 Descartar</button>
                        <button class="btn btn-secondary btn-sm" @onclick="@(() => { borradorBannerVisible = false; })">✕ Ignorar</button>
                    </div>
                }
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                @* 2026-06-17: ① y ② lado a lado cuando NO esta en Venta Rapida (que ocupa todo el ancho con sus campos extra).
                   En Venta Rapida se apilan como antes para que entren bien los campos manuales del cliente. *@
                <div style="display: flex; gap: 1.5rem; flex-direction: @(modoVentaRapida ? "column" : "row"); align-items: flex-start;">
                @* ── Datos generales ── *@
                @* 2026-06-17: bloque compactado — sin caja, header chiquito, padding reducido.
                   2026-06-17 v3: flex 0.9 para no robarle aire al bloque Cliente. *@
                <div style="padding: 0.3rem 0; margin-bottom: 0.4rem; flex: 0.9; min-width: 0;">
                    <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
                        <strong style="font-size: 0.78rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;">Datos generales</strong>
                    </div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">Tipo de comprobante *</label>
                            <select class="form-input" @bind="formTipoComprobante" @bind:after="OnTipoComprobanteChanged" disabled="@modoVentaRapida">
                                <option value="X">X — Cotización / Remito interno (sin IVA)</option>
                                <option value="PRO">📋 PRESUPUESTO — Proforma con IVA (NO descuenta stock)</option>
                                <option value="FA">Factura A — emite por ARCA (con CAE)</option>
                                <option value="FB">Factura B — emite por ARCA (con CAE)</option>
                                @* Factura C es para monotributistas — PALANICA es Responsable Inscripto, no aplica.
                                   Si en el futuro hay un CUIT MO, se vuelve a habilitar segun NegocioCondicionIva. *@
                            </select>
                            @if (modoVentaRapida)
                            {
                                <p style="font-size: 0.7rem; color: #d97706; margin: 0.2rem 0 0;">⚡ En Venta Rápida solo se emite Remito interno (X).</p>
                            }
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Condición IVA del cliente</label>
                            <select class="form-input" @bind="formCondicionIva">
                                <option value="CF">Consumidor final</option>
                                <option value="RI">Responsable Inscripto</option>
                                <option value="MO">Monotributo</option>
                                <option value="EX">Exento</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Condición de pago</label>
                            <select class="form-input" @bind="formCondicionPago">
                                <option value="EFECTIVO">Efectivo</option>
                                <option value="TRANSFERENCIA">Transferencia</option>
                                <option value="MERCADOPAGO">Mercado Pago</option>
                                <option value="DEBITO">Tarjeta de débito</option>
                                <option value="CREDITO">Tarjeta de crédito</option>
                                <option value="CTA_CORRIENTE">Cuenta corriente</option>
                                <option value="CHEQUE">Cheque</option>
                                <option value="V_PRIVADO">*V********</option>
                            </select>
                        </div>
                        @* 2026-06-17: Fecha movida acá (antes estaba en el bloque Cliente y fecha). *@
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Fecha</label>
                            <input class="form-input" type="date" @bind="formFecha" />
                        </div>
                    </div>
                </div>

                @* ── Cliente y fecha ── *@
                @* 2026-06-17: bloque compactado — sin caja, header chiquito. Lado a lado con ① cuando no es Venta Rapida. *@
                <div style="padding: 0.3rem 0; margin-bottom: 0.4rem; flex: 1.5; min-width: 0; @(modoVentaRapida ? "border-top: 1px solid #f3f4f6;" : "")">
                    <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem; flex-wrap: wrap;">
                        <strong style="font-size: 0.78rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;">Cliente y fecha</strong>
                        <div style="margin-left: auto; display: flex; gap: 0.3rem;">
                            @if (!modoVentaRapida)
                            {
                                <button type="button" class="btn btn-secondary" style="font-size: 0.78rem; padding: 0.25rem 0.6rem; background:#fef3c7; border-color:#d97706; color:#78350f;"
                                        @onclick="ActivarVentaRapida"
                                        title="Cargar datos del cliente a mano (sin elegir del catálogo). Ideal para ventas eventuales / sin cliente fijo. Solo emite Remito interno (X).">
                                    ⚡ Venta rápida
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary" style="font-size: 0.78rem; padding: 0.25rem 0.6rem;"
                                        @onclick="DesactivarVentaRapida"
                                        title="Volver al buscador de clientes del catálogo.">
                                    🔍 Volver a elegir cliente
                                </button>
                            }
                        </div>
                    </div>
                    @if (modoVentaRapida)
                    {
                        <div style="background: #fffbeb; border: 1px dashed #d97706; border-radius: 6px; padding: 0.5rem 0.7rem; margin-bottom: 0.5rem; font-size: 0.78rem; color: #78350f;">
                            ⚡ <strong>Modo Venta Rápida</strong> — los datos se guardan SOLO en esta venta, no se crea un cliente nuevo. Solo emite <strong>X (Remito interno)</strong>.
                        </div>
                        <div class="form-row">
                            <div class="form-group" style="flex: 2;">
                                <label class="form-label">Nombre / Razón social *</label>
                                <input class="form-input" type="text" @bind="vrNombre" placeholder="Ej: Juan Pérez · CONSUMIDOR FINAL · Kiosko de la esquina..." />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Tipo</label>
                                <select class="form-input" @bind="formClienteTipo" @bind:after="Cotizar">
                                    <option value="OTRO">🏢 Comercial</option>
                                    <option value="BAR">🍺 BAR</option>
                                </select>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Fecha</label>
                                <input class="form-input" type="date" @bind="formFecha" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">CUIT / DNI</label>
                                <input class="form-input" type="text" @bind="vrCuit" placeholder="20-12345678-9" />
                            </div>
                            <div class="form-group" style="flex: 2;">
                                <label class="form-label">Domicilio</label>
                                <input class="form-input" type="text" @bind="vrDireccion" placeholder="Calle 123, piso, depto..." />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Localidad</label>
                                <input class="form-input" type="text" @bind="vrLocalidad" placeholder="Ej: Berazategui" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">CP</label>
                                <input class="form-input" type="text" @bind="vrCp" placeholder="1880" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Teléfono</label>
                                <input class="form-input" type="text" @bind="vrTelefono" placeholder="11 1234-5678" />
                            </div>
                            <div class="form-group" style="flex: 2;">
                                <label class="form-label">Domicilio de entrega (si difiere)</label>
                                <input class="form-input" type="text" @bind="vrDomicilioEntrega" placeholder="Solo si entregás en otra dirección" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Razón social</label>
                                <input class="form-input" type="text" @bind="vrRazonSocial" placeholder="Si difiere del nombre" />
                            </div>
                        </div>
                    }
                    else
                    {
                    <div class="form-row">
                        <div class="form-group" style="flex: 2; position: relative;">
                            <label class="form-label">Cliente</label>
                            @if (formClienteId > 0)
                            {
                                var ciSel = clientes?.FirstOrDefault(x => x.Id == formClienteId);
                                var dirSel = ciSel is null ? null : (!string.IsNullOrWhiteSpace(ciSel.DomicilioEntrega) ? ciSel.DomicilioEntrega : ciSel.Direccion);
                                var locSel = ciSel is null ? null : string.Join(" · ", new[] { ciSel.Localidad, ciSel.Ciudad, ciSel.Cp }.Where(x => !string.IsNullOrWhiteSpace(x)));
                                @* 2026-06-17: cliente seleccionado compactado en 1-2 lineas con padding y fonts mas chicos. *@
                                <div style="display: flex; gap: 0.3rem; align-items: stretch;">
                                    <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; flex-direction: column; gap: 0.1rem; padding: 0.3rem 0.55rem; height: auto;">
                                        <div style="display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; line-height: 1.15;">
                                            <span style="font-family: monospace; font-weight: 700; color: #1d4ed8; font-size: 0.82rem;">@(ciSel?.Codigo ?? "—")</span>
                                            <strong style="font-size: 0.88rem;">@(ciSel?.Nombre ?? "?")</strong>
                                            @if (ciSel is not null)
                                            {
                                                <span style="font-size: 0.7rem; color: #6b7280;">· @ciSel.Tipo</span>
                                                @if (!string.IsNullOrEmpty(ciSel.Cuit)) { <span style="font-size: 0.7rem; color: #6b7280;">· @ciSel.Cuit</span> }
                                                @if (!string.IsNullOrEmpty(ciSel.Telefono)) { <span style="font-size: 0.7rem; color: #6b7280;">· 📞 @ciSel.Telefono</span> }
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(dirSel) || !string.IsNullOrWhiteSpace(locSel))
                                        {
                                            <div style="font-size: 0.72rem; color: #6b7280; line-height: 1.15;">
                                                @if (!string.IsNullOrWhiteSpace(dirSel)) { <span>📍 @dirSel</span> }
                                                @if (!string.IsNullOrWhiteSpace(dirSel) && !string.IsNullOrWhiteSpace(locSel)) { <span> · </span> }
                                                @if (!string.IsNullOrWhiteSpace(locSel)) { <span>@locSel</span> }
                                            </div>
                                        }
                                    </div>
                                    @* 2026-06-18 v2: editar el cliente en ventana emergente — usa el modal completo de /cafe/clientes
                                       con TODOS los campos (codigo interno, padron AFIP, notas, mapeo, etc). *@
                                    <button class="btn btn-secondary" type="button" @onclick="() => AbrirEditarClienteVentana(ciSel)"
                                            title="Editar este cliente (abre ventana emergente, no cierra la venta)"
                                            style="padding: 0 0.55rem; font-size: 0.85rem; color: #1d4ed8;">✏️</button>
                                    <button class="btn btn-secondary" type="button" @onclick="ClearCliente" title="Quitar cliente" style="padding: 0 0.5rem; font-size: 0.85rem;">×</button>
                                </div>
                                @* 2026-06-02: Post-it amarillo SIEMPRE VISIBLE con las "Notas internas" del cliente.
                                   Solo aparece si el cliente tiene algo cargado en ese campo. NO sale en el PDF.
                                   Pedido del usuario: que se vea mientras carga la venta sin tener que tocar nada. *@
                                @* 2026-06-17: notas internas compactas — max-height + scroll para que no ocupen toda la pantalla. *@
                                @if (ciSel is not null && !string.IsNullOrWhiteSpace(ciSel.Notas))
                                {
                                    <div style="background: #fefce8; border: 1px dashed #facc15; border-radius: 6px; padding: 0.35rem 0.6rem;
                                                margin-top: 0.4rem; font-size: 0.78rem; color: #713f12; line-height: 1.35;
                                                white-space: pre-wrap; word-break: break-word; max-height: 80px; overflow-y: auto;">
                                        <div style="font-size: 0.68rem; color: #92400e; font-weight: 700; text-transform: uppercase; margin-bottom: 0.15rem;">📌 Notas del cliente <span style="font-weight:400; opacity:0.7;">(solo vos las ves)</span></div>
                                        @ciSel.Notas
                                    </div>
                                }
                            }
                            else
                            {
                                <input id="nv-cliente" class="form-input" @bind="clienteSearch" @bind:event="oninput"
                                       @onfocus="() => clienteSearchOpen = true"
                                       @onkeydown="OnKeyDownCliente"
                                       placeholder="🔍 Buscar por código, nombre, CUIT, tel, email, dirección, localidad, CP… (Enter para seguir)" />
                                @if (clienteSearchOpen && !string.IsNullOrWhiteSpace(clienteSearch))
                                {
                                    var matches = ClientesMatching(clienteSearch).Take(20).ToList();
                                    <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 420px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                        @if (matches.Count == 0)
                                        {
                                            @* 2026-06-18: si no hay resultados, ofrecer crear el cliente con lo tipeado como nombre. *@
                                            <div style="padding: 0.7rem 0.9rem; background: #fef3c7; border-left: 3px solid #f59e0b; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; flex-wrap: wrap;">
                                                <div style="font-size: 0.85rem; color: #78350f;">😕 Sin resultados para "<strong>@clienteSearch</strong>"</div>
                                                <button class="btn btn-primary" type="button" style="background: #d97706; border-color: #b45309; font-size: 0.82rem; padding: 0.35rem 0.7rem; display: inline-flex; align-items: center; gap: 0.3rem;"
                                                        @onclick="() => AbrirCrearClienteVentana(clienteSearch)">
                                                    ➕ Crear cliente nuevo
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            @foreach (var ci in matches)
                                            {
                                                var ciId = ci.Id;
                                                var dirCi = !string.IsNullOrWhiteSpace(ci.DomicilioEntrega) ? ci.DomicilioEntrega : ci.Direccion;
                                                var locCi = string.Join(" · ", new[] { ci.Localidad, ci.Ciudad, ci.Cp }.Where(x => !string.IsNullOrWhiteSpace(x)));
                                                <div class="cli-pick-row" @onclick="() => SelectCliente(ciId)"
                                                     style="padding: 0.55rem 0.75rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; line-height: 1.25;">
                                                    <div style="display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;">
                                                        <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; font-size: 0.9rem;">@ci.Codigo</span>
                                                        <strong style="font-size: 0.95rem;">@ci.Nombre</strong>
                                                        <span style="color: #6b7280; font-size: 0.75rem;">· @ci.Tipo</span>
                                                        @if (!string.IsNullOrEmpty(ci.Cuit))
                                                        {
                                                            <span style="color: #6b7280; font-size: 0.75rem;">· @ci.Cuit</span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(ci.Telefono))
                                                        {
                                                            <span style="color: #6b7280; font-size: 0.75rem;">· 📞 @ci.Telefono</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(dirCi) || !string.IsNullOrWhiteSpace(locCi))
                                                    {
                                                        <div style="color: #9ca3af; font-size: 0.78rem; margin-top: 0.1rem;">
                                                            @if (!string.IsNullOrWhiteSpace(dirCi)) { <span>📍 @dirCi</span> }
                                                            @if (!string.IsNullOrWhiteSpace(dirCi) && !string.IsNullOrWhiteSpace(locCi)) { <span> · </span> }
                                                            @if (!string.IsNullOrWhiteSpace(locCi)) { <span>@locCi</span> }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                        </div>
                        @* 2026-06-17 v2: dropdown grande de Tipo eliminado — ahora es un chip mini al lado del saldo deudor.
                           Si NO hay cliente seleccionado (consumidor final), mostramos el selector chico para que se pueda elegir BAR/Comercial. *@
                        @if (formClienteId == 0)
                        {
                            <div class="form-group" style="flex: 0 0 150px;">
                                <label class="form-label" style="font-size: 0.75rem;">Tipo (consumidor final)</label>
                                <select class="form-input" @bind="formClienteTipo" @bind:after="Cotizar" style="font-size: 0.85rem; padding: 0.3rem 0.5rem;">
                                    <option value="OTRO">🏢 Comercial</option>
                                    <option value="BAR">🍺 BAR</option>
                                </select>
                            </div>
                        }
                    </div>
                    }

                    @* 2026-06-17 v2: chips Tipo + Saldo en una sola línea. Tipo se muestra siempre que haya cliente seleccionado;
                       Saldo solo si tiene deudas. *@
                    @if (formClienteId > 0)
                    {
                        <div style="margin-top: 0.4rem; display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center;">
                            @* 2026-06-17 v3: chip mas sutil — fondo blanco con borde de color, no compite con "Debe" *@
                            <span style="display: inline-flex; align-items: center; padding: 0.2rem 0.55rem;
                                         background: white;
                                         border: 1px solid @(formClienteTipo == "BAR" ? "#93c5fd" : "#a7f3d0");
                                         border-radius: 999px;
                                         color: @(formClienteTipo == "BAR" ? "#1e40af" : "#047857");
                                         font-size: 0.72rem; font-weight: 600;"
                                  title="Tipo del cliente">
                                @(formClienteTipo == "BAR" ? "🍺 BAR" : "🏢 Comercial")
                            </span>
                            @if (unpaidPrevSales.Count > 0)
                            {
                            <div @onclick="@(() => saldoAnteriorExpandido = !saldoAnteriorExpandido)"
                                 style="display: inline-flex; align-items: center; gap: 0.4rem; cursor: pointer;
                                        padding: 0.25rem 0.6rem; background: #fef3c7; border: 1px solid #d97706;
                                        border-radius: 999px; color: #78350f; font-size: 0.78rem; user-select: none;">
                                <span style="font-weight: 700;">⚠ Debe $@FormatMoney(UnpaidPrevTotal)</span>
                                <span style="opacity: 0.85;">· @unpaidPrevSales.Count cbte@(unpaidPrevSales.Count == 1 ? "" : "s")</span>
                                <span style="font-size: 0.7rem; margin-left: 0.2rem;">@(saldoAnteriorExpandido ? "▴" : "▾")</span>
                            </div>
                            }
                            @if (saldoAnteriorExpandido)
                            {
                                <div style="margin-top: 0.35rem; padding: 0.4rem 0.6rem; background: #fffbeb; border: 1px solid #fcd34d; border-radius: 6px; color: #78350f; font-size: 0.78rem;">
                                    @foreach (var s in unpaidPrevSales)
                                    {
                                        var sld = saldosPorVenta.TryGetValue(s.Id, out var sl) ? sl : s.Total;
                                        var pag = s.Total - sld;
                                        var tooltipText = s.Fecha.ToString("dd/MM/yyyy") + " · Total $" + FormatMoney(s.Total) + (pag > 0.01m ? " · Pagado $" + FormatMoney(pag) : "");
                                        <span style="display: inline-block; margin-right: 0.4rem; margin-bottom: 0.2rem; padding: 0.1rem 0.4rem; background: white; border: 1px solid #d97706; border-radius: 4px; font-family: monospace;"
                                              title="@tooltipText">
                                            @s.Numero (debe $@FormatMoney(sld))
                                        </span>
                                    }
                                    <label style="display: flex; align-items: center; gap: 0.35rem; margin-top: 0.35rem; cursor: pointer;">
                                        <input type="checkbox" @bind="includePrevBalanceInNotes" style="margin: 0;" />
                                        Incluir "Saldo anterior" en las observaciones del comprobante
                                    </label>
                                </div>
                            }
                        </div>
                    }
                </div>
                @* ── ③ ENTREGA + COMENTARIO ARMADO ── *@
                @* 2026-06-17 v2: 3a columna del header. Antes vivían en el panel sticky derecho.
                   No se muestra en modo Venta Rápida (en ese flujo el wrapper es column). *@
                @if (!modoVentaRapida)
                {
                <div style="flex: 1.25; min-width: 0; display: flex; flex-direction: column; gap: 0.7rem;">

                    @* Entrega *@
                    <div style="padding: 0.7rem 0.85rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; display: flex; flex-direction: column; gap: 0.55rem;">
                        <strong style="font-size: 0.78rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;">🚚 Entrega</strong>

                        <div>
                            <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">Días de visita / reparto</label>
                            <div style="display: flex; gap: 0.25rem; flex-wrap: wrap; margin-top: 0.3rem;">
                                @foreach (var d in AllWeekDays)
                                {
                                    var onH = formWeekDays.Contains(d);
                                    var bgH = onH ? "#dbeafe" : "white";
                                    var fgH = onH ? "#1e3a8a" : "#374151";
                                    var bdH = onH ? "#1e40af" : "#d1d5db";
                                    <button type="button" @onclick="() => ToggleFormDay(d)"
                                            style="padding: 0.3rem 0.5rem; border: 1px solid @bdH; background: @bgH; color: @fgH; border-radius: 5px; font-weight: 700; font-size: 0.72rem; cursor: pointer; min-width: 36px;">@(onH ? "✓" : "")@d</button>
                                }
                            </div>
                        </div>

                        <div style="display: flex; gap: 0.35rem; flex-wrap: wrap;">
                            @{
                                var radarBgH = formEnRadar ? "#1d4ed8" : "white";
                                var radarFgH = formEnRadar ? "white" : "#374151";
                                var retiraBgH = formRetira ? "#16a34a" : "white";
                                var retiraFgH = formRetira ? "white" : "#374151";
                                var trBgH = formPorTransporte ? "#ea580c" : "white";
                                var trFgH = formPorTransporte ? "white" : "#374151";
                            }
                            <button type="button" @onclick="ToggleEnRadar" title="El cliente ve 'a coordinar'"
                                    style="padding: 0.3rem 0.65rem; border: 1px solid #1e3a8a; background: @radarBgH; color: @radarFgH; border-radius: 5px; font-weight: 700; font-size: 0.72rem; cursor: pointer;">@(formEnRadar ? "✓ " : "")🛰 RADAR</button>
                            <button type="button" @onclick="ToggleRetira" title="Retira en local"
                                    style="padding: 0.3rem 0.65rem; border: 1px solid #15803d; background: @retiraBgH; color: @retiraFgH; border-radius: 5px; font-weight: 700; font-size: 0.72rem; cursor: pointer;">@(formRetira ? "✓ " : "")🚗 RETIRA</button>
                            <button type="button" @onclick="ToggleTransporte" title="Por empresa de transporte"
                                    style="padding: 0.3rem 0.65rem; border: 1px solid #c2410c; background: @trBgH; color: @trFgH; border-radius: 5px; font-weight: 700; font-size: 0.72rem; cursor: pointer;">@(formPorTransporte ? "✓ " : "")🚛 TRANSPORTE</button>
                        </div>

                        @if (formPorTransporte)
                        {
                            <div style="background:#fff7ed; border:1px solid #fdba74; border-radius:6px; padding:0.45rem; display: flex; gap: 0.35rem; flex-direction: column;">
                                <input class="form-input" @bind="formTransporteEmpresa" placeholder="Empresa (Andreani, Cruz del Sur…)" style="font-size: 0.8rem; padding: 0.3rem 0.5rem;" />
                                <input class="form-input" @bind="formTransporteDestino" placeholder="Destino (ciudad/sucursal)" style="font-size: 0.8rem; padding: 0.3rem 0.5rem;" />
                            </div>
                        }

                        <div>
                            <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600; text-transform: uppercase;">Entrega por</label>
                            <select class="form-input" @bind="formEntregaPor" style="font-size: 0.85rem; padding: 0.3rem 0.5rem; margin-top: 0.25rem;">
                                <option value="">— sin asignar —</option>
                                @foreach (var nom in EntregaResponsables)
                                {
                                    <option value="@nom">@nom</option>
                                }
                                <option value="Logística tercerizada">📦 Logística tercerizada</option>
                            </select>
                        </div>

                        @if (editingVentaId.HasValue && saldosPorVenta.TryGetValue(editingVentaId.Value, out var saldoEditH))
                        {
                            var totalEditH = ventas?.FirstOrDefault(v => v.Id == editingVentaId.Value)?.Total ?? 0m;
                            var pagadoEditH = totalEditH - saldoEditH;
                            <div style="padding: 0.5rem 0.65rem; border-radius:6px; background: @(saldoEditH <= 0.01m ? "#dcfce7" : pagadoEditH > 0.01m ? "#fef3c7" : "#fee2e2"); font-size: 0.82rem;">
                                @if (saldoEditH <= 0.01m) { <strong style="color:#166534;">✅ PAGADA</strong> }
                                else if (pagadoEditH > 0.01m) { <strong style="color:#92400e;">⚠ Pagó $@FormatMoney(pagadoEditH), debe $@FormatMoney(saldoEditH)</strong> }
                                else { <strong style="color:#991b1b;">⏳ Sin cobranzas · saldo $@FormatMoney(saldoEditH)</strong> }
                            </div>
                        }
                        else if (!editingVentaId.HasValue)
                        {
                            <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.85rem; padding: 0.4rem 0; border-top: 1px solid #e5e7eb; margin-top: 0.2rem;">
                                <input type="checkbox" @bind="formIsPaid" />
                                <strong>💰 Cobrar al guardar</strong>
                            </label>
                        }
                    </div>

                    @* Comentario para armado *@
                    <div style="padding: 0.7rem 0.85rem; background: #fefce8; border: 2px dashed #facc15; border-radius: 10px;">
                        <div style="display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.4rem;">
                            <span style="font-size: 1rem;">📌</span>
                            <strong style="font-size: 0.78rem; color: #92400e; text-transform: uppercase; letter-spacing: 0.04em;">Comentario para armado</strong>
                        </div>
                        <textarea class="form-input" rows="2" @bind="formComentarioArmado"
                                  placeholder="Ej: SOBRES CORTESIA"
                                  style="background: white; font-size: 0.85rem; resize: vertical; width: 100%; padding: 0.4rem 0.55rem; border-radius: 6px;"></textarea>
                        <div style="font-size: 0.66rem; color: #78716c; margin-top: 0.3rem; font-style: italic;">Solo lo ve quien arma el pedido. No sale al cliente.</div>
                    </div>
                </div>
                }
                </div> @* fin wrapper flex ① + ② + ③ *@

                @* ── Items ── *@
                @* 2026-06-17: bloque compactado — sin caja, header chico. *@
                <div style="padding: 0.3rem 0; margin-bottom: 0.4rem; border-top: 1px solid #f3f4f6;">
                    <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
                        <strong style="font-size: 0.78rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;">Productos a vender</strong>
                    </div>

                    @* 2026-06-17: la seccion "productos mas comprados" se movio al panel sticky de la derecha — ver final del modal-body *@

                    @* Selector Producto / Combo / Concepto libre *@
                    <div style="display: inline-flex; gap: 0; margin-bottom: 0.5rem; border: 1px solid #d1d5db; border-radius: 6px; overflow: hidden;">
                        <button type="button"
                                class="btn"
                                style="border: none; border-radius: 0; padding: 0.35rem 0.8rem; font-size: 0.82rem; @(addMode == "PRODUCTO" ? "background:#1d4ed8;color:white;" : "background:white;color:#374151;")"
                                @onclick="@(() => addMode = "PRODUCTO")">
                            📦 Producto
                        </button>
                        <button type="button"
                                class="btn"
                                style="border: none; border-radius: 0; padding: 0.35rem 0.8rem; font-size: 0.82rem; @(addMode == "COMBO" ? "background:#1d4ed8;color:white;" : "background:white;color:#374151;")"
                                @onclick="@(() => addMode = "COMBO")">
                            🎁 Combo
                        </button>
                        <button type="button"
                                class="btn"
                                style="border: none; border-radius: 0; padding: 0.35rem 0.8rem; font-size: 0.82rem; @(addMode == "SERVICIO" ? "background:#7c3aed;color:white;" : "background:white;color:#374151;")"
                                @onclick="@(async () => { addMode = "SERVICIO"; await CargarServiciosSiHaceFalta(); })"
                                title="Servicio del catálogo (envío, mano de obra, instalación, etc). No descuenta stock.">
                            🛠 Servicio
                        </button>
                        <button type="button"
                                class="btn"
                                style="border: none; border-radius: 0; padding: 0.35rem 0.8rem; font-size: 0.82rem; @(addMode == "LIBRE" ? "background:#1d4ed8;color:white;" : "background:white;color:#374151;")"
                                @onclick="@(() => addMode = "LIBRE")"
                                title="Item con descripción y precio cargados a mano, sin producto del catálogo">
                            ✏️ Concepto libre
                        </button>
                    </div>

                    @if (addMode == "SERVICIO")
                    {
                        <div class="form-row" style="align-items: end;">
                            <div class="form-group" style="flex: 3;">
                                <label class="form-label" style="font-size: 0.75rem;">Servicio *</label>
                                @if (catalogoServicios is null)
                                {
                                    <input class="form-input" disabled placeholder="Cargando catálogo..." />
                                }
                                else if (catalogoServicios.Count == 0)
                                {
                                    <div style="padding:0.4rem; border:1px dashed #d1d5db; border-radius:4px; font-size:0.78rem; color:#6b7280;">
                                        No hay servicios cargados.
                                        <a href="/cafe/servicios" target="_blank" style="color:#7c3aed; font-weight:600;">Crear ahora →</a>
                                    </div>
                                }
                                else
                                {
                                    <select class="form-input" @bind="addServicioId">
                                        <option value="0">-- Elegir servicio --</option>
                                        @foreach (var s in catalogoServicios.OrderBy(x => x.Nombre))
                                        {
                                            <option value="@s.Id">@s.Nombre — $@s.Precio.ToString("N2")</option>
                                        }
                                    </select>
                                }
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Precio U. sin IVA</label>
                                <input class="form-input" type="number" step="0.01" min="0" @bind="addServicioPrecio"
                                       placeholder="(usa precio del catálogo)" title="Dejar vacío usa el precio del catálogo. Cargar acá lo pisa." />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Cant.</label>
                                <input class="form-input" type="number" min="1" @bind="addServicioCantidad" placeholder="1" />
                            </div>
                            <div class="form-group" style="flex: 0 0 auto;">
                                <button type="button" class="btn btn-primary" style="background:#7c3aed; border-color:#7c3aed;"
                                        @onclick="AddItemServicio"
                                        disabled="@(addServicioId <= 0 || addServicioCantidad < 1)">
                                    + Agregar
                                </button>
                            </div>
                        </div>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.25rem 0 0;">
                            💡 No descuenta stock. Se cobra como item adicional. Si dejás el precio vacío, usa el del catálogo.
                            <a href="/cafe/servicios" target="_blank" style="color:#7c3aed;">Administrar servicios →</a>
                        </p>
                    }

                    @if (addMode == "LIBRE")
                    {
                        <div class="form-row" style="align-items: end;">
                            <div class="form-group" style="flex: 3;">
                                <label class="form-label" style="font-size: 0.75rem;">Descripción *</label>
                                <input class="form-input" @bind="addLibreDescripcion"
                                       placeholder="Ej: Servicio de delivery / Capacitación / Honorarios..." />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Precio U. sin IVA *</label>
                                <input class="form-input" type="number" step="0.01" min="0" @bind="addLibrePrecio" placeholder="0,00" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label" style="font-size: 0.75rem;">Cant.</label>
                                <input class="form-input" type="number" min="1" @bind="addLibreCantidad" placeholder="1" />
                            </div>
                            <div class="form-group" style="flex: 0 0 auto;">
                                <button type="button" class="btn btn-primary" @onclick="AddItemLibre"
                                        disabled="@(string.IsNullOrWhiteSpace(addLibreDescripcion) || addLibrePrecio <= 0 || addLibreCantidad < 1)">
                                    + Agregar
                                </button>
                            </div>
                        </div>
                        <p style="font-size: 0.7rem; color: #6b7280; margin: 0.25rem 0 0;">
                            💡 No descuenta stock, no consulta el catálogo. Pensado para servicios o conceptos manuales que querés facturar.
                        </p>
                    }

                    @if (addMode == "COMBO")
                    {
                        <div class="form-row" style="align-items: end;">
                            <div class="form-group" style="flex: 3; position: relative;">
                                <label class="form-label" style="font-size: 0.75rem;">Combo</label>
                                @if (addComboId > 0)
                                {
                                    var cSel = combos?.FirstOrDefault(x => x.Id == addComboId);
                                    <div style="display: flex; gap: 0.3rem; align-items: center;">
                                        <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                            <span style="font-size: 1.1rem;">🎁</span>
                                            <strong>@(cSel?.Nombre ?? "?")</strong>
                                            @if (cSel is not null)
                                            {
                                                <span style="font-size: 0.72rem; color: #6b7280;">· @cSel.ItemsCount item@(cSel.ItemsCount == 1 ? "" : "s")</span>
                                                <span style="font-size: 0.72rem; color: #6b7280;">· @(formClienteTipo == "BAR" ? "BAR" : "Comercial"): $@FormatMoney(formClienteTipo == "BAR" ? cSel.PreviewPrecioBar : cSel.PreviewPrecioOtro)</span>
                                            }
                                        </div>
                                        <button class="btn btn-secondary" type="button" @onclick="ClearCombo" title="Quitar combo">×</button>
                                    </div>
                                }
                                else
                                {
                                    <input class="form-input" @bind="comboSearch" @bind:event="oninput"
                                           @onfocus="() => comboSearchOpen = true"
                                           placeholder="🔍 Buscar combo por nombre..." />
                                    @if (comboSearchOpen && combos is not null)
                                    {
                                        var cmatches = string.IsNullOrWhiteSpace(comboSearch)
                                            ? combos.Where(c => c.IsActive).Take(20).ToList()
                                            : combos.Where(c => c.IsActive && (
                                                c.Nombre.MatchesSearch(comboSearch)
                                                || c.Descripcion.MatchesSearch(comboSearch)
                                                || (c.Sku ?? "").MatchesSearch(comboSearch))).Take(20).ToList();
                                        <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                            @if (cmatches.Count == 0)
                                            {
                                                <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin combos. Creálos desde "Combos" en el menú.</div>
                                            }
                                            else
                                            {
                                                @foreach (var c in cmatches)
                                                {
                                                    var cId = c.Id;
                                                    <div class="cli-pick-row" @onclick="() => SelectCombo(cId)"
                                                         style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                                        <span style="margin-right: 0.4rem;">🎁</span>
                                                        @if (!string.IsNullOrEmpty(c.Sku))
                                                        {
                                                            <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; margin-right: 0.5rem;">@c.Sku</span>
                                                        }
                                                        <strong>@c.Nombre</strong>
                                                        <span style="color: #6b7280; font-size: 0.78rem;"> · @c.ItemsCount item@(c.ItemsCount == 1 ? "" : "s")</span>
                                                        <span style="color: #1d4ed8; font-size: 0.78rem;"> · BAR $@FormatMoney(c.PreviewPrecioBar)</span>
                                                        <span style="color: #15803d; font-size: 0.78rem;"> · OTRO $@FormatMoney(c.PreviewPrecioOtro)</span>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                }
                            </div>
                            <div class="form-group" style="flex: 0 0 80px;">
                                <label class="form-label" style="font-size: 0.75rem;">Cant.</label>
                                <input class="form-input" type="number" min="1" @bind="addComboCantidad" style="text-align: right;" />
                                <p style="font-size: 0.7rem; color: #6b7280; margin: 0.2rem 0 0;">cant. de combos</p>
                            </div>
                            <div class="form-group" style="flex: 0 0 130px;">
                                <button class="btn btn-primary" type="button" @onclick="AddCombo" style="width: 100%;" disabled="@(addComboId <= 0)">+ Agregar combo</button>
                            </div>
                        </div>
                    }
                    else
                    {
                    @* 2026-06-17 v3: grid CSS en lugar de form-row para garantizar una sola fila — las columnas son fijas
                       (Cant 70 / Producto 1fr / Formato 130 / Molienda 200 / Envase 180). Cuando NO es café desaparecen
                       las dos últimas y la grilla se ajusta sola. *@
                    <div style="display: grid; grid-template-columns: 70px minmax(0, 1fr) 130px@(AddProductoCategoria == "CAFE" ? " 200px 180px" : ""); gap: 0.5rem; align-items: end;">
                        @* 2026-06-17 v2: Cant. movido al inicio de la fila — orden Cant | Producto | Formato | Molienda | Envase. *@
                        <div class="form-group" style="margin:0;">
                            <label class="form-label" style="font-size: 0.75rem;">Cant.</label>
                            <input id="nv-cantidad" class="form-input" type="number" min="1" @bind="addCantidad" @onkeydown="OnKeyDownCantidad" style="text-align: right;" />
                        </div>
                        <div class="form-group" style="margin:0; position: relative; min-width: 0;">
                            <label class="form-label" style="font-size: 0.75rem;">Producto</label>
                            @if (addProductoId > 0)
                            {
                                var pSel = productos?.FirstOrDefault(x => x.Id == addProductoId);
                                <div style="display: flex; gap: 0.3rem; align-items: center;">
                                    <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                        <span style="font-family: monospace; font-weight: 700; color: #1d4ed8;">@(pSel?.Sku ?? "—")</span>
                                        <strong>@(pSel?.Nombre ?? "?")</strong>
                                        @if (pSel is not null)
                                        {
                                            <span style="font-size: 0.72rem; color: #6b7280;">· @pSel.Categoria</span>
                                            @if (!string.IsNullOrEmpty(pSel.Marca))
                                            {
                                                <span style="font-size: 0.72rem; color: #6b7280;">· @pSel.Marca</span>
                                            }
                                            @* 2026-06-01: shells muestran armable *@
                                            <span style="font-size: 0.72rem; color: #6b7280;">· stock: @(pSel.Categoria == "CAFE"
                                                ? FormatGramos(pSel.StockGramos)
                                                : (pSel.StockArmable.HasValue ? $"{pSel.StockArmable.Value} u. 🧩" : pSel.StockUnidades + " u."))</span>
                                        }
                                    </div>
                                    <button class="btn btn-secondary" type="button" @onclick="ClearProducto" title="Quitar producto">×</button>
                                </div>
                            }
                            else
                            {
                                <input id="nv-producto" class="form-input" @bind="productoSearch" @bind:event="oninput"
                                       @onfocus="() => productoSearchOpen = true"
                                       @onkeydown="OnKeyDownProducto"
                                       placeholder="🔍 SKU, código de barras, nombre, marca... (Enter para seguir)" />
                                @if (productoSearchOpen && !string.IsNullOrWhiteSpace(productoSearch))
                                {
                                    var pmatches = ProductosMatching(productoSearch).Take(20).ToList();
                                    var cmpMatches = CompuestosMatching(productoSearch).Take(10).ToList();
                                    <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 320px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                        @if (pmatches.Count == 0 && cmpMatches.Count == 0)
                                        {
                                            <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados.</div>
                                        }
                                        else
                                        {
                                            @foreach (var p in pmatches)
                                            {
                                                var pId = p.Id;
                                                // 2026-06-01: para productos "shell" (con StockArmable) mostrar el armable en lugar del 0 propio.
                                                var stockTxt = p.Categoria == "CAFE"
                                                    ? FormatGramos(p.StockGramos)
                                                    : (p.StockArmable.HasValue
                                                        ? $"{p.StockArmable.Value} u. 🧩"
                                                        : $"{p.StockUnidades} u.");
                                                <div class="cli-pick-row" @onclick="() => SelectProducto(pId)"
                                                     style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                                    <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; margin-right: 0.5rem;">@(p.Sku ?? "—")</span>
                                                    <strong>@p.Nombre</strong>
                                                    @if (p.Categoria == "CAFE")
                                                    {
                                                        <span style="display:inline-block; padding:0.05rem 0.35rem; background:#fef3c7; color:#92400e; border-radius:999px; font-size:0.65rem; font-weight:700; margin-left: 0.4rem;">☕</span>
                                                    }
                                                    else
                                                    {
                                                        <span style="display:inline-block; padding:0.05rem 0.35rem; background:#e0e7ff; color:#3730a3; border-radius:999px; font-size:0.65rem; font-weight:700; margin-left: 0.4rem;">📦</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(p.Marca))
                                                    {
                                                        <span style="color: #6b7280; font-size: 0.78rem;"> · @p.Marca</span>
                                                    }
                                                    <span style="color: #6b7280; font-size: 0.78rem;"> · stock: @stockTxt</span>
                                                </div>
                                            }
                                            @* 2026-06-01: combos marcados como "compuesto" tambien aparecen aca *@
                                            @if (cmpMatches.Count > 0)
                                            {
                                                <div style="background:#fef3c7; padding:0.25rem 0.6rem; font-size:0.7rem; color:#92400e; font-weight:700; border-top:1px solid #fcd34d; border-bottom:1px solid #fcd34d;">
                                                    🧩 Productos compuestos (se arman de varias piezas)
                                                </div>
                                                @foreach (var c in cmpMatches)
                                                {
                                                    var cId = c.Id;
                                                    var precioTxt = formClienteTipo == "BAR" ? c.PreviewPrecioBar : c.PreviewPrecioOtro;
                                                    <div class="cli-pick-row" @onclick="() => SelectCompuestoDesdeProducto(cId)"
                                                         style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem; background:#fffbeb;">
                                                        <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; margin-right: 0.5rem;">@(c.Sku ?? "—")</span>
                                                        <strong>@c.Nombre</strong>
                                                        <span style="display:inline-block; padding:0.05rem 0.35rem; background:#fde68a; color:#92400e; border-radius:999px; font-size:0.65rem; font-weight:700; margin-left: 0.4rem;">🧩 COMP</span>
                                                        <span style="color: #6b7280; font-size: 0.78rem;"> · @c.ItemsCount pieza@(c.ItemsCount == 1 ? "" : "s") · $@FormatMoney(precioTxt)</span>
                                                    </div>
                                                }
                                            }
                                        }
                                    </div>
                                }
                            }
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label class="form-label" style="font-size: 0.75rem;">Formato</label>
                            <select id="nv-formato" class="form-input" value="@addFormato" @onchange="OnAddFormatoChanged" @onkeydown="OnKeyDownFormato">
                                @if (AddProductoCategoria == "CAFE")
                                {
                                    <option value="1KG">1 kg</option>
                                    <option value="MEDIO">1/2 kg</option>
                                    <option value="CUARTO">1/4 kg</option>
                                }
                                else
                                {
                                    <option value="UNIT">Suelto</option>
                                    @foreach (var pack in AddProductoPacks)
                                    {
                                        <option value="@($"PACK_{pack.Cantidad}")">@pack.Nombre</option>
                                    }
                                    @if (AddProductoTieneBulto)
                                    {
                                        <option value="BULTO">@AddProductoBultoLabel</option>
                                    }
                                }
                            </select>
                        </div>
                        @* 2026-06-17 v2: Molienda + Envase pasaron a la MISMA fila (al lado de Formato). Solo café. *@
                        @if (AddProductoCategoria == "CAFE")
                        {
                            <div class="form-group" style="margin:0;">
                                <label class="form-label" style="font-size: 0.75rem;">Molienda</label>
                                <select id="nv-molienda" class="form-input" @bind="addMolienda" @onkeydown="OnKeyDownMolienda" style="background:#fef3c7; border-color:#d97706; font-weight:600;">
                                    <option value="EN GRANOS">🫘 EN GRANOS</option>
                                    <option value="MOLIDO FILTRO">☕ MOLIDO FILTRO</option>
                                    <option value="MOLIDO EXPRESS">⚡ MOLIDO EXPRESS</option>
                                    <option value="MOLIDO MOKA">☕ MOLIDO MOKA</option>
                                    <option value="MOLIDO BODUM">☕ MOLIDO BODUM</option>
                                    <option value="MOLIDO PRENSA FRANCESA">☕ MOLIDO PRENSA FRANCESA</option>
                                    <option value="MOLIDO CAFETERA ITALIANA">☕ MOLIDO CAFETERA ITALIANA</option>
                                    <option value="MOLIDO A LA TURCA">☕ MOLIDO A LA TURCA</option>
                                    <option value="MINI EXPRESS">🔸 MINI EXPRESS</option>
                                </select>
                            </div>
                            <div class="form-group" style="margin:0;">
                                <label class="form-label" style="font-size: 0.75rem;">Envase</label>
                                <select id="nv-envase" class="form-input" @bind="addEnvase" @onkeydown="OnKeyDownEnvase" style="background:#f3f4f6; border-color:#9ca3af; font-weight:600;">
                                    <option value="NEGRO">⚫ Envase negro</option>
                                    <option value="PLATEADO">⚪ Envase plateado</option>
                                    <option value="DOY_PACK">📦 Doy pack</option>
                                </select>
                            </div>
                        }
                    </div>
                    @* 2026-06-17 v3: SEGUNDA FILA — botón Agregar (50%) + chip de precio en vivo (50%). Grid CSS para garantizar 50/50. *@
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; align-items: stretch; margin-top: 0.5rem;">
                        <button class="btn btn-primary" type="button" @onclick="AddItem" style="padding: 0.6rem; font-size: 0.95rem; font-weight: 700;">+ Agregar</button>
                        <div style="background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%); border: 1.5px solid #2563eb; border-radius: 4px; padding: 0.4rem 0.8rem; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; box-sizing: border-box;">
                            <span style="color: #1e3a8a; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;">💰 Precio</span>
                            @if (AddPrecioPreview > 0)
                            {
                                <span style="font-size: 1.05rem; font-weight: 800; color: #065f46;">$ @FormatMoney(AddPrecioPreview)</span>
                                <span style="color: #6b7280; font-size: 0.7rem;">@(formClienteTipo == "BAR" ? "BAR" : "Comercial") · @AddPrecioPreviewLabel</span>
                            }
                            else
                            {
                                <span style="color: #9ca3af; font-size: 0.85rem;">—</span>
                                <span style="color: #9ca3af; font-size: 0.7rem;">Elegí un producto</span>
                            }
                        </div>
                    </div>
                    @* Antes Cant. estaba en la fila 1 a la derecha. Ahora va al principio. *@
                    @if (AvisoBultoConviene is not null)
                    {
                        <div style="margin: 0.4rem 0 0; padding: 0.5rem 0.7rem; background: #fef3c7; border: 1px solid #d97706; border-radius: 6px; display: flex; gap: 0.5rem; align-items: center; font-size: 0.85rem; color: #92400e;">
                            <span>💡</span>
                            <span style="flex: 1;">@AvisoBultoConviene</span>
                            <button type="button" class="btn btn-secondary" @onclick="CambiarABulto" style="font-size: 0.75rem; padding: 0.25rem 0.6rem; white-space: nowrap;">
                                Cambiar a Bulto
                            </button>
                        </div>
                    }
                    }

                    @if (formItems.Count == 0)
                    {
                        <div style="padding: 0.8rem; text-align: center; color: #9ca3af; font-size: 0.9rem;">
                            Sin items. Elegí un producto, formato y tocá <strong>+ Agregar</strong>.
                        </div>
                    }
                    else if (cotizacion is not null)
                    {
                        <div class="table-responsive" style="margin-top: 0.5rem;">
                            <table class="data-table" style="font-size: 0.85rem;">
                                <thead>
                                    <tr>
                                        <th style="width: 70px; text-align: right;">Cant.</th>
                                        <th>Producto</th>
                                        <th style="width: 90px;">Formato</th>
                                        <th style="width: 130px; text-align: right;">P. Unit.</th>
                                        <th style="width: 90px; text-align: right;">Desc %</th>
                                        <th style="width: 140px; text-align: right;">Subtotal</th>
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* 2026-06-08: pre-agrupar items por ComboOrigenId. El primer item del grupo se renderiza
                                       como una sola fila "combo" que muestra nombre del combo + precio total. El resto del grupo se
                                       skipea. Los items sueltos se siguen renderizando uno por uno como antes.  *@
                                    @{
                                        var comboGroups = new Dictionary<int, List<int>>();
                                        for (int gi = 0; gi < formItems.Count; gi++)
                                        {
                                            if (formItems[gi].ComboOrigenId.HasValue)
                                            {
                                                var k = formItems[gi].ComboOrigenId.Value;
                                                if (!comboGroups.ContainsKey(k)) comboGroups[k] = new List<int>();
                                                comboGroups[k].Add(gi);
                                            }
                                        }
                                        var firstIdxOfCombo = comboGroups.ToDictionary(kv => kv.Value[0], kv => kv.Key);
                                    }
                                    @for (int idx = 0; idx < cotizacion.Items.Count; idx++)
                                    {
                                        var i = idx;
                                        var ci = cotizacion.Items[i];
                                        var rojo = !ci.StockOk;
                                        var formItem = formItems[i];
                                        var esCafe = ci.Categoria == "CAFE";

                                        // ── Fila combo agrupada ──
                                        @if (formItem.ComboOrigenId.HasValue)
                                        {
                                            // ¿Este idx es el primer item del grupo? Si no, skip (ya se renderizó).
                                            if (!firstIdxOfCombo.ContainsKey(i)) { continue; }
                                            var cid = firstIdxOfCombo[i];
                                            var idxsGrupo = comboGroups[cid];
                                            var comboInfo = combos?.FirstOrDefault(c => c.Id == cid);
                                            var comboNombre = comboInfo?.Nombre ?? "Producto compuesto";
                                            var comboSku = comboInfo?.Sku;
                                            // Subtotal + costo del grupo (suma de componentes)
                                            var subtotalGrupo = idxsGrupo.Sum(ix => cotizacion.Items[ix].Subtotal);
                                            var costoGrupo = idxsGrupo.Sum(ix => cotizacion.Items[ix].CostoUnitario * cotizacion.Items[ix].Cantidad);
                                            // "Packs" del combo = cantidad del primer item / cantidad esperada del componente (asumimos 1)
                                            // Para la mayoría de combos cada componente va 1×pack, así que tomamos la cantidad del primer item como packs
                                            var cantPacks = cotizacion.Items[i].Cantidad;
                                            var precioUnitCombo = cantPacks > 0 ? Math.Round(subtotalGrupo / cantPacks, 2, MidpointRounding.AwayFromZero) : 0m;
                                            // SKUs que se descuentan en el cartel
                                            var skusCartel = string.Join(" + ", idxsGrupo.Select(ix => {
                                                var skuCmp = productos?.FirstOrDefault(p => p.Id == cotizacion.Items[ix].ProductoId)?.Sku ?? "?";
                                                return $"{skuCmp} (×{cotizacion.Items[ix].Cantidad})";
                                            }));
                                            var hayPrecioOverride = idxsGrupo.Any(ix => formItems[ix].PrecioUnitarioOverride.HasValue);
                                            var descPctCombo = formItems[i].DescuentoPct;
                                            <tr style="background: #fff7ed;">
                                                <td style="text-align: right;">
                                                    <input class="form-input" type="number" step="1" min="1"
                                                           style="width: 70px; text-align: right; padding: 0.25rem 0.4rem; font-size: 0.9rem; font-weight: 700;"
                                                           value="@cantPacks" @onchange="@(e => OnComboCantidadChanged(cid, e.Value?.ToString()))" />
                                                </td>
                                                <td>
                                                    <div style="display:flex; align-items:center; gap:0.3rem; flex-wrap:wrap;">
                                                        @if (!string.IsNullOrEmpty(comboSku))
                                                        {
                                                            <span style="font-family:monospace; font-size:0.7rem; color:#9a3412; font-weight:700; background:#fed7aa; padding:1px 6px; border-radius:3px;">@comboSku</span>
                                                        }
                                                        <span style="background:#fed7aa; color:#7c2d12; font-size:0.65rem; font-weight:700; padding:1px 5px; border-radius:3px; letter-spacing:0.04em;">📦 COMBO</span>
                                                        <span style="font-weight:700; font-size:0.9rem; color:#1f2937;">@comboNombre</span>
                                                    </div>
                                                    <div style="margin-top:0.25rem; font-size:0.72rem; color:#7c2d12; background:#ffedd5; border-left:3px solid #f97316; padding:0.2rem 0.5rem; border-radius:3px;">
                                                        ↓ Descuenta stock: @skusCartel
                                                    </div>
                                                </td>
                                                <td><span style="display:inline-block; padding:0.15rem 0.5rem; background:#fed7aa; border:1px dashed #f97316; border-radius:12px; font-family:Georgia,serif; font-style:italic; font-size:0.85rem; color:#7c2d12;">Combo</span></td>
                                                <td style="text-align: right;">
                                                    <input class="form-input" type="number" step="0.01" min="0"
                                                           style="width: 110px; text-align: right; padding: 0.25rem 0.4rem; font-size: 0.85rem; font-weight: 700; @(hayPrecioOverride ? "background:#fef3c7; border-color:#d97706;" : "")"
                                                           value="@precioUnitCombo.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                                           @onchange="@(e => OnComboPrecioChanged(cid, e.Value?.ToString()))"
                                                           title="Precio unitario del combo. Si lo modificás, se distribuye proporcionalmente entre los componentes." />
                                                    @if (hayPrecioOverride)
                                                    {
                                                        <div style="display:flex; gap:0.2rem; justify-content:flex-end; align-items:center; margin-top:0.15rem;">
                                                            <span style="font-size:0.65rem; color:#d97706; font-weight:600;">✏️ manual</span>
                                                            <button type="button" class="btn-icon" style="color:#6b7280; font-size:0.7rem; padding:0 0.2rem;"
                                                                    @onclick="() => ClearComboPrecioOverride(cid)"
                                                                    title="Volver al precio del catálogo">✕</button>
                                                        </div>
                                                    }
                                                </td>
                                                <td style="text-align: right;">
                                                    <input class="form-input" type="number" step="0.5" min="0" max="100"
                                                           style="width: 80px; text-align: right; padding: 0.25rem 0.4rem; font-size: 0.85rem;"
                                                           value="@descPctCombo" @onchange="@(e => OnComboDescuentoChanged(cid, e.Value?.ToString()))" />
                                                </td>
                                                <td style="text-align: right; font-weight: 700;">
                                                    <div>$@FormatMoney(subtotalGrupo)</div>
                                                    @{
                                                        var margenComboPct = costoGrupo > 0
                                                            ? Math.Round((subtotalGrupo / costoGrupo - 1m) * 100m, 1, MidpointRounding.AwayFromZero)
                                                            : 0m;
                                                        var colorMargenC = margenComboPct >= 50m ? "#16a34a" : (margenComboPct >= 20m ? "#d97706" : "#dc2626");
                                                    }
                                                    @if (costoGrupo > 0)
                                                    {
                                                        <div style="font-size: 0.7rem; font-weight: 500; color: @colorMargenC; margin-top: 0.15rem;"
                                                             title="Margen sobre costo de los componentes">
                                                            Margen: @margenComboPct%
                                                        </div>
                                                    }
                                                </td>
                                                <td><button class="btn-icon btn-delete" type="button" @onclick="() => RemoveCombo(cid)" title="Quitar combo (saca todos los componentes)">×</button></td>
                                            </tr>
                                            continue;
                                        }

                                        // ── Fila item normal (no combo) ──
                                        <tr style="@(rojo ? "background: #fef2f2;" : "")">
                                            <td style="text-align: right;">
                                                <input class="form-input" type="number" step="1" min="1"
                                                       style="width: 70px; text-align: right; padding: 0.25rem 0.4rem; font-size: 0.9rem; font-weight: 700;"
                                                       value="@formItem.Cantidad" @onchange="@(e => OnItemCantidadChanged(i, e.Value?.ToString()))" />
                                                @if (ci.Formato == "BULTO" || (ci.Formato?.StartsWith("PACK_") ?? false))
                                                {
                                                    var unidadesReales = CantidadParaMostrar(ci.ProductoId, ci.Formato, ci.Cantidad);
                                                    <div style="font-size: 0.7rem; color: #92400e; font-weight: 600; margin-top: 0.15rem; white-space: nowrap;">= @unidadesReales u.</div>
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    var skuItem = productos?.FirstOrDefault(p => p.Id == ci.ProductoId)?.Sku;
                                                    var nombreActual = !string.IsNullOrWhiteSpace(formItem.DescripcionOverride) ? formItem.DescripcionOverride : ci.ProductoNombre;
                                                    var nombrePisado = !string.IsNullOrWhiteSpace(formItem.DescripcionOverride);
                                                }
                                                <div style="display:flex; align-items:center; gap:0.3rem; flex-wrap:wrap;">
                                                    @if (!string.IsNullOrEmpty(skuItem))
                                                    {
                                                        <span style="font-family:monospace; font-size:0.7rem; color:#1d4ed8; font-weight:700;">@skuItem</span>
                                                    }
                                                    <input type="text" class="form-input desc-inline-edit"
                                                           style="flex:1; min-width:200px; font-weight:700; font-size:0.9rem; padding:0.2rem 0.4rem; @(nombrePisado ? "background:#fef3c7; border-color:#d97706;" : "background:transparent; border:1px dashed transparent;")"
                                                           value="@nombreActual"
                                                           @onchange="@(e => OnItemDescripcionChanged(i, e.Value?.ToString()))"
                                                           title="@(nombrePisado ? "Nombre modificado para esta venta. ✕ para volver al original." : "Tocá para editar el nombre que aparece en el comprobante (solo en esta venta).")" />
                                                    @if (nombrePisado)
                                                    {
                                                        <span style="font-size:0.7rem; color:#d97706; font-weight:600;" title="Nombre modificado">✏️</span>
                                                        <button type="button" class="btn-icon" style="color:#6b7280; font-size:0.75rem; padding:0 0.2rem;"
                                                                @onclick="() => ClearItemDescripcion(i)"
                                                                title="Volver al nombre original del catálogo">✕</button>
                                                    }
                                                </div>
                                                @if (esCafe)
                                                {
                                                    <div style="display: flex; gap: 0.3rem; align-items: center; margin-top: 0.25rem; flex-wrap: wrap;">
                                                        <select class="form-input"
                                                                style="font-size: 0.72rem; padding: 0.15rem 0.3rem; background: #fef3c7; border-color: #d97706; font-weight: 600; max-width: 175px;"
                                                                value="@(formItem.Molienda ?? "")"
                                                                @onchange="@(e => OnItemMoliendaChanged(i, e.Value?.ToString()))"
                                                                title="Tipo de molienda del café">
                                                            @* 2026-06-09 fix: alineo opciones con el dropdown de ARRIBA (form de agregar).
                                                               Antes tenia 'MOLIDO ESPRESS' (typo sin X) y faltaba 'MOLIDO CAFETERA ITALIANA'.
                                                               Eso causaba que items recien agregados con 'MOLIDO EXPRESS' o 'MOLIDO CAFETERA ITALIANA'
                                                               apareciera el dropdown vacio y diera la sensacion de que la molienda se perdia. *@
                                                            <option value="">☕ (sin especificar)</option>
                                                            <option value="EN GRANOS">🫘 EN GRANOS</option>
                                                            <option value="MOLIDO FILTRO">☕ MOLIDO FILTRO</option>
                                                            <option value="MOLIDO EXPRESS">⚡ MOLIDO EXPRESS</option>
                                                            <option value="MOLIDO MOKA">☕ MOLIDO MOKA</option>
                                                            <option value="MOLIDO BODUM">☕ MOLIDO BODUM</option>
                                                            <option value="MOLIDO PRENSA FRANCESA">☕ MOLIDO PRENSA FRANCESA</option>
                                                            <option value="MOLIDO CAFETERA ITALIANA">☕ MOLIDO CAFETERA ITALIANA</option>
                                                            <option value="MOLIDO A LA TURCA">☕ MOLIDO A LA TURCA</option>
                                                            <option value="MINI EXPRESS">🔸 MINI EXPRESS</option>
                                                        </select>
                                                        @* Envase: dropdown con 3 opciones mutuamente excluyentes. Default = NEGRO. *@
                                                        @{
                                                            var envaseSel = formItem.EsDoyPack ? "DOY_PACK"
                                                                          : (formItem.EsEnvasePlateado ? "PLATEADO" : "NEGRO");
                                                        }
                                                        <select class="form-input"
                                                                style="font-size:0.72rem; padding:0.15rem 0.3rem; background:#f3f4f6; border-color:#9ca3af; font-weight:600; max-width:175px;"
                                                                value="@envaseSel"
                                                                @onchange="@(e => SetItemEnvaseFromString(i, e.Value?.ToString() ?? "NEGRO"))"
                                                                title="Tipo de envase. Se refleja en el comprobante.">
                                                            <option value="NEGRO">⚫ Envase negro</option>
                                                            <option value="PLATEADO">⚪ Envase plateado</option>
                                                            <option value="DOY_PACK">📦 Doy pack</option>
                                                        </select>
                                                    </div>
                                                }
                                                @if (rojo && !string.IsNullOrEmpty(ci.Aviso))
                                                {
                                                    <div style="color: #b91c1c; font-size: 0.72rem; font-weight: 600; margin-top: 0.2rem;">⚠ @ci.Aviso</div>
                                                }
                                            </td>
                                            <td><span style="display:inline-block; padding:0.15rem 0.5rem; background:#f3f4f6; border:1px dashed #9ca3af; border-radius:12px; font-family:Georgia,serif; font-style:italic; font-size:0.85rem; color:#4b5563;">@FormatoParaMostrar(ci.ProductoId, ci.Formato)</span></td>
                                            <td style="text-align: right;">
                                                @* Precio unitario editable: input + indicador si está overridado.
                                                   IMPORTANTE: formatear con InvariantCulture (punto decimal) — los <input type="number">
                                                   no aceptan coma como separador, y en es-AR Razor lo renderizaba "36000,00" → input quedaba vacío.  *@
                                                <input class="form-input" type="number" step="0.01" min="0"
                                                       style="width: 110px; text-align: right; padding: 0.25rem 0.4rem; font-size: 0.85rem; font-weight: 700; @(formItem.PrecioUnitarioOverride.HasValue ? "background:#fef3c7; border-color:#d97706;" : "")"
                                                       value="@ci.PrecioUnitario.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                                       @onchange="@(e => OnItemPrecioOverrideChanged(i, e.Value?.ToString()))"
                                                       title="@(formItem.PrecioUnitarioOverride.HasValue ? "Precio modificado manualmente — click derecho o ✕ para volver al precio del catálogo" : "Precio del catálogo. Editá el valor para pisarlo manualmente.")" />
                                                @if (formItem.PrecioUnitarioOverride.HasValue)
                                                {
                                                    <div style="display:flex; gap:0.2rem; justify-content:flex-end; align-items:center; margin-top:0.15rem;">
                                                        <span style="font-size:0.65rem; color:#d97706; font-weight:600;" title="Precio modificado">✏️ manual</span>
                                                        <button type="button" class="btn-icon" style="color:#6b7280; font-size:0.7rem; padding:0 0.2rem;"
                                                                @onclick="() => ClearItemPrecioOverride(i)"
                                                                title="Volver al precio del catálogo">✕</button>
                                                    </div>
                                                }
                                                @if (ci.DescuentoPct > 0)
                                                {
                                                    <div style="font-size:0.7rem; color:#6b7280; margin-top:0.15rem;">
                                                        c/desc -@ci.DescuentoPct%: <strong style="color:#16a34a;">$@FormatMoney(Math.Round(ci.PrecioUnitario * (1m - ci.DescuentoPct / 100m), 2, MidpointRounding.AwayFromZero))</strong>
                                                    </div>
                                                }
                                            </td>
                                            <td style="text-align: right;">
                                                <input class="form-input" type="number" step="0.5" min="0" max="100"
                                                       style="width: 80px; text-align: right; padding: 0.25rem 0.4rem; font-size: 0.85rem;"
                                                       value="@formItem.DescuentoPct" @onchange="@(e => OnItemDescuentoChanged(i, e.Value?.ToString()))" />
                                            </td>
                                            <td style="text-align: right; font-weight: 700;">
                                                <div>$@FormatMoney(ci.Subtotal)</div>
                                                @{
                                                    var costoLinea = ci.CostoUnitario * ci.Cantidad;
                                                    var margenLinea = ci.Subtotal - costoLinea;
                                                    var margenPctLinea = costoLinea > 0
                                                        ? Math.Round((ci.Subtotal / costoLinea - 1m) * 100m, 1, MidpointRounding.AwayFromZero)
                                                        : 0m;
                                                    var colorMargen = margenPctLinea >= 50m ? "#16a34a" : (margenPctLinea >= 20m ? "#d97706" : "#dc2626");
                                                }
                                                @* Solo mostrar margen cuando hay costo razonable. Items sin costo (concepto libre, saldos) no muestran margen. *@
                                                @if (costoLinea > 0 && ci.CostoUnitario > 0)
                                                {
                                                    <div style="font-size: 0.7rem; font-weight: 500; color: @colorMargen; margin-top: 0.15rem;"
                                                         title="Margen sobre costo: ganancia $@FormatMoney(margenLinea)">
                                                        Margen: @margenPctLinea%
                                                    </div>
                                                }
                                            </td>
                                            <td><button class="btn-icon btn-delete" type="button" @onclick="() => RemoveItem(i)" title="Quitar">×</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @* 2026-06-17: solo queda Notas internas en la izq — el resto (Dias, Entrega, Comentario armado, Totales, Cobrar al guardar)
                   se movio al panel sticky derecho. *@
                <div style="padding: 0.3rem 0; margin-bottom: 0.4rem;">
                    <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
                        <strong style="font-size: 0.78rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;">Notas internas de la venta</strong>
                    </div>
                    <textarea class="form-input" rows="2" @bind="formObservaciones" placeholder="Notas internas (opcional)"></textarea>
                </div>
            </div>
            @* 2026-06-17: el bloque "Enviar al cliente al emitir" se movio al panel sticky derecho. *@
                </div> @* fin columna izquierda (formulario) *@

                @* 2026-06-17 v4: Panel sticky derecho con TOTALES anclado al fondo.
                   - top: 56px → libera aire para los botones — □ ✕ del modal arriba a la derecha.
                   - altura fija calc(94vh - 200px) y display:flex column → permite que Totales quede pegado abajo.
                   - Más comprados es el unico hijo con overflow-y:auto (la lista de productos scrollea ahí dentro).
                   - Totales tiene flex:0 0 auto → SIEMPRE visible al fondo del panel, no entra en el scroll. *@
                <div style="position: absolute; top: 56px; right: 0; width: 340px; height: calc(94vh - 200px); overflow: hidden; display:flex; flex-direction:column; gap:0.6rem;">

                @if (MostrarPanelTopProductos)
                {
                    <div style="padding: 0.6rem; background: linear-gradient(180deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #f59e0b; border-radius: 8px; display:flex; flex-direction:column; gap:0.5rem; flex: 1 1 auto; min-height: 0; overflow-y: auto;">
                        <div style="display: flex; align-items: center; gap: 0.4rem;">
                            <span style="font-size: 1.1rem;">⭐</span>
                            <strong style="font-size: 0.85rem; color: #78350f;">Más comprados</strong>
                        </div>
                        <div style="font-size: 0.72rem; color: #92400e;">
                            por @(clientes?.FirstOrDefault(c => c.Id == formClienteId)?.Nombre ?? "este cliente") (@topProductsForClient.Count)
                        </div>
                        <div style="font-size: 0.7rem; color: #78350f; font-style: italic;">Tocá el producto para agregar 1 al carrito · Ajustá la cantidad abajo.</div>

                        <input type="text" placeholder="🔍 Buscar..." @bind="topProductsSearch" @bind:event="oninput"
                               style="width: 100%; padding: 0.3rem 0.5rem; font-size: 0.78rem; border: 1px solid #f59e0b; border-radius: 4px;" />

                        @if (topProductosDescartadosCount > 0)
                        {
                            <button type="button"
                                    style="background:transparent; border:1px solid #f59e0b; color:#78350f; padding:0.25rem 0.4rem; border-radius:4px; font-size:0.7rem; cursor:pointer;"
                                    @onclick="RestaurarTopProductosDescartados"
                                    title="Volver a ver los productos descartados">
                                🔄 Restaurar @topProductosDescartadosCount descartado@(topProductosDescartadosCount == 1 ? "" : "s")
                            </button>
                        }

                        @{
                            var filtroTop = (topProductsSearch ?? "").Trim();
                            var listaFiltrada = string.IsNullOrEmpty(filtroTop)
                                ? topProductsForClient
                                : topProductsForClient.Where(p =>
                                    (p.Nombre ?? "").Contains(filtroTop, StringComparison.OrdinalIgnoreCase)
                                    || (p.Sku ?? "").Contains(filtroTop, StringComparison.OrdinalIgnoreCase)
                                    || (p.Marca ?? "").Contains(filtroTop, StringComparison.OrdinalIgnoreCase)).ToList();
                        }

                        @if (listaFiltrada.Count == 0)
                        {
                            <div style="font-size: 0.78rem; color: #92400e; text-align: center; padding: 0.6rem;">Sin resultados.</div>
                        }

                        <div style="display:flex; flex-direction:column; gap:0.3rem;">
                            @foreach (var t in listaFiltrada)
                            {
                                var stockTxt = t.Categoria == "CAFE" ? FormatGramos(t.StockGramos) : $"{t.StockUnidades} u.";
                                var stockColor = (t.Categoria == "CAFE" ? t.StockGramos : t.StockUnidades) <= 0 ? "#dc2626" : "#15803d";
                                var prodId = t.ProductoId;
                                var fmt = t.Formato;
                                var enCarrito = ContarEnCarrito(prodId, fmt);
                                var borderColor = enCarrito > 0 ? "#16a34a" : "#fcd34d";
                                var bgColor = enCarrito > 0 ? "#f0fdf4" : "white";
                                <div style="display:flex; flex-direction:column; gap:0.15rem; background:@bgColor; border:1.5px solid @borderColor; border-radius:6px; padding:0.4rem 0.5rem; font-size:0.78rem; cursor:pointer; transition:background 0.12s, transform 0.08s;"
                                     @onclick="() => AddTopProduct(prodId, fmt)"
                                     title="Tocá para agregar 1 al carrito — Comprado @t.TimesOrdered ve@(t.TimesOrdered == 1 ? "z" : "ces") · Última: @t.LastPurchase.ToString("dd/MM/yyyy")">
                                    <div style="display:flex; align-items:center; gap:0.4rem;">
                                        <span style="background:#f59e0b; color:white; padding:0.1rem 0.35rem; border-radius:999px; font-size:0.66rem; font-weight:800; min-width:26px; text-align:center;">@t.TimesOrdered×</span>
                                        <strong style="flex:1; color:#78350f; line-height:1.15; word-break: break-word;">@t.Nombre</strong>
                                        @if (enCarrito > 0)
                                        {
                                            <span style="background:#16a34a; color:white; padding:0.1rem 0.35rem; border-radius:999px; font-size:0.7rem; font-weight:800;" title="En el carrito">✓ @enCarrito</span>
                                        }
                                        <button type="button"
                                                style="background:transparent; color:#dc2626; border:1px solid #fca5a5; border-radius:4px; padding:0.05rem 0.3rem; font-weight:700; cursor:pointer; font-size:0.72rem;"
                                                @onclick="() => DescartarTopProduct(prodId)"
                                                @onclick:stopPropagation="true"
                                                title="Descartar — no volverá a aparecer hasta que el cliente lo compre de nuevo">×</button>
                                    </div>
                                    <div style="display:flex; gap:0.5rem; align-items:center; color:#92400e; font-size:0.7rem;">
                                        <span style="font-family:monospace;">@(string.IsNullOrEmpty(t.Sku) ? "—" : t.Sku)</span>
                                        <span style="font-weight:500;">@FormatoLabel(t.Formato)</span>
                                        <span style="margin-left:auto; color:@stockColor;">@stockTxt</span>
                                        <span style="color:#78350f; font-weight:600;">$@FormatMoney(t.PrecioReferencia)</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* 2026-06-17 v2: bloques Entrega + Comentario armado movidos a la 3a columna del header.
                   Acá en el panel sticky derecho solo quedan Más comprados + Totales. *@

                @* ─── TOTALES ─── *@
                @* 2026-06-17 v4: flex 0 0 auto → siempre visible al fondo del panel sticky, no entra al scroll de Más comprados. *@
                @if (cotizacion is not null)
                {
                    <div style="padding: 0.6rem 0.8rem; background: white; border: 1px solid #d1d5db; border-radius: 10px; flex: 0 0 auto; box-shadow: 0 -2px 8px rgba(0,0,0,0.04);">
                        <div class="venta-totals-row" style="font-size: 0.85rem;">
                            <span>Subtotal:</span>
                            <strong>$@FormatMoney(cotizacion.Subtotal)</strong>
                        </div>
                        <div class="venta-totals-row" style="font-size: 0.85rem;">
                            <span>Descuento:</span>
                            <input class="form-input" type="number" step="0.01" @bind="formDescuento" @bind:after="Cotizar"
                                   style="text-align: right; max-width: 100px; font-weight: 700; padding: 0.15rem 0.3rem; font-size: 0.8rem;" />
                        </div>
                        @{
                            bool formMostrarIva2 = formTipoComprobante is "FA" or "FB" or "PRO";
                            decimal formIva2 = formMostrarIva2 ? Math.Round(cotizacion.Total * 0.21m, 2, MidpointRounding.AwayFromZero) : 0m;
                            decimal formTotalConIva2 = cotizacion.Total + formIva2;
                        }
                        @if (formMostrarIva2)
                        {
                            <hr style="margin: 0.35rem 0; border: none; border-top: 1px dashed #d1d5db;" />
                            <div class="venta-totals-row" style="font-size: 0.78rem;"><span>Neto:</span><strong>$@FormatMoney(cotizacion.Total)</strong></div>
                            <div class="venta-totals-row" style="font-size: 0.78rem; color: #1d4ed8;"><span>IVA 21%:</span><strong>$@FormatMoney(formIva2)</strong></div>
                            <hr style="margin: 0.35rem 0; border: none; border-top: 2px solid #1f2937;" />
                            <div class="venta-totals-row" style="font-size: 1.05rem; font-weight: 800; color: #059669;"><span>TOTAL c/IVA:</span><strong>$@FormatMoney(formTotalConIva2)</strong></div>
                        }
                        else
                        {
                            <hr style="margin: 0.35rem 0; border: none; border-top: 2px solid #1f2937;" />
                            <div class="venta-totals-row" style="font-size: 1.05rem; font-weight: 800; color: #059669;"><span>TOTAL:</span><strong>$@FormatMoney(cotizacion.Total)</strong></div>
                        }
                        <hr style="margin: 0.35rem 0; border: none; border-top: 1px dashed #d1d5db;" />
                        <div class="venta-totals-row" style="font-size: 0.72rem; color: #6b7280;"><span>Costo:</span><span>$@FormatMoney(cotizacion.CostoTotal)</span></div>
                        <div class="venta-totals-row" style="font-size: 0.85rem; font-weight: 700; color: @(cotizacion.Margen >= 0 ? "#15803d" : "#b91c1c");">
                            <span>Margen:</span>
                            <span>
                                $@FormatMoney(cotizacion.Margen)
                                @if (cotizacion.CostoTotal > 0)
                                {
                                    var margenPctGlobal2 = Math.Round((cotizacion.Total / cotizacion.CostoTotal - 1m) * 100m, 1, MidpointRounding.AwayFromZero);
                                    <span style="font-size: 0.72rem; font-weight: 500; opacity: 0.85;">(@margenPctGlobal2%)</span>
                                }
                            </span>
                        </div>
                    </div>
                }

                </div> @* fin panel sticky derecho *@
                </div> @* fin wrapper flex split *@

            @* 2026-06-17 v5: footer con botones centrados horizontalmente — asi el panel sticky derecho
               (Mas comprados) nunca puede taparlos por mas larga que sea la lista del cliente.
               El chip Auto-guardado va a la izquierda como elemento absoluto para no romper el centrado. *@
            <div class="modal-footer" style="position: relative; justify-content: center; gap: 0.5rem;">
                @if (!editingVentaId.HasValue && lastBorradorSavedAt.HasValue)
                {
                    <span style="font-size:0.75rem; color:#16a34a; position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);">💾 Auto-guardado · @LastSavedAgo()</span>
                }
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@saving">Cancelar</button>
                <button class="btn btn-secondary" @onclick="PreviewPdf" disabled="@(saving || previewLoading || formItems.Count == 0 || cotizacion?.TodoOk != true)"
                        title="Ver cómo quedaría el PDF sin guardar la venta">
                    @(previewLoading ? "⏳ Generando..." : "👁 Previsualizar PDF")
                </button>
                <button class="btn btn-primary" @onclick="ConfirmarEmision" disabled="@(saving || formItems.Count == 0 || cotizacion?.TodoOk != true)">
                    @(saving
                        ? (editingVentaId.HasValue ? "Guardando..." : "Emitiendo...")
                        : (editingVentaId.HasValue ? "💾 Guardar cambios" : $"Emitir {EmitirLabelForTipo(formTipoComprobante)}"))
                </button>
            </div>
        </div>
    </div> @* fin modal-overlay *@
    }

    @* 2026-06-17: chip flotante cuando el modal esta MINIMIZADO. *@
    @if (formModalMode == "MINIMIZADO")
    {
        <div @onclick="RestaurarModal"
             style="position: fixed; bottom: 16px; right: 16px; z-index: 9000; background: #1d4ed8; color: white;
                    border-radius: 999px; padding: 0.6rem 1rem; box-shadow: 0 6px 20px rgba(0,0,0,0.25);
                    cursor: pointer; display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; font-weight: 600;"
             title="Tocá para volver a la venta">
            <span style="font-size: 1.1rem;">🧾</span>
            <span>Venta en curso</span>
            @if (formClienteId > 0)
            {
                var cliMin = clientes?.FirstOrDefault(c => c.Id == formClienteId);
                <span style="opacity: 0.85; font-weight: 400;">· @(cliMin?.Nombre ?? "(s/cliente)")</span>
            }
            @if (formItems.Count > 0)
            {
                <span style="background: rgba(255,255,255,0.25); padding: 0.1rem 0.5rem; border-radius: 999px; font-size: 0.78rem;">@formItems.Count items</span>
            }
            <span style="margin-left: 0.4rem; opacity: 0.7;">↗</span>
        </div>
    }
}

@* ════════ Modal de confirmacion de emision (doble-check para FA/FB/FC) ════════ *@
@if (showConfirmEmision && cotizacion is not null)
{
    <div class="modal-overlay" style="z-index: 9100;" @onclick="@(() => showConfirmEmision = false)">
        <div id="confirm-emision-modal" class="modal-card" @onclick:stopPropagation="true" style="max-width: 480px;">
            <div class="modal-header" style="background: #fef3c7;" title="Arrastrá para mover">
                <h3 style="margin: 0; color: #92400e;">⚠ Confirmar emisión <span style="font-size:0.7rem; color:#92400e; opacity:0.6; font-weight:normal; margin-left:0.4rem;">(arrastrame)</span></h3>
                <button class="btn-close" @onclick="@(() => showConfirmEmision = false)">&times;</button>
            </div>
            <div class="modal-body" style="padding: 1.2rem;">
                <p style="margin: 0 0 1rem; color: #4b5563;">Estás por <strong>emitir un comprobante con CAE</strong>. Una vez emitido <strong>no se puede deshacer</strong>: solo se puede revertir con Nota de Crédito.</p>

                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.8rem; margin-bottom: 1rem;">
                    <div style="display: flex; justify-content: space-between; padding: 0.2rem 0; font-size: 0.88rem;">
                        <span style="color: #6b7280;">Tipo:</span>
                        <strong>@TipoComprobanteLargo(formTipoComprobante)</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; padding: 0.2rem 0; font-size: 0.88rem;">
                        <span style="color: #6b7280;">Cliente:</span>
                        <strong>@(NombreClienteConfirmacion())</strong>
                    </div>
                    <div style="display: flex; justify-content: space-between; padding: 0.2rem 0; font-size: 0.88rem;">
                        <span style="color: #6b7280;">Items:</span>
                        <strong>@formItems.Count</strong>
                    </div>
                    @{
                        // Para FA/FB/FC el cotizacion.Total es NETO. El cliente paga Total + 21% IVA.
                        // Para FC (Monotributo) NO se suma IVA discriminado al cliente.
                        var sumaIvaConfirm = formTipoComprobante is "FA" or "FB";
                        var ivaConfirm = sumaIvaConfirm
                            ? Math.Round(cotizacion.Total * 0.21m, 2, MidpointRounding.AwayFromZero)
                            : 0m;
                        var totalFinalConfirm = cotizacion.Total + ivaConfirm;
                    }
                    @if (sumaIvaConfirm)
                    {
                        <div style="display: flex; justify-content: space-between; padding: 0.2rem 0; font-size: 0.82rem; color: #6b7280; border-top: 1px solid #e5e7eb; margin-top: 0.4rem; padding-top: 0.4rem;">
                            <span>Neto sin IVA:</span>
                            <span>$@FormatMoney(cotizacion.Total)</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 0.2rem 0; font-size: 0.82rem; color: #1d4ed8;">
                            <span>IVA 21%:</span>
                            <span>$@FormatMoney(ivaConfirm)</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 0.4rem 0 0; border-top: 1px solid #e5e7eb; margin-top: 0.4rem; font-size: 1.1rem;">
                            <span style="color: #6b7280;">TOTAL c/IVA:</span>
                            <strong style="color: #15803d;">$@FormatMoney(totalFinalConfirm)</strong>
                        </div>
                    }
                    else
                    {
                        <div style="display: flex; justify-content: space-between; padding: 0.4rem 0 0; border-top: 1px solid #e5e7eb; margin-top: 0.4rem; font-size: 1.05rem;">
                            <span style="color: #6b7280;">TOTAL:</span>
                            <strong style="color: #1d4ed8;">$@FormatMoney(cotizacion.Total)</strong>
                        </div>
                    }
                </div>

                @if (sumaIvaConfirm)
                {
                    <p style="font-size: 0.78rem; color: #1d4ed8; margin: 0 0 0.5rem; background: #eff6ff; padding: 0.4rem 0.6rem; border-radius: 4px; border-left: 3px solid #1d4ed8;">
                        💵 El cliente paga <strong>$@FormatMoney(totalFinalConfirm)</strong> (incluye 21% IVA).
                    </p>
                }
                <p style="font-size: 0.78rem; color: #6b7280; margin: 0;">💡 Tip: si querés ver el PDF antes de confirmar, tocá <em>Cancelar</em> y después <em>Previsualizar PDF</em>.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="@(() => showConfirmEmision = false)" disabled="@saving">Cancelar</button>
                <button class="btn btn-primary" style="background: #16a34a; border-color: #15803d;" @onclick="ConfirmarYEmitir" disabled="@saving">
                    @(saving ? "Emitiendo..." : "✓ Sí, emitir")
                </button>
            </div>
        </div>
    </div>
}

@* ═══════════════ MODAL VIEWER / PDF ═══════════════ *@
@if (printVenta is not null && settings is not null)
{
    <style>
        /* Sello PAGADO acorde al tamaño del comprobante (más chico que en Ventas) */
        .cafe-pagado-stamp {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%) rotate(-18deg);
            font-size: 2rem;
            font-weight: 900;
            color: rgba(220, 38, 38, 0.22);
            border: 3px solid rgba(220, 38, 38, 0.22);
            padding: 0.25rem 1.1rem;
            border-radius: 7px;
            letter-spacing: 0.18rem;
            pointer-events: none;
            user-select: none;
            z-index: 5;
        }
        @@media print {
            @@page { size: A4; margin: 12mm; }
            html, body { background: white !important; margin: 0 !important; padding: 0 !important; }
            body * { visibility: hidden; }
            #cafe-print, #cafe-print * { visibility: visible; }
            #cafe-print {
                position: absolute !important;
                left: 0 !important; top: 0 !important; right: 0 !important;
                margin: 0 !important; padding: 0 !important; background: white !important;
            }
            .no-print { display: none !important; }
        }
    </style>
    <div class="modal-overlay" @onclick="ClosePrint">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 820px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header no-print" style="background: whitesmoke;">
                <h3 style="margin: 0;">📄 Comprobante @printVenta.Numero</h3>
                <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
                    <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.85rem; cursor: pointer;">
                        <input type="checkbox" checked="@printVenta.IsPaid" @onchange="TogglePaid" />
                        Pagado
                    </label>
                    <button class="btn" style="background:#16a34a; color: white; border: none; font-size: 0.85rem;"
                            @onclick="@(() => OpenReenvio(printVenta))" title="Mandar este comprobante por mail / WhatsApp">
                        📤 Enviar al cliente
                    </button>
                    @* Boton Subir a Drive — SIEMPRE visible (permite re-subir si hubo cambios o si la
                       carpeta de destino cambio). Si ya esta subido, mostramos un mini link "👁" al lado
                       para abrir el PDF actual en Drive. *@
                    <button class="btn" style="background:#4285f4; color: white; border: none; font-size: 0.85rem;"
                            @onclick="@(() => SubirADrive(printVenta!))" disabled="@subiendoDrive"
                            title="@(printVenta.DriveSubidoAt.HasValue ? $"Re-subir a Drive (último: {printVenta.DriveSubidoAt:dd/MM HH:mm})" : "Subir a Drive")">
                        @(subiendoDrive
                            ? "Subiendo..."
                            : (printVenta.DriveSubidoAt.HasValue ? "🔄 Re-subir a Drive" : "📁 Subir a Drive"))
                    </button>
                    @if (printVenta.DriveSubidoAt.HasValue && !string.IsNullOrEmpty(printVenta.DriveFileId))
                    {
                        <a class="btn" href="https://drive.google.com/file/d/@printVenta.DriveFileId/view" target="_blank"
                           style="background:white; color:#4285f4; border:1px solid #4285f4; font-size: 0.85rem; text-decoration: none; padding: 0.3rem 0.6rem;"
                           title="Abrir el PDF actual en Drive">
                            👁 Ver actual
                        </a>
                    }
                    @if (HasWhatsapp)
                    {
                        <a class="btn" style="background:#25D366;color:white;border:none;font-size: 0.85rem; text-decoration: none;"
                           href="@WhatsappLink" target="_blank">📱 WhatsApp</a>
                    }
                    <button class="btn btn-secondary" @onclick="DoPrint" style="font-size: 0.85rem;">🖨 Imprimir / PDF</button>
                    <button class="btn-close" @onclick="ClosePrint">&times;</button>
                </div>
            </div>
            <div class="modal-body" id="cafe-print" style="background: #525659; padding: 0; overflow: hidden; position: relative;">
                @* PDF REAL embebido (decision 2026-05-20: lo que ves = lo que descargas).
                   Los hash params #navpanes=0 + #pagemode=none esconden el panel lateral
                   de miniaturas del visor PDF de Chrome — sino se veia "doble". *@
                @if (!string.IsNullOrEmpty(printPdfUrl))
                {
                    <embed src="@(printPdfUrl + "#toolbar=1&navpanes=0&scrollbar=0&pagemode=none&zoom=60")" type="application/pdf"
                           style="width: 100%; height: 75vh; border: none; display: block; background: #525659;" />
                }
                else
                {
                    <div style="padding: 3rem; text-align: center; color: white; background: #525659;">⏳ Cargando PDF…</div>
                }

                @* HTML legacy del comprobante: oculto. Se mantiene en el codigo por si en algun
                   momento se quiere alternar entre vistas. Sacarlo definitivamente requiere borrar
                   ~370 lineas — riesgo bajo pero pendiente para un cleanup posterior. *@
                <div style="display: none;">
                @if (printVenta.Estado == "anulado")
                {
                    <div style="background: #fee2e2; border: 2px solid #b91c1c; color: #7f1d1d; padding: 0.6rem 0.9rem; border-radius: 6px; margin-bottom: 0.6rem; font-weight: 800;">
                        ⚠ COMPROBANTE ANULADO
                    </div>
                }
                @* ARCA estado banner — solo si es FA/FB/FC *@
                @if (printVenta.TipoComprobante is "FA" or "FB" or "FC")
                {
                    @if (printVenta.ArcaEstado == "autorizado")
                    {
                        <div class="no-print" style="background: #dcfce7; border: 1px solid #86efac; padding: 0.6rem 0.9rem; border-radius: 6px; margin-bottom: 0.6rem;">
                            <strong style="color: #166534;">✅ Factura autorizada en ARCA</strong>
                            <div style="font-size: 0.85rem; color: #166534; margin-top: 0.2rem;">
                                <strong>CAE:</strong> <span style="font-family: monospace;">@printVenta.ArcaCae</span> ·
                                <strong>Vto:</strong> @(printVenta.ArcaCaeVto?.ToString("dd/MM/yyyy") ?? "—") ·
                                <strong>Nro ARCA:</strong> @($"{(printVenta.ArcaPtoVta ?? 0):00000}-{(printVenta.ArcaCbteNro ?? 0):00000000}")
                            </div>
                        </div>
                    }
                    else if (printVenta.ArcaEstado == "pendiente")
                    {
                        <div class="no-print" style="background: #fed7aa; border: 2px solid #fb923c; padding: 0.7rem 0.9rem; border-radius: 6px; margin-bottom: 0.6rem; display: flex; justify-content: space-between; align-items: center; gap: 0.8rem; flex-wrap: wrap;">
                            <div style="flex: 1; min-width: 240px;">
                                <strong style="color: #9a3412;">⚠ Factura PENDIENTE — no se autorizó en ARCA todavía</strong>
                                <div style="font-size: 0.8rem; color: #7c2d12; margin-top: 0.2rem; white-space: pre-wrap;">@printVenta.ArcaError</div>
                            </div>
                            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                                <button class="btn btn-secondary" style="font-size: 0.85rem; background: #ffffff; border: 1px solid #fb923c; color: #9a3412;"
                                        @onclick="EditarYReintentar" disabled="@arcaRetrying">
                                    ✎ Editar y reintentar
                                </button>
                                <button class="btn btn-primary" style="font-size: 0.85rem; background: #ea580c; border: none;"
                                        @onclick="RetryArca" disabled="@arcaRetrying">
                                    @(arcaRetrying ? "Reintentando..." : "🔄 Reintentar emisión")
                                </button>
                            </div>
                        </div>
                    }
                }
                @if (printVenta.IsPaid && printVenta.Estado != "anulado")
                {
                    <div class="cafe-pagado-stamp">PAGADO</div>
                }

                @* Cabecera: identidad del NEGOCIO (emisor) — datos fiscales completos para factura *@
                <div style="border: 1px solid #d1d5db; padding: 0.85rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                        <div style="flex: 1; display: flex; gap: 0.7rem; align-items: flex-start;">
                            @if (!string.IsNullOrEmpty(settings.NegocioLogoUrl))
                            {
                                <img src="@settings.NegocioLogoUrl" alt="Logo"
                                     style="max-height: 70px; max-width: 130px; object-fit: contain; flex: 0 0 auto;"
                                     onerror="this.style.display='none'" />
                            }
                            <div style="flex: 1;">
                                @{
                                    var negNombreFantasia = string.IsNullOrEmpty(settings.NegocioNombre) ? "Café e insumos" : settings.NegocioNombre!;
                                    var negRazonSocial = string.IsNullOrWhiteSpace(settings.NegocioRazonSocial) ? negNombreFantasia : settings.NegocioRazonSocial!;
                                }
                                <h2 style="margin: 0; font-size: 1.4rem; font-weight: 800; line-height: 1.15;">@negRazonSocial</h2>
                                @if (!string.IsNullOrWhiteSpace(settings.NegocioRazonSocial) && !string.IsNullOrEmpty(settings.NegocioNombre))
                                {
                                    <div style="font-size: 0.85rem; color: #4b5563; margin-top: 0.1rem;"><em>@settings.NegocioNombre</em></div>
                                }
                                <div style="font-size: 0.78rem; color: #4b5563; margin-top: 0.3rem; line-height: 1.5;">
                                    @if (!string.IsNullOrEmpty(settings.NegocioDireccion))
                                    {
                                        var locCp = string.Join(" - ", new[] { settings.NegocioLocalidad, settings.NegocioCp }
                                            .Where(x => !string.IsNullOrWhiteSpace(x)));
                                        <div>@settings.NegocioDireccion@(string.IsNullOrEmpty(locCp) ? "" : " · " + locCp)</div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(settings.NegocioLocalidad) || !string.IsNullOrWhiteSpace(settings.NegocioCp))
                                    {
                                        <div>@string.Join(" - ", new[] { settings.NegocioLocalidad, settings.NegocioCp }.Where(x => !string.IsNullOrWhiteSpace(x)))</div>
                                    }
                                    @if (!string.IsNullOrEmpty(settings.NegocioCuit) || !string.IsNullOrEmpty(settings.NegocioCondicionIva))
                                    {
                                        <div>
                                            @if (!string.IsNullOrEmpty(settings.NegocioCuit)) { <span><strong>CUIT:</strong> @settings.NegocioCuit</span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioCuit) && !string.IsNullOrEmpty(settings.NegocioCondicionIva)) { <span> · </span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioCondicionIva)) { <span><strong>Cond. IVA:</strong> @CondicionIvaLabel(settings.NegocioCondicionIva!)</span> }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(settings.NegocioIngresosBrutos) || settings.NegocioInicioActividad.HasValue)
                                    {
                                        <div>
                                            @if (!string.IsNullOrEmpty(settings.NegocioIngresosBrutos)) { <span><strong>IIBB:</strong> @settings.NegocioIngresosBrutos</span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioIngresosBrutos) && settings.NegocioInicioActividad.HasValue) { <span> · </span> }
                                            @if (settings.NegocioInicioActividad.HasValue) { <span><strong>Inicio actividad:</strong> @settings.NegocioInicioActividad.Value.ToString("dd/MM/yyyy")</span> }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(settings.NegocioTelefono) || !string.IsNullOrEmpty(settings.NegocioEmail) || !string.IsNullOrEmpty(settings.NegocioWeb))
                                    {
                                        <div style="margin-top: 0.15rem; color: #6b7280;">
                                            @if (!string.IsNullOrEmpty(settings.NegocioTelefono)) { <span>Tel: @settings.NegocioTelefono</span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioTelefono) && (!string.IsNullOrEmpty(settings.NegocioEmail) || !string.IsNullOrEmpty(settings.NegocioWeb))) { <span> · </span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioEmail)) { <span>@settings.NegocioEmail</span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioEmail) && !string.IsNullOrEmpty(settings.NegocioWeb)) { <span> · </span> }
                                            @if (!string.IsNullOrEmpty(settings.NegocioWeb)) { <span>@settings.NegocioWeb</span> }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <div style="display: flex; align-items: center; gap: 0.4rem; justify-content: flex-end;">
                                <div style="background: #f3f4f6; border: 2px solid #d1d5db; padding: 0.2rem 0.6rem; font-weight: 800; font-size: 1.4rem;">@TipoComprobanteCorto(printVenta.TipoComprobante)</div>
                                <div style="font-size: 1.2rem; font-weight: 800; color: #1d4ed8;">@TipoComprobanteLargo(printVenta.TipoComprobante)</div>
                            </div>
                            <div style="font-family: monospace; font-size: 1.05rem; font-weight: 700; margin-top: 0.2rem;">N° @printVenta.Numero</div>
                            <div style="font-size: 0.85rem;"><strong>Fecha:</strong> @printVenta.Fecha.ToString("dd/MM/yyyy")</div>
                            @if (printVenta.TipoComprobante == "X")
                            {
                                <div style="color: #6b7280; font-style: italic; font-size: 0.72rem; margin-top: 0.3rem;">Documento no válido como factura</div>
                            }
                        </div>
                    </div>
                </div>

                @* Cliente: identidad del RECEPTOR — datos fiscales (sin domicilio de entrega: ese va al pie) *@
                <div style="border: 1px solid #d1d5db; border-top: 0; padding: 0.6rem; font-size: 0.9rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; flex-wrap: wrap;">
                        <div style="flex: 1;">
                            @if (!string.IsNullOrWhiteSpace(printVenta.ClienteRazonSocial))
                            {
                                <div style="font-size: 1rem;"><strong>@printVenta.ClienteRazonSocial</strong></div>
                                <div style="font-size: 0.82rem; color: #6b7280;"><em>@(printVenta.ClienteNombre ?? "—")</em></div>
                            }
                            else
                            {
                                <div style="font-size: 1rem;"><strong>@(printVenta.ClienteNombre ?? "Consumidor final")</strong></div>
                            }
                            @{
                                var lineas = new List<string>();
                                if (!string.IsNullOrWhiteSpace(printVenta.ClienteCuit)) lineas.Add("CUIT/DNI: " + printVenta.ClienteCuit);
                                if (!string.IsNullOrWhiteSpace(printVenta.ClienteDireccion)) lineas.Add(printVenta.ClienteDireccion!);
                                var locCli = string.Join(" - ",
                                    new[] { printVenta.ClienteLocalidad, printVenta.ClienteCiudad, printVenta.ClienteCp }
                                        .Where(x => !string.IsNullOrWhiteSpace(x)));
                                if (!string.IsNullOrEmpty(locCli)) lineas.Add(locCli);
                            }
                            @if (lineas.Count > 0)
                            {
                                <div style="font-size: 0.82rem; color: #4b5563; margin-top: 0.2rem; line-height: 1.45;">
                                    @foreach (var l in lineas) { <div>@l</div> }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(printVenta.ClienteTelefono))
                            {
                                var tel = printVenta.ClienteTelefono!;
                                var telDigits = new string(tel.Where(char.IsDigit).ToArray());
                                <div style="margin-top: 0.2rem; font-size: 0.82rem;">
                                    <strong>Tel:</strong>
                                    @if (!string.IsNullOrEmpty(telDigits))
                                    {
                                        <a href="@BuildClienteWhatsappLink(tel)" target="_blank"
                                           style="color: #25D366; font-weight: 700; text-decoration: none; margin-left: 0.2rem;"
                                           title="Abrir WhatsApp con el cliente">
                                            📱 @tel
                                        </a>
                                    }
                                    else
                                    {
                                        <span>@tel</span>
                                    }
                                </div>
                            }
                        </div>
                        <div style="display: flex; flex-direction: column; gap: 0.25rem; align-items: flex-end;">
                            @if (printVenta.ClienteTipo == "BAR")
                            { <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dbeafe; color:#1e40af; border-radius:999px; font-size:0.72rem; font-weight:700;">🍺 BAR</span> }
                            else
                            { <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dcfce7; color:#166534; border-radius:999px; font-size:0.72rem; font-weight:700;">🏢 Comercial</span> }
                            <span style="font-size: 0.78rem; color: #6b7280;"><strong>Cond. IVA:</strong> @CondicionIvaLabel(printVenta.CondicionIva)</span>
                        </div>
                    </div>
                </div>

                @* Tabla items *@
                <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; margin-top: 0.6rem;">
                    <thead>
                        <tr style="background: #f3f4f6;">
                            <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: center; width: 70px;">Cant.</th>
                            <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: left;">Producto</th>
                            <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: center; width: 90px;">Formato</th>
                            <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: right; width: 110px;">P. Unitario</th>
                            <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: right; width: 70px;">Desc.</th>
                            <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: right; width: 130px;">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in printVenta.Items)
                        {
                            <tr>
                                @{
                                    // Si es BULTO, expandimos cant × UxB para que el deposito vea el TOTAL real de unidades.
                                    var cantPrintReal = CantidadParaMostrar(i.ProductoId ?? 0, i.Formato, i.Cantidad);
                                    var fmtPrintReal = FormatoParaMostrar(i.ProductoId ?? 0, i.Formato);
                                    var precioPrintReal = PrecioUnitarioParaMostrar(i.ProductoId ?? 0, i.Formato, i.PrecioUnitario);
                                }
                                <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: center; font-weight: 700;">@cantPrintReal</td>
                                <td style="border: 1px solid #d1d5db; padding: 4px 8px;">
                                    @{
                                        var skuPrint = productos?.FirstOrDefault(p => p.Id == i.ProductoId)?.Sku;
                                    }
                                    @if (!string.IsNullOrEmpty(skuPrint))
                                    {
                                        <span style="font-family:monospace; font-size:0.78rem; color:#1d4ed8; font-weight:700; margin-right:0.4rem;">@skuPrint</span>
                                    }
                                    <strong>@i.ProductoNombre</strong>
                                    @if (i.EsDoyPack)
                                    {
                                        <strong style="margin-left: 0.3rem; color: #1e3a8a;">d.p.</strong>
                                    }
                                    else if (i.EsEnvasePlateado)
                                    {
                                        <strong style="margin-left: 0.3rem; color: #52525b;">env. plat.</strong>
                                    }
                                    @if (!string.IsNullOrEmpty(i.Molienda))
                                    {
                                        <span style="color: #6b7280; font-size: 0.82rem;"> — @i.Molienda</span>
                                    }
                                </td>
                                <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: center;"><span style="display:inline-block; padding:0.1rem 0.5rem; background:#f3f4f6; border:1px dashed #9ca3af; border-radius:12px; font-family:Georgia,serif; font-style:italic; color:#4b5563;">@fmtPrintReal</span></td>
                                <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: right;">$@FormatMoney(precioPrintReal)</td>
                                <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: right; color: @(i.DescuentoPct > 0 ? "#b91c1c" : "#9ca3af");">
                                    @(i.DescuentoPct > 0 ? "-" + i.DescuentoPct.ToString("0.##") + "%" : "—")
                                </td>
                                <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: right; font-weight: 700;">$@FormatMoney(i.Subtotal)</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* Totales — discriminacion de IVA segun el tipo de comprobante *@
                @{
                    bool esProforma = printVenta.TipoComprobante == "PRO";
                    bool esFA = printVenta.TipoComprobante == "FA";
                    bool esFB = printVenta.TipoComprobante == "FB";
                    bool esFC = printVenta.TipoComprobante == "FC";
                    // Precios cargados son NETO (sin IVA). Para FA/FB se suma 21%. Para FC y X/PRO no se suma (informativo).
                    bool sumarIvaArriba = esFA || esFB;
                    decimal netoSinIva = printVenta.Total;
                    decimal iva21 = sumarIvaArriba || esProforma
                        ? Math.Round(netoSinIva * 0.21m, 2, MidpointRounding.AwayFromZero)
                        : 0m;
                    decimal totalConIva = netoSinIva + iva21;
                }
                <div style="display: flex; justify-content: flex-end; margin-top: 0.5rem;">
                    <div style="min-width: 340px; border: 1px solid #d1d5db; padding: 0.6rem 0.8rem;">
                        <div style="display: flex; justify-content: space-between; font-size: 0.9rem; padding: 0.15rem 0;">
                            <span>Subtotal @(esProforma || esFA || esFB ? "(neto sin IVA)" : ""):</span>
                            <strong>$@FormatMoney(printVenta.Subtotal)</strong>
                        </div>
                        @if (printVenta.Descuento > 0)
                        {
                            <div style="display: flex; justify-content: space-between; font-size: 0.9rem; padding: 0.15rem 0; color: #dc2626;">
                                <span>Descuento:</span><span>− $@FormatMoney(printVenta.Descuento)</span>
                            </div>
                        }
                        @if (esFA || esFB || esProforma)
                        {
                            @* "Neto gravado" solo si hay descuento — sino es identico al Subtotal de arriba (redundante). *@
                            @if (printVenta.Descuento > 0)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 0.9rem; padding: 0.15rem 0;">
                                    <span>Neto gravado:</span><strong>$@FormatMoney(netoSinIva)</strong>
                                </div>
                            }
                            <div style="display: flex; justify-content: space-between; font-size: 0.9rem; padding: 0.15rem 0; color: #1d4ed8;">
                                <span>IVA 21%@(esProforma ? " (estimado)" : ""):</span><span>$@FormatMoney(iva21)</span>
                            </div>
                            <hr style="margin: 0.4rem 0; border: none; border-top: 2px solid #1f2937;" />
                            <div style="display: flex; justify-content: space-between; font-size: 1.15rem; font-weight: 800; color: #059669;">
                                <span>TOTAL c/IVA:</span><span>$@FormatMoney(totalConIva)</span>
                            </div>
                        }
                        else
                        {
                            <hr style="margin: 0.4rem 0; border: none; border-top: 2px solid #1f2937;" />
                            <div style="display: flex; justify-content: space-between; font-size: 1.15rem; font-weight: 800; color: #059669;">
                                <span>TOTAL:</span><span>$@FormatMoney(printVenta.Total)</span>
                            </div>
                        }
                        <hr style="margin: 0.4rem 0; border: none; border-top: 1px dashed #d1d5db;" />
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:0.5rem 0.7rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; gap:0.5rem;">
                            <div>
                                <div style="font-size:0.7rem; color:#6b7280; text-transform:uppercase; font-weight:700; letter-spacing:0.5px;">Forma de pago</div>
                                <div style="font-size:1.05rem; font-weight:800; color:#1f2937;">@CondicionPagoLabel(printVenta.CondicionPago)</div>
                            </div>
                            @if (printVenta.IsPaid)
                            {
                                <div style="padding:0.35rem 0.8rem; background:#dcfce7; color:#166534; border:1px solid #86efac; border-radius:6px; font-weight:800; font-size:0.9rem;">✅ PAGADA</div>
                            }
                            else
                            {
                                <div style="padding:0.35rem 0.8rem; background:#fef3c7; color:#92400e; border:1px solid #fcd34d; border-radius:6px; font-weight:800; font-size:0.9rem;">⏳ PENDIENTE</div>
                            }
                        </div>
                    </div>
                </div>
                @if (esProforma)
                {
                    <div style="margin-top: 0.4rem; padding: 0.4rem 0.7rem; background: #fef3c7; border: 1px solid #f59e0b; border-radius: 6px; font-size: 0.78rem; color: #92400e;">
                        ⚠ <strong>Proforma — preview de cómo quedaría con IVA cuando emitas factura por ARCA.</strong>
                        Para esta vista se aplica 21% al neto. Cuando se emita la factura real, los productos con IVA 10,5% (alimentos) se discriminarán por separado.
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(printVenta.ClienteDomicilioEntrega))
                {
                    <div style="margin-top: 0.5rem; border: 1px solid #d1d5db; padding: 0.5rem 0.7rem; font-size: 0.85rem; background: #f9fafb;">
                        <strong>🚚 Entrega en:</strong> @printVenta.ClienteDomicilioEntrega
                    </div>
                }

                @if (!string.IsNullOrEmpty(printVenta.ClienteComentariosComprobante))
                {
                    <div style="margin-top: 0.5rem; border-left: 4px solid #f59e0b; background: #fef3c7; padding: 0.5rem 0.7rem; font-size: 0.85rem; color: #78350f;">
                        <strong>📝 @printVenta.ClienteComentariosComprobante</strong>
                    </div>
                }

                @if (!string.IsNullOrEmpty(printVenta.Observaciones))
                {
                    <div style="margin-top: 0.5rem; border: 1px solid #d1d5db; padding: 0.5rem 0.7rem; font-size: 0.85rem;">
                        <strong>Observaciones:</strong> @printVenta.Observaciones
                    </div>
                }

                @* Dias de visita / reparto al pie (clickeable también ya emitido — se autoguarda) *@
                @{
                    var diasActivos = (printVenta.WeekDays ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim().ToUpperInvariant()).ToHashSet();
                }
                <div style="margin-top: 0.7rem; border: 1px solid #d1d5db; padding: 0.4rem 0.6rem; display: flex; gap: 0.3rem; align-items: center; flex-wrap: wrap; justify-content: center;">
                    <span style="font-size: 0.7rem; color: #6b7280; margin-right: 0.3rem;">Días de visita / reparto:</span>
                    @foreach (var d in AllWeekDays)
                    {
                        var on = diasActivos.Contains(d);
                        var bg = on ? "#1f2937" : "white";
                        var fg = on ? "white" : "#374151";
                        var bd = on ? "#1f2937" : "#d1d5db";
                        <button type="button"
                                @onclick="() => ToggleViewerDay(d)"
                                title="Click para tildar/destildar"
                                style="display: inline-flex; align-items: center; justify-content: center; padding: 0.2rem 0.5rem; border: 1px solid @bd; background: @bg; color: @fg; border-radius: 4px; font-weight: 700; font-size: 0.72rem; cursor: pointer; min-width: 36px; user-select: none; -webkit-print-color-adjust: exact; print-color-adjust: exact;">
                            @d
                        </button>
                    }
                </div>

                @* Entrega responsable: solo se muestra si esta cargado. *@
                @if (!string.IsNullOrWhiteSpace(printVenta.EntregaPor))
                {
                    <div style="margin-top: 0.4rem; border: 1px solid #d1d5db; padding: 0.4rem 0.6rem; display: flex; gap: 0.3rem; align-items: center; flex-wrap: wrap; justify-content: center;">
                        <span style="font-size: 0.7rem; color: #6b7280;">Entrega:</span>
                        <span style="font-size: 0.85rem; font-weight: 700; color: #1f2937;">🚚 @printVenta.EntregaPor</span>
                    </div>
                }

                <div style="margin-top: 0.6rem; text-align: center; font-size: 0.78rem; color: #6b7280; border-top: 1px dashed #d1d5db; padding-top: 0.5rem;">
                    Gracias por tu compra ☕
                    @if (HasWhatsapp)
                    {
                        <span> · <a href="@WhatsappLink" target="_blank" style="color: #25D366; font-weight: 700;">📱 Contactanos por WhatsApp</a></span>
                    }
                </div>
                </div>  @* cierra el wrapper display:none del HTML legacy *@
            </div>
        </div>
    </div>
}

@if (convirtiendo is not null)
{
    <div class="modal-overlay" @onclick="CloseConvertirAFacturaModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 520px;">
            <div class="modal-header" style="background: #7c3aed; color: white;">
                <h4 style="margin: 0;">📈 Convertir a factura con CAE</h4>
                <button class="btn-close" @onclick="CloseConvertirAFacturaModal" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Vas a convertir <strong>@convirtiendo.Numero</strong> (@(convirtiendo.TipoComprobante == "PRO" ? "Proforma" : "Cotización")) en una factura real emitida por ARCA con CAE.</p>
                <p style="font-size: 0.85rem; color: #6b7280;">
                    Se crea una <strong>venta nueva</strong> (con número nuevo) que se vincula a esta proforma como origen.
                    Los items y montos se copian exactamente. La proforma queda marcada como "facturada".
                </p>
                <div class="form-row" style="margin-top: 0.8rem;">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Tipo de factura</label>
                        <select class="form-input" @bind="convertirTipoFactura">
                            <option value="FB">Factura B (para CF / Monotributo)</option>
                            <option value="FA">Factura A (para Responsable Inscripto)</option>
                            <option value="FC">Factura C (si el emisor es Monotributo)</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Cond. IVA del receptor</label>
                        <select class="form-input" @bind="convertirCondIva">
                            <option value="RI">Responsable Inscripto</option>
                            <option value="MO">Monotributo</option>
                            <option value="EX">Exento</option>
                            <option value="CF">Consumidor final</option>
                        </select>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(convertirError))
                {
                    <div class="form-error" style="margin-top: 0.6rem;">@convertirError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseConvertirAFacturaModal" disabled="@convirtiendoLoading">Cancelar</button>
                <button class="btn" style="background: #7c3aed; color: white;" @onclick="DoConvertirAFactura" disabled="@convirtiendoLoading">
                    @(convirtiendoLoading ? "Emitiendo..." : "📈 Emitir factura con CAE")
                </button>
            </div>
        </div>
    </div>
}

@* ════════ Modal de reenvio de comprobante ya emitido ════════
   Se abre desde el visor del comprobante (boton "Enviar al cliente"). Muestra
   los mismos 3 canales del modal de carga (Mail / WhatsApp Web / WhatsApp Interno)
   pero dispara contra una venta YA emitida. Reusa Api.SendCafeVentaEmailAsync y
   SendCafeVentaWhatsappInternoAsync. z-index alto para quedar arriba del visor. *@
@if (reenvioVenta is not null)
{
    <div class="modal-overlay" style="z-index: 9200;" @onclick="CloseReenvio">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 540px;">
            <div class="modal-header" style="background: #ecfdf5;">
                <h3 style="margin: 0; color: #065f46;">📤 Enviar comprobante @reenvioVenta.Numero</h3>
                <button class="btn-close" @onclick="CloseReenvio">&times;</button>
            </div>
            <div class="modal-body" style="padding: 1rem 1.2rem;">
                <p style="margin: 0 0 0.8rem; color: #4b5563; font-size: 0.88rem;">
                    Tildá los canales por los que querés mandar el comprobante.
                    Si los destinatarios están vacíos, completalos a mano.
                </p>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem;">
                        <input type="checkbox" @bind="reenvioEmail" />
                        <span>📧 <strong>Por Mail</strong></span>
                        <input type="email" class="form-input" placeholder="email@cliente.com"
                               style="flex: 1; font-size: 0.82rem; padding: 0.3rem 0.5rem;"
                               @bind="reenvioEmailTo" disabled="@(!reenvioEmail)" />
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem;">
                        <input type="checkbox" @bind="reenvioWhatsappWeb" />
                        <span>📱 <strong>WhatsApp Web</strong> <span style="font-size: 0.72rem; color: #6b7280;">(abre, vos confirmas)</span></span>
                        <input type="tel" class="form-input" placeholder="541112345678"
                               style="flex: 1; font-size: 0.82rem; padding: 0.3rem 0.5rem;"
                               @bind="reenvioWhatsappPhone" disabled="@(!reenvioWhatsappWeb)" />
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem;">
                        <input type="checkbox" @bind="reenvioWhatsappInterno" />
                        <span>🚀 <strong>WhatsApp Interno</strong> <span style="font-size: 0.72rem; color: #6b7280;">(auto + PDF)</span></span>
                        <input type="tel" class="form-input" placeholder="541112345678"
                               style="flex: 1; font-size: 0.82rem; padding: 0.3rem 0.5rem;"
                               @bind="reenvioWhatsappPhone" disabled="@(!reenvioWhatsappInterno)" />
                    </label>
                </div>
            </div>
            <div class="modal-footer">
