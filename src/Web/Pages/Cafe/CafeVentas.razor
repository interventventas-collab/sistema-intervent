    /// <summary>El operador edita el "P. Unit." a mano. Si el valor difiere del precio del
    /// catálogo, se setea como override. Si vuelve al precio del catálogo, se limpia el override.</summary>
    private async Task OnItemPrecioOverrideChanged(int idx, string? value)
    {
        if (idx < 0 || idx >= formItems.Count || cotizacion is null || idx >= cotizacion.Items.Count) return;
        if (!string.IsNullOrWhiteSpace(value)
            && decimal.TryParse(value.Replace(",", "."), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v) && v >= 0m)
        {
            // Si el valor que tipeó coincide con el del catálogo, NO lo marcamos como override
            // (no hay nada que pisar). Si difiere, sí.
            var precioCatalogo = cotizacion.Items[idx].PrecioUnitario;
            if (Math.Abs(v - precioCatalogo) < 0.005m)
                formItems[idx].PrecioUnitarioOverride = null;
            else
                formItems[idx].PrecioUnitarioOverride = Math.Round(v, 2, MidpointRounding.AwayFromZero);
        }
        else
        {
            formItems[idx].PrecioUnitarioOverride = null;
        }
        await Cotizar();
    }

    /// <summary>Vuelve al precio del catálogo (sin override).</summary>
    private async Task ClearItemPrecioOverride(int idx)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        formItems[idx].PrecioUnitarioOverride = null;
        await Cotizar();
    }

    // ═══════════════════════════════════════════════════════════════════════
    //  2026-06-08: Handlers para fila "combo agrupada" en la grilla
    // ═══════════════════════════════════════════════════════════════════════
    //  Cuando el operador toca un valor en la fila del combo (cantidad, precio,
    //  descuento, eliminar), se propaga al grupo de items componentes de ese
    //  combo en formItems. Los componentes siguen viviendo como items separados
    //  (para que stock se descuente bien), pero el operador los ve como uno solo.

    private List<int> GetIndicesGrupoCombo(int comboId)
    {
        var res = new List<int>();
        for (int gi = 0; gi < formItems.Count; gi++)
            if (formItems[gi].ComboOrigenId == comboId) res.Add(gi);
        return res;
    }

    /// <summary>Cambia la cantidad del combo entero: escala la cantidad de cada componente
    /// usando la relación original "1 componente por pack". Si un componente tenía cantidad>1
    /// originalmente (combo con 2 unidades de algo), se respeta el ratio.</summary>
    private async Task OnComboCantidadChanged(int comboId, string? value)
    {
        var idxs = GetIndicesGrupoCombo(comboId);
        if (idxs.Count == 0) return;
        int nuevaCantPacks = 1;
        if (!string.IsNullOrWhiteSpace(value)) int.TryParse(value, out nuevaCantPacks);
        nuevaCantPacks = Math.Max(1, nuevaCantPacks);
        // El "primer item" del grupo representa 1 pack del combo. Sacamos el ratio de cada
        // componente respecto al primer item para preservar la composición.
        var basePacks = Math.Max(1, formItems[idxs[0]].Cantidad);
        // Si la cantidad base ya es la deseada, no hacemos nada
        if (basePacks == nuevaCantPacks) return;
        foreach (var ix in idxs)
        {
            var ratio = formItems[ix].Cantidad / (decimal)basePacks;
            formItems[ix].Cantidad = Math.Max(1, (int)Math.Round(ratio * nuevaCantPacks, MidpointRounding.AwayFromZero));
        }
        await Cotizar();
    }

    /// <summary>Pisa el precio unitario del combo. Lo distribuye proporcionalmente entre los
    /// componentes según su subtotal actual (para preservar el peso relativo).
    /// Si todos los subtotales son 0, reparte en partes iguales.</summary>
    private async Task OnComboPrecioChanged(int comboId, string? value)
    {
        var idxs = GetIndicesGrupoCombo(comboId);
        if (idxs.Count == 0 || cotizacion is null) return;
        if (string.IsNullOrWhiteSpace(value)
            || !decimal.TryParse(value.Replace(",", "."), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var nuevoPU) || nuevoPU < 0m)
            return;
        var cantPacks = Math.Max(1, formItems[idxs[0]].Cantidad);
        var nuevoTotalCombo = Math.Round(nuevoPU * cantPacks, 2, MidpointRounding.AwayFromZero);
        // Suma actual de subtotales del grupo (usando cotización para tener los valores actuales)
        decimal subtotalActual = 0m;
        foreach (var ix in idxs)
            if (ix < cotizacion.Items.Count) subtotalActual += cotizacion.Items[ix].Subtotal;
        if (subtotalActual <= 0m)
        {
            // Distribución equitativa entre componentes (cada uno recibe nuevoTotalCombo / N / cant)
            var porComp = Math.Round(nuevoTotalCombo / idxs.Count, 2, MidpointRounding.AwayFromZero);
            foreach (var ix in idxs)
            {
                var cant = Math.Max(1, formItems[ix].Cantidad);
                formItems[ix].PrecioUnitarioOverride = Math.Round(porComp / cant, 2, MidpointRounding.AwayFromZero);
            }
        }
        else
        {
            var ratio = nuevoTotalCombo / subtotalActual;
            foreach (var ix in idxs)
            {
                if (ix >= cotizacion.Items.Count) continue;
                var subAnt = cotizacion.Items[ix].Subtotal;
                var subNuevo = subAnt * ratio;
                var cant = Math.Max(1, formItems[ix].Cantidad);
                var puNuevo = Math.Round(subNuevo / cant, 2, MidpointRounding.AwayFromZero);
                // Si quedó igual al precio del catálogo, limpia override
                var pCat = cotizacion.Items[ix].PrecioUnitario;
                if (Math.Abs(puNuevo - pCat) < 0.005m && !formItems[ix].PrecioUnitarioOverride.HasValue)
                    formItems[ix].PrecioUnitarioOverride = null;
                else
                    formItems[ix].PrecioUnitarioOverride = puNuevo;
            }
        }
        await Cotizar();
    }

    /// <summary>Quita el override de precio en todos los componentes del combo.
    /// Volvemos al precio del catálogo del componente (precio individual de cada pieza).</summary>
    private async Task ClearComboPrecioOverride(int comboId)
    {
        var idxs = GetIndicesGrupoCombo(comboId);
        if (idxs.Count == 0) return;
        foreach (var ix in idxs) formItems[ix].PrecioUnitarioOverride = null;
        await Cotizar();
    }

    /// <summary>Aplica el mismo descuento % a todos los componentes del combo.</summary>
    private async Task OnComboDescuentoChanged(int comboId, string? value)
    {
        var idxs = GetIndicesGrupoCombo(comboId);
        if (idxs.Count == 0) return;
        decimal d = 0m;
        if (!string.IsNullOrWhiteSpace(value))
            decimal.TryParse(value.Replace(",", "."), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out d);
        d = Math.Clamp(d, 0m, 100m);
        foreach (var ix in idxs) formItems[ix].DescuentoPct = d;
        await Cotizar();
    }

    /// <summary>Elimina TODOS los componentes del combo en una sola acción.</summary>
    private async Task RemoveCombo(int comboId)
    {
        var idxs = GetIndicesGrupoCombo(comboId);
        if (idxs.Count == 0) return;
        // Borrar de mayor a menor para no desfasar índices
        foreach (var ix in idxs.OrderByDescending(x => x))
            formItems.RemoveAt(ix);
        await Cotizar();
    }

    private async Task ToggleItemDoyPack(int idx)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        formItems[idx].EsDoyPack = !formItems[idx].EsDoyPack;
        await Cotizar();
    }

    /// <summary>Elige el tipo de envase. Solo uno puede estar prendido (negro = ambos false).</summary>
    private async Task SetItemEnvase(int idx, bool doyPack, bool plateado)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        formItems[idx].EsDoyPack = doyPack;
        formItems[idx].EsEnvasePlateado = plateado;
        await Cotizar();
    }

    /// <summary>Variante del setter que recibe el value del dropdown ("NEGRO" | "PLATEADO" | "DOY_PACK").</summary>
    private async Task SetItemEnvaseFromString(int idx, string val)
    {
        if (idx < 0 || idx >= formItems.Count) return;
        switch (val)
        {
            case "DOY_PACK":
                formItems[idx].EsDoyPack = true; formItems[idx].EsEnvasePlateado = false; break;
            case "PLATEADO":
                formItems[idx].EsDoyPack = false; formItems[idx].EsEnvasePlateado = true; break;
            default: // NEGRO
                formItems[idx].EsDoyPack = false; formItems[idx].EsEnvasePlateado = false; break;
        }
        await Cotizar();
    }

    private async Task Cotizar()
    {
        if (formItems.Count == 0) { cotizacion = null; return; }
        try
        {
            cotizacion = await Api.CotizarCafeAsync(new CafeCotizarRequest
            {
                ClienteId = formClienteId > 0 ? formClienteId : null,
                ClienteTipo = formClienteTipo,
                Items = formItems,
                Descuento = formDescuento,
                // 2026-06-18: al editar una venta, le decimos al backend que NO cuente su propio
                // stock reservado como conflicto. Sin esto, una cotización X que ya descontó stock
                // tiraba "stock insuficiente" al intentar editarla o convertirla a Factura.
                EditandoVentaId = editingVentaId
            });
        }
        catch (Exception ex) { ToastService.Error("Error al cotizar: " + ex.Message); }
        // Auto-save del borrador después de cada cotización — ahí tenemos el total fresco
        // para mostrar en el banner si después se restaura. Fire-and-forget.
        _ = SaveBorradorAsync();
    }

