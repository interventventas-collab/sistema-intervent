    /// <summary>Expande el combo en N items (uno por linea del combo, multiplicados por addComboCantidad).
    /// Si el mismo prod+formato+molienda ya existe, suma cantidades.</summary>
    private async Task AddCombo()
    {
        if (addComboId <= 0 || addComboCantidad <= 0) return;
        var combo = combos?.FirstOrDefault(c => c.Id == addComboId);
        if (combo is null || combo.Items.Count == 0) return;

        foreach (var ci in combo.Items)
        {
            var qty = ci.Cantidad * addComboCantidad;
            var existing = formItems.FirstOrDefault(i =>
                i.ProductoId == ci.ProductoId &&
                i.Formato == ci.Formato &&
                (i.Molienda ?? "") == (ci.Molienda ?? "") &&
                i.EsDoyPack == ci.EsDoyPack);
            if (existing is not null)
            {
                existing.Cantidad += qty;
            }
            else
            {
                formItems.Add(new CafeCotizarItemRequest
                {
                    ProductoId = ci.ProductoId,
                    Formato = ci.Formato,
                    Cantidad = qty,
                    // Si el combo no especifica molienda, default a EN GRANOS para cafe.
                    Molienda = !string.IsNullOrEmpty(ci.Molienda) ? ci.Molienda : DefaultMolienda(ci.ProductoId),
                    EsDoyPack = ci.EsDoyPack
                });
            }
        }

        ToastService.Success($"Combo '{combo.Nombre}' agregado ({combo.Items.Count} producto{(combo.Items.Count == 1 ? "" : "s")})");
        addComboId = 0; addComboCantidad = 1;
        comboSearch = ""; comboSearchOpen = false;
        await Cotizar();
    }

