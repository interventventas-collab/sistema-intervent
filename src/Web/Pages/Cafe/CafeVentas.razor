    // ===== Modal Convertir Proforma → Factura =====
    private CafeVentaDto? convirtiendo;
    private string convertirTipoFactura = "FB";
    private string convertirCondIva = "RI";
    private bool convirtiendoLoading;
    private string? convertirError;

    private void OpenConvertirAFacturaModal(CafeVentaDto v)
    {
        convirtiendo = v;
        // Sugerimos FB por default (lo más común). El usuario puede elegir FA si el receptor es RI.
        convertirTipoFactura = "FB";
        // La condición IVA del receptor: si la venta original tiene una válida la usamos, sino RI default
        convertirCondIva = !string.IsNullOrWhiteSpace(v.CondicionIva) && v.CondicionIva != "CF" ? v.CondicionIva : "RI";
        convertirError = null;
    }

    private void CloseConvertirAFacturaModal() { convirtiendo = null; convertirError = null; }

    private async Task DoConvertirAFactura()
    {
        if (convirtiendo is null) return;
        convirtiendoLoading = true; convertirError = null;
        try
        {
            var nuevaVenta = await Api.ConvertirCafeVentaAFacturaAsync(convirtiendo.Id, new ConvertirAFacturaRequest
            {
                TipoFactura = convertirTipoFactura,
                CondicionIva = convertirCondIva
            });
            if (nuevaVenta is null) { convertirError = "No se pudo convertir."; return; }

            if (nuevaVenta.ArcaEstado == "autorizado")
                ToastService.Success($"✓ Factura {nuevaVenta.Numero} emitida — CAE {nuevaVenta.ArcaCae}");
            else if (nuevaVenta.ArcaEstado == "pendiente")
                ToastService.Error($"Factura {nuevaVenta.Numero} creada pero ARCA rechazó: {nuevaVenta.ArcaError}");
            else
                ToastService.Success($"Venta {nuevaVenta.Numero} creada");

            convirtiendo = null;
            await Load();
        }
        catch (Exception ex)
        {
            convertirError = "Error: " + ex.Message;
        }
        finally { convirtiendoLoading = false; }
    }

    /// <summary>Pide al backend un payload con los datos del comprobante a duplicar y abre
    /// el modal de Nueva Venta pre-cargado con esos datos. La venta NUEVA se crea recién
    /// cuando el usuario aprieta "Emitir comprobante" en el modal (descuenta stock + ARCA si corresponde).</summary>
    private async Task DuplicarComprobante(CafeVentaDto v)
    {
        try
        {
            var payload = await Api.DuplicarCafeVentaAsync(v.Id);
            if (payload is null)
            {
                ToastService.Error("No se pudo obtener los datos para duplicar.");
                return;
            }
            // Limpiar el form (como ShowCreate) pero con los datos del payload
            editingVentaId = null; editingVentaNumero = "";
            duplicadoDeNumero = payload.OrigenNumero;
            unpaidPrevSales = new(); topProductsForClient = new(); includePrevBalanceInNotes = true;
            formClienteId = payload.ClienteId ?? 0;
            formClienteTipo = payload.ClienteTipo;
            clienteSearch = ""; clienteSearchOpen = false;
            formFecha = DateTime.Today; // fecha de HOY, no la del original
            formDescuento = 0;
            formObservaciones = payload.Observaciones ?? "";
            formTipoComprobante = payload.TipoComprobante;
            formCondicionIva = payload.CondicionIva;
            formCondicionPago = payload.CondicionPago;
            formItems = payload.Items.ToList();
            cotizacion = null;
            addProductoId = 0; addFormato = "1KG"; addCantidad = 1;
            productoSearch = ""; productoSearchOpen = false;
            addMode = "PRODUCTO";
            addComboId = 0; addComboCantidad = 1;
            comboSearch = ""; comboSearchOpen = false;
            formWeekDays = (payload.WeekDays ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(s => s.Trim().ToUpperInvariant()).ToHashSet();
            formEnRadar = payload.EnRadar;
            formRetira = payload.Retira;
            formIsPaid = false; // empezás impago, el cobro de la nueva es independiente
            // 2026-05-30: solo OSMAR arranca con "Enviar a IMPRIMIR PEDIDOS" tildado.
            envioDrive = string.Equals(Operator.Current ?? "", "OSMAR", StringComparison.OrdinalIgnoreCase);
            formError = null; showForm = true;
            // Cargar info del cliente (productos top, deudas, condIva default si cambió)
            if (formClienteId > 0) await OnClienteChanged();
            else await Cotizar();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al duplicar: " + ex.Message);
        }
    }

    private async Task OnClienteChanged()
    {
        if (formClienteId > 0)
        {
            var c = clientes?.FirstOrDefault(x => x.Id == formClienteId);
            if (c is not null)
            {
                formClienteTipo = c.Tipo;
                // Si el cliente tiene cargada su Condición IVA Default en la ficha, la usamos
                // como sugerencia en este comprobante. El usuario siempre puede cambiarla a mano.
                if (!string.IsNullOrWhiteSpace(c.CondicionIvaDefault))
                    formCondicionIva = c.CondicionIvaDefault!;
                // Auto-poblar destinatarios del panel "Enviar al cliente" con los datos del cliente.
                envioEmailTo = c.Email ?? "";
                envioWhatsappPhone = c.Telefono ?? "";
            }
        }
        else
        {
            // Sin cliente seleccionado: limpiar destinatarios.
            envioEmailTo = "";
            envioWhatsappPhone = "";
        }
        // FIX 2026-05-28: si el usuario cambia el cliente, sacar de Observaciones cualquier línea
        // "Saldo anterior: $X (comprobantes: Y)" que haya quedado del cliente ANTERIOR. Si no
        // limpiamos, se arrastra la deuda de otro cliente a este comprobante (bug que causó
        // que CAFE-2026-0314 saliera con la deuda de CAFE-2026-0313 de otro cliente).
        // El saldo anterior del cliente NUEVO se vuelve a inyectar limpio al emitir, si corresponde.
        if (!string.IsNullOrWhiteSpace(formObservaciones))
        {
            // Separa por saltos de línea Y por " · " (que es el separador típico que usa Cotizar()).
            var partes = formObservaciones
                .Split(new[] { "\n", "\r\n", " · " }, StringSplitOptions.None)
                .Where(p => !p.TrimStart().StartsWith("Saldo anterior", StringComparison.OrdinalIgnoreCase))
                .Select(p => p.Trim())
                .Where(p => !string.IsNullOrEmpty(p))
                .ToList();
            formObservaciones = string.Join("\n", partes);
        }
        RecomputeUnpaidPrevSales();
        await LoadTopProductsForClient();
        await Cotizar();
    }

    /// <summary>Activa el modo "Venta Rápida": cliente ad-hoc, no del catálogo. Limpia el cliente
    /// seleccionado, fuerza el tipo de comprobante a X (Remito interno) y abre los inputs de datos
    /// del cliente para llenar a mano.</summary>
