    /// <summary>Filtra clientes por código / nombre / cuit / telefono / email.</summary>
    private IEnumerable<CafeClienteDto> ClientesMatching(string q)
    {
        if (clientes is null) return Enumerable.Empty<CafeClienteDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return clientes;
        bool h(string? s) => s.MatchesSearch(t);
        return clientes.Where(c => c.IsActive
            && (h(c.Codigo) || h(c.Nombre) || h(c.RazonSocial) || h(c.Cuit)
                || h(c.Telefono) || h(c.Email)
                || h(c.Direccion) || h(c.Localidad) || h(c.Ciudad) || h(c.Cp)
                || h(c.DomicilioEntrega)));
    }

