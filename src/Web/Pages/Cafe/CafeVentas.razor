    /// <summary>Filtra productos activos + visibles en ventas por SKU / código de barras / nombre / marca.
    /// IsVisibleEnVentas=false oculta productos que solo existen como componentes de combos MeLi (no se venden sueltos).</summary>
    private IEnumerable<CafeProductoDto> ProductosMatching(string q)
    {
        if (productos is null) return Enumerable.Empty<CafeProductoDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return productos.Where(p => p.IsActive && p.IsVisibleEnVentas);
        bool h(string? s) => s.MatchesSearch(t);
        return productos.Where(p => p.IsActive && p.IsVisibleEnVentas && (h(p.Sku) || h(p.Barcode) || h(p.Nombre) || h(p.Marca)));
    }

    /// <summary>2026-06-01: Combos marcados como "EsCompuesto=true" tambien aparecen en
    /// el buscador de la pestana Producto. Aceleran la venta de items individuales armados
    /// (ej: cesto C9172NEG = recipiente + tapa) sin tener que cambiar a la pestana Combo.</summary>
    private IEnumerable<CafeComboDto> CompuestosMatching(string q)
    {
        if (combos is null) return Enumerable.Empty<CafeComboDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return Enumerable.Empty<CafeComboDto>();
        bool h(string? s) => s.MatchesSearch(t);
        return combos.Where(c => c.IsActive && c.EsCompuesto && (
            h(c.Sku) || h(c.Nombre) || h(c.Descripcion)));
    }

    /// <summary>2026-06-01: agrega un combo "compuesto" como si se hubiera elegido desde
    /// la pestana Combo. Reusa la logica de AddCombo (expande en items).</summary>
    private async Task SelectCompuestoDesdeProducto(int comboId)
    {
        addComboId = comboId;
        addComboCantidad = 1;
        productoSearch = "";
