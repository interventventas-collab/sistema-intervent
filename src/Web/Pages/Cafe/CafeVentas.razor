    /// <summary>Abre el modal de reenvio precargando email/telefono desde el cliente
    /// de la venta. Si la venta no tiene cliente o el cliente no tiene email/telefono,
    /// los campos quedan vacios para que el operador los complete a mano.</summary>
    private void OpenReenvio(CafeVentaDto? v)
    {
        if (v is null) return;
        reenvioVenta = v;
        reenvioEmail = false;
        reenvioWhatsappWeb = false;
        reenvioWhatsappInterno = false;
        reenvioSending = false;
        // Buscar email del cliente en el dict en memoria; si no esta, queda vacio.
        var cli = v.ClienteId.HasValue ? clientes?.FirstOrDefault(x => x.Id == v.ClienteId.Value) : null;
        reenvioEmailTo = cli?.Email ?? "";
        reenvioWhatsappPhone = !string.IsNullOrWhiteSpace(v.ClienteTelefono)
            ? v.ClienteTelefono!
            : (cli?.Telefono ?? "");
    }

    private void CloseReenvio()
    {
        if (reenvioSending) return; // no cerrar mientras esta enviando
        reenvioVenta = null;
    }

    private void MarcarTodosReenvio()
    {
        var todosOn = reenvioEmail && reenvioWhatsappWeb && reenvioWhatsappInterno;
        reenvioEmail = !todosOn;
        reenvioWhatsappWeb = !todosOn;
        reenvioWhatsappInterno = !todosOn;
    }

    /// <summary>Ejecuta el reenvio segun los checkboxes tildados, contra la venta YA emitida.
    /// Email + WhatsApp Interno en paralelo (backend); WhatsApp Web abre wa.me en pestaña nueva.</summary>
    private async Task EjecutarReenvio()
    {
        if (reenvioVenta is null) return;
        if (!(reenvioEmail || reenvioWhatsappWeb || reenvioWhatsappInterno))
        {
            ToastService.Error("Tildá al menos un canal");
            return;
        }
        reenvioSending = true;
        try
        {
            var v = reenvioVenta;
            // Conseguir el token publico (lo genera si la venta es vieja y no tenia).
            var publicToken = await Api.EnsurePublicTokenAsync(v.Id);
            var publicUrl = !string.IsNullOrEmpty(publicToken)
                ? $"{Navigation.BaseUri.TrimEnd('/')}/comprobante/{publicToken}"
                : null;
            string MensajeWA() => publicUrl is not null
                ? $"Hola! Te paso el comprobante {v.Numero}:\n\n{publicUrl}\n\nCualquier cosa avisame. Gracias!"
                : $"Hola! Te paso el comprobante {v.Numero}. Cualquier cosa avisame. Gracias!";

            // 1) WhatsApp Web: abre wa.me con el mensaje (link incluido — no hace falta adjunto)
            if (reenvioWhatsappWeb && !string.IsNullOrWhiteSpace(reenvioWhatsappPhone))
            {
                var phone = new string(reenvioWhatsappPhone.Where(char.IsDigit).ToArray());
                if (phone.Length >= 8)
                {
                    var msg = Uri.EscapeDataString(MensajeWA());
                    try { await JS.InvokeVoidAsync("openInNewTab", $"https://wa.me/{phone}?text={msg}"); }
                    catch { }
                }
            }
            // 2) Email + WhatsApp Interno en paralelo (backend hace el laburo pesado)
            var tasks = new List<Task>();
            if (reenvioEmail && !string.IsNullOrWhiteSpace(reenvioEmailTo))
            {
                tasks.Add(Task.Run(async () =>
                {
                    try
                    {
                        var (sent, err) = await Api.SendCafeVentaEmailAsync(v.Id, reenvioEmailTo, publicUrl: publicUrl);
                        if (sent) ToastService.Success($"📧 Email enviado a {reenvioEmailTo}");
                        else ToastService.Error($"📧 Email falló: {err}");
                    }
                    catch (Exception ex) { ToastService.Error($"📧 Email error: {ex.Message}"); }
                }));
            }
            if (reenvioWhatsappInterno && !string.IsNullOrWhiteSpace(reenvioWhatsappPhone))
            {
                tasks.Add(Task.Run(async () =>
                {
                    try
                    {
                        var (sent, err) = await Api.SendCafeVentaWhatsappInternoAsync(v.Id, reenvioWhatsappPhone, caption: MensajeWA());
                        if (sent) ToastService.Success($"🚀 WhatsApp enviado a {reenvioWhatsappPhone}");
                        else ToastService.Error($"🚀 WhatsApp Interno falló: {err}");
                    }
                    catch (Exception ex) { ToastService.Error($"🚀 WhatsApp Interno error: {ex.Message}"); }
                }));
            }
            if (tasks.Count > 0)
            {
                try { await Task.WhenAll(tasks); } catch { }
            }
            // Cerrar el modal al terminar (los toasts ya avisaron de cada canal)
            reenvioVenta = null;
        }
        finally
        {
            reenvioSending = false;
        }
    }

    /// <summary>Despues de emitir una venta exitosa, dispara los canales tildados
    /// (Email, WhatsApp Web manual, WhatsApp Interno). Cada uno corre en paralelo y
    /// avisa con un toast si funciono o fallo. No bloquea — si uno falla, los otros
    /// igual se intentan. Mensaje incluye link publico /comprobante/{token} asi el
    /// cliente lo ve online (en vez de pelearse con archivos adjuntos).</summary>
    private async Task DispararCanalesDeEnvioAsync(int ventaId, string ventaNumero)
    {
        // Conseguir el token publico de la venta (lo genera si no tiene).
        var publicToken = await Api.EnsurePublicTokenAsync(ventaId);
        var publicUrl = !string.IsNullOrEmpty(publicToken)
            ? $"{Navigation.BaseUri.TrimEnd('/')}/comprobante/{publicToken}"
            : null;

        // Mensaje de WhatsApp comun a todos los canales (con o sin link)
        string MensajeWhatsApp() => publicUrl is not null
            ? $"Hola! Te paso el comprobante {ventaNumero}:\n\n{publicUrl}\n\nCualquier cosa avisame. Gracias!"
            : $"Hola! Te paso el comprobante {ventaNumero}. Cualquier cosa avisame. Gracias!";

        // 1) WhatsApp Web: abre wa.me en pestaña nueva con el mensaje precargado.
        //    Como ahora mandamos LINK (no PDF), no hace falta descargar nada.
        if (envioWhatsappWeb && !string.IsNullOrWhiteSpace(envioWhatsappPhone))
        {
            var phone = new string(envioWhatsappPhone.Where(char.IsDigit).ToArray());
            if (phone.Length >= 8)
            {
                var msg = Uri.EscapeDataString(MensajeWhatsApp());
                try { await JS.InvokeVoidAsync("openInNewTab", $"https://wa.me/{phone}?text={msg}"); }
                catch { /* popup blocker — no rompemos el flujo */ }
            }
        }

        // 2) Email + WhatsApp Interno: corren en paralelo en el backend.
        var tasks = new List<Task>();
        if (envioEmail && !string.IsNullOrWhiteSpace(envioEmailTo))
        {
            tasks.Add(Task.Run(async () =>
            {
                try
                {
                    var (sent, err) = await Api.SendCafeVentaEmailAsync(ventaId, envioEmailTo, publicUrl: publicUrl);
                    if (sent) ToastService.Success($"📧 Email enviado a {envioEmailTo}");
                    else ToastService.Error($"📧 Email fallo: {err}");
                }
                catch (Exception ex) { ToastService.Error($"📧 Email error: {ex.Message}"); }
            }));
        }
        if (envioWhatsappInterno && !string.IsNullOrWhiteSpace(envioWhatsappPhone))
        {
            tasks.Add(Task.Run(async () =>
            {
                try
                {
                    // Para WhatsApp Interno mandamos el mismo mensaje con el link como caption
                    // (sigue adjuntando el PDF por las dudas — si el cliente prefiere bajar archivo).
                    var (sent, err) = await Api.SendCafeVentaWhatsappInternoAsync(ventaId, envioWhatsappPhone, caption: MensajeWhatsApp());
                    if (sent) ToastService.Success($"🚀 WhatsApp enviado a {envioWhatsappPhone}");
                    else ToastService.Error($"🚀 WhatsApp Interno fallo: {err}");
                }
                catch (Exception ex) { ToastService.Error($"🚀 WhatsApp Interno error: {ex.Message}"); }
            }));
        }
        // Esperamos a que terminen pero sin bloquear demasiado (los toasts ya avisaron).
        if (tasks.Count > 0)
        {
            try { await Task.WhenAll(tasks); } catch { }
        }
    }

