        await JS.InvokeVoidAsync("open", $"/cafe/clientes?new={nombreEnc}", "crearCliente", "width=920,height=720,resizable=yes,scrollbars=yes");
    }

    /// <summary>Registra el listener de postMessage si todavía no se hizo. Se llama lazy.</summary>
    private async Task AsegurarListenerClienteVentanaAsync()
    {
        if (clienteVentanaRef is not null) return;
        clienteVentanaRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("eval", @"
            if (!window.__cafeVentaClienteListener) {
                window.__cafeVentaClienteListener = true;
                window.addEventListener('message', function(ev) {
                    if (!ev.data || ev.data.type !== 'cafe-cliente-guardado') return;
                    if (window.__cafeVentaDotNet) {
                        window.__cafeVentaDotNet.invokeMethodAsync('OnClienteGuardadoEnPopup', ev.data.id || 0);
                    }
                });
            }
        ");
        await JS.InvokeVoidAsync("eval", "window.__cafeVentaDotNet = arguments[0]", clienteVentanaRef);
    }

    /// <summary>Invocado desde JS cuando la popup hizo postMessage al guardar un cliente.
    /// Refresca el cliente en la lista local y, si era el seleccionado en la venta, recotiza.</summary>
    [JSInvokable]
    public async Task OnClienteGuardadoEnPopup(int clienteId)
    {
        if (clienteId <= 0) return;
        try
        {
            var lista = await Api.GetCafeClientesAsync();
            if (lista is null) return;
            clientes = lista;
            var actualizado = clientes.FirstOrDefault(c => c.Id == clienteId);
            if (actualizado is null) return;

            // Si era un cliente nuevo (no había seleccionado), lo seleccionamos automáticamente.
            // Si era el cliente activo, recotizamos por si cambió el tipo BAR/Comercial.
            if (formClienteId == 0 || formClienteId == actualizado.Id)
            {
                formClienteId = actualizado.Id;
                formClienteTipo = actualizado.Tipo ?? "OTRO";
                if (!string.IsNullOrWhiteSpace(actualizado.CondicionIvaDefault))
                    formCondicionIva = actualizado.CondicionIvaDefault!;
                clienteSearch = "";
                clienteSearchOpen = false;
                await Cotizar();
            }
            ToastService.Success("✓ Cliente guardado");
            StateHasChanged();
        }
        catch (Exception ex) { ToastService.Error("Error refrescando cliente: " + ex.Message); }
    }

