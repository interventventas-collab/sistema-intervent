        clienteSearch = ""; clienteSearchOpen = false;
        vrNombre = vrRazonSocial = vrCuit = vrDireccion = vrLocalidad = vrCiudad = vrCp = vrTelefono = vrDomicilioEntrega = "";
        formTipoComprobante = "X";
        formCondicionIva = "CF";
        unpaidPrevSales = new();
        topProductsForClient = new();
        await Cotizar();
    }

