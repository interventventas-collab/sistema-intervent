    }

    private async Task AddItem()
    {
        if (addProductoId <= 0 || addCantidad <= 0) return;
        var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
        if (p is null) return;

        // Molienda + envase los toma de los selectores del form. Si el producto NO es
        // cafe, usamos los defaults seguros (sin molienda, sin envase especial).
        var esCafe = p.Categoria == "CAFE";

        // 2026-06-09 fix defensivo: garantizar que addMolienda/addEnvase reflejen el
        // valor REAL del DOM. Cuando el usuario navega con teclado (Enter), a veces
        // el @bind del <select> no commitea su onchange antes de que se dispare AddItem.
        if (esCafe)
        {
            try
            {
                var realMol = await JS.InvokeAsync<string>("eval", "document.getElementById('nv-molienda')?.value || ''");
                if (!string.IsNullOrEmpty(realMol)) addMolienda = realMol;
                var realEnv = await JS.InvokeAsync<string>("eval", "document.getElementById('nv-envase')?.value || ''");
                if (!string.IsNullOrEmpty(realEnv)) addEnvase = realEnv;
            }
            catch { /* no-op: si JS falla, seguimos con lo que tiene Blazor */ }
        }

        var molienda = esCafe ? (string.IsNullOrEmpty(addMolienda) ? null : addMolienda) : null;
        var esDoyPack = esCafe && addEnvase == "DOY_PACK";
        var esPlateado = esCafe && addEnvase == "PLATEADO";
        // SIEMPRE agrego una linea nueva — pedido del usuario 2026-05-19: poder cargar
        // el mismo producto mas de una vez en el comprobante (ej: 4 facturados + 2 con
        // 100% descuento como bonificacion). Si el operador quiere consolidar dos lineas
        // del mismo producto, edita las cantidades a mano o borra una de las dos.
        formItems.Add(new CafeCotizarItemRequest
        {
            ProductoId = addProductoId,
            Formato = addFormato,
            Cantidad = addCantidad,
            Molienda = molienda,
            EsDoyPack = esDoyPack,
            EsEnvasePlateado = esPlateado
        });

        addProductoId = 0; addFormato = "1KG"; addCantidad = 1;
        addMolienda = "EN GRANOS"; addEnvase = "NEGRO";
        productoSearch = ""; productoSearchOpen = false;
        await Cotizar();
    }

