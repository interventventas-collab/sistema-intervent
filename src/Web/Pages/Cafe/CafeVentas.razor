    /// <summary>2026-06-17: Preview del precio del item a agregar (antes de tocar + Agregar).
    /// Calcula el precio unitario según producto + formato + tipo cliente, y lo multiplica por la cantidad.
    /// Si no hay producto seleccionado o no hay precio, devuelve 0.</summary>
    private decimal AddPrecioPreview
    {
        get
        {
            var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
            if (p is null) return 0m;
            var esBar = ClienteTipoActual() == "BAR";
            decimal precioUnit = 0m;

            if (p.Categoria == "CAFE")
            {
                var precioKg = esBar ? (p.PrecioBar ?? p.PrecioOtro ?? p.Pvp1 ?? 0m)
                                     : (p.PrecioOtro ?? p.PrecioBar ?? p.Pvp2 ?? 0m);
                precioUnit = addFormato switch
                {
                    "1KG" => precioKg,
                    "MEDIO" => Math.Round(precioKg / 2m, 2, MidpointRounding.AwayFromZero),
                    "CUARTO" => Math.Round(precioKg / 4m, 2, MidpointRounding.AwayFromZero),
                    _ => precioKg
                };
            }
            else
            {
                if (addFormato == "BULTO")
                {
                    precioUnit = esBar ? (p.PrecioBulto ?? p.PrecioBultoOtro ?? 0m)
                                       : (p.PrecioBultoOtro ?? p.PrecioBulto ?? 0m);
                }
                else if (addFormato?.StartsWith("PACK_") == true && p.Packs is not null)
                {
                    var packN = addFormato.Substring(5);
                    if (int.TryParse(packN, out var n))
                    {
                        var pack = p.Packs.FirstOrDefault(x => x.IsActive && x.Cantidad == n);
                        if (pack is not null)
                        {
                            // Si el pack tiene PrecioOverride, ese es el precio del pack completo. Si no, calculamos
                            // como precio unitario × N.
                            if (pack.PrecioOverride.HasValue && pack.PrecioOverride.Value > 0m)
                                precioUnit = pack.PrecioOverride.Value;
                            else
                            {
                                var precioBase = esBar ? (p.PrecioBar ?? p.PrecioOtro ?? 0m)
                                                       : (p.PrecioOtro ?? p.PrecioBar ?? 0m);
                                precioUnit = precioBase * n;
                            }
                        }
                    }
                }
                else // UNIT
                {
                    // 2026-06-18: respetar BAR/Comercial sin IVA, igual que el carrito.
                    // Antes priorizaba PrecioEfectivoConIva que SIEMPRE usa PrecioOtro+IVA, ignorando si era BAR.
                    // Ejemplo: ABE-MER-FRU PrecioBar=12000 / PrecioOtro=14000 mostraba 16940 (14000*1.21) en preview
                    // pero al agregar al carrito quedaba en 12000. Discrepancia del 41% para clientes BAR.
                    precioUnit = esBar ? (p.PrecioBar ?? p.PrecioOtro ?? 0m)
                                       : (p.PrecioOtro ?? p.PrecioBar ?? 0m);
                }
            }
            return precioUnit * addCantidad;
        }
    }

    /// <summary>2026-06-17: Etiqueta del formato para el chip de precio en vivo.</summary>
    private string AddPrecioPreviewLabel => addFormato switch
    {
        "1KG" => "1 kg",
        "MEDIO" => "1/2 kg",
        "CUARTO" => "1/4 kg",
        "UNIT" => "Unidad",
        "BULTO" => AddProductoBultoLabel,
        var f when f?.StartsWith("PACK_") == true => $"Pack x {f.Substring(5)}",
        _ => addFormato ?? ""
    };

    /// <summary>Aviso suave para el operador: si carga Suelto con cantidad >= UxB y el producto
    /// tiene precio de bulto, le sugiere cambiar a Bulto y le muestra cuánto le ahorraría al cliente.
    /// null = no mostrar aviso.</summary>
    private string? AvisoBultoConviene
    {
        get
        {
            if (!AddProductoTieneBulto) return null;
            if (addFormato != "UNIT") return null;
            var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
            if (p is null) return null;
            var uxb = p.UxB ?? 0;
            if (uxb <= 0 || addCantidad < uxb) return null;

            // Calculo precio suelto vs precio bulto segun tipo de cliente actual.
            var tipo = ClienteTipoActual();
            var precioUnit = tipo == "BAR"
                ? (p.PrecioBar ?? p.PrecioOtro ?? p.Pvp1 ?? 0m)
                : (p.PrecioOtro ?? p.PrecioBar ?? p.Pvp2 ?? 0m);
            var precioBulto = tipo == "BAR"
                ? (p.PrecioBulto ?? p.PrecioBultoOtro)
                : (p.PrecioBultoOtro ?? p.PrecioBulto);
            if (!precioBulto.HasValue || precioBulto.Value <= 0 || precioUnit <= 0) return null;

            var bultosCompletos = addCantidad / uxb;        // div entera
            var sueltas = addCantidad - (bultosCompletos * uxb);
            var costoComoSuelto = precioUnit * addCantidad;
            var costoComoBulto = (bultosCompletos * precioBulto.Value) + (sueltas * precioUnit);
            var ahorro = costoComoSuelto - costoComoBulto;
            if (ahorro <= 0) return null;

            return $"Conviene venderlo como Bulto: cobrás ${costoComoBulto:N0} en vez de ${costoComoSuelto:N0} (ahorra ${ahorro:N0} al cliente).";
        }
    }

    /// <summary>Determina el tipo de cliente actual de la venta en curso (BAR / OTRO).</summary>
    private string ClienteTipoActual()
    {
        if (!string.IsNullOrWhiteSpace(formClienteTipo))
            return formClienteTipo.ToUpperInvariant() == "BAR" ? "BAR" : "OTRO";
        return "OTRO";
    }

    /// <summary>Cambia el formato del item en carga a BULTO y ajusta la cantidad a "1 bulto"
    /// (cantidad ÷ UxB redondeado hacia abajo). Click handler del botón "Cambiar a Bulto".</summary>
    private void CambiarABulto()
    {
        var p = productos?.FirstOrDefault(x => x.Id == addProductoId);
        var uxb = p?.UxB ?? 0;
        if (uxb <= 0) return;
        var nuevosBultos = addCantidad / uxb;       // div entera = bultos completos
        if (nuevosBultos < 1) return;
        addFormato = "BULTO";
        addCantidad = nuevosBultos;
    }

