                }
                <button class="btn btn-secondary" @onclick="@(() => pinningVenta = null)" disabled="@savingPin">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarPinAsync" disabled="@savingPin">@(savingPin ? "Guardando..." : "Guardar")</button>
