@page "/cafe/tesoreria/cobranzas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@inject OperatorService Operator

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        @{
            var vigentes = cobranzas?.Count(c => c.Estado != "ANULADA") ?? 0;
            var anuladas = cobranzas?.Count(c => c.Estado == "ANULADA") ?? 0;
        }
        <h3 style="margin:0;">📥 Cobranzas (@vigentes@(anuladas > 0 ? $" + {anuladas} anuladas" : ""))</h3>
        <div style="display:flex; gap:0.5rem; align-items:center;">
            <button class="btn btn-primary" @onclick="ShowNueva">+ Nueva cobranza</button>
        </div>
    </div>
    @* ─── Barra de filtros ─── *@
    @if (cobranzas is not null && cobranzas.Count > 0)
    {
        <div style="background: #f9fafb; border-bottom: 1px solid #e5e7eb; padding: 0.6rem 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: end;">
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 130px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Desde</label>
                <input type="date" class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       value="@(filtroFechaDesde?.ToString("yyyy-MM-dd"))"
                       @onchange="@(e => filtroFechaDesde = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 130px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Hasta</label>
                <input type="date" class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       value="@(filtroFechaHasta?.ToString("yyyy-MM-dd"))"
                       @onchange="@(e => filtroFechaHasta = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 200px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Buscar</label>
                <input class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;"
                       value="@filtroBuscar"
                       @oninput="OnFiltroBuscarInput"
                       placeholder="🔍 N° de recibo, cliente (busca en TODA la base)..." />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 130px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Estado</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroEstado">
                    <option value="VIGENTE">Vigentes</option>
                    <option value="ANULADA">Anuladas</option>
                    <option value="TODOS">Todas</option>
                </select>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 150px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Retenciones</label>
                <select class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" @bind="filtroRetenciones">
                    <option value="TODOS">Todas</option>
                    <option value="CON">Con retenciones</option>
                    <option value="SIN">Sin retenciones</option>
                </select>
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 110px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Monto mín.</label>
                <input class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" type="number" min="0" step="1000"
                       @bind="filtroMontoMin" @bind:event="oninput" placeholder="$0" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.15rem; min-width: 110px;">
                <label style="font-size: 0.7rem; color: #6b7280; font-weight: 600;">Monto máx.</label>
                <input class="form-input" style="padding: 0.3rem 0.5rem; font-size: 0.85rem;" type="number" min="0" step="1000"
                       @bind="filtroMontoMax" @bind:event="oninput" placeholder="∞" />
            </div>
            @if (HayFiltrosActivos)
            {
                <button class="btn btn-secondary" @onclick="LimpiarFiltros"
                        style="padding: 0.35rem 0.7rem; font-size: 0.8rem;"
                        title="Limpiar todos los filtros">✕ Limpiar</button>
            }
        </div>
    }
    <div class="card-body" style="padding:0;">
        @{
            var cobranzasFiltradas = AplicarFiltros();
        }
        @if (loading)
        {
            <p class="text-muted" style="padding:1rem;">Cargando...</p>
        }
        else if (cobranzasFiltradas.Count == 0)
        {
            <p class="text-muted" style="padding:1rem;">@(cobranzas?.Count > 0 ? "No hay cobranzas que coincidan con los filtros. Tocá ✕ Limpiar para verlas todas." : "Sin cobranzas aún. Hace clic en \"+ Nueva cobranza\" para empezar.")</p>
        }
        else
        {
            <table class="table table-compact">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th style="text-align:right;">Retenciones</th>
                        <th style="text-align:right;">Total</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in cobranzasFiltradas)
                    {
                        <tr style="@(c.Estado == "ANULADA" ? "opacity:0.5; text-decoration:line-through;" : "")">
                            <td><b>@c.Numero</b></td>
                            <td>@c.Fecha.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>@c.ClienteNombre</td>
                            <td style="text-align:right;">@(c.Retenciones > 0 ? $"${c.Retenciones:N2}" : "—")</td>
                            <td style="text-align:right; font-weight:600;">$@c.Total.ToString("N2")</td>
                            <td><span class="badge @(c.Estado == "VIGENTE" ? "badge-success" : "badge-danger")">@c.Estado</span></td>
                            <td>
                                <a class="btn-icon" href="@Api.GetCobranzaPdfUrl(c.Id)" target="_blank" title="Imprimir recibo PDF">📄</a>
                                @if (c.Estado == "VIGENTE")
                                {
                                    <button class="btn-icon" @onclick="() => AnularCobranza(c)" title="Anular cobranza">❌</button>
                                }
                                else if (c.Estado == "ANULADA")
                                {
                                    <button class="btn-icon" @onclick="() => AbrirEliminar(c)" title="Eliminar definitivamente (requiere clave)" style="color:#b91c1c;">🗑</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @* Totales del filtro actual *@
            <div style="background:#f9fafb; border-top:1px solid #e5e7eb; padding:0.6rem 1rem; display:flex; gap:1rem; flex-wrap:wrap; font-size:0.85rem; color:#4b5563;">
                <div>📊 <strong>@cobranzasFiltradas.Count</strong> cobranza(s)</div>
                <div>💰 Total: <strong style="color:#16a34a;">$@cobranzasFiltradas.Where(c => c.Estado != "ANULADA").Sum(c => c.Total).ToString("N2")</strong></div>
                @if (cobranzasFiltradas.Any(c => c.Retenciones > 0))
                {
                    <div>📋 Retenciones: <strong>$@cobranzasFiltradas.Where(c => c.Estado != "ANULADA").Sum(c => c.Retenciones).ToString("N2")</strong></div>
                }
            </div>
        }
    </div>
</div>

@if (showNueva)
{
    <div class="modal-overlay" @onclick="CloseNueva">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 900px; width:90vw; max-height: 90vh; overflow-y:auto;">
            <div class="modal-header">
                <h4 style="margin:0;">📥 Nueva cobranza</h4>
                <button class="btn-close" @onclick="CloseNueva">&times;</button>
            </div>
            <div class="modal-body">

                @* --- Cliente (buscador filtrable) --- *@
                <div class="form-group" style="position: relative;">
                    <label class="form-label">Cliente</label>
                    @if (selClienteId > 0)
                    {
                        var ciSel = clientes?.FirstOrDefault(x => x.Id == selClienteId);
                        <div style="display: flex; gap: 0.3rem; align-items: center;">
                            <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-family: monospace; font-weight: 700; color: #1d4ed8;">@(ciSel?.Codigo ?? "—")</span>
                                <strong>@(ciSel?.Nombre ?? "?")</strong>
                                @if (ciSel is not null && !string.IsNullOrEmpty(ciSel.Cuit))
                                {
                                    <span style="font-size: 0.72rem; color: #6b7280;">· @ciSel.Cuit</span>
                                }
                            </div>
                            <button class="btn btn-secondary" type="button" @onclick="ClearCliente" title="Cambiar cliente">×</button>
                        </div>
                    }
                    else
                    {
                        <input class="form-input" @bind="clienteSearch" @bind:event="oninput"
                               @onfocus="() => clienteSearchOpen = true"
                               placeholder="🔍 Buscar por código, nombre, CUIT, tel, email, dirección…" />
                        @if (clienteSearchOpen && !string.IsNullOrWhiteSpace(clienteSearch))
                        {
                            var matches = ClientesMatching(clienteSearch).Take(20).ToList();
                            <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                @if (matches.Count == 0)
                                {
                                    <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados.</div>
                                }
                                else
                                {
                                    @foreach (var ci in matches)
                                    {
                                        var ciId = ci.Id;
                                        // Nombre a mostrar: prioriza Nombre (fantasia/comercial); si no, RazonSocial (fiscal).
                                        var nombreMostrar = !string.IsNullOrWhiteSpace(ci.Nombre) ? ci.Nombre : (ci.RazonSocial ?? "—");
                                        // Direccion a mostrar: prioriza DomicilioEntrega; si no, Direccion (fiscal).
                                        var dirMostrar = !string.IsNullOrWhiteSpace(ci.DomicilioEntrega) ? ci.DomicilioEntrega : ci.Direccion;
                                        <div @onclick="() => SelectCliente(ciId)"
                                             style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                            <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; margin-right: 0.5rem;">@ci.Codigo</span>
                                            <strong>@nombreMostrar</strong>
                                            @if (!string.IsNullOrEmpty(ci.Cuit))
                                            {
                                                <span style="color: #6b7280; font-size: 0.78rem;"> · @ci.Cuit</span>
                                            }
                                            @if (!string.IsNullOrEmpty(ci.Telefono))
                                            {
                                                <span style="color: #6b7280; font-size: 0.78rem;"> · 📞 @ci.Telefono</span>
                                            }
                                            @if (!string.IsNullOrEmpty(dirMostrar))
                                            {
                                                <div style="color: #6b7280; font-size: 0.75rem; margin-top: 0.15rem;">📍 @dirMostrar</div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>

                @if (selClienteId > 0)
                {
                    @if (pendienteOrigen is not null)
                    {
                        <div style="margin: 0.8rem 0; padding: 0.7rem 0.9rem; background: #dcfce7; border: 1px solid #16a34a; border-radius: 8px; display: flex; gap: 0.6rem; align-items: center;">
                            <span style="font-size: 1.5rem;">🚚</span>
                            <div style="flex: 1; font-size: 0.88rem;">
                                <b>Cobranza del repartidor @pendienteOrigen.RepartidorNombre</b> por <b style="color:#16a34a;">$@pendienteOrigen.Importe.ToString("N2")</b>
                                <div style="font-size: 0.78rem; color: #166534; margin-top: 0.15rem;">
                                    Originalmente para @pendienteOrigen.VentaNumero. Imputalo a donde corresponda y guardá.
                                </div>
                            </div>
                        </div>
                    }
                    @* --- Comprobantes a cobrar --- *@
                    <div style="margin: 1rem 0; padding: 0.8rem; background: #f9fafb; border-radius: 8px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                            <h5 style="margin:0;">Comprobantes a cobrar</h5>
                            @if (pendientes is not null && pendientes.Count > 0)
                            {
                                <div style="display:flex; gap:0.4rem;">
                                    <button class="btn btn-secondary" style="font-size:0.78rem;" @onclick="ImputarTodo">⚡ Cobrar todo lo pendiente</button>
                                </div>
                            }
                        </div>
                        @if (saldoCliente.HasValue && saldoCliente.Value > 0)
                        {
                            <div style="background:#fef3c7; padding:0.4rem 0.6rem; border-radius:6px; font-size:0.82rem; margin-bottom:0.5rem;">
                                💰 Saldo actual del cliente: <b>$@saldoCliente.Value.ToString("N2")</b> (te debe)
                            </div>
                        }
                        @* Si el cliente comparte CUIT con otras sucursales, ofrecer agruparlas en la misma cobranza. *@
                        @if (sucursalesMismoCuit.Count > 0)
                        {
                            <div style="background:#dbeafe; padding:0.5rem 0.7rem; border-radius:6px; font-size:0.85rem; margin-bottom:0.5rem; border:1px solid #93c5fd;">
                                <label style="display:flex; align-items:flex-start; gap:0.5rem; cursor:pointer;">
                                    <input type="checkbox" checked="@incluirSucursales"
                                           @onchange="@(async e => await OnToggleIncluirSucursales((bool)e.Value!))"
                                           style="margin-top:0.2rem;" />
                                    <div>
                                        <div><b>🏢 Cobrar también las otras @sucursalesMismoCuit.Count sucursale@(sucursalesMismoCuit.Count == 1 ? "" : "s") con el mismo CUIT</b></div>
                                        <div style="font-size:0.78rem; color:#1e40af; margin-top:0.2rem;">
                                            @string.Join(" · ", sucursalesMismoCuit.Select(s => s.Nombre))
                                        </div>
                                    </div>
                                </label>
                            </div>
                        }
                        @if (pendientes is null)
                        {
                            <p class="text-muted">Cargando...</p>
                        }
                        else if (pendientes.Count == 0)
                        {
                            <p class="text-muted" style="margin:0;">Sin comprobantes pendientes. Podés cargar igual como "A cuenta".</p>
                        }
                        else
                        {
                            <table class="table table-compact" style="margin-bottom:0.5rem;">
                                <thead>
                                    <tr><th></th><th>Número</th><th>Fecha</th><th style="text-align:right;">Saldo</th><th style="text-align:right;">A cobrar</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in pendientes)
                                    {
                                        <tr>
                                            <td><input type="checkbox" @bind="imputaciones[p.VentaId].Seleccionado" @bind:after="RecalcularTotal" /></td>
                                            <td>
                                                <b>@p.Numero</b>
                                                @if (incluirSucursales && !string.IsNullOrEmpty(p.ClienteNombre))
                                                {
                                                    <div style="font-size:0.7rem; color:#6b7280;">@p.ClienteNombre</div>
                                                }
                                            </td>
                                            <td>@p.Fecha.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                            <td style="text-align:right;">$@p.Saldo.ToString("N2")</td>
                                            <td style="text-align:right;">
                                                <input class="form-input" type="number" step="0.01" style="text-align:right; width:120px; display:inline-block;"
                                                       value="@imputaciones[p.VentaId].Importe"
                                                       @onchange="@(e => OnImputeChange(p.VentaId, e.Value?.ToString()))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <label class="form-check"><input type="checkbox" @bind="aCuentaActivo" @bind:after="RecalcularTotal" /> A cuenta:</label>
                            <input class="form-input" type="number" step="0.01" style="width:140px;"
                                   @bind="aCuentaImporte" @bind:after="RecalcularTotal" disabled="@(!aCuentaActivo)" />
                        </div>
                        <div style="margin-top:0.5rem; text-align:right; font-weight:700;">
                            Total imputado: $@TotalImputado.ToString("N2")
                        </div>
                    </div>

                    @* --- Movimientos del banco asociados disponibles (Etapa B) --- *@
                    @if (movsBancoDisponibles.Count > 0 || movsBancoDescartados.Count > 0)
                    {
                        <div style="margin: 1rem 0; padding: 0.7rem 0.8rem; background: #dbeafe; border: 1px solid #93c5fd; border-radius: 8px;">
                            <h5 style="margin:0 0 0.5rem; color:#1e40af;">💰 Movimientos del banco asociados a este cliente</h5>
                            @if (movsBancoDisponibles.Count > 0)
                            {
                                <p style="margin: 0 0 0.5rem; font-size: 0.78rem; color: #1e40af;">Tildá los que querés usar como forma de cobro. Si alguno NO es de este cliente, tocá 🚫 para descartarlo.</p>
                                @foreach (var mov in movsBancoDisponibles)
                                {
                                    var ya = movsBancoUsados.Contains(mov.Id);
                                    var movId = mov.Id;
                                    <div style="display:flex; gap:0.5rem; align-items:center; padding:0.3rem 0.5rem; background:white; border-radius:5px; margin-bottom:0.3rem;">
                                        <label style="display:flex; gap:0.5rem; align-items:center; flex:1; cursor:pointer; min-width:0;">
                                            <input type="checkbox" checked="@ya" @onchange="@(e => ToggleMovimientoBanco(movId, (bool)e.Value!))" />
                                            <span style="flex:1; min-width:0;">
                                                <b>@mov.Fecha.ToString("dd/MM/yyyy")</b> · @(mov.Descripcion ?? "Transferencia")
                                                @if (!string.IsNullOrEmpty(mov.VentaNumeroAsociada))
                                                {
                                                    <span style="font-size:0.72rem; color:#16a34a; margin-left:0.3rem;">→ @mov.VentaNumeroAsociada</span>
                                                }
                                            </span>
                                            <span style="font-weight:700; color:#16a34a;">$@mov.Importe.ToString("N2")</span>
                                        </label>
                                        <button type="button" class="btn-icon" title="Descartar — este movimiento NO es de este cliente"
                                                style="padding:0.15rem 0.4rem; background:transparent; border:1px solid #fca5a5; color:#b91c1c; border-radius:5px; font-size:0.85rem; cursor:pointer;"
                                                @onclick="@(() => DescartarMovimientoBanco(movId))">🚫</button>
                                    </div>
                                }
                            }
                            @* 2026-06-03: toggle para ver/restaurar movimientos descartados *@
                            @if (movsBancoDescartados.Count > 0)
                            {
                                <div style="margin-top:0.6rem; padding-top:0.5rem; border-top:1px dashed #93c5fd;">
                                    <button type="button" style="background:transparent; border:none; color:#7c2d12; font-size:0.78rem; cursor:pointer; font-weight:600;"
                                            @onclick="@(() => verDescartados = !verDescartados)">
                                        @(verDescartados ? "▼" : "▶") 🚫 Ver descartados (@movsBancoDescartados.Count)
                                    </button>
                                    @if (verDescartados)
                                    {
                                        <div style="margin-top:0.4rem;">
                                            @foreach (var d in movsBancoDescartados)
                                            {
                                                var movId = d.MovimientoId;
                                                <div style="display:flex; gap:0.5rem; align-items:center; padding:0.3rem 0.5rem; background:#fef2f2; border-radius:5px; margin-bottom:0.3rem; opacity:0.85;">
                                                    <span style="flex:1; min-width:0; text-decoration:line-through; color:#7c2d12;">
                                                        <b>@d.Fecha.ToString("dd/MM/yyyy")</b> · @(d.Descripcion ?? "Transferencia")
                                                    </span>
                                                    <span style="font-weight:700; color:#7c2d12; text-decoration:line-through;">$@d.Importe.ToString("N2")</span>
                                                    <button type="button" class="btn-icon" title="Restaurar — volver a mostrar este movimiento"
                                                            style="padding:0.15rem 0.4rem; background:transparent; border:1px solid #16a34a; color:#15803d; border-radius:5px; font-size:0.78rem; cursor:pointer;"
                                                            @onclick="@(() => RestaurarMovimientoBanco(movId))">↩ Restaurar</button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @* --- Formas de cobro --- *@
                    <div style="margin: 1rem 0; padding: 0.8rem; background: #fef3c7; border-radius: 8px;">
                        <h5 style="margin:0 0 0.5rem;">Forma de cobro</h5>
                        @for (int i = 0; i < formMedios.Count; i++)
                        {
                            var idx = i;
                            var m = formMedios[idx];
                            <div style="display:grid; grid-template-columns: 2fr 1fr 2fr 30px; gap:0.4rem; margin-bottom:0.4rem; align-items:start;">
                                <select class="form-input" value="@m.CajaId" @onchange="@(e => OnCajaChange(idx, e.Value?.ToString()))">
                                    <option value="0">— Caja —</option>
                                    @if (cajas is not null)
                                    {
                                        @foreach (var c in cajas.Where(x => x.IsActive))
                                        {
                                            <option value="@c.Id">@c.Nombre</option>
                                        }
                                    }
                                </select>
                                <input class="form-input" type="number" step="0.01" placeholder="Importe"
                                       @bind="m.Importe" @bind:after="RecalcularTotal" />
                                <input class="form-input" placeholder="Referencia (opcional)" @bind="m.Referencia" />
                                <button class="btn-icon" @onclick="() => formMedios.RemoveAt(idx)" title="Quitar">🗑</button>
                            </div>
                            @if (m.EsCheque)
                            {
                                <div style="margin-left:1rem; padding:0.6rem; background:white; border-radius:6px; margin-bottom:0.5rem;">
                                    <div style="font-size:0.78rem; color:#6b7280; margin-bottom:0.3rem;">Datos del cheque</div>
                                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.4rem;">
                                        <input class="form-input" placeholder="Banco" @bind="m.ChequeBanco" />
                                        <input class="form-input" placeholder="Número" @bind="m.ChequeNumero" />
                                        <input class="form-input" placeholder="Emisor (opcional)" @bind="m.ChequeEmisor" />
                                        <input class="form-input" type="date" @bind="m.ChequeFechaVencimiento" />
                                    </div>
                                </div>
                            }
                        }
                        <button class="btn btn-secondary" style="font-size:0.8rem;" @onclick="AgregarMedio">+ Agregar forma de cobro</button>
                    </div>

                    @* --- Retenciones --- *@
                    <div class="form-row">
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Retenciones sufridas</label>
                            <input class="form-input" type="number" step="0.01" @bind="formRetenciones" @bind:after="RecalcularTotal" />
                            <p style="font-size:0.7rem; color:#6b7280; margin:0.2rem 0 0;">Si te aplicaron retenciones (IIBB, IVA, ganancias) ponelas acá. Cancela saldo del cliente pero NO entra a caja.</p>
                        </div>
                    </div>

                    @* --- Observaciones --- *@
                    <div class="form-group">
                        <label class="form-label">Observaciones</label>
                        <input class="form-input" @bind="formObservaciones" />
                    </div>

                    @* --- Resumen --- *@
                    <div style="padding:0.6rem; background:#dbeafe; border-radius:6px;">
                        <div style="display:flex; justify-content:space-between;"><span>Total medios de cobro:</span><b>$@TotalMedios.ToString("N2")</b></div>
                        <div style="display:flex; justify-content:space-between;"><span>+ Retenciones:</span><b>$@formRetenciones.ToString("N2")</b></div>
                        <div style="display:flex; justify-content:space-between;"><span>= Debe igualar el imputado a comprobantes:</span><b style="color:@(CuadraTotal ? "#059669" : "#dc2626");">$@TotalImputado.ToString("N2")</b></div>
                        @* 2026-06-05: cartel grande de diferencia cuando no cuadra *@
                        @if (!CuadraTotal)
                        {
                            var dif = TotalImputado - (TotalMedios + formRetenciones);
                            var falta = dif > 0;
                            <div style="margin-top:0.6rem; padding:0.7rem 0.9rem; border-radius:8px;
                                        background:@(falta ? "#fee2e2" : "#fef3c7");
                                        border:2px solid @(falta ? "#dc2626" : "#d97706");
                                        display:flex; justify-content:space-between; align-items:center;">
                                <div style="font-weight:700; color:@(falta ? "#991b1b" : "#92400e"); font-size:0.95rem;">
                                    @if (falta)
                                    {
                                        <span>⚠ Falta cobrar:</span>
                                    }
                                    else
                                    {
                                        <span>⚠ Sobra (cobraste de más):</span>
                                    }
                                </div>
                                <div style="font-weight:800; font-size:1.35rem; color:@(falta ? "#dc2626" : "#d97706"); font-family:monospace;">
                                    $@Math.Abs(dif).ToString("N2")
                                </div>
                            </div>
                            <div style="color:#6b7280; font-size:0.78rem; margin-top:0.4rem; line-height:1.35;">
                                @if (falta)
                                {
                                    <span>💡 Agregá una forma de cobro por <b>$@Math.Abs(dif).ToString("N2")</b>, o bajá el importe a imputar a ese mismo valor.</span>
                                }
                                else
                                {
                                    <span>💡 Subí lo imputado a comprobantes por <b>$@Math.Abs(dif).ToString("N2")</b>, o bajá los medios de cobro.</span>
                                }
                            </div>
                        }
                    </div>
                }

            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseNueva" disabled="@guardando">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarCobranza" disabled="@(!CuadraTotal || TotalImputado <= 0 || guardando)">
                    @(guardando ? "..." : "Guardar cobranza")
                </button>
            </div>
        </div>
    </div>
}

@* ===== Modal: confirmar eliminacion definitiva con clave ===== *@
@if (eliminandoCobranza is not null)
{
    var c = eliminandoCobranza;
    <div class="modal-overlay" @onclick="() => eliminandoCobranza = null">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background:#fee2e2;">
                <h3 style="margin:0; color:#7f1d1d;">🗑 Eliminar definitivamente</h3>
                <button class="btn-close" @onclick="() => eliminandoCobranza = null">&times;</button>
            </div>
            <div class="modal-body">
                <div style="padding:0.5rem 0.8rem; background:#fef2f2; border-left:3px solid #b91c1c; font-size:0.85rem; margin-bottom:0.6rem;">
                    Vas a borrar para SIEMPRE la cobranza <strong>@c.Numero</strong> de <strong>@c.ClienteNombre</strong> por <strong>$@c.Total.ToString("N2")</strong>. Esta acción no se puede deshacer.
                </div>
                <label class="form-label">Confirmá con tu clave:</label>
                <input type="password" class="form-input" @bind="eliminarPassword" @bind:event="oninput"
                       placeholder="Tu clave actual" @onkeydown="OnEliminarKeydown" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => eliminandoCobranza = null">Cancelar</button>
                <button class="btn btn-danger" disabled="@(string.IsNullOrEmpty(eliminarPassword) || eliminando)" @onclick="EjecutarEliminar">
                    @(eliminando ? "Eliminando..." : "🗑 Eliminar definitivamente")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CobranzaListDto>? cobranzas;
    private bool loading = true;
    // Por default ocultamos las cobranzas anuladas para que el listado quede limpio.
    // El usuario puede tildar el checkbox del header si quiere ver el historial.
    private bool mostrarAnuladas = false;

    // ─── Filtros ───
    private DateTime? filtroFechaDesde;
    private DateTime? filtroFechaHasta;
    private string filtroBuscar = "";
    private string filtroEstado = "VIGENTE";     // VIGENTE | ANULADA | TODOS
    private string filtroRetenciones = "TODOS";  // TODOS | CON | SIN
    private decimal? filtroMontoMin;
    private decimal? filtroMontoMax;

    private bool HayFiltrosActivos =>
        filtroFechaDesde.HasValue || filtroFechaHasta.HasValue
        || !string.IsNullOrWhiteSpace(filtroBuscar)
        || filtroEstado != "VIGENTE"
        || filtroRetenciones != "TODOS"
        || filtroMontoMin.HasValue || filtroMontoMax.HasValue;

    private void LimpiarFiltros()
    {
        filtroFechaDesde = null;
        filtroFechaHasta = null;
        filtroBuscar = "";
        filtroEstado = "VIGENTE";
        filtroRetenciones = "TODOS";
        filtroMontoMin = null;
        filtroMontoMax = null;
    }

    /// <summary>Aplica los filtros activos a la lista de cobranzas. Se llama desde el render.</summary>
    private List<CobranzaListDto> AplicarFiltros()
    {
        if (cobranzas is null) return new();
        IEnumerable<CobranzaListDto> q = cobranzas;

        // Estado
        if (filtroEstado == "VIGENTE") q = q.Where(c => c.Estado != "ANULADA");
        else if (filtroEstado == "ANULADA") q = q.Where(c => c.Estado == "ANULADA");
        // si TODOS no filtra

        // Rango de fechas
        if (filtroFechaDesde.HasValue) q = q.Where(c => c.Fecha.Date >= filtroFechaDesde.Value.Date);
        if (filtroFechaHasta.HasValue) q = q.Where(c => c.Fecha.Date <= filtroFechaHasta.Value.Date);

        // Buscar texto (número o cliente)
        if (!string.IsNullOrWhiteSpace(filtroBuscar))
        {
            var t = filtroBuscar.Trim().ToUpperInvariant();
            q = q.Where(c =>
                (c.Numero ?? "").ToUpperInvariant().Contains(t)
                || (c.ClienteNombre ?? "").ToUpperInvariant().Contains(t));
        }

        // Retenciones
        if (filtroRetenciones == "CON") q = q.Where(c => c.Retenciones > 0);
        else if (filtroRetenciones == "SIN") q = q.Where(c => c.Retenciones == 0);

        // Monto
        if (filtroMontoMin.HasValue) q = q.Where(c => c.Total >= filtroMontoMin.Value);
        if (filtroMontoMax.HasValue) q = q.Where(c => c.Total <= filtroMontoMax.Value);

        return q.ToList();
    }

    // Eliminacion definitiva de cobranzas anuladas — requiere clave del usuario
    private CobranzaListDto? eliminandoCobranza;
    private string eliminarPassword = "";
    private bool eliminando;

    private void AbrirEliminar(CobranzaListDto c)
    {
        eliminandoCobranza = c;
        eliminarPassword = "";
    }

    private async Task OnEliminarKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(eliminarPassword) && !eliminando)
            await EjecutarEliminar();
    }

    private async Task EjecutarEliminar()
    {
        if (eliminandoCobranza is null || string.IsNullOrEmpty(eliminarPassword)) return;
        eliminando = true;
        try
        {
            var (ok, error) = await Api.EliminarCafeCobranzaAsync(eliminandoCobranza.Id, eliminarPassword);
            if (ok)
            {
                ToastService.Success("Cobranza eliminada definitivamente");
                eliminandoCobranza = null;
                eliminarPassword = "";
                await Load();
            }
            else
            {
                ToastService.Error(error ?? "No se pudo eliminar");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { eliminando = false; }
    }
    private List<CafeClienteDto>? clientes;
    private List<CafeCajaDto>? cajas;

    private bool showNueva, guardando;
    private int selClienteId = 0;
    private string clienteSearch = "";
    private bool clienteSearchOpen;
    private List<ComprobantePendienteDto>? pendientes;
    private decimal? saldoCliente;
    // Si el cliente tiene CUIT compartido con otras sucursales, las cargamos aca para
    // mostrar el checkbox "Incluir otras sucursales con mismo CUIT". Vacio = no hay agrupacion posible.
    private List<SucursalMismoCuitDto> sucursalesMismoCuit = new();
    private bool incluirSucursales;
    [Parameter, SupplyParameterFromQuery(Name = "cliente")] public int? PreClienteId { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "venta")] public int? PreVentaId { get; set; }
    /// <summary>Si vino desde el extracto bancario con ?movimiento=Y, precargamos
    /// ese movimiento como forma de cobro tipo Transferencia.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "movimiento")] public int? PreMovimientoId { get; set; }
    /// <summary>Si vino desde Cobranzas pendientes (repartidor cargo desde QR), precargamos
    /// la cobranza con efectivo + importe. Al guardar vinculamos la pendiente.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "pendienteId")] public int? PrePendienteId { get; set; }
    // 2026-06-06: abre el modal de Nueva Cobranza vacío (atajo desde topbar)
    [Parameter, SupplyParameterFromQuery(Name = "nueva")] public int? PreNueva { get; set; }
    private CobranzaPendienteDto? pendienteOrigen;
    // Movimientos del banco asociados al cliente actual que aun no se usaron en cobranza.
    private List<MovimientoDisponibleDto> movsBancoDisponibles = new();
    // Ids de movimientos elegidos para esta cobranza (para marcarlos como usados al guardar)
    private HashSet<int> movsBancoUsados = new();
    // 2026-06-03: movimientos que el usuario descarto para este cliente (no es de el)
    private List<ApiClient.MovDescartadoDto> movsBancoDescartados = new();
    private bool verDescartados = false;
    private Dictionary<int, ImputData> imputaciones = new();
    private bool aCuentaActivo;
    private decimal aCuentaImporte;
    private decimal formRetenciones;
    private string? formObservaciones;
    private List<MedioForm> formMedios = new();

    private class ImputData { public bool Seleccionado { get; set; } public decimal Importe { get; set; } }
    private class MedioForm
    {
        public int CajaId { get; set; }
        public string TipoCaja { get; set; } = "";
        public decimal Importe { get; set; }
        public string? Referencia { get; set; }
        public bool EsCheque => TipoCaja == "CHEQUES_CARTERA";
        public string ChequeBanco { get; set; } = "";
        public string ChequeNumero { get; set; } = "";
        public string? ChequeEmisor { get; set; }
        public DateTime? ChequeFechaVencimiento { get; set; }
    }

    private decimal TotalImputado => imputaciones.Where(kv => kv.Value.Seleccionado).Sum(kv => kv.Value.Importe) + (aCuentaActivo ? aCuentaImporte : 0);
    private decimal TotalMedios => formMedios.Sum(m => m.Importe);
    private bool CuadraTotal => Math.Abs(TotalImputado - (TotalMedios + formRetenciones)) < 0.01m;

    protected override async Task OnInitializedAsync()
    {
        clientes = await Api.GetCafeClientesAsync() ?? new();
        cajas = await Api.GetCafeCajasAsync() ?? new();
        await Load();
        // 2026-06-06: atajo desde topbar — ?nueva=1 abre el modal vacío para elegir cliente
        if (PreNueva.HasValue && PreNueva.Value == 1 && (!PreClienteId.HasValue || PreClienteId.Value <= 0))
        {
            ShowNueva();
            return;
        }
        // Atajo desde otra pantalla: si vino con ?cliente=X o ?cliente=X&venta=Y, abre el modal precargado
        if (PreClienteId.HasValue && PreClienteId.Value > 0)
        {
            ShowNueva();
            await SelectCliente(PreClienteId.Value);
            if (PreVentaId.HasValue && PreVentaId.Value > 0 && imputaciones.TryGetValue(PreVentaId.Value, out var imp))
                imp.Seleccionado = true;
            // Si viene desde el extracto bancario con un movimiento puntual, agregarlo
            // automaticamente como medio de cobro tipo Transferencia.
            if (PreMovimientoId.HasValue && PreMovimientoId.Value > 0)
                AgregarMovimientoBancoComoMedio(PreMovimientoId.Value);
            // Si viene desde una cobranza pendiente del repartidor, precargamos efectivo
            if (PrePendienteId.HasValue && PrePendienteId.Value > 0)
                await PrecargarDesdePendienteAsync(PrePendienteId.Value);
            RecalcularTotal();
        }
    }

    /// <summary>Precarga el form con los datos que cargo el repartidor desde el QR:
    /// medio efectivo + importe + observaciones automaticas con el repartidor que lo cobro.</summary>
    private async Task PrecargarDesdePendienteAsync(int pendienteId)
    {
        try
        {
            pendienteOrigen = await Api.GetCobranzaPendienteAsync(pendienteId);
            if (pendienteOrigen is null) return;
            // Buscar caja efectivo
            var cajaEf = cajas?.FirstOrDefault(c => c.IsActive && c.Tipo == "EFECTIVO");
            if (cajaEf is not null)
            {
                formMedios.Add(new MedioForm
                {
                    CajaId = cajaEf.Id,
                    TipoCaja = cajaEf.Tipo,
                    Importe = pendienteOrigen.Importe,
                    Referencia = $"Cobrado por {pendienteOrigen.RepartidorNombre} (QR repartidor)"
                });
            }
            formObservaciones = $"Cobranza precargada por {pendienteOrigen.RepartidorNombre} desde el QR" +
                (string.IsNullOrEmpty(pendienteOrigen.Notas) ? "" : $". Notas: {pendienteOrigen.Notas}");
        }
        catch { /* no critico */ }
    }

    /// <summary>Agrega un movimiento del extracto como medio de cobro tipo Transferencia.
    /// Lo busca en la lista de disponibles y completa caja + importe + referencia.</summary>
    private void AgregarMovimientoBancoComoMedio(int movimientoId)
    {
        var mov = movsBancoDisponibles.FirstOrDefault(m => m.Id == movimientoId);
        if (mov is null) return;
        // Buscar una caja tipo BANCO/TRANSFERENCIA (sino la primera "no efectivo")
        var caja = cajas?.FirstOrDefault(c => c.Tipo == "BANCO" || c.Tipo == "TRANSFERENCIA")
                ?? cajas?.FirstOrDefault(c => c.Tipo != "EFECTIVO" && c.Tipo != "CHEQUES_CARTERA");
        if (caja is null) return;
        formMedios.Add(new MedioForm
        {
            CajaId = caja.Id,
            TipoCaja = caja.Tipo,
            Importe = mov.Importe,
            Referencia = $"Transferencia banco {mov.Fecha:dd/MM} — {(mov.Descripcion ?? "")}"
        });
        movsBancoUsados.Add(mov.Id);
    }

    private async Task Load()
    {
        loading = true;
        try
        {
            // 2026-06-06: si hay texto de búsqueda, lo mandamos al server (busca en TODA la base, no solo
            // entre las últimas 200). Sin texto, trae las últimas 200 como siempre.
            var search = string.IsNullOrWhiteSpace(filtroBuscar) ? null : filtroBuscar.Trim();
            cobranzas = await Api.GetCafeCobranzasAsync(search: search) ?? new();
        }
        catch { ToastService.Error("Error al cargar"); cobranzas = new(); }
        loading = false;
    }

    // 2026-06-06: debounce del buscador — espera 400ms tras la última tecla y dispara Load() al server.
    private System.Threading.CancellationTokenSource? _debounceCts;
    private async Task OnFiltroBuscarInput(ChangeEventArgs e)
    {
        filtroBuscar = e.Value?.ToString() ?? "";
        _debounceCts?.Cancel();
        _debounceCts = new System.Threading.CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(400, token);
            if (token.IsCancellationRequested) return;
            await Load();
            StateHasChanged();
        }
        catch (TaskCanceledException) { /* el usuario sigue tipeando */ }
    }

    private void ShowNueva()
    {
        selClienteId = 0;
        clienteSearch = ""; clienteSearchOpen = false;
        pendientes = null;
        imputaciones = new();
        aCuentaActivo = false; aCuentaImporte = 0;
        formMedios = new();
        formRetenciones = 0;
        formObservaciones = null;
        showNueva = true;
    }

    private IEnumerable<CafeClienteDto> ClientesMatching(string q)
    {
        if (clientes is null) return Enumerable.Empty<CafeClienteDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return clientes;
        bool h(string? s) => s.MatchesSearch(t);
        return clientes.Where(c => c.IsActive
            && (h(c.Codigo) || h(c.Nombre) || h(c.RazonSocial) || h(c.Cuit)
                || h(c.Telefono) || h(c.Email)
                || h(c.Direccion) || h(c.DomicilioEntrega)
                || h(c.Localidad) || h(c.Ciudad) || h(c.Cp)));
    }

    private async Task SelectCliente(int id)
    {
        selClienteId = id;
        clienteSearch = "";
        clienteSearchOpen = false;
        await OnClienteChange();
    }

    private void ClearCliente()
    {
        selClienteId = 0;
        clienteSearch = "";
        clienteSearchOpen = false;
        pendientes = null;
        imputaciones = new();
    }

    private void CloseNueva()
    {
        if (guardando) return;
        showNueva = false;
    }

    private async Task OnClienteChange()
    {
        imputaciones = new();
        saldoCliente = null;
        incluirSucursales = false;
        sucursalesMismoCuit = new();
        movsBancoDisponibles = new();
        movsBancoUsados = new();
        movsBancoDescartados = new();
        verDescartados = false;
        if (selClienteId <= 0) { pendientes = new(); return; }
        try
        {
            // Detectar si hay otras sucursales con el mismo CUIT (caso Dulce Lugar / Premium Bakery).
            try
            {
                sucursalesMismoCuit = await Api.GetSucursalesMismoCuitAsync(selClienteId) ?? new();
            }
            catch { sucursalesMismoCuit = new(); }

            // Cargar movimientos del extracto bancario asociados a este cliente que aun no se usaron
            try { movsBancoDisponibles = await Api.GetMovimientosAsociadosSinCobrarAsync(selClienteId) ?? new(); }
            catch { movsBancoDisponibles = new(); }
            // 2026-06-03: cargar tambien los movimientos descartados para este cliente
            try { movsBancoDescartados = await Api.GetMovimientosDescartadosParaClienteAsync(selClienteId) ?? new(); }
            catch { movsBancoDescartados = new(); }

            await RecargarPendientesAsync();

            // Traer saldo total del cliente
            try
            {
                var ec = await Api.GetEstadoCuentaClienteAsync(selClienteId);
                if (ec is not null) saldoCliente = ec.Saldo;
            }
            catch { }
        }
        catch { ToastService.Error("Error al traer pendientes"); pendientes = new(); }
    }

    /// <summary>Recarga los comprobantes pendientes respetando el flag de "incluir sucursales".
    /// Llamado al cambiar cliente y al tildar/destildar el checkbox.</summary>
    private async Task RecargarPendientesAsync()
    {
        pendientes = await Api.GetComprobantesPendientesAsync(selClienteId, incluirSucursales) ?? new();
        imputaciones = new();
        foreach (var p in pendientes)
            imputaciones[p.VentaId] = new ImputData { Seleccionado = false, Importe = p.Saldo };
    }

    private async Task OnToggleIncluirSucursales(bool val)
    {
        incluirSucursales = val;
        await RecargarPendientesAsync();
    }

    /// <summary>Tildá todos los comprobantes pendientes y poneles el saldo completo (1 click).</summary>
    private void ImputarTodo()
    {
        if (pendientes is null) return;
        foreach (var p in pendientes)
        {
            if (imputaciones.TryGetValue(p.VentaId, out var imp))
            {
                imp.Seleccionado = true;
                imp.Importe = p.Saldo;
            }
        }
        RecalcularTotal();
    }

    private async Task AnularCobranza(CobranzaListDto c)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Anular la cobranza {c.Numero}? Esta acción no se puede revertir.")) return;
        try
        {
            await Api.AnularCafeCobranzaAsync(c.Id);
            ToastService.Success("Cobranza anulada");
            await Load();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private void OnImputeChange(int ventaId, string? value)
    {
        if (imputaciones.TryGetValue(ventaId, out var imp))
        {
            decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v);
            imp.Importe = v;
            // Si tipea importe, asume que quiere imputar
            if (v > 0) imp.Seleccionado = true;
            RecalcularTotal();
        }
    }

    private void OnCajaChange(int idx, string? value)
    {
        if (int.TryParse(value, out var cajaId))
        {
            formMedios[idx].CajaId = cajaId;
            formMedios[idx].TipoCaja = cajas?.FirstOrDefault(c => c.Id == cajaId)?.Tipo ?? "";
        }
    }

    private void AgregarMedio() => formMedios.Add(new MedioForm());

    /// <summary>Tilda/destilda un movimiento del banco para usarlo como forma de cobro.
    /// Al tildar: agrega un medio nuevo con datos pre-rellenados. Al destildar: lo saca.</summary>
    private void ToggleMovimientoBanco(int movId, bool seleccionar)
    {
        if (seleccionar)
        {
            if (!movsBancoUsados.Contains(movId))
            {
                AgregarMovimientoBancoComoMedio(movId);
                RecalcularTotal();
            }
        }
        else
        {
            // Buscamos el medio que vino de este movimiento y lo sacamos
            var mov = movsBancoDisponibles.FirstOrDefault(m => m.Id == movId);
            if (mov is not null)
            {
                var ix = formMedios.FindIndex(m => m.Referencia != null && m.Referencia.Contains(mov.Fecha.ToString("dd/MM")));
                if (ix >= 0) formMedios.RemoveAt(ix);
            }
            movsBancoUsados.Remove(movId);
            RecalcularTotal();
        }
    }

    /// <summary>2026-06-03: descarta un movimiento bancario para este cliente. Llama al backend
    /// que inserta una fila en Cafe_ExtractoMov_DescartadoPorCliente. Despues lo saca de la lista
    /// visible y lo agrega a la lista de descartados (sin recargar todo).</summary>
    private async Task DescartarMovimientoBanco(int movId)
    {
        var mov = movsBancoDisponibles.FirstOrDefault(m => m.Id == movId);
        if (mov is null) return;
        // Si estaba seleccionado como medio, sacarlo primero
        if (movsBancoUsados.Contains(movId)) ToggleMovimientoBanco(movId, false);
        try
        {
            var ok = await Api.DescartarMovimientoParaClienteAsync(movId, selClienteId, Operator.Current);
            if (!ok) { ToastService.Error("No se pudo descartar"); return; }
            movsBancoDisponibles.RemoveAll(m => m.Id == movId);
            movsBancoDescartados.Insert(0, new ApiClient.MovDescartadoDto(mov.Id, mov.Fecha, mov.Descripcion, mov.Importe, DateTime.UtcNow, Operator.Current));
            ToastService.Success("Movimiento descartado para este cliente");
            StateHasChanged();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    /// <summary>2026-06-03: deshace el descarte. El movimiento vuelve a la lista visible.</summary>
    private async Task RestaurarMovimientoBanco(int movId)
    {
        var d = movsBancoDescartados.FirstOrDefault(x => x.MovimientoId == movId);
        if (d is null) return;
        try
        {
            var ok = await Api.RestaurarMovimientoParaClienteAsync(movId, selClienteId);
            if (!ok) { ToastService.Error("No se pudo restaurar"); return; }
            movsBancoDescartados.RemoveAll(x => x.MovimientoId == movId);
            // Recargar la lista visible para que aparezca de vuelta (la fuente de verdad la tiene el backend).
            try { movsBancoDisponibles = await Api.GetMovimientosAsociadosSinCobrarAsync(selClienteId) ?? new(); }
            catch { /* ignore */ }
            ToastService.Success("Movimiento restaurado");
            StateHasChanged();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private void RecalcularTotal() => StateHasChanged();

    private async Task GuardarCobranza()
    {
        if (selClienteId <= 0) { ToastService.Error("Elegí un cliente"); return; }
        if (TotalImputado <= 0) { ToastService.Error("Imputá algo a un comprobante o A cuenta"); return; }
        if (!CuadraTotal) { ToastService.Error("No cuadra: medios + retenciones ≠ imputado"); return; }
        if (formMedios.Any(m => m.CajaId == 0 || m.Importe <= 0)) { ToastService.Error("Hay formas de cobro sin caja o sin importe"); return; }

        var comps = new List<ApiClient.CrearComprobanteItemRequest>();
        foreach (var kv in imputaciones)
            if (kv.Value.Seleccionado && kv.Value.Importe > 0)
                comps.Add(new ApiClient.CrearComprobanteItemRequest(kv.Key, kv.Value.Importe));
        if (aCuentaActivo && aCuentaImporte > 0)
            comps.Add(new ApiClient.CrearComprobanteItemRequest(null, aCuentaImporte));

        var medios = formMedios.Select(m => new ApiClient.CrearMedioItemRequest(
            m.CajaId, m.Importe, m.Referencia,
            m.EsCheque ? new ApiClient.CrearChequeItemRequest(
                m.ChequeNumero, m.ChequeBanco, m.ChequeEmisor, m.Importe,
                m.ChequeFechaVencimiento, m.ChequeFechaVencimiento, null) : null
        )).ToList();

        guardando = true;
        try
        {
            var r = await Api.CrearCafeCobranzaAsync(selClienteId, formRetenciones, null, formObservaciones, comps, medios);
            if (r is null) { ToastService.Error("Error al crear cobranza"); return; }
            // Si se usaron movimientos del extracto bancario, marcarlos como "usados" para que
            // no se sugieran de nuevo en futuras cobranzas.
            if (movsBancoUsados.Count > 0)
            {
                try { await Api.MarcarMovimientosUsadosAsync(movsBancoUsados.ToList(), r.Id); }
                catch { /* no critico — si falla, queda como pendiente */ }
            }
            // Si vino desde una cobranza pendiente del repartidor, vincularla (queda APROBADA)
            if (pendienteOrigen is not null)
            {
                try { await Api.VincularCobranzaPendienteAsync(pendienteOrigen.Id, r.Id, Operator.Current); }
                catch { /* no critico */ }
                pendienteOrigen = null;
            }
            ToastService.Success($"Cobranza {r.Numero} creada");
            showNueva = false;
            await Load();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { guardando = false; }
    }
}
