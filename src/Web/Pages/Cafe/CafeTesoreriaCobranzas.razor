@page "/cafe/tesoreria/cobranzas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        @{
            var vigentes = cobranzas?.Count(c => c.Estado != "ANULADA") ?? 0;
            var anuladas = cobranzas?.Count(c => c.Estado == "ANULADA") ?? 0;
        }
        <h3 style="margin:0;">📥 Cobranzas (@vigentes@(anuladas > 0 ? $" + {anuladas} anuladas" : ""))</h3>
        <div style="display:flex; gap:0.5rem; align-items:center;">
            @if (anuladas > 0)
            {
                <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.8rem; color:#6b7280;">
                    <input type="checkbox" @bind="mostrarAnuladas" />
                    Mostrar anuladas
                </label>
            }
            <button class="btn btn-primary" @onclick="ShowNueva">+ Nueva cobranza</button>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        @{
            var cobranzasFiltradas = cobranzas?.Where(c => mostrarAnuladas || c.Estado != "ANULADA").ToList() ?? new();
        }
        @if (loading)
        {
            <p class="text-muted" style="padding:1rem;">Cargando...</p>
        }
        else if (cobranzasFiltradas.Count == 0)
        {
            <p class="text-muted" style="padding:1rem;">@(cobranzas?.Count > 0 ? "No hay cobranzas vigentes. Tildá 'Mostrar anuladas' para ver el historial." : "Sin cobranzas aún. Hace clic en \"+ Nueva cobranza\" para empezar.")</p>
        }
        else
        {
            <table class="table table-compact">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th style="text-align:right;">Retenciones</th>
                        <th style="text-align:right;">Total</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in cobranzasFiltradas)
                    {
                        <tr style="@(c.Estado == "ANULADA" ? "opacity:0.5; text-decoration:line-through;" : "")">
                            <td><b>@c.Numero</b></td>
                            <td>@c.Fecha.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            <td>@c.ClienteNombre</td>
                            <td style="text-align:right;">@(c.Retenciones > 0 ? $"${c.Retenciones:N2}" : "—")</td>
                            <td style="text-align:right; font-weight:600;">$@c.Total.ToString("N2")</td>
                            <td><span class="badge @(c.Estado == "VIGENTE" ? "badge-success" : "badge-danger")">@c.Estado</span></td>
                            <td>
                                <a class="btn-icon" href="@Api.GetCobranzaPdfUrl(c.Id)" target="_blank" title="Imprimir recibo PDF">📄</a>
                                @if (c.Estado == "VIGENTE")
                                {
                                    <button class="btn-icon" @onclick="() => AnularCobranza(c)" title="Anular cobranza">❌</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showNueva)
{
    <div class="modal-overlay" @onclick="CloseNueva">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 900px; width:90vw; max-height: 90vh; overflow-y:auto;">
            <div class="modal-header">
                <h4 style="margin:0;">📥 Nueva cobranza</h4>
                <button class="btn-close" @onclick="CloseNueva">&times;</button>
            </div>
            <div class="modal-body">

                @* --- Cliente (buscador filtrable) --- *@
                <div class="form-group" style="position: relative;">
                    <label class="form-label">Cliente</label>
                    @if (selClienteId > 0)
                    {
                        var ciSel = clientes?.FirstOrDefault(x => x.Id == selClienteId);
                        <div style="display: flex; gap: 0.3rem; align-items: center;">
                            <div class="form-input" style="flex: 1; background: #ecfdf5; border-color: #10b981; display: flex; align-items: center; gap: 0.5rem;">
                                <span style="font-family: monospace; font-weight: 700; color: #1d4ed8;">@(ciSel?.Codigo ?? "—")</span>
                                <strong>@(ciSel?.Nombre ?? "?")</strong>
                                @if (ciSel is not null && !string.IsNullOrEmpty(ciSel.Cuit))
                                {
                                    <span style="font-size: 0.72rem; color: #6b7280;">· @ciSel.Cuit</span>
                                }
                            </div>
                            <button class="btn btn-secondary" type="button" @onclick="ClearCliente" title="Cambiar cliente">×</button>
                        </div>
                    }
                    else
                    {
                        <input class="form-input" @bind="clienteSearch" @bind:event="oninput"
                               @onfocus="() => clienteSearchOpen = true"
                               placeholder="🔍 Buscar por código, nombre, CUIT, tel, email, dirección…" />
                        @if (clienteSearchOpen && !string.IsNullOrWhiteSpace(clienteSearch))
                        {
                            var matches = ClientesMatching(clienteSearch).Take(20).ToList();
                            <div style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #d1d5db; border-radius: 6px; max-height: 280px; overflow-y: auto; z-index: 100; box-shadow: 0 4px 14px rgba(0,0,0,0.12); margin-top: 0.2rem;">
                                @if (matches.Count == 0)
                                {
                                    <div style="padding: 0.6rem; color: #6b7280; font-size: 0.85rem;">Sin resultados.</div>
                                }
                                else
                                {
                                    @foreach (var ci in matches)
                                    {
                                        var ciId = ci.Id;
                                        <div @onclick="() => SelectCliente(ciId)"
                                             style="padding: 0.4rem 0.6rem; cursor: pointer; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem;">
                                            <span style="font-family: monospace; color: #1d4ed8; font-weight: 700; margin-right: 0.5rem;">@ci.Codigo</span>
                                            <strong>@ci.Nombre</strong>
                                            @if (!string.IsNullOrEmpty(ci.Cuit))
                                            {
                                                <span style="color: #6b7280; font-size: 0.78rem;"> · @ci.Cuit</span>
                                            }
                                            @if (!string.IsNullOrEmpty(ci.Telefono))
                                            {
                                                <span style="color: #6b7280; font-size: 0.78rem;"> · 📞 @ci.Telefono</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>

                @if (selClienteId > 0)
                {
                    @* --- Comprobantes a cobrar --- *@
                    <div style="margin: 1rem 0; padding: 0.8rem; background: #f9fafb; border-radius: 8px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                            <h5 style="margin:0;">Comprobantes a cobrar</h5>
                            @if (pendientes is not null && pendientes.Count > 0)
                            {
                                <div style="display:flex; gap:0.4rem;">
                                    <button class="btn btn-secondary" style="font-size:0.78rem;" @onclick="ImputarTodo">⚡ Cobrar todo lo pendiente</button>
                                </div>
                            }
                        </div>
                        @if (saldoCliente.HasValue && saldoCliente.Value > 0)
                        {
                            <div style="background:#fef3c7; padding:0.4rem 0.6rem; border-radius:6px; font-size:0.82rem; margin-bottom:0.5rem;">
                                💰 Saldo actual del cliente: <b>$@saldoCliente.Value.ToString("N2")</b> (te debe)
                            </div>
                        }
                        @if (pendientes is null)
                        {
                            <p class="text-muted">Cargando...</p>
                        }
                        else if (pendientes.Count == 0)
                        {
                            <p class="text-muted" style="margin:0;">Sin comprobantes pendientes. Podés cargar igual como "A cuenta".</p>
                        }
                        else
                        {
                            <table class="table table-compact" style="margin-bottom:0.5rem;">
                                <thead>
                                    <tr><th></th><th>Número</th><th>Fecha</th><th style="text-align:right;">Saldo</th><th style="text-align:right;">A cobrar</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in pendientes)
                                    {
                                        <tr>
                                            <td><input type="checkbox" @bind="imputaciones[p.VentaId].Seleccionado" @bind:after="RecalcularTotal" /></td>
                                            <td><b>@p.Numero</b></td>
                                            <td>@p.Fecha.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                            <td style="text-align:right;">$@p.Saldo.ToString("N2")</td>
                                            <td style="text-align:right;">
                                                <input class="form-input" type="number" step="0.01" style="text-align:right; width:120px; display:inline-block;"
                                                       value="@imputaciones[p.VentaId].Importe"
                                                       @onchange="@(e => OnImputeChange(p.VentaId, e.Value?.ToString()))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <label class="form-check"><input type="checkbox" @bind="aCuentaActivo" @bind:after="RecalcularTotal" /> A cuenta:</label>
                            <input class="form-input" type="number" step="0.01" style="width:140px;"
                                   @bind="aCuentaImporte" @bind:after="RecalcularTotal" disabled="@(!aCuentaActivo)" />
                        </div>
                        <div style="margin-top:0.5rem; text-align:right; font-weight:700;">
                            Total imputado: $@TotalImputado.ToString("N2")
                        </div>
                    </div>

                    @* --- Formas de cobro --- *@
                    <div style="margin: 1rem 0; padding: 0.8rem; background: #fef3c7; border-radius: 8px;">
                        <h5 style="margin:0 0 0.5rem;">Forma de cobro</h5>
                        @for (int i = 0; i < formMedios.Count; i++)
                        {
                            var idx = i;
                            var m = formMedios[idx];
                            <div style="display:grid; grid-template-columns: 2fr 1fr 2fr 30px; gap:0.4rem; margin-bottom:0.4rem; align-items:start;">
                                <select class="form-input" value="@m.CajaId" @onchange="@(e => OnCajaChange(idx, e.Value?.ToString()))">
                                    <option value="0">— Caja —</option>
                                    @if (cajas is not null)
                                    {
                                        @foreach (var c in cajas.Where(x => x.IsActive))
                                        {
                                            <option value="@c.Id">@c.Nombre</option>
                                        }
                                    }
                                </select>
                                <input class="form-input" type="number" step="0.01" placeholder="Importe"
                                       @bind="m.Importe" @bind:after="RecalcularTotal" />
                                <input class="form-input" placeholder="Referencia (opcional)" @bind="m.Referencia" />
                                <button class="btn-icon" @onclick="() => formMedios.RemoveAt(idx)" title="Quitar">🗑</button>
                            </div>
                            @if (m.EsCheque)
                            {
                                <div style="margin-left:1rem; padding:0.6rem; background:white; border-radius:6px; margin-bottom:0.5rem;">
                                    <div style="font-size:0.78rem; color:#6b7280; margin-bottom:0.3rem;">Datos del cheque</div>
                                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.4rem;">
                                        <input class="form-input" placeholder="Banco" @bind="m.ChequeBanco" />
                                        <input class="form-input" placeholder="Número" @bind="m.ChequeNumero" />
                                        <input class="form-input" placeholder="Emisor (opcional)" @bind="m.ChequeEmisor" />
                                        <input class="form-input" type="date" @bind="m.ChequeFechaVencimiento" />
                                    </div>
                                </div>
                            }
                        }
                        <button class="btn btn-secondary" style="font-size:0.8rem;" @onclick="AgregarMedio">+ Agregar forma de cobro</button>
                    </div>

                    @* --- Retenciones --- *@
                    <div class="form-row">
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Retenciones sufridas</label>
                            <input class="form-input" type="number" step="0.01" @bind="formRetenciones" @bind:after="RecalcularTotal" />
                            <p style="font-size:0.7rem; color:#6b7280; margin:0.2rem 0 0;">Si te aplicaron retenciones (IIBB, IVA, ganancias) ponelas acá. Cancela saldo del cliente pero NO entra a caja.</p>
                        </div>
                    </div>

                    @* --- Observaciones --- *@
                    <div class="form-group">
                        <label class="form-label">Observaciones</label>
                        <input class="form-input" @bind="formObservaciones" />
                    </div>

                    @* --- Resumen --- *@
                    <div style="padding:0.6rem; background:#dbeafe; border-radius:6px;">
                        <div style="display:flex; justify-content:space-between;"><span>Total medios de cobro:</span><b>$@TotalMedios.ToString("N2")</b></div>
                        <div style="display:flex; justify-content:space-between;"><span>+ Retenciones:</span><b>$@formRetenciones.ToString("N2")</b></div>
                        <div style="display:flex; justify-content:space-between;"><span>= Debe igualar el imputado a comprobantes:</span><b style="color:@(CuadraTotal ? "#059669" : "#dc2626");">$@TotalImputado.ToString("N2")</b></div>
                        @if (!CuadraTotal)
                        {
                            <div style="color:#dc2626; font-size:0.78rem; margin-top:0.3rem;">⚠ Los medios + retenciones tienen que sumar exactamente lo imputado a comprobantes.</div>
                        }
                    </div>
                }

            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseNueva" disabled="@guardando">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarCobranza" disabled="@(!CuadraTotal || TotalImputado <= 0 || guardando)">
                    @(guardando ? "..." : "Guardar cobranza")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CobranzaListDto>? cobranzas;
    private bool loading = true;
    // Por default ocultamos las cobranzas anuladas para que el listado quede limpio.
    // El usuario puede tildar el checkbox del header si quiere ver el historial.
    private bool mostrarAnuladas = false;
    private List<CafeClienteDto>? clientes;
    private List<CafeCajaDto>? cajas;

    private bool showNueva, guardando;
    private int selClienteId = 0;
    private string clienteSearch = "";
    private bool clienteSearchOpen;
    private List<ComprobantePendienteDto>? pendientes;
    private decimal? saldoCliente;
    [Parameter, SupplyParameterFromQuery(Name = "cliente")] public int? PreClienteId { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "venta")] public int? PreVentaId { get; set; }
    private Dictionary<int, ImputData> imputaciones = new();
    private bool aCuentaActivo;
    private decimal aCuentaImporte;
    private decimal formRetenciones;
    private string? formObservaciones;
    private List<MedioForm> formMedios = new();

    private class ImputData { public bool Seleccionado { get; set; } public decimal Importe { get; set; } }
    private class MedioForm
    {
        public int CajaId { get; set; }
        public string TipoCaja { get; set; } = "";
        public decimal Importe { get; set; }
        public string? Referencia { get; set; }
        public bool EsCheque => TipoCaja == "CHEQUES_CARTERA";
        public string ChequeBanco { get; set; } = "";
        public string ChequeNumero { get; set; } = "";
        public string? ChequeEmisor { get; set; }
        public DateTime? ChequeFechaVencimiento { get; set; }
    }

    private decimal TotalImputado => imputaciones.Where(kv => kv.Value.Seleccionado).Sum(kv => kv.Value.Importe) + (aCuentaActivo ? aCuentaImporte : 0);
    private decimal TotalMedios => formMedios.Sum(m => m.Importe);
    private bool CuadraTotal => Math.Abs(TotalImputado - (TotalMedios + formRetenciones)) < 0.01m;

    protected override async Task OnInitializedAsync()
    {
        clientes = await Api.GetCafeClientesAsync() ?? new();
        cajas = await Api.GetCafeCajasAsync() ?? new();
        await Load();
        // Atajo desde otra pantalla: si vino con ?cliente=X o ?cliente=X&venta=Y, abre el modal precargado
        if (PreClienteId.HasValue && PreClienteId.Value > 0)
        {
            ShowNueva();
            await SelectCliente(PreClienteId.Value);
            if (PreVentaId.HasValue && PreVentaId.Value > 0 && imputaciones.TryGetValue(PreVentaId.Value, out var imp))
                imp.Seleccionado = true;
        }
    }

    private async Task Load()
    {
        loading = true;
        try { cobranzas = await Api.GetCafeCobranzasAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar"); cobranzas = new(); }
        loading = false;
    }

    private void ShowNueva()
    {
        selClienteId = 0;
        clienteSearch = ""; clienteSearchOpen = false;
        pendientes = null;
        imputaciones = new();
        aCuentaActivo = false; aCuentaImporte = 0;
        formMedios = new();
        formRetenciones = 0;
        formObservaciones = null;
        showNueva = true;
    }

    private IEnumerable<CafeClienteDto> ClientesMatching(string q)
    {
        if (clientes is null) return Enumerable.Empty<CafeClienteDto>();
        var t = q.Trim();
        if (string.IsNullOrEmpty(t)) return clientes;
        bool h(string? s) => !string.IsNullOrEmpty(s) && s.Contains(t, StringComparison.OrdinalIgnoreCase);
        return clientes.Where(c => c.IsActive
            && (h(c.Codigo) || h(c.Nombre) || h(c.RazonSocial) || h(c.Cuit)
                || h(c.Telefono) || h(c.Email)
                || h(c.Direccion) || h(c.Localidad) || h(c.Ciudad) || h(c.Cp)));
    }

    private async Task SelectCliente(int id)
    {
        selClienteId = id;
        clienteSearch = "";
        clienteSearchOpen = false;
        await OnClienteChange();
    }

    private void ClearCliente()
    {
        selClienteId = 0;
        clienteSearch = "";
        clienteSearchOpen = false;
        pendientes = null;
        imputaciones = new();
    }

    private void CloseNueva()
    {
        if (guardando) return;
        showNueva = false;
    }

    private async Task OnClienteChange()
    {
        imputaciones = new();
        saldoCliente = null;
        if (selClienteId <= 0) { pendientes = new(); return; }
        try
        {
            pendientes = await Api.GetComprobantesPendientesAsync(selClienteId) ?? new();
            foreach (var p in pendientes)
                imputaciones[p.VentaId] = new ImputData { Seleccionado = false, Importe = p.Saldo };
            // Traer saldo total del cliente
            try
            {
                var ec = await Api.GetEstadoCuentaClienteAsync(selClienteId);
                if (ec is not null) saldoCliente = ec.Saldo;
            }
            catch { }
        }
        catch { ToastService.Error("Error al traer pendientes"); pendientes = new(); }
    }

    /// <summary>Tildá todos los comprobantes pendientes y poneles el saldo completo (1 click).</summary>
    private void ImputarTodo()
    {
        if (pendientes is null) return;
        foreach (var p in pendientes)
        {
            if (imputaciones.TryGetValue(p.VentaId, out var imp))
            {
                imp.Seleccionado = true;
                imp.Importe = p.Saldo;
            }
        }
        RecalcularTotal();
    }

    private async Task AnularCobranza(CobranzaListDto c)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Anular la cobranza {c.Numero}? Esta acción no se puede revertir.")) return;
        try
        {
            await Api.AnularCafeCobranzaAsync(c.Id);
            ToastService.Success("Cobranza anulada");
            await Load();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private void OnImputeChange(int ventaId, string? value)
    {
        if (imputaciones.TryGetValue(ventaId, out var imp))
        {
            decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v);
            imp.Importe = v;
            // Si tipea importe, asume que quiere imputar
            if (v > 0) imp.Seleccionado = true;
            RecalcularTotal();
        }
    }

    private void OnCajaChange(int idx, string? value)
    {
        if (int.TryParse(value, out var cajaId))
        {
            formMedios[idx].CajaId = cajaId;
            formMedios[idx].TipoCaja = cajas?.FirstOrDefault(c => c.Id == cajaId)?.Tipo ?? "";
        }
    }

    private void AgregarMedio() => formMedios.Add(new MedioForm());
    private void RecalcularTotal() => StateHasChanged();

    private async Task GuardarCobranza()
    {
        if (selClienteId <= 0) { ToastService.Error("Elegí un cliente"); return; }
        if (TotalImputado <= 0) { ToastService.Error("Imputá algo a un comprobante o A cuenta"); return; }
        if (!CuadraTotal) { ToastService.Error("No cuadra: medios + retenciones ≠ imputado"); return; }
        if (formMedios.Any(m => m.CajaId == 0 || m.Importe <= 0)) { ToastService.Error("Hay formas de cobro sin caja o sin importe"); return; }

        var comps = new List<ApiClient.CrearComprobanteItemRequest>();
        foreach (var kv in imputaciones)
            if (kv.Value.Seleccionado && kv.Value.Importe > 0)
                comps.Add(new ApiClient.CrearComprobanteItemRequest(kv.Key, kv.Value.Importe));
        if (aCuentaActivo && aCuentaImporte > 0)
            comps.Add(new ApiClient.CrearComprobanteItemRequest(null, aCuentaImporte));

        var medios = formMedios.Select(m => new ApiClient.CrearMedioItemRequest(
            m.CajaId, m.Importe, m.Referencia,
            m.EsCheque ? new ApiClient.CrearChequeItemRequest(
                m.ChequeNumero, m.ChequeBanco, m.ChequeEmisor, m.Importe,
                m.ChequeFechaVencimiento, m.ChequeFechaVencimiento, null) : null
        )).ToList();

        guardando = true;
        try
        {
            var r = await Api.CrearCafeCobranzaAsync(selClienteId, formRetenciones, null, formObservaciones, comps, medios);
            if (r is null) { ToastService.Error("Error al crear cobranza"); return; }
            ToastService.Success($"Cobranza {r.Numero} creada");
            showNueva = false;
            await Load();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { guardando = false; }
    }
}
