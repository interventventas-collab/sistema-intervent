@page "/cafe/tesoreria/cajas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h3 style="margin:0;">💰 Tesorería · Cajas (@(cajas?.Count ?? 0))</h3>
        <button class="btn btn-primary" @onclick="ShowCreate">+ Nueva caja</button>
    </div>
    <div class="card-body" style="padding:0;">
        @if (loading)
        {
            <p class="text-muted" style="padding:1rem;">Cargando...</p>
        }
        else if (cajas is null || cajas.Count == 0)
        {
            <p class="text-muted" style="padding:1rem;">Sin cajas configuradas.</p>
        }
        else
        {
            <table class="table table-compact">
                <thead>
                    <tr>
                        <th style="width:60px;">Orden</th>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th style="text-align:right;">Saldo inicial</th>
                        <th style="text-align:right;">Saldo actual</th>
                        <th>Estado</th>
                        <th style="width:120px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in cajas.OrderBy(x => x.Orden).ThenBy(x => x.Nombre))
                    {
                        <tr style="@(c.IsActive ? "" : "opacity:0.5;")">
                            <td>@c.Orden</td>
                            <td><b>@c.Nombre</b>@if (!string.IsNullOrWhiteSpace(c.Notas)) { <div style="font-size:0.75rem; color:#6b7280;">@c.Notas</div> }</td>
                            <td><span class="badge badge-secondary">@FormatTipo(c.Tipo)</span></td>
                            <td style="text-align:right;">$@c.SaldoInicial.ToString("N2")</td>
                            <td style="text-align:right; font-weight:700; color:@(c.SaldoActual >= 0 ? "#059669" : "#dc2626");">
                                $@c.SaldoActual.ToString("N2")
                            </td>
                            <td>@(c.IsActive ? "Activa" : "Inactiva")</td>
                            <td>
                                <button class="btn-icon" @onclick="() => ShowEdit(c)" title="Editar">✎</button>
                                <button class="btn-icon" @onclick="() => Eliminar(c)" title="Eliminar" disabled="@(c.SaldoActual != c.SaldoInicial)">🗑</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4 style="margin:0;">@(editing is null ? "Nueva caja" : $"Editar: {editing.Nombre}")</h4>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Nombre</label>
                    <input class="form-input" @bind="formNombre" placeholder="ej: Galicia Empresas" />
                </div>
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-input" @bind="formTipo">
                        <option value="EFECTIVO">Efectivo</option>
                        <option value="BANCO">Banco</option>
                        <option value="BILLETERA_VIRTUAL">Billetera virtual (MP, Modo, etc.)</option>
                        <option value="CHEQUES_CARTERA">Cheques en cartera</option>
                        <option value="V_PRIVADO">V / Privada (triangulación)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Saldo inicial</label>
                    <input class="form-input" type="number" step="0.01" @bind="formSaldoInicial" />
                    <p style="font-size:0.7rem; color:#6b7280; margin:0.2rem 0 0;">Lo que tenés HOY en esta caja al arrancar el sistema.</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Orden de aparición</label>
                    <input class="form-input" type="number" @bind="formOrden" />
                </div>
                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <input class="form-input" @bind="formNotas" />
                </div>
                @if (editing is not null)
                {
                    <div class="form-group">
                        <label class="form-check">
                            <input type="checkbox" @bind="formIsActive" /> Activa
                        </label>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm">Cancelar</button>
                <button class="btn btn-primary" @onclick="Guardar" disabled="@saving">@(saving ? "..." : "Guardar")</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CafeCajaDto>? cajas;
    private bool loading = true;
    private bool showForm, saving;
    private CafeCajaDto? editing;
    private string formNombre = "", formTipo = "EFECTIVO", formNotas = "";
    private decimal formSaldoInicial = 0;
    private int formOrden = 0;
    private bool formIsActive = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        try { cajas = await Api.GetCafeCajasAsync(incluirInactivas: true) ?? new(); }
        catch { ToastService.Error("Error al cargar cajas"); cajas = new(); }
        loading = false;
    }

    private void ShowCreate()
    {
        editing = null;
        formNombre = ""; formTipo = "EFECTIVO"; formNotas = "";
        formSaldoInicial = 0; formOrden = (cajas?.Max(c => (int?)c.Orden) ?? 0) + 1;
        formIsActive = true;
        showForm = true;
    }

    private void ShowEdit(CafeCajaDto c)
    {
        editing = c;
        formNombre = c.Nombre; formTipo = c.Tipo; formNotas = c.Notas ?? "";
        formSaldoInicial = c.SaldoInicial; formOrden = c.Orden; formIsActive = c.IsActive;
        showForm = true;
    }

    private void CloseForm()
    {
        if (saving) return;
        showForm = false;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(formNombre)) { ToastService.Error("Nombre vacío"); return; }
        saving = true;
        try
        {
            if (editing is null)
                await Api.CrearCafeCajaAsync(formNombre, formTipo, formSaldoInicial, formOrden, formNotas);
            else
                await Api.EditarCafeCajaAsync(editing.Id, formNombre, formTipo, formSaldoInicial, formOrden, formIsActive, formNotas);
            ToastService.Success("Caja guardada");
            showForm = false;
            await Load();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { saving = false; }
    }

    private async Task Eliminar(CafeCajaDto c)
    {
        if (!await ConfirmAsync($"Eliminar la caja \"{c.Nombre}\"? Solo se puede si no tiene movimientos.")) return;
        try
        {
            await Api.EliminarCafeCajaAsync(c.Id);
            ToastService.Success("Caja eliminada");
            await Load();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private Task<bool> ConfirmAsync(string msg) => Task.FromResult(true); // placeholder simple

    private static string FormatTipo(string t) => t switch
    {
        "EFECTIVO" => "💵 Efectivo",
        "BANCO" => "🏦 Banco",
        "BILLETERA_VIRTUAL" => "📱 Billetera virtual",
        "CHEQUES_CARTERA" => "📄 Cheques en cartera",
        "V_PRIVADO" => "🔀 V / Privada",
        _ => t
    };
}
