@page "/stock/ranking"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@using System.Globalization
@using System.Text

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <div>
            <h3 style="margin:0;">🏆 Ranking de productos vendidos</h3>
            <p class="text-muted" style="margin:0.3rem 0 0; font-size:0.82rem;">
                Top productos según unidades, facturación, margen o cantidad de clientes. Filtros idénticos al de reposición.
            </p>
        </div>
        <div style="display:flex; gap:0.5rem;">
            <button class="btn btn-secondary" @onclick="CargarAsync" disabled="@cargando">🔄 Actualizar</button>
            <button class="btn btn-primary" @onclick="ExportarExcel" disabled="@(filas.Count == 0)">📄 Exportar Excel</button>
        </div>
    </div>

    <div class="card-body" style="background:#f8fafc; border-bottom:1px solid #e5e7eb;">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:0.7rem;">
            <div>
                <label class="form-label">Desde</label>
                <input type="date" class="form-control" @bind="desde" />
            </div>
            <div>
                <label class="form-label">Hasta</label>
                <input type="date" class="form-control" @bind="hasta" />
            </div>
            <div>
                <label class="form-label">Marca</label>
                <select class="form-control" @bind="marcaTexto">
                    <option value="">— Todas —</option>
                    @foreach (var m in marcas) { <option value="@m">@m</option> }
                </select>
            </div>
            <div>
                <label class="form-label">Código OEM</label>
                <input type="text" class="form-control" placeholder="ej: 1076" @bind="oemCodigo" />
            </div>
            <div>
                <label class="form-label">SKU del sistema</label>
                <input type="text" class="form-control" placeholder="ej: C1076" @bind="sku" />
            </div>
            <div>
                <label class="form-label">Categoría</label>
                <select class="form-control" @bind="categoria">
                    <option value="">— Todas —</option>
                    <option value="CAFE">CAFE</option>
                    <option value="OTROS">OTROS</option>
                </select>
            </div>
            <div>
                <label class="form-label">Cliente (opcional)</label>
                <select class="form-control" @bind="clienteId">
                    <option value="0">— Todos —</option>
                    @foreach (var c in clientes) { <option value="@c.Id">@c.Nombre</option> }
                </select>
            </div>
        </div>

        <div style="margin-top:0.8rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
            <div>
                <label class="form-label" style="margin-right:0.3rem;">Ordenar por:</label>
                <select @bind="orderBy" style="padding:0.35rem 0.6rem; border:1px solid #d1d5db; border-radius:6px;">
                    <option value="unidades">🏆 Cantidad vendida</option>
                    <option value="facturado">💰 Facturación total</option>
                    <option value="margen">📈 Margen ganado</option>
                    <option value="clientes">👥 Clientes únicos</option>
                </select>
            </div>
            <div>
                <label class="form-label" style="margin-right:0.3rem;">Mostrar:</label>
                <select @bind="top" style="padding:0.35rem 0.6rem; border:1px solid #d1d5db; border-radius:6px;">
                    <option value="20">Top 20</option>
                    <option value="50">Top 50</option>
                    <option value="100">Top 100</option>
                    <option value="500">Top 500</option>
                </select>
            </div>
            <div style="margin-left:auto;">
                <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando">
                    @(cargando ? "Buscando..." : "🔍 Buscar")
                </button>
            </div>
        </div>

        <div style="margin-top:0.5rem; display:flex; gap:0.3rem; flex-wrap:wrap;">
            <button class="btn-shortcut" @onclick="@(() => SetPeriodo(7))">Últimos 7 días</button>
            <button class="btn-shortcut" @onclick="@(() => SetPeriodo(30))">Últimos 30 días</button>
            <button class="btn-shortcut" @onclick="@(() => SetPeriodo(90))">Últimos 90 días</button>
            <button class="btn-shortcut" @onclick="SetMesActual">Este mes</button>
            <button class="btn-shortcut" @onclick="SetMesAnterior">Mes pasado</button>
        </div>
    </div>

    <div class="card-body" style="padding:0;">
        @if (cargando)
        {
            <p class="text-muted" style="padding:1.5rem;">Calculando...</p>
        }
        else if (filas.Count == 0)
        {
            <p class="text-muted" style="padding:1.5rem;">Sin datos. Tocá <strong>Buscar</strong> para empezar.</p>
        }
        else
        {
            <div style="padding:0.75rem 1rem; background:#fffbeb; border-bottom:1px solid #fde68a; font-size:0.85rem;">
                🏆 Top <strong>@filas.Count</strong> de @totalSinTop productos · Unidades: <strong>@filas.Sum(f => f.VendidoUnidades) u</strong> · Facturado: <strong>$@filas.Sum(f => f.FacturadoTotal).ToString("N0", CultureInfo.GetCultureInfo("es-AR"))</strong> · Margen: <strong>$@filas.Sum(f => f.MargenTotal).ToString("N0", CultureInfo.GetCultureInfo("es-AR"))</strong>
            </div>
            <div style="overflow-x:auto;">
                <table class="table" style="margin:0; font-size:0.85rem;">
                    <thead>
                        <tr>
                            <th style="width:50px;">#</th>
                            <th>SKU</th>
                            <th>Producto</th>
                            <th>Marca</th>
                            <th style="text-align:right;">Stock</th>
                            <th style="text-align:right;">Unidades</th>
                            <th style="text-align:right;">Facturado</th>
                            <th style="text-align:right;">Margen</th>
                            <th style="text-align:right;">Clientes</th>
                            <th style="text-align:right;">Ventas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 0; }
                        @foreach (var f in filas)
                        {
                            i++;
                            var bgRank = i <= 3 ? "background:#fef3c7;" : "";
                            <tr>
                                <td style="@bgRank font-weight:700;">@(i)@(i==1?"🥇":i==2?"🥈":i==3?"🥉":"")</td>
                                <td><code>@(f.Sku ?? "—")</code></td>
                                <td>@f.Nombre</td>
                                <td>@(f.Marca ?? "—")</td>
                                <td style="text-align:right; @(f.StockActual <= 0 ? "color:#dc2626;" : "")">@f.StockActual</td>
                                <td style="text-align:right; font-weight:700;">@f.VendidoUnidades</td>
                                <td style="text-align:right;">$@f.FacturadoTotal.ToString("N0", CultureInfo.GetCultureInfo("es-AR"))</td>
                                <td style="text-align:right; color:@(f.MargenTotal >= 0 ? "#15803d" : "#991b1b");">$@f.MargenTotal.ToString("N0", CultureInfo.GetCultureInfo("es-AR"))</td>
                                <td style="text-align:right;">@f.ClientesUnicos</td>
                                <td style="text-align:right; color:#6b7280;">@f.CantidadVentas</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.btn-shortcut {
    background:#fff; border:1px solid #d1d5db; color:#374151;
    padding:0.3rem 0.7rem; border-radius:6px; font-size:0.78rem; cursor:pointer;
}
.btn-shortcut:hover { background:#f3f4f6; }
</style>

@code {
    private DateTime? desde = DateTime.Today.AddDays(-30);
    private DateTime? hasta = DateTime.Today;
    private string? marcaTexto;
    private string? oemCodigo;
    private string? sku;
    private string? categoria;
    private int clienteId;
    private string orderBy = "unidades";
    private int top = 50;

    private List<string> marcas = new();
    private List<CafeClienteDto> clientes = new();
    private List<ApiClient.RankingRow> filas = new();
    private int totalSinTop;
    private bool cargando;

    private void SetPeriodo(int dias) { desde = DateTime.Today.AddDays(-dias); hasta = DateTime.Today; }
    private void SetMesActual() { var hoy = DateTime.Today; desde = new DateTime(hoy.Year, hoy.Month, 1); hasta = hoy; }
    private void SetMesAnterior() { var hoy = DateTime.Today; var inicio = new DateTime(hoy.Year, hoy.Month, 1).AddMonths(-1); desde = inicio; hasta = inicio.AddMonths(1).AddDays(-1); }

    protected override async Task OnInitializedAsync()
    {
        var marcasData = await Api.GetCafeMarcasAsync(activos: true);
        if (marcasData is not null) marcas = marcasData.Select(m => m.Nombre).OrderBy(n => n).ToList();
        var clientesData = await Api.GetCafeClientesAsync();
        if (clientesData is not null) clientes = clientesData.OrderBy(c => c.Nombre).ToList();
    }

    private async Task CargarAsync()
    {
        cargando = true;
        try
        {
            var res = await Api.GetRankingAsync(
                desde: desde, hasta: hasta?.AddDays(1),
                marcaTexto: string.IsNullOrWhiteSpace(marcaTexto) ? null : marcaTexto,
                oemCodigo: string.IsNullOrWhiteSpace(oemCodigo) ? null : oemCodigo,
                sku: string.IsNullOrWhiteSpace(sku) ? null : sku,
                categoria: string.IsNullOrWhiteSpace(categoria) ? null : categoria,
                clienteId: clienteId > 0 ? clienteId : null,
                orderBy: orderBy, top: top);
            filas = res?.Filas ?? new();
            totalSinTop = res?.Total ?? 0;
            if (filas.Count == 0) ToastService.Info("Sin resultados");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { cargando = false; }
    }

    private async Task ExportarExcel()
    {
        if (filas.Count == 0) return;
        var sb = new StringBuilder();
        sb.Append('﻿');
        var hoy = DateTime.Today.ToString("dd/MM/yyyy");
        sb.AppendLine($"RANKING DE PRODUCTOS;;;;;;;;");
        sb.AppendLine($"Fecha;{hoy};;;;;;;");
        sb.AppendLine($"Período;{desde:dd/MM/yyyy} a {hasta:dd/MM/yyyy};;;;;;;");
        sb.AppendLine($"Ordenado por;{orderBy};;;;;;;");
        sb.AppendLine();
        sb.AppendLine("#;SKU;Producto;Marca;Stock actual;Unidades vendidas;Facturado;Margen;Clientes únicos;Cant. ventas");
        int i = 0;
        foreach (var f in filas)
        {
            i++;
            sb.AppendLine($"{i};{Esc(f.Sku)};{Esc(f.Nombre)};{Esc(f.Marca)};{f.StockActual};{f.VendidoUnidades};{f.FacturadoTotal:0.00};{f.MargenTotal:0.00};{f.ClientesUnicos};{f.CantidadVentas}");
        }
        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var fileName = $"Ranking-{orderBy}-{DateTime.Today:yyyy-MM-dd}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(bytes));
        ToastService.Success("Ranking descargado");
    }

    private static string Esc(string? s) => string.IsNullOrEmpty(s) ? "" : s.Replace(";", ",").Replace("\n", " ").Replace("\r", " ");
}
