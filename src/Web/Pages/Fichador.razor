@page "/fichador"
@attribute [AllowAnonymous]
@layout Web.Layout.LoginLayout
@inject HttpClient Http
@inject IJSRuntime JS

@* 2026-06-03: Kiosco de fichada. Pantalla pensada para correr SIEMPRE ABIERTA en un celular
   o tablet del negocio. Empleados tocan su nombre + PIN -> ficha entrada o salida (auto).
   Fase 2 (proximamente): huella biometrica via WebAuthn.
   2026-06-05: PWA — desde el celu se puede agregar a pantalla principal con icono propio. *@

<HeadContent>
    <link rel="manifest" href="/manifest-fichador.json" />
    <meta name="theme-color" content="#1e3a8a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Fichador" />
    <link rel="apple-touch-icon" href="/img/fichador-icon.svg" />
    <title>Fichador · FRIKAF</title>
</HeadContent>

<style>
    body { background: linear-gradient(135deg, #0f172a, #1e3a8a); min-height: 100vh; color: white; margin:0; }
    .kio-wrap { max-width: 900px; margin: 0 auto; padding: 1rem; }
    .kio-header { display:flex; justify-content:space-between; align-items:center; margin-bottom: 1.2rem; }
    .kio-titulo { font-size: 1.6rem; font-weight: 800; margin: 0; }
    .kio-fecha { font-size: 0.95rem; opacity: 0.85; }
    .kio-reloj { font-family: monospace; font-size: 2rem; font-weight: 700; color: #fbbf24; }
    .kio-instruccion { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; padding: 0.9rem 1.1rem; margin-bottom: 1.2rem; font-size: 1rem; }
    .kio-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.7rem; }
    .kio-card {
        background: white; color: #1f2937; border-radius: 14px; padding: 1rem 0.8rem;
        text-align: center; cursor: pointer; transition: transform 0.1s, box-shadow 0.2s;
        border: 3px solid transparent; min-height: 130px; display: flex; flex-direction: column;
        justify-content: center; align-items: center; box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }
    .kio-card:active { transform: scale(0.96); }
    /* 2026-06-03 Semaforo: ROJO sin fichar / VERDE trabajando / AZUL salio */
    .kio-card.sin-fichar { background: #fee2e2; border-color: #dc2626; }
    .kio-card.trabajando { background: #dcfce7; border-color: #16a34a; }
    .kio-card.salio { background: #dbeafe; border-color: #3b82f6; }
    .kio-card-avatar { width: 48px; height: 48px; border-radius: 50%; background: #1d4ed8; color: white; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem; }
    .kio-card.sin-fichar .kio-card-avatar { background: #dc2626; }
    .kio-card.trabajando .kio-card-avatar { background: #16a34a; }
    .kio-card.salio .kio-card-avatar { background: #3b82f6; }
    .kio-card-nombre { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.3rem; }
    .kio-card-estado { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .kio-card.sin-fichar .kio-card-estado { color: #991b1b; }
    .kio-card.trabajando .kio-card-estado { color: #15803d; }
    .kio-card.salio .kio-card-estado { color: #1e40af; }

    .kio-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
    .kio-modal { background: white; color: #1f2937; border-radius: 16px; padding: 1.4rem; max-width: 380px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
    .kio-modal-titulo { font-size: 1.3rem; font-weight: 800; margin: 0 0 0.4rem; text-align: center; }
    .kio-modal-tipo { text-align: center; font-size: 1rem; color: #6b7280; margin-bottom: 1rem; }
    .kio-pin-input { width: 100%; padding: 1rem; font-size: 2.5rem; text-align: center; letter-spacing: 0.7rem; border: 2px solid #d1d5db; border-radius: 10px; font-weight: 700; color: #1d4ed8; font-family: monospace; }
    .kio-pin-input:focus { outline: none; border-color: #1d4ed8; box-shadow: 0 0 0 4px rgba(29,78,216,0.15); }
    .kio-modal-btn { width: 100%; padding: 1rem; font-size: 1.1rem; font-weight: 700; border: none; border-radius: 10px; cursor: pointer; margin-top: 0.8rem; }
    .kio-modal-btn-primary { background: #1d4ed8; color: white; }
    .kio-modal-btn-primary:disabled { background: #9ca3af; cursor: not-allowed; }
    .kio-modal-btn-cancel { background: #e5e7eb; color: #1f2937; }
    .kio-modal-err { color: #b91c1c; text-align: center; margin-top: 0.5rem; font-size: 0.9rem; font-weight: 600; }

    .kio-huella-btn {
        width: 100%; padding: 1.1rem; font-size: 1.15rem; font-weight: 800;
        border: none; border-radius: 14px; cursor: pointer; margin-bottom: 1rem;
        background: linear-gradient(135deg, #16a34a, #047857); color: white;
        box-shadow: 0 4px 14px rgba(22,163,74,0.4); text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .kio-huella-btn:active { transform: scale(0.98); }
    .kio-huella-btn:disabled { background: #6b7280; cursor: not-allowed; box-shadow: none; }
    .kio-huella-chk {
        display: flex; align-items: center; gap: 0.5rem;
        background: #f0fdf4; border: 1px solid #16a34a; border-radius: 8px;
        padding: 0.6rem 0.8rem; margin-top: 0.7rem; cursor: pointer;
        font-size: 0.9rem; color: #15803d;
    }
    .kio-huella-chk input { width: 1.1rem; height: 1.1rem; cursor: pointer; }

    .kio-toast { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #16a34a; color: white; padding: 1.5rem 2.5rem; border-radius: 16px; font-weight: 700; font-size: 1.4rem; box-shadow: 0 20px 60px rgba(0,0,0,0.4); z-index: 2000; text-align: center; }
    .kio-toast.error { background: #dc2626; }
    .kio-toast-tipo { font-size: 0.8rem; opacity: 0.85; font-weight: 600; }
    .kio-toast-msg { margin: 0.3rem 0; }
    .kio-toast-hora { font-family: monospace; font-size: 1.8rem; }

    @@media (max-width: 600px) {
        .kio-grid { grid-template-columns: repeat(2, 1fr); }
        .kio-titulo { font-size: 1.3rem; }
        .kio-reloj { font-size: 1.6rem; }
    }
</style>

<div class="kio-wrap">
    <div class="kio-header">
        <div>
            <h1 class="kio-titulo">🕐 Fichar Entrada / Salida</h1>
            <div class="kio-fecha">@FechaLabel</div>
        </div>
        <div class="kio-reloj">@HoraActual</div>
    </div>

    @if (huellaDisponible)
    {
        <button class="kio-huella-btn" @onclick="FicharConHuella" disabled="@huellaProcessing">
            @(huellaProcessing ? "Esperando huella..." : "👆 FICHAR CON HUELLA")
        </button>
    }

    <div class="kio-instruccion">
        👉 Tocá tu nombre, ingresá tu PIN (3 últimos del DNI) y listo.
        @if (huellaDisponible) { <span> O tocá <strong>FICHAR CON HUELLA</strong> arriba si ya la registraste.</span> }
    </div>

    @if (cargando)
    {
        <p style="text-align:center; padding:2rem;">Cargando empleados...</p>
    }
    else if (empleados.Count == 0)
    {
        <p style="text-align:center; padding:2rem; opacity:0.8;">No hay empleados activos. Pedile al admin que cargue empleados.</p>
    }
    else
    {
        <div class="kio-grid">
            @foreach (var e in empleados)
            {
                <div class="kio-card @e.Estado" @onclick="() => OnCardTap(e)">
                    <div class="kio-card-avatar">@(e.Nombre.Length > 0 ? e.Nombre[0].ToString() : "?")</div>
                    <div class="kio-card-nombre">@e.Nombre</div>
                    @* 2026-06-10: texto de estado oculto, solo se muestra el color del borde *@
                </div>
            }
        </div>
    }
</div>

@if (empleadoElegido is not null)
{
    <div class="kio-modal-overlay" @onclick="CerrarPin">
        <div class="kio-modal" @onclick:stopPropagation="true">
            <h2 class="kio-modal-titulo">Hola @empleadoElegido.Nombre 👋</h2>
            <div class="kio-modal-tipo">
                @if (empleadoElegido.Estado == "trabajando") { <span>🌆 Vas a marcar <strong>SALIDA</strong></span> }
                else { <span>🌅 Vas a marcar <strong>ENTRADA</strong></span> }
            </div>

            @if (modoModal == "huella-esperando")
            {
                <div style="text-align:center; padding:1.5rem 0;">
                    <div style="font-size:5rem;">👆</div>
                    <div style="font-size:1.1rem; font-weight:600; color:#15803d; margin-top:0.5rem;">
                        Poné tu dedo en el lector
                    </div>
                    @if (intentosHuella > 0)
                    {
                        <div style="font-size:0.85rem; color:#b91c1c; margin-top:0.6rem;">
                            ⚠ Intento @(intentosHuella) de 3 fallado. @(intentosHuella >= 3 ? "Usá tu PIN abajo." : "Volvé a intentar.")
                        </div>
                    }
                </div>
                @if (intentosHuella >= 3)
                {
                    <input type="tel" inputmode="numeric" maxlength="3" class="kio-pin-input"
                           value="@pinInput" @oninput="OnPinInput" @onkeydown="OnPinKeyDown"
                           placeholder="PIN" autofocus />
                    @if (!string.IsNullOrEmpty(errorPin)) { <div class="kio-modal-err">⚠ @errorPin</div> }
                    <button class="kio-modal-btn kio-modal-btn-primary" @onclick="MarcarConPinAsync" disabled="@(marcando || pinInput.Length != 3)">
                        @(marcando ? "Marcando..." : "✅ FICHAR CON PIN")
                    </button>
                }
                else
                {
                    <button class="kio-modal-btn kio-modal-btn-cancel" @onclick="@(async () => await IntentarHuellaParaEmpleado())">
                        🔄 Reintentar huella
                    </button>
                }
            }
            else if (modoModal == "registrar-huella")
            {
                <input type="tel" inputmode="numeric" maxlength="3" class="kio-pin-input"
                       value="@pinInput" @oninput="OnPinInput" @onkeydown="OnPinKeyDown"
                       placeholder="PIN" autofocus />
                @if (!string.IsNullOrEmpty(errorPin)) { <div class="kio-modal-err">⚠ @errorPin</div> }
                <div style="font-size:0.85rem; color:#15803d; background:#f0fdf4; padding:0.6rem; border-radius:8px; margin-top:0.6rem;">
                    Ingresá tu PIN y tocá "REGISTRAR HUELLA". El celular te va a pedir el dedo.
                </div>
                <button class="kio-modal-btn kio-modal-btn-primary" @onclick="RegistrarHuellaAsync" disabled="@(marcando || pinInput.Length != 3)">
                    @(marcando ? "Procesando..." : "👆 REGISTRAR HUELLA")
                </button>
            }
            else  // modo "pin" (clásico, sin huella registrada en este empleado)
            {
                <input type="tel" inputmode="numeric" maxlength="3" class="kio-pin-input"
                       value="@pinInput" @oninput="OnPinInput" @onkeydown="OnPinKeyDown"
                       placeholder="•••" autofocus />
                @if (!string.IsNullOrEmpty(errorPin)) { <div class="kio-modal-err">⚠ @errorPin</div> }
                <button class="kio-modal-btn kio-modal-btn-primary" @onclick="MarcarConPinAsync" disabled="@(marcando || pinInput.Length != 3)">
                    @(marcando ? "Marcando..." : "✅ FICHAR")
                </button>
                @if (huellaDisponible)
                {
                    <button class="kio-modal-btn kio-modal-btn-cancel" style="background:#16a34a; color:white;"
                            @onclick="@(() => { modoModal = "registrar-huella"; pinInput = ""; errorPin = null; })">
                        👆 Registrar mi huella ahora
                    </button>
                }
            }

            <button class="kio-modal-btn kio-modal-btn-cancel" @onclick="CerrarPin">Cancelar</button>
        </div>
    </div>
}

@if (toastVisible)
{
    <div class="kio-toast @(toastError ? "error" : "")">
        @if (!string.IsNullOrEmpty(toastTipo))
        {
            <div class="kio-toast-tipo">@toastTipo</div>
        }
        <div class="kio-toast-msg">@toastMsg</div>
        @if (!string.IsNullOrEmpty(toastHora))
        {
            <div class="kio-toast-hora">@toastHora</div>
        }
    </div>
}

@code {
    public record FichadorEmpleadoDto(int Id, string Nombre, string Slug, string Estado, bool TieneHuella);
    public record FichadorMarcarResult(bool Ok, string? Mensaje, string? Tipo, string? Hora, string? NombreEmpleado);

    private List<FichadorEmpleadoDto> empleados = new();
    private bool cargando = true;
    private FichadorEmpleadoDto? empleadoElegido;
    private string pinInput = "";
    private string? errorPin;
    private bool marcando;
    private System.Threading.Timer? refreshTimer;
    private System.Threading.Timer? clockTimer;

    // Modos del modal: "pin" (solo PIN), "huella-esperando" (esperando dedo, max 3 reintentos), "registrar-huella"
    private string modoModal = "pin";
    private int intentosHuella = 0;

    private string FechaLabel
    {
        get
        {
            var es = new System.Globalization.CultureInfo("es-AR");
            var ahora = DateTime.UtcNow.AddHours(-3);
            return ahora.ToString("dddd dd 'de' MMMM yyyy", es);
        }
    }
    private string HoraActual => DateTime.UtcNow.AddHours(-3).ToString("HH:mm:ss");

    private bool toastVisible;
    private bool toastError;
    private string? toastTipo;
    private string? toastMsg;
    private string? toastHora;

    // 2026-06-03: WebAuthn (huella)
    private bool huellaDisponible;       // browser+device soporta huella
    private bool huellaProcessing;       // botón "FICHAR CON HUELLA" en progreso

    protected override async Task OnInitializedAsync()
    {
        // 2026-06-05: registrar service worker para que Chrome muestre "Instalar app".
        try
        {
            await JS.InvokeVoidAsync("eval", @"
                if ('serviceWorker' in navigator) {
                    navigator.serviceWorker.register('/sw.js', { scope: '/fichador' })
                        .catch(err => console.log('SW register failed:', err));
                }
            ");
        }
        catch { /* navegador viejo o JS bloqueado, ignorar */ }
        await CargarEmpleados();
        // Detectar si este dispositivo+browser tiene huella biometrica (WebAuthn)
        try { huellaDisponible = await JS.InvokeAsync<bool>("webAuthnAvailable"); }
        catch { huellaDisponible = false; }
        // Auto-refresh cada 30s para que la lista se actualice (ej: alguien fichó desde otro lugar)
        refreshTimer = new System.Threading.Timer(async _ => await InvokeAsync(CargarEmpleados), null, 30000, 30000);
        // Reloj actualizado cada segundo
        clockTimer = new System.Threading.Timer(async _ => await InvokeAsync(StateHasChanged), null, 1000, 1000);
    }

    public void Dispose() { refreshTimer?.Dispose(); clockTimer?.Dispose(); }

    private async Task CargarEmpleados()
    {
        try
        {
            var data = await Http.GetFromJsonAsync<List<FichadorEmpleadoDto>>("api/horas-extras/fichador/empleados");
            empleados = data ?? new();
        }
        catch { /* ignore */ }
        finally { cargando = false; StateHasChanged(); }
    }

    /// <summary>Tap en card: si tiene huella registrada y el dispositivo la soporta, va directo a huella.
    /// Si no, abre el modal de PIN clásico.</summary>
    private async Task OnCardTap(FichadorEmpleadoDto e)
    {
        empleadoElegido = e;
        pinInput = "";
        errorPin = null;
        intentosHuella = 0;
        if (e.TieneHuella && huellaDisponible)
        {
            modoModal = "huella-esperando";
            StateHasChanged();
            await IntentarHuellaParaEmpleado();
        }
        else
        {
            modoModal = "pin";
            StateHasChanged();
        }
    }

    private void OnPinInput(ChangeEventArgs e)
    {
        pinInput = e.Value?.ToString() ?? "";
        errorPin = null;
    }

    private async Task OnPinKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && pinInput.Length == 3)
        {
            if (modoModal == "registrar-huella") await RegistrarHuellaAsync();
            else await MarcarConPinAsync();
        }
    }

    private void CerrarPin()
    {
        empleadoElegido = null;
        pinInput = "";
        errorPin = null;
        modoModal = "pin";
        intentosHuella = 0;
    }

    private async Task MarcarConPinAsync()
    {
        if (empleadoElegido is null || pinInput.Length != 3) return;
        marcando = true;
        errorPin = null;
        try
        {
            // GPS de alta precisión (lo usa el bloqueo por geocerca si está activo). Si falla, manda
            // null y el backend decide: para los empleados del piloto GPS, sin ubicación no deja fichar.
            decimal? lat = null, lon = null; int? acc = null;
            try
            {
                var pos = await JS.InvokeAsync<GpsPos?>("heGetPositionAccurate", 8000);
                if (pos is not null && pos.Lat.HasValue && pos.Lon.HasValue) { lat = pos.Lat; lon = pos.Lon; acc = pos.Accuracy; }
            }
            catch { }

            var body = new
            {
                EmpleadoId = empleadoElegido.Id,
                Pin = pinInput,
                GpsLat = lat,
                GpsLon = lon,
                GpsAccuracy = acc
            };
            var resp = await Http.PostAsJsonAsync("api/horas-extras/fichador/marcar", body);
            var r = await resp.Content.ReadFromJsonAsync<FichadorMarcarResult>();
            if (r is null) { errorPin = "Error de conexión"; return; }
            if (!r.Ok)
            {
                errorPin = r.Mensaje ?? "Error";
                return;
            }
            // Exito: mostrar toast + cerrar modal + recargar lista
            CerrarPin();
            toastTipo = r.Tipo == "ENTRADA" ? "🌅 ENTRADA REGISTRADA" : "🌆 SALIDA REGISTRADA";
            toastMsg = r.Mensaje;
            toastHora = r.Hora;
            toastError = false;
            toastVisible = true;
            StateHasChanged();
            await Task.Delay(3000);
            toastVisible = false;
            await CargarEmpleados();
            StateHasChanged();
        }
        catch (Exception ex) { errorPin = "Error: " + ex.Message; }
        finally { marcando = false; }
    }

    public record GpsPos(decimal? Lat, decimal? Lon, int? Accuracy);

    // ─── 2026-06-03: Flujos de huella biometrica ───

    /// <summary>Registra una nueva credencial WebAuthn para el empleado del modal abierto.
    /// Requiere PIN correcto (lo manda el endpoint del backend para validar).</summary>
    private async Task RegistrarHuellaAsync()
    {
        if (empleadoElegido is null) return;
        marcando = true;
        errorPin = null;
        try
        {
            var beginResp = await Http.PostAsJsonAsync("api/horas-extras/fichador/huella/registro/begin",
                new { EmpleadoId = empleadoElegido.Id, Pin = pinInput, DeviceName = "Celular del fichador" });
            var begin = await beginResp.Content.ReadFromJsonAsync<HuellaRegistroBeginResp>();
            if (begin is null || !begin.Ok)
            {
                errorPin = begin?.Mensaje ?? "Error al iniciar registro";
                return;
            }

            // Llamar al browser para pedir la huella
            var credJs = await JS.InvokeAsync<System.Text.Json.JsonElement>("webAuthnCreate", begin.Options!);
            if (credJs.TryGetProperty("_error", out var errEl))
            {
                errorPin = "Tu celular cancelo o no pudo leer la huella: " + errEl.GetString();
                return;
            }

            // Mandar al backend para guardar la credencial
            var completeBody = new { SessionId = begin.SessionId, AttestationResponse = credJs };
            var completeResp = await Http.PostAsJsonAsync("api/horas-extras/fichador/huella/registro/complete", completeBody);
            var complete = await completeResp.Content.ReadFromJsonAsync<HuellaRegistroCompleteResp>();
            if (complete is null || !complete.Ok)
            {
                errorPin = complete?.Mensaje ?? "Error guardando huella";
                return;
            }

            CerrarPin();
            toastTipo = "👆 HUELLA REGISTRADA";
            toastMsg = $"Listo. Desde ahora podes tocar 'FICHAR CON HUELLA'.";
            toastHora = null;
            toastError = false;
            toastVisible = true;
            StateHasChanged();
            await Task.Delay(3500);
            toastVisible = false;
            StateHasChanged();
        }
        catch (Exception ex) { errorPin = "Error: " + ex.Message; }
        finally { marcando = false; }
    }

    /// <summary>Login con huella PARA UN EMPLEADO PUNTUAL (tocó su card). Llama al begin con
    /// empleadoId, le pide al browser el dedo, y completa. Si falla, incrementa intentosHuella.
    /// A los 3 fallos el UI cae al PIN automáticamente.</summary>
    private async Task IntentarHuellaParaEmpleado()
    {
        if (empleadoElegido is null) return;
        try
        {
            var beginResp = await Http.PostAsync($"api/horas-extras/fichador/huella/login/begin?empleadoId={empleadoElegido.Id}", null);
            var begin = await beginResp.Content.ReadFromJsonAsync<HuellaLoginBeginResp>();
            if (begin is null || !begin.Ok)
            {
                // Sin huella registrada para este empleado → caemos al PIN
                modoModal = "pin"; StateHasChanged(); return;
            }

            var credJs = await JS.InvokeAsync<System.Text.Json.JsonElement>("webAuthnGet", begin.Options!);
            if (credJs.TryGetProperty("_error", out var _))
            {
                intentosHuella++;
                StateHasChanged();
                return; // el UI muestra el reintento o cae a PIN al llegar a 3
            }

            // GPS opcional
            decimal? lat = null, lon = null; int? acc = null;
            try
            {
                var pos = await JS.InvokeAsync<GpsPos?>("heTryGetPosition", 3000);
                if (pos is not null) { lat = pos.Lat; lon = pos.Lon; acc = pos.Accuracy; }
            }
            catch { }

            var body = new { SessionId = begin.SessionId, AssertionResponse = credJs, GpsLat = lat, GpsLon = lon, GpsAccuracy = acc };
            var resp = await Http.PostAsJsonAsync("api/horas-extras/fichador/huella/login/complete", body);
            var r = await resp.Content.ReadFromJsonAsync<FichadorMarcarResult>();
            if (r is null || !r.Ok)
            {
                intentosHuella++;
                errorPin = r?.Mensaje;
                StateHasChanged();
                return;
            }

            CerrarPin();
            toastTipo = r.Tipo == "ENTRADA" ? "🌅 ENTRADA REGISTRADA" : "🌆 SALIDA REGISTRADA";
            toastMsg = r.Mensaje;
            toastHora = r.Hora;
            toastError = false;
            toastVisible = true;
            StateHasChanged();
            await Task.Delay(3000);
            toastVisible = false;
            await CargarEmpleados();
            StateHasChanged();
        }
        catch
        {
            intentosHuella++;
            StateHasChanged();
        }
    }

    /// <summary>Login con huella SIN saber empleado (boton global "FICHAR CON HUELLA"). El backend
    /// busca a quién pertenece la firma entre todas las credenciales registradas.</summary>
    private async Task FicharConHuella()
    {
        huellaProcessing = true;
        try
        {
            var beginResp = await Http.PostAsync("api/horas-extras/fichador/huella/login/begin", null);
            var begin = await beginResp.Content.ReadFromJsonAsync<HuellaLoginBeginResp>();
            if (begin is null || !begin.Ok)
            {
                MostrarToastError(begin?.Mensaje ?? "No se pudo iniciar el login con huella");
                return;
            }

            var credJs = await JS.InvokeAsync<System.Text.Json.JsonElement>("webAuthnGet", begin.Options!);
            if (credJs.TryGetProperty("_error", out var errEl))
            {
                MostrarToastError("Cancelaste o tu celular no pudo leer la huella: " + errEl.GetString());
                return;
            }

            // GPS opcional
            decimal? lat = null, lon = null; int? acc = null;
            try
            {
                var pos = await JS.InvokeAsync<GpsPos?>("heTryGetPosition", 3000);
                if (pos is not null) { lat = pos.Lat; lon = pos.Lon; acc = pos.Accuracy; }
            }
            catch { }

            var body = new { SessionId = begin.SessionId, AssertionResponse = credJs, GpsLat = lat, GpsLon = lon, GpsAccuracy = acc };
            var resp = await Http.PostAsJsonAsync("api/horas-extras/fichador/huella/login/complete", body);
            var r = await resp.Content.ReadFromJsonAsync<FichadorMarcarResult>();
            if (r is null) { MostrarToastError("Error de conexión"); return; }
            if (!r.Ok) { MostrarToastError(r.Mensaje ?? "Error fichando"); return; }

            toastTipo = r.Tipo == "ENTRADA" ? "🌅 ENTRADA REGISTRADA" : "🌆 SALIDA REGISTRADA";
            toastMsg = r.Mensaje;
            toastHora = r.Hora;
            toastError = false;
            toastVisible = true;
            StateHasChanged();
            await Task.Delay(3000);
            toastVisible = false;
            await CargarEmpleados();
            StateHasChanged();
        }
        catch (Exception ex) { MostrarToastError("Error: " + ex.Message); }
        finally { huellaProcessing = false; StateHasChanged(); }
    }

    private void MostrarToastError(string msg)
    {
        toastTipo = "⚠ ERROR";
        toastMsg = msg;
        toastHora = null;
        toastError = true;
        toastVisible = true;
        StateHasChanged();
        _ = Task.Run(async () => { await Task.Delay(4000); toastVisible = false; await InvokeAsync(StateHasChanged); });
    }

    public record HuellaRegistroBeginResp(bool Ok, string? Mensaje, object? Options, string? SessionId);
    public record HuellaRegistroCompleteResp(bool Ok, string? Mensaje, string? DeviceName);
    public record HuellaLoginBeginResp(bool Ok, string? Mensaje, object? Options, string? SessionId);
}
