@page "/listas-precios"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>Listas de precios (@(tiers?.Count ?? 0))</h3>
        <button class="btn btn-primary" @onclick="ShowCreateForm">+ Nueva lista</button>
    </div>
    <div class="card-body" style="padding: 0;">
        <div style="padding: 1rem 1.25rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-size: 0.85rem; color: #4b5563;">
            <p style="margin: 0;">
                Cada cliente queda asociado a una lista. Cuando cargas una venta, el sistema calcula el precio
                automaticamente segun la lista del cliente, aplicando el <strong>% de ajuste</strong> sobre el
                PVP base del producto.
            </p>
            <p style="margin: 0.4rem 0 0;">
                Ej: si <strong>Bares</strong> tiene -10% y un producto vale $1000, los clientes Bares lo veran a $900.
                Negativo = descuento, positivo = recargo.
            </p>
        </div>

        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (tiers is null || tiers.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay listas creadas. Tocá "+ Nueva lista".</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;">Orden</th>
                            <th>Nombre</th>
                            <th style="width: 110px;">Codigo</th>
                            <th style="text-align: right; width: 110px;">Ajuste %</th>
                            <th style="text-align: center; width: 90px;">Default</th>
                            <th style="text-align: center; width: 100px;">Clientes</th>
                            <th style="text-align: center; width: 110px;">Excepciones</th>
                            <th style="width: 110px;">Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in tiers!.OrderBy(x => x.SortOrder).ThenBy(x => x.Name))
                        {
                            <tr>
                                <td style="text-align: center; color: #6b7280;">@t.SortOrder</td>
                                <td>
                                    <strong>@t.Name</strong>
                                    @if (!string.IsNullOrEmpty(t.Notes))
                                    {
                                        <div style="font-size: 0.72rem; color: #6b7280; margin-top: 0.15rem;">@t.Notes</div>
                                    }
                                </td>
                                <td style="font-family: monospace; color: #374151;">@t.Code</td>
                                <td style="text-align: right; font-weight: 700; color: @(t.AdjustmentPercent < 0 ? "#dc2626" : (t.AdjustmentPercent > 0 ? "#059669" : "#374151"));">
                                    @FormatPercent(t.AdjustmentPercent)
                                </td>
                                <td style="text-align: center;">
                                    @if (t.IsDefault)
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#dcfce7; color:#166534; border-radius:999px; font-size:0.7rem; font-weight:700;">Default</span>
                                    }
                                    else
                                    {
                                        <span style="color: #d1d5db;">—</span>
                                    }
                                </td>
                                <td style="text-align: center; font-weight: 600;">@t.ClientCount</td>
                                <td style="text-align: center; color: #6b7280;">@t.OverrideCount</td>
                                <td>
                                    <span class="status-badge @(t.IsActive ? "status-active" : "status-inactive")">
                                        @(t.IsActive ? "Activa" : "Inactiva")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEditForm(t)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(t)" title="Eliminar" disabled="@t.IsDefault">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar lista" : "Nueva lista de precios")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-input" @bind="formName" placeholder="Ej: Bares" autofocus />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Codigo *</label>
                        <input class="form-input" @bind="formCode" placeholder="bares" disabled="@isEditing" />
                        @if (!isEditing)
                        {
                            <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">Codigo corto unico. No se puede cambiar despues.</p>
                        }
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Ajuste %</label>
                        <div style="display: flex; align-items: center; gap: 0.4rem;">
                            <input class="form-input" type="number" step="0.1" @bind="formPercent" style="text-align: right; max-width: 140px;" />
                            <span style="font-weight: 700;">%</span>
                        </div>
                        <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                            Ej: -10 (10% mas barato), 0 (sin ajuste), 15 (15% mas caro).
                        </p>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Orden</label>
                        <input class="form-input" type="number" @bind="formSortOrder" style="max-width: 120px;" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <textarea class="form-input" @bind="formNotes" rows="2"
                              placeholder="(Opcional) descripcion breve de cuando aplica esta lista"></textarea>
                </div>

                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                        <input type="checkbox" @bind="formIsDefault" style="width: 18px; height: 18px;" />
                        <span><strong>Marcar como lista por defecto</strong> (los clientes nuevos sin lista asignada usan esta)</span>
                    </label>
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive" style="max-width: 200px;">
                            <option value="true">Activa</option>
                            <option value="false">Inactiva</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && tierToDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar lista</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar <strong>@tierToDelete.Name</strong>?</p>
                @if (tierToDelete.ClientCount > 0)
                {
                    <p style="background:#fef3c7; color:#92400e; padding:0.5rem 0.75rem; border-radius:6px; font-size:0.85rem;">
                        Atencion: hay <strong>@tierToDelete.ClientCount</strong> cliente(s) asignado(s) a esta lista.
                        Al eliminarla, esos clientes quedan sin lista (se les aplicara la default al cargar ventas).
                    </p>
                }
                @if (tierToDelete.OverrideCount > 0)
                {
                    <p style="background:#fef3c7; color:#92400e; padding:0.5rem 0.75rem; border-radius:6px; font-size:0.85rem;">
                        Tambien se borraran @tierToDelete.OverrideCount precio(s) especial(es) asociados a esta lista.
                    </p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<CustomerTierDto>? tiers;
    private bool isLoading = true;

    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;
    private int? editingId;

    // Form state
    private string formName = "";
    private string formCode = "";
    private decimal formPercent;
    private int formSortOrder;
    private string formNotes = "";
    private bool formIsDefault;
    private bool formIsActive = true;

    private bool showDeleteConfirm;
    private CustomerTierDto? tierToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            tiers = await Api.GetCustomerTiersAsync() ?? new();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); tiers = new(); }
        isLoading = false;
    }

    private void ShowCreateForm()
    {
        isEditing = false; editingId = null;
        formName = ""; formCode = ""; formPercent = 0;
        formSortOrder = (tiers?.Count ?? 0) + 1;
        formNotes = ""; formIsDefault = false; formIsActive = true;
        formError = null; showForm = true;
    }

    private void ShowEditForm(CustomerTierDto t)
    {
        isEditing = true; editingId = t.Id;
        formName = t.Name; formCode = t.Code; formPercent = t.AdjustmentPercent;
        formSortOrder = t.SortOrder; formNotes = t.Notes ?? "";
        formIsDefault = t.IsDefault; formIsActive = t.IsActive;
        formError = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formName)) { formError = "El nombre es obligatorio"; return; }
        if (!isEditing && string.IsNullOrWhiteSpace(formCode)) { formError = "El codigo es obligatorio"; return; }

        isSaving = true;
        try
        {
            if (isEditing && editingId.HasValue)
            {
                var updated = await Api.UpdateCustomerTierAsync(editingId.Value, new UpdateCustomerTierRequest
                {
                    Name = formName,
                    AdjustmentPercent = formPercent,
                    IsDefault = formIsDefault ? true : (bool?)null, // solo enviar true para evitar la validacion de "no se puede desmarcar"
                    IsActive = formIsActive,
                    SortOrder = formSortOrder,
                    Notes = formNotes
                });
                if (updated is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Lista actualizada");
            }
            else
            {
                var created = await Api.CreateCustomerTierAsync(new CreateCustomerTierRequest
                {
                    Name = formName,
                    Code = formCode,
                    AdjustmentPercent = formPercent,
                    IsDefault = formIsDefault,
                    SortOrder = formSortOrder,
                    Notes = formNotes
                });
                if (created is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Lista creada");
            }
            showForm = false;
            await LoadData();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    private void ConfirmDelete(CustomerTierDto t) { tierToDelete = t; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (tierToDelete is null) return;
        try
        {
            var ok = await Api.DeleteCustomerTierAsync(tierToDelete.Id);
            if (ok) { ToastService.Success("Lista eliminada"); await LoadData(); }
            else { ToastService.Error("No se pudo eliminar"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; tierToDelete = null; }
    }

    private static string FormatPercent(decimal p)
    {
        var sign = p > 0 ? "+" : "";
        return $"{sign}{p.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture).Replace(".", ",")}%";
    }
}
