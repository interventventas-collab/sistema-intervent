@page "/clientes"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject CurrentCompanyService Company

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Clientes (@(clients?.Count ?? 0))</h3>
        <div style="display: flex; gap: 0.4rem; align-items: center;">
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ Nuevo Cliente</button>
            <button class="btn btn-primary" @onclick="() => showImport = true" title="Subir varios clientes desde un Excel" style="background: #059669; border-color: #059669;">📤 Importar Excel</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando clientes...</p>
        }
        else if (clients is null || clients.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">Todavia no cargaste ningun cliente. Hace clic en "+ Nuevo Cliente" para empezar.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">Codigo</th>
                            <th>Nombre</th>
                            <th>CUIT / DNI</th>
                            <th>Telefono</th>
                            <th>Email</th>
                            <th>Direccion</th>
                            <th>Contacto</th>
                            <th style="width: 130px;">Lista de precios</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in clients)
                        {
                            <tr>
                                <td style="font-family: monospace; color: #374151;">@c.Code</td>
                                <td><strong>@c.Name</strong></td>
                                <td style="font-size: 0.85rem;">@(c.Cuit ?? "")</td>
                                <td style="font-size: 0.85rem;">@(c.Phone ?? "")</td>
                                <td style="font-size: 0.85rem;">@(c.Email ?? "")</td>
                                <td style="font-size: 0.85rem; color: #6b7280;">@(c.Address ?? "")</td>
                                <td style="font-size: 0.85rem;">@(c.ContactName ?? "")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.CustomerTierName))
                                    {
                                        <span style="display:inline-block; padding:0.15rem 0.5rem; background:#e0e7ff; color:#3730a3; border-radius:999px; font-size:0.7rem; font-weight:600;">@c.CustomerTierName</span>
                                    }
                                    else
                                    {
                                        <span style="color: #9ca3af; font-size: 0.75rem;">— sin asignar —</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(c.IsActive ? "status-active" : "status-inactive")">
                                        @(c.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEditForm(c)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(c)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar Cliente" : "Nuevo Cliente")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Codigo</label>
                        <input class="form-input" @bind="formCode" placeholder="@(isEditing ? "" : "Se genera automatico")" />
                        <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">
                            @(isEditing ? "Podes cambiarlo, pero debe ser unico." : "Si lo dejas vacio, el sistema genera el siguiente codigo automaticamente (CLI-001, CLI-002, ...).")
                        </p>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre / Razon social *</label>
                        <input class="form-input" @bind="formName" placeholder="Ej: Juan Perez / Empresa SA" autofocus />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">CUIT / DNI</label>
                        <div style="display: flex; gap: 0.4rem; align-items: stretch;">
                            <input class="form-input" @bind="formCuit" placeholder="20-12345678-9" style="flex: 1;" />
                            <button class="btn btn-secondary" type="button" @onclick="LookupAfip" disabled="@isLookingUp"
                                    style="white-space: nowrap;" title="Buscar datos en AFIP por CUIT/CUIL">
                                @(isLookingUp ? "..." : "🔍 AFIP")
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(lookupMessage))
                        {
                            <p style="font-size: 0.75rem; color: @(lookupOk ? "#15803d" : "#b91c1c"); margin: 0.2rem 0 0;">@lookupMessage</p>
                        }
                    </div>
                    <div class="form-group">
                        <label class="form-label">Telefono</label>
                        <input class="form-input" @bind="formPhone" placeholder="+54 11 1234-5678" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input class="form-input" type="email" @bind="formEmail" placeholder="cliente@ejemplo.com" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Persona de contacto</label>
                        <input class="form-input" @bind="formContactName" placeholder="Nombre y apellido" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Domicilio fiscal</label>
                    <input class="form-input" @bind="formAddress" placeholder="Calle, número, ciudad, provincia (lo que figura en factura)" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        Domicilio de entrega
                        <span style="font-size: 0.72rem; color: #6b7280; font-weight: 400;">(opcional · solo si recibe en otro lugar)</span>
                    </label>
                    <input class="form-input" @bind="formDeliveryAddress" placeholder="Si entrega en el mismo domicilio fiscal, dejá vacío" />
                </div>
                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <textarea class="form-input" @bind="formNotes" rows="3" placeholder="Cualquier informacion extra (preferencias, condiciones, etc)"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Lista de precios</label>
                    <select class="form-input" @bind="formCustomerTierId" style="max-width: 320px;">
                        @{
                            // Filtrar listas por la empresa actual. Si no hay empresa elegida, mostrar todas.
                            var availableTiers = tiers is null
                                ? new List<CustomerTierDto>()
                                : tiers.Where(x => x.IsActive
                                    && (!Company.HasCompany || CurrentCompanyService.IsVisibleForCompany(x.Companies, Company.Current!)))
                                    .OrderBy(x => x.SortOrder).ToList();
                            var defaultTier = availableTiers.FirstOrDefault(x => x.IsDefault) ?? tiers?.FirstOrDefault(x => x.IsDefault);
                        }
                        @if (availableTiers.Count == 0)
                        {
                            <option value="0">— (sin listas configuradas para @(Company.HasCompany ? Company.CurrentDisplayName : "esta empresa")) —</option>
                        }
                        else
                        {
                            <option value="0">— Default (@(defaultTier?.Name ?? "—")) —</option>
                            @foreach (var t in availableTiers)
                            {
                                <option value="@t.Id">@t.Name (@FormatPercent(t.AdjustmentPercent))</option>
                            }
                        }
                    </select>
                    <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                        Define que precios se autocompletan al cargar una venta de este cliente.
                    </p>
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive" style="max-width: 200px;">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && clientToDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar cliente</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar al cliente <strong>@clientToDelete.Name</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">Esta accion no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

<BulkImportModal @bind-Visible="showImport"
                 EntityNameSingular="cliente"
                 EntityNamePlural="clientes"
                 TemplateUrl="/api/clients/import-template"
                 TemplateFileName="clientes-template.xlsx"
                 ImportUrl="/api/clients/bulk-import"
                 OnImported="LoadData" />

@code {
    private bool showImport;
    private List<ClientDto>? clients;
    private List<CustomerTierDto>? tiers;
    private bool isLoading = true;
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;
    private int? editingId;
    private string formCode = "";
    private string formName = "";
    private string formCuit = "";
    private string formPhone = "";
    private string formEmail = "";
    private string formAddress = "";
    private string formDeliveryAddress = "";
    private string formContactName = "";
    private string formNotes = "";
    private bool formIsActive = true;
    // 0 = usar default; >0 = id de la lista elegida
    private int formCustomerTierId;
    private bool showDeleteConfirm;
    private ClientDto? clientToDelete;
    private bool isLookingUp;
    private string? lookupMessage;
    private bool lookupOk;

    private static string FormatPercent(decimal p)
    {
        var sign = p > 0 ? "+" : "";
        return $"{sign}{p.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture).Replace(".", ",")}%";
    }

    private async Task LookupAfip()
    {
        lookupMessage = null;
        if (string.IsNullOrWhiteSpace(formCuit)) { lookupMessage = "Ingresa primero un CUIT/CUIL."; lookupOk = false; return; }
        isLookingUp = true;
        try
        {
            var result = await Api.LookupCuitAsync(formCuit);
            if (result is not null && result.Found)
            {
                if (!string.IsNullOrWhiteSpace(result.Name) && string.IsNullOrWhiteSpace(formName))
                    formName = result.Name;
                if (!string.IsNullOrWhiteSpace(result.Address) && string.IsNullOrWhiteSpace(formAddress))
                    formAddress = result.Address;
                lookupMessage = $"Datos traidos de AFIP: {result.Name}";
                lookupOk = true;
            }
            else
            {
                lookupMessage = result?.Error ?? "No se encontraron datos para ese CUIT.";
                lookupOk = false;
            }
        }
        catch (Exception ex) { lookupMessage = "Error: " + ex.Message; lookupOk = false; }
        finally { isLookingUp = false; }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        try { clients = await Api.GetClientsAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar los clientes"); clients = new(); }

        // Cargar listas de precios disponibles para el dropdown del form
        try { tiers = await Api.GetCustomerTiersAsync() ?? new(); }
        catch { tiers = new(); }

        isLoading = false;
    }

    private void ShowCreateForm()
    {
        isEditing = false; editingId = null;
        formCode = ""; formName = ""; formCuit = ""; formPhone = ""; formEmail = "";
        formAddress = ""; formDeliveryAddress = ""; formContactName = ""; formNotes = "";
        formIsActive = true; formCustomerTierId = 0;
        formError = null; showForm = true;
    }

    private void ShowEditForm(ClientDto c)
    {
        isEditing = true; editingId = c.Id;
        formCode = c.Code;
        formName = c.Name;
        formCuit = c.Cuit ?? "";
        formPhone = c.Phone ?? "";
        formEmail = c.Email ?? "";
        formAddress = c.Address ?? "";
        formDeliveryAddress = c.DeliveryAddress ?? "";
        formContactName = c.ContactName ?? "";
        formNotes = c.Notes ?? "";
        formIsActive = c.IsActive;
        formCustomerTierId = c.CustomerTierId ?? 0;
        formError = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formName)) { formError = "El nombre es obligatorio"; return; }
        isSaving = true;
        try
        {
            // Helper para evitar mandar "" donde el backend espera null (rompe validaciones como [EmailAddress])
            string? Nz(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

            if (isEditing && editingId.HasValue)
            {
                var updated = await Api.UpdateClientAsync(editingId.Value, new UpdateClientRequest
                {
                    Code = Nz(formCode),
                    Name = formName.Trim(),
                    Cuit = Nz(formCuit),
                    Phone = Nz(formPhone),
                    Email = Nz(formEmail),
                    Address = Nz(formAddress),
                    DeliveryAddress = Nz(formDeliveryAddress),
                    ContactName = Nz(formContactName),
                    Notes = Nz(formNotes),
                    IsActive = formIsActive,
                    // 0 = desasignar (vuelve a default); >0 = lista elegida
                    CustomerTierId = formCustomerTierId
                });
                if (updated is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Cliente actualizado");
            }
            else
            {
                var created = await Api.CreateClientAsync(new CreateClientRequest
                {
                    Code = Nz(formCode),
                    Name = formName.Trim(),
                    Cuit = Nz(formCuit),
                    Phone = Nz(formPhone),
                    Email = Nz(formEmail),
                    Address = Nz(formAddress),
                    DeliveryAddress = Nz(formDeliveryAddress),
                    ContactName = Nz(formContactName),
                    Notes = Nz(formNotes),
                    CustomerTierId = formCustomerTierId == 0 ? (int?)null : formCustomerTierId
                });
                if (created is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Cliente creado");
            }
            showForm = false;
            await LoadData();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    private void ConfirmDelete(ClientDto c) { clientToDelete = c; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (clientToDelete is null) return;
        try
        {
            var ok = await Api.DeleteClientAsync(clientToDelete.Id);
            if (ok) { ToastService.Success("Cliente eliminado"); await LoadData(); }
            else { ToastService.Error("No se pudo eliminar el cliente"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; clientToDelete = null; }
    }
}
