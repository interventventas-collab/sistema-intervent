@page "/integraciones/mercadopago"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="view-header">
    <h2>💳 Mercado Pago — saldo</h2>
</div>

<div style="max-width: 760px;">

    <p style="color:#6b7280; font-size:0.9rem; margin-bottom:1rem;">
        Conectá tu cuenta de <strong>Mercado Pago</strong> por la conexión oficial (no hace falta ningún robot).
        Con el <strong>Access Token</strong> el sistema lee el <strong>saldo</strong> de tu cuenta y lo muestra en el dashboard.
        Esta es la primera etapa: de a poco vamos sumando movimientos, ventas cobradas y conciliación.
    </p>

    @if (cargando)
    {
        <p>Cargando…</p>
    }
    else
    {
        @* Saldo actual *@
        @if (account is not null && account.LastSaldoDisponible.HasValue)
        {
            <div style="padding:1rem 1.2rem; margin-bottom:1.2rem; background:#e7f2ff; border:1px solid #b6dcff; border-radius:10px;">
                <div style="font-size:0.8rem; color:#0b5cad;">Saldo disponible@(string.IsNullOrEmpty(account.Nickname) ? "" : $" · {account.Nickname}")</div>
                <div style="font-size:1.6rem; font-weight:700; color:#0b5cad;">$@Fmt(account.LastSaldoDisponible)</div>
                @if (account.LastSaldoTotal.HasValue && account.LastSaldoTotal != account.LastSaldoDisponible)
                {
                    <div style="font-size:0.82rem; color:#6b7280;">Total en la cuenta: $@Fmt(account.LastSaldoTotal)</div>
                }
                @if (account.LastSaldoAt.HasValue)
                {
                    <div style="font-size:0.78rem; color:#6b7280;">Actualizado: @account.LastSaldoAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                }
            </div>
        }
        else if (account is not null && !string.IsNullOrEmpty(account.LastError))
        {
            <div style="padding:0.8rem 1rem; margin-bottom:1.2rem; background:#fef2f2; border:1px solid #fecaca; border-radius:8px; color:#991b1b; font-size:0.86rem;">
                <strong>Última lectura falló:</strong> @account.LastError
            </div>
        }

        @* Cómo sacar el token (ayuda) *@
        <details style="margin-bottom:1.2rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:10px; padding:0.8rem 1rem;">
            <summary style="cursor:pointer; font-weight:600; color:#374151;">¿Dónde saco el Access Token?</summary>
            <ol style="margin:0.7rem 0 0 1.1rem; color:#4b5563; font-size:0.86rem; line-height:1.7;">
                <li>Entrá a <strong>mercadopago.com.ar/developers</strong> con tu usuario de Mercado Pago.</li>
                <li>Andá a <strong>"Tus integraciones"</strong> → creá una aplicación (o usá una que ya tengas).</li>
                <li>En <strong>Credenciales de producción</strong> copiá el <strong>"Access Token"</strong> (empieza con <code>APP_USR-</code>).</li>
                <li>Pegalo acá abajo y tocá <strong>Guardar</strong>.</li>
            </ol>
        </details>

        @* Datos de acceso *@
        <div class="card" style="padding:1.1rem; margin-bottom:1.2rem; border:1px solid #e5e7eb; border-radius:10px;">
            <h3 style="margin-top:0;">Conexión</h3>
            <div class="form-group">
                <label>Access Token @(account?.HasToken == true ? "(dejá vacío para no cambiarlo)" : "")</label>
                <input class="form-control" type="password" @bind="accessToken"
                       placeholder="@(account?.HasToken == true ? "•••••••• (ya guardado)" : "APP_USR-...")" />
            </div>
            <div class="form-group">
                <label>Alias (opcional)</label>
                <input class="form-control" @bind="alias" placeholder="ej: Mercado Pago Palanica" />
            </div>
            <button class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                @(guardando ? "Guardando…" : "Guardar")
            </button>
        </div>

        @* Saldo disponible estimado (punto de partida manual + movimientos) *@
        <div class="card" style="padding:1.1rem; margin-bottom:1.2rem; border:1px solid #b6dcff; border-radius:10px; background:#f5faff;">
            <h3 style="margin-top:0;">💵 Saldo disponible (estimado)</h3>
            <p style="color:#6b7280; font-size:0.85rem;">
                Como Mercado Pago no deja leer el disponible automático, lo hacemos así: entrá a la app de MP,
                mirá el <strong>"Disponible"</strong> y pegá ese número acá <strong>una vez</strong>. El sistema le va
                sumando los movimientos que entran, así se mantiene aproximado. Cada tanto, volvé a poner el número real para recalibrar.
            </p>

            @if (mpDash?.DisponibleEstimado is not null)
            {
                <div style="padding:0.9rem 1.1rem; margin-bottom:0.9rem; background:#e7f2ff; border:1px solid #b6dcff; border-radius:10px;">
                    <div style="display:flex; gap:2rem; flex-wrap:wrap; align-items:flex-end;">
                        <div>
                            <div style="font-size:0.8rem; color:#166534;">💵 Disponible para usar (estimado)</div>
                            <div style="font-size:1.6rem; font-weight:800; color:#166534;">$@Fmt(mpDash.DisponibleEstimado)</div>
                        </div>
                        <div>
                            <div style="font-size:0.8rem; color:#92400e;">🕒 Por acreditarse</div>
                            <div style="font-size:1.6rem; font-weight:800; color:#92400e;">$@Fmt(mpDash.PorAcreditarse)</div>
                        </div>
                        <div style="border-left:2px solid #b6dcff; padding-left:1.5rem;">
                            <div style="font-size:0.8rem; color:#0b5cad;">💰 Total en Mercado Pago</div>
                            <div style="font-size:1.8rem; font-weight:900; color:#0b5cad;">$@Fmt(mpDash.DisponibleEstimado + mpDash.PorAcreditarse)</div>
                        </div>
                    </div>
                    @if (mpDash.SaldoInicial is not null && mpDash.SaldoInicialFecha is not null)
                    {
                        <div style="font-size:0.76rem; color:#6b7280; margin-top:0.6rem;">Disponible = base $@Fmt(mpDash.SaldoInicial) (puesto el @mpDash.SaldoInicialFecha.Value.ToLocalTime().ToString("dd/MM/yy HH:mm")) + movimientos. "Por acreditarse" es aproximado (lo que MP retiene de tus cobros).</div>
                    }
                </div>
            }

            <div style="display:flex; gap:0.6rem; align-items:flex-end; flex-wrap:wrap;">
                <div>
                    <label style="font-size:0.82rem; color:#374151;">Disponible real de la app de MP</label>
                    <input class="form-control" type="number" step="0.01" @bind="saldoInicialInput" placeholder="Ej: 23000317.20" style="max-width:220px;" />
                </div>
                <button class="btn btn-primary" @onclick="GuardarSaldoInicial" disabled="@(guardandoSaldo || account?.HasToken != true)">
                    @(guardandoSaldo ? "Guardando…" : (mpDash?.SaldoInicial is not null ? "Recalibrar" : "Guardar punto de partida"))
                </button>
            </div>
            <div style="font-size:0.74rem; color:#9ca3af; margin-top:0.4rem;">Poné el número tal cual lo ves en Mercado Pago (sin el signo $). Es un estimado — no reemplaza al de la app, pero te da una idea al toque.</div>
        </div>

        @* Leer saldo ahora *@
        <div class="card" style="padding:1.1rem; margin-bottom:1.2rem; border:1px solid #e5e7eb; border-radius:10px;">
            <h3 style="margin-top:0;">Leer el saldo ahora</h3>
            <p style="color:#6b7280; font-size:0.85rem;">
                Consulta la API de Mercado Pago al instante. <strong>Ojo:</strong> Mercado Pago dejó de permitir
                el saldo directo para las cuentas nuevas (puede dar error). El saldo real completo va a llegar por
                los "Reportes" (lo estamos armando). Mientras tanto, mirá los <strong>cobros recibidos</strong> más abajo.
            </p>
            <button class="btn btn-primary" @onclick="LeerSaldo" disabled="@(leyendo || account?.HasToken != true)">
                @(leyendo ? "Leyendo…" : "🔄 Leer saldo ahora")
            </button>
            @if (account is null)
            {
                <p style="color:#b45309; font-size:0.85rem; margin-top:0.6rem;">Guardá primero el Access Token.</p>
            }

            @if (!leyendo && leerResult is not null)
            {
                @if (leerResult.Ok)
                {
                    <div style="padding:0.8rem; margin-top:1rem; background:#e7f2ff; border:1px solid #b6dcff; border-radius:8px; color:#0b5cad;">
                        <strong>✅ Saldo leído:</strong> $@Fmt(leerResult.Disponible) disponible
                    </div>
                }
                else
                {
                    <div style="padding:0.8rem; margin-top:1rem; background:#fef2f2; border:1px solid #fecaca; border-radius:8px; color:#991b1b;">
                        <strong>❌ No se pudo:</strong> @leerResult.Error
                    </div>
                }
            }
        </div>

        @* Cobros recibidos (Parte A) *@
        <div class="card" style="padding:1.1rem; margin-bottom:1.2rem; border:1px solid #e5e7eb; border-radius:10px;">
            <h3 style="margin-top:0;">Cobros recibidos por Mercado Pago</h3>
            <p style="color:#6b7280; font-size:0.85rem;">
                Trae los pagos que entraron a tu cuenta (ventas cobradas por Mercado Pago). Elegí el período y tocá el botón.
            </p>
            <div style="display:flex; gap:0.6rem; align-items:center; flex-wrap:wrap;">
                <select class="form-control" style="max-width:200px;" @bind="pagosDias">
                    <option value="7">Últimos 7 días</option>
                    <option value="30">Últimos 30 días</option>
                    <option value="90">Últimos 90 días</option>
                    <option value="180">Últimos 180 días</option>
                    <option value="365">Último año</option>
                </select>
                <button class="btn btn-primary" @onclick="TraerCobros" disabled="@(trayendoPagos || account?.HasToken != true)">
                    @(trayendoPagos ? "Trayendo…" : "🔄 Traer cobros")
                </button>
            </div>
            @if (account is null)
            {
                <p style="color:#b45309; font-size:0.85rem; margin-top:0.6rem;">Guardá primero el Access Token.</p>
            }

            @if (!trayendoPagos && pagosResult is not null)
            {
                @if (pagosResult.Ok)
                {
                    <div style="padding:0.7rem 0.9rem; margin-top:0.9rem; background:#e7f2ff; border:1px solid #b6dcff; border-radius:8px; color:#0b5cad; font-size:0.88rem;">
                        ✅ Listo: <strong>@pagosResult.Nuevos</strong> cobros nuevos (@pagosResult.TotalTraidos revisados).
                    </div>
                    @if (pagosResult.Truncado)
                    {
                        <div style="padding:0.7rem 0.9rem; margin-top:0.6rem; background:#fffbeb; border:1px solid #fde68a; border-radius:8px; color:#92400e; font-size:0.85rem;">
                            ⚠️ Hay <strong>más de 10.000 cobros</strong> en este período (el máximo por consulta de Mercado Pago). Para el total completo, elegí un período más corto (ej. por semana o por mes).
                        </div>
                    }
                }
                else
                {
                    <div style="padding:0.7rem 0.9rem; margin-top:0.9rem; background:#fef2f2; border:1px solid #fecaca; border-radius:8px; color:#991b1b; font-size:0.88rem;">
                        ❌ @pagosResult.Error
                    </div>
                }
            }

            @if (resumenPagos is not null && resumenPagos.Cantidad > 0)
            {
                <div style="display:flex; gap:1.5rem; margin-top:1rem; flex-wrap:wrap;">
                    <div><div style="font-size:0.75rem; color:#6b7280;">Cobros aprobados</div><div style="font-size:1.2rem; font-weight:700;">@resumenPagos.Cantidad</div></div>
                    <div><div style="font-size:0.75rem; color:#6b7280;">Total bruto</div><div style="font-size:1.2rem; font-weight:700; color:#166534;">$@Fmt(resumenPagos.TotalBruto)</div></div>
                    <div><div style="font-size:0.75rem; color:#6b7280;">Total neto (con comisión)</div><div style="font-size:1.2rem; font-weight:700; color:#0b5cad;">$@Fmt(resumenPagos.TotalNeto)</div></div>
                    <div style="border-left:2px solid #e5e7eb; padding-left:1.2rem;"><div style="font-size:0.75rem; color:#166534;">💚 Ya liberado (disponible)</div><div style="font-size:1.2rem; font-weight:800; color:#166534;">$@Fmt(resumenPagos.Liberado)</div></div>
                    <div><div style="font-size:0.75rem; color:#92400e;">🕒 Por liberarse</div><div style="font-size:1.2rem; font-weight:800; color:#92400e;">$@Fmt(resumenPagos.Pendiente)</div></div>
                </div>
                <div style="font-size:0.72rem; color:#9ca3af; margin-top:0.4rem;">"Ya liberado" es la plata de estos cobros que Mercado Pago ya te habilitó; "Por liberarse" es la que todavía está retenida y te cae en unos días. (Aproximado: no descuenta lo que ya retiraste al banco.)</div>
            }

            @if (pagos is not null && pagos.Count > 0)
            {
                <div style="overflow-x:auto; margin-top:1rem;">
                    <table class="data-table" style="width:100%; font-size:0.85rem;">
                        <thead>
                            <tr><th>Fecha</th><th>Quién pagó</th><th>Medio</th><th style="text-align:right;">Monto</th><th style="text-align:right;">Neto</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var p in pagos.Take(15))
                            {
                                <tr>
                                    <td>@p.Fecha.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                                    <td>@(string.IsNullOrEmpty(p.PayerNombre) ? (p.PayerEmail ?? "—") : p.PayerNombre)</td>
                                    <td>@(p.MedioPago ?? "—")</td>
                                    <td style="text-align:right; font-weight:600;">$@Fmt(p.Monto)</td>
                                    <td style="text-align:right; color:#6b7280;">@(p.MontoNeto.HasValue ? "$" + Fmt(p.MontoNeto) : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="font-size:0.75rem; color:#6b7280; margin-top:0.4rem;">Mostrando los <strong>últimos 15</strong> cobros. El total de todos está arriba en el resumen (@resumenPagos?.Cantidad cobros).</div>
            }
            else if (pagos is not null && !trayendoPagos)
            {
                <p style="color:#6b7280; font-size:0.85rem; margin-top:0.8rem;">Todavía no hay cobros guardados. Tocá "Traer cobros".</p>
            }
        </div>

        @* Movimientos por reportes (Parte B) *@
        <div class="card" style="padding:1.1rem; margin-bottom:1.2rem; border:1px solid #e5e7eb; border-radius:10px;">
            <h3 style="margin-top:0;">Movimientos de la cuenta (saldo / dinero)</h3>
            <p style="color:#6b7280; font-size:0.85rem;">
                Trae el detalle de <strong>todo lo que entra y sale</strong> de tu cuenta (ventas, retiros, comisiones)
                usando el reporte oficial de Mercado Pago. Sumando el neto tenés el <strong>panorama del dinero</strong>.
                <br/>⏳ El reporte lo genera Mercado Pago y <strong>puede tardar 1-3 minutos</strong>: tocá el botón y esperá; si no está listo, volvé a tocarlo en un ratito.
            </p>
            <div style="display:flex; gap:0.6rem; align-items:center; flex-wrap:wrap;">
                <select class="form-control" style="max-width:200px;" @bind="movDias">
                    <option value="7">Últimos 7 días</option>
                    <option value="15">Últimos 15 días</option>
                    <option value="30">Últimos 30 días</option>
                    <option value="60">Últimos 60 días</option>
                </select>
                <button class="btn btn-primary" @onclick="ActualizarMovimientos" disabled="@(actualizandoMov || account?.HasToken != true)">
                    @(actualizandoMov ? "Generando y trayendo… (puede tardar)" : "🔄 Actualizar movimientos")
                </button>
            </div>
            @if (account is null)
            {
                <p style="color:#b45309; font-size:0.85rem; margin-top:0.6rem;">Guardá primero el Access Token.</p>
            }

            @if (!actualizandoMov && movResult is not null)
            {
                @if (movResult.EnProceso)
                {
                    <div style="padding:0.7rem 0.9rem; margin-top:0.9rem; background:#fffbeb; border:1px solid #fde68a; border-radius:8px; color:#92400e; font-size:0.86rem;">
                        ⏳ @movResult.Error
                    </div>
                }
                else if (movResult.Ok)
                {
                    <div style="padding:0.7rem 0.9rem; margin-top:0.9rem; background:#e7f2ff; border:1px solid #b6dcff; border-radius:8px; color:#0b5cad; font-size:0.88rem;">
                        ✅ Listo: <strong>@movResult.Nuevos</strong> movimientos nuevos (@movResult.TotalFilas filas en el reporte).
                    </div>
                }
                else
                {
                    <div style="padding:0.7rem 0.9rem; margin-top:0.9rem; background:#fef2f2; border:1px solid #fecaca; border-radius:8px; color:#991b1b; font-size:0.88rem;">
                        ❌ @movResult.Error
                    </div>
                }
            }

            @if (resumenMov is not null && resumenMov.Cantidad > 0)
            {
                <div style="display:flex; gap:1.5rem; margin-top:1rem; flex-wrap:wrap;">
                    <div><div style="font-size:0.75rem; color:#6b7280;">Ingresos</div><div style="font-size:1.15rem; font-weight:700; color:#166534;">$@Fmt(resumenMov.TotalIngresos)</div></div>
                    <div><div style="font-size:0.75rem; color:#6b7280;">Egresos</div><div style="font-size:1.15rem; font-weight:700; color:#991b1b;">$@Fmt(resumenMov.TotalEgresos)</div></div>
                    <div><div style="font-size:0.75rem; color:#6b7280;">Comisiones</div><div style="font-size:1.15rem; font-weight:700; color:#92400e;">$@Fmt(resumenMov.TotalComisiones)</div></div>
                    <div style="border-left:2px solid #e5e7eb; padding-left:1.2rem;"><div style="font-size:0.75rem; color:#6b7280;">Neto del período</div><div style="font-size:1.3rem; font-weight:800; color:#0b5cad;">$@Fmt(resumenMov.NetoPeriodo)</div></div>
                </div>
            }

            @if (movimientos is not null && movimientos.Count > 0)
            {
                <div style="overflow-x:auto; margin-top:1rem;">
                    <table class="data-table" style="width:100%; font-size:0.85rem;">
                        <thead>
                            <tr><th>Fecha</th><th>Tipo</th><th>Detalle</th><th style="text-align:right;">Bruto</th><th style="text-align:right;">Comisión</th><th style="text-align:right;">Neto</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var m in movimientos.Take(15))
                            {
                                <tr>
                                    <td>@m.Fecha.ToLocalTime().ToString("dd/MM/yy")</td>
                                    <td>@(m.TipoTransaccion ?? "—")</td>
                                    <td style="max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@(m.Descripcion ?? "—")</td>
                                    <td style="text-align:right;">$@Fmt(m.MontoBruto)</td>
                                    <td style="text-align:right; color:#92400e;">$@Fmt(m.Comision)</td>
                                    <td style="text-align:right; font-weight:600; color:@(m.MontoNeto < 0 ? "#991b1b" : "#166534");">$@Fmt(m.MontoNeto)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="font-size:0.75rem; color:#6b7280; margin-top:0.4rem;">Mostrando los <strong>últimos 15</strong> movimientos. El total está arriba en el resumen.</div>
            }
        </div>

        @* Automático *@
        <div class="card" style="padding:1.1rem; border:1px solid #e5e7eb; border-radius:10px;">
            <h3 style="margin-top:0;">Leer automático (sin apretar nada)</h3>
            <p style="color:#6b7280; font-size:0.85rem;">
                Prendé esto y elegí a qué horas leer el saldo solo. Horarios de Argentina.
            </p>
            <label style="display:flex; align-items:center; gap:0.5rem; font-weight:600; cursor:pointer;">
                <input type="checkbox" @bind="autoEnabled" /> Activar el automático
            </label>
            @if (autoEnabled)
            {
                <div style="margin-top:0.8rem;">
                    <div style="font-size:0.85rem; color:#374151; margin-bottom:0.3rem;">Horarios:</div>
                    @for (int i = 0; i < horarios.Count; i++)
                    {
                        var idx = i;
                        <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.4rem;">
                            <input type="time" @bind="horarios[idx]" style="padding:0.3rem 0.5rem; border:1px solid #d1d5db; border-radius:6px;" />
                            <button class="btn btn-secondary" style="padding:0.2rem 0.6rem;" @onclick="() => horarios.RemoveAt(idx)">✕</button>
                        </div>
                    }
                    <button class="btn btn-secondary" style="padding:0.3rem 0.7rem;" @onclick="() => horarios.Add(new TimeOnly(8, 0))">+ Agregar horario</button>
                    <div style="font-size:0.78rem; color:#6b7280; margin-top:0.4rem;">Sugerencia: los mismos que el banco (ej: 08:00, 12:00, 18:00, 22:00).</div>
                </div>
            }
            <div style="margin-top:1rem;">
                <button class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando…" : "Guardar horarios")
                </button>
            </div>
            @if (account?.AutoSyncEnabled == true && !string.IsNullOrEmpty(account.AutoSyncTimes))
            {
                <div style="padding:0.7rem 0.9rem; margin-top:1rem; background:#e7f2ff; border:1px solid #b6dcff; border-radius:8px; color:#0b5cad; font-size:0.85rem;">
                    ✅ Automático <strong>activo</strong> — lee a las <strong>@account.AutoSyncTimes</strong> (hora Argentina).
                </div>
            }
        </div>
    }
</div>

@code {
    private bool cargando = true;
    private Web.Models.MpAccountDto? account;
    private string accessToken = "";
    private string alias = "";
    private bool guardando;
    private bool autoEnabled;
    private List<TimeOnly> horarios = new();

    private bool leyendo;
    private Web.Models.MpSincronizarResultDto? leerResult;

    // Cobros recibidos (Parte A)
    private int pagosDias = 30;
    private bool trayendoPagos;
    private Web.Models.MpSyncPagosResultDto? pagosResult;
    private List<Web.Models.MpPagoDto>? pagos;
    private Web.Models.MpPagosResumenDto? resumenPagos;

    // Movimientos por reportes (Parte B)
    private int movDias = 30;
    private bool actualizandoMov;
    private Web.Models.MpSyncMovResultDto? movResult;
    private List<Web.Models.MpMovimientoDto>? movimientos;
    private Web.Models.MpMovResumenDto? resumenMov;

    // Saldo disponible estimado
    private Web.Models.MpDashboardDto? mpDash;
    private decimal? saldoInicialInput;
    private bool guardandoSaldo;

    private static readonly System.Globalization.CultureInfo ArCulture = new("es-AR");
    private static string Fmt(decimal? v) => v.HasValue ? v.Value.ToString("N2", ArCulture) : "0,00";

    protected override async Task OnInitializedAsync()
    {
        await CargarCuenta();
        await CargarPagos();
        await CargarMovimientos();
        await CargarDash();
    }

    private async Task CargarDash()
    {
        try { mpDash = await Api.GetMpDashboardAsync(); }
        catch { /* opcional */ }
    }

    private async Task GuardarSaldoInicial()
    {
        if (saldoInicialInput is null || saldoInicialInput < 0)
        {
            ToastService.Error("Poné el número del disponible que ves en Mercado Pago");
            return;
        }
        guardandoSaldo = true;
        try
        {
            var ok = await Api.SetMpSaldoInicialAsync(saldoInicialInput.Value);
            if (ok) { ToastService.Success("Punto de partida guardado"); saldoInicialInput = null; await CargarDash(); }
            else ToastService.Error("No se pudo guardar");
        }
        catch (Exception ex) { ToastService.Error("No se pudo guardar: " + ex.Message); }
        finally { guardandoSaldo = false; }
    }

    private async Task CargarMovimientos()
    {
        try
        {
            movimientos = await Api.GetMpMovimientosAsync();
            resumenMov = await Api.GetMpMovimientosResumenAsync();
        }
        catch { /* opcional */ }
    }

    private async Task ActualizarMovimientos()
    {
        movResult = null;
        actualizandoMov = true;
        StateHasChanged();
        try
        {
            movResult = await Api.SincronizarMpMovimientosAsync(movDias);
            if (movResult is not null && movResult.Ok && !movResult.EnProceso) await CargarMovimientos();
        }
        catch (Exception ex)
        {
            movResult = new Web.Models.MpSyncMovResultDto { Ok = false, Error = ex.Message };
