@code {
    private DateTime mesActual = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private List<AlqReservaDto>? reservas;
    private bool isLoading = true;
    private bool mostrarOcultas;
    private DateTime? diaSeleccionado;

    private record DiaSemana(string Long, string Short);
    private static readonly DiaSemana[] DiasSemana = new[]
    {
        new DiaSemana("Lun", "L"),
        new DiaSemana("Mar", "M"),
        new DiaSemana("Mié", "M"),
        new DiaSemana("Jue", "J"),
        new DiaSemana("Vie", "V"),
        new DiaSemana("Sáb", "S"),
        new DiaSemana("Dom", "D")
    };

    // Primer día visible en la grilla (lunes anterior o igual al 1ro del mes)
    private DateTime primerDiaGrilla
    {
        get
        {
            var primero = mesActual;
            // En .NET DayOfWeek: Sunday=0, Monday=1, ..., Saturday=6. Queremos lunes como inicio.
            int diff = ((int)primero.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
            return primero.AddDays(-diff);
        }
    }

    private DateTime ultimoDiaGrilla => primerDiaGrilla.AddDays(41); // 6 semanas × 7 días - 1

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        isLoading = true;
        try
        {
            reservas = await Api.GetAlqReservasAsync(from: primerDiaGrilla, to: ultimoDiaGrilla) ?? new();
            if (!mostrarOcultas)
            {
                reservas = reservas.Where(r => r.Estado != "cancelado" && r.Estado != "finalizado").ToList();
            }
        }
        catch { ToastService.Error("Error al cargar reservas"); reservas = new(); }
        isLoading = false;
    }

    private List<AlqReservaDto> EventosDe(DateTime dia)
    {
        if (reservas is null) return new();
        return reservas
            .Where(r => r.FechaEntrega.Date <= dia.Date && r.FechaRetiro.Date >= dia.Date)
            .OrderBy(r => r.FechaEntrega)
            .ThenBy(r => r.HoraInicio)
            .ToList();
    }

    private async Task PrevMes()
    {
        mesActual = mesActual.AddMonths(-1);
        await Reload();
    }

    private async Task NextMes()
    {
        mesActual = mesActual.AddMonths(1);
        await Reload();
    }

    private async Task GoToHoy()
    {
        mesActual = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        await Reload();
    }

    private void OnDayClick(DateTime fecha)
    {
        var eventos = EventosDe(fecha);
        if (eventos.Count > 0)
        {
            // Día con eventos → abrir modal con la lista (sirve tanto en mobile como en desktop;
            // en desktop podés además clickear directo el chip para abrir uno solo).
            diaSeleccionado = fecha;
        }
        else
        {
            // Día vacío → crear nueva reserva con esa fecha
            Nav.NavigateTo($"/alquileres/reservas?newDate={fecha:yyyy-MM-dd}");
        }
    }

    private void CrearEnFecha(DateTime fecha)
    {
        diaSeleccionado = null;
        Nav.NavigateTo($"/alquileres/reservas?newDate={fecha:yyyy-MM-dd}");
    }

    private void OpenReserva(int id)
    {
        diaSeleccionado = null;
        Nav.NavigateTo($"/alquileres/reservas?openId={id}");
    }

    private static string DiaNombre(DayOfWeek d) => d switch
    {
        DayOfWeek.Monday => "Lunes",
        DayOfWeek.Tuesday => "Martes",
        DayOfWeek.Wednesday => "Miércoles",
        DayOfWeek.Thursday => "Jueves",
        DayOfWeek.Friday => "Viernes",
        DayOfWeek.Saturday => "Sábado",
        DayOfWeek.Sunday => "Domingo",
        _ => d.ToString()
    };

    private static string FormatRange(AlqReservaDto r)
    {
        var f1 = r.FechaEntrega.ToString("dd/MM");
        var f2 = r.FechaRetiro.ToString("dd/MM");
        return f1 == f2 ? f1 : $"{f1} → {f2}";
    }

    private static (string bg, string fg) ColorEstado(string estado) => estado switch
    {
        "reservado" => ("#3b82f6", "white"),
        "confirmado" => ("#10b981", "white"),
        "entregado" => ("#f59e0b", "white"),
        "finalizado" => ("#6b7280", "white"),
        "cancelado" => ("#ef4444", "white"),
        _ => ("#9ca3af", "white")
    };

    private static string MesNombre(int m) => m switch
    {
        1 => "Enero", 2 => "Febrero", 3 => "Marzo", 4 => "Abril",
        5 => "Mayo", 6 => "Junio", 7 => "Julio", 8 => "Agosto",
        9 => "Septiembre", 10 => "Octubre", 11 => "Noviembre", 12 => "Diciembre",
        _ => m.ToString()
    };
}
