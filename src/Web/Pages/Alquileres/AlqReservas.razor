@page "/alquileres/reservas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject BrandSettingsService BrandSettings

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>
            📅 Reservas de Alquileres
            <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(reservas?.Count ?? 0))</span>
        </h3>
        <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
            <select class="form-input" style="max-width: 180px; font-size: 0.85rem;" @bind="filtroEstado" @bind:after="Load">
                <option value="">Todos los estados</option>
                <option value="reservado">Reservado</option>
                <option value="confirmado">Confirmado</option>
                <option value="entregado">Entregado</option>
                <option value="finalizado">Finalizado</option>
                <option value="cancelado">Cancelado</option>
            </select>
            <button class="btn btn-secondary" @onclick="ShowCondicionesEditor" title="Editar las condiciones que aparecen al pie del PDF">📝 Condiciones</button>
            <button class="btn btn-primary" @onclick="ShowCreate">+ Nueva Reserva</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando reservas...</p>
        }
        else if (reservas is null || reservas.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                No hay reservas para mostrar. Tocá <strong>"+ Nueva Reserva"</strong> para crear la primera.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Cliente</th>
                            <th>Entrega</th>
                            <th>Retiro</th>
                            <th>Hora</th>
                            <th style="text-align: right;">Total</th>
                            <th style="text-align: right;">Seña</th>
                            <th style="text-align: right;">Saldo</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in reservas)
                        {
                            var saldo = r.MontoTotal - r.Sena - r.MontoCobrado;
                            <tr style="cursor: pointer;" @onclick="() => ShowEdit(r)">
                                <td style="font-family: monospace; font-weight: 600;">@r.Numero</td>
                                <td>
                                    <strong>@r.ClienteNombre</strong>
                                    @if (!string.IsNullOrEmpty(r.ClienteTelefono))
                                    {
                                        <div style="font-size: 0.78rem; color: #6b7280;">@r.ClienteTelefono</div>
                                    }
                                    @if (r.EntregadoPorRepartidorId.HasValue || r.RetiradoPorRepartidorId.HasValue || r.AsignadoARepartidorId.HasValue)
                                    {
                                        <div style="margin-top: 0.2rem; display: flex; gap: 0.25rem; flex-wrap: wrap;">
                                            @if (r.AsignadoARepartidorId.HasValue && !r.EntregadoPorRepartidorId.HasValue)
                                            {
                                                <span style="font-size: 0.7rem; background: #ede9fe; color: #5b21b6; padding: 0.1rem 0.4rem; border-radius: 999px; font-weight: 700;">🚚 Asignado a @r.AsignadoARepartidorNombre</span>
                                            }
                                            @if (r.EntregadoPorRepartidorId.HasValue)
                                            {
                                                <span style="font-size: 0.7rem; background: #dcfce7; color: #166534; padding: 0.1rem 0.4rem; border-radius: 999px; font-weight: 700;">✅ Entregó @r.EntregadoPorRepartidorNombre</span>
                                            }
                                            @if (r.RetiradoPorRepartidorId.HasValue)
                                            {
                                                <span style="font-size: 0.7rem; background: #e0e7ff; color: #3730a3; padding: 0.1rem 0.4rem; border-radius: 999px; font-weight: 700;">🔙 Retiró @r.RetiradoPorRepartidorNombre</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td style="font-size: 0.85rem;">@r.FechaEntrega.ToString("dd/MM/yyyy")</td>
                                <td style="font-size: 0.85rem;">@r.FechaRetiro.ToString("dd/MM/yyyy")</td>
                                <td style="font-size: 0.85rem; color: #6b7280;">@FormatHorario(r)</td>
                                <td style="text-align: right; font-weight: 700;">$@FormatMoney(r.MontoTotal)</td>
                                <td style="text-align: right; color: #059669;">$@FormatMoney(r.Sena)</td>
                                <td style="text-align: right; color: @(saldo > 0 ? "#dc2626" : "#059669"); font-weight: 600;">$@FormatMoney(saldo)</td>
                                <td>@EstadoBadge(r.Estado)</td>
                                <td class="actions-cell" @onclick:stopPropagation="true">
                                    <button class="btn-icon" style="color: #7c3aed;" @onclick="() => ShowAsignar(r)" title="Asignar a repartidor">🚚</button>
                                    <button class="btn-icon" style="color: #1d4ed8;" @onclick="() => ShowPrint(r)" title="Ver / imprimir / PDF">🖨</button>
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(r)" title="Editar / Ver">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(r)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 1100px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? $"Editar Reserva {editingNumero}" : "Nueva Reserva")</h3>
                <div style="display: flex; gap: 0.4rem; align-items: center;">
                    @if (isEditing && editingId.HasValue)
                    {
                        <button class="btn btn-secondary" type="button" @onclick="OpenPrintFromEdit" style="font-size: 0.85rem;">🖨 Imprimir / PDF</button>
                    }
                    <button class="btn-close" @onclick="CloseForm">&times;</button>
                </div>
            </div>
            <div class="modal-body" style="overflow-y: auto;">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                @* ═══════════════ 1. CLIENTE Y FECHAS ═══════════════ *@
                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem; margin-bottom: 0.75rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                        <span style="background: #3b82f6; color: white; width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.78rem;">1</span>
                        <strong>Cliente y fechas del evento</strong>
                    </div>

                    <div class="form-row">
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">Cliente *</label>
                            <div style="display: flex; gap: 0.4rem;">
                                <select class="form-input" @bind="formClienteId" @bind:after="OnClienteChanged" style="flex: 1;">
                                    <option value="0">— Elegí un cliente —</option>
                                    @foreach (var c in clientes ?? new())
                                    {
                                        <option value="@c.Id">@c.Nombre @(string.IsNullOrEmpty(c.Empresa) ? "" : $"({c.Empresa})")</option>
                                    }
                                </select>
                                <button class="btn btn-secondary" type="button" @onclick="() => showQuickClient = true" title="Crear cliente nuevo en el momento">+ Nuevo</button>
                            </div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Fecha entrega *</label>
                            <input class="form-input" type="date" @bind="formFechaEntrega" @bind:after="OnFechasChanged" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Fecha retiro *</label>
                            <input class="form-input" type="date" @bind="formFechaRetiro" @bind:after="OnFechasChanged" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Horario evento</label>
                            <div style="display: flex; gap: 0.3rem; align-items: center;">
                                <input class="form-input" type="text" placeholder="HH:mm" maxlength="5" @bind="formHoraInicio" style="flex: 1;" />
                                <span style="color: #6b7280;">a</span>
                                <input class="form-input" type="text" placeholder="HH:mm" maxlength="5" @bind="formHoraFin" style="flex: 1;" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group" style="margin-top: 0.5rem;">
                        <label class="form-label">Dirección del evento</label>
                        <input class="form-input" @bind="formDireccionEvento" placeholder="Se autocompleta con la del cliente. Editala si el evento es en otra dirección." />
                    </div>
                </div>

                @* ═══════════════ 2. EQUIPOS ═══════════════ *@
                <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem; margin-bottom: 0.75rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                        <span style="background: #3b82f6; color: white; width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.78rem;">2</span>
                        <strong>Equipos a alquilar</strong>
                    </div>

                    <label style="display: inline-flex; align-items: center; gap: 0.45rem; margin-bottom: 0.7rem; font-size: 0.85rem; cursor: pointer; color: #374151;">
                        <input type="checkbox" @bind="formUsarPrecios" style="width: 16px; height: 16px; cursor: pointer;" />
                        Usar precios de los equipos (calcular el total solo). Si lo dejás destildado, cargás solo los equipos y escribís el importe total a mano.
                    </label>

                    <div class="form-row" style="align-items: end;">
                        <div class="form-group" style="flex: 0 0 90px;">
                            <label class="form-label" style="font-size: 0.75rem;">Cantidad</label>
                            <input class="form-input" type="number" min="1" @bind="addCantidad" style="text-align: right;" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label" style="font-size: 0.75rem;">Seleccioná un equipo</label>
                            <select class="form-input" @bind="addEquipoId">
                                <option value="0">— Tipeá o elegí un equipo —</option>
                                @foreach (var e in equipos ?? new())
                                {
                                    var disp = DisponibleDe(e.Id);
                                    <option value="@e.Id">
                                        @e.Sku · @e.Nombre — $@FormatMoney(e.PrecioDiario)/día @(disp.HasValue ? $"· disp: {disp.Value}" : "")
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="form-group" style="flex: 0 0 110px;">
                            <button class="btn btn-primary" type="button" @onclick="AddItem" style="width: 100%;">+ Agregar</button>
                        </div>
                    </div>

                    @if (formItems.Count == 0)
                    {
                        <div style="padding: 1rem; text-align: center; color: #9ca3af; font-size: 0.9rem;">
                            Sin equipos todavía. Elegí uno arriba y tocá <strong>+ Agregar</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive" style="margin-top: 0.6rem;">
                            <table class="data-table" style="font-size: 0.85rem;">
                                <thead>
                                    <tr>
                                        <th style="width: 80px; text-align: right;">Cant.</th>
                                        <th style="width: 110px;">SKU</th>
                                        <th>Equipo</th>
                                        @if (formUsarPrecios)
                                        {
                                            <th style="width: 130px; text-align: right;">P. Unit.</th>
                                            <th style="width: 130px; text-align: right;">Subtotal</th>
                                        }
                                        <th style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int idx = 0; idx < formItems.Count; idx++)
                                    {
                                        var i = idx;
                                        var it = formItems[i];
                                        var eq = equipos?.FirstOrDefault(x => x.Id == it.EquipoId);
                                        var subtotal = it.Cantidad * it.PrecioUnitario;
                                        var disp = DisponibleDe(it.EquipoId);
                                        var excedido = disp.HasValue && it.Cantidad > disp.Value;
                                        <tr style="@(excedido ? "background: #fef2f2;" : "")">
                                            <td>
                                                <input class="form-input" type="number" min="1" @bind="it.Cantidad" style="text-align: right; padding: 0.25rem;" />
                                            </td>
                                            <td style="font-family: monospace;">@(eq?.Sku ?? "—")</td>
                                            <td>
                                                <strong>@(eq?.Nombre ?? "—")</strong>
                                                @if (excedido)
                                                {
                                                    <div style="color: #dc2626; font-size: 0.72rem; font-weight: 600;">⚠ Excede disponible (@disp.Value)</div>
                                                }
                                            </td>
                                            @if (formUsarPrecios)
                                            {
                                                <td>
                                                    <input class="form-input" type="number" step="0.01" min="0" @bind="it.PrecioUnitario" style="text-align: right; padding: 0.25rem;" />
                                                </td>
                                                <td style="text-align: right; font-weight: 700;">$@FormatMoney(subtotal)</td>
                                            }
                                            <td>
                                                <button class="btn-icon btn-delete" type="button" @onclick="() => RemoveItem(i)" title="Quitar">×</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @* ═══════════════ 3. TOTALES Y ESTADO ═══════════════ *@
                <div class="form-row" style="align-items: stretch;">
                    <div style="flex: 1.4;">
                        <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem; height: 100%;">
                            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                                <span style="background: #3b82f6; color: white; width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.78rem;">3</span>
                                <strong>Estado y observaciones</strong>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Estado de la reserva</label>
                                <select class="form-input" @bind="formEstado">
                                    <option value="reservado">📋 Reservado</option>
                                    <option value="confirmado">✅ Confirmado</option>
                                    <option value="entregado">🚚 Entregado</option>
                                    <option value="finalizado">🏁 Finalizado</option>
                                    <option value="cancelado">❌ Cancelado</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Observaciones</label>
                                <textarea class="form-input" rows="3" @bind="formNotas" placeholder="Notas internas (opcional)"></textarea>
                            </div>
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <div class="venta-totals-box" style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem;">
                            @if (formUsarPrecios)
                            {
                                <div class="venta-totals-row">
                                    <span>Subtotal:</span>
                                    <strong>$@FormatMoney(Subtotal)</strong>
                                </div>
                                <div class="venta-totals-row">
                                    <span>Descuento ($):</span>
                                    <input class="form-input" type="number" step="0.01" min="0" @bind="formDescuento"
                                           style="text-align: right; max-width: 130px; font-weight: 700;" />
                                </div>
                                <hr style="margin: 0.5rem 0; border: none; border-top: 1px solid #d1d5db;" />
                                <div class="venta-totals-row" style="font-size: 1.15rem; font-weight: 800; color: #059669;">
                                    <span>TOTAL:</span>
                                    <strong>$@FormatMoney(Total)</strong>
                                </div>
                            }
                            else
                            {
                                <div class="venta-totals-row" style="font-size: 1.15rem; font-weight: 800; color: #059669;">
                                    <span>TOTAL:</span>
                                    <input class="form-input" type="number" step="0.01" min="0" @bind="formTotalManual"
                                           style="text-align: right; max-width: 150px; font-weight: 800; font-size: 1.05rem; color: #059669;" />
                                </div>
                            }
                            <hr style="margin: 0.5rem 0; border: none; border-top: 1px dashed #d1d5db;" />
                            <div class="venta-totals-row">
                                <span>Seña pagada:</span>
                                <input class="form-input" type="number" step="0.01" min="0" @bind="formSena"
                                       style="text-align: right; max-width: 130px; font-weight: 700; color: #059669;" />
                            </div>
                            <div class="venta-totals-row" style="font-size: 1rem; font-weight: 700; color: @(Saldo > 0 ? "#dc2626" : "#059669");">
                                <span>Saldo pendiente:</span>
                                <span>$@FormatMoney(Saldo)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(isSaving || formItems.Count == 0)">
                    @(isSaving ? "Guardando..." : (isEditing ? "Guardar cambios" : "Crear reserva"))
                </button>
            </div>
        </div>
    </div>
}

@if (showQuickClient)
{
    <div class="modal-overlay" @onclick="() => showQuickClient = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h4 style="margin: 0;">Nuevo cliente rápido</h4>
                <button class="btn-close" @onclick="() => showQuickClient = false">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #6b7280; margin: 0 0 0.5rem;">
                    Cargá lo mínimo. Después podés completar el resto en <strong>Clientes</strong>.
                </p>
                <div class="form-group">
                    <label class="form-label">Nombre y apellido *</label>
                    <input class="form-input" @bind="quickNombre" autofocus />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">DNI/CUIT</label>
                        <input class="form-input" @bind="quickDniCuit" />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Teléfono</label>
                        <input class="form-input" @bind="quickTelefono" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Dirección</label>
                    <input class="form-input" @bind="quickDireccion" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showQuickClient = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="CreateQuickClient">Crear y elegir</button>
            </div>
        </div>
    </div>
}

@* ═══════ Modal Print/PDF ═══════ *@
@if (printReserva is not null)
{
    <style>
        @@media print {
            @@page { size: A4; margin: 12mm; }
            html, body { background: white !important; margin: 0 !important; padding: 0 !important; }
            body * { visibility: hidden; }
            #alq-print, #alq-print * { visibility: visible; }
            #alq-print {
                position: absolute !important;
                left: 0 !important; top: 0 !important; right: 0 !important;
                margin: 0 !important; padding: 0 !important; background: white !important;
            }
            .no-print { display: none !important; }
            .alq-print-items { page-break-inside: auto; }
            .alq-print-items th, .alq-print-items td { font-size: 0.78rem; }
            .alq-print-condiciones { page-break-inside: avoid; }
        }
        .alq-print-stamp {
            position: fixed; top: 50%; left: 50%;
            transform: translate(-50%, -50%) rotate(-22deg);
            font-size: 7rem; font-weight: 900;
            color: rgba(220, 38, 38, 0.18);
            border: 8px solid rgba(220, 38, 38, 0.18);
            padding: 0.6rem 3.5rem; border-radius: 14px;
            letter-spacing: 0.5rem; z-index: 9999; pointer-events: none;
        }
    </style>
    <div class="modal-overlay" @onclick="ClosePrint">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 820px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header no-print" style="background: whitesmoke;">
                <h3 style="margin: 0;">📄 Reserva @printReserva.Numero</h3>
                <div style="display: flex; gap: 0.4rem; align-items: center;">
                    <button class="btn btn-secondary" @onclick="DoPrint" style="font-size: 0.85rem;">🖨 Imprimir / Guardar PDF</button>
                    <button class="btn-close" @onclick="ClosePrint">&times;</button>
                </div>
            </div>
            <div class="modal-body" id="alq-print" style="background: white; overflow-y: auto; position: relative;">
                @if (printReserva.Estado == "cancelado")
                {
                    <div style="background: #fee2e2; border: 2px solid #b91c1c; color: #7f1d1d; padding: 0.6rem 0.9rem; border-radius: 6px; margin-bottom: 0.6rem; font-weight: 800;">
                        ⚠ RESERVA CANCELADA
                    </div>
                }

                @* Cabecera *@
                <div style="border: 1px solid #d1d5db; padding: 0.85rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                        <div style="flex: 1;">
                            @if (BrandSettings.HasCustomLogo)
                            {
                                <img src="@BrandSettings.BrandLogo" alt="Logo" style="max-height: 55px; max-width: 220px; object-fit: contain;" />
                            }
                            else
                            {
                                <h2 style="margin: 0; font-size: 1.5rem; font-weight: 800;">@BrandSettings.BrandName</h2>
                            }
                        </div>
                        <div style="text-align: right; display: flex; gap: 0.6rem; align-items: flex-start;">
                            <div>
                                <div style="font-size: 1.4rem; font-weight: 800; color: #1d4ed8;">RESERVA</div>
                                <div style="font-family: monospace; font-size: 1.1rem; font-weight: 700;">@printReserva.Numero</div>
                                <div style="font-size: 0.78rem; color: #6b7280;">Emitida: @DateTime.Today.ToString("dd/MM/yyyy")</div>
                                <div style="margin-top: 0.3rem;">@EstadoBadge(printReserva.Estado)</div>
                            </div>
                            @* QR para el repartidor: lleva a /alquiler/{token} (marcar entrega/retiro/cobro) *@
                            <div style="text-align: center;">
                                <img src="@Api.AlqReservaQrUrl(printReserva.Id)" alt="QR repartidor"
                                     style="width: 150px; height: 150px; object-fit: contain;" />
                                <div style="font-size: 0.7rem; color: #6b7280; max-width: 150px;">Escaneá para entregar/retirar/cobrar</div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Datos del cliente y del evento *@
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-top: 0.6rem;">
                    <div style="border: 1px solid #d1d5db; padding: 0.6rem;">
                        <div style="font-size: 0.7rem; color: #6b7280; font-weight: 700; text-transform: uppercase; margin-bottom: 0.3rem;">Cliente</div>
                        @{
                            var cli = clientes?.FirstOrDefault(c => c.Id == printReserva.ClienteId);
                        }
                        <div style="font-weight: 700; font-size: 1.05rem;">@printReserva.ClienteNombre</div>
                        @if (cli is not null)
                        {
                            @if (!string.IsNullOrEmpty(cli.DniCuit))
                            {
                                <div style="font-size: 0.85rem;">DNI/CUIT: <strong>@cli.DniCuit</strong></div>
                            }
                            @if (!string.IsNullOrEmpty(cli.Telefono))
                            {
                                <div style="font-size: 0.85rem;">Tel: @cli.Telefono @(string.IsNullOrEmpty(cli.Telefono2) ? "" : $"/ {cli.Telefono2}")</div>
                            }
                            @if (!string.IsNullOrEmpty(cli.Email))
                            {
                                <div style="font-size: 0.85rem;">@cli.Email</div>
                            }
                        }
                        else if (!string.IsNullOrEmpty(printReserva.ClienteTelefono))
                        {
                            <div style="font-size: 0.85rem;">Tel: @printReserva.ClienteTelefono</div>
                        }
                    </div>
                    <div style="border: 1px solid #d1d5db; padding: 0.6rem;">
                        <div style="font-size: 0.7rem; color: #6b7280; font-weight: 700; text-transform: uppercase; margin-bottom: 0.3rem;">Evento</div>
                        <div style="font-size: 0.9rem;">
                            <strong>Entrega:</strong> @printReserva.FechaEntrega.ToString("dd/MM/yyyy") <span style="color: #6b7280;">(@DiaSemana(printReserva.FechaEntrega))</span>
                            @if (!string.IsNullOrEmpty(printReserva.HoraInicio)) { <span> · @printReserva.HoraInicio hs</span> }
                        </div>
                        <div style="font-size: 0.9rem;">
                            <strong>Retiro:</strong> @printReserva.FechaRetiro.ToString("dd/MM/yyyy") <span style="color: #6b7280;">(@DiaSemana(printReserva.FechaRetiro))</span>
                            @if (!string.IsNullOrEmpty(printReserva.HoraFin)) { <span> · @printReserva.HoraFin hs</span> }
                        </div>
                        @if (!string.IsNullOrEmpty(printReserva.DireccionEvento))
                        {
                            <div style="margin-top: 0.3rem; font-size: 0.85rem;">
                                <strong>Dirección:</strong> @printReserva.DireccionEvento
                            </div>
                        }
                    </div>
                </div>

                @* Tabla de items *@
                @{ var printConPrecios = printReserva.Items.Any(i => i.PrecioUnitario > 0); }
                <div style="margin-top: 0.6rem;">
                    <table class="alq-print-items" style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                        <thead>
                            <tr style="background: #f3f4f6;">
                                <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: center; width: 70px;">Cant.</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: left;">Descripción</th>
                                @if (printConPrecios)
                                {
                                    <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: right; width: 110px;">P. Unit.</th>
                                    <th style="border: 1px solid #d1d5db; padding: 5px 8px; text-align: right; width: 130px;">Subtotal</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var i in printReserva.Items)
                            {
                                <tr>
                                    <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: center; font-weight: 700;">@i.Cantidad</td>
                                    <td style="border: 1px solid #d1d5db; padding: 4px 8px;">
                                        <div style="font-weight: 600;">@i.EquipoNombre</div>
                                        <div style="font-size: 0.75rem; color: #6b7280; font-family: monospace;">@i.EquipoSku</div>
                                    </td>
                                    @if (printConPrecios)
                                    {
                                        <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: right;">$@FormatMoney(i.PrecioUnitario)</td>
                                        <td style="border: 1px solid #d1d5db; padding: 4px 8px; text-align: right; font-weight: 700;">$@FormatMoney(i.Cantidad * i.PrecioUnitario)</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Totales *@
                <div style="display: flex; justify-content: flex-end; margin-top: 0.5rem;">
                    <div style="min-width: 320px; border: 1px solid #d1d5db; padding: 0.6rem 0.8rem;">
                        @{
                            var subtotalPrint = printReserva.Items.Sum(i => i.Cantidad * i.PrecioUnitario);
                            var saldoPrint = printReserva.MontoTotal - printReserva.Sena - printReserva.MontoCobrado;
                        }
                        @if (printConPrecios)
                        {
                            <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                                <span>Subtotal:</span>
                                <strong>$@FormatMoney(subtotalPrint)</strong>
                            </div>
                            @if (printReserva.Descuento > 0)
                            {
                                <div style="display: flex; justify-content: space-between; font-size: 0.9rem; color: #dc2626;">
                                    <span>Descuento:</span>
                                    <span>− $@FormatMoney(printReserva.Descuento)</span>
                                </div>
                            }
                            <hr style="margin: 0.4rem 0; border: none; border-top: 1px solid #d1d5db;" />
                        }
                        <div style="display: flex; justify-content: space-between; font-size: 1.1rem; font-weight: 800; color: #059669;">
                            <span>TOTAL:</span>
                            <span>$@FormatMoney(printReserva.MontoTotal)</span>
                        </div>
                        <hr style="margin: 0.4rem 0; border: none; border-top: 1px dashed #d1d5db;" />
                        <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                            <span>Seña pagada:</span>
                            <strong style="color: #059669;">$@FormatMoney(printReserva.Sena)</strong>
                        </div>
                        @if (printReserva.MontoCobrado > 0)
                        {
                            <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                                <span>Cobrado en mano:</span>
                                <strong style="color: #059669;">$@FormatMoney(printReserva.MontoCobrado)</strong>
                            </div>
                        }
                        <div style="display: flex; justify-content: space-between; font-size: 1rem; font-weight: 800; color: @(saldoPrint > 0 ? "#dc2626" : "#059669");">
                            <span>Saldo pendiente:</span>
                            <span>$@FormatMoney(saldoPrint)</span>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(printReserva.Notas))
                {
                    <div style="margin-top: 0.5rem; border: 1px solid #d1d5db; padding: 0.5rem 0.7rem; font-size: 0.85rem;">
                        <strong>Observaciones:</strong> @printReserva.Notas
                    </div>
                }

                @* Condiciones *@
                @if (!string.IsNullOrWhiteSpace(condicionesTexto))
                {
                    <div class="alq-print-condiciones" style="margin-top: 0.7rem; border-top: 2px solid #d1d5db; padding-top: 0.6rem;">
                        <div style="font-size: 0.7rem; color: #6b7280; font-weight: 700; text-transform: uppercase; margin-bottom: 0.3rem;">Condiciones de servicio</div>
                        <div style="white-space: pre-wrap; font-size: 0.78rem; color: #374151; line-height: 1.45;">@condicionesTexto</div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ═══════ Modal editar condiciones ═══════ *@
@if (showCondicionesEditor)
{
    <div class="modal-overlay" @onclick="() => showCondicionesEditor = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 720px;">
            <div class="modal-header" style="background: whitesmoke;">
                <h3 style="margin: 0;">📝 Condiciones de servicio</h3>
                <button class="btn-close" @onclick="() => showCondicionesEditor = false">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color: #6b7280; font-size: 0.85rem; margin: 0 0 0.5rem;">
                    Este texto aparece al pie del PDF de cada reserva. Editalo cuando cambien tus condiciones.
                </p>
                <textarea class="form-input" rows="10" @bind="condicionesEditor" style="font-family: inherit; line-height: 1.5;"></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showCondicionesEditor = false" disabled="@savingCondiciones">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveCondiciones" disabled="@savingCondiciones">
                    @(savingCondiciones ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && reservaToDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar reserva</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar la reserva <strong>@reservaToDelete.Numero</strong> de <strong>@reservaToDelete.ClienteNombre</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">Esta accion no se puede deshacer. Si la reserva fue cancelada o nunca se concretó, conviene mejor cambiar su estado a "Cancelado" para mantener el historial.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar definitivamente</button>
            </div>
        </div>
    </div>
}

@* ═══════════════ MODAL: Asignar reparto ═══════════════ *@
@if (showAsignar && reservaAsignar is not null)
{
    <div class="modal-overlay" @onclick="() => showAsignar = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h4 style="margin: 0;">🚚 Asignar reparto</h4>
                <button class="btn-close" @onclick="() => showAsignar = false">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.9rem; color: #6b7280; margin-top: 0;">
                    Reserva <strong>@reservaAsignar.Numero</strong>
                    @if (reservaAsignar.AsignadoARepartidorId.HasValue)
                    {
                        <text>— ahora la tiene <strong>@reservaAsignar.AsignadoARepartidorNombre</strong></text>
                    }
                    else
                    {
                        <text>— todavía no tiene repartidor asignado</text>
                    }
                </p>
                <label class="form-label">¿A quién se la pasás?</label>
                <select class="form-input" @bind="asignarRepartidorId">
                    <option value="0">— Sin asignar (que nadie la tenga) —</option>
                    @foreach (var rep in repartidores.Where(x => x.IsActive))
                    {
                        <option value="@rep.Id">🚚 Pasarla a @rep.Nombre</option>
                    }
                </select>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showAsignar = false" disabled="@asignando">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmarAsignar" disabled="@asignando">
                    @(asignando ? "Guardando..." : "Confirmar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "openId")] public int? OpenIdParam { get; set; }
    [SupplyParameterFromQuery(Name = "newDate")] public string? NewDateParam { get; set; }

    private List<AlqReservaDto>? reservas;
    private List<AlqClienteDto>? clientes;
    private List<AlqEquipoDto>? equipos;
    private List<AlqDisponibilidadDto>? disponibilidad;
    private List<RepartidorDto> repartidores = new();
    private bool isLoading = true;

    // Asignar reparto
    private bool showAsignar;
    private AlqReservaDto? reservaAsignar;
    private int asignarRepartidorId;
    private bool asignando;
    private string filtroEstado = "";
    private bool deepLinkApplied;

    // Form state
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;
    private int? editingId;
    private string editingNumero = "";
    private int formClienteId;
    private DateTime formFechaEntrega = DateTime.Today;
    private DateTime formFechaRetiro = DateTime.Today.AddDays(1);
    private string formHoraInicio = "";
    private string formHoraFin = "";
    private string formDireccionEvento = "";
    private decimal formDescuento;
    private decimal formSena;
    private bool formUsarPrecios;
    private decimal formTotalManual;
    private string formEstado = "reservado";
    private string formNotas = "";
    private List<CreateAlqReservaItemRequest> formItems = new();

    // Add item state
    private int addCantidad = 1;
    private int addEquipoId;

    // Quick client
    private bool showQuickClient;
    private string quickNombre = "";
    private string quickDniCuit = "";
    private string quickTelefono = "";
    private string quickDireccion = "";

    // Delete
    private bool showDeleteConfirm;
    private AlqReservaDto? reservaToDelete;

    // Print / PDF
    private AlqReservaDto? printReserva;
    private string condicionesTexto = "";
    private bool showCondicionesEditor;
    private string condicionesEditor = "";
    private bool savingCondiciones;

    private decimal Subtotal => formItems.Sum(i => i.Cantidad * i.PrecioUnitario);
    private decimal Total => formUsarPrecios
        ? Math.Max(0m, Subtotal - Math.Max(0m, formDescuento))
        : Math.Max(0m, formTotalManual);
    private decimal Saldo => Math.Max(0m, Total - Math.Max(0m, formSena));

    protected override async Task OnInitializedAsync()
    {
        // 2026-06-26: cargar todo en paralelo (antes era secuencial y se sentía lento).
        await Task.WhenAll(Load(), LoadCatalogos());
    }

    protected override async Task OnParametersSetAsync()
    {
        if (deepLinkApplied) return;
        // Si venimos del calendario con ?openId=N => abrir esa reserva en edicion
        if (OpenIdParam.HasValue && OpenIdParam.Value > 0)
        {
            // Asegurarse de tener los catalogos cargados antes de abrir el modal
            if (clientes is null || equipos is null) await LoadCatalogos();
            if (reservas is null || reservas.Count == 0) await Load();
            var r = reservas?.FirstOrDefault(x => x.Id == OpenIdParam.Value)
                    ?? await Api.GetAlqReservaAsync(OpenIdParam.Value);
            if (r is not null) await ShowEdit(r);
            deepLinkApplied = true;
            // Limpiar la url para que no se reabra al refrescar
            Nav.NavigateTo("/alquileres/reservas", replace: true);
        }
        // Si venimos con ?newDate=YYYY-MM-DD => abrir +Nueva Reserva con esa fecha
        else if (!string.IsNullOrWhiteSpace(NewDateParam) && DateTime.TryParse(NewDateParam, out var d))
        {
            if (clientes is null || equipos is null) await LoadCatalogos();
            await ShowCreate();
            formFechaEntrega = d.Date;
            formFechaRetiro = d.Date.AddDays(1);
            await RefreshDisponibilidad();
            deepLinkApplied = true;
            Nav.NavigateTo("/alquileres/reservas", replace: true);
        }
    }

    private async Task Load()
    {
        isLoading = true;
        try { reservas = await Api.GetAlqReservasAsync(string.IsNullOrEmpty(filtroEstado) ? null : filtroEstado) ?? new(); }
        catch { ToastService.Error("Error al cargar reservas"); reservas = new(); }
        isLoading = false;
    }

    private async Task LoadCatalogos()
    {
        try
        {
            var tClientes = Api.GetAlqClientesAsync();
            var tEquipos = Api.GetAlqEquiposAsync();
            var tReps = Api.GetRepartidoresAsync();
            await Task.WhenAll(tClientes, tEquipos, tReps);
            clientes = tClientes.Result ?? new();
            equipos = tEquipos.Result ?? new();
            repartidores = tReps.Result ?? new();
        }
        catch { clientes ??= new(); equipos ??= new(); }
    }

    // ===== Asignar reparto =====
    private void ShowAsignar(AlqReservaDto r)
    {
        reservaAsignar = r;
        asignarRepartidorId = r.AsignadoARepartidorId ?? 0;
        showAsignar = true;
    }

    private async Task ConfirmarAsignar()
    {
        if (reservaAsignar is null) return;
        asignando = true;
        var ok = await Api.AsignarRepartoAlqAsync(reservaAsignar.Id, asignarRepartidorId == 0 ? (int?)null : asignarRepartidorId);
        asignando = false;
        if (ok)
        {
            ToastService.Success(asignarRepartidorId == 0 ? "Reserva sin asignar" : "Reserva asignada");
            showAsignar = false;
            await Load();
        }
        else ToastService.Error("No se pudo asignar");
    }

    private async Task RefreshDisponibilidad()
    {
        if (formFechaEntrega == default || formFechaRetiro == default || formFechaRetiro < formFechaEntrega)
        {
            disponibilidad = null;
            return;
        }
        try
        {
            disponibilidad = await Api.GetAlqDisponibilidadAsync(formFechaEntrega, formFechaRetiro, editingId) ?? new();
        }
        catch { disponibilidad = null; }
    }

    private int? DisponibleDe(int equipoId)
    {
        if (disponibilidad is null) return null;
        var d = disponibilidad.FirstOrDefault(x => x.EquipoId == equipoId);
        return d?.Disponible;
    }

    private async Task OnFechasChanged()
    {
        await RefreshDisponibilidad();
    }

    private void OnClienteChanged()
    {
        if (formClienteId > 0 && string.IsNullOrWhiteSpace(formDireccionEvento))
        {
            var c = clientes?.FirstOrDefault(x => x.Id == formClienteId);
            if (c is not null)
            {
                formDireccionEvento = ArmarDireccion(c);
            }
        }
    }

    private static string ArmarDireccion(AlqClienteDto c)
    {
        var partes = new List<string>();
        if (!string.IsNullOrWhiteSpace(c.DireccionDefault)) partes.Add(c.DireccionDefault);
        var pisoDepto = "";
        if (!string.IsNullOrWhiteSpace(c.Piso)) pisoDepto += $"P. {c.Piso}";
        if (!string.IsNullOrWhiteSpace(c.Depto)) pisoDepto += (pisoDepto.Length > 0 ? " " : "") + $"Depto {c.Depto}";
        if (pisoDepto.Length > 0) partes.Add(pisoDepto);
        if (!string.IsNullOrWhiteSpace(c.Barrio)) partes.Add(c.Barrio);
        if (!string.IsNullOrWhiteSpace(c.EntreCalles)) partes.Add($"e/ {c.EntreCalles}");
        return string.Join(" · ", partes);
    }

    private async Task ShowCreate()
    {
        ResetForm();
        isEditing = false; editingId = null; editingNumero = "";
        await RefreshDisponibilidad();
        showForm = true;
    }

    private async Task ShowEdit(AlqReservaDto r)
    {
        ResetForm();
        isEditing = true; editingId = r.Id; editingNumero = r.Numero;
        formClienteId = r.ClienteId;
        formFechaEntrega = r.FechaEntrega.Date;
        formFechaRetiro = r.FechaRetiro.Date;
        formHoraInicio = r.HoraInicio ?? "";
        formHoraFin = r.HoraFin ?? "";
        formDireccionEvento = r.DireccionEvento ?? "";
        formDescuento = r.Descuento;
        formSena = r.Sena;
        formEstado = r.Estado;
        formNotas = r.Notas ?? "";
        formItems = r.Items.Select(i => new CreateAlqReservaItemRequest
        {
            EquipoId = i.EquipoId,
            Cantidad = i.Cantidad,
            PrecioUnitario = i.PrecioUnitario
        }).ToList();
        // Si la reserva no tiene precios cargados en los items, fue hecha con importe a mano
        formUsarPrecios = r.Items.Any(i => i.PrecioUnitario > 0);
        formTotalManual = r.MontoTotal;
        await RefreshDisponibilidad();
        showForm = true;
    }

    private void ResetForm()
    {
        formClienteId = 0;
        formFechaEntrega = DateTime.Today;
        formFechaRetiro = DateTime.Today.AddDays(1);
        formHoraInicio = ""; formHoraFin = "";
        formDireccionEvento = "";
        formDescuento = 0m; formSena = 0m;
        formUsarPrecios = false; formTotalManual = 0m;
        formEstado = "reservado";
        formNotas = "";
        formItems = new();
        addCantidad = 1; addEquipoId = 0;
        formError = null;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private void AddItem()
    {
        if (addEquipoId <= 0 || addCantidad <= 0) return;
        var eq = equipos?.FirstOrDefault(x => x.Id == addEquipoId);
        if (eq is null) return;

        // Si ya existe el item, sumar cantidad
        var existing = formItems.FirstOrDefault(i => i.EquipoId == addEquipoId);
        if (existing is not null)
        {
            existing.Cantidad += addCantidad;
        }
        else
        {
            formItems.Add(new CreateAlqReservaItemRequest
            {
                EquipoId = addEquipoId,
                Cantidad = addCantidad,
                PrecioUnitario = formUsarPrecios ? eq.PrecioDiario : 0m
            });
        }
        addCantidad = 1; addEquipoId = 0;
    }

    private void RemoveItem(int idx)
    {
        if (idx >= 0 && idx < formItems.Count) formItems.RemoveAt(idx);
    }

    private async Task CreateQuickClient()
    {
        if (string.IsNullOrWhiteSpace(quickNombre)) { ToastService.Error("Falta el nombre"); return; }
        try
        {
            var nuevo = await Api.CreateAlqClienteAsync(new CreateAlqClienteRequest
            {
                Nombre = quickNombre, DniCuit = quickDniCuit, Telefono = quickTelefono,
                DireccionDefault = quickDireccion
            });
            if (nuevo is null) { ToastService.Error("No se pudo crear"); return; }
            clientes = await Api.GetAlqClientesAsync() ?? new();
            formClienteId = nuevo.Id;
            OnClienteChanged();
            quickNombre = ""; quickDniCuit = ""; quickTelefono = ""; quickDireccion = "";
            showQuickClient = false;
            ToastService.Success("Cliente creado y seleccionado");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task Save()
    {
        formError = null;
        if (formClienteId <= 0) { formError = "Tenés que elegir un cliente"; return; }
        if (formFechaRetiro < formFechaEntrega) { formError = "La fecha de retiro no puede ser anterior a la de entrega"; return; }
        if (formItems.Count == 0) { formError = "Agregá al menos un equipo"; return; }
        if (formItems.Any(i => i.Cantidad <= 0)) { formError = "Las cantidades deben ser mayores a 0"; return; }

        isSaving = true;
        try
        {
            if (isEditing && editingId.HasValue)
            {
                var updated = await Api.UpdateAlqReservaAsync(editingId.Value, new UpdateAlqReservaRequest
                {
                    ClienteId = formClienteId,
                    FechaEntrega = formFechaEntrega,
                    FechaRetiro = formFechaRetiro,
                    HoraInicio = formHoraInicio,
                    HoraFin = formHoraFin,
                    DireccionEvento = formDireccionEvento,
                    Descuento = formDescuento,
                    Sena = formSena,
                    MontoTotalManual = formUsarPrecios ? (decimal?)null : Math.Max(0m, formTotalManual),
                    Estado = formEstado,
                    Notas = formNotas,
                    Items = formItems
                });
                if (updated is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success($"Reserva {updated.Numero} actualizada");
            }
            else
            {
                var created = await Api.CreateAlqReservaAsync(new CreateAlqReservaRequest
                {
                    ClienteId = formClienteId,
                    FechaEntrega = formFechaEntrega,
                    FechaRetiro = formFechaRetiro,
                    HoraInicio = formHoraInicio,
                    HoraFin = formHoraFin,
                    DireccionEvento = formDireccionEvento,
                    Descuento = formDescuento,
                    Sena = formSena,
                    MontoTotalManual = formUsarPrecios ? (decimal?)null : Math.Max(0m, formTotalManual),
                    Estado = formEstado,
                    Notas = formNotas,
                    Items = formItems
                });
                if (created is null) { formError = "No se pudo crear"; return; }
                ToastService.Success($"Reserva {created.Numero} creada");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    private void ConfirmDelete(AlqReservaDto r) { reservaToDelete = r; showDeleteConfirm = true; }

    // ═══════ Print / PDF ═══════
    private async Task ShowPrint(AlqReservaDto r)
    {
        // Asegurarse de tener clientes cargados (para mostrar DNI/CUIT, telefonos en el PDF)
        if (clientes is null) await LoadCatalogos();
        // Cargar condiciones (cacheadas para no pedir varias veces)
        if (string.IsNullOrEmpty(condicionesTexto))
        {
            try { condicionesTexto = await Api.GetAlqCondicionesAsync(); }
            catch { condicionesTexto = ""; }
        }
        // Refrescar la reserva por si hubo cambios
        var fresh = await Api.GetAlqReservaAsync(r.Id);
        printReserva = fresh ?? r;
    }

    private async Task OpenPrintFromEdit()
    {
        if (!editingId.HasValue) return;
        // Forzamos guardar primero los cambios pendientes para que el PDF refleje lo último.
        // El usuario igual puede haber tocado "Guardar" antes; usamos la lista cargada.
        var current = reservas?.FirstOrDefault(x => x.Id == editingId.Value) ?? await Api.GetAlqReservaAsync(editingId.Value);
        if (current is not null) await ShowPrint(current);
    }

    private void ClosePrint() => printReserva = null;

    private async Task DoPrint()
    {
        try { await JS.InvokeVoidAsync("printElement", "alq-print", $"Reserva {printReserva?.Numero}"); }
        catch { ToastService.Error("No se pudo abrir la ventana de impresión. Permitilo en el navegador."); }
    }

    // ═══════ Condiciones ═══════
    private async Task ShowCondicionesEditor()
    {
        try { condicionesTexto = await Api.GetAlqCondicionesAsync(); }
        catch { condicionesTexto = ""; }
        condicionesEditor = condicionesTexto;
        showCondicionesEditor = true;
    }

    private async Task SaveCondiciones()
    {
        savingCondiciones = true;
        try
        {
            var ok = await Api.SetAlqCondicionesAsync(condicionesEditor ?? "");
            if (ok)
            {
                condicionesTexto = condicionesEditor ?? "";
                showCondicionesEditor = false;
                ToastService.Success("Condiciones guardadas");
            }
            else
            {
                ToastService.Error("No se pudo guardar");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { savingCondiciones = false; }
    }

    private async Task Delete()
    {
        if (reservaToDelete is null) return;
        try
        {
            var ok = await Api.DeleteAlqReservaAsync(reservaToDelete.Id);
            if (ok) { ToastService.Success("Reserva eliminada"); await Load(); }
            else { ToastService.Error("No se pudo eliminar"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; reservaToDelete = null; }
    }

    // --- Helpers de formato ---
    private static string FormatMoney(decimal v)
        => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));

    // Nombre del dia en espanol, en mayusculas (ej: SABADO). Mapeo manual para no depender de la cultura del navegador.
    private static string DiaSemana(DateTime d) => d.DayOfWeek switch
    {
        DayOfWeek.Monday => "LUNES",
        DayOfWeek.Tuesday => "MARTES",
        DayOfWeek.Wednesday => "MIÉRCOLES",
        DayOfWeek.Thursday => "JUEVES",
        DayOfWeek.Friday => "VIERNES",
        DayOfWeek.Saturday => "SÁBADO",
        DayOfWeek.Sunday => "DOMINGO",
        _ => ""
    };

    private static string FormatHorario(AlqReservaDto r)
    {
        if (string.IsNullOrEmpty(r.HoraInicio) && string.IsNullOrEmpty(r.HoraFin)) return "—";
        var h1 = r.HoraInicio ?? "";
        var h2 = r.HoraFin ?? "";
        if (!string.IsNullOrEmpty(h1) && !string.IsNullOrEmpty(h2)) return $"{h1} a {h2}";
        return !string.IsNullOrEmpty(h1) ? $"desde {h1}" : $"hasta {h2}";
    }

    private static MarkupString EstadoBadge(string estado)
    {
        var (label, bg, fg) = estado switch
        {
            "reservado" => ("📋 Reservado", "#dbeafe", "#1e40af"),
            "confirmado" => ("✅ Confirmado", "#dcfce7", "#166534"),
            "entregado" => ("🚚 Entregado", "#fef3c7", "#92400e"),
            "finalizado" => ("🏁 Finalizado", "#e5e7eb", "#374151"),
            "cancelado" => ("❌ Cancelado", "#fee2e2", "#991b1b"),
            _ => (estado, "#f3f4f6", "#6b7280")
        };
        return (MarkupString)$"<span style=\"display:inline-block; padding:0.15rem 0.55rem; background:{bg}; color:{fg}; border-radius:999px; font-size:0.75rem; font-weight:600;\">{label}</span>";
    }
}
