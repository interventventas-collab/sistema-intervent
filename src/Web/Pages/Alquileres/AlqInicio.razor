@page "/alquileres"
@attribute [Authorize]
@inject NavigationManager Nav

<div class="card">
    <div class="card-header">
        <h3>🏷️ Alquileres</h3>
    </div>
    <div class="card-body">
        <p style="color: #6b7280; margin-top: 0;">
            Módulo de alquiler de equipos para eventos. Es <strong>independiente</strong> del resto del sistema —
            tiene su propia base de datos, sus propios clientes y sus propios equipos.
        </p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin-top: 1.5rem;">
            <div class="card" style="cursor: pointer;" @onclick='() => Nav.NavigateTo("/alquileres/equipos")'>
                <div class="card-body" style="text-align: center; padding: 1.5rem;">
                    <div style="font-size: 2.5rem;">🛋️</div>
                    <h4 style="margin: 0.5rem 0 0.3rem;">Equipos</h4>
                    <p style="color: #6b7280; font-size: 0.85rem; margin: 0;">Sillas, mesas, vajilla, etc.</p>
                </div>
            </div>
            <div class="card" style="cursor: pointer;" @onclick='() => Nav.NavigateTo("/alquileres/clientes")'>
                <div class="card-body" style="text-align: center; padding: 1.5rem;">
                    <div style="font-size: 2.5rem;">👥</div>
                    <h4 style="margin: 0.5rem 0 0.3rem;">Clientes</h4>
                    <p style="color: #6b7280; font-size: 0.85rem; margin: 0;">Quiénes alquilan tus equipos.</p>
                </div>
            </div>
            <div class="card" style="cursor: pointer;" @onclick='() => Nav.NavigateTo("/alquileres/reservas")'>
                <div class="card-body" style="text-align: center; padding: 1.5rem;">
                    <div style="font-size: 2.5rem;">📅</div>
                    <h4 style="margin: 0.5rem 0 0.3rem;">Reservas</h4>
                    <p style="color: #6b7280; font-size: 0.85rem; margin: 0;">Crear y gestionar reservas con fechas y disponibilidad.</p>
                </div>
            </div>
            <div class="card" style="cursor: pointer;" @onclick='() => Nav.NavigateTo("/alquileres/calendario")'>
                <div class="card-body" style="text-align: center; padding: 1.5rem;">
                    <div style="font-size: 2.5rem;">🗓️</div>
                    <h4 style="margin: 0.5rem 0 0.3rem;">Calendario</h4>
                    <p style="color: #6b7280; font-size: 0.85rem; margin: 0;">Vista mensual de eventos.</p>
                </div>
            </div>
            <div class="card" style="opacity: 0.55;">
                <div class="card-body" style="text-align: center; padding: 1.5rem;">
                    <div style="font-size: 2.5rem;">🗺️</div>
                    <h4 style="margin: 0.5rem 0 0.3rem;">Mapa de eventos</h4>
                    <p style="color: #6b7280; font-size: 0.85rem; margin: 0;">Próximamente</p>
                </div>
            </div>
        </div>
    </div>
</div>
