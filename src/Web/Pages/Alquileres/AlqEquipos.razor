@page "/alquileres/equipos"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>
            🛋️ Equipos en alquiler
            <span style="font-weight: 500; font-size: 0.85rem; color: #6b7280;">(@(equipos?.Count ?? 0))</span>
        </h3>
        <button class="btn btn-primary" @onclick="ShowCreate">+ Nuevo Equipo</button>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando equipos...</p>
        }
        else if (equipos is null || equipos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">
                Todavia no cargaste ningun equipo. Tocá <strong>"+ Nuevo Equipo"</strong> para empezar.
            </p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">SKU</th>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th style="text-align: right;">Stock total</th>
                            <th style="text-align: right;">Precio diario</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in equipos)
                        {
                            <tr>
                                <td style="font-family: monospace; color: #374151;">@e.Sku</td>
                                <td><strong>@e.Nombre</strong>@if (!string.IsNullOrEmpty(e.Descripcion)) { <div style="font-size: 0.78rem; color: #6b7280;">@e.Descripcion</div>}</td>
                                <td style="color: #6b7280; font-size: 0.85rem;">@(e.Categoria ?? "—")</td>
                                <td style="text-align: right; font-weight: 700;">@e.StockTotal</td>
                                <td style="text-align: right;">$@e.PrecioDiario.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</td>
                                <td>
                                    <span class="status-badge @(e.IsActive ? "status-active" : "status-inactive")">
                                        @(e.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEdit(e)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(e)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar Equipo" : "Nuevo Equipo")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">SKU</label>
                        <input class="form-input" @bind="formSku" placeholder="@(isEditing ? "" : "Se genera automatico")" />
                        <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">
                            @(isEditing ? "Podes cambiarlo, pero debe ser unico." : "Si lo dejas vacio, el sistema genera ALQ-001, ALQ-002, ...")
                        </p>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre *</label>
                        <input class="form-input" @bind="formNombre" placeholder="Ej: Silla Tiffany" autofocus />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Categoría</label>
                        <input class="form-input" @bind="formCategoria" placeholder="Ej: Sillas, Mesas, Vajilla..." list="alq-categorias" />
                        <datalist id="alq-categorias">
                            @foreach (var cat in categoriasExistentes) { <option value="@cat" /> }
                        </datalist>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Stock total</label>
                        <input class="form-input" type="number" min="0" @bind="formStockTotal" />
                        <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">Cantidad total que tenés disponible.</p>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Precio diario ($)</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="formPrecioDiario" />
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Precio reposición ($)</label>
                        <input class="form-input" type="number" step="0.01" min="0" @bind="formPrecioReposicion" placeholder="Opcional" />
                        <p style="font-size: 0.75rem; color: #6b7280; margin: 0.2rem 0 0;">Lo que cobrás si no vuelve o vuelve roto.</p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Descripción</label>
                    <textarea class="form-input" @bind="formDescripcion" rows="2" placeholder="Notas sobre el equipo (opcional)"></textarea>
                </div>
                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && equipoToDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar equipo</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar el equipo <strong>@equipoToDelete.Nombre</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">Esta accion no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<AlqEquipoDto>? equipos;
    private bool isLoading = true;
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;
    private int? editingId;
    private string formSku = "";
    private string formNombre = "";
    private string formCategoria = "";
    private string formDescripcion = "";
    private int formStockTotal;
    private decimal formPrecioDiario;
    private decimal? formPrecioReposicion;
    private bool formIsActive = true;
    private bool showDeleteConfirm;
    private AlqEquipoDto? equipoToDelete;

    private List<string> categoriasExistentes => equipos is null
        ? new()
        : equipos.Where(e => !string.IsNullOrWhiteSpace(e.Categoria))
                 .Select(e => e.Categoria!)
                 .Distinct(StringComparer.OrdinalIgnoreCase)
                 .OrderBy(s => s)
                 .ToList();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        isLoading = true;
        try { equipos = await Api.GetAlqEquiposAsync() ?? new(); }
        catch { ToastService.Error("Error al cargar los equipos"); equipos = new(); }
        isLoading = false;
    }

    private void ShowCreate()
    {
        isEditing = false; editingId = null;
        formSku = ""; formNombre = ""; formCategoria = ""; formDescripcion = "";
        formStockTotal = 0; formPrecioDiario = 0m; formPrecioReposicion = null;
        formIsActive = true;
        formError = null; showForm = true;
    }

    private void ShowEdit(AlqEquipoDto e)
    {
        isEditing = true; editingId = e.Id;
        formSku = e.Sku; formNombre = e.Nombre; formCategoria = e.Categoria ?? "";
        formDescripcion = e.Descripcion ?? "";
        formStockTotal = e.StockTotal;
        formPrecioDiario = e.PrecioDiario;
        formPrecioReposicion = e.PrecioReposicion;
        formIsActive = e.IsActive;
        formError = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formNombre)) { formError = "El nombre es obligatorio"; return; }
        if (formPrecioDiario < 0) { formError = "El precio diario no puede ser negativo"; return; }
        if (formStockTotal < 0) { formError = "El stock no puede ser negativo"; return; }
        isSaving = true;
        try
        {
            if (isEditing && editingId.HasValue)
            {
                var updated = await Api.UpdateAlqEquipoAsync(editingId.Value, new UpdateAlqEquipoRequest
                {
                    Sku = formSku, Nombre = formNombre, Categoria = formCategoria,
                    Descripcion = formDescripcion, StockTotal = formStockTotal,
                    PrecioDiario = formPrecioDiario, PrecioReposicion = formPrecioReposicion,
                    IsActive = formIsActive
                });
                if (updated is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Equipo actualizado");
            }
            else
            {
                var created = await Api.CreateAlqEquipoAsync(new CreateAlqEquipoRequest
                {
                    Sku = string.IsNullOrWhiteSpace(formSku) ? null : formSku,
                    Nombre = formNombre, Categoria = formCategoria,
                    Descripcion = formDescripcion, StockTotal = formStockTotal,
                    PrecioDiario = formPrecioDiario, PrecioReposicion = formPrecioReposicion
                });
                if (created is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Equipo creado");
            }
            showForm = false;
            await Load();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    private void ConfirmDelete(AlqEquipoDto e) { equipoToDelete = e; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (equipoToDelete is null) return;
        try
        {
            var ok = await Api.DeleteAlqEquipoAsync(equipoToDelete.Id);
            if (ok) { ToastService.Success("Equipo eliminado"); await Load(); }
            else { ToastService.Error("No se pudo eliminar"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; equipoToDelete = null; }
    }
}
