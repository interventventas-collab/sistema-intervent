@if (showAdjuntarServidor)
{
    <div class="wa-modal-backdrop" @onclick="CerrarAdjuntarServidor" style="z-index:1099;"></div>
    <div class="wa-srv-modal" @onclick:stopPropagation="true">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <h5 style="margin:0;">🗂️ Adjuntar del servidor</h5>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CerrarAdjuntarServidor">×</button>
        </div>
        <div style="font-size:0.75rem; color:#6b7280; margin-top:0.25rem;">
            Enviar a <strong>@(SelectedConv()?.NombrePerfil ?? PrettyNumero(selectedNumero ?? ""))</strong>
        </div>
        <div class="wa-srv-tabs">
            <button class="wa-srv-tab @(srvTab == "VENTA" ? "active" : "")" @onclick='() => CambiarTabServidor("VENTA")'>🧾 Facturas/Ventas</button>
            <button class="wa-srv-tab @(srvTab == "COBRANZA" ? "active" : "")" @onclick='() => CambiarTabServidor("COBRANZA")'>💰 Recibos cobranza</button>
            <button class="wa-srv-tab @(srvTab == "UPLOAD" ? "active" : "")" @onclick='() => CambiarTabServidor("UPLOAD")'>📁 Mis subidos</button>
        </div>
        <input class="wa-srv-search" placeholder="@SrvSearchPlaceholder()"
               value="@srvSearch" @oninput="OnSrvSearchInput" />
        <div class="wa-srv-list">
            @if (srvLoading)
            {
                <div class="wa-srv-empty">Cargando…</div>
            }
            else if (srvResultados.Count == 0)
            {
                <div class="wa-srv-empty">@(string.IsNullOrWhiteSpace(srvSearch) ? "Sin resultados. Probá buscando." : "Sin resultados con ese filtro.")</div>
            }
            else
            {
                @foreach (var f in srvResultados)
                {
                    <div class="wa-srv-item">
                        <div class="wa-srv-item-main">
                            <div class="wa-srv-item-label">@f.Label</div>
                            @if (!string.IsNullOrWhiteSpace(f.SubLabel))
                            {
                                <div class="wa-srv-item-sub">@f.SubLabel</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(f.Info))
                            {
                                <div class="wa-srv-item-info">@f.Info · @f.Fecha.ToArTime().ToString("dd/MM/yyyy")</div>
                            }
                        </div>
                        <button class="wa-srv-send-btn" @onclick="() => EnviarServerFile(f)" disabled="@(srvEnviandoId == f.Id)">
                            @(srvEnviandoId == f.Id ? "Enviando…" : "📤 Enviar")
                        </button>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    List<ApiClient.TwConvDto> conversaciones = new();
    List<ApiClient.TwMsgDto> mensajes = new();
    string? selectedNumero;
    string composerText = "";
    bool loadingConv = true, loadingMsg = false, sending = false, uploading = false, enviandoMenuRol = false;
    System.Threading.Timer? refreshTimer;
    Microsoft.AspNetCore.Components.ElementReference messagesScroll;

    // Respuestas rapidas + contactos
    List<ApiClient.TwRespRapidaDto> respuestas = new();
    List<ApiClient.TwContactoDto> contactos = new();
    bool showConfig = false;
    string configTab = "resp";
    // dict para edicion inline
    Dictionary<int, string> editRespNombre = new(), editRespTexto = new();
    Dictionary<int, int> editRespOrden = new();
    Dictionary<int, bool> editRespActivo = new();
    Dictionary<int, string> editContNombre = new(), editContRol = new(), editContNotas = new();
    Dictionary<int, bool> editContActivo = new();
    Dictionary<int, int?> editContClienteId = new();
    Dictionary<int, string?> editContClienteNombre = new();
    Dictionary<int, string> editContClienteQuery = new();
    int? clienteBusquedaActivaId = null;
    List<ApiClient.TwClienteBuscarDto> clienteResultados = new();
    // Reacciones
    int? pickerOpenMsgId = null;
    static readonly string[] QuickEmojis = new[] { "👍", "❤️", "😂", "😮", "😢", "🙏", "✅", "⏳", "❗" };
    // === Selección de mensajes + Nueva Venta en ventana popup ===
    HashSet<int> mensajesSeleccionadosIds = new();

    string NuevaVentaPopupUrl()
    {
        var seleccionados = mensajes.Where(m => mensajesSeleccionadosIds.Contains(m.Id))
            .OrderBy(m => m.CreatedAt).ToList();
        var conv = SelectedConv();
        var lineas = new List<string>();
        var nombre = conv?.NombrePerfil ?? PrettyNumero(selectedNumero ?? "");
        lineas.Add($"📱 WhatsApp de {nombre} ({PrettyNumero(selectedNumero ?? "")})");
        foreach (var m in seleccionados)
            if (!string.IsNullOrWhiteSpace(m.Cuerpo)) lineas.Add(m.Cuerpo!);
        var notas = string.Join(" · ", lineas);
        var url = $"/cafe/ventas?fromTwilio=1&notas={Uri.EscapeDataString(notas)}";
        if (conv?.ClienteId is int cid) url += $"&clienteIdPre={cid}";
        return url;
    }

    void ToggleSeleccionMensaje(int id)
    {
        if (mensajesSeleccionadosIds.Contains(id)) mensajesSeleccionadosIds.Remove(id);
        else mensajesSeleccionadosIds.Add(id);
    }

    /// <summary>2026-06-20: abre Nueva Venta en una ventana popup separada (window.open) con tamaño
    /// específico. Se ve la pantalla normal del modal de Nueva Venta, no embebida.</summary>
    async Task AbrirVentanaVenta()
    {
        if (mensajesSeleccionadosIds.Count == 0) { Toast.Warning("Seleccioná al menos un mensaje"); return; }
        var url = NuevaVentaPopupUrl();
        // width=1300, height=850, posicionado a la derecha. Resizable + scrollbars activos.
        var features = "width=1300,height=850,left=200,top=50,resizable=yes,scrollbars=yes,toolbar=no,menubar=no,location=no";
        await JS.InvokeVoidAsync("open", url, "nueva-venta-wa", features);
        // Limpiamos la seleccion para evitar abrir 2 veces el mismo set
        mensajesSeleccionadosIds.Clear();
    }
    // Quick contact modal
    bool showQuickContact = false;
    string quickContactNumero = "", quickContactNombre = "", quickContactRol = "hermano", quickContactNotas = "";
    int? quickContactClienteId = null;
    string? quickContactClienteNombre = null;
    string quickContactClienteQuery = "";
    List<ApiClient.TwClienteBuscarDto> clienteResultadosQuick = new();

    bool EstaEnContactos(string? numero)
        => !string.IsNullOrEmpty(numero) && contactos.Any(c => c.Numero == numero);

    ApiClient.TwContactoDto? GetContactoByNumero(string numero)
        => contactos.FirstOrDefault(c => c.Numero == numero);

    void AbrirAsignarContacto()
    {
        if (selectedNumero == null) return;
        var conv = SelectedConv();
        quickContactNumero = selectedNumero;
        quickContactNombre = conv?.NombrePerfil ?? "";
        quickContactRol = "hermano";
        quickContactNotas = "";
        quickContactClienteId = null;
        quickContactClienteNombre = null;
        quickContactClienteQuery = "";
        clienteResultadosQuick = new();
        showQuickContact = true;
    }

    void AbrirEditarContacto()
    {
        showConfig = true;
        configTab = "cont";
    }

    async Task BuscarClientesQuick()
    {
        try { clienteResultadosQuick = await Api.BuscarTwClientesAsync(quickContactClienteQuery ?? ""); }
        catch { clienteResultadosQuick = new(); }
    }

    void SeleccionarClienteQuick(ApiClient.TwClienteBuscarDto cli)
    {
        quickContactClienteId = cli.Id;
        quickContactClienteNombre = cli.Nombre;
        clienteResultadosQuick = new();
        quickContactClienteQuery = "";
    }

    async Task GuardarQuickContact()
    {
        if (string.IsNullOrWhiteSpace(quickContactNombre)) { Toast.Error("El nombre es obligatorio"); return; }
        var (ok, err) = await Api.CreateTwContactoAsync(new ApiClient.TwContactoUpsert(
            quickContactNumero, quickContactNombre, quickContactRol, quickContactNotas, true, quickContactClienteId));
        if (ok)
        {
            Toast.Success("Contacto asignado");
            showQuickContact = false;
            await LoadContactos();
            await LoadConversaciones(silent: true);
        }
        else Toast.Error(err ?? "Error al guardar");
    }
    // nuevos
    string nuevaRespNombre = "", nuevaRespTexto = "";
    int nuevaRespOrden = 99;
    string nuevoContNumero = "", nuevoContNombre = "", nuevoContRol = "hermano", nuevoContNotas = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadConversaciones();
        await LoadRespuestas();
        await LoadContactos();
        refreshTimer = new System.Threading.Timer(async _ => await OnTick(), null, 10_000, 10_000);
    }

    async Task LoadRespuestas()
    {
        try
        {
            respuestas = await Api.GetTwRespuestasAsync();
            foreach (var r in respuestas)
            {
                editRespNombre[r.Id] = r.Nombre;
                editRespTexto[r.Id] = r.Texto;
                editRespOrden[r.Id] = r.Orden;
                editRespActivo[r.Id] = r.Activo;
            }
        }
        catch { }
    }
    async Task LoadContactos()
    {
        try
        {
            contactos = await Api.GetTwContactosAsync();
            foreach (var c in contactos)
            {
                editContNombre[c.Id] = c.Nombre;
                editContRol[c.Id] = c.Rol;
                editContNotas[c.Id] = c.Notas ?? "";
                editContActivo[c.Id] = c.Activo;
                editContClienteId[c.Id] = c.ClienteId;
                editContClienteNombre[c.Id] = c.ClienteNombre;
                editContClienteQuery[c.Id] = "";
            }
        }
        catch { }
    }

    async Task BuscarClientes(int contactoId)
    {
        clienteBusquedaActivaId = contactoId;
        var q = editContClienteQuery.GetValueOrDefault(contactoId, "");
        try { clienteResultados = await Api.BuscarTwClientesAsync(q); }
        catch { clienteResultados = new(); }
    }

    void SeleccionarCliente(int contactoId, ApiClient.TwClienteBuscarDto cli)
    {
        editContClienteId[contactoId] = cli.Id;
        editContClienteNombre[contactoId] = cli.Nombre;
        clienteResultados = new();
        clienteBusquedaActivaId = null;
    }

    // === Reacciones ===
    void TogglePicker(int msgId)
    {
        pickerOpenMsgId = pickerOpenMsgId == msgId ? null : msgId;
    }

    async Task ReaccionarA(int msgId, string emoji)
    {
        pickerOpenMsgId = null;
        var ok = await Api.ToggleReaccionAsync(msgId, emoji);
        if (ok) await LoadMensajes(silent: true);
    }

    void InsertarRespuesta(ApiClient.TwRespRapidaDto r)
    {
        var texto = ReemplazarVariables(r.Texto);
        composerText = string.IsNullOrWhiteSpace(composerText) ? texto : composerText + " " + texto;
    }

    // 2026-06-20: reemplaza {nombre}, {numero} con datos del contacto seleccionado.
    string ReemplazarVariables(string s)
    {
        var conv = SelectedConv();
        var nombre = (conv?.NombrePerfil ?? "").Split(' ').FirstOrDefault() ?? "";
        var num = PrettyNumero(conv?.Numero ?? "");
        return s.Replace("{nombre}", nombre).Replace("{numero}", num).Replace("{Nombre}", nombre);
    }

    async Task GuardarResp(ApiClient.TwRespRapidaDto r)
    {
        var ok = await Api.UpdateTwRespuestaAsync(r.Id, new ApiClient.TwRespUpsert(editRespNombre[r.Id], editRespTexto[r.Id], editRespOrden[r.Id], editRespActivo[r.Id]));
        if (ok) { Toast.Success("Guardado"); await LoadRespuestas(); }
        else Toast.Error("Error al guardar");
    }
    async Task BorrarResp(ApiClient.TwRespRapidaDto r)
    {
        if (await Api.DeleteTwRespuestaAsync(r.Id)) { Toast.Success("Borrado"); await LoadRespuestas(); }
    }
    async Task AgregarResp()
    {
        if (string.IsNullOrWhiteSpace(nuevaRespNombre) || string.IsNullOrWhiteSpace(nuevaRespTexto)) { Toast.Error("Nombre y texto son obligatorios"); return; }
        if (await Api.CreateTwRespuestaAsync(new ApiClient.TwRespUpsert(nuevaRespNombre, nuevaRespTexto, nuevaRespOrden, true)))
        {
            Toast.Success("Agregado");
            nuevaRespNombre = ""; nuevaRespTexto = ""; nuevaRespOrden = 99;
            await LoadRespuestas();
        }
    }
    async Task GuardarCont(ApiClient.TwContactoDto c)
    {
        if (await Api.UpdateTwContactoAsync(c.Id, new ApiClient.TwContactoUpsert(
                c.Numero, editContNombre[c.Id], editContRol[c.Id], editContNotas[c.Id], editContActivo[c.Id],
                editContClienteId.GetValueOrDefault(c.Id))))
        { Toast.Success("Guardado"); await LoadContactos(); await LoadConversaciones(silent: true); }
    }
    async Task BorrarCont(ApiClient.TwContactoDto c)
    {
        if (await Api.DeleteTwContactoAsync(c.Id)) { Toast.Success("Borrado"); await LoadContactos(); await LoadConversaciones(silent: true); }
    }
    async Task AgregarCont()
    {
        if (string.IsNullOrWhiteSpace(nuevoContNumero) || string.IsNullOrWhiteSpace(nuevoContNombre)) { Toast.Error("Número y nombre son obligatorios"); return; }
        var (ok, err) = await Api.CreateTwContactoAsync(new ApiClient.TwContactoUpsert(nuevoContNumero, nuevoContNombre, nuevoContRol, nuevoContNotas, true, null));
        if (ok)
        {
            Toast.Success("Contacto agregado");
            nuevoContNumero = ""; nuevoContNombre = ""; nuevoContNotas = "";
            await LoadContactos(); await LoadConversaciones(silent: true);
        }
        else Toast.Error(err ?? "Error");
    }

    async Task OnTick()
    {
        await InvokeAsync(async () =>
        {
            await LoadConversaciones(silent: true);
            if (selectedNumero != null) await LoadMensajes(silent: true);
            StateHasChanged();
        });
    }

    async Task LoadConversaciones(bool silent = false)
    {
        if (!silent) loadingConv = true;
        try { conversaciones = await Api.GetTwConversacionesAsync(); }
        catch { }
        loadingConv = false;
    }

    async Task SelectConv(string numero)
    {
        selectedNumero = numero;
        await LoadMensajes();
    }

    async Task LoadMensajes(bool silent = false)
    {
        if (selectedNumero == null) return;
        if (!silent) loadingMsg = true;
        try { mensajes = await Api.GetTwMensajesAsync(selectedNumero); }
        catch { }
        loadingMsg = false;
    }

    async Task EnviarMensaje()
    {
        if (selectedNumero == null || string.IsNullOrWhiteSpace(composerText)) return;
        sending = true;
        var (ok, err) = await Api.SendTwMensajeAsync(selectedNumero, composerText.Trim());
        sending = false;
        if (ok)
        {
            composerText = "";
            await LoadMensajes();
            await LoadConversaciones(silent: true);
        }
        else
        {
            Toast.Error($"Error al enviar: {err}");
        }
    }

    async Task OnComposerKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await EnviarMensaje();
        }
    }

    async Task EnviarMenuRol()
    {
        if (string.IsNullOrEmpty(selectedNumero)) return;
        enviandoMenuRol = true;
        var (ok, err) = await Api.SendTwMenuRolAsync(selectedNumero);
        enviandoMenuRol = false;
        if (ok)
        {
            Toast.Success("Menú enviado");
            await LoadMensajes();
            await LoadConversaciones(silent: true);
        }
        else
        {
            Toast.Error($"Error al enviar: {err}");
        }
    }

    // ===== Adjuntar archivo de la PC =====
    const long MaxUploadBytes = 16L * 1024 * 1024; // 16 MB (limite WhatsApp)

    async Task OnArchivoSeleccionado(InputFileChangeEventArgs e)
    {
        if (selectedNumero == null) { Toast.Warning("Seleccioná primero un chat"); return; }
        var file = e.File;
        if (file == null) return;
        if (file.Size > MaxUploadBytes) { Toast.Error($"El archivo {file.Name} supera los 16 MB"); return; }

        uploading = true;
        StateHasChanged();
        try
        {
            // Tomamos el caption del composer (si hay) para acompañar el archivo
            var caption = composerText?.Trim();

            // 1) Subir al servidor (que devuelve URL publica con token)
            using var stream = file.OpenReadStream(MaxUploadBytes);
            var (resp, err) = await Api.UploadTwArchivoAsync(stream, file.Name, file.ContentType);
            if (resp == null) { Toast.Error($"Error subiendo: {err}"); return; }

            // 2) Mandar el WhatsApp con la URL publica al numero seleccionado
            var (ok, sendErr) = await Api.SendTwMediaAsync(selectedNumero, resp.Url, caption, file.Name);
            if (!ok) { Toast.Error($"Error enviando: {sendErr}"); return; }

            composerText = "";
            Toast.Success($"📎 {file.Name} enviado");
            await LoadMensajes();
            await LoadConversaciones(silent: true);
        }
        catch (Exception ex) { Toast.Error($"Error: {ex.Message}"); }
        finally { uploading = false; StateHasChanged(); }
    }

    // ===== Adjuntar archivos del servidor (Fase 2) =====
    bool showAdjuntarServidor = false;
    string srvTab = "COBRANZA";
    string srvSearch = "";
    bool srvLoading = false;
    List<ApiClient.TwServerFileDto> srvResultados = new();
    int? srvEnviandoId = null;
    System.Threading.Timer? srvSearchTimer;

    string SrvSearchPlaceholder() => srvTab switch
    {
        "VENTA" => "🔍 Nº venta, cliente o código...",
        "COBRANZA" => "🔍 Nº recibo, cliente o código...",
        _ => "🔍 Nombre del archivo..."
    };

    async Task AbrirAdjuntarServidor()
    {
        if (selectedNumero == null) { Toast.Warning("Seleccioná primero un chat"); return; }
        showAdjuntarServidor = true;
        srvSearch = "";
        srvTab = "VENTA";
        await CargarServerFiles();
    }

    void CerrarAdjuntarServidor()
    {
        showAdjuntarServidor = false;
        srvResultados.Clear();
        srvEnviandoId = null;
        srvSearchTimer?.Dispose();
        srvSearchTimer = null;
    }

    async Task CambiarTabServidor(string tab)
    {
        srvTab = tab;
        srvSearch = "";
        await CargarServerFiles();
    }

    void OnSrvSearchInput(ChangeEventArgs e)
    {
        srvSearch = e.Value?.ToString() ?? "";
        srvSearchTimer?.Dispose();
        srvSearchTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () => { await CargarServerFiles(); StateHasChanged(); });
        }, null, 250, System.Threading.Timeout.Infinite);
    }

    async Task CargarServerFiles()
    {
        srvLoading = true;
        StateHasChanged();
        srvResultados = await Api.GetTwServerFilesAsync(srvTab, string.IsNullOrWhiteSpace(srvSearch) ? null : srvSearch);
        srvLoading = false;
        StateHasChanged();
    }

    async Task EnviarServerFile(ApiClient.TwServerFileDto f)
    {
        if (selectedNumero == null) return;
        srvEnviandoId = f.Id;
        StateHasChanged();
        var caption = composerText?.Trim();
        var (ok, err) = await Api.SendTwServerFileAsync(selectedNumero, f.Tipo, f.Id, caption);
        srvEnviandoId = null;
        if (ok)
        {
            composerText = "";
            Toast.Success($"📎 {f.Label} enviado");
            CerrarAdjuntarServidor();
            await LoadMensajes();
            await LoadConversaciones(silent: true);
        }
        else
        {
            Toast.Error($"Error: {err}");
            StateHasChanged();
        }
    }

    void CargarComoPedido()
    {
        var conv = SelectedConv();
        var nombre = conv?.NombrePerfil ?? PrettyNumero(selectedNumero ?? "");
        var ultimoIn = mensajes.LastOrDefault(m => m.Direccion == "INCOMING");
        var notas = $"📱 WhatsApp de {nombre} ({PrettyNumero(selectedNumero ?? "")})\n\n{ultimoIn?.Cuerpo ?? ""}";
        var url = $"/cafe/ventas?notas={Uri.EscapeDataString(notas)}";
        // Si el contacto está vinculado a un cliente, precargar el id
        if (conv?.ClienteId is int cid) url += $"&clienteId={cid}";
        Nav.NavigateTo(url);
    }

    ApiClient.TwConvDto? SelectedConv() => conversaciones.FirstOrDefault(c => c.Numero == selectedNumero);

    string AvatarLetra(ApiClient.TwConvDto? c)
    {
        if (c?.NombrePerfil is { Length: > 0 } n) return n.Substring(0, 1).ToUpper();
        return "?";
    }

    string PrettyNumero(string numero) => numero?.Replace("whatsapp:", "").Trim() ?? "";

    string FormatHora(DateTime utc)
    {
        var local = utc.ToArTime();
        var ahora = DateTime.Now;
        if (local.Date == ahora.Date) return local.ToString("HH:mm");
        if (local.Date == ahora.Date.AddDays(-1)) return "Ayer";
        return local.ToString("dd/MM");
    }

    string TruncateText(string? s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "";
        return s.Length <= max ? s : s.Substring(0, max) + "…";
    }

    string EscapeMsg(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        return System.Net.WebUtility.HtmlEncode(s).Replace("\n", "<br/>");
    }

    bool IsImage(string? url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        var lower = url.ToLowerInvariant();
        return lower.Contains(".jpg") || lower.Contains(".jpeg") || lower.Contains(".png")
            || lower.Contains(".gif") || lower.Contains(".webp") || lower.Contains("image");
    }

    // ===== Filtros / detección de pedido =====
    string filtroRol = "";
    List<ApiClient.TwConvDto> conversacionesFiltradas => conversaciones.Where(MatchFiltro).ToList();

    bool MatchFiltro(ApiClient.TwConvDto c)
    {
        if (string.IsNullOrEmpty(filtroRol)) return true;
        if (filtroRol == "pedido") return EsPedido(c.UltimoMensaje);
        if (filtroRol == "sin") return string.IsNullOrEmpty(c.Rol);
        return c.Rol == filtroRol;
    }

    // Heuristica simple: si el mensaje contiene palabras tipicas de pedido.
    bool EsPedido(string? msg)
    {
        if (string.IsNullOrWhiteSpace(msg)) return false;
        var m = msg.ToLowerInvariant();
        return m.StartsWith("#ped") || m.StartsWith("pedido")
            || m.Contains("necesito") || m.Contains("pasame") || m.Contains("mandame")
            || m.Contains("traeme") || m.Contains("llevame") || m.Contains("encarg");
    }

    string RolEmoji(string? rol) => rol switch
    {
        "hermano" => "👨‍👦",
        "empleado" => "👷",
        "cliente" => "🛍️",
        "proveedor" => "🚚",
        _ => ""
    };

    string AvatarColor(ApiClient.TwConvDto c)
    {
        var bg = c.Rol switch
        {
            "hermano" => "#3b82f6",
            "empleado" => "#f59e0b",
            "cliente" => "#10b981",
            "proveedor" => "#8b5cf6",
            _ => "#25d366"
        };
        return $"background:{bg};";
    }

