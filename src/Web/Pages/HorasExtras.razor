                                <td style="padding:0.4rem 0; font-weight:700; color:#16a34a;">+@registroParaBorrar.Cantidad.ToString("0.##") h</td></tr>
                        }
                        @if (!string.IsNullOrEmpty(registroParaBorrar.Observaciones))
                        {
                            <tr><td style="padding:0.4rem 0.6rem 0.4rem 0; color:#6b7280; font-weight:600; vertical-align:top;">Observación:</td>
