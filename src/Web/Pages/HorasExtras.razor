@code {
    public record AdminEmpleadoDto(int Id, string Nombre, string Token, bool IsActive,
        decimal TotalHoy, decimal TotalSemana, decimal TotalMes, DateTime? UltimaCargaAt, DateTime CreatedAt,
        string? UltimaHoraEntrada = null, string? UltimaHoraSalida = null,
        string? DniUltimos3 = null, string Slug = "",
        // 2026-06-02: jornada laboral configurable + acumulados de horario marcado vs esperado
        decimal HorasLunes = 8m, decimal HorasMartes = 8m, decimal HorasMiercoles = 8m, decimal HorasJueves = 8m,
        decimal HorasViernes = 8m, decimal HorasSabado = 5m, decimal HorasDomingo = 0m,
        decimal JornadaSemanal = 45m,
        decimal TrabajadoSemana = 0m, decimal EsperadoSemana = 0m, decimal DiferenciaSemana = 0m,
        decimal TrabajadoMes = 0m, decimal EsperadoMes = 0m, decimal DiferenciaMes = 0m,
        // 2026-06-03: flag mostrar extras al empleado + ciclo de liquidacion
        bool MostrarExtrasAlEmpleado = false, int? CicloDiaInicio = null, int? CicloDiaFin = null,
        DateTime CicloDesde = default, DateTime CicloHasta = default, string CicloLabel = "",
        decimal TrabajadoCiclo = 0m, decimal EsperadoCiclo = 0m, decimal DiferenciaCiclo = 0m,
        // 2026-06-03 v2: flags granulares de visibilidad
        bool MostrarCuadroCiclo = false, bool MostrarHorasTrabajadasDia = false,
        // 2026-06-03 v3: flag para probar el modo nuevo de fichada (WiFi + GPS) solo en este empleado
        bool ProbarModoNuevoFichada = false,
        // 2026-06-03 v4: mostrar este empleado en el kiosco /fichador
        bool MostrarEnFichador = true);
    public record AdminRegistroDto(int Id, int EmpleadoId, string EmpleadoNombre, DateTime Fecha,
        decimal Cantidad, string? Observaciones, string? HoraEntrada, string? HoraSalida,
        DateTime CreatedAt, DateTime? UpdatedAt,
        decimal HorasTrabajadas = 0m, decimal HorasEsperadas = 0m, decimal Diferencia = 0m, string DiaNombre = "");

    private List<AdminEmpleadoDto>? empleados;
    private List<AdminRegistroDto>? registros;
    // 2026-06-03: filtro client-side por empleado en la tabla de registros recientes. 0 = todos.
    private int filtroEmpleadoId = 0;

    private bool showFormEmp, savingEmp;
    private int? editingId;
    private string formNombre = "";
    private string formDniUltimos3 = "";
    private bool formActive = true, formRegenToken;
    // 2026-06-02: jornada por dia de la semana (default LUN-VIE 8h, SAB 5h, DOM 0h)
    private decimal formHLun = 8m, formHMar = 8m, formHMie = 8m, formHJue = 8m, formHVie = 8m, formHSab = 5m, formHDom = 0m;
    // 2026-06-03: flag para mostrar extras al empleado + ciclo de liquidacion
    private bool formMostrarExtras = false;
    private bool formCicloPersonalizado = false;  // false = mes calendario
    private int formCicloDiaInicio = 16;          // default 16 cuando elegis personalizado
    private int formCicloDiaFin = 15;             // default 15
    // 2026-06-03 v2: flags granulares de visibilidad
    private bool formMostrarCuadroCiclo = false;
    private bool formMostrarHorasTrabajadasDia = false;
    // 2026-06-03 v3: flag para probar el modo nuevo de fichada SOLO en este empleado
    private bool formProbarModoNuevoFichada = false;
    // 2026-06-03 v4: mostrar este empleado en el kiosco /fichador (default true)
    private bool formMostrarEnFichador = true;

    // Carga manual (para acumulados)
    private bool showCargarManual, savingManual;
    private AdminEmpleadoDto? cargandoManualPara;
    private DateTime manualFecha = DateTime.Today;
    private decimal manualCantidad;
    private string manualObservacion = "";

    private void ShowCargarManual(AdminEmpleadoDto e)
    {
        cargandoManualPara = e;
        manualFecha = DateTime.Today;
        manualCantidad = 0;
        manualObservacion = "Carga manual";
        showCargarManual = true;
    }

    private async Task GuardarManualAsync()
    {
        if (cargandoManualPara is null) return;
        if (manualCantidad <= 0) { ToastService.Error("La cantidad tiene que ser mayor a 0"); return; }
        savingManual = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/horas-extras/admin/registros/manual",
                new { EmpleadoId = cargandoManualPara.Id, Fecha = manualFecha, Cantidad = manualCantidad, Observaciones = manualObservacion });
            if (resp.IsSuccessStatusCode)
            {
                ToastService.Success($"Cargadas {manualCantidad:0.#}h para {cargandoManualPara.Nombre}");
                showCargarManual = false;
                await RecargarTodo();
            }
            else { ToastService.Error("Error al guardar"); }
        }
        finally { savingManual = false; }
    }

    private System.Threading.Timer? autoRefreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await RecargarTodo();
        // Auto-refresh cada 30s para que el admin vea la carga del empleado en tiempo real.
        autoRefreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RecargarTodo();
                StateHasChanged();
            });
        }, null, 30000, 30000);
    }

    public void Dispose() => autoRefreshTimer?.Dispose();

    private async Task RecargarTodo()
    {
        empleados = await Http.GetFromJsonAsync<List<AdminEmpleadoDto>>("api/horas-extras/admin/empleados");
        registros = await Http.GetFromJsonAsync<List<AdminRegistroDto>>("api/horas-extras/admin/registros");
    }

    private void ShowCreateEmpleado()
    {
        editingId = null; formNombre = ""; formDniUltimos3 = ""; formActive = true; formRegenToken = false; showFormEmp = true;
        // Defaults jornada: LUN-VIE 8h, SAB 5h, DOM 0h
        formHLun = 8m; formHMar = 8m; formHMie = 8m; formHJue = 8m; formHVie = 8m; formHSab = 5m; formHDom = 0m;
        // 2026-06-03: defaults nuevo empleado
        formMostrarExtras = false;
        formCicloPersonalizado = false;
        formCicloDiaInicio = 16;
        formCicloDiaFin = 15;
        // 2026-06-03 v2: nuevos defaults OFF
        formMostrarCuadroCiclo = false;
        formMostrarHorasTrabajadasDia = false;
        formProbarModoNuevoFichada = false;
        formMostrarEnFichador = true;
    }

    private void ShowEditEmpleado(AdminEmpleadoDto e)
    {
        editingId = e.Id; formNombre = e.Nombre; formDniUltimos3 = e.DniUltimos3 ?? "";
        formActive = e.IsActive; formRegenToken = false; showFormEmp = true;
        // Jornada actual del empleado
        formHLun = e.HorasLunes; formHMar = e.HorasMartes; formHMie = e.HorasMiercoles;
        formHJue = e.HorasJueves; formHVie = e.HorasViernes; formHSab = e.HorasSabado; formHDom = e.HorasDomingo;
        // 2026-06-03: flag + ciclo
        formMostrarExtras = e.MostrarExtrasAlEmpleado;
        formCicloPersonalizado = e.CicloDiaInicio.HasValue && e.CicloDiaFin.HasValue;
        formCicloDiaInicio = e.CicloDiaInicio ?? 16;
        formCicloDiaFin = e.CicloDiaFin ?? 15;
        // 2026-06-03 v2: flags granulares
        formMostrarCuadroCiclo = e.MostrarCuadroCiclo;
        formMostrarHorasTrabajadasDia = e.MostrarHorasTrabajadasDia;
        formProbarModoNuevoFichada = e.ProbarModoNuevoFichada;
        formMostrarEnFichador = e.MostrarEnFichador;
    }

    private async Task GuardarEmpleado()
    {
        if (string.IsNullOrWhiteSpace(formNombre)) { ToastService.Error("Nombre obligatorio"); return; }
        // Si vino DNI, validar 3 dígitos.
        var dni3 = string.IsNullOrWhiteSpace(formDniUltimos3) ? null : formDniUltimos3.Trim();
        if (!string.IsNullOrEmpty(dni3) && (dni3.Length != 3 || !dni3.All(char.IsDigit)))
        {
            ToastService.Error("DNI debe ser 3 dígitos");
            return;
        }
        savingEmp = true;
        try
        {
            if (editingId.HasValue)
            {
                // 2026-06-03: si NO es personalizado -> ClearCiclo=true (vuelve a mes calendario).
                //              si SI es personalizado -> mandamos los dias para que el backend los persista.
                var resp = await Http.PutAsJsonAsync($"api/horas-extras/admin/empleados/{editingId.Value}",
                    new { Nombre = formNombre, IsActive = formActive, DniUltimos3 = dni3,
                          ClearDniUltimos3 = string.IsNullOrEmpty(dni3), RegenerarToken = formRegenToken,
                          HorasLunes = formHLun, HorasMartes = formHMar, HorasMiercoles = formHMie,
                          HorasJueves = formHJue, HorasViernes = formHVie, HorasSabado = formHSab, HorasDomingo = formHDom,
                          MostrarExtrasAlEmpleado = formMostrarExtras,
                          CicloDiaInicio = formCicloPersonalizado ? (int?)formCicloDiaInicio : null,
                          CicloDiaFin = formCicloPersonalizado ? (int?)formCicloDiaFin : null,
                          ClearCiclo = !formCicloPersonalizado,
                          MostrarCuadroCiclo = formMostrarCuadroCiclo,
                          MostrarHorasTrabajadasDia = formMostrarHorasTrabajadasDia,
                          ProbarModoNuevoFichada = formProbarModoNuevoFichada,
                          MostrarEnFichador = formMostrarEnFichador });
                if (resp.IsSuccessStatusCode) ToastService.Success("Empleado actualizado");
                else { ToastService.Error("Error actualizando"); return; }
            }
            else
            {
                // Crear primero, despues update con la jornada (el endpoint create todavia
                // no acepta jornada en el body, pero el update si — patron mas seguro).
                var resp = await Http.PostAsJsonAsync("api/horas-extras/admin/empleados",
                    new { Nombre = formNombre, DniUltimos3 = dni3 });
                if (resp.IsSuccessStatusCode)
                {
                    ToastService.Success("Empleado creado");
                    // Si el create devuelve el empleado nuevo con su Id, le aplicamos la jornada
                    try
                    {
                        var nuevo = await resp.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                        if (nuevo.TryGetProperty("id", out var idEl) && idEl.TryGetInt32(out var newId))
                        {
                            await Http.PutAsJsonAsync($"api/horas-extras/admin/empleados/{newId}",
                                new { HorasLunes = formHLun, HorasMartes = formHMar, HorasMiercoles = formHMie,
                                      HorasJueves = formHJue, HorasViernes = formHVie, HorasSabado = formHSab, HorasDomingo = formHDom,
                                      MostrarExtrasAlEmpleado = formMostrarExtras,
                                      CicloDiaInicio = formCicloPersonalizado ? (int?)formCicloDiaInicio : null,
                                      CicloDiaFin = formCicloPersonalizado ? (int?)formCicloDiaFin : null,
                                      ClearCiclo = !formCicloPersonalizado });
                        }
                    }
                    catch { /* no es critico — si fallo, queda con los defaults del backend */ }
                }
                else
                {
                    var err = await resp.Content.ReadAsStringAsync();
                    ToastService.Error(err.Contains("Ya existe") ? "Ya existe un empleado con ese nombre + DNI" : "Error creando");
                    return;
                }
            }
            showFormEmp = false;
            await RecargarTodo();
        }
        finally { savingEmp = false; }
    }

    // 2026-06-03: confirmacion de borrado con modal grande que muestra los datos del registro
    // (antes era confirm() del browser y no se veia que se estaba borrando).
    private AdminRegistroDto? registroParaBorrar;
    private bool borrandoRegistro;

    private void PedirBorrarRegistro(AdminRegistroDto r) { registroParaBorrar = r; }
    private void CancelarBorrarRegistro() { registroParaBorrar = null; }

    private async Task ConfirmarBorrarRegistro()
    {
        if (registroParaBorrar is null) return;
        borrandoRegistro = true;
        try
        {
            var resp = await Http.DeleteAsync($"api/horas-extras/admin/registros/{registroParaBorrar.Id}");
            if (resp.IsSuccessStatusCode)
            {
                ToastService.Success($"Registro de {registroParaBorrar.EmpleadoNombre} del {registroParaBorrar.Fecha:dd/MM} borrado");
                registroParaBorrar = null;
                await RecargarTodo();
            }
            else
            {
                ToastService.Error("No se pudo borrar el registro");
            }
        }
        finally { borrandoRegistro = false; }
    }

    // 2026-06-08: edición manual de horario (admin)
    private AdminRegistroDto? registroParaEditar;
    private TimeOnly? editHoraEntrada;
    private TimeOnly? editHoraSalida;
    private string editObservaciones = "";
    private string? editError;
    private bool guardandoEdicion;

    private void AbrirEditarRegistro(AdminRegistroDto r)
    {
        registroParaEditar = r;
        editHoraEntrada = TimeOnly.TryParse(r.HoraEntrada, out var he) ? he : (TimeOnly?)null;
        editHoraSalida = TimeOnly.TryParse(r.HoraSalida, out var hs) ? hs : (TimeOnly?)null;
        editObservaciones = r.Observaciones ?? "";
        editError = null;
    }
    private void CancelarEditar() { registroParaEditar = null; editError = null; }

    private async Task ConfirmarEditar()
    {
        if (registroParaEditar is null) return;
        guardandoEdicion = true;
        editError = null;
        try
        {
            var body = new
            {
                HoraEntrada = editHoraEntrada?.ToString("HH:mm"),
                HoraSalida = editHoraSalida?.ToString("HH:mm"),
                Observaciones = string.IsNullOrWhiteSpace(editObservaciones) ? null : editObservaciones
            };
            var resp = await Http.PutAsJsonAsync($"api/horas-extras/admin/registros/{registroParaEditar.Id}", body);
            if (resp.IsSuccessStatusCode)
            {
                ToastService.Success($"Horario de {registroParaEditar.EmpleadoNombre} actualizado");
                registroParaEditar = null;
                await RecargarTodo();
            }
            else
            {
                editError = "No se pudo guardar. Verificá los horarios (formato HH:mm).";
            }
        }
        catch
        {
            editError = "Error de conexión.";
        }
        finally { guardandoEdicion = false; }
    }

    /// <summary>Genera el URL público del empleado. La clave NO va en el URL — se la pide
    /// al empleado en una pantalla aparte al entrar. Igual chequeamos que esté cargada antes
    /// de generar el link, sino el empleado no tiene cómo entrar.</summary>
    private string? BuildLinkPublico(AdminEmpleadoDto e, string origin)
    {
        if (string.IsNullOrEmpty(e.DniUltimos3)) return null;
        return $"{origin}/he/{e.Slug}/horario";
    }

    private async Task CopiarLink(AdminEmpleadoDto e)
    {
        var origin = await JS.InvokeAsync<string>("eval", "window.location.origin");
        var url = BuildLinkPublico(e, origin);
        if (url is null)
        {
            ToastService.Error($"Falta cargar los últimos 3 del DNI de {e.Nombre}. Editalo primero.");
            return;
        }
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
        ToastService.Success($"Link de {e.Nombre} copiado");
    }

    private async Task MandarWhatsapp(AdminEmpleadoDto e)
    {
        var origin = await JS.InvokeAsync<string>("eval", "window.location.origin");
        var url = BuildLinkPublico(e, origin);
        if (url is null)
        {
            ToastService.Error($"Falta cargar los últimos 3 del DNI de {e.Nombre}. Editalo primero.");
            return;
        }
        var texto = Uri.EscapeDataString($"Hola {e.Nombre}! Te paso el link para cargar tus horas extras cada día:\n\n{url}\n\nCuando entres te va a pedir una clave de 3 dígitos: son los últimos 3 de tu DNI.\n\nGuardalo y entrá todos los días. Gracias!");
        await JS.InvokeVoidAsync("open", $"https://wa.me/?text={texto}", "_blank");
    }

}
