    private TypeInfo GetTypeInfo(FileEntryDto entry)
    {
        if (entry.IsFolder) return new("Carpeta", "fa-solid fa-folder", "#d97706", "#fffbeb");
        var ext = System.IO.Path.GetExtension(entry.Name);
        if (string.IsNullOrEmpty(ext)) return new("Archivo", "fa-solid fa-file", "#6b7280", "#f3f4f6");
        if (_typeMap.TryGetValue(ext, out var info)) return info;
        return new(ext.TrimStart('.').ToUpperInvariant(), "fa-solid fa-file", "#6b7280", "#f3f4f6");
    }

    private static string FormatSize(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int unit = 0;
        while (size >= 1024 && unit < units.Length - 1) { size /= 1024; unit++; }
        return $"{size:0.##} {units[unit]}";
    }

    private static string FormatRelative(DateTime dt)
    {
        var local = dt.ToLocalTime();
        var diff = DateTime.Now - local;
        if (diff.TotalMinutes < 1) return "Hace instantes";
        if (diff.TotalMinutes < 60) return $"Hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"Hace {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7) return $"Hace {(int)diff.TotalDays} d";
        return local.ToString("dd/MM/yyyy HH:mm");
    }
