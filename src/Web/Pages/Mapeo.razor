        finally { isLoading = false; }
    }

    private async Task RenderMap()
    {
        if (shipments is null) return;
        var list = new List<object>();
        if (startPoint?.Lat is not null && startPoint?.Lng is not null)
        {
            list.Add(new
            {
                id = -1,
                lat = startPoint.Lat,
                lng = startPoint.Lng,
                label = "🏠",
                color = "#15803d",
                popupHtml = $"<div style='font-size:0.85rem;'><strong>📍 Punto de partida</strong><br/>{System.Net.WebUtility.HtmlEncode(startPoint.Address ?? "")}</div>"
            });
        }
        // Set de shipment IDs que ya fueron importados como stops (origin=flex) — para no duplicar marcadores
        var shipmentsImportados = new HashSet<long>(
            (stops ?? new()).Where(s => s.Origin == "flex" && s.OriginRefId != null && long.TryParse(s.OriginRefId, out _))
                            .Select(s => long.Parse(s.OriginRefId!))
        );
        // Lista unificada cacheada para el render: se usa para saber si cada marker
        // está en la selección de ruta (rutaSeleccion) y mostrar el botón apropiado
        // en el popup (Sumar / Quitar).
        var listaUnificadaCacheada = BuildListaUnificada();
        // Si hay un filtro de vehículo activo (no es "Todos"), también ocultamos los shipments
        // (porque solo queremos ver los stops asignados a ese vehículo).
        var verShipments = vehiculoFiltro == null;
        if (verShipments)
        {
            list.AddRange(shipments.Where(s => s.Latitude.HasValue && s.Longitude.HasValue
                                            && !shipmentsImportados.Contains(s.MeliShipmentId)).Select((s, i) =>
            {
                var grupo = listaUnificadaCacheada?.FirstOrDefault(g => g.Flex.Any(f => f.Id == s.Id));
                var enRuta = grupo is not null && rutaSeleccion.Contains(grupo.Key);
                var btnBg = enRuta ? "#dc2626" : "#16a34a";
                var btnTxt = enRuta ? "✗ Quitar de ruta" : "✓ Sumar a ruta";
                var esMe1 = s.Mode == "me1";
                return (object)new
                {
                    id = s.Id,
                    lat = s.Latitude,
                    lng = s.Longitude,
                    // ME1: mismo estilo visual que las paradas pendientes (naranja con estrella).
                    // Flex: numerito secuencial (1, 2, 3...) y color según estado.
                    label = esMe1 ? "★" : (i + 1).ToString(),
                    color = esMe1 ? "#d97706" : ColorFor(EffectiveKey(s)),
                    // ME1 = cuadrado, Flex = círculo. Las paradas manuales/favoritos = triángulo (más abajo).
                    shape = esMe1 ? "square" : "circle",
                    // Flex: dimmed=true (blanco + borde negro). ME1: dimmed=false (naranja sólido con
                    // estrella) — el usuario quiere que se vea igual que las paradas pendientes,
                    // diferenciado SOLO por la forma cuadrada.
                    dimmed = !esMe1,
                    popupHtml = $"<div style='font-size:0.8rem; line-height:1.4;'><strong>{System.Net.WebUtility.HtmlEncode(s.ReceiverName ?? "—")}</strong>{(esMe1 ? " <span style='background:#fce7f3;color:#9d174d;padding:0 0.3rem;border-radius:3px;font-size:0.65rem;font-weight:800;'>ME1</span>" : "")}<br/>{System.Net.WebUtility.HtmlEncode(s.AddressLine ?? "")}<br/><em>{System.Net.WebUtility.HtmlEncode(s.City ?? "")}</em><br/><button onclick=\"window.mapeoActions.toggleRoute({s.Id}); event.stopPropagation();\" style='margin-top:0.3rem; padding:0.2rem 0.5rem; background:{btnBg}; color:white; border:none; border-radius:4px; font-size:0.72rem; font-weight:600; cursor:pointer;'>{btnTxt}</button></div>"
                };
            }));
        }
        // Stops (incluye los Flex importados + favoritos + manuales)
        // Si tienen driver asignado: color del driver y label = número de orden.
        // Si no: naranja con ★.
        if (stops is not null)
        {
            // Filtro de vehículo: null=todos, 0=sin asignar, >0=slot
            var stopsFiltrados = stops.Where(st =>
                vehiculoFiltro == null ||
                (vehiculoFiltro == 0 && !st.AssignedVehicleSlot.HasValue) ||
                (vehiculoFiltro > 0 && st.AssignedVehicleSlot == vehiculoFiltro));
            list.AddRange(stopsFiltrados.Select(st => {
                // Prioridad de color: 1) vehiculo asignado, 2) driver asignado, 3) naranja default
                string color = st.AssignedVehicleSlot.HasValue ? VehicleColor(st.AssignedVehicleSlot.Value)
                              : (string.IsNullOrEmpty(st.AssignedDriverColor) ? "#d97706" : st.AssignedDriverColor!);
                string label = st.OrderInRoute.HasValue ? st.OrderInRoute.Value.ToString()
                              : (st.AssignedVehicleSlot.HasValue ? "V" + st.AssignedVehicleSlot : "★");
                // Forma del marker: TRIÁNGULO si NO viene de Flex (favorito/manual/cliente-cafe/etc),
                // CÍRCULO si es un envío Flex importado. Así el operador distingue visualmente.
                string shape = st.Origin == "flex" ? "circle" : "triangle";
                var markerId = -1000 - st.Id;
                var grupoSt = listaUnificadaCacheada.FirstOrDefault(g => g.Manual.Any(m => m.Id == st.Id));
                var enRutaSt = grupoSt is not null && rutaSeleccion.Contains(grupoSt.Key);
                var btnBgSt = enRutaSt ? "#dc2626" : "#16a34a";
                var btnTxtSt = enRutaSt ? "✗ Quitar de ruta" : "✓ Sumar a ruta";
                return (object)new
                {
                    id = markerId,
                    lat = st.Latitude,
                    lng = st.Longitude,
                    label,
                    color,
                    shape,
                    popupHtml = $"<div style='font-size:0.8rem; line-height:1.4;'><strong>{System.Net.WebUtility.HtmlEncode(st.Alias ?? st.ContactName ?? "Parada")}</strong>{(st.AssignedVehicleSlot.HasValue ? $" <span style='color:{color}'>· V{st.AssignedVehicleSlot}</span>" : "")}{(st.AssignedDriverName is null ? "" : $" · {System.Net.WebUtility.HtmlEncode(st.AssignedDriverName)}")}<br/>{System.Net.WebUtility.HtmlEncode(st.Direccion)}{(string.IsNullOrEmpty(st.Telefono) ? "" : $"<br/>📞 {System.Net.WebUtility.HtmlEncode(st.Telefono)}")}<br/><button onclick=\"window.mapeoActions.toggleRoute({markerId}); event.stopPropagation();\" style='margin-top:0.3rem; padding:0.2rem 0.5rem; background:{btnBgSt}; color:white; border:none; border-radius:4px; font-size:0.72rem; font-weight:600; cursor:pointer;'>{btnTxtSt}</button></div>"
                };
            }));
        }
        await JS.InvokeVoidAsync("mapeoFlex.renderMarkers", new object[] { list.ToArray() });
    }

