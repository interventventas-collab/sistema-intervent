@page "/mapeo"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@implements IAsyncDisposable

<style>
    .mapeo-layout { display: grid; grid-template-columns: 360px 1fr; gap: 0.7rem; height: calc(100vh - 7rem); min-height: 480px; }
    .mapeo-side { background: white; border: 1px solid #e5e7eb; border-radius: 8px; display: flex; flex-direction: column; overflow: hidden; }
    .mapeo-side-header { padding: 0.6rem 0.7rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; }
    .mapeo-side-list { flex: 1; overflow-y: auto; padding: 0.3rem; }
    .mapeo-card { padding: 0.5rem 0.6rem; border: 1px solid transparent; border-radius: 6px; cursor: pointer; margin-bottom: 0.3rem; font-size: 0.78rem; }
    .mapeo-card:hover { background: #f0f9ff; border-color: #93c5fd; }
    .mapeo-card.activa { background: #dbeafe; border-color: #1d4ed8; }
    .mapeo-map { background: white; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }
    #leafletMap { width: 100%; height: 100%; }
    .mapeo-status-pill { display: inline-block; padding: 0.05rem 0.4rem; border-radius: 4px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; }
    .copy-chip { display: inline-flex; align-items: center; gap: 0.2rem; padding: 0.05rem 0.35rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 4px; cursor: pointer; transition: all 0.12s; }
    .copy-chip:hover { background: #dbeafe; border-color: #1d4ed8; color: #1d4ed8; }
    .copy-chip:active { background: #bfdbfe; transform: scale(0.97); }
</style>

<div class="card" style="margin-bottom: 0.5rem;">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3 style="margin:0;">🗺️ Mapeo — Envíos Flex</h3>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
            <select class="form-input" style="max-width:130px; font-size:0.85rem;" @bind="diasFiltro" @bind:after="LoadAndRender">
                <option value="1">Hoy</option>
                <option value="3">Últimos 3 días</option>
                <option value="7">Últimos 7 días</option>
                <option value="15">Últimos 15 días</option>
            </select>
            <select class="form-input" style="max-width:170px; font-size:0.85rem;" @bind="filtroInterno" @bind:after="LoadAndRender">
                <option value="">Estado: todos</option>
                <option value="pending">Pendiente</option>
                <option value="en_ruta">En ruta</option>
                <option value="entregado">Entregado</option>
                <option value="no_encontrado">No encontrado</option>
                <option value="reprogramado">Reprogramado</option>
            </select>
            <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.85rem;">
                <input type="checkbox" @bind="excluirEntregados" @bind:after="LoadAndRender" />
                Ocultar entregados/cancelados
            </label>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="LoadAndRender" disabled="@isLoading">
                @(isLoading ? "Cargando..." : "🔄 Refrescar lista")
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenStartPointModal" title="Configurar punto de partida del reparto">
                @(startPoint?.Lat.HasValue == true ? "📍 Punto de partida ✓" : "📍 Punto de partida")
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenDriversModal" title="Repartidores">
                👥 Repartidores (@(drivers?.Count ?? 0))
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenFavoritosModal" title="Direcciones favoritas">
                ⭐ Favoritos (@(favoritos?.Count ?? 0))
            </button>
            <button class="btn btn-primary" style="font-size:0.85rem;" @onclick="SyncFromMeli" disabled="@isSyncing">
                @(isSyncing ? "Sincronizando..." : "📥 Traer envíos de MeLi")
            </button>
        </div>
    </div>
</div>

<div class="mapeo-layout">
    <div class="mapeo-side">
        <div class="mapeo-side-header">
            <strong>@(shipments?.Count ?? 0) envíos</strong>
            <span style="font-size:0.72rem; color:#6b7280;">
                @(shipments?.Count(s => s.Latitude.HasValue && s.Longitude.HasValue) ?? 0) con geo
            </span>
        </div>
        <div class="mapeo-side-list">
            @if (isLoading) { <p class="text-muted" style="padding:0.7rem;">Cargando...</p> }
            else if (shipments is null || shipments.Count == 0)
            {
                <div style="padding:1rem; text-align:center; color:#6b7280;">
                    <div style="font-size:2rem;">📭</div>
                    Todavía no hay envíos cargados. Tocá <strong>"Traer envíos de MeLi"</strong>.
                </div>
            }
            else
            {
                @foreach (var s in shipments)
                {
                    var act = activeShipmentId == s.Id;
                    <div class="mapeo-card @(act ? "activa" : "")" @onclick="() => OnSelectFromList(s)">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.4rem;">
                            <strong>@(s.ReceiverName ?? "—")</strong>
                            <span class="mapeo-status-pill" style="@EffectiveStatusStyle(s)">@EffectiveStatusLabel(s)</span>
                        </div>
                        <div style="font-size:0.7rem; color:#6b7280; margin-top:0.1rem; display:flex; gap:0.4rem; flex-wrap:wrap;">
                            @if (!string.IsNullOrEmpty(s.BuyerNickname))
                            {
                                <span class="copy-chip" title="Click: copiar nickname"
                                      @onclick="@(e => CopyValue(s.BuyerNickname!, "Comprador"))" @onclick:stopPropagation="true">
                                    👤 <strong>@s.BuyerNickname</strong> 📋
                                </span>
                            }
                            @if (s.MeliOrderId.HasValue)
                            {
                                <span class="copy-chip" title="Click: copiar N° de venta" style="font-family:monospace;"
                                      @onclick="@(e => CopyValue(s.MeliOrderId.Value.ToString(), "N° venta"))" @onclick:stopPropagation="true">
                                    🧾 @s.MeliOrderId.Value 📋
                                </span>
                            }
                        </div>
                        <div style="color:#4b5563; margin-top:0.15rem;">@(s.AddressLine ?? "—")</div>
                        <div style="color:#6b7280; font-size:0.72rem; margin-top:0.1rem;">
                            @(s.City ?? "—") · CP @(s.ZipCode ?? "—")
                            @if (!string.IsNullOrEmpty(s.GeolocationType) && s.GeolocationType != "ROOFTOP")
                            { <span style="color:#d97706;"> · ⚠ geo @s.GeolocationType.ToLower()</span> }
                        </div>
                        @if (s.EstimatedDeliveryLimit.HasValue)
                        {
                            <div style="color:#6b7280; font-size:0.7rem; margin-top:0.1rem;">SLA: @s.EstimatedDeliveryLimit.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>
                        }
                    </div>
                }
            }
        </div>
    </div>
    <div class="mapeo-map">
        <div id="leafletMap"></div>
    </div>
</div>

@if (showDriversModal)
{
    <div class="modal-overlay" @onclick="() => showDriversModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:640px;">
            <div class="modal-header" style="background:#dbeafe;">
                <h3 style="margin:0;">👥 Repartidores</h3>
                <button class="btn-close" @onclick="() => showDriversModal = false">&times;</button>
            </div>
            <div class="modal-body">
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end; margin-bottom:0.7rem; padding:0.5rem; background:#f9fafb; border-radius:6px;">
                    <div class="form-group" style="flex:2;"><label class="form-label">Nombre *</label><input class="form-input" @bind="newDriverName" placeholder="Juan" /></div>
                    <div class="form-group" style="flex:1;"><label class="form-label">Tel</label><input class="form-input" @bind="newDriverPhone" placeholder="5491100000000" /></div>
                    <div class="form-group" style="flex:0 0 80px;"><label class="form-label">Color</label><input type="color" class="form-input" style="height:38px; padding:0.2rem;" @bind="newDriverColor" /></div>
                    <button class="btn btn-primary" @onclick="AddDriver" disabled="@(string.IsNullOrWhiteSpace(newDriverName))" style="height:38px;">+ Agregar</button>
                </div>
                @if (drivers is null || drivers.Count == 0)
                { <p style="text-align:center; color:#6b7280; padding:1rem;">No hay repartidores cargados todavía.</p> }
                else
                {
                    <table class="data-table" style="font-size:0.85rem;">
                        <thead><tr><th></th><th>Nombre</th><th>Tel</th><th>Activo</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var d in drivers)
                        {
                            <tr>
                                <td><input type="color" @bind="d.Color" style="width:30px; height:24px; border:none; padding:0;" /></td>
                                <td><input class="form-input" style="font-size:0.85rem; padding:0.2rem 0.4rem;" @bind="d.Nombre" /></td>
                                <td><input class="form-input" style="font-size:0.85rem; padding:0.2rem 0.4rem;" @bind="d.Telefono" /></td>
                                <td style="text-align:center;"><input type="checkbox" @bind="d.IsActive" /></td>
                                <td style="white-space:nowrap;">
                                    <button class="btn btn-secondary" style="font-size:0.75rem; padding:0.2rem 0.5rem;" @onclick="() => SaveDriver(d)">💾</button>
                                    <button class="btn btn-danger" style="font-size:0.75rem; padding:0.2rem 0.5rem;" @onclick="() => DeleteDriver(d)">🗑</button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDriversModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showFavoritosModal)
{
    <div class="modal-overlay" @onclick="() => showFavoritosModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:780px;">
            <div class="modal-header" style="background:#fef3c7;">
                <h3 style="margin:0;">⭐ Direcciones favoritas</h3>
                <button class="btn-close" @onclick="() => showFavoritosModal = false">&times;</button>
            </div>
            <div class="modal-body" style="max-height:65vh; overflow-y:auto;">
                <div style="background:#f9fafb; border:1px solid #e5e7eb; padding:0.6rem; border-radius:6px; margin-bottom:0.7rem;">
                    <strong style="font-size:0.85rem;">Agregar nueva dirección</strong>
                    <div class="form-group">
                        <label class="form-label">Alias (corto)</label>
                        <input class="form-input" @bind="newFavAlias" placeholder="Cafetería Don Pepe" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Buscar dirección</label>
                        <div style="display:flex; gap:0.4rem;">
                            <input class="form-input" @bind="newFavQuery" placeholder="Calle 123, Ciudad" @onkeydown="OnFavGeocodeKey" style="flex:1;" />
                            <button class="btn btn-secondary" @onclick="DoFavGeocode" disabled="@favGeocoding">@(favGeocoding ? "..." : "🔍")</button>
                        </div>
                    </div>
                    @if (favGeocodeResults is not null && favGeocodeResults.Count > 0)
                    {
                        <div style="border:1px solid #e5e7eb; border-radius:6px; max-height:120px; overflow-y:auto; margin-bottom:0.5rem;">
                            @foreach (var r in favGeocodeResults)
                            {
                                <div style="padding:0.3rem 0.5rem; border-bottom:1px solid #f3f4f6; cursor:pointer; font-size:0.78rem;"
                                     @onclick="() => PickFavGeocode(r)">@r.DisplayName</div>
                            }
                        </div>
                    }
                    @if (newFavLat != 0 || newFavLng != 0)
                    {
                        <div style="font-size:0.75rem; color:#15803d;">✓ @newFavDireccion (@newFavLat.ToString("0.####") , @newFavLng.ToString("0.####"))</div>
                    }
                    <div class="form-row" style="margin-top:0.4rem;">
                        <div class="form-group" style="flex:1;"><label class="form-label">Contacto</label><input class="form-input" @bind="newFavContact" placeholder="Pepe" /></div>
                        <div class="form-group" style="flex:1;"><label class="form-label">Tel</label><input class="form-input" @bind="newFavPhone" /></div>
                    </div>
                    <div class="form-group"><label class="form-label">Notas</label><input class="form-input" @bind="newFavNotas" placeholder="Tocar timbre 3 veces" /></div>
                    <button class="btn btn-primary" style="width:100%;" @onclick="AddFavorito" disabled="@(string.IsNullOrWhiteSpace(newFavAlias) || (newFavLat == 0 && newFavLng == 0))">+ Guardar favorito</button>
                </div>
                @if (favoritos is null || favoritos.Count == 0)
                { <p style="text-align:center; color:#6b7280; padding:1rem;">No hay favoritos cargados todavía.</p> }
                else
                {
                    @foreach (var f in favoritos)
                    {
                        <div style="border:1px solid #e5e7eb; padding:0.5rem 0.7rem; border-radius:6px; margin-bottom:0.4rem;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.4rem;">
                                <div>
                                    <strong>@f.Alias</strong> · <span style="font-size:0.78rem; color:#4b5563;">@f.Direccion</span>
                                    @if (!string.IsNullOrEmpty(f.ContactName) || !string.IsNullOrEmpty(f.Telefono))
                                    {
                                        <div style="font-size:0.75rem; color:#6b7280;">
                                            @if (!string.IsNullOrEmpty(f.ContactName)) { <span>👤 @f.ContactName</span> }
                                            @if (!string.IsNullOrEmpty(f.Telefono)) { <span> · 📞 @f.Telefono</span> }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(f.Notas))
                                    { <div style="font-size:0.72rem; color:#9ca3af;">📝 @f.Notas</div> }
                                </div>
                                <button class="btn btn-danger" style="font-size:0.75rem; padding:0.2rem 0.5rem;" @onclick="() => DeleteFavorito(f)">🗑</button>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showFavoritosModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showStartPointModal)
{
    <div class="modal-overlay" @onclick="CloseStartPointModal">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background:#dcfce7;">
                <h3 style="margin:0;">📍 Punto de partida</h3>
                <button class="btn-close" @onclick="CloseStartPointModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color:#6b7280; font-size:0.85rem; margin:0 0 0.5rem;">
                    Es el lugar desde donde salís a repartir. Aparece como casita verde 🏠 en el mapa para que veas la ruta desde ahí.
                </p>
                <div class="form-group">
                    <label class="form-label">Buscar dirección</label>
                    <div style="display:flex; gap:0.4rem;">
                        <input class="form-input" @bind="geocodeQuery" placeholder="Calle 123, Ciudad, Provincia" @onkeydown="OnGeocodeKey" style="flex:1;" />
                        <button class="btn btn-secondary" @onclick="DoGeocode" disabled="@geocoding">@(geocoding ? "..." : "🔍")</button>
                    </div>
                    <p style="font-size:0.7rem; color:#6b7280; margin:0.2rem 0 0;">Buscamos en OpenStreetMap (gratis, ~5 candidatos).</p>
                </div>
                @if (geocodeResults is not null && geocodeResults.Count > 0)
                {
                    <div style="border:1px solid #e5e7eb; border-radius:6px; max-height:160px; overflow-y:auto; margin-bottom:0.5rem;">
                        @foreach (var r in geocodeResults)
                        {
                            <div style="padding:0.4rem 0.6rem; border-bottom:1px solid #f3f4f6; cursor:pointer; font-size:0.8rem;"
                                 @onclick="() => PickGeocode(r)" title="Usar esta dirección">
                                <strong>@r.DisplayName</strong>
                                <div style="font-size:0.7rem; color:#9ca3af;">@r.Lat.ToString("0.######") , @r.Lng.ToString("0.######")</div>
                            </div>
                        }
                    </div>
                }
                <div class="form-group">
                    <label class="form-label">Dirección a guardar</label>
                    <input class="form-input" @bind="formStartAddress" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Latitud</label>
                        <input class="form-input" @bind="formStartLat" placeholder="-34.603722" />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Longitud</label>
                        <input class="form-input" @bind="formStartLng" placeholder="-58.381592" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="ClearStartPoint" disabled="@savingStartPoint">Borrar</button>
                <button class="btn btn-secondary" @onclick="CloseStartPointModal" disabled="@savingStartPoint">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveStartPoint" disabled="@savingStartPoint">
                    @(savingStartPoint ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@if (showDetail && selected is not null)
{
    <div class="modal-overlay" @onclick="() => showDetail = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin:0;">📦 Envío @selected.MeliShipmentId</h3>
                <button class="btn-close" @onclick="() => showDetail = false">&times;</button>
            </div>
            <div class="modal-body" style="font-size:0.88rem;">
                @if (selected.MeliOrderId.HasValue || !string.IsNullOrEmpty(selected.BuyerNickname))
                {
                    <div style="background:#f0f9ff; border:1px solid #bfdbfe; padding:0.4rem 0.6rem; border-radius:6px; margin-bottom:0.5rem; font-size:0.82rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
                        @if (!string.IsNullOrEmpty(selected.BuyerNickname))
                        {
                            <span class="copy-chip" title="Click: copiar nickname"
                                  @onclick="@(e => CopyValue(selected.BuyerNickname!, "Comprador"))">
                                👤 <strong>@selected.BuyerNickname</strong> 📋
                            </span>
                        }
                        @if (selected.MeliOrderId.HasValue)
                        {
                            <span class="copy-chip" title="Click: copiar N° de venta" style="font-family:monospace;"
                                  @onclick="@(e => CopyValue(selected.MeliOrderId.Value.ToString(), "N° venta"))">
                                🧾 <strong>@selected.MeliOrderId.Value</strong> 📋
                            </span>
                        }
                    </div>
                }
                <p><strong>@(selected.ReceiverName ?? "—")</strong></p>
                <p style="color:#4b5563; margin:0.2rem 0;">@selected.AddressLine</p>
                <p style="color:#6b7280; font-size:0.78rem; margin:0;">
                    @selected.Neighborhood @(string.IsNullOrEmpty(selected.Neighborhood) ? "" : "·") @selected.City · @selected.State · CP @selected.ZipCode
                </p>
                @if (!string.IsNullOrEmpty(selected.ReceiverPhone))
                {
                    var tel = selected.ReceiverPhone!;
                    var digits = new string(tel.Where(char.IsDigit).ToArray());
                    <p style="margin:0.4rem 0;"><strong>📞 Tel:</strong>
                        <a href="@($"https://wa.me/{digits}")" target="_blank" style="color:#25D366; font-weight:700;">@tel (WhatsApp)</a>
                    </p>
                }
                @if (!string.IsNullOrEmpty(selected.Comment))
                {
                    <p style="background:#fef3c7; border-left:3px solid #d97706; padding:0.4rem 0.6rem; margin:0.4rem 0; font-size:0.82rem;">
                        💬 <strong>Comentario del comprador:</strong> @selected.Comment
                    </p>
                }
                <p style="margin:0.4rem 0;"><strong>Items:</strong> @(selected.ItemsSummary ?? "—")</p>
                @if (selected.OrderTotal.HasValue)
                { <p style="margin:0.2rem 0;"><strong>Total:</strong> $@selected.OrderTotal.Value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</p> }
                <p style="margin:0.2rem 0;"><strong>Tracking:</strong> @(selected.TrackingNumber ?? "—")</p>
                <p style="margin:0.2rem 0;"><strong>Estado MeLi:</strong> @selected.Status / @(selected.Substatus ?? "—")</p>

                <hr style="margin:0.7rem 0;" />

                <div class="form-group">
                    <label class="form-label">Estado interno (lo controlas vos)</label>
                    <select class="form-input" @bind="selected.InternalStatus">
                        <option value="pending">Pendiente</option>
                        <option value="en_ruta">En ruta</option>
                        <option value="entregado">Entregado</option>
                        <option value="no_encontrado">No encontrado</option>
                        <option value="reprogramado">Reprogramado</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Notas internas</label>
                    <textarea class="form-input" rows="2" @bind="selected.Notes" placeholder="Ej: tocar timbre 3 veces, dejar en portería..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDetail = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarEstadoInterno" disabled="@isSavingDetail">
                    @(isSavingDetail ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<MeliShipmentDto>? shipments;
    private bool isLoading, isSyncing, isSavingDetail;
    private string diasFiltro = "7";
    private string filtroInterno = "";
    private bool excluirEntregados = false;
    private DotNetObjectReference<Mapeo>? selfRef;
    private bool mapInitialized;

    private MeliShipmentDto? selected;
    private bool showDetail;
    private int? activeShipmentId;

    // Punto de partida
    private StartPointDto? startPoint;
    private bool showStartPointModal, savingStartPoint, geocoding;
    private string formStartAddress = "", formStartLat = "", formStartLng = "";
    private string geocodeQuery = "";
    private List<GeocodeResultDto>? geocodeResults;

    // Drivers
    private List<MapeoDriverDto>? drivers;
    private bool showDriversModal;
    private string newDriverName = "", newDriverPhone = "", newDriverColor = "#1d4ed8";

    // Favoritos
    private List<MapeoFavoritoDto>? favoritos;
    private bool showFavoritosModal;
    private string newFavAlias = "", newFavQuery = "", newFavDireccion = "", newFavContact = "", newFavPhone = "", newFavNotas = "";
    private decimal newFavLat = 0m, newFavLng = 0m;
    private bool favGeocoding;
    private List<GeocodeResultDto>? favGeocodeResults;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mapeoFlex.init", "leafletMap", selfRef);
            mapInitialized = true;
            try { startPoint = await Api.GetMapeoStartPointAsync(); } catch { }
            await LoadDrivers();
            await LoadFavoritos();
            await LoadAndRender();
        }
    }

    private async Task LoadAndRender()
    {
        isLoading = true;
        try
        {
            int days = int.TryParse(diasFiltro, out var d) ? d : 7;
            shipments = await Api.GetMeliFlexShipmentsAsync(days, string.IsNullOrEmpty(filtroInterno) ? null : filtroInterno, excluirEntregados) ?? new();
            if (mapInitialized) await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isLoading = false; }
    }

    private async Task RenderMap()
    {
        if (shipments is null) return;
        var list = new List<object>();
        if (startPoint?.Lat is not null && startPoint?.Lng is not null)
        {
            list.Add(new
            {
                id = -1,
                lat = startPoint.Lat,
                lng = startPoint.Lng,
                label = "🏠",
                color = "#15803d",
                popupHtml = $"<div style='font-size:0.85rem;'><strong>📍 Punto de partida</strong><br/>{System.Net.WebUtility.HtmlEncode(startPoint.Address ?? "")}</div>"
            });
        }
        list.AddRange(shipments.Where(s => s.Latitude.HasValue && s.Longitude.HasValue).Select((s, i) => (object)new
        {
            id = s.Id,
            lat = s.Latitude,
            lng = s.Longitude,
            label = (i + 1).ToString(),
            color = ColorFor(EffectiveKey(s)),
            popupHtml = $"<div style='font-size:0.8rem;'><strong>{System.Net.WebUtility.HtmlEncode(s.ReceiverName ?? "—")}</strong><br/>{System.Net.WebUtility.HtmlEncode(s.AddressLine ?? "")}<br/><em>{System.Net.WebUtility.HtmlEncode(s.City ?? "")}</em></div>"
        }));
        await JS.InvokeVoidAsync("mapeoFlex.renderMarkers", new object[] { list.ToArray() });
    }

    private static string ColorFor(string s) => s switch
    {
        "en_ruta" => "#d97706",
        "entregado" => "#15803d",
        "no_encontrado" => "#b91c1c",
        "reprogramado" => "#7c3aed",
        "cancelled" => "#6b7280",
        _ => "#1d4ed8"
    };

    private static string StatusLabel(string s) => s switch
    {
        "en_ruta" => "En ruta",
        "entregado" => "Entregado",
        "no_encontrado" => "No encontró",
        "reprogramado" => "Reprogramado",
        "cancelled" => "Cancelado",
        _ => "Pendiente"
    };

    private static string StatusStyle(string s)
    {
        var c = ColorFor(s);
        return $"background:{c}33; color:{c};";
    }

    /// <summary>
    /// El estado "efectivo" combina lo que dice MeLi (delivered/cancelled gana sobre tu pending)
    /// con el estado interno que vos vas marcando manualmente.
    /// Asi una venta entregada en MeLi aparece como "Entregado" aunque vos no la hayas tocado.
    /// </summary>
    private static string EffectiveKey(MeliShipmentDto s)
    {
        if (string.Equals(s.Status, "delivered", StringComparison.OrdinalIgnoreCase)) return "entregado";
        if (string.Equals(s.Status, "cancelled", StringComparison.OrdinalIgnoreCase)) return "cancelled";
        // Si el usuario ya marcó algo (no es "pending"), respetamos su estado interno.
        if (!string.Equals(s.InternalStatus, "pending", StringComparison.OrdinalIgnoreCase)) return s.InternalStatus;
        return "pending";
    }
    private static string EffectiveStatusLabel(MeliShipmentDto s) => StatusLabel(EffectiveKey(s));
    private static string EffectiveStatusStyle(MeliShipmentDto s) => StatusStyle(EffectiveKey(s));

    private async Task OnSelectFromList(MeliShipmentDto s)
    {
        activeShipmentId = s.Id;
        selected = s;
        showDetail = true;
        if (s.Latitude.HasValue && s.Longitude.HasValue)
            await JS.InvokeVoidAsync("mapeoFlex.focusOn", (double)s.Latitude.Value, (double)s.Longitude.Value, 16);
    }

    [JSInvokable]
    public Task OnMarkerClicked(int id)
    {
        var s = shipments?.FirstOrDefault(x => x.Id == id);
        if (s is not null) { activeShipmentId = id; selected = s; showDetail = true; StateHasChanged(); }
        return Task.CompletedTask;
    }

    private async Task LoadDrivers() { try { drivers = await Api.GetMapeoDriversAsync() ?? new(); } catch { drivers = new(); } }
    private async Task LoadFavoritos() { try { favoritos = await Api.GetMapeoFavoritosAsync() ?? new(); } catch { favoritos = new(); } }

    private async Task OpenDriversModal() { await LoadDrivers(); showDriversModal = true; }
    private async Task OpenFavoritosModal() { await LoadFavoritos(); showFavoritosModal = true; }

    private async Task AddDriver()
    {
        if (string.IsNullOrWhiteSpace(newDriverName)) return;
        try
        {
            var d = await Api.CreateMapeoDriverAsync(newDriverName, string.IsNullOrWhiteSpace(newDriverPhone) ? null : newDriverPhone, newDriverColor);
            if (d is not null) { drivers ??= new(); drivers.Add(d); newDriverName = ""; newDriverPhone = ""; ToastService.Success("Repartidor agregado"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task SaveDriver(MapeoDriverDto d)
    {
        try
        {
            await Api.UpdateMapeoDriverAsync(d.Id, d.Nombre, d.Telefono, d.Color, d.IsActive);
            ToastService.Success("Guardado");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DeleteDriver(MapeoDriverDto d)
    {
        if (!await ConfirmAsync($"Eliminar al repartidor '{d.Nombre}'?")) return;
        try { if (await Api.DeleteMapeoDriverAsync(d.Id)) { drivers?.Remove(d); ToastService.Success("Eliminado"); } }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task OnFavGeocodeKey(KeyboardEventArgs e) { if (e.Key == "Enter") await DoFavGeocode(); }

    private async Task DoFavGeocode()
    {
        if (string.IsNullOrWhiteSpace(newFavQuery)) return;
        favGeocoding = true;
        try { favGeocodeResults = await Api.GeocodeAsync(newFavQuery) ?? new(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { favGeocoding = false; }
    }

    private void PickFavGeocode(GeocodeResultDto r)
    {
        newFavDireccion = r.DisplayName;
        newFavLat = r.Lat;
        newFavLng = r.Lng;
        favGeocodeResults = null;
    }

    private async Task AddFavorito()
    {
        if (string.IsNullOrWhiteSpace(newFavAlias) || (newFavLat == 0 && newFavLng == 0)) return;
        try
        {
            var dto = new MapeoFavoritoDto
            {
                Alias = newFavAlias.Trim(),
                Direccion = newFavDireccion,
                Latitude = newFavLat, Longitude = newFavLng,
                ContactName = string.IsNullOrWhiteSpace(newFavContact) ? null : newFavContact.Trim(),
                Telefono = string.IsNullOrWhiteSpace(newFavPhone) ? null : newFavPhone.Trim(),
                Notas = string.IsNullOrWhiteSpace(newFavNotas) ? null : newFavNotas.Trim()
            };
            var f = await Api.CreateMapeoFavoritoAsync(dto);
            if (f is not null)
            {
                favoritos ??= new(); favoritos.Insert(0, f);
                newFavAlias = ""; newFavQuery = ""; newFavDireccion = ""; newFavContact = ""; newFavPhone = ""; newFavNotas = "";
                newFavLat = 0; newFavLng = 0; favGeocodeResults = null;
                ToastService.Success("Favorito guardado");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DeleteFavorito(MapeoFavoritoDto f)
    {
        if (!await ConfirmAsync($"Eliminar '{f.Alias}'?")) return;
        try { if (await Api.DeleteMapeoFavoritoAsync(f.Id)) { favoritos?.Remove(f); ToastService.Success("Eliminado"); } }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private Task<bool> ConfirmAsync(string msg) => JS.InvokeAsync<bool>("confirm", msg).AsTask();

    private void OpenStartPointModal()
    {
        formStartAddress = startPoint?.Address ?? "";
        formStartLat = startPoint?.Lat?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        formStartLng = startPoint?.Lng?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        geocodeQuery = formStartAddress;
        geocodeResults = null;
        showStartPointModal = true;
    }
    private void CloseStartPointModal() { showStartPointModal = false; geocodeResults = null; }

    private async Task OnGeocodeKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoGeocode();
    }

    private async Task DoGeocode()
    {
        if (string.IsNullOrWhiteSpace(geocodeQuery)) return;
        geocoding = true;
        try
        {
            geocodeResults = await Api.GeocodeAsync(geocodeQuery) ?? new();
            if (geocodeResults.Count == 0) ToastService.Info("Sin resultados — probá ser más específico (calle, ciudad, provincia).");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { geocoding = false; }
    }

    private void PickGeocode(GeocodeResultDto r)
    {
        formStartAddress = r.DisplayName;
        formStartLat = r.Lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
        formStartLng = r.Lng.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private async Task SaveStartPoint()
    {
        decimal? lat = decimal.TryParse(formStartLat, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var la) ? la : null;
        decimal? lng = decimal.TryParse(formStartLng, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lo) ? lo : null;
        if (!lat.HasValue || !lng.HasValue) { ToastService.Error("Faltan latitud o longitud (buscá la dirección y elegí una opción)."); return; }
        savingStartPoint = true;
        try
        {
            var ok = await Api.SetMapeoStartPointAsync(formStartAddress, lat, lng);
            if (ok)
            {
                startPoint = new StartPointDto { Address = formStartAddress, Lat = lat, Lng = lng };
                ToastService.Success("Punto de partida guardado");
                showStartPointModal = false;
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { savingStartPoint = false; }
    }

    private async Task ClearStartPoint()
    {
        savingStartPoint = true;
        try
        {
            var ok = await Api.SetMapeoStartPointAsync(null, null, null);
            if (ok)
            {
                startPoint = new StartPointDto();
                ToastService.Success("Punto de partida borrado");
                showStartPointModal = false;
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { savingStartPoint = false; }
    }

    private async Task CopyValue(string value, string label)
    {
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", value);
            ToastService.Success($"{label} copiado: {value}");
