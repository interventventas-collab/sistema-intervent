    /// <summary>
    /// Invocado desde el botón "✓ Sumar a ruta" dentro del popup del marker del mapa.
    /// Encuentra el grupo unificado al que pertenece el marker (sea Flex o parada) y
    /// togglea su selección en la ruta de Google Maps. Después fuerza un re-render
    /// para que se vea el outline verde en la tarjeta correspondiente del panel lateral.
    /// </summary>
    [JSInvokable]
    public async Task ToggleMarkerInRoute(int markerId)
    {
        var lista = BuildListaUnificada();
        string? groupKey = null;
        if (markerId > -1000)
        {
            var s = shipments?.FirstOrDefault(x => x.Id == markerId);
            if (s is null) return;
            var grupo = lista.FirstOrDefault(g => g.Flex.Any(f => f.Id == s.Id));
            groupKey = grupo?.Key;
        }
        else
        {
            var stopId = -1000 - markerId;
            var st = stops?.FirstOrDefault(x => x.Id == stopId);
            if (st is null) return;
            var grupo = lista.FirstOrDefault(g => g.Manual.Any(m => m.Id == st.Id));
            groupKey = grupo?.Key;
        }
        if (groupKey is null) return;
        ToggleRutaSeleccion(groupKey);
        StateHasChanged();
        await Task.CompletedTask;
    }

    /// <summary>
    /// Click sobre un cluster (varias paradas apiladas en la misma coordenada).
    /// En modo asignación: asigna TODAS al V activo de un solo click.
    /// En modo orden: numera TODAS en secuencia (la primera con el próximo número, etc.).
    /// En modo normal: abre el detalle del primer Flex del grupo si lo hay.
    /// </summary>
    [JSInvokable]
    public async Task OnClusterClicked(int[] ids)
    {
        if (ids is null || ids.Length == 0) return;

        if (modoAsignacion)
        {
            assigningSlot = true;
            try
            {
                foreach (var id in ids)
                {
                    if (id > -1000) continue; // solo paradas (id negativo), no Flex puro
                    var stopId = -1000 - id;
                    var st = stops?.FirstOrDefault(x => x.Id == stopId);
                    if (st is null) continue;
                    // Asignación masiva: NO togglea, siempre asigna al V activo.
                    // Si la parada ya estaba en otro V, la mueve a este.
                    await Api.AssignVehicleSlotAsync(st.Id, vehiculoSeleccionado);
                    st.AssignedVehicleSlot = vehiculoSeleccionado;
                }
                await RenderMap();
                ToastService.Success($"{ids.Length} paradas asignadas al V{vehiculoSeleccionado}");
            }
            catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
            finally { assigningSlot = false; }
            return;
        }

        if (modoOrden)
        {
            // Numerar todas las paradas del V activo en secuencia. Las que no son del V activo
            // se saltan con un toast informativo.
            int salteadas = 0;
            foreach (var id in ids)
            {
                if (id > -1000) continue;
                var stopId = -1000 - id;
                var st = stops?.FirstOrDefault(x => x.Id == stopId);
                if (st is null) continue;
                if (st.AssignedVehicleSlot != ordenVehiculoSeleccionado) { salteadas++; continue; }
                if (st.OrderInRoute.HasValue) continue; // ya numerada, dejamos como está
                await OnMarkerOrden(st);
            }
            if (salteadas > 0) ToastService.Info($"{salteadas} paradas del cluster no son del V{ordenVehiculoSeleccionado} y se saltaron");
            return;
        }

        // Modo normal: si hay un Flex en el grupo, abrir su detalle
        var firstFlexId = ids.FirstOrDefault(id => id > -1000);
        if (firstFlexId > 0)
        {
            var s = shipments?.FirstOrDefault(x => x.Id == firstFlexId);
            if (s is not null) { activeShipmentId = firstFlexId; selected = s; showDetail = true; StateHasChanged(); }
        }
    }

    [JSInvokable]
    public async Task OnMarkerClicked(int id)
    {
        // En modo orden o modo asignación, los clicks NO deben abrir la ventana de detalle,
        // sino ejecutar la acción del modo (numerar / asignar). Bloqueamos el comportamiento
        // de "abrir popup" para que el usuario pueda trabajar sin que se interponga el panel.
        if (modoOrden)
        {
            if (id <= -1000)
            {
                var stopId = -1000 - id;
                var st = stops?.FirstOrDefault(x => x.Id == stopId);
                if (st is not null) await OnMarkerOrden(st);
            }
            else
            {
                ToastService.Info("Este envío no es una parada todavía. Importalo desde el paso 'Sumar Flex' para poder ordenarlo.");
            }
            return;
        }
        if (modoAsignacion)
        {
            if (id <= -1000)
            {
                var stopId = -1000 - id;
                var st = stops?.FirstOrDefault(x => x.Id == stopId);
                if (st is not null) await OnMarkerAssign(st);
            }
            return;
        }
        // Modo normal: click abre el panel de detalle del envío
        if (id <= -1000) return;
        var s = shipments?.FirstOrDefault(x => x.Id == id);
        if (s is not null) { activeShipmentId = id; selected = s; showDetail = true; StateHasChanged(); }
    }

