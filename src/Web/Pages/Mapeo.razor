    private async Task OpenSnapshotDetail(int id)
    {
        try
        {
            var raw = await Api.GetMapeoSnapshotDetailAsync(id);
            if (raw is null) return;
            // El endpoint devuelve {id, title, stopsCount, ..., stops: [...]}
            // Re-serializo para tener un objeto fuerte tipado.
            var json = System.Text.Json.JsonSerializer.Serialize(raw);
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;
            snapshotDetail = new SnapshotDetailVm
            {
                Id = root.GetProperty("id").GetInt32(),
                Title = root.GetProperty("title").GetString() ?? "",
                StopsCount = root.GetProperty("stopsCount").GetInt32(),
                VehiclesCount = root.GetProperty("vehiclesCount").GetInt32(),
                DriversCount = root.GetProperty("driversCount").GetInt32(),
                CreatedAt = root.GetProperty("createdAt").GetDateTime(),
                Stops = root.TryGetProperty("stops", out var stopsArr) && stopsArr.ValueKind == System.Text.Json.JsonValueKind.Array
                    ? stopsArr.EnumerateArray().Select(s => new SnapshotStopVm
                    {
                        Id = s.TryGetProperty("id", out var i) ? i.GetInt32() : 0,
                        Alias = s.TryGetProperty("alias", out var a) && a.ValueKind == System.Text.Json.JsonValueKind.String ? a.GetString() : null,
                        Direccion = s.TryGetProperty("direccion", out var d) ? d.GetString() ?? "" : "",
                        ContactName = s.TryGetProperty("contactName", out var c) && c.ValueKind == System.Text.Json.JsonValueKind.String ? c.GetString() : null,
                        InternalStatus = s.TryGetProperty("internalStatus", out var st) && st.ValueKind == System.Text.Json.JsonValueKind.String ? st.GetString() ?? "pending" : "pending",
                        AssignedDriverId = s.TryGetProperty("assignedDriverId", out var di) && di.ValueKind == System.Text.Json.JsonValueKind.Number ? di.GetInt32() : null,
                        AssignedDriverName = s.TryGetProperty("assignedDriverName", out var dn) && dn.ValueKind == System.Text.Json.JsonValueKind.String ? dn.GetString() : null,
                        AssignedVehicleSlot = s.TryGetProperty("assignedVehicleSlot", out var vs) && vs.ValueKind == System.Text.Json.JsonValueKind.Number ? vs.GetInt32() : null,
                        OrderInRoute = s.TryGetProperty("orderInRoute", out var or) && or.ValueKind == System.Text.Json.JsonValueKind.Number ? or.GetInt32() : null
                    }).ToList()
                    : new()
            };
            showSnapshotDetail = true;
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

