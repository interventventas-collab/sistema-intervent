    private async Task LoadAndRender()
    {
        isLoading = true;
        try
        {
            shipments = await Api.GetMeliFlexShipmentsAsync(diasFiltro, string.IsNullOrEmpty(filtroInterno) ? null : filtroInterno, excluirEntregados) ?? new();
