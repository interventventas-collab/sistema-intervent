@code {
    private List<MeliShipmentDto>? shipments;
    private bool isLoading, isSyncing, isSavingDetail;
    private string diasFiltro = "today";       // Default: ENTREGAR hoy
    private string filtroInterno = "pending";   // Default: solo PENDIENTES
    private bool excluirEntregados = true;      // Default: ocultar entregados/cancelados
    private DotNetObjectReference<Mapeo>? selfRef;
    private bool mapInitialized;

    private MeliShipmentDto? selected;
    private bool showDetail;
    private int? activeShipmentId;
    private int? activeStopId;

    // Multi-stop: selección de hasta 10 destinos para armar ruta en Google Maps.
    // Guardamos la "Key" del grupo unificado (cubre Flex y paradas manuales),
    // así una sola tarjeta = un solo waypoint sin importar de qué tipo sea.
    private HashSet<string> rutaSeleccion = new(StringComparer.Ordinal);

    // Filtro de zonas (chips): conjunto de zonas que el usuario ocultó. Vacío = todas visibles.
    private HashSet<string> zonasOcultas = new(StringComparer.Ordinal);

    private void ToggleZonaOculta(string zona)
    {
        if (zonasOcultas.Contains(zona)) zonasOcultas.Remove(zona);
        else zonasOcultas.Add(zona);
    }

    // ¿Todas las paradas son del día anterior (creadas antes de hoy 00:00 ART)?
    // Sirve para mostrar el banner "tenés paradas del día anterior".
    private bool HayParadasViejas
    {
        get
        {
            if (stops is null || stops.Count == 0) return false;
            var hoyArtUtc = DateTime.UtcNow.AddHours(-3).Date.AddHours(3); // 00:00 ART en UTC
            return stops.All(s => s.CreatedAt < hoyArtUtc);
        }
    }

    // ─── Lista unificada con dedup ───
    // Agrupa paradas adicionales + envíos Flex que apuntan al mismo destino
    // (mismo nombre + misma dirección, normalizado) en una sola tarjeta con "× N".
    private sealed class GrupoUnificado
    {
        public string Key { get; set; } = "";
        public string Zona { get; set; } = "";
        public List<MeliShipmentDto> Flex { get; set; } = new();
        public List<MapeoStopDto> Manual { get; set; } = new();
        // Cuenta los destinos únicos: las paradas con Origin="flex" representan al mismo
        // envío que ya está en Flex, así que NO las contamos dos veces.
        public int Count
        {
            get
            {
                var paradasFlex = Manual.Count(m => m.Origin == "flex");
                var paradasManuales = Manual.Count - paradasFlex;
                return Flex.Count + paradasManuales;
            }
        }
        public bool TieneFlex => Flex.Count > 0;
        public bool TieneManual => Manual.Count > 0;
        // Devuelve la parada (Origin=flex) que linkea con un Flex puntual, si existe.
        public MapeoStopDto? GetParadaFlex(long meliShipmentId) =>
            Manual.FirstOrDefault(m => m.Origin == "flex" && m.OriginRefId == meliShipmentId.ToString());
    }

    // Detecta cuando un texto de "dirección" es en realidad un par de coordenadas
    // escrito en formato local (ej. "(-34,7721, -58,423)" o "-34.7721,-58.423").
    // Google Maps no entiende coordenadas con coma decimal o entre paréntesis,
    // así que cuando esto pasa preferimos usar los campos Latitude/Longitude.
    private static bool ParecenCoordenadas(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return false;
        var t = s.Trim();
        if (t.StartsWith("(") && t.EndsWith(")")) return true;
        // Si la mayoría de los chars son dígitos / signos / separadores → es número, no calle
        int letras = t.Count(char.IsLetter);
        int digitos = t.Count(char.IsDigit);
        return letras == 0 && digitos >= 4;
    }

    private static string NormTxt(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "";
        var lower = s.Trim().ToLowerInvariant();
        var sb = new System.Text.StringBuilder(lower.Length);
        char prev = '\0';
        foreach (var c in lower)
        {
            if (char.IsLetterOrDigit(c) || c == ' ') { sb.Append(c); prev = c; }
            else if (prev != ' ') { sb.Append(' '); prev = ' '; }
        }
        return sb.ToString().Trim();
    }

    private List<GrupoUnificado> BuildListaUnificada()
    {
        var dict = new Dictionary<string, GrupoUnificado>(StringComparer.Ordinal);

        // Mapa: MeliShipmentId → key del grupo donde quedó la parada-flex.
        // Permite que el Flex original caiga en el MISMO grupo cuando ya fue importado,
        // así no aparece duplicado y conserva su info de Estado/SLA junto con la asignación.
        var paradaFlexGroupKey = new Dictionary<long, string>();

        if (stops is not null)
        {
            foreach (var st in stops)
            {
                var nombre = NormTxt(st.Alias ?? st.ContactName ?? "");
                var direc = NormTxt(st.Direccion);
                var key = "M|" + nombre + "|" + direc;
                if (!dict.TryGetValue(key, out var g))
                {
                    g = new GrupoUnificado { Key = key, Zona = string.IsNullOrWhiteSpace(st.Localidad) ? "(sin localidad)" : st.Localidad!.Trim() };
                    dict[key] = g;
                }
                g.Manual.Add(st);

                if (st.Origin == "flex" && !string.IsNullOrEmpty(st.OriginRefId)
                    && long.TryParse(st.OriginRefId, out var sid))
                {
                    paradaFlexGroupKey[sid] = key;
                }
            }
        }
        if (shipments is not null)
        {
            foreach (var s in shipments)
            {
                // Si este Flex ya fue importado como parada, lo agregamos al MISMO grupo
                // (no como duplicado): el grupo termina teniendo Flex + Manual con datos linkeados.
                if (paradaFlexGroupKey.TryGetValue(s.MeliShipmentId, out var existingKey))
                {
                    dict[existingKey].Flex.Add(s);
                    continue;
                }

                var nombre = NormTxt(s.ReceiverName ?? "");
                var direc = NormTxt(s.AddressLine ?? "");
                // Mismo nombre + dirección con paradas manuales → mismo grupo (cross-source dedup)
                var keyManual = "M|" + nombre + "|" + direc;
                var keyFlex = "F|" + nombre + "|" + direc;
                var key = dict.ContainsKey(keyManual) ? keyManual : keyFlex;
                if (!dict.TryGetValue(key, out var g))
                {
                    g = new GrupoUnificado { Key = key, Zona = string.IsNullOrWhiteSpace(s.City) ? "(sin localidad)" : s.City!.Trim() };
                    dict[key] = g;
                }
                g.Flex.Add(s);
            }
        }
        return dict.Values
            .OrderBy(g => g.Zona == "(sin localidad)" ? "ZZZ" : g.Zona)
            .ThenByDescending(g => g.TieneFlex)
            .ToList();
    }

    private async Task DeleteGrupoManual(GrupoUnificado g)
    {
        if (g.Manual.Count == 0) return;
        if (g.Manual.Count > 1)
        {
            var ok = await JS.InvokeAsync<bool>("confirm", $"Esta parada se repite {g.Manual.Count} veces. ¿Quitar TODAS?");
            if (!ok) return;
        }
        foreach (var st in g.Manual.ToList())
        {
            await DeleteStop(st);
        }
    }

