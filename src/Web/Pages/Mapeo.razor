    private static string AddrFromGroup(GrupoUnificado g)
    {
        // Estrategia: si tenemos coordenadas válidas, las preferimos — Google Maps NUNCA falla con
        // un par "lat,lng" y el formato path-based las acepta perfecto. Si no hay coords, usamos
        // la dirección de texto + localidad; si la localidad falta, sumamos "Buenos Aires, Argentina"
        // como contexto para que Google no devuelva resultados de otro país.
        const string CONTEXTO_DEFAULT = "Buenos Aires, Argentina";

        if (g.Flex.Count > 0)
        {
            var s = g.Flex.First();
            if (s.Latitude.HasValue && s.Longitude.HasValue && (s.Latitude.Value != 0 || s.Longitude.Value != 0))
            {
                var coord = $"{s.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)},{s.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
                return Uri.EscapeDataString(coord);
            }
            if (!string.IsNullOrWhiteSpace(s.AddressLine) && !ParecenCoordenadas(s.AddressLine))
            {
                var city = !string.IsNullOrWhiteSpace(s.City) ? s.City : CONTEXTO_DEFAULT;
                return Uri.EscapeDataString((s.AddressLine + ", " + city).Trim());
            }
            return Uri.EscapeDataString(s.City ?? CONTEXTO_DEFAULT);
        }
        else
        {
            var st = g.Manual.First();
            if (st.Latitude != 0 && st.Longitude != 0)
            {
                var coord = $"{st.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)},{st.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
                return Uri.EscapeDataString(coord);
            }
            if (!string.IsNullOrWhiteSpace(st.Direccion) && !ParecenCoordenadas(st.Direccion))
            {
                var loc = !string.IsNullOrWhiteSpace(st.Localidad) ? st.Localidad : CONTEXTO_DEFAULT;
                return Uri.EscapeDataString((st.Direccion + ", " + loc).Trim());
            }
            return Uri.EscapeDataString(st.Localidad ?? CONTEXTO_DEFAULT);
        }
    }

    /// <summary>
    /// Construye una "address string" lista para Google Maps a partir de una parada del Mapeo
    /// (no de un envío Flex). Usa coordenadas si las tiene; sino dirección + localidad; sino
    /// localidad sola o el contexto "Buenos Aires, Argentina" como fallback.
    /// </summary>
    private static string AddrFromStop(MapeoStopDto st)
    {
        const string CONTEXTO_DEFAULT = "Buenos Aires, Argentina";
        if (st.Latitude != 0 && st.Longitude != 0)
        {
            var coord = $"{st.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)},{st.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
            return Uri.EscapeDataString(coord);
        }
        if (!string.IsNullOrWhiteSpace(st.Direccion) && !ParecenCoordenadas(st.Direccion))
        {
            var loc = !string.IsNullOrWhiteSpace(st.Localidad) ? st.Localidad : CONTEXTO_DEFAULT;
            return Uri.EscapeDataString((st.Direccion + ", " + loc).Trim());
        }
        return Uri.EscapeDataString(st.Localidad ?? CONTEXTO_DEFAULT);
    }

    /// <summary>
    /// Devuelve la URL de Google Maps con LAS paradas de un chofer puntual, en el orden ya cargado
    /// (OrderInRoute ascendente, luego Id). Usa el formato path-based para no tener tope de 10.
    /// Si la URL queda muy larga (browser limit), la trunca a las primeras paradas que entren.
    /// </summary>
    private string BuildGmapsRouteUrlForDriver(int driverId)
    {
        if (stops is null) return "#";
        var driverStops = stops
            .Where(s => s.AssignedDriverId == driverId)
            .OrderBy(s => s.OrderInRoute ?? int.MaxValue)
            .ThenBy(s => s.Id)
            .ToList();
        if (driverStops.Count == 0) return "#";

        const int MAX_URL_LEN = 1800;
        const string BASE = "https://www.google.com/maps/dir/";
        var direcciones = driverStops.Select(AddrFromStop).ToList();
        var chunk = new List<string>();
        int len = BASE.Length;
        foreach (var d in direcciones)
        {
            int addLen = d.Length + 1;
            if (chunk.Count >= 2 && len + addLen > MAX_URL_LEN) break;
            chunk.Add(d);
            len += addLen;
        }
        return BASE + string.Join("/", chunk) + "/";
    }

    /// <summary>
    /// Arma la(s) URL(s) de ruta para Google Maps usando el formato "path-based"
    /// (https://www.google.com/maps/dir/A/B/C/...) que NO tiene tope de 10 paradas como el formato ?api=1.
    /// Si la URL resultante supera ~1800 chars (límite seguro de browsers), parte en TRAMOS
    /// encadenados — cada tramo arranca con la última parada del tramo anterior, así el chofer
    /// nunca pierde continuidad. Devuelve una lista de tramos con label legible y URL.
    /// </summary>
    private List<(string Label, string Url, int Desde, int Hasta)> BuildGmapsRouteTramos()
    {
        var tramos = new List<(string, string, int, int)>();
        if (rutaSeleccion.Count == 0) return tramos;
        var lista = BuildListaUnificada();
        var seleccionados = lista.Where(g => rutaSeleccion.Contains(g.Key)).ToList();
        if (seleccionados.Count == 0) return tramos;

        var direcciones = seleccionados.Select(AddrFromGroup).ToList();
        const int MAX_URL_LEN = 1800;
        const string BASE = "https://www.google.com/maps/dir/";

        int i = 0;
        int tramoNum = 1;
        while (i < direcciones.Count)
        {
            var chunk = new List<string>();
            int len = BASE.Length;
            int startIdx = i;
            while (i < direcciones.Count)
            {
                int addLen = direcciones[i].Length + 1; // + "/"
                if (chunk.Count >= 2 && len + addLen > MAX_URL_LEN) break;
                chunk.Add(direcciones[i]);
                len += addLen;
                i++;
            }
            if (chunk.Count == 0) break;
            var url = BASE + string.Join("/", chunk) + "/";
            int endIdx = startIdx + chunk.Count - 1;
            var label = direcciones.Count <= chunk.Count
                ? "🗺 Abrir ruta"
                : $"🗺 Tramo {tramoNum} ({startIdx + 1}–{endIdx + 1})";
            tramos.Add((label, url, startIdx + 1, endIdx + 1));
            tramoNum++;
            // Encadenar: si quedan paradas, retrocedo 1 para que el próximo tramo
            // arranque con la última de éste como origen.
            if (i < direcciones.Count) i--;
        }
        return tramos;
    }

