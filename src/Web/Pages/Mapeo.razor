    private async Task RenderMap()
    {
        if (shipments is null) return;
        var list = new List<object>();
        if (startPoint?.Lat is not null && startPoint?.Lng is not null)
        {
            list.Add(new
            {
                id = -1,
                lat = startPoint.Lat,
                lng = startPoint.Lng,
                label = "🏠",
                color = "#15803d",
                popupHtml = $"<div style='font-size:0.85rem;'><strong>📍 Punto de partida</strong><br/>{System.Net.WebUtility.HtmlEncode(startPoint.Address ?? "")}</div>"
            });
        }
        // Set de shipment IDs que ya fueron importados como stops (origin=flex) — para no duplicar marcadores
        var shipmentsImportados = new HashSet<long>(
            (stops ?? new()).Where(s => s.Origin == "flex" && s.OriginRefId != null && long.TryParse(s.OriginRefId, out _))
                            .Select(s => long.Parse(s.OriginRefId!))
        );
        // Si hay un filtro de vehículo activo (no es "Todos"), también ocultamos los shipments
        // (porque solo queremos ver los stops asignados a ese vehículo).
        var verShipments = vehiculoFiltro == null;
        if (verShipments)
        {
            list.AddRange(shipments.Where(s => s.Latitude.HasValue && s.Longitude.HasValue
                                            && !shipmentsImportados.Contains(s.MeliShipmentId)).Select((s, i) => (object)new
            {
                id = s.Id,
                lat = s.Latitude,
                lng = s.Longitude,
                label = (i + 1).ToString(),
                color = ColorFor(EffectiveKey(s)),
                popupHtml = $"<div style='font-size:0.8rem;'><strong>{System.Net.WebUtility.HtmlEncode(s.ReceiverName ?? "—")}</strong><br/>{System.Net.WebUtility.HtmlEncode(s.AddressLine ?? "")}<br/><em>{System.Net.WebUtility.HtmlEncode(s.City ?? "")}</em></div>"
            }));
        }
        // Stops (incluye los Flex importados + favoritos + manuales)
        // Si tienen driver asignado: color del driver y label = número de orden.
        // Si no: naranja con ★.
        if (stops is not null)
        {
            // Filtro de vehículo: null=todos, 0=sin asignar, >0=slot
            var stopsFiltrados = stops.Where(st =>
                vehiculoFiltro == null ||
                (vehiculoFiltro == 0 && !st.AssignedVehicleSlot.HasValue) ||
                (vehiculoFiltro > 0 && st.AssignedVehicleSlot == vehiculoFiltro));
            list.AddRange(stopsFiltrados.Select(st => {
                // Prioridad de color: 1) vehiculo asignado, 2) driver asignado, 3) naranja default
                string color = st.AssignedVehicleSlot.HasValue ? VehicleColor(st.AssignedVehicleSlot.Value)
                              : (string.IsNullOrEmpty(st.AssignedDriverColor) ? "#d97706" : st.AssignedDriverColor!);
                string label = st.OrderInRoute.HasValue ? st.OrderInRoute.Value.ToString()
                              : (st.AssignedVehicleSlot.HasValue ? "V" + st.AssignedVehicleSlot : "★");
                return (object)new
                {
                    id = -1000 - st.Id,
                    lat = st.Latitude,
                    lng = st.Longitude,
                    label,
                    color,
                    popupHtml = $"<div style='font-size:0.8rem;'><strong>{System.Net.WebUtility.HtmlEncode(st.Alias ?? st.ContactName ?? "Parada")}</strong>{(st.AssignedVehicleSlot.HasValue ? $" <span style='color:{color}'>· V{st.AssignedVehicleSlot}</span>" : "")}{(st.AssignedDriverName is null ? "" : $" · {System.Net.WebUtility.HtmlEncode(st.AssignedDriverName)}")}<br/>{System.Net.WebUtility.HtmlEncode(st.Direccion)}{(string.IsNullOrEmpty(st.Telefono) ? "" : $"<br/>📞 {System.Net.WebUtility.HtmlEncode(st.Telefono)}")}</div>"
                };
            }));
        }
        await JS.InvokeVoidAsync("mapeoFlex.renderMarkers", new object[] { list.ToArray() });
    }

