    /// <summary>
    /// Resalta el botón asociado al paso del stepper (efecto spotlight pulsante).
    /// El usuario click en un chip y ve "tocá ESE botón" sin texto largo.
    /// </summary>
    private async Task HighlightStep(int step)
    {
        // Mapeo step -> selector de boton:
        // 1 → "📥 Sumar Flex a paradas" (importacion + Flex)
        // 2 → "➕ Agregar parada" (sumar más manuales)
        // 3 → "🚚 Modo asignación"
        // 4 → "👤 Asignar choferes"
        // 5 → modal de asignar choferes (donde están los links)
        try
        {
            await JS.InvokeVoidAsync("eval", $@"
                (function() {{
                    var step = {step};
                    var labels = {{1:'Sumar Flex', 2:'Agregar parada', 3:'Modo asignación', 4:'Armar ruta', 5:'Armar ruta'}};
                    var label = labels[step];
                    var allBtns = document.querySelectorAll('button');
                    var target = null;
                    for (var i = 0; i < allBtns.length; i++) {{
                        if (allBtns[i].textContent.indexOf(label) >= 0) {{ target = allBtns[i]; break; }}
                    }}
                    if (target) {{
                        target.scrollIntoView({{ behavior: 'smooth', block: 'center' }});
                        target.classList.add('stepper-spotlight');
                        setTimeout(function() {{ target.classList.remove('stepper-spotlight'); }}, 4500);
                    }}
                }})();
            ");
        }
        catch { }
    }

