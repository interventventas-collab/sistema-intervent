    private async Task SyncFromMeli()
    {
        isSyncing = true;
        try
        {
            int days = int.TryParse(diasFiltro, out var d) ? d : 7;
            var r = await Api.SyncMeliFlexShipmentsAsync(days, 200);
            if (r is not null)
            {
                ToastService.Success($"Sincronizados {r.TotalFlex} Flex (de {r.TotalSynced} envíos)");
                await LoadAndRender();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isSyncing = false; }
    }

    private async Task GuardarEstadoInterno()
    {
        if (selected is null) return;
        isSavingDetail = true;
        try
        {
            var ok = await Api.UpdateMeliShipmentInternalStatusAsync(selected.Id, selected.InternalStatus, selected.Notes);
            if (ok) { ToastService.Success("Estado actualizado"); showDetail = false; await RenderMap(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isSavingDetail = false; }
    }

