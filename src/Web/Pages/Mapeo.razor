    private async Task SyncFromMeli()
    {
        isSyncing = true;
        try
        {
            int days = int.TryParse(diasFiltro, out var d) ? d : 7;
            // Sincronizamos Flex y ME1 EN PARALELO contra MeLi. Asi en un solo click el usuario
            // se asegura de tener al dia todos los envios que va a tener que entregar.
            var taskFlex = Api.SyncMeliFlexShipmentsAsync(days, 200);
            var taskMe1 = Api.SyncMeliMe1ShipmentsAsync(30, 300);
            await Task.WhenAll(taskFlex, taskMe1);
            var rFlex = taskFlex.Result;
            var rMe1 = taskMe1.Result;
            int flex = rFlex?.TotalFlex ?? 0;
            int me1 = rMe1?.TotalMe1 ?? 0;
            ToastService.Success($"Sincronizados: {flex} Flex · {me1} ME1");
            await LoadAndRender();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isSyncing = false; }
    }

