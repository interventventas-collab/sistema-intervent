    private async Task SaveStartPoint()
    {
        decimal? lat = decimal.TryParse(formStartLat, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var la) ? la : null;
        decimal? lng = decimal.TryParse(formStartLng, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lo) ? lo : null;
        if (!lat.HasValue || !lng.HasValue) { ToastService.Error("Faltan latitud o longitud (buscá la dirección y elegí una opción)."); return; }
        savingStartPoint = true;
        try
        {
            var ok = await Api.SetMapeoStartPointAsync(formStartAddress, lat, lng);
            if (ok)
            {
                startPoint = new StartPointDto { Address = formStartAddress, Lat = lat, Lng = lng };
                ToastService.Success("Punto de partida guardado");
                showStartPointModal = false;
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { savingStartPoint = false; }
    }

