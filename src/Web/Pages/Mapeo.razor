    /// <summary>
    /// Mueve una parada arriba (delta=-1) o abajo (delta=+1) dentro del mismo driver.
    /// Reordena toda la lista del driver y persiste los nuevos OrderInRoute.
    /// </summary>
    private async Task MoveStop(List<MapeoStopDto> sortedList, int idx, int delta)
    {
        var newIdx = idx + delta;
        if (newIdx < 0 || newIdx >= sortedList.Count) return;
        // Swap in memory
        var tmp = sortedList[idx];
        sortedList[idx] = sortedList[newIdx];
        sortedList[newIdx] = tmp;
        // Renumerar 1..N en orden actual
        routeBusy = true;
        try
        {
            for (int i = 0; i < sortedList.Count; i++)
            {
                var s = sortedList[i];
                int nuevoOrden = i + 1;
                if (s.OrderInRoute != nuevoOrden)
                {
                    s.OrderInRoute = nuevoOrden;
                    await Api.UpdateMapeoStopAsync(s.Id, new { orderInRoute = nuevoOrden });
                }
            }
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { routeBusy = false; }
    }

