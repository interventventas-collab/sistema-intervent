    private async Task AddStopFromCliente(CafeClienteDto cli)
    {
        if (!cli.MapeoLat.HasValue || !cli.MapeoLng.HasValue)
        {
            ToastService.Error("Este cliente no tiene coordenadas extraídas todavía. Editalo en Café → Clientes y apretá '🔄 Re-extraer'.");
            return;
        }
        try
        {
            var alias = cli.CodigoInterno.HasValue ? $"#{cli.CodigoInterno} · {cli.Nombre}" : cli.Nombre;
            // Prioridad para la dirección que va al mapeo:
            //   1) DomicilioEntrega (el operador lo carga cuando difiere del fiscal — caso típico)
            //   2) Direccion fiscal + Localidad
            //   3) Coords como string si no hay nada
            string direccion;
            if (!string.IsNullOrWhiteSpace(cli.DomicilioEntrega))
            {
                direccion = cli.DomicilioEntrega!.Trim();
            }
            else if (!string.IsNullOrEmpty(cli.Direccion))
            {
                direccion = string.IsNullOrEmpty(cli.Localidad) ? cli.Direccion : $"{cli.Direccion}, {cli.Localidad}";
            }
            else
            {
                direccion = $"({cli.MapeoLat?.ToString("0.####")}, {cli.MapeoLng?.ToString("0.####")})";
            }
            var s = await Api.CreateMapeoStopAsync(
                "cliente-cafe",
                cli.Id.ToString(),
                alias,
                direccion,
                cli.MapeoLat.Value,
                cli.MapeoLng.Value,
                null, cli.Telefono, null);
            if (s is not null) { stops!.Insert(0, s); ToastService.Success($"'{alias}' agregado al mapa"); await RenderMap(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }
