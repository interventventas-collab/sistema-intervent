@page "/mapeo"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@implements IAsyncDisposable

<style>
    .mapeo-layout { display: grid; grid-template-columns: 360px 1fr; gap: 0.7rem; height: calc(100vh - 7rem); min-height: 480px; }
    .mapeo-side { background: white; border: 1px solid #e5e7eb; border-radius: 8px; display: flex; flex-direction: column; overflow: hidden; }
    .mapeo-side-header { padding: 0.6rem 0.7rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; }
    .mapeo-side-list { flex: 1; overflow-y: auto; padding: 0.3rem; }
    .mapeo-card { padding: 0.5rem 0.6rem; border: 1px solid transparent; border-radius: 6px; cursor: pointer; margin-bottom: 0.3rem; font-size: 0.78rem; }
    .mapeo-card:hover { background: #f0f9ff; border-color: #93c5fd; }
    .mapeo-card.activa { background: #dbeafe; border-color: #1d4ed8; }
    .mapeo-map { background: white; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }
    #leafletMap { width: 100%; height: 100%; }
    .mapeo-status-pill { display: inline-block; padding: 0.05rem 0.4rem; border-radius: 4px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; }
    .copy-chip { display: inline-flex; align-items: center; gap: 0.2rem; padding: 0.05rem 0.35rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 4px; cursor: pointer; transition: all 0.12s; }
    .copy-chip:hover { background: #dbeafe; border-color: #1d4ed8; color: #1d4ed8; }
    .copy-chip:active { background: #bfdbfe; transform: scale(0.97); }
</style>

<div class="card" style="margin-bottom: 0.5rem;">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <h3 style="margin:0;">🗺️ Mapeo — Envíos Flex</h3>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
            <select class="form-input" style="max-width:130px; font-size:0.85rem;" @bind="diasFiltro" @bind:after="LoadAndRender">
                <option value="1">Hoy</option>
                <option value="3">Últimos 3 días</option>
                <option value="7">Últimos 7 días</option>
                <option value="15">Últimos 15 días</option>
            </select>
            <select class="form-input" style="max-width:170px; font-size:0.85rem;" @bind="filtroInterno" @bind:after="LoadAndRender">
                <option value="">Estado: todos</option>
                <option value="pending">Pendiente</option>
                <option value="en_ruta">En ruta</option>
                <option value="entregado">Entregado</option>
                <option value="no_encontrado">No encontrado</option>
                <option value="reprogramado">Reprogramado</option>
            </select>
            <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.85rem;">
                <input type="checkbox" @bind="excluirEntregados" @bind:after="LoadAndRender" />
                Ocultar entregados/cancelados
            </label>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="LoadAndRender" disabled="@isLoading">
                @(isLoading ? "Cargando..." : "🔄 Refrescar lista")
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenStartPointModal" title="Configurar punto de partida del reparto">
                @(startPoint?.Lat.HasValue == true ? "📍 Punto de partida ✓" : "📍 Punto de partida")
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenDriversModal" title="Repartidores">
                👥 Repartidores (@(drivers?.Count ?? 0))
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenFavoritosModal" title="Direcciones favoritas">
                ⭐ Favoritos (@(favoritos?.Count ?? 0))
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="OpenAddStopModal" title="Agregar parada al mapa (favorito o manual)">
                ➕ Agregar parada
            </button>
            <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="ImportFlexAsStops" disabled="@importingFlex" title="Trae los Flex pendientes a la lista de paradas para asignarles repartidor">
                @(importingFlex ? "..." : "📥 Sumar Flex a paradas")
            </button>
            <button class="btn btn-primary" style="font-size:0.85rem;" @onclick="OpenArmarRutaModal" title="Asignar paradas a repartidores y optimizar orden">
                📋 Armar ruta
            </button>
            <button class="btn btn-primary" style="font-size:0.85rem;" @onclick="SyncFromMeli" disabled="@isSyncing">
                @(isSyncing ? "Sincronizando..." : "📥 Traer envíos de MeLi")
            </button>
        </div>
    </div>
</div>

<div class="mapeo-layout">
    <div class="mapeo-side">
        <div class="mapeo-side-header" style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <strong>@(shipments?.Count ?? 0) Flex</strong>
                <span style="color:#9ca3af;">·</span>
                <strong>@(stops?.Count ?? 0) paradas</strong>
            </div>
            <span style="font-size:0.72rem; color:#6b7280;">
                @(shipments?.Count(s => s.Latitude.HasValue && s.Longitude.HasValue) ?? 0) + @(stops?.Count ?? 0) en mapa
            </span>
        </div>
        <div class="mapeo-side-list">
            @if (isLoading) { <p class="text-muted" style="padding:0.7rem;">Cargando...</p> }
            else if (shipments is null || shipments.Count == 0)
            {
                <div style="padding:1rem; text-align:center; color:#6b7280;">
                    <div style="font-size:2rem;">📭</div>
                    Todavía no hay envíos cargados. Tocá <strong>"Traer envíos de MeLi"</strong>.
                </div>
            }
            else
            {
                @if (stops is not null && stops.Count > 0)
                {
                    <div style="padding:0.4rem 0.6rem; background:#fef3c7; border-bottom:1px solid #fde68a; font-size:0.72rem; font-weight:700; color:#92400e; text-transform:uppercase;">
                        ⭐ Paradas adicionales (@stops.Count)
                    </div>
                    @foreach (var st in stops)
                    {
                        <div class="mapeo-card" style="border-left:3px solid #d97706;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.4rem;">
                                <strong>@(st.Alias ?? st.ContactName ?? "Parada")</strong>
                                <button class="btn-icon btn-delete" style="font-size:0.7rem;" @onclick="() => DeleteStop(st)" title="Quitar">×</button>
                            </div>
                            <div style="color:#4b5563; margin-top:0.15rem;">@st.Direccion</div>
                            @if (!string.IsNullOrEmpty(st.Telefono))
                            { <div style="font-size:0.72rem; color:#6b7280;">📞 @st.Telefono</div> }
                            @if (!string.IsNullOrEmpty(st.Notas))
                            { <div style="font-size:0.7rem; color:#9ca3af;">📝 @st.Notas</div> }
                        </div>
                    }
                    <div style="padding:0.4rem 0.6rem; background:#dbeafe; border-bottom:1px solid #93c5fd; font-size:0.72rem; font-weight:700; color:#1e40af; text-transform:uppercase; margin-top:0.3rem;">
                        📦 Envíos Flex (@shipments.Count)
                    </div>
                }
                @foreach (var s in shipments)
                {
                    var act = activeShipmentId == s.Id;
                    <div class="mapeo-card @(act ? "activa" : "")" @onclick="() => OnSelectFromList(s)">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.4rem;">
                            <strong>@(s.ReceiverName ?? "—")</strong>
                            <span class="mapeo-status-pill" style="@EffectiveStatusStyle(s)">@EffectiveStatusLabel(s)</span>
                        </div>
                        <div style="font-size:0.7rem; color:#6b7280; margin-top:0.1rem; display:flex; gap:0.4rem; flex-wrap:wrap;">
                            @if (!string.IsNullOrEmpty(s.BuyerNickname))
                            {
                                <span class="copy-chip" title="Click: copiar nickname"
                                      @onclick="@(e => CopyValue(s.BuyerNickname!, "Comprador"))" @onclick:stopPropagation="true">
                                    👤 <strong>@s.BuyerNickname</strong> 📋
                                </span>
                            }
                            @if (s.MeliOrderId.HasValue)
                            {
                                <span class="copy-chip" title="Click: copiar N° de venta" style="font-family:monospace;"
                                      @onclick="@(e => CopyValue(s.MeliOrderId.Value.ToString(), "N° venta"))" @onclick:stopPropagation="true">
                                    🧾 @s.MeliOrderId.Value 📋
                                </span>
                            }
                        </div>
                        <div style="color:#4b5563; margin-top:0.15rem;">@(s.AddressLine ?? "—")</div>
                        <div style="color:#6b7280; font-size:0.72rem; margin-top:0.1rem;">
                            @(s.City ?? "—") · CP @(s.ZipCode ?? "—")
                            @if (!string.IsNullOrEmpty(s.GeolocationType) && s.GeolocationType != "ROOFTOP")
                            { <span style="color:#d97706;"> · ⚠ geo @s.GeolocationType.ToLower()</span> }
                        </div>
                        @if (s.EstimatedDeliveryLimit.HasValue)
                        {
                            <div style="color:#6b7280; font-size:0.7rem; margin-top:0.1rem;">SLA: @s.EstimatedDeliveryLimit.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>
                        }
                    </div>
                }
            }
        </div>
    </div>
    <div class="mapeo-map">
        <div id="leafletMap"></div>
    </div>
</div>

@if (showArmarRutaModal)
{
    <div class="modal-overlay" @onclick="() => showArmarRutaModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:1100px; max-height:92vh; display:flex; flex-direction:column;">
            <div class="modal-header" style="background:#dbeafe;">
                <h3 style="margin:0;">📋 Armar ruta — @(stops?.Count ?? 0) paradas · @(drivers?.Count(d => d.IsActive) ?? 0) repartidores</h3>
                <button class="btn-close" @onclick="() => showArmarRutaModal = false">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y:auto;">
                @if ((drivers?.Count(d => d.IsActive) ?? 0) == 0)
                {
                    <div style="background:#fee2e2; border-left:3px solid #b91c1c; padding:0.7rem; margin-bottom:0.7rem; font-size:0.9rem;">
                        ⚠ No tenés repartidores activos. Andá a <strong>👥 Repartidores</strong> arriba y agregá al menos uno.
                    </div>
                }
                else if ((stops?.Count ?? 0) == 0)
                {
                    <div style="background:#fef3c7; border-left:3px solid #d97706; padding:0.7rem; margin-bottom:0.7rem; font-size:0.9rem;">
                        ⚠ No hay paradas. Tocá <strong>📥 Sumar Flex a paradas</strong> o <strong>➕ Agregar parada</strong> arriba.
                    </div>
                }
                else
                {
                    <div style="display:flex; gap:0.4rem; flex-wrap:wrap; margin-bottom:0.8rem; padding:0.5rem; background:#f9fafb; border-radius:6px;">
                        <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="DoAutoAssign" disabled="@routeBusy" title="Reparte las paradas SIN driver entre los repartidores activos por cercanía geográfica (k-means)">
                            @(routeBusy ? "..." : "🧠 Repartir auto (sin asignar)")
                        </button>
                        <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="DoAutoAssignAll" disabled="@routeBusy" title="Reasigna TODAS las paradas (incluso las que ya tenían driver)">
                            🔄 Reasignar todas
                        </button>
                        <button class="btn btn-secondary" style="font-size:0.85rem;" @onclick="DoOptimizeAll" disabled="@routeBusy" title="Calcula el mejor orden por driver desde tu punto de partida (nearest-neighbor)">
                            ⚡ Optimizar orden
                        </button>
                        <button class="btn btn-secondary" style="font-size:0.85rem; color:#b91c1c;" @onclick="DoUnassignAll" disabled="@routeBusy" title="Quita todas las asignaciones">
                            🗑 Limpiar
                        </button>
                    </div>

                    @foreach (var g in stops!.GroupBy(s => s.AssignedDriverId).OrderBy(g => g.Key.HasValue ? 0 : 1).ThenBy(g => g.Key))
                    {
                        var driver = g.Key.HasValue ? drivers!.FirstOrDefault(d => d.Id == g.Key.Value) : null;
                        var headerColor = driver?.Color ?? "#9ca3af";
                        var headerLabel = driver?.Nombre ?? "🚫 Sin asignar";
                        <div style="margin-bottom:0.7rem; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden;">
                            <div style="padding:0.5rem 0.7rem; background:@(headerColor)22; border-bottom:1px solid @headerColor; display:flex; justify-content:space-between; align-items:center;">
                                <strong style="color:@headerColor;">@headerLabel · @g.Count() parada(s)</strong>
                                @if (driver is not null)
                                {
                                    <button class="btn btn-secondary" style="font-size:0.72rem; padding:0.15rem 0.4rem;" @onclick="() => DoOptimizeDriver(driver.Id)" disabled="@routeBusy" title="Optimizar solo este driver">⚡</button>
                                }
                            </div>
                            <table class="data-table" style="font-size:0.8rem; margin:0;">
                                <thead><tr><th style="width:60px;">Orden</th><th>Parada</th><th>Dirección</th><th style="width:170px;">Repartidor</th></tr></thead>
                                <tbody>
                                @foreach (var s in g.OrderBy(x => x.OrderInRoute ?? int.MaxValue).ThenBy(x => x.Id))
                                {
                                    <tr>
                                        <td style="text-align:center; font-weight:700; font-size:0.95rem; color:@headerColor;">@(s.OrderInRoute?.ToString() ?? "—")</td>
                                        <td>
                                            <strong>@(s.Alias ?? s.ContactName ?? "Parada")</strong>
                                            <div style="font-size:0.7rem; color:#9ca3af;">@OriginLabel(s.Origin)</div>
                                        </td>
                                        <td style="font-size:0.78rem;">@s.Direccion</td>
                                        <td>
                                            <select class="form-input" style="font-size:0.78rem; padding:0.15rem 0.3rem;"
                                                    value="@(s.AssignedDriverId?.ToString() ?? "")"
                                                    @onchange="@(e => OnAssignDriver(s, e.Value?.ToString()))">
                                                <option value="">— Sin asignar —</option>
                                                @foreach (var d in drivers!.Where(x => x.IsActive))
                                                {
                                                    <option value="@d.Id" selected="@(s.AssignedDriverId == d.Id)">@d.Nombre</option>
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showArmarRutaModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showAddStopModal)
{
    <div class="modal-overlay" @onclick="() => showAddStopModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:620px;">
            <div class="modal-header" style="background:#fef3c7;">
                <h3 style="margin:0;">➕ Agregar parada al mapa</h3>
                <button class="btn-close" @onclick="() => showAddStopModal = false">&times;</button>
            </div>
            <div class="modal-body">
                <div style="display:flex; gap:0.4rem; margin-bottom:0.7rem;">
                    <button class="btn @(addStopTab == "favorito" ? "btn-primary" : "btn-secondary")" style="flex:1;" @onclick="@(() => addStopTab = "favorito")">⭐ Desde favoritos</button>
                    <button class="btn @(addStopTab == "manual" ? "btn-primary" : "btn-secondary")" style="flex:1;" @onclick="@(() => addStopTab = "manual")">✏️ Tipear nueva</button>
                </div>
                @if (addStopTab == "favorito")
                {
                    @if (favoritos is null || favoritos.Count == 0)
                    {
                        <p style="text-align:center; color:#6b7280; padding:1rem;">No tenés favoritos. Tocá ⭐ Favoritos arriba para crearlos.</p>
                    }
                    else
                    {
                        <input class="form-input" @bind="addStopFavSearch" @bind:event="oninput" placeholder="Buscar..." style="margin-bottom:0.5rem;" />
                        <div style="max-height:340px; overflow-y:auto;">
                            @foreach (var f in favoritos.Where(x => string.IsNullOrEmpty(addStopFavSearch)
                                || x.Alias.Contains(addStopFavSearch, StringComparison.OrdinalIgnoreCase)
                                || x.Direccion.Contains(addStopFavSearch, StringComparison.OrdinalIgnoreCase)))
                            {
                                <div style="border:1px solid #e5e7eb; padding:0.5rem 0.7rem; border-radius:6px; margin-bottom:0.3rem; cursor:pointer;"
                                     @onclick="() => AddStopFromFavorito(f)" title="Click para agregar al mapa">
                                    <strong>@f.Alias</strong>
                                    <div style="font-size:0.78rem; color:#4b5563;">@f.Direccion</div>
                                    @if (!string.IsNullOrEmpty(f.Telefono))
                                    { <div style="font-size:0.7rem; color:#6b7280;">📞 @f.Telefono</div> }
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="form-group">
                        <label class="form-label">Buscar dirección</label>
                        <div style="display:flex; gap:0.4rem;">
                            <input class="form-input" @bind="addStopQuery" placeholder="Calle 123, Ciudad" @onkeydown="OnAddStopGeocodeKey" style="flex:1;" />
                            <button class="btn btn-secondary" @onclick="DoAddStopGeocode" disabled="@addStopGeocoding">@(addStopGeocoding ? "..." : "🔍")</button>
                        </div>
                    </div>
                    @if (addStopGeocodeResults is not null && addStopGeocodeResults.Count > 0)
                    {
                        <div style="border:1px solid #e5e7eb; border-radius:6px; max-height:140px; overflow-y:auto; margin-bottom:0.5rem;">
                            @foreach (var r in addStopGeocodeResults)
                            {
                                <div style="padding:0.3rem 0.5rem; border-bottom:1px solid #f3f4f6; cursor:pointer; font-size:0.78rem;"
                                     @onclick="() => PickAddStopGeocode(r)">@r.DisplayName</div>
                            }
                        </div>
                    }
                    @if (addStopLat != 0 || addStopLng != 0)
                    {
                        <div style="font-size:0.75rem; color:#15803d; margin-bottom:0.4rem;">✓ @addStopDireccion (@addStopLat.ToString("0.####") , @addStopLng.ToString("0.####"))</div>
                    }
                    <div class="form-group"><label class="form-label">Alias / Cliente</label><input class="form-input" @bind="addStopAlias" placeholder="Bar Don Pepe" /></div>
                    <div class="form-row">
                        <div class="form-group" style="flex:1;"><label class="form-label">Contacto</label><input class="form-input" @bind="addStopContact" placeholder="Pepe" /></div>
                        <div class="form-group" style="flex:1;"><label class="form-label">Tel</label><input class="form-input" @bind="addStopPhone" /></div>
                    </div>
                    <div class="form-group"><label class="form-label">Notas (instrucciones, comentarios)</label><input class="form-input" @bind="addStopNotas" /></div>
                    <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.78rem; color:#6b7280;">
                        <input type="checkbox" @bind="addStopAlsoSaveFav" /> También guardar como favorito
                    </label>
                    <button class="btn btn-primary" style="width:100%; margin-top:0.5rem;" @onclick="AddStopManual"
                            disabled="@(addStopLat == 0 && addStopLng == 0)">+ Agregar parada</button>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showAddStopModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showDriversModal)
{
    <div class="modal-overlay" @onclick="() => showDriversModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:640px;">
            <div class="modal-header" style="background:#dbeafe;">
                <h3 style="margin:0;">👥 Repartidores</h3>
                <button class="btn-close" @onclick="() => showDriversModal = false">&times;</button>
            </div>
            <div class="modal-body">
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:flex-end; margin-bottom:0.7rem; padding:0.5rem; background:#f9fafb; border-radius:6px;">
                    <div class="form-group" style="flex:2;"><label class="form-label">Nombre *</label><input class="form-input" @bind="newDriverName" placeholder="Juan" /></div>
                    <div class="form-group" style="flex:1;"><label class="form-label">Tel</label><input class="form-input" @bind="newDriverPhone" placeholder="5491100000000" /></div>
                    <div class="form-group" style="flex:0 0 80px;"><label class="form-label">Color</label><input type="color" class="form-input" style="height:38px; padding:0.2rem;" @bind="newDriverColor" /></div>
                    <button class="btn btn-primary" @onclick="AddDriver" disabled="@(string.IsNullOrWhiteSpace(newDriverName))" style="height:38px;">+ Agregar</button>
                </div>
                @if (drivers is null || drivers.Count == 0)
                { <p style="text-align:center; color:#6b7280; padding:1rem;">No hay repartidores cargados todavía.</p> }
                else
                {
                    <table class="data-table" style="font-size:0.85rem;">
                        <thead><tr><th></th><th>Nombre</th><th>Tel</th><th>Activo</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var d in drivers)
                        {
                            <tr>
                                <td><input type="color" @bind="d.Color" style="width:30px; height:24px; border:none; padding:0;" /></td>
                                <td><input class="form-input" style="font-size:0.85rem; padding:0.2rem 0.4rem;" @bind="d.Nombre" /></td>
                                <td><input class="form-input" style="font-size:0.85rem; padding:0.2rem 0.4rem;" @bind="d.Telefono" /></td>
                                <td style="text-align:center;"><input type="checkbox" @bind="d.IsActive" /></td>
                                <td style="white-space:nowrap;">
                                    <button class="btn btn-secondary" style="font-size:0.75rem; padding:0.2rem 0.5rem;" @onclick="() => SaveDriver(d)">💾</button>
                                    <button class="btn btn-danger" style="font-size:0.75rem; padding:0.2rem 0.5rem;" @onclick="() => DeleteDriver(d)">🗑</button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDriversModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showFavoritosModal)
{
    <div class="modal-overlay" @onclick="() => showFavoritosModal = false">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width:780px;">
            <div class="modal-header" style="background:#fef3c7;">
                <h3 style="margin:0;">⭐ Direcciones favoritas</h3>
                <button class="btn-close" @onclick="() => showFavoritosModal = false">&times;</button>
            </div>
            <div class="modal-body" style="max-height:65vh; overflow-y:auto;">
                <div style="background:#f9fafb; border:1px solid #e5e7eb; padding:0.6rem; border-radius:6px; margin-bottom:0.7rem;">
                    <strong style="font-size:0.85rem;">Agregar nueva dirección</strong>
                    <div class="form-group">
                        <label class="form-label">Alias (corto)</label>
                        <input class="form-input" @bind="newFavAlias" placeholder="Cafetería Don Pepe" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Buscar dirección</label>
                        <div style="display:flex; gap:0.4rem;">
                            <input class="form-input" @bind="newFavQuery" placeholder="Calle 123, Ciudad" @onkeydown="OnFavGeocodeKey" style="flex:1;" />
                            <button class="btn btn-secondary" @onclick="DoFavGeocode" disabled="@favGeocoding">@(favGeocoding ? "..." : "🔍")</button>
                        </div>
                    </div>
                    @if (favGeocodeResults is not null && favGeocodeResults.Count > 0)
                    {
                        <div style="border:1px solid #e5e7eb; border-radius:6px; max-height:120px; overflow-y:auto; margin-bottom:0.5rem;">
                            @foreach (var r in favGeocodeResults)
                            {
                                <div style="padding:0.3rem 0.5rem; border-bottom:1px solid #f3f4f6; cursor:pointer; font-size:0.78rem;"
                                     @onclick="() => PickFavGeocode(r)">@r.DisplayName</div>
                            }
                        </div>
                    }
                    @if (newFavLat != 0 || newFavLng != 0)
                    {
                        <div style="font-size:0.75rem; color:#15803d;">✓ @newFavDireccion (@newFavLat.ToString("0.####") , @newFavLng.ToString("0.####"))</div>
                    }
                    <div class="form-row" style="margin-top:0.4rem;">
                        <div class="form-group" style="flex:1;"><label class="form-label">Contacto</label><input class="form-input" @bind="newFavContact" placeholder="Pepe" /></div>
                        <div class="form-group" style="flex:1;"><label class="form-label">Tel</label><input class="form-input" @bind="newFavPhone" /></div>
                    </div>
                    <div class="form-group"><label class="form-label">Notas</label><input class="form-input" @bind="newFavNotas" placeholder="Tocar timbre 3 veces" /></div>
                    <button class="btn btn-primary" style="width:100%;" @onclick="AddFavorito" disabled="@(string.IsNullOrWhiteSpace(newFavAlias) || (newFavLat == 0 && newFavLng == 0))">+ Guardar favorito</button>
                </div>
                @if (favoritos is null || favoritos.Count == 0)
                { <p style="text-align:center; color:#6b7280; padding:1rem;">No hay favoritos cargados todavía.</p> }
                else
                {
                    @foreach (var f in favoritos)
                    {
                        <div style="border:1px solid #e5e7eb; padding:0.5rem 0.7rem; border-radius:6px; margin-bottom:0.4rem;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.4rem;">
                                <div>
                                    <strong>@f.Alias</strong> · <span style="font-size:0.78rem; color:#4b5563;">@f.Direccion</span>
                                    @if (!string.IsNullOrEmpty(f.ContactName) || !string.IsNullOrEmpty(f.Telefono))
                                    {
                                        <div style="font-size:0.75rem; color:#6b7280;">
                                            @if (!string.IsNullOrEmpty(f.ContactName)) { <span>👤 @f.ContactName</span> }
                                            @if (!string.IsNullOrEmpty(f.Telefono)) { <span> · 📞 @f.Telefono</span> }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(f.Notas))
                                    { <div style="font-size:0.72rem; color:#9ca3af;">📝 @f.Notas</div> }
                                </div>
                                <button class="btn btn-danger" style="font-size:0.75rem; padding:0.2rem 0.5rem;" @onclick="() => DeleteFavorito(f)">🗑</button>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showFavoritosModal = false">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showStartPointModal)
{
    <div class="modal-overlay" @onclick="CloseStartPointModal">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background:#dcfce7;">
                <h3 style="margin:0;">📍 Punto de partida</h3>
                <button class="btn-close" @onclick="CloseStartPointModal">&times;</button>
            </div>
            <div class="modal-body">
                <p style="color:#6b7280; font-size:0.85rem; margin:0 0 0.5rem;">
                    Es el lugar desde donde salís a repartir. Aparece como casita verde 🏠 en el mapa para que veas la ruta desde ahí.
                </p>
                <div class="form-group">
                    <label class="form-label">Buscar dirección</label>
                    <div style="display:flex; gap:0.4rem;">
                        <input class="form-input" @bind="geocodeQuery" placeholder="Calle 123, Ciudad, Provincia" @onkeydown="OnGeocodeKey" style="flex:1;" />
                        <button class="btn btn-secondary" @onclick="DoGeocode" disabled="@geocoding">@(geocoding ? "..." : "🔍")</button>
                    </div>
                    <p style="font-size:0.7rem; color:#6b7280; margin:0.2rem 0 0;">Buscamos en OpenStreetMap (gratis, ~5 candidatos).</p>
                </div>
                @if (geocodeResults is not null && geocodeResults.Count > 0)
                {
                    <div style="border:1px solid #e5e7eb; border-radius:6px; max-height:160px; overflow-y:auto; margin-bottom:0.5rem;">
                        @foreach (var r in geocodeResults)
                        {
                            <div style="padding:0.4rem 0.6rem; border-bottom:1px solid #f3f4f6; cursor:pointer; font-size:0.8rem;"
                                 @onclick="() => PickGeocode(r)" title="Usar esta dirección">
                                <strong>@r.DisplayName</strong>
                                <div style="font-size:0.7rem; color:#9ca3af;">@r.Lat.ToString("0.######") , @r.Lng.ToString("0.######")</div>
