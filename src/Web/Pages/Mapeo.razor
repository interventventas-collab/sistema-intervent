    /// <summary>Color, fondo y etiqueta del badge según el SLA del envío.</summary>
    private static (string Bg, string Fg, string Label) SlaStyle(DateTime slaLocal)
    {
        var today = DateTime.Now.Date;
        var sla = slaLocal.Date;
        if (sla < today) return ("#fee2e2", "#b91c1c", "🚨 Vencido");
        if (sla == today) return ("#fef3c7", "#92400e", "⏰ Hoy");
        if (sla == today.AddDays(1)) return ("#dbeafe", "#1e40af", "📅 Mañana");
        return ("#f3f4f6", "#374151", "📆");
    }

