                }
                <div class="form-group">
                    <label class="form-label">Dirección a guardar</label>
                    <input class="form-input" @bind="formStartAddress" />
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Latitud</label>
                        <input class="form-input" @bind="formStartLat" placeholder="-34.603722" />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Longitud</label>
                        <input class="form-input" @bind="formStartLng" placeholder="-58.381592" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="ClearStartPoint" disabled="@savingStartPoint">Borrar</button>
                <button class="btn btn-secondary" @onclick="CloseStartPointModal" disabled="@savingStartPoint">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveStartPoint" disabled="@savingStartPoint">
                    @(savingStartPoint ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@if (showDetail && selected is not null)
{
    <div class="modal-overlay" @onclick="() => showDetail = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin:0;">📦 Envío @selected.MeliShipmentId</h3>
                <button class="btn-close" @onclick="() => showDetail = false">&times;</button>
            </div>
            <div class="modal-body" style="font-size:0.88rem;">
                @if (selected.MeliOrderId.HasValue || !string.IsNullOrEmpty(selected.BuyerNickname))
                {
                    <div style="background:#f0f9ff; border:1px solid #bfdbfe; padding:0.4rem 0.6rem; border-radius:6px; margin-bottom:0.5rem; font-size:0.82rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
                        @if (!string.IsNullOrEmpty(selected.BuyerNickname))
                        {
                            <span class="copy-chip" title="Click: copiar nickname"
                                  @onclick="@(e => CopyValue(selected.BuyerNickname!, "Comprador"))">
                                👤 <strong>@selected.BuyerNickname</strong> 📋
                            </span>
                        }
                        @if (selected.MeliOrderId.HasValue)
                        {
                            <span class="copy-chip" title="Click: copiar N° de venta" style="font-family:monospace;"
                                  @onclick="@(e => CopyValue(selected.MeliOrderId.Value.ToString(), "N° venta"))">
                                🧾 <strong>@selected.MeliOrderId.Value</strong> 📋
                            </span>
                        }
                    </div>
                }
                <p><strong>@(selected.ReceiverName ?? "—")</strong></p>
                <p style="color:#4b5563; margin:0.2rem 0;">@selected.AddressLine</p>
                <p style="color:#6b7280; font-size:0.78rem; margin:0;">
                    @selected.Neighborhood @(string.IsNullOrEmpty(selected.Neighborhood) ? "" : "·") @selected.City · @selected.State · CP @selected.ZipCode
                </p>
                @if (!string.IsNullOrEmpty(selected.ReceiverPhone))
                {
                    var tel = selected.ReceiverPhone!;
                    var digits = new string(tel.Where(char.IsDigit).ToArray());
                    <p style="margin:0.4rem 0;"><strong>📞 Tel:</strong>
                        <a href="@($"https://wa.me/{digits}")" target="_blank" style="color:#25D366; font-weight:700;">@tel (WhatsApp)</a>
                    </p>
                }
                @if (!string.IsNullOrEmpty(selected.Comment))
                {
                    <p style="background:#fef3c7; border-left:3px solid #d97706; padding:0.4rem 0.6rem; margin:0.4rem 0; font-size:0.82rem;">
                        💬 <strong>Comentario del comprador:</strong> @selected.Comment
                    </p>
                }
                <p style="margin:0.4rem 0;"><strong>Items:</strong> @(selected.ItemsSummary ?? "—")</p>
                @if (selected.OrderTotal.HasValue)
                { <p style="margin:0.2rem 0;"><strong>Total:</strong> $@selected.OrderTotal.Value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</p> }
                <p style="margin:0.2rem 0;"><strong>Tracking:</strong> @(selected.TrackingNumber ?? "—")</p>
                <p style="margin:0.2rem 0;"><strong>Estado MeLi:</strong> @selected.Status / @(selected.Substatus ?? "—")</p>

                <hr style="margin:0.7rem 0;" />

                <div class="form-group">
                    <label class="form-label">Estado interno (lo controlas vos)</label>
                    <select class="form-input" @bind="selected.InternalStatus">
                        <option value="pending">Pendiente</option>
                        <option value="en_ruta">En ruta</option>
                        <option value="entregado">Entregado</option>
                        <option value="no_encontrado">No encontrado</option>
                        <option value="reprogramado">Reprogramado</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Notas internas</label>
                    <textarea class="form-input" rows="2" @bind="selected.Notes" placeholder="Ej: tocar timbre 3 veces, dejar en portería..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDetail = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="GuardarEstadoInterno" disabled="@isSavingDetail">
                    @(isSavingDetail ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<MeliShipmentDto>? shipments;
    private bool isLoading, isSyncing, isSavingDetail;
    private string diasFiltro = "7";
    private string filtroInterno = "";
    private bool excluirEntregados = false;
    private DotNetObjectReference<Mapeo>? selfRef;
    private bool mapInitialized;

    private MeliShipmentDto? selected;
    private bool showDetail;
    private int? activeShipmentId;

    // Punto de partida
    private StartPointDto? startPoint;
    private bool showStartPointModal, savingStartPoint, geocoding;
    private string formStartAddress = "", formStartLat = "", formStartLng = "";
    private string geocodeQuery = "";
    private List<GeocodeResultDto>? geocodeResults;

    // Drivers
    private List<MapeoDriverDto>? drivers;
    private bool showDriversModal;
    private string newDriverName = "", newDriverPhone = "", newDriverColor = "#1d4ed8";

    // Favoritos
    private List<MapeoFavoritoDto>? favoritos;
    private bool showFavoritosModal;

    // Stops adicionales (paradas no-Flex)
    private List<MapeoStopDto>? stops;
    private bool showAddStopModal;
    private string addStopTab = "favorito";
    private string addStopFavSearch = "";
    private string addStopQuery = "", addStopDireccion = "", addStopAlias = "", addStopContact = "", addStopPhone = "", addStopNotas = "";
    private decimal addStopLat = 0, addStopLng = 0;
    private bool addStopGeocoding, addStopAlsoSaveFav;
    private List<GeocodeResultDto>? addStopGeocodeResults;

    // Armar ruta
    private bool showArmarRutaModal, importingFlex, routeBusy;
    private string newFavAlias = "", newFavQuery = "", newFavDireccion = "", newFavContact = "", newFavPhone = "", newFavNotas = "";
    private decimal newFavLat = 0m, newFavLng = 0m;
    private bool favGeocoding;
    private List<GeocodeResultDto>? favGeocodeResults;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mapeoFlex.init", "leafletMap", selfRef);
            mapInitialized = true;
            try { startPoint = await Api.GetMapeoStartPointAsync(); } catch { }
            await LoadDrivers();
            await LoadFavoritos();
            await LoadStops();
            await LoadAndRender();
        }
    }

    private async Task LoadAndRender()
    {
        isLoading = true;
        try
        {
            int days = int.TryParse(diasFiltro, out var d) ? d : 7;
            shipments = await Api.GetMeliFlexShipmentsAsync(days, string.IsNullOrEmpty(filtroInterno) ? null : filtroInterno, excluirEntregados) ?? new();
            if (mapInitialized) await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isLoading = false; }
    }

    private async Task RenderMap()
    {
        if (shipments is null) return;
        var list = new List<object>();
        if (startPoint?.Lat is not null && startPoint?.Lng is not null)
        {
            list.Add(new
            {
                id = -1,
                lat = startPoint.Lat,
                lng = startPoint.Lng,
                label = "🏠",
                color = "#15803d",
                popupHtml = $"<div style='font-size:0.85rem;'><strong>📍 Punto de partida</strong><br/>{System.Net.WebUtility.HtmlEncode(startPoint.Address ?? "")}</div>"
            });
        }
        list.AddRange(shipments.Where(s => s.Latitude.HasValue && s.Longitude.HasValue).Select((s, i) => (object)new
        {
            id = s.Id,
            lat = s.Latitude,
            lng = s.Longitude,
            label = (i + 1).ToString(),
            color = ColorFor(EffectiveKey(s)),
            popupHtml = $"<div style='font-size:0.8rem;'><strong>{System.Net.WebUtility.HtmlEncode(s.ReceiverName ?? "—")}</strong><br/>{System.Net.WebUtility.HtmlEncode(s.AddressLine ?? "")}<br/><em>{System.Net.WebUtility.HtmlEncode(s.City ?? "")}</em></div>"
        }));
        // Stops (incluye los Flex importados + favoritos + manuales)
        // Si tienen driver asignado: color del driver y label = número de orden.
        // Si no: naranja con ★.
        if (stops is not null)
        {
            list.AddRange(stops.Select(st => (object)new
            {
                id = -1000 - st.Id,
                lat = st.Latitude,
                lng = st.Longitude,
                label = st.OrderInRoute.HasValue ? st.OrderInRoute.Value.ToString() : "★",
                color = string.IsNullOrEmpty(st.AssignedDriverColor) ? "#d97706" : st.AssignedDriverColor,
                popupHtml = $"<div style='font-size:0.8rem;'><strong>{System.Net.WebUtility.HtmlEncode(st.Alias ?? st.ContactName ?? "Parada")}</strong>{(st.AssignedDriverName is null ? "" : $" <span style='color:{st.AssignedDriverColor}'>· {System.Net.WebUtility.HtmlEncode(st.AssignedDriverName)}{(st.OrderInRoute.HasValue ? $" #{st.OrderInRoute}" : "")}</span>")}<br/>{System.Net.WebUtility.HtmlEncode(st.Direccion)}{(string.IsNullOrEmpty(st.Telefono) ? "" : $"<br/>📞 {System.Net.WebUtility.HtmlEncode(st.Telefono)}")}</div>"
            }));
        }
        await JS.InvokeVoidAsync("mapeoFlex.renderMarkers", new object[] { list.ToArray() });
    }

    private static string ColorFor(string s) => s switch
    {
        "en_ruta" => "#d97706",
        "entregado" => "#15803d",
        "no_encontrado" => "#b91c1c",
        "reprogramado" => "#7c3aed",
        "cancelled" => "#6b7280",
        _ => "#1d4ed8"
    };

    private static string StatusLabel(string s) => s switch
    {
        "en_ruta" => "En ruta",
        "entregado" => "Entregado",
        "no_encontrado" => "No encontró",
        "reprogramado" => "Reprogramado",
        "cancelled" => "Cancelado",
        _ => "Pendiente"
    };

    private static string StatusStyle(string s)
    {
        var c = ColorFor(s);
        return $"background:{c}33; color:{c};";
    }

    /// <summary>
    /// El estado "efectivo" combina lo que dice MeLi (delivered/cancelled gana sobre tu pending)
    /// con el estado interno que vos vas marcando manualmente.
    /// Asi una venta entregada en MeLi aparece como "Entregado" aunque vos no la hayas tocado.
    /// </summary>
    private static string EffectiveKey(MeliShipmentDto s)
    {
        if (string.Equals(s.Status, "delivered", StringComparison.OrdinalIgnoreCase)) return "entregado";
        if (string.Equals(s.Status, "cancelled", StringComparison.OrdinalIgnoreCase)) return "cancelled";
        // Si el usuario ya marcó algo (no es "pending"), respetamos su estado interno.
        if (!string.Equals(s.InternalStatus, "pending", StringComparison.OrdinalIgnoreCase)) return s.InternalStatus;
        return "pending";
    }
    private static string EffectiveStatusLabel(MeliShipmentDto s) => StatusLabel(EffectiveKey(s));
    private static string EffectiveStatusStyle(MeliShipmentDto s) => StatusStyle(EffectiveKey(s));

    private async Task OnSelectFromList(MeliShipmentDto s)
    {
        activeShipmentId = s.Id;
        selected = s;
        showDetail = true;
        if (s.Latitude.HasValue && s.Longitude.HasValue)
            await JS.InvokeVoidAsync("mapeoFlex.focusOn", (double)s.Latitude.Value, (double)s.Longitude.Value, 16);
    }

    [JSInvokable]
    public Task OnMarkerClicked(int id)
    {
        var s = shipments?.FirstOrDefault(x => x.Id == id);
        if (s is not null) { activeShipmentId = id; selected = s; showDetail = true; StateHasChanged(); }
        return Task.CompletedTask;
    }

    private async Task LoadDrivers() { try { drivers = await Api.GetMapeoDriversAsync() ?? new(); } catch { drivers = new(); } }
    private async Task LoadFavoritos() { try { favoritos = await Api.GetMapeoFavoritosAsync() ?? new(); } catch { favoritos = new(); } }
    private async Task LoadStops() { try { stops = await Api.GetMapeoStopsAsync() ?? new(); } catch { stops = new(); } }

    // ===== Agregar parada (manual o desde favorito) =====
    private void OpenAddStopModal()
    {
        addStopTab = (favoritos?.Count ?? 0) > 0 ? "favorito" : "manual";
        addStopFavSearch = ""; addStopQuery = ""; addStopDireccion = ""; addStopAlias = "";
        addStopContact = ""; addStopPhone = ""; addStopNotas = "";
        addStopLat = 0; addStopLng = 0; addStopAlsoSaveFav = false;
        addStopGeocodeResults = null;
        showAddStopModal = true;
    }

    private async Task OnAddStopGeocodeKey(KeyboardEventArgs e) { if (e.Key == "Enter") await DoAddStopGeocode(); }

    private async Task DoAddStopGeocode()
    {
        if (string.IsNullOrWhiteSpace(addStopQuery)) return;
        addStopGeocoding = true;
        try { addStopGeocodeResults = await Api.GeocodeAsync(addStopQuery) ?? new(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { addStopGeocoding = false; }
    }

    private void PickAddStopGeocode(GeocodeResultDto r)
    {
        addStopDireccion = r.DisplayName;
        addStopLat = r.Lat;
        addStopLng = r.Lng;
        addStopGeocodeResults = null;
    }

    private async Task AddStopFromFavorito(MapeoFavoritoDto f)
    {
        try
        {
            var s = await Api.CreateMapeoStopAsync("favorito", f.Id.ToString(), f.Alias, f.Direccion, f.Latitude, f.Longitude,
                f.ContactName, f.Telefono, f.Notas);
            if (s is not null) { stops!.Insert(0, s); ToastService.Success($"'{f.Alias}' agregado al mapa"); await RenderMap(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task AddStopManual()
    {
        if (addStopLat == 0 && addStopLng == 0) return;
        try
        {
            var s = await Api.CreateMapeoStopAsync("manual", null, addStopAlias, addStopDireccion, addStopLat, addStopLng,
                addStopContact, addStopPhone, addStopNotas);
            if (s is not null)
            {
                stops!.Insert(0, s);
                if (addStopAlsoSaveFav && !string.IsNullOrWhiteSpace(addStopAlias))
                {
                    var f = await Api.CreateMapeoFavoritoAsync(new MapeoFavoritoDto
                    {
                        Alias = addStopAlias, Direccion = addStopDireccion,
                        Latitude = addStopLat, Longitude = addStopLng,
                        ContactName = addStopContact, Telefono = addStopPhone, Notas = addStopNotas
                    });
                    if (f is not null) { favoritos!.Insert(0, f); }
                }
                ToastService.Success("Parada agregada al mapa");
                showAddStopModal = false;
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private static string OriginLabel(string o) => o switch
    {
        "flex" => "📦 MeLi Flex",
        "favorito" => "⭐ Favorito",
        "venta_cafe" => "☕ Café",
        _ => "✏️ Manual"
    };

    private async Task ImportFlexAsStops()
    {
        importingFlex = true;
        try
        {
            await Api.ImportFlexAsStopsAsync(15);
            await LoadStops();
            ToastService.Success("Flex pendientes agregados a la lista de paradas");
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { importingFlex = false; }
    }

    private void OpenArmarRutaModal() => showArmarRutaModal = true;

    private async Task OnAssignDriver(MapeoStopDto s, string? value)
    {
        int? did = int.TryParse(value, out var v) && v > 0 ? v : null;
        s.AssignedDriverId = did;
        var d = did.HasValue ? drivers?.FirstOrDefault(x => x.Id == did.Value) : null;
        s.AssignedDriverName = d?.Nombre;
        s.AssignedDriverColor = d?.Color;
        try
        {
            await Api.UpdateMapeoStopAsync(s.Id, new { assignedDriverId = did ?? 0 });
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DoAutoAssign() => await DoAutoAssignInternal(false);
    private async Task DoAutoAssignAll() => await DoAutoAssignInternal(true);

    private async Task DoAutoAssignInternal(bool reassignAll)
    {
        routeBusy = true;
        try
        {
            await Api.AutoAssignStopsAsync(reassignAll);
            await LoadStops();
            ToastService.Success("Paradas repartidas entre los repartidores");
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { routeBusy = false; }
    }

    private async Task DoOptimizeAll()
    {
        routeBusy = true;
        try
        {
            await Api.OptimizeStopsOrderAsync(null);
            await LoadStops();
            ToastService.Success("Orden optimizado para todos los repartidores");
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { routeBusy = false; }
    }

    private async Task DoOptimizeDriver(int driverId)
    {
        routeBusy = true;
        try
        {
            await Api.OptimizeStopsOrderAsync(driverId);
            await LoadStops();
            ToastService.Success("Orden optimizado");
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { routeBusy = false; }
    }

    private async Task DoUnassignAll()
    {
        if (!await ConfirmAsync("Quitar TODAS las asignaciones de drivers y orden?")) return;
        routeBusy = true;
        try
        {
            var ids = stops?.Select(s => s.Id).ToList() ?? new();
            if (ids.Count > 0) await Api.AssignBulkStopsAsync(ids, null);
            // Limpiar tambien el orden via update individual (no tan crítico, pero prolijo)
            await LoadStops();
            ToastService.Success("Asignaciones limpiadas");
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { routeBusy = false; }
    }

    private async Task DeleteStop(MapeoStopDto s)
    {
        if (!await ConfirmAsync($"Quitar '{s.Alias ?? s.Direccion}' del mapa?")) return;
        try
        {
            if (await Api.DeleteMapeoStopAsync(s.Id))
            {
                stops?.Remove(s);
                ToastService.Success("Parada quitada");
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task OpenDriversModal() { await LoadDrivers(); showDriversModal = true; }
    private async Task OpenFavoritosModal() { await LoadFavoritos(); showFavoritosModal = true; }

    private async Task AddDriver()
    {
        if (string.IsNullOrWhiteSpace(newDriverName)) return;
        try
        {
            var d = await Api.CreateMapeoDriverAsync(newDriverName, string.IsNullOrWhiteSpace(newDriverPhone) ? null : newDriverPhone, newDriverColor);
            if (d is not null) { drivers ??= new(); drivers.Add(d); newDriverName = ""; newDriverPhone = ""; ToastService.Success("Repartidor agregado"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task SaveDriver(MapeoDriverDto d)
    {
        try
        {
            await Api.UpdateMapeoDriverAsync(d.Id, d.Nombre, d.Telefono, d.Color, d.IsActive);
            ToastService.Success("Guardado");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DeleteDriver(MapeoDriverDto d)
    {
        if (!await ConfirmAsync($"Eliminar al repartidor '{d.Nombre}'?")) return;
        try { if (await Api.DeleteMapeoDriverAsync(d.Id)) { drivers?.Remove(d); ToastService.Success("Eliminado"); } }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task OnFavGeocodeKey(KeyboardEventArgs e) { if (e.Key == "Enter") await DoFavGeocode(); }

    private async Task DoFavGeocode()
    {
        if (string.IsNullOrWhiteSpace(newFavQuery)) return;
        favGeocoding = true;
        try { favGeocodeResults = await Api.GeocodeAsync(newFavQuery) ?? new(); }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { favGeocoding = false; }
    }

    private void PickFavGeocode(GeocodeResultDto r)
    {
        newFavDireccion = r.DisplayName;
        newFavLat = r.Lat;
        newFavLng = r.Lng;
        favGeocodeResults = null;
    }

    private async Task AddFavorito()
    {
        if (string.IsNullOrWhiteSpace(newFavAlias) || (newFavLat == 0 && newFavLng == 0)) return;
        try
        {
            var dto = new MapeoFavoritoDto
            {
                Alias = newFavAlias.Trim(),
                Direccion = newFavDireccion,
                Latitude = newFavLat, Longitude = newFavLng,
                ContactName = string.IsNullOrWhiteSpace(newFavContact) ? null : newFavContact.Trim(),
                Telefono = string.IsNullOrWhiteSpace(newFavPhone) ? null : newFavPhone.Trim(),
                Notas = string.IsNullOrWhiteSpace(newFavNotas) ? null : newFavNotas.Trim()
            };
            var f = await Api.CreateMapeoFavoritoAsync(dto);
            if (f is not null)
            {
                favoritos ??= new(); favoritos.Insert(0, f);
                newFavAlias = ""; newFavQuery = ""; newFavDireccion = ""; newFavContact = ""; newFavPhone = ""; newFavNotas = "";
                newFavLat = 0; newFavLng = 0; favGeocodeResults = null;
                ToastService.Success("Favorito guardado");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task DeleteFavorito(MapeoFavoritoDto f)
    {
        if (!await ConfirmAsync($"Eliminar '{f.Alias}'?")) return;
        try { if (await Api.DeleteMapeoFavoritoAsync(f.Id)) { favoritos?.Remove(f); ToastService.Success("Eliminado"); } }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private Task<bool> ConfirmAsync(string msg) => JS.InvokeAsync<bool>("confirm", msg).AsTask();

    private void OpenStartPointModal()
    {
        formStartAddress = startPoint?.Address ?? "";
        formStartLat = startPoint?.Lat?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        formStartLng = startPoint?.Lng?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        geocodeQuery = formStartAddress;
        geocodeResults = null;
        showStartPointModal = true;
    }
    private void CloseStartPointModal() { showStartPointModal = false; geocodeResults = null; }

    private async Task OnGeocodeKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoGeocode();
    }

    private async Task DoGeocode()
    {
        if (string.IsNullOrWhiteSpace(geocodeQuery)) return;
        geocoding = true;
        try
        {
            geocodeResults = await Api.GeocodeAsync(geocodeQuery) ?? new();
            if (geocodeResults.Count == 0) ToastService.Info("Sin resultados — probá ser más específico (calle, ciudad, provincia).");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { geocoding = false; }
    }

    private void PickGeocode(GeocodeResultDto r)
    {
        formStartAddress = r.DisplayName;
        formStartLat = r.Lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
        formStartLng = r.Lng.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private async Task SaveStartPoint()
    {
        decimal? lat = decimal.TryParse(formStartLat, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var la) ? la : null;
        decimal? lng = decimal.TryParse(formStartLng, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lo) ? lo : null;
        if (!lat.HasValue || !lng.HasValue) { ToastService.Error("Faltan latitud o longitud (buscá la dirección y elegí una opción)."); return; }
        savingStartPoint = true;
        try
        {
            var ok = await Api.SetMapeoStartPointAsync(formStartAddress, lat, lng);
            if (ok)
            {
                startPoint = new StartPointDto { Address = formStartAddress, Lat = lat, Lng = lng };
                ToastService.Success("Punto de partida guardado");
                showStartPointModal = false;
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { savingStartPoint = false; }
    }

    private async Task ClearStartPoint()
    {
        savingStartPoint = true;
        try
        {
            var ok = await Api.SetMapeoStartPointAsync(null, null, null);
            if (ok)
            {
                startPoint = new StartPointDto();
                ToastService.Success("Punto de partida borrado");
                showStartPointModal = false;
                await RenderMap();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { savingStartPoint = false; }
    }

    private async Task CopyValue(string value, string label)
    {
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", value);
            ToastService.Success($"{label} copiado: {value}");
        }
        catch { ToastService.Error("No se pudo copiar"); }
    }

    private async Task SyncFromMeli()
    {
        isSyncing = true;
        try
        {
            int days = int.TryParse(diasFiltro, out var d) ? d : 7;
            var r = await Api.SyncMeliFlexShipmentsAsync(days, 200);
            if (r is not null)
            {
                ToastService.Success($"Sincronizados {r.TotalFlex} Flex (de {r.TotalSynced} envíos)");
                await LoadAndRender();
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isSyncing = false; }
    }

    private async Task GuardarEstadoInterno()
    {
        if (selected is null) return;
        isSavingDetail = true;
        try
        {
            var ok = await Api.UpdateMeliShipmentInternalStatusAsync(selected.Id, selected.InternalStatus, selected.Notes);
            if (ok) { ToastService.Success("Estado actualizado"); showDetail = false; await RenderMap(); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { isSavingDetail = false; }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("mapeoFlex.destroy"); } catch { }
        selfRef?.Dispose();
    }
