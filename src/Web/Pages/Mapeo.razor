    /// <summary>
    /// Si el vehículo NO tiene orden asignado todavía, lo pre-numera por cercanía al punto de partida.
    /// Si ya hay orden manual previo (cualquiera tiene OrderInRoute), no toca nada.
    /// </summary>
    private async Task AutoOptimizarSiHaceFalta(int slot)
    {
        if (stops is null) return;
        var stopsDelV = stops.Where(s => s.AssignedVehicleSlot == slot).ToList();
        if (stopsDelV.Count == 0) return;
        bool yaTieneOrden = stopsDelV.Any(s => s.OrderInRoute.HasValue);
        if (yaTieneOrden) return;
        try
        {
            await Api.OptimizeStopsOrderAsync(null, slot);
            await LoadStops();
            ToastService.Info($"V{slot}: pre-numerado por cercanía. Editá tocando los puntos.");
        }
        catch { /* tolerar */ }
    }

    /// <summary>Click en un marker en modo orden — asigna o desasigna el siguiente número.</summary>
    private async Task OnMarkerOrden(MapeoStopDto s)
    {
        if (s.AssignedVehicleSlot != ordenVehiculoSeleccionado)
        {
            ToastService.Info($"Esa parada no es del V{ordenVehiculoSeleccionado}");
            return;
        }
        assigningSlot = true;
        try
        {
            if (s.OrderInRoute.HasValue)
            {
                // Ya tiene orden — desnumerarla y reordenar las siguientes (-1 a las que tenían orden mayor)
                int removedOrder = s.OrderInRoute.Value;
                s.OrderInRoute = null;
                await Api.UpdateMapeoStopAsync(s.Id, new { orderInRoute = 0 });
                // Ajustar las siguientes
                if (stops is not null)
                {
                    foreach (var other in stops.Where(x => x.AssignedVehicleSlot == ordenVehiculoSeleccionado
                                                       && x.Id != s.Id
                                                       && x.OrderInRoute.HasValue
                                                       && x.OrderInRoute.Value > removedOrder))
                    {
                        var nuevo = other.OrderInRoute!.Value - 1;
                        other.OrderInRoute = nuevo;
                        await Api.UpdateMapeoStopAsync(other.Id, new { orderInRoute = nuevo });
                    }
                }
            }
            else
            {
                // Asignar el siguiente número
                int max = stops!.Where(x => x.AssignedVehicleSlot == ordenVehiculoSeleccionado)
                    .Max(x => x.OrderInRoute ?? 0);
                int proximo = max + 1;
                s.OrderInRoute = proximo;
                await Api.UpdateMapeoStopAsync(s.Id, new { orderInRoute = proximo });
            }
            await RenderMap();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { assigningSlot = false; }
    }

    private async Task ResetOrdenDelVehiculo()
    {
        if (!await ConfirmAsync($"Borrar el orden manual del V{ordenVehiculoSeleccionado}?")) return;
        assigningSlot = true;
        try
        {
            var paradas = stops?.Where(x => x.AssignedVehicleSlot == ordenVehiculoSeleccionado && x.OrderInRoute.HasValue).ToList() ?? new();
            foreach (var s in paradas)
            {
                s.OrderInRoute = null;
                await Api.UpdateMapeoStopAsync(s.Id, new { orderInRoute = 0 });
            }
            await RenderMap();
            ToastService.Success("Orden reiniciado");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { assigningSlot = false; }
    }

