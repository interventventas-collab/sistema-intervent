    [JSInvokable]
    public async Task OnMarkerClicked(int id)
    {
        // Markers de stops adicionales tienen id negativo (-1000 - st.Id)
        if (id <= -1000)
        {
            var stopId = -1000 - id;
            var st = stops?.FirstOrDefault(x => x.Id == stopId);
            if (st is null) return;
            if (modoOrden) { await OnMarkerOrden(st); return; }
            if (modoAsignacion) { await OnMarkerAssign(st); return; }
            return;
        }
        var s = shipments?.FirstOrDefault(x => x.Id == id);
        if (s is not null) { activeShipmentId = id; selected = s; showDetail = true; StateHasChanged(); }
    }

