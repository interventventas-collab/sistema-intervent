@page "/usuarios"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Usuarios (@(users?.Count ?? 0))</h3>
        <button class="btn btn-primary" @onclick="ShowCreateForm">+ Nuevo Usuario</button>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (users is null || !users.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay usuarios registrados</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Telefono</th>
                            <th>Rol</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr>
                                <td><strong>@user.Username</strong></td>
                                <td>@($"{user.FirstName} {user.LastName}".Trim())</td>
                                <td>@user.Email</td>
                                <td>@(user.Phone ?? "-")</td>
                                <td><span class="role-badge">@user.Role</span></td>
                                <td>
                                    <span class="status-badge @(user.IsActive ? "status-active" : "status-inactive")">
                                        @(user.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEditForm(user)" title="Editar">
                                        @SvgIcons.Settings
                                    </button>
                                    @if (user.Username != "admin")
                                    {
                                        <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(user)" title="Eliminar">
                                            @SvgIcons.AlertCircle
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(isEditing ? "Editar Usuario" : "Nuevo Usuario")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                @if (!isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Usuario</label>
                        <input class="form-input" @bind="newUser.Username" placeholder="Nombre de usuario" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contrasena</label>
                        <input class="form-input" type="password" @bind="newUser.Password" placeholder="Minimo 6 caracteres" />
                    </div>
                }

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nombre</label>
                        <input class="form-input" @bind="formFirstName" placeholder="Nombre" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Apellido</label>
                        <input class="form-input" @bind="formLastName" placeholder="Apellido" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" type="email" @bind="formEmail" placeholder="correo@ejemplo.com" />
                </div>

                <div class="form-group">
                    <label class="form-label">Telefono</label>
                    <input class="form-input" @bind="formPhone" placeholder="+54 11 1234-5678" />
                </div>

                <div class="form-group">
                    <label class="form-label">Rol</label>
                    <select class="form-input" @bind="formRoleId">
                        @if (roles is not null)
                        {
                            @foreach (var role in roles)
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                        }
                    </select>
                </div>

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveUser" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Confirmar eliminacion</h3>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar al usuario <strong>@userToDelete?.Username</strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="DeleteUser">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserManageDto>? users;
    private List<RoleDto>? roles;
    private bool isLoading = true;
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;

    // Form fields
    private CreateUserRequest newUser = new();
    private int? editingUserId;
    private string formFirstName = "";
    private string formLastName = "";
    private string formEmail = "";
    private string formPhone = "";
    private int formRoleId = 2;
    private bool formIsActive = true;

    // Delete
    private bool showDeleteConfirm;
    private UserManageDto? userToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            users = await Api.GetUsersAsync();
            roles = await Api.GetRolesAsync();
        }
        catch
        {
            ToastService.Error("Error al cargar los datos");
        }
        isLoading = false;
    }

    private void ShowCreateForm()
    {
        isEditing = false;
        editingUserId = null;
        newUser = new CreateUserRequest { RoleId = 2 };
        formFirstName = "";
        formLastName = "";
        formEmail = "";
        formPhone = "";
        formRoleId = 2;
        formIsActive = true;
        formError = null;
        showForm = true;
    }

    private void ShowEditForm(UserManageDto user)
    {
        isEditing = true;
        editingUserId = user.Id;
        formFirstName = user.FirstName ?? "";
        formLastName = user.LastName ?? "";
        formEmail = user.Email;
        formPhone = user.Phone ?? "";
        formRoleId = user.RoleId;
        formIsActive = user.IsActive;
        formError = null;
        showForm = true;
    }

    private void CloseForm()
    {
        showForm = false;
        formError = null;
    }

    private async Task SaveUser()
    {
        formError = null;
        isSaving = true;

        try
        {
            if (isEditing && editingUserId.HasValue)
            {
                var update = new UpdateUserRequest
                {
                    FirstName = formFirstName,
                    LastName = formLastName,
                    Email = formEmail,
                    Phone = formPhone,
                    RoleId = formRoleId,
                    IsActive = formIsActive
                };

                var result = await Api.UpdateUserAsync(editingUserId.Value, update);
                if (result is null)
                {
                    formError = "Error al actualizar. Verificar que el email no este en uso.";
                    isSaving = false;
                    return;
                }
                ToastService.Success("Usuario actualizado");
            }
            else
            {
                if (string.IsNullOrWhiteSpace(newUser.Username) || string.IsNullOrWhiteSpace(newUser.Password) || string.IsNullOrWhiteSpace(formEmail))
                {
                    formError = "Completa usuario, contrasena y email";
                    isSaving = false;
                    return;
                }

                newUser.FirstName = formFirstName;
                newUser.LastName = formLastName;
                newUser.Email = formEmail;
                newUser.Phone = formPhone;
                newUser.RoleId = formRoleId;

                var result = await Api.CreateUserAsync(newUser);
                if (result is null)
                {
                    formError = "El usuario o email ya existe";
                    isSaving = false;
                    return;
                }
                ToastService.Success("Usuario creado");
            }

            showForm = false;
            await LoadData();
        }
        catch
        {
            formError = "Error al guardar el usuario";
        }

        isSaving = false;
    }

    private void ConfirmDelete(UserManageDto user)
    {
        userToDelete = user;
        showDeleteConfirm = true;
    }

    private async Task DeleteUser()
    {
        if (userToDelete is null) return;

        var result = await Api.DeleteUserAsync(userToDelete.Id);
        if (result)
        {
            ToastService.Success("Usuario eliminado");
            await LoadData();
        }
        else
        {
            ToastService.Error("Error al eliminar el usuario");
        }

        showDeleteConfirm = false;
        userToDelete = null;
    }
}
