    private string GetShippingDisplayLabel(string? status, string? substatus)
    {
        var subLabel = GetShippingSubstatusLabel(substatus);
        if (!string.IsNullOrEmpty(subLabel))
            return subLabel;
        return GetShippingStatusLabel(status, substatus);
    }

    private string Truncate(string text, int maxLength) =>
        text.Length <= maxLength ? text : text[..maxLength] + "...";

