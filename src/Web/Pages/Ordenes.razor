@code {
    private List<MeliOrderDto>? orders;
    private List<MeliAccountDto>? accounts;
    private bool isLoading = true;
    private bool isSyncing;
    private int totalOrders;
    private DateTime dateFrom = DateTime.Today.AddDays(-30);
    private DateTime dateTo = DateTime.Today;

    // Sort state
    private string? sortColumn;
    private bool sortAsc = true;

    // Text filter state
    private Dictionary<string, string> textFilters = new();

    // Checkbox filter state (cuenta, estado)
    private string? activeFilterColumn;
    private Dictionary<string, HashSet<string>> checkboxFilters = new();
    private string checkboxSearchText = "";

    // Date filter state
    private bool showDateFilter;
    private bool dateFilterActive;

    // Detail modal state
    private bool showDetailModal;
    private bool isLoadingDetail;
    private MeliOrderDetailResponse? orderDetail;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
        await LoadOrders();
    }

    private async Task LoadAccounts()
    {
        try
        {
            accounts = await Api.GetMeliAccountsAsync();
        }
        catch { accounts = new(); }
    }

    private async Task SyncAndLoad()
    {
        isSyncing = true;
        StateHasChanged();

        try
        {
            await Api.SyncMeliOrdersAsync(dateFrom, dateTo.AddDays(1));
        }
        catch { }

        isSyncing = false;
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Api.GetMeliOrdersAsync(dateFrom, dateTo.AddDays(1), null);
            if (response is not null)
            {
                orders = response.Orders;
                totalOrders = response.Total;
            }
        }
        catch
        {
            ToastService.Error("Error al cargar las ordenes");
            orders = new();
        }

        isLoading = false;
    }

    private async Task SyncOrders()
    {
        isSyncing = true;

        try
        {
            var result = await Api.SyncMeliOrdersAsync(dateFrom, dateTo.AddDays(1));
            if (result is not null)
            {
                if (result.TotalErrors > 0)
                    ToastService.Warning($"Sincronizadas {result.TotalSynced} ordenes con {result.TotalErrors} errores");
                else
                    ToastService.Success($"Sincronizadas {result.TotalSynced} ordenes");
            }
            await LoadOrders();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al sincronizar: " + ex.Message);
        }

        isSyncing = false;
    }

    // --- Sort ---
    private void ToggleSort(string column)
    {
        activeFilterColumn = null; // Cerrar dropdown de filtro al ordenar
        if (sortColumn == column)
            sortAsc = !sortAsc;
        else
        {
            sortColumn = column;
            sortAsc = true;
        }
    }

    // --- Text Filters ---
    private void SetTextFilter(string column, string value)
    {
        textFilters[column] = value;
    }

    private string GetTextFilter(string column)
    {
        return textFilters.TryGetValue(column, out var val) ? val : "";
    }

    private bool IsFilterActive(string column)
    {
        return textFilters.TryGetValue(column, out var tv) && !string.IsNullOrEmpty(tv);
    }

    private void ClearTextFilter(string column)
    {
        textFilters.Remove(column);
    }

    // --- Checkbox Filters (Cuenta, Estado) ---
    private void ToggleDropdownFilter(string column)
    {
        if (activeFilterColumn == column)
            activeFilterColumn = null;
        else
        {
            activeFilterColumn = column;
            checkboxSearchText = "";
            showDateFilter = false;
        }
    }

    private void ToggleCheckboxValue(string column, string value)
    {
        if (!checkboxFilters.ContainsKey(column))
            checkboxFilters[column] = new HashSet<string>();
        if (!checkboxFilters[column].Remove(value))
            checkboxFilters[column].Add(value);
    }

    private bool IsCheckboxChecked(string column, string value)
    {
        return checkboxFilters.TryGetValue(column, out var set) && set.Contains(value);
    }

    private bool IsCheckboxFilterActive(string column)
    {
        return checkboxFilters.TryGetValue(column, out var cv) && cv.Count > 0;
    }

    private List<string> GetUniqueValues(string column)
    {
        if (orders is null) return new();
        var values = column switch
        {
            "cuenta" => orders.Select(o => o.AccountNickname).Distinct(),
            "estado" => orders.Select(o => GetStatusLabel(o.Status)).Distinct(),
            "envio" => orders.Select(o => GetShippingDisplayLabel(o.ShippingStatus, o.ShippingSubstatus)).Where(s => s != "-").Distinct(),
            _ => Enumerable.Empty<string>()
        };
        var list = values.OrderBy(v => v).ToList();
        if (!string.IsNullOrEmpty(checkboxSearchText))
            list = list.Where(v => v.Contains(checkboxSearchText, StringComparison.OrdinalIgnoreCase)).ToList();
        return list;
    }

    private void ClearCheckboxFilter(string column)
    {
        checkboxFilters.Remove(column);
        activeFilterColumn = null;
    }

    // --- Date Filter ---
    private void ToggleDateFilter()
    {
        showDateFilter = !showDateFilter;
        activeFilterColumn = null;
    }

    private void SetDatePreset(string preset)
    {
        var today = DateTime.Today;
        switch (preset)
        {
            case "hoy":
                dateFrom = today;
                dateTo = today;
                break;
            case "ayer":
                dateFrom = today.AddDays(-1);
                dateTo = today.AddDays(-1);
                break;
            case "7dias":
                dateFrom = today.AddDays(-7);
                dateTo = today;
                break;
            case "30dias":
                dateFrom = today.AddDays(-30);
                dateTo = today;
                break;
            case "estemes":
                dateFrom = new DateTime(today.Year, today.Month, 1);
                dateTo = today;
                break;
            case "mespasado":
                var firstOfMonth = new DateTime(today.Year, today.Month, 1);
                dateFrom = firstOfMonth.AddMonths(-1);
                dateTo = firstOfMonth.AddDays(-1);
                break;
        }
    }

    private async Task ApplyDateFilter()
    {
        showDateFilter = false;
        dateFilterActive = true;
        await LoadOrders();
    }

    private async Task ClearDateFilter()
    {
        dateFrom = DateTime.Today.AddDays(-30);
        dateTo = DateTime.Today;
        showDateFilter = false;
        dateFilterActive = false;
        await LoadOrders();
    }

    // --- General ---
    private void CloseAllDropdowns()
    {
        activeFilterColumn = null;
        showDateFilter = false;
    }

    private bool HasActiveFilters()
    {
        return textFilters.Any(f => !string.IsNullOrEmpty(f.Value))
            || checkboxFilters.Any(f => f.Value.Count > 0);
    }

    private void ClearAllFilters()
    {
        textFilters.Clear();
        checkboxFilters.Clear();
    }

    private string GetColumnLabel(string column) => column switch
    {
        "orden" => "Orden",
        "fecha" => "Fecha",
        "cuenta" => "Cuenta",
        "comprador" => "Comprador",
        "producto" => "Producto",
        "cantidad" => "Cant.",
        "precio" => "Precio Unit.",
        "total" => "Total",
        "estado" => "Estado",
        "envio" => "Envio",
        _ => column
    };

    // --- Filtered + Sorted + Grouped ---
    private List<OrderGroup> GetFilteredAndSortedOrders()
    {
        if (orders is null) return new();

        var filtered = orders.AsEnumerable();

        // Apply text filters
        foreach (var kv in textFilters.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            var search = kv.Value;
            filtered = kv.Key switch
            {
                "orden" => filtered.Where(o => o.MeliOrderId.ToString().Contains(search, StringComparison.OrdinalIgnoreCase)),
                "comprador" => filtered.Where(o => o.BuyerNickname.Contains(search, StringComparison.OrdinalIgnoreCase)),
                "producto" => filtered.Where(o => o.ItemTitle.Contains(search, StringComparison.OrdinalIgnoreCase)),
                _ => filtered
            };
        }

        // Apply checkbox filters
        foreach (var kv in checkboxFilters.Where(f => f.Value.Count > 0))
        {
            var values = kv.Value;
            filtered = kv.Key switch
            {
                "cuenta" => filtered.Where(o => values.Contains(o.AccountNickname)),
                "estado" => filtered.Where(o => values.Contains(GetStatusLabel(o.Status))),
                "envio" => filtered.Where(o => values.Contains(GetShippingDisplayLabel(o.ShippingStatus, o.ShippingSubstatus))),
                _ => filtered
            };
        }

        var list = filtered.ToList();

        // Sort
        if (sortColumn is not null)
        {
            list = sortColumn switch
            {
                "orden" => sortAsc ? list.OrderBy(o => o.MeliOrderId).ToList() : list.OrderByDescending(o => o.MeliOrderId).ToList(),
                "fecha" => sortAsc ? list.OrderBy(o => o.DateCreated).ToList() : list.OrderByDescending(o => o.DateCreated).ToList(),
                "cuenta" => sortAsc ? list.OrderBy(o => o.AccountNickname).ToList() : list.OrderByDescending(o => o.AccountNickname).ToList(),
                "comprador" => sortAsc ? list.OrderBy(o => o.BuyerNickname).ToList() : list.OrderByDescending(o => o.BuyerNickname).ToList(),
                "producto" => sortAsc ? list.OrderBy(o => o.ItemTitle).ToList() : list.OrderByDescending(o => o.ItemTitle).ToList(),
                "cantidad" => sortAsc ? list.OrderBy(o => o.Quantity).ToList() : list.OrderByDescending(o => o.Quantity).ToList(),
                "precio" => sortAsc ? list.OrderBy(o => o.UnitPrice).ToList() : list.OrderByDescending(o => o.UnitPrice).ToList(),
                "total" => sortAsc ? list.OrderBy(o => o.TotalAmount).ToList() : list.OrderByDescending(o => o.TotalAmount).ToList(),
                "estado" => sortAsc ? list.OrderBy(o => o.Status).ToList() : list.OrderByDescending(o => o.Status).ToList(),
                "envio" => sortAsc ? list.OrderBy(o => o.ShippingStatus ?? "").ToList() : list.OrderByDescending(o => o.ShippingStatus ?? "").ToList(),
                _ => list
            };
        }

        // Group by pack (only show as pack if 2+ products)
        var groups = new List<OrderGroup>();
        var packGroups = list.Where(o => o.PackId.HasValue).GroupBy(o => o.PackId!.Value);
        var singleOrders = list.Where(o => !o.PackId.HasValue).ToList();

        foreach (var g in packGroups)
        {
            if (g.Count() >= 2)
            {
                groups.Add(new OrderGroup
                {
                    IsPack = true,
                    PackId = g.Key,
                    Orders = g.ToList(),
                    SortDate = g.Max(o => o.DateCreated)
                });
            }
            else
            {
                // Pack de 1 solo producto: mostrar como orden individual
                singleOrders.AddRange(g);
            }
        }

        foreach (var o in singleOrders)
        {
            groups.Add(new OrderGroup
            {
                IsPack = false,
                Orders = new List<MeliOrderDto> { o },
                SortDate = o.DateCreated
            });
        }

        if (sortColumn is not null)
            return groups; // Already sorted via individual orders

        return groups.OrderByDescending(g => g.SortDate).ToList();
    }

    // --- Detail Modal ---
    private async Task ShowOrderDetail(long meliOrderId)
    {
        showDetailModal = true;
        isLoadingDetail = true;
        orderDetail = new MeliOrderDetailResponse();
        StateHasChanged();

        try
        {
            orderDetail = await Api.GetMeliOrderDetailAsync(meliOrderId);
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el detalle: " + ex.Message);
            showDetailModal = false;
        }

        isLoadingDetail = false;
        StateHasChanged();
    }

    private async Task ShowPackDetail(long packId)
    {
        showDetailModal = true;
        isLoadingDetail = true;
        orderDetail = new MeliOrderDetailResponse();
        StateHasChanged();

        try
        {
            orderDetail = await Api.GetMeliPackDetailAsync(packId);
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al cargar el detalle del pack: " + ex.Message);
            showDetailModal = false;
        }

        isLoadingDetail = false;
        StateHasChanged();
    }

    private void CloseDetailModal()
    {
        showDetailModal = false;
        orderDetail = null;
    }

