@page "/ordenes"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Ordenes de MercadoLibre (@totalOrders)</h3>
        <button class="btn btn-primary" @onclick="SyncOrders" disabled="@isSyncing">
            @(isSyncing ? "Sincronizando..." : "Sincronizar")
        </button>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando ordenes...</p>
        }
        else if (orders is null || !orders.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay ordenes en el rango seleccionado. Hace clic en "Sincronizar" para traer las ordenes de MercadoLibre.</p>
        }
        else
        {
            @if (HasActiveFilters())
            {
                <div class="active-filters-bar">
                    <span>Filtros activos:</span>
                    @foreach (var kv in textFilters.Where(f => !string.IsNullOrEmpty(f.Value)))
                    {
                        <span class="filter-tag">
                            @GetColumnLabel(kv.Key): "@kv.Value"
                            <button @onclick="() => ClearTextFilter(kv.Key)">&times;</button>
                        </span>
                    }
                    @foreach (var kv in checkboxFilters.Where(f => f.Value.Count > 0))
                    {
                        <span class="filter-tag">
                            @GetColumnLabel(kv.Key): @string.Join(", ", kv.Value)
                            <button @onclick="() => ClearCheckboxFilter(kv.Key)">&times;</button>
                        </span>
                    }
                    <button class="btn-clear-all" @onclick="ClearAllFilters">Limpiar todos</button>
                </div>
            }
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <!-- Orden: text input -->
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("orden") ? "has-filter" : "")" placeholder="Orden"
                                           value='@GetTextFilter("orden")' @oninput='(e) => SetTextFilter("orden", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("orden")' title="Ordenar">
                                        <span class="@(sortColumn == "orden" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "orden" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Fecha: label + sort + date dropdown -->
                            <th class="th-dropdown @(showDateFilter ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("fecha")'>Fecha</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("fecha")'>
                                            <span class="@(sortColumn == "fecha" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "fecha" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(dateFilterActive ? "filter-active" : "")" @onclick="ToggleDateFilter" @onclick:stopPropagation="true" title="Filtrar por fecha">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (showDateFilter)
                                {
                                    <div class="column-filter-dropdown date-filter-dropdown" @onclick:stopPropagation="true">
                                        <div class="date-filter-field">
                                            <label>DESDE:</label>
                                            <input type="date" class="form-input" @bind="dateFrom" />
                                        </div>
                                        <div class="date-filter-field">
                                            <label>HASTA:</label>
                                            <input type="date" class="form-input" @bind="dateTo" />
                                        </div>
                                        <div class="date-quick-buttons">
                                            <button class="date-quick-btn" @onclick='() => SetDatePreset("hoy")'>Hoy</button>
                                            <button class="date-quick-btn" @onclick='() => SetDatePreset("ayer")'>Ayer</button>
                                            <button class="date-quick-btn" @onclick='() => SetDatePreset("7dias")'>7 dias</button>
                                            <button class="date-quick-btn" @onclick='() => SetDatePreset("30dias")'>30 dias</button>
                                            <button class="date-quick-btn" @onclick='() => SetDatePreset("estemes")'>Este mes</button>
                                            <button class="date-quick-btn" @onclick='() => SetDatePreset("mespasado")'>Mes pasado</button>
                                        </div>
                                        <div class="date-filter-actions">
                                            <button class="btn btn-primary btn-sm" @onclick="ApplyDateFilter">Aplicar</button>
                                            <button class="btn btn-secondary btn-sm" @onclick="ClearDateFilter">Limpiar</button>
                                        </div>
                                    </div>
                                }
                            </th>
                            <!-- Cuenta: label + sort + checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "cuenta" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("cuenta")'>Cuenta</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("cuenta")'>
                                            <span class="@(sortColumn == "cuenta" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "cuenta" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("cuenta") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("cuenta")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "cuenta")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <input type="text" class="filter-search-input" placeholder="Buscar..." @bind="checkboxSearchText" @bind:event="oninput" />
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("cuenta"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("cuenta", v)" @onchange='() => ToggleCheckboxValue("cuenta", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("cuenta"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("cuenta")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Comprador: text input -->
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("comprador") ? "has-filter" : "")" placeholder="Comprador"
                                           value='@GetTextFilter("comprador")' @oninput='(e) => SetTextFilter("comprador", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("comprador")' title="Ordenar">
                                        <span class="@(sortColumn == "comprador" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "comprador" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Foto: no sort/filter -->
                            <th style="width: 50px; text-align: center;">
                                <div class="th-inner"><span class="th-label">Foto</span></div>
                            </th>
                            <!-- Producto: text input -->
                            <th class="th-filterable">
                                <div class="th-filter-inner">
                                    <input type="text" class="th-filter-input @(IsFilterActive("producto") ? "has-filter" : "")" placeholder="Producto"
                                           value='@GetTextFilter("producto")' @oninput='(e) => SetTextFilter("producto", e.Value?.ToString() ?? "")' />
                                    <span class="sort-icon" @onclick='() => ToggleSort("producto")' title="Ordenar">
                                        <span class="@(sortColumn == "producto" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "producto" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Cant: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("cantidad")'>
                                <div class="th-inner">
                                    <span class="th-label">Cant.</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "cantidad" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "cantidad" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Precio: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("precio")'>
                                <div class="th-inner">
                                    <span class="th-label">Precio U.</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "precio" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "precio" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Total: sort only -->
                            <th class="th-sortable" @onclick='() => ToggleSort("total")'>
                                <div class="th-inner">
                                    <span class="th-label">Total</span>
                                    <span class="sort-icon">
                                        <span class="@(sortColumn == "total" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                        <span class="@(sortColumn == "total" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                    </span>
                                </div>
                            </th>
                            <!-- Estado: label + sort + checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "estado" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("estado")'>Estado</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("estado")'>
                                            <span class="@(sortColumn == "estado" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "estado" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("estado") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("estado")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "estado")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <input type="text" class="filter-search-input" placeholder="Buscar..." @bind="checkboxSearchText" @bind:event="oninput" />
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("estado"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("estado", v)" @onchange='() => ToggleCheckboxValue("estado", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("estado"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("estado")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                            <!-- Envio: label + sort + checkbox dropdown -->
                            <th class="th-dropdown @(activeFilterColumn == "envio" ? "filter-open" : "")">
                                <div class="th-inner">
                                    <span class="th-label" @onclick='() => ToggleSort("envio")'>Envio</span>
                                    <span class="th-icons">
                                        <span class="sort-icon" @onclick='() => ToggleSort("envio")'>
                                            <span class="@(sortColumn == "envio" && sortAsc ? "sort-up-active" : "")">&#9650;</span>
                                            <span class="@(sortColumn == "envio" && !sortAsc ? "sort-down-active" : "")">&#9660;</span>
                                        </span>
                                        <button class="filter-btn @(IsCheckboxFilterActive("envio") ? "filter-active" : "")" @onclick='() => ToggleDropdownFilter("envio")' @onclick:stopPropagation="true" title="Filtrar">
                                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                                        </button>
                                    </span>
                                </div>
                                @if (activeFilterColumn == "envio")
                                {
                                    <div class="column-filter-dropdown" @onclick:stopPropagation="true">
                                        <input type="text" class="filter-search-input" placeholder="Buscar..." @bind="checkboxSearchText" @bind:event="oninput" />
                                        <div class="filter-checkbox-list">
                                            @foreach (var val in GetUniqueValues("envio"))
                                            {
                                                var v = val;
                                                <label class="filter-checkbox-item">
                                                    <input type="checkbox" checked="@IsCheckboxChecked("envio", v)" @onchange='() => ToggleCheckboxValue("envio", v)' />
                                                    @v
                                                </label>
                                            }
                                        </div>
                                        @if (IsCheckboxFilterActive("envio"))
                                        {
                                            <div class="filter-actions"><button class="filter-clear-btn" @onclick='() => ClearCheckboxFilter("envio")'>Limpiar</button></div>
                                        }
                                    </div>
                                }
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in GetFilteredAndSortedOrders())
                        {
                            @if (group.IsPack)
                            {
                                <tr class="pack-header-row clickable-row" @onclick="() => ShowPackDetail(group.PackId!.Value)">
                                    <td><strong>Pack @group.PackId</strong></td>
                                    <td>@group.Orders.First().DateCreated.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@group.Orders.First().AccountNickname</td>
                                    <td>@group.Orders.First().BuyerNickname</td>
                                    <td></td>
                                    <td><em>@group.Orders.Count productos</em></td>
                                    <td>@group.Orders.Sum(o => o.Quantity)</td>
                                    <td></td>
                                    <td><strong>@group.Orders.First().CurrencyId @(group.Orders.Sum(o => o.UnitPrice * o.Quantity).ToString("N2"))</strong></td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(group.Orders.First().Status)">
                                            @GetStatusLabel(group.Orders.First().Status)
                                        </span>
                                    </td>
                                    <td class="td-shipping-status">
                                        @{ var gFirst = group.Orders.First(); }
                                        @if (!string.IsNullOrEmpty(gFirst.ShippingStatus))
                                        {
                                            <span class="status-badge @GetShippingStatusClass(gFirst.ShippingStatus, gFirst.ShippingSubstatus)">
                                                @GetShippingDisplayLabel(gFirst.ShippingStatus, gFirst.ShippingSubstatus)
                                            </span>
                                        }
                                    </td>
                                </tr>
                                @foreach (var order in group.Orders)
                                {
                                    <tr class="pack-item-row clickable-row" @onclick="() => ShowPackDetail(group.PackId!.Value)">
                                        <td class="pack-indent">@order.MeliOrderId</td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td class="td-thumbnail">
                                            @if (!string.IsNullOrEmpty(order.ItemThumbnailUrl))
                                            {
                                                <img src="@order.ItemThumbnailUrl" alt="" class="order-thumbnail" />
                                            }
                                        </td>
                                        <td title="@order.ItemId">@Truncate(order.ItemTitle, 40)</td>
                                        <td>@order.Quantity</td>
                                        <td>
                                            @if (order.FullUnitPrice.HasValue && order.FullUnitPrice.Value > order.UnitPrice)
                                            {
                                                <span class="price-original">@order.CurrencyId @order.FullUnitPrice.Value.ToString("N2")</span>
                                            }
                                            <span>@order.CurrencyId @order.UnitPrice.ToString("N2")</span>
                                        </td>
                                        <td>@order.CurrencyId @((order.UnitPrice * order.Quantity).ToString("N2"))</td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                var order = group.Orders.First();
                                <tr class="clickable-row" @onclick="() => ShowOrderDetail(order.MeliOrderId)">
                                    <td><strong>@order.MeliOrderId</strong></td>
                                    <td>@order.DateCreated.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@order.AccountNickname</td>
                                    <td>@order.BuyerNickname</td>
                                    <td class="td-thumbnail">
                                        @if (!string.IsNullOrEmpty(order.ItemThumbnailUrl))
                                        {
                                            <img src="@order.ItemThumbnailUrl" alt="" class="order-thumbnail" />
                                        }
                                    </td>
                                    <td title="@order.ItemId">@Truncate(order.ItemTitle, 40)</td>
                                    <td>@order.Quantity</td>
                                    <td>
                                        @if (order.FullUnitPrice.HasValue && order.FullUnitPrice.Value > order.UnitPrice)
                                        {
                                            <span class="price-original">@order.CurrencyId @order.FullUnitPrice.Value.ToString("N2")</span>
                                        }
                                        <span>@order.CurrencyId @order.UnitPrice.ToString("N2")</span>
                                    </td>
                                    <td><strong>@order.CurrencyId @order.TotalAmount.ToString("N2")</strong></td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(order.Status)">
                                            @GetStatusLabel(order.Status)
                                        </span>
                                    </td>
                                    <td class="td-shipping-status">
                                        @if (!string.IsNullOrEmpty(order.ShippingStatus))
                                        {
                                            <span class="status-badge @GetShippingStatusClass(order.ShippingStatus, order.ShippingSubstatus)">
                                                @GetShippingDisplayLabel(order.ShippingStatus, order.ShippingSubstatus)
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (activeFilterColumn is not null || showDateFilter)
{
    <div class="filter-overlay" @onclick="CloseAllDropdowns"></div>
}

@if (showDetailModal && orderDetail is not null)
{
    <div class="modal-overlay" @onclick="CloseDetailModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>
                    @if (orderDetail.Orders.Count > 1)
                    {
                        <span>Pack - @orderDetail.Orders.Count ordenes</span>
                    }
                    else
                    {
                        <span>Orden #@orderDetail.Orders.First().MeliOrderId</span>
                    }
                </h3>
                <button class="modal-close" @onclick="CloseDetailModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (isLoadingDetail)
                {
                    <p class="text-muted">Cargando detalle...</p>
                }
                else
                {
                    @foreach (var od in orderDetail.Orders)
                    {
                        <div class="detail-order-section @(orderDetail.Orders.Count > 1 ? "multi-order" : "")">
                            @if (orderDetail.Orders.Count > 1)
                            {
                                <div class="detail-order-title">Orden #@od.MeliOrderId</div>
                            }

                            <!-- Order info header -->
                            <div class="detail-info-grid">
                                <div class="detail-info-item">
                                    <span class="detail-label">Fecha</span>
                                    <span class="detail-value">@od.DateCreated.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Estado</span>
                                    <span class="status-badge @GetStatusClass(od.Status)">@GetStatusLabel(od.Status)</span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">Comprador</span>
                                    <span class="detail-value">
                                        @if (!string.IsNullOrEmpty(od.BuyerFirstName) || !string.IsNullOrEmpty(od.BuyerLastName))
                                        {
                                            @($"{od.BuyerFirstName} {od.BuyerLastName}".Trim())
                                            <small style="color: #6b7280;"> (@od.BuyerNickname)</small>
                                        }
                                        else
                                        {
                                            @od.BuyerNickname
                                        }
                                    </span>
                                </div>
                                <div class="detail-info-item">
                                    <span class="detail-label">N° Operacion</span>
                                    <span class="detail-value">@od.MeliOrderId</span>
                                </div>
                            </div>

                            <!-- Products -->
                            <div class="detail-section">
                                <h4>Productos</h4>
                                @foreach (var item in od.Items)
                                {
                                    <div class="detail-product">
                                        <div class="detail-product-thumb">
                                            @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                            {
                                                <img src="@item.ThumbnailUrl" alt="@item.Title" />
                                            }
                                            else
                                            {
                                                <div class="thumb-placeholder">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="#9ca3af"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                                                </div>
                                            }
                                        </div>
                                        <div class="detail-product-info">
                                            <div class="detail-product-title">@item.Title</div>
                                            <div class="detail-product-id">ID: @item.ItemId</div>
                                            <div class="detail-product-qty">Cantidad: @item.Quantity x @od.CurrencyId @item.UnitPrice.ToString("N2")</div>
                                        </div>
                                        <div class="detail-product-price">
                                            <strong>@od.CurrencyId @((item.UnitPrice * item.Quantity).ToString("N2"))</strong>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Breakdown -->
                            <div class="detail-section">
                                <h4>Desglose</h4>
                                <div class="detail-breakdown">
                                    <div class="breakdown-row">
                                        <span>Precio del producto</span>
                                        <span>@od.CurrencyId @od.Items.Sum(i => i.UnitPrice * i.Quantity).ToString("N2")</span>
                                    </div>
                                    @if (od.TotalSaleFee.HasValue && od.TotalSaleFee.Value > 0)
                                    {
                                        <div class="breakdown-row deduction">
                                            <span>Comision de venta</span>
                                            <span>-@od.CurrencyId @od.TotalSaleFee.Value.ToString("N2")</span>
                                        </div>
                                    }
                                    @if (od.ShippingCost.HasValue && od.ShippingCost.Value > 0)
                                    {
                                        <div class="breakdown-row deduction">
                                            <span>Costo de envio</span>
                                            <span>-@od.CurrencyId @od.ShippingCost.Value.ToString("N2")</span>
                                        </div>
                                    }
                                    @if (od.TaxesAmount.HasValue && od.TaxesAmount.Value > 0)
                                    {
                                        <div class="breakdown-row deduction">
                                            <span>Impuestos / Retenciones</span>
                                            <span>-@od.CurrencyId @od.TaxesAmount.Value.ToString("N2")</span>
                                        </div>
                                    }
                                    <div class="breakdown-row total">
                                        <span>Total de la venta</span>
                                        <span>@od.CurrencyId @od.TotalAmount.ToString("N2")</span>
                                    </div>
                                    @{
                                        var totalToReceive = od.Items.Sum(i => i.UnitPrice * i.Quantity)
                                            - (od.TotalSaleFee ?? 0)
                                            - (od.ShippingCost ?? 0)
                                            - (od.TaxesAmount ?? 0);
                                    }
                                    @if (totalToReceive != od.TotalAmount)
                                    {
                                        <div class="breakdown-row total highlight">
                                            <span>Total a recibir</span>
                                            <span>@od.CurrencyId @totalToReceive.ToString("N2")</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Payments -->
                            @if (od.Payments.Any())
                            {
                                <div class="detail-section">
                                    <h4>Pago</h4>
                                    @foreach (var pay in od.Payments)
                                    {
                                        <div class="detail-payment">
                                            <div class="payment-method">
                                                <strong>@GetPaymentMethodLabel(pay.PaymentMethodId) @GetPaymentTypeLabel(pay.PaymentType)</strong>
                                                @if (pay.Installments.HasValue && pay.Installments.Value > 1)
                                                {
                                                    <span class="payment-installments">(@pay.Installments cuotas)</span>
                                                }
                                            </div>
                                            <div class="payment-details">
                                                <span>Monto: @od.CurrencyId @pay.TotalPaidAmount.ToString("N2")</span>
                                                <span class="payment-status @GetPaymentStatusClass(pay.Status)">@GetPaymentStatusLabel(pay.Status)</span>
                                            </div>
                                            @if (pay.DateApproved.HasValue)
                                            {
                                                <div class="payment-date">Aprobado: @pay.DateApproved.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseDetailModal">Cerrar</button>
            </div>
        </div>
    </div>
}

