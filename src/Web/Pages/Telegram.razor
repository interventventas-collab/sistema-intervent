@page "/integraciones/telegram"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Telegram</PageTitle>

<div class="page-container" style="max-width:860px;">
    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem;">
        <span style="font-size:1.6rem;">📲</span>
        <h1 style="margin:0;">Telegram</h1>
    </div>
    <p style="color:#64748b;margin-top:0;">
        Cada bot tiene un trabajo: <b>📣 Avisos</b> te manda las novedades (ventas, alertas, fichadas),
        <b>🤖 Funciones</b> contesta consultas (ventas, saldo, precios) y <b>🧾 Preventas</b> es el chat
        para cargar preventas. Podés vincular <b>varias personas</b> a cada bot y elegir qué recibe cada una.
    </p>

    @if (loading)
    {
        <p style="color:#94a3b8;">Cargando…</p>
    }
    else
    {
        <!-- ═══════════════ 📣 BOT DE AVISOS ═══════════════ -->
        <div class="card" style="padding:1.2rem 1.4rem;margin-bottom:1.6rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                <h3 style="margin:0;">📣 Bot de Avisos <span style="font-weight:400;color:#94a3b8;font-size:0.85rem;">(solo manda avisos)</span></h3>
                @EstadoChip(account)
            </div>
            <p style="color:#64748b;font-size:0.9rem;margin:0.6rem 0 1rem;">
                Manda las ventas nuevas de MercadoLibre, tus alertas y las fichadas. Pegá el <b>token</b>
                que te dio <b>@@BotFather</b> (algo como <code>123456789:AA...</code>).
            </p>
            @if (account?.BotUsername is not null)
            {
                <p style="color:#334155;font-size:0.9rem;margin:0 0 0.6rem;">Bot: <b>@@@account.BotUsername</b></p>
            }
            <div>
                <label style="font-weight:600;font-size:0.85rem;">Token del bot</label>
                <input @bind="botToken" type="password"
                       placeholder="@(account?.HasToken == true ? "•••• (ya guardado)" : "123456789:AAE...")"
                       class="form-control" style="width:100%;" />
            </div>
            <div style="display:flex;align-items:center;gap:0.8rem;margin-top:1rem;flex-wrap:wrap;">
                <button class="btn btn-primary" @onclick="Guardar" disabled="@saving">@(saving ? "Guardando…" : "Guardar token")</button>
                <button class="btn btn-secondary" @onclick="Probar" disabled="@(probando || account?.HasToken != true)">@(probando ? "Probando…" : "Probar conexión")</button>
                @if (account is not null && account.HasToken && account.PersonasVinculadas > 0)
                {
                    <button class="btn btn-secondary" @onclick="TestMensaje" disabled="@testando">@(testando ? "Mandando…" : "📤 Mensaje de prueba a todos")</button>
                }
                @if (account is not null && !account.LastSyncOk && !string.IsNullOrEmpty(account.LastError))
                {
                    <span style="color:#b91c1c;font-size:0.88rem;">⚠ @account.LastError</span>
                }
            </div>

            @if (account is not null && account.HasToken)
            {
                @PersonasSection(avisosChats, true, "AVISOS")
                @CodigoSection(account, "AVISOS")
            }

            <div style="margin-top:1rem;padding:0.8rem 1rem;border-radius:10px;background:#f8fbff;border:1px solid #e2e8f0;font-size:0.88rem;color:#334155;">
                🔔 <b>¿Qué avisos existen?</b> Eso se maneja desde <a href="/mis-alertas">Mis Alertas</a>: ahí
                elegís qué cosas avisan por Telegram. Y acá arriba, con los tildes de cada persona, elegís
                <b>a quién</b> le llega cada tipo de aviso.
            </div>
        </div>

        <!-- ═══════════════ 🤖 BOT DE FUNCIONES ═══════════════ -->
        <div class="card" style="padding:1.2rem 1.4rem;margin-bottom:1.6rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                <h3 style="margin:0;">🤖 Bot de Funciones <span style="font-weight:400;color:#94a3b8;font-size:0.85rem;">(contesta consultas)</span></h3>
                @EstadoChip(funcionesAccount)
            </div>
            <p style="color:#64748b;font-size:0.9rem;margin:0.6rem 0 1rem;">
                Un chat aparte para <b>preguntarle cosas</b>: <b>ventas</b>, <b>saldo</b>, <b>shell</b>,
                <b>alertas</b>, <b>precio C3622AZ</b>… Así el chat de Avisos queda limpio, solo con novedades.
                Creá otro bot con <b>@@BotFather</b> y pegá su token acá.
            </p>
            @if (funcionesAccount?.BotUsername is not null)
            {
                <p style="color:#334155;font-size:0.9rem;margin:0 0 0.6rem;">Bot: <b>@@@funcionesAccount.BotUsername</b></p>
            }
            <div>
                <label style="font-weight:600;font-size:0.85rem;">Token del bot de Funciones</label>
                <input @bind="funcionesToken" type="password"
                       placeholder="@(funcionesAccount?.HasToken == true ? "•••• (ya guardado)" : "123456789:AAE...")"
                       class="form-control" style="width:100%;" />
            </div>
            <div style="display:flex;align-items:center;gap:0.8rem;margin-top:1rem;flex-wrap:wrap;">
                <button class="btn btn-primary" @onclick="GuardarFunciones" disabled="@savingFn">@(savingFn ? "Guardando…" : "Guardar token")</button>
                <button class="btn btn-secondary" @onclick="ProbarFunciones" disabled="@(probandoFn || funcionesAccount?.HasToken != true)">@(probandoFn ? "Probando…" : "Probar conexión")</button>
                @if (funcionesAccount is not null && !funcionesAccount.LastSyncOk && !string.IsNullOrEmpty(funcionesAccount.LastError))
                {
                    <span style="color:#b91c1c;font-size:0.88rem;">⚠ @funcionesAccount.LastError</span>
                }
            </div>

            @if (funcionesAccount is not null && funcionesAccount.HasToken)
            {
                @PersonasSection(funcionesChats, false, "FUNCIONES")
                @CodigoSection(funcionesAccount, "FUNCIONES")
            }
        </div>

        <!-- ═══════════════ 🧾 BOT DE PREVENTAS (igual que siempre) ═══════════════ -->
        <div class="card" style="padding:1.2rem 1.4rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                <h3 style="margin:0;">🧾 Bot de Preventas <span style="font-weight:400;color:#94a3b8;font-size:0.85rem;">(chat aparte, una sola persona)</span></h3>
                @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is not null && preventaAccount.LastSyncOk)
                {
                    <span style="background:#dcfce7;color:#166534;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">✓ Conectado y vinculado</span>
                }
                else if (preventaAccount is not null && preventaAccount.HasToken)
                {
                    <span style="background:#fef9c3;color:#854d0e;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Token guardado — falta vincular</span>
                }
                else
                {
                    <span style="background:#fee2e2;color:#991b1b;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Sin conectar</span>
                }
            </div>
            <p style="color:#64748b;font-size:0.9rem;margin:0.6rem 0 1rem;">
                Chat aparte donde solo se cargan preventas (así no se mezclan con los avisos).
            </p>
            @if (preventaAccount?.BotUsername is not null)
            {
                <p style="color:#334155;font-size:0.9rem;margin:0 0 0.6rem;">Bot: <b>@@@preventaAccount.BotUsername</b>@(preventaAccount.ChatId is not null ? " · vinculado ✓" : "")</p>
            }
            <div>
                <label style="font-weight:600;font-size:0.85rem;">Token del bot de Preventas</label>
                <input @bind="preventaToken" type="password"
                       placeholder="@(preventaAccount?.HasToken == true ? "•••• (ya guardado)" : "123456789:AAE...")"
                       class="form-control" style="width:100%;" />
            </div>
            <div style="display:flex;align-items:center;gap:0.8rem;margin-top:1rem;flex-wrap:wrap;">
                <button class="btn btn-primary" @onclick="GuardarPreventa" disabled="@savingPv">@(savingPv ? "Guardando…" : "Guardar token")</button>
                <button class="btn btn-secondary" @onclick="ProbarPreventa" disabled="@(probandoPv || preventaAccount?.HasToken != true)">@(probandoPv ? "Probando…" : "Probar y mandar mensaje")</button>
                @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is null)
                {
                    <button class="btn btn-secondary" @onclick="VincularPreventa" disabled="@vinculandoPv">@(vinculandoPv ? "Buscando…" : "🔗 Vincular")</button>
                }
                @if (preventaAccount is not null && !preventaAccount.LastSyncOk && !string.IsNullOrEmpty(preventaAccount.LastError))
                {
                    <span style="color:#b91c1c;font-size:0.88rem;">⚠ @preventaAccount.LastError</span>
                }
            </div>
            @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is null)
            {
                <p style="color:#64748b;font-size:0.86rem;margin:0.7rem 0 0;">Para vincular: abrí el bot de Preventas en Telegram, escribile <b>hola</b>, y apretá "Probar" (o "Vincular").</p>
            }
            @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is not null && preventaAccount.LastSyncOk)
            {
                <p style="color:#16a34a;font-size:0.88rem;margin:0.7rem 0 0;">✅ Listo. Abrí el chat del bot de Preventas y escribile <b>nueva</b> para cargar una preventa.</p>
            }
            @if (preventaAccount is not null && preventaAccount.HasToken)
            {
                <div style="margin-top:0.9rem;padding-top:0.8rem;border-top:1px solid #f1f5f9;font-size:0.86rem;color:#475569;">
                    🔒 <b>Código de seguridad</b>: <span style="font-family:monospace;font-size:1rem;background:#f1f5f9;padding:0.1rem 0.5rem;border-radius:6px;">@preventaAccount.VinculacionCode</span>
                    @if (preventaAccount.ChatId is not null)
                    {
                        <button class="btn btn-secondary btn-sm" style="margin-left:0.6rem;" @onclick="DesvincularPreventa" disabled="@desvincPv">
                            @(desvincPv ? "…" : "Desvincular")
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private TelegramAccountDto? account;          // 📣 AVISOS
    private TelegramAccountDto? funcionesAccount; // 🤖 FUNCIONES
    private TelegramAccountDto? preventaAccount;  // 🧾 PREVENTAS

    private List<TelegramChatDto> avisosChats = new();
    private List<TelegramChatDto> funcionesChats = new();

    private bool loading = true, saving = false, probando = false, testando = false;
    private bool savingFn = false, probandoFn = false;
    private bool savingPv = false, probandoPv = false, vinculandoPv = false, desvincPv = false;

    private string botToken = "";
    private string funcionesToken = "";
    private string preventaToken = "";

    // ═══════════ Fragmentos compartidos (personas vinculadas + código) ═══════════

    private RenderFragment EstadoChip(TelegramAccountDto? a) => @<text>
        @if (a is not null && a.HasToken && a.PersonasVinculadas > 0 && a.LastSyncOk)
        {
            <span style="background:#dcfce7;color:#166534;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">✓ Conectado · @a.PersonasVinculadas persona@(a.PersonasVinculadas == 1 ? "" : "s")</span>
        }
        else if (a is not null && a.HasToken)
        {
            <span style="background:#fef9c3;color:#854d0e;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Token guardado — falta vincular gente</span>
        }
        else
        {
            <span style="background:#fee2e2;color:#991b1b;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Sin conectar</span>
        }
    </text>;

    private RenderFragment PersonasSection(List<TelegramChatDto> chats, bool conTildes, string proposito) => @<div style="margin-top:1.1rem;padding-top:0.9rem;border-top:1px solid #f1f5f9;">
        <h4 style="margin:0 0 0.5rem;font-size:0.98rem;">👥 Personas vinculadas</h4>
        @if (chats.Count == 0)
        {
            <p style="color:#94a3b8;font-size:0.88rem;margin:0 0 0.5rem;">Todavía no hay nadie vinculado. Pasale el código de seguridad (acá abajo) a la persona: lo manda al bot desde su Telegram y aparece en esta lista.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
                    <thead>
                        <tr style="text-align:left;color:#64748b;font-size:0.8rem;">
                            <th style="padding:0.3rem 0.5rem;">Nombre</th>
                            @if (conTildes)
                            {
                                <th style="padding:0.3rem 0.5rem;text-align:center;">🛒 Ventas</th>
                                <th style="padding:0.3rem 0.5rem;text-align:center;">🔔 Alertas</th>
                                <th style="padding:0.3rem 0.5rem;text-align:center;">🕐 Fichadas</th>
                            }
                            <th style="padding:0.3rem 0.5rem;">Desde</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in chats)
                        {
                            var chat = c;
                            <tr style="border-top:1px solid #f1f5f9;">
                                <td style="padding:0.35rem 0.5rem;">
                                    <input value="@chat.Nombre" class="form-control" style="max-width:180px;font-size:0.88rem;padding:0.25rem 0.5rem;"
                                           placeholder="(sin nombre)"
                                           @onchange="@(async e => await CambiarNombre(chat, e.Value?.ToString(), proposito))" />
                                </td>
                                @if (conTildes)
                                {
                                    <td style="padding:0.35rem 0.5rem;text-align:center;">
                                        <input type="checkbox" checked="@chat.NotifVentas" style="width:1.1rem;height:1.1rem;cursor:pointer;"
                                               @onchange="@(async e => { chat.NotifVentas = (bool)e.Value!; await GuardarChat(chat, proposito); })" />
                                    </td>
                                    <td style="padding:0.35rem 0.5rem;text-align:center;">
                                        <input type="checkbox" checked="@chat.NotifAlertas" style="width:1.1rem;height:1.1rem;cursor:pointer;"
                                               @onchange="@(async e => { chat.NotifAlertas = (bool)e.Value!; await GuardarChat(chat, proposito); })" />
                                    </td>
                                    <td style="padding:0.35rem 0.5rem;text-align:center;">
                                        <input type="checkbox" checked="@chat.NotifFichadas" style="width:1.1rem;height:1.1rem;cursor:pointer;"
                                               @onchange="@(async e => { chat.NotifFichadas = (bool)e.Value!; await GuardarChat(chat, proposito); })" />
                                    </td>
                                }
                                <td style="padding:0.35rem 0.5rem;color:#94a3b8;font-size:0.82rem;white-space:nowrap;">@chat.CreatedAt.AddHours(-3).ToString("dd/MM/yy")</td>
                                <td style="padding:0.35rem 0.5rem;text-align:right;">
                                    <button class="btn btn-secondary btn-sm" style="color:#b91c1c;" @onclick="@(async () => await QuitarChat(chat, proposito))">Quitar</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (conTildes)
            {
                <p style="color:#94a3b8;font-size:0.8rem;margin:0.4rem 0 0;">Los tildes eligen qué avisos le llegan a cada persona. Los recién vinculados arrancan sin nada: prendeles lo que quieras que reciban.</p>
            }
        }
    </div>;

    private RenderFragment CodigoSection(TelegramAccountDto a, string proposito) => @<div style="margin-top:0.9rem;padding-top:0.8rem;border-top:1px solid #f1f5f9;font-size:0.86rem;color:#475569;">
        🔒 <b>Código de seguridad para sumar gente</b>:
        <span style="font-family:monospace;font-size:1rem;background:#f1f5f9;padding:0.1rem 0.5rem;border-radius:6px;">@a.VinculacionCode</span>
        <button class="btn btn-secondary btn-sm" style="margin-left:0.6rem;" @onclick="@(async () => await RegenerarCodigo(proposito))">↻ Generar otro</button>
        <div style="color:#94a3b8;font-size:0.8rem;margin-top:0.3rem;">
            Pasale este código a la persona que quieras sumar. Ella abre el bot en Telegram (@(string.IsNullOrEmpty(a.BotUsername) ? "buscalo por nombre" : $"@{a.BotUsername}")),
            le manda el código, y queda vinculada. Después de cada alta el código cambia solo, así nadie lo reusa sin que lo sepas.
        </div>
    </div>;

    // ═══════════ Carga ═══════════

    protected override async Task OnInitializedAsync()
    {
        await CargarTodo();
        loading = false;
    }

    private async Task CargarTodo()
    {
        try
        {
            account = await Api.GetTelegramAccountAsync();
            funcionesAccount = await Api.GetTelegramAccountAsync("FUNCIONES");
            preventaAccount = await Api.GetTelegramAccountAsync("PREVENTAS");
            avisosChats = (account?.HasToken == true ? await Api.GetTelegramChatsAsync("AVISOS") : null) ?? new();
            funcionesChats = (funcionesAccount?.HasToken == true ? await Api.GetTelegramChatsAsync("FUNCIONES") : null) ?? new();
        }
        catch (Exception ex) { ToastService.Error("No se pudo leer la configuración: " + ex.Message); }
    }

    private async Task RecargarChats(string proposito)
    {
        try
        {
            if (proposito == "AVISOS")
            {
                avisosChats = await Api.GetTelegramChatsAsync("AVISOS") ?? new();
                account = await Api.GetTelegramAccountAsync();
            }
            else
            {
                funcionesChats = await Api.GetTelegramChatsAsync("FUNCIONES") ?? new();
                funcionesAccount = await Api.GetTelegramAccountAsync("FUNCIONES");
            }
        }
        catch { }
    }

    // ═══════════ Personas vinculadas ═══════════

    private async Task GuardarChat(TelegramChatDto chat, string proposito)
    {
        try
        {
            var res = await Api.UpdateTelegramChatAsync(chat.Id, new UpdateTelegramChatRequest
            {
                Nombre = chat.Nombre,
                NotifVentas = chat.NotifVentas,
                NotifAlertas = chat.NotifAlertas,
                NotifFichadas = chat.NotifFichadas
            });
            if (res is null) { ToastService.Error("No se pudo guardar."); await RecargarChats(proposito); }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); await RecargarChats(proposito); }
    }

    private async Task CambiarNombre(TelegramChatDto chat, string? nombre, string proposito)
    {
        chat.Nombre = nombre;
        await GuardarChat(chat, proposito);
    }

    private async Task QuitarChat(TelegramChatDto chat, string proposito)
    {
        var quien = string.IsNullOrWhiteSpace(chat.Nombre) ? "esta persona" : chat.Nombre;
        var ok = await JS.InvokeAsync<bool>("confirm", $"¿Quitar a {quien}? Deja de recibir avisos y el bot no le contesta más. Para volver, necesita el código de seguridad nuevo.");
        if (!ok) return;
        try
        {
            var res = await Api.DeleteTelegramChatAsync(chat.Id);
            if (res) ToastService.Success($"Listo, {quien} quedó desvinculado.");
            await RecargarChats(proposito);
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    private async Task RegenerarCodigo(string proposito)
    {
        try
        {
            var res = await Api.RegenerarCodigoTelegramAsync(proposito);
            if (res is not null)
            {
                if (proposito == "AVISOS") account = res; else if (proposito == "FUNCIONES") funcionesAccount = res;
                ToastService.Success("Código nuevo generado. El anterior ya no sirve.");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
    }

    // ═══════════ 📣 Avisos ═══════════

    private async Task Guardar()
    {
        saving = true;
        try
        {
            var req = new SaveTelegramAccountRequest
            {
                BotToken = string.IsNullOrWhiteSpace(botToken) ? null : botToken.Trim(),
                IsActive = true
            };
            var res = await Api.SaveTelegramAccountAsync(req);
            if (res is not null)
            {
                account = res;
                botToken = "";
                ToastService.Success("Token guardado. Ahora probá la conexión.");
                await RecargarChats("AVISOS");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { saving = false; }
    }

    private async Task Probar()
    {
        probando = true;
        try
        {
            var res = await Api.ProbarTelegramAsync();
            if (res is not null && res.Ok)
            {
                if (res.TestEnviado) ToastService.Success("¡Conexión OK! Les mandé un mensaje de prueba a los vinculados.");
                else ToastService.Success("¡Token OK! Ahora vinculá gente con el código de seguridad.");
            }
            else ToastService.Error(res?.Error ?? "No se pudo conectar con Telegram.");
            await CargarTodo();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { probando = false; }
    }

    private async Task TestMensaje()
    {
        testando = true;
        try
        {
            var res = await Api.TestMensajeTelegramAsync();
            if (res is not null && res.Ok) ToastService.Success("Mensaje enviado a todas las personas vinculadas. 📲");
            else ToastService.Error(res?.Error ?? "No se pudo enviar el mensaje.");
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { testando = false; }
    }

    // ═══════════ 🤖 Funciones ═══════════

    private async Task GuardarFunciones()
    {
        savingFn = true;
        try
        {
            var req = new SaveTelegramAccountRequest
            {
                BotToken = string.IsNullOrWhiteSpace(funcionesToken) ? null : funcionesToken.Trim(),
                IsActive = true
            };
            var res = await Api.SaveTelegramAccountAsync(req, "FUNCIONES");
            if (res is not null)
            {
                funcionesAccount = res;
                funcionesToken = "";
                ToastService.Success("Token del bot de Funciones guardado. Ahora probá la conexión.");
                await RecargarChats("FUNCIONES");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { savingFn = false; }
    }

    private async Task ProbarFunciones()
    {
        probandoFn = true;
        try
        {
            var res = await Api.ProbarTelegramAsync("FUNCIONES");
            if (res is not null && res.Ok)
            {
                if (res.TestEnviado) ToastService.Success("¡Conexión OK! Les mandé un mensaje a los vinculados.");
                else ToastService.Success("¡Token OK! Ahora vinculate con el código de seguridad.");
            }
            else ToastService.Error(res?.Error ?? "No se pudo conectar con el bot de Funciones.");
            await CargarTodo();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { probandoFn = false; }
    }

    // ═══════════ 🧾 Preventas (igual que siempre) ═══════════

    private async Task GuardarPreventa()
    {
        savingPv = true;
        try
        {
            var req = new SaveTelegramAccountRequest
            {
                BotToken = string.IsNullOrWhiteSpace(preventaToken) ? null : preventaToken.Trim(),
                IsActive = true
            };
            var res = await Api.SaveTelegramAccountAsync(req, "PREVENTAS");
            if (res is not null)
            {
                preventaAccount = res;
                preventaToken = "";
                ToastService.Success("Token del bot de Preventas guardado. Ahora probá la conexión.");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { savingPv = false; }
    }

    private async Task ProbarPreventa()
    {
        probandoPv = true;
        try
        {
            var res = await Api.ProbarTelegramAsync("PREVENTAS");
            if (res is not null && res.Ok)
            {
                if (res.TestEnviado) ToastService.Success("¡Conexión OK! Te mandé un mensaje al bot de Preventas.");
                else ToastService.Success("¡Token OK! Escribile 'hola' al bot de Preventas y apretá Vincular.");
            }
            else ToastService.Error(res?.Error ?? "No se pudo conectar con el bot de Preventas.");
            preventaAccount = await Api.GetTelegramAccountAsync("PREVENTAS");
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { probandoPv = false; }
    }

    private async Task VincularPreventa()
    {
        vinculandoPv = true;
        try
        {
            var res = await Api.VincularTelegramAsync("PREVENTAS");
            if (res is not null && res.Ok)
            {
                ToastService.Success("¡Bot de Preventas vinculado!");
                preventaAccount = await Api.GetTelegramAccountAsync("PREVENTAS");
            }
            else ToastService.Error(res?.Error ?? "No encontré tu mensaje. Escribile 'hola' al bot de Preventas y reintentá.");
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { vinculandoPv = false; }
    }

    private async Task DesvincularPreventa()
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "¿Desvincular el bot de Preventas? Para volver a usarlo hay que mandarle el código nuevo.");
        if (!ok) return;
        desvincPv = true;
        try
        {
            var res = await Api.DesvincularTelegramAsync("PREVENTAS");
            if (res is not null) { preventaAccount = res; ToastService.Success("Bot de Preventas desvinculado. Código nuevo generado."); }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { desvincPv = false; }
    }
}
