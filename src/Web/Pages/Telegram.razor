@page "/integraciones/telegram"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Telegram</PageTitle>

<div class="page-container" style="max-width:820px;">
    <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem;">
        <span style="font-size:1.6rem;">📲</span>
        <h1 style="margin:0;">Avisos por Telegram</h1>
    </div>
    <p style="color:#64748b;margin-top:0;">
        Recibí en tu celular las ventas nuevas de MercadoLibre y tus alertas. Y podés escribirle al
        bot <b>ventas</b>, <b>saldo</b> o <b>alertas</b> para que te conteste al toque.
    </p>

    @if (loading)
    {
        <p style="color:#94a3b8;">Cargando…</p>
    }
    else
    {
        <!-- ─────────── Estado / conexión ─────────── -->
        <div class="card" style="padding:1.2rem 1.4rem;margin-bottom:1.4rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                <h3 style="margin:0;">🤖 Conexión con el bot</h3>
                @if (account is not null && account.HasToken && account.ChatId is not null && account.LastSyncOk)
                {
                    <span style="background:#dcfce7;color:#166534;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">✓ Conectado y vinculado</span>
                }
                else if (account is not null && account.HasToken)
                {
                    <span style="background:#fef9c3;color:#854d0e;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Token guardado — falta vincular tu Telegram</span>
                }
                else
                {
                    <span style="background:#fee2e2;color:#991b1b;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Sin conectar</span>
                }
            </div>

            @if (account?.BotUsername is not null)
            {
                <p style="color:#334155;font-size:0.9rem;margin:0.7rem 0 0;">
                    Bot: <b>@@@account.BotUsername</b>
                    @if (account.ChatId is not null)
                    {
                        <span style="color:#16a34a;"> · tu Telegram está vinculado ✓</span>
                    }
                </p>
            }

            <p style="color:#64748b;font-size:0.9rem;margin:0.6rem 0 1rem;">
                Pegá el <b>token</b> que te dio <b>@@BotFather</b> cuando creaste el bot (algo como
                <code>123456789:AA...</code>). Se guarda una sola vez.
            </p>

            <div>
                <label style="font-weight:600;font-size:0.85rem;">Token del bot</label>
                <input @bind="botToken" type="password"
                       placeholder="@(account?.HasToken == true ? "•••• (ya guardado)" : "123456789:AAE...")"
                       class="form-control" style="width:100%;" />
            </div>

            <div style="display:flex;align-items:center;gap:0.8rem;margin-top:1rem;flex-wrap:wrap;">
                <button class="btn btn-primary" @onclick="Guardar" disabled="@saving">
                    @(saving ? "Guardando…" : "Guardar token")
                </button>
                <button class="btn btn-secondary" @onclick="Probar" disabled="@(probando || account?.HasToken != true)">
                    @(probando ? "Probando…" : "Probar y mandar mensaje")
                </button>
                @if (account is not null && !account.LastSyncOk && !string.IsNullOrEmpty(account.LastError))
                {
                    <span style="color:#b91c1c;font-size:0.88rem;">⚠ @account.LastError</span>
                }
            </div>
        </div>

        <!-- ─────────── Vincular tu Telegram ─────────── -->
        @if (account is not null && account.HasToken)
        {
            <div class="card" style="padding:1.2rem 1.4rem;margin-bottom:1.4rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
                <h3 style="margin:0 0 0.4rem;">📱 Vincular tu Telegram</h3>
                @if (account.ChatId is not null)
                {
                    <p style="color:#16a34a;font-size:0.92rem;margin:0 0 0.8rem;">
                        ✓ Ya está vinculado. Los avisos te llegan a tu Telegram.
                    </p>
                    <button class="btn btn-secondary btn-sm" @onclick="TestMensaje" disabled="@testando">
                        @(testando ? "Mandando…" : "📤 Mandarme un mensaje de prueba")
                    </button>
                }
                else
                {
                    <p style="color:#64748b;font-size:0.92rem;margin:0 0 0.8rem;">
                        1) Abrí el bot en Telegram@(account.BotUsername is not null ? $" (@{account.BotUsername})" : "") y escribile <b>hola</b>.<br />
                        2) Volvé acá y apretá este botón.
                    </p>
                    <button class="btn btn-primary btn-sm" @onclick="Vincular" disabled="@vinculando">
                        @(vinculando ? "Buscando…" : "🔗 Vincular mi Telegram")
                    </button>
                }

                <div style="margin-top:0.9rem;padding-top:0.8rem;border-top:1px solid #f1f5f9;font-size:0.86rem;color:#475569;">
                    🔒 <b>Código de seguridad</b>: <span style="font-family:monospace;font-size:1rem;background:#f1f5f9;padding:0.1rem 0.5rem;border-radius:6px;">@account.VinculacionCode</span>
                    <div style="color:#94a3b8;font-size:0.8rem;margin-top:0.3rem;">
                        Si el bot no está vinculado, solo se activa cuando le mandan este código. Nadie puede adueñárselo sin él.
                    </div>
                    @if (account.ChatId is not null)
                    {
                        <button class="btn btn-secondary btn-sm" style="margin-top:0.5rem;" @onclick="Desvincular" disabled="@desvinc">
                            @(desvinc ? "…" : "Desvincular este celular")
                        </button>
                    }
                </div>
            </div>

            <!-- ─────────── Qué avisos recibir → ahora todo en Mis Alertas ─────────── -->
            <div class="card" style="padding:1.2rem 1.4rem;border:1px solid #e2e8f0;border-radius:12px;background:#f8fbff;">
                <h3 style="margin:0 0 0.5rem;">🔔 ¿Qué avisos querés recibir?</h3>
                <p style="color:#334155;font-size:0.92rem;margin:0 0 0.8rem;">
                    Todos los avisos se manejan desde un solo lugar: <b><a href="/mis-alertas">Mis Alertas</a></b>.
                    Ahí, para cada aviso —las <b>Ventas de MercadoLibre</b>, las <b>Fichadas de empleados</b> y
                    tus propias alertas (Shell, banco, cheques, fechas, correos)— elegís por dónde te llega:
                    por la <b>campanita 🔔</b>, por <b>Telegram 📲</b>, o por ambos.
                </p>
                <a class="btn btn-primary btn-sm" href="/mis-alertas">Ir a Mis Alertas →</a>
            </div>
        }

        <!-- ─────────── Bot de PREVENTAS (chat aparte) ─────────── -->
        <div class="card" style="padding:1.2rem 1.4rem;margin-top:1.6rem;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                <h3 style="margin:0;">🧾 Bot de Preventas <span style="font-weight:400;color:#94a3b8;font-size:0.85rem;">(chat aparte)</span></h3>
                @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is not null && preventaAccount.LastSyncOk)
                {
                    <span style="background:#dcfce7;color:#166534;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">✓ Conectado y vinculado</span>
                }
                else if (preventaAccount is not null && preventaAccount.HasToken)
                {
                    <span style="background:#fef9c3;color:#854d0e;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Token guardado — falta vincular</span>
                }
                else
                {
                    <span style="background:#fee2e2;color:#991b1b;padding:0.25rem 0.7rem;border-radius:999px;font-weight:600;font-size:0.85rem;">Sin conectar</span>
                }
            </div>
            <p style="color:#64748b;font-size:0.9rem;margin:0.6rem 0 1rem;">
                Un segundo bot, en un <b>chat aparte</b>, donde solo cargás preventas (así no se mezclan con los avisos).
                Creá el bot con <b>@@BotFather</b> y pegá su token acá.
            </p>
            @if (preventaAccount?.BotUsername is not null)
            {
                <p style="color:#334155;font-size:0.9rem;margin:0 0 0.6rem;">Bot: <b>@@@preventaAccount.BotUsername</b>@(preventaAccount.ChatId is not null ? " · vinculado ✓" : "")</p>
            }
            <div>
                <label style="font-weight:600;font-size:0.85rem;">Token del bot de Preventas</label>
                <input @bind="preventaToken" type="password"
                       placeholder="@(preventaAccount?.HasToken == true ? "•••• (ya guardado)" : "123456789:AAE...")"
                       class="form-control" style="width:100%;" />
            </div>
            <div style="display:flex;align-items:center;gap:0.8rem;margin-top:1rem;flex-wrap:wrap;">
                <button class="btn btn-primary" @onclick="GuardarPreventa" disabled="@savingPv">@(savingPv ? "Guardando…" : "Guardar token")</button>
                <button class="btn btn-secondary" @onclick="ProbarPreventa" disabled="@(probandoPv || preventaAccount?.HasToken != true)">@(probandoPv ? "Probando…" : "Probar y mandar mensaje")</button>
                @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is null)
                {
                    <button class="btn btn-secondary" @onclick="VincularPreventa" disabled="@vinculandoPv">@(vinculandoPv ? "Buscando…" : "🔗 Vincular")</button>
                }
                @if (preventaAccount is not null && !preventaAccount.LastSyncOk && !string.IsNullOrEmpty(preventaAccount.LastError))
                {
                    <span style="color:#b91c1c;font-size:0.88rem;">⚠ @preventaAccount.LastError</span>
                }
            </div>
            @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is null)
            {
                <p style="color:#64748b;font-size:0.86rem;margin:0.7rem 0 0;">Para vincular: abrí el bot de Preventas en Telegram, escribile <b>hola</b>, y apretá "Probar" (o "Vincular").</p>
            }
            @if (preventaAccount is not null && preventaAccount.HasToken && preventaAccount.ChatId is not null && preventaAccount.LastSyncOk)
            {
                <p style="color:#16a34a;font-size:0.88rem;margin:0.7rem 0 0;">✅ Listo. Abrí el chat del bot de Preventas y escribile <b>nueva</b> para cargar una preventa.</p>
            }
            @if (preventaAccount is not null && preventaAccount.HasToken)
            {
                <div style="margin-top:0.9rem;padding-top:0.8rem;border-top:1px solid #f1f5f9;font-size:0.86rem;color:#475569;">
                    🔒 <b>Código de seguridad</b>: <span style="font-family:monospace;font-size:1rem;background:#f1f5f9;padding:0.1rem 0.5rem;border-radius:6px;">@preventaAccount.VinculacionCode</span>
                    @if (preventaAccount.ChatId is not null)
                    {
                        <button class="btn btn-secondary btn-sm" style="margin-left:0.6rem;" @onclick="DesvincularPreventa" disabled="@desvincPv">
                            @(desvincPv ? "…" : "Desvincular")
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private TelegramAccountDto? account;
    private bool loading = true, saving = false, probando = false, vinculando = false, testando = false;
    private bool desvinc = false, desvincPv = false;

    private string botToken = "";

    // Bot de Preventas (chat aparte)
    private TelegramAccountDto? preventaAccount;
    private string preventaToken = "";
    private bool savingPv = false, probandoPv = false, vinculandoPv = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarCuenta();
        loading = false;
    }

    private async Task CargarCuenta()
    {
        try
        {
            account = await Api.GetTelegramAccountAsync();
            preventaAccount = await Api.GetTelegramAccountAsync("PREVENTAS");
        }
        catch (Exception ex) { ToastService.Error("No se pudo leer la configuración: " + ex.Message); }
    }

    private async Task GuardarPreventa()
    {
        savingPv = true;
        try
        {
            var req = new SaveTelegramAccountRequest
            {
                BotToken = string.IsNullOrWhiteSpace(preventaToken) ? null : preventaToken.Trim(),
                IsActive = true
            };
            var res = await Api.SaveTelegramAccountAsync(req, "PREVENTAS");
            if (res is not null)
            {
                preventaAccount = res;
                preventaToken = "";
                ToastService.Success("Token del bot de Preventas guardado. Ahora probá la conexión.");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { savingPv = false; }
    }

    private async Task ProbarPreventa()
    {
        probandoPv = true;
        try
        {
            var res = await Api.ProbarTelegramAsync("PREVENTAS");
            if (res is not null && res.Ok)
            {
                if (res.TestEnviado)
                    ToastService.Success("¡Conexión OK! Te mandé un mensaje al bot de Preventas.");
                else
                    ToastService.Success("¡Token OK! Escribile 'hola' al bot de Preventas y apretá Vincular.");
            }
            else
            {
                ToastService.Error(res?.Error ?? "No se pudo conectar con el bot de Preventas.");
            }
            preventaAccount = await Api.GetTelegramAccountAsync("PREVENTAS");
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { probandoPv = false; }
    }

    private async Task VincularPreventa()
    {
        vinculandoPv = true;
        try
        {
            var res = await Api.VincularTelegramAsync("PREVENTAS");
            if (res is not null && res.Ok)
            {
                ToastService.Success("¡Bot de Preventas vinculado!");
                preventaAccount = await Api.GetTelegramAccountAsync("PREVENTAS");
            }
            else
            {
                ToastService.Error(res?.Error ?? "No encontré tu mensaje. Escribile 'hola' al bot de Preventas y reintentá.");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { vinculandoPv = false; }
    }

    private async Task Guardar()
    {
        saving = true;
        try
        {
            var req = new SaveTelegramAccountRequest
            {
                BotToken = string.IsNullOrWhiteSpace(botToken) ? null : botToken.Trim(),
                IsActive = true
            };
            var res = await Api.SaveTelegramAccountAsync(req);
            if (res is not null)
            {
                account = res;
                botToken = "";
                ToastService.Success("Token guardado. Ahora probá la conexión.");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { saving = false; }
    }

    private async Task Probar()
    {
        probando = true;
        try
        {
            var res = await Api.ProbarTelegramAsync();
            if (res is not null && res.Ok)
            {
                if (res.TestEnviado)
                    ToastService.Success("¡Conexión OK! Te mandé un mensaje de prueba, fijate en tu Telegram.");
                else
                    ToastService.Success("¡Token OK! Ahora vinculá tu Telegram (escribile 'hola' al bot).");
            }
            else
            {
                ToastService.Error(res?.Error ?? "No se pudo conectar con Telegram.");
            }
            await CargarCuenta();
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { probando = false; }
    }

    private async Task Vincular()
    {
        vinculando = true;
        try
        {
            var res = await Api.VincularTelegramAsync();
            if (res is not null && res.Ok)
            {
                ToastService.Success("¡Listo! Tu Telegram quedó vinculado.");
                await CargarCuenta();
            }
            else
            {
                ToastService.Error(res?.Error ?? "No encontré tu mensaje. Escribile 'hola' al bot y probá de nuevo.");
            }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { vinculando = false; }
    }

    private async Task TestMensaje()
    {
        testando = true;
        try
        {
            var res = await Api.TestMensajeTelegramAsync();
            if (res is not null && res.Ok) ToastService.Success("Mensaje enviado. Fijate en tu Telegram. 📲");
            else ToastService.Error(res?.Error ?? "No se pudo enviar el mensaje.");
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { testando = false; }
    }

    private async Task Desvincular()
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "¿Desvincular este celular del bot de Avisos? Vas a dejar de recibir avisos hasta volver a vincularlo con el código nuevo.");
        if (!ok) return;
        desvinc = true;
        try
        {
            var res = await Api.DesvincularTelegramAsync("AVISOS");
            if (res is not null) { account = res; ToastService.Success("Desvinculado. Se generó un código nuevo."); }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { desvinc = false; }
    }

    private async Task DesvincularPreventa()
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "¿Desvincular el bot de Preventas? Para volver a usarlo hay que mandarle el código nuevo.");
        if (!ok) return;
        desvincPv = true;
        try
        {
            var res = await Api.DesvincularTelegramAsync("PREVENTAS");
            if (res is not null) { preventaAccount = res; ToastService.Success("Bot de Preventas desvinculado. Código nuevo generado."); }
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { desvincPv = false; }
    }
}
