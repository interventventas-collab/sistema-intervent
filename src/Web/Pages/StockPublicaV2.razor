@page "/stock/v2/{token}"
@attribute [AllowAnonymous]
@layout Web.Layout.LoginLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

@* ═══════════════════════════════════════════════════════════════════════
   Stock móvil V2 — Pantalla pública de carga rápida desde el depósito.
   Prompt 2 del rediseño (2026-05-28). Coexiste con StockPublica.razor (la vieja)
   hasta que validemos toda la migración. Este commit (3) solo cubre el SHELL:
     - Validar token
     - Modo AUDITORÍA: redirigir a la pantalla vieja (la migración del modo audit
       queda fuera del Prompt 2 — ver Prompt 5+).
     - Selector de operador
     - Header sticky con operador + depósito + botón Cambiar
     - Buscador integrado (componente ProductSearchInput con LoadOnlyProductos=true)
     - Al seleccionar un producto: toast informativo. NO escribe en DB todavía.
   La pantalla 2 (ajuste de cantidad + confirmación de movimiento) llega en el commit 4.
   ═══════════════════════════════════════════════════════════════════════ *@

<style>
    /* Reset/viewport — mismo enfoque que la pantalla vieja para que LoginLayout no rompa el ancho. */
    html, body { margin: 0; padding: 0; overflow-x: hidden; width: 100%; max-width: 100vw; }
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #f8fafc; min-height: 100vh; }
    .login-page {
        display: block !important; padding: 0 !important;
        background: #f8fafc !important;
        align-items: initial !important; justify-content: initial !important;
        min-height: 100vh; width: 100%; max-width: 100vw; overflow-x: hidden;
    }
    .v2-app { display: flex; flex-direction: column; height: 100vh; max-width: 560px; margin: 0 auto; background: #fafafa; }
    .v2-header { background: #1e40af; color: white; padding: 0.7rem 0.9rem; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; position: sticky; top: 0; z-index: 10; }
    .v2-header-info { flex: 1; min-width: 0; }
    .v2-header-info strong { font-size: 1rem; }
    .v2-header-info span { font-size: 0.78rem; opacity: 0.85; }
    .v2-header-btn { background: rgba(255,255,255,0.18); color: white; border: 1px solid rgba(255,255,255,0.35); padding: 0.4rem 0.65rem; border-radius: 6px; font-size: 0.78rem; cursor: pointer; flex-shrink: 0; }
    .v2-header-btn:hover { background: rgba(255,255,255,0.28); }

    .v2-loading, .v2-error { padding: 2rem; text-align: center; color: #6b7280; }
    .v2-error h2 { color: #b91c1c; margin: 0 0 0.4rem; }

    .v2-card { background: white; padding: 1rem; border-radius: 12px; margin: 0.7rem; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .v2-card h1 { font-size: 1.15rem; margin: 0 0 0.3rem; color: #1f2937; }
    .v2-card p { font-size: 0.85rem; color: #6b7280; margin: 0; }
    .v2-op-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem; margin-top: 0.8rem; }
    .v2-op-btn { padding: 1.1rem 0.4rem; font-size: 1.05rem; font-weight: 800; background: white; border: 2px solid #d1d5db; border-radius: 10px; cursor: pointer; color: #1f2937; }
    .v2-op-btn:hover { border-color: #1d4ed8; background: #dbeafe; color: #1e40af; }

    /* El ProductSearchInput se mete en el resto del espacio, ocupando flex:1 */
    .v2-search-wrap { flex: 1; min-height: 0; display: flex; flex-direction: column; background: white; overflow: hidden; }

    .v2-toast { position: fixed; bottom: 1rem; left: 50%; transform: translateX(-50%); background: #16a34a; color: white; padding: 0.7rem 1.3rem; border-radius: 999px; font-weight: 700; font-size: 0.95rem; box-shadow: 0 4px 14px rgba(0,0,0,0.2); z-index: 9999; }

    .v2-info-banner { background: #fffbeb; border: 1px solid #fcd34d; color: #92400e; padding: 0.6rem 0.8rem; font-size: 0.8rem; margin: 0.7rem; border-radius: 8px; }
</style>

<div class="v2-app">
    @if (loading)
    {
        <div class="v2-loading">⏳ Cargando…</div>
    }
    else if (init is null)
    {
        <div class="v2-card v2-error">
            <h2>🚫 Link inválido</h2>
            <p>El link puede haber expirado. Pedile uno nuevo a tu encargado.</p>
        </div>
    }
    else if (operadorActivo is null)
    {
        @* === PASO 1: elegir operador === *@
        <div class="v2-card">
            <h1>📦 Carga de stock</h1>
            <p>Depósito: <strong>@init.DepositoActual</strong></p>
            <p style="margin-top: 0.8rem;"><strong>¿Quién está cargando?</strong></p>
            <div class="v2-op-grid">
                @foreach (var op in init.Operadores)
                {
                    <button class="v2-op-btn" @onclick="() => SeleccionarOperador(op)">@op.Nombre</button>
                }
            </div>
        </div>
    }
    else
    {
        @* === PASO 2: operador activo, buscador integrado === *@
        <div class="v2-header">
            <div class="v2-header-info">
                👤 <strong>@operadorActivo.Nombre</strong>
                <span>· @init.DepositoActual</span>
            </div>
            <button class="v2-header-btn" @onclick="ResetOperador">Cambiar</button>
        </div>

        @* Commit 3: solo el shell con el buscador. Al seleccionar muestra toast — sin escribir DB. *@
        <div class="v2-info-banner">
            🚧 <strong>V2 en construcción</strong> · Este commit solo muestra el buscador.
            Para cargar movimientos reales seguí usando <a href="@($"/stock/{Token}")" style="color:#1d4ed8;">la pantalla anterior</a>.
        </div>

        <div class="v2-search-wrap">
            <ProductSearchInput
                OnSelect="HandleSelect"
                LoadOnlyProductos="true"
                CustomCatalogUrl="@($"/api/stock/publica/{Uri.EscapeDataString(Token)}/catalogo?onlyProductos=true")"
                Context="stock-v2" />
        </div>
    }

    @if (toastVisible)
    {
        <div class="v2-toast">@toastMensaje</div>
    }
</div>

@code {
    [Parameter] public string Token { get; set; } = "";
    [SupplyParameterFromQuery(Name = "modo")] public string? Modo { get; set; }

    private bool loading = true;
    private StockInitPubDto? init;
    private StockOperadorPubDto? operadorActivo;
    private bool toastVisible;
    private string? toastMensaje;

    public record StockOperadorPubDto(int Id, string Nombre);
    public record StockAuditoriaPubDto(int Id, DateTime IniciadaAt, string? IniciadaPorNombre, int ItemsContados);
    public record StockInitPubDto(string Token, List<StockOperadorPubDto> Operadores, string DepositoActual, StockAuditoriaPubDto? AuditoriaActiva);

    protected override async Task OnInitializedAsync()
    {
        // Ajuste 1 del Prompt 2: si vienen al V2 con ?modo=auditoria, redirigir a la vieja.
        // El modo auditoría no está migrado en este Prompt — sigue funcionando intacto en /stock/{token}.
        if (string.Equals(Modo, "auditoria", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo($"/stock/{Token}?modo=auditoria", forceLoad: true);
            return;
        }

        await CargarInitAsync();
        loading = false;
    }

    private async Task CargarInitAsync()
    {
        try
        {
            var resp = await Http.GetAsync($"api/stock/publica/{Uri.EscapeDataString(Token)}/init");
            if (resp.IsSuccessStatusCode)
            {
                init = await resp.Content.ReadFromJsonAsync<StockInitPubDto>();
            }
        }
        catch { init = null; }
    }

    private void SeleccionarOperador(StockOperadorPubDto op)
    {
        operadorActivo = op;
    }

    private void ResetOperador()
    {
        operadorActivo = null;
    }

    /// <summary>
    /// COMMIT 3: solo muestra un toast con el SKU seleccionado. NO escribe en DB.
    /// La pantalla 2 (ajuste de cantidad + POST a /movimiento) llega en el commit 4.
    /// </summary>
    private async Task HandleSelect(Web.Models.Mobile.CatalogItem item)
    {
        toastMensaje = $"✓ {item.Sku} · {Trunc(item.Nombre, 30)} (stock {item.Stock:0})";
        toastVisible = true;
        StateHasChanged();
        try { await JS.InvokeVoidAsync("navigator.vibrate", 10); } catch { }
        await Task.Delay(1800);
        toastVisible = false;
        StateHasChanged();
    }

    private static string Trunc(string s, int n)
        => string.IsNullOrEmpty(s) ? "" : (s.Length > n ? s.Substring(0, n) + "…" : s);
}
