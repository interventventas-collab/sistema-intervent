    private async Task ArcaWsWizardStep1Submit()
    {
        arcaWsWizardError = null;
        var cuitDigits = new string((arcaWsWizardCuit ?? "").Where(char.IsDigit).ToArray());
        if (cuitDigits.Length != 11)
        {
            arcaWsWizardError = "El CUIT debe tener 11 dígitos";
            return;
        }
        if (string.IsNullOrWhiteSpace(arcaWsWizardAlias))
        {
            arcaWsWizardError = "El alias es obligatorio";
            return;
        }

        arcaWsWizardBusy = true;
        try
        {
            var (ok, error, dto) = await Api.GenerateArcaCsrAsync(cuitDigits, arcaWsWizardAlias.Trim());
            if (!ok || dto is null)
            {
                arcaWsWizardError = error ?? "No se pudo generar el CSR";
                return;
            }
            arcaWsWizardCsrId = dto.Id;
            arcaWsWizardCsrFileName = dto.FileName;
            arcaWsWizardCsrSubject = dto.Subject;
            arcaWsWizardCsrPem = dto.CsrPem;
            // Precargar el alias final del paso 3 con el que escribió en el paso 1
            arcaWsWizardAliasFinal = arcaWsWizardAlias.Trim();
            arcaWsWizardStep = 2;
        }
        catch (Exception ex)
        {
            arcaWsWizardError = ex.Message;
        }
        finally
        {
            arcaWsWizardBusy = false;
        }
    }

    private async Task DownloadArcaWsCsr()
    {
        if (string.IsNullOrEmpty(arcaWsWizardCsrPem) || string.IsNullOrEmpty(arcaWsWizardCsrFileName)) return;
        try
        {
            await JS.InvokeVoidAsync("downloadTextFile", arcaWsWizardCsrFileName, arcaWsWizardCsrPem, "application/x-pem-file");
        }
        catch (Exception ex)
        {
            ToastService.Error("No se pudo descargar: " + ex.Message);
        }
    }

    private void OnArcaWsWizardCrtPicked(InputFileChangeEventArgs e)
    {
        arcaWsWizardError = null;
        var f = e.File;
        if (f is null) { arcaWsWizardCrtFile = null; arcaWsWizardCrtFileName = ""; return; }
        // Aceptamos .crt, .cer, .pem (no validamos extensión estricto: el back parsea
        // PEM o DER igual). Pero rechazamos lo que claramente no es un certificado.
        if (f.Size > 5 * 1024 * 1024)
        {
            arcaWsWizardError = "El archivo es muy grande (max 5 MB)";
            return;
        }
        arcaWsWizardCrtFile = f;
        arcaWsWizardCrtFileName = f.Name;
    }

    private async Task ArcaWsWizardStep3Submit()
    {
        arcaWsWizardError = null;
        if (!arcaWsWizardCsrId.HasValue)
        {
            arcaWsWizardError = "No hay un pedido de CSR activo. Volvé al paso 1.";
            return;
        }
        if (arcaWsWizardCrtFile is null)
        {
            arcaWsWizardError = "Tenés que elegir el archivo .crt que te devolvió ARCA";
            return;
        }
        arcaWsWizardBusy = true;
        try
        {
            using var stream = arcaWsWizardCrtFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var (ok, error, dto) = await Api.FinalizeArcaCsrAsync(
                arcaWsWizardCsrId.Value,
                stream,
                arcaWsWizardCrtFile.Name,
                arcaWsWizardPfxPassword,
                arcaWsWizardEnvironment,
                arcaWsWizardAliasFinal);
            if (!ok || dto is null)
            {
                arcaWsWizardError = error ?? "No se pudo generar el .pfx";
                return;
            }
            ToastService.Success("Certificado generado y agregado a la lista");
            showArcaWsWizard = false;
            await LoadArcaWsCerts();
        }
        catch (Exception ex)
        {
            arcaWsWizardError = ex.Message;
        }
        finally
        {
            arcaWsWizardBusy = false;
        }
    }

    /// <summary>
    /// Devuelve (color, texto) según vencimiento del cert: rojo si vencido,
    /// naranja si quedan menos de 30 días, verde si queda más, gris si no se pudo leer.
    /// </summary>
    private static (string color, string texto) VencimientoEstilo(DateTime? expiresAt)
    {
        if (!expiresAt.HasValue) return ("#6b7280", "No detectada");
        var days = (expiresAt.Value.Date - DateTime.Today).Days;
        var fmt = expiresAt.Value.ToString("dd/MM/yyyy");
        if (days < 0) return ("#dc2626", $"⚠ Vencido el {fmt}");
        if (days < 30) return ("#ea580c", $"⏰ Vence el {fmt} ({days} día{(days == 1 ? "" : "s")})");
        return ("#059669", fmt);
    }

    /// <summary>Formatea "yyyy-MM-dd" → "dd/MM/yyyy". Si no parsea, devuelve tal cual.</summary>
    private static string FormatFechaArca(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return "";
        // Formatos posibles: "yyyy-MM-dd", "dd/MM/yyyy", "yyyyMMdd", "yyyy-MM-dd HH:mm:ss"
        var s = raw.Trim();
        if (DateTime.TryParseExact(s, new[] { "yyyy-MM-dd", "dd/MM/yyyy", "yyyyMMdd", "yyyy-MM-dd HH:mm:ss", "dd-MM-yyyy" },
            System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var d))
            return d.ToString("dd/MM/yyyy");
        if (DateTime.TryParse(s, out d)) return d.ToString("dd/MM/yyyy");
        return s;
    }

    /// <summary>"$1.234,56" si tiene valor, "" si null.</summary>
    private static string FormatMoneyOrEmpty(decimal? v)
    {
        if (!v.HasValue) return "";
        return "$" + v.Value.ToString("N2", new System.Globalization.CultureInfo("es-AR"));
    }

    /// <summary>"01/05/2026 — 31/05/2026" a partir de las dos fechas ISO.</summary>
    private static string FormatoRango(string? desde, string? hasta)
    {
        var d = FormatFechaArca(desde);
        var h = FormatFechaArca(hasta);
        if (string.IsNullOrEmpty(d) && string.IsNullOrEmpty(h)) return "—";
        if (string.IsNullOrEmpty(d)) return $"hasta {h}";
        if (string.IsNullOrEmpty(h)) return $"desde {d}";
        return $"{d} — {h}";
    }

    /// <summary>Formatea CUIT 30715938091 -> 30-71593809-1 para mostrar.</summary>
    private static string FormatCuit(string? raw)
    {
        var digits = new string((raw ?? "").Where(char.IsDigit).ToArray());
        if (digits.Length != 11) return raw ?? "";
        return $"{digits[..2]}-{digits[2..10]}-{digits[10..]}";
    }

    /// <summary>Confirmación nativa del browser (simple, sin modal custom).</summary>
    private async Task<bool> ConfirmAsync(string message)
    {
        try { return await JS.InvokeAsync<bool>("confirm", message); }
        catch { return false; }
    }
