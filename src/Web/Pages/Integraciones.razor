    // --- Google Drive Methods (OAuth 2.0) ---
    private async Task LoadDrive()
    {
        try
        {
            var integration = await Api.GetIntegrationAsync("google-drive");
            if (integration is not null)
            {
                driveId = integration.Id;
                driveActive = integration.IsActive;
                driveHasSecret = integration.HasSecret; // refresh_token presente => "conectado"
                driveClientId = "";
                driveClientSecret = "";
                driveFolderId = "";
                driveHasClientSecret = false;
                if (!string.IsNullOrEmpty(integration.Settings))
                {
                    try
                    {
                        var doc = System.Text.Json.JsonDocument.Parse(integration.Settings);
                        if (doc.RootElement.TryGetProperty("folderId", out var f))
                            driveFolderId = f.GetString() ?? "";
                        if (doc.RootElement.TryGetProperty("clientId", out var ci))
                            driveClientId = ci.GetString() ?? "";
                        if (doc.RootElement.TryGetProperty("clientSecret", out var cs))
                        {
                            // No mostramos el secret en el campo — solo marcamos que ya hay uno guardado.
                            driveHasClientSecret = !string.IsNullOrEmpty(cs.GetString());
                        }
                    }
                    catch { }
                }
            }
        }
        catch { }
    }

    private async Task SaveDrive()
    {
        driveSaving = true;
        try
        {
            // Si el usuario no pegó un client_secret nuevo, preservamos el existente leyéndolo del backend.
            string? clientSecretToSave = string.IsNullOrWhiteSpace(driveClientSecret) ? null : driveClientSecret;
            if (clientSecretToSave is null && driveHasClientSecret)
            {
                // Re-leemos el integration para mantener el client_secret que ya estaba.
                var existing = await Api.GetIntegrationAsync("google-drive");
                if (existing is not null && !string.IsNullOrEmpty(existing.Settings))
                {
                    try
                    {
                        var doc = System.Text.Json.JsonDocument.Parse(existing.Settings);
                        if (doc.RootElement.TryGetProperty("clientSecret", out var cs))
                            clientSecretToSave = cs.GetString();
                    }
                    catch { }
                }
            }

            var settings = System.Text.Json.JsonSerializer.Serialize(new
            {
                clientId = driveClientId ?? "",
                clientSecret = clientSecretToSave ?? "",
                folderId = driveFolderId ?? ""
            });

            var request = new SaveIntegrationRequest
            {
                Provider = "google-drive",
                AppId = null,
                // El AppSecret (refresh_token) NO lo tocamos desde acá — solo se setea
                // en el callback OAuth. Mandamos null para no pisar el refresh_token existente.
                AppSecret = null,
                RedirectUrl = null,
                Settings = settings,
                IsActive = driveActive
            };

            var result = await Api.SaveIntegrationAsync(request);
            if (result is not null)
            {
                driveId = result.Id;
                driveHasSecret = result.HasSecret;
                driveHasClientSecret = !string.IsNullOrWhiteSpace(clientSecretToSave);
                driveClientSecret = ""; // limpiamos el input
                ToastService.Success("Configuración de Google Drive guardada");
                // No cerramos el modal — el usuario probablemente quiera tocar "Conectar con Google" después.
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar: " + ex.Message);
        }
        finally
        {
            driveSaving = false;
        }
    }

    private async Task DeleteDrive()
    {
        driveSaving = true;
        try
        {
            var deleted = await Api.DeleteIntegrationAsync("google-drive");
            if (deleted)
            {
                driveId = 0;
                driveClientId = "";
                driveClientSecret = "";
                driveFolderId = "";
                driveActive = false;
                driveHasSecret = false;
                driveHasClientSecret = false;
                showDriveModal = false;
                ToastService.Success("Integración de Google Drive eliminada");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al eliminar: " + ex.Message);
        }
        finally
        {
            driveSaving = false;
        }
    }

