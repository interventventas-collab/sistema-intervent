            if (!ok)
            {
                showWaQrModal = false;
                ToastService.Error("No se pudo iniciar la vinculacion de WhatsApp");
                return;
            }
            // Pequeño delay para que Playwright tenga tiempo de renderizar el QR
            await Task.Delay(4000);
            waQrUrl = $"/api/whatsapp/qr?t={DateTimeOffset.Now.ToUnixTimeMilliseconds()}";
            waPreparingQr = false;
            StartWhatsAppPolling();
        }
        catch (Exception ex)
        {
            showWaQrModal = false;
            ToastService.Error("Error al iniciar vinculacion: " + ex.Message);
        }
        finally
        {
            waBusy = false;
        }
    }

    private void StartWhatsAppPolling()
    {
        waPollCts?.Cancel();
        waPollCts = new CancellationTokenSource();
        var token = waPollCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(3000, token);
                    if (token.IsCancellationRequested) break;

                    // Refrescar QR (cache-bust)
                    waQrUrl = $"/api/whatsapp/qr?t={DateTimeOffset.Now.ToUnixTimeMilliseconds()}";

                    var linked = await Api.CheckWhatsAppLinkedAsync();
                    await InvokeAsync(StateHasChanged);
                    if (linked)
                    {
                        waLinked = true;
                        showWaQrModal = false;
                        ToastService.Success("WhatsApp vinculado correctamente");
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                }
                catch (TaskCanceledException) { break; }
                catch { /* swallow, seguimos */ }
            }
        }, token);
    }

