    private async Task StartArcaTest(ArcaAccountDto account)
    {
        if (arcaTestRunning) return;
        if (!account.HasPassword)
        {
            ToastService.Error("Esta cuenta no tiene contraseña cargada. Editala primero.");
            return;
        }

        arcaTestMode = "test";
        arcaTestCuit = FormatCuit(account.Cuit);
        arcaTestStep = "Iniciando...";
        arcaTestResult = null;
        arcaTestRunning = true;
        arcaScreenshotUrl = "";
        showArcaTestModal = true;
        StateHasChanged();

        var (ok, error) = await Api.StartArcaTestAsync(account.Id);
        if (!ok)
        {
            arcaTestRunning = false;
            arcaTestResult = new ArcaTestResultDto { Ok = false, Error = error ?? "No se pudo iniciar la prueba" };
            StateHasChanged();
            return;
        }

        // Disparar polling
        arcaPollCts?.Cancel();
        arcaPollCts = new CancellationTokenSource();
        _ = PollArcaTestAsync(arcaPollCts.Token);
    }

    /// <summary>
    /// Abre el modal de comprobantes en fase "configurar". El usuario elige el
    /// rango y luego toca Buscar (StartArcaComprobantes).
    /// </summary>
    private void OpenArcaComprobantesModal(ArcaAccountDto account)
    {
        if (arcaTestRunning) return;
