    private static List<string> ParseTestPhones(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return new();
        var parts = raw.Split(new[] { ';', ',', '\n', '\r', ' ', '\t', '|' }, StringSplitOptions.RemoveEmptyEntries);
        var seen = new HashSet<string>();
        var result = new List<string>();
        foreach (var p in parts)
        {
            var digits = new string(p.Where(char.IsDigit).ToArray());
            if (digits.Length >= 8 && seen.Add(digits))
                result.Add(digits);
        }
        return result;
    }

    private async Task SendWhatsAppTest()
    {
        var phones = ParseTestPhones(waTestPhone ?? "");
        if (phones.Count == 0)
        {
            waTestResult = "Ingresa al menos un telefono valido (al menos 8 digitos, con codigo de pais)";
            waTestSuccess = false;
            waTestResults = new();
            return;
        }
        waTesting = true;
        waTestResult = "";
        waTestResults = new();
        try
        {
            if (phones.Count == 1)
            {
                var result = await Api.SendWhatsAppTestAsync(phones[0]);
                if (result is null)
                {
                    waTestResult = "Sin respuesta del servidor";
                    waTestSuccess = false;
                }
                else if (result.Success)
                {
                    waTestResult = $"Mensaje enviado a {phones[0]} ({result.Message})";
                    waTestSuccess = true;
                }
                else
                {
                    waTestResult = "Error: " + result.Message;
                    waTestSuccess = false;
                }
            }
            else
            {
                var results = await Api.SendWhatsAppTestBulkAsync(phones);
                if (results is null || results.Count == 0)
                {
                    waTestResult = "Sin respuesta del servidor";
                    waTestSuccess = false;
                }
                else
                {
                    waTestResults = results;
                    var ok = results.Count(r => r.Success);
                    waTestSuccess = ok == results.Count;
                    waTestResult = $"Envio masivo finalizado: {ok}/{results.Count} exitosos";
                }
            }
        }
        catch (Exception ex)
        {
            waTestResult = "Error: " + ex.Message;
            waTestSuccess = false;
        }
        finally
        {
            waTesting = false;
        }
    }

