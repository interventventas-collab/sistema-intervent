                showOpenaiModal = false;
                ToastService.Success("Integracion de OpenAI eliminada");
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al eliminar: " + ex.Message);
        }
        finally
        {
            openaiSaving = false;
        }
    }

