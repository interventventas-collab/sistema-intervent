    /// <summary>Cuando el usuario elige un CUIT en el dropdown, traemos su ficha (si existe).</summary>
    private async Task OnArcaEmisorCuitChanged()
    {
        arcaEmisorError = null;
        arcaEmisorSavedOk = false;
        arcaEmisorActual = null;
        if (string.IsNullOrEmpty(arcaEmisorCuitSelected))
        {
            arcaEmisorForm = new UpsertArcaEmisorRequest { CondicionIva = "Responsable Inscripto" };
            arcaEmisorFormInicioAct = null;
            return;
        }

        try
        {
            arcaEmisorActual = await Api.GetArcaEmisorAsync(arcaEmisorCuitSelected);
        }
        catch { arcaEmisorActual = null; }

        if (arcaEmisorActual is not null)
        {
            arcaEmisorForm = new UpsertArcaEmisorRequest
            {
                Cuit = arcaEmisorActual.Cuit,
                RazonSocial = arcaEmisorActual.RazonSocial,
                CondicionIva = arcaEmisorActual.CondicionIva,
                Domicilio = arcaEmisorActual.Domicilio,
                IIBBTipo = arcaEmisorActual.IIBBTipo,
                IIBBNumero = arcaEmisorActual.IIBBNumero,
                InicioActividades = arcaEmisorActual.InicioActividades,
                Telefono = arcaEmisorActual.Telefono,
                Telefono2 = arcaEmisorActual.Telefono2,
                Email = arcaEmisorActual.Email,
                Web = arcaEmisorActual.Web,
                Web2 = arcaEmisorActual.Web2,
                BancoNombre = arcaEmisorActual.BancoNombre,
                BancoCbu = arcaEmisorActual.BancoCbu,
                BancoAlias = arcaEmisorActual.BancoAlias,
            };
            arcaEmisorFormInicioAct = arcaEmisorActual.InicioActividades;
        }
        else
        {
            arcaEmisorForm = new UpsertArcaEmisorRequest
            {
                Cuit = arcaEmisorCuitSelected,
                CondicionIva = "Responsable Inscripto",
            };
            arcaEmisorFormInicioAct = null;
        }
    }

    private async Task SaveArcaEmisor()
    {
        arcaEmisorError = null;
        arcaEmisorSavedOk = false;
        if (string.IsNullOrEmpty(arcaEmisorCuitSelected))
        {
            arcaEmisorError = "Elegí un CUIT primero";
            return;
        }
        arcaEmisorForm.Cuit = arcaEmisorCuitSelected;
        arcaEmisorForm.InicioActividades = arcaEmisorFormInicioAct;
        arcaEmisorSaving = true;
        try
        {
            var dto = await Api.UpsertArcaEmisorAsync(arcaEmisorForm);
            if (dto is null) { arcaEmisorError = "No se pudo guardar"; return; }
            arcaEmisorActual = dto;
            arcaEmisorSavedOk = true;
            ToastService.Success("Ficha guardada");
        }
        catch (Exception ex)
        {
            arcaEmisorError = ex.Message;
        }
        finally
        {
            arcaEmisorSaving = false;
        }
    }

    private async Task OnArcaEmisorLogoPicked(InputFileChangeEventArgs e)
    {
        if (string.IsNullOrEmpty(arcaEmisorCuitSelected))
        {
            arcaEmisorError = "Elegí un CUIT primero";
            return;
        }
        var f = e.File;
        if (f is null) return;
        if (f.Size > 5 * 1024 * 1024)
        {
            arcaEmisorError = "El archivo supera el máximo de 5 MB";
            return;
        }
        arcaEmisorError = null;
        arcaEmisorLogoBusy = true;
        try
        {
            using var stream = f.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var (ok, error, dto) = await Api.UploadArcaEmisorLogoAsync(arcaEmisorCuitSelected, stream, f.Name, f.ContentType ?? "application/octet-stream");
            if (!ok || dto is null) { arcaEmisorError = error ?? "No se pudo cargar el logo"; return; }
            arcaEmisorActual = dto;
            ToastService.Success("Logo cargado");
        }
        catch (Exception ex)
        {
            arcaEmisorError = ex.Message;
        }
        finally
        {
            arcaEmisorLogoBusy = false;
        }
    }

    private async Task DeleteArcaEmisorLogo()
    {
        if (string.IsNullOrEmpty(arcaEmisorCuitSelected)) return;
        if (!await ConfirmAsync("¿Quitar el logo cargado?")) return;
        arcaEmisorLogoBusy = true;
        try
        {
            await Api.DeleteArcaEmisorLogoAsync(arcaEmisorCuitSelected);
            if (arcaEmisorActual is not null) arcaEmisorActual.LogoPath = null;
            ToastService.Success("Logo eliminado");
        }
        catch (Exception ex)
        {
            arcaEmisorError = ex.Message;
        }
        finally
        {
            arcaEmisorLogoBusy = false;
        }
    }

