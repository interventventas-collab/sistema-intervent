    private async Task StartArcaTest(ArcaAccountDto account)
    {
        if (arcaTestRunning) return;
        if (!account.HasPassword)
        {
            ToastService.Error("Esta cuenta no tiene contraseña cargada. Editala primero.");
            return;
        }

        arcaTestMode = "test";
        arcaTestCuit = FormatCuit(account.Cuit);
        arcaTestStep = "Iniciando...";
        arcaTestResult = null;
        arcaTestRunning = true;
        arcaScreenshotUrl = "";
        showArcaTestModal = true;
        StateHasChanged();

        var (ok, error) = await Api.StartArcaTestAsync(account.Id);
        if (!ok)
        {
            arcaTestRunning = false;
            arcaTestResult = new ArcaTestResultDto { Ok = false, Error = error ?? "No se pudo iniciar la prueba" };
            StateHasChanged();
            return;
        }

        // Disparar polling
        arcaPollCts?.Cancel();
        arcaPollCts = new CancellationTokenSource();
        _ = PollArcaTestAsync(arcaPollCts.Token);
    }

    /// <summary>
    /// Abre el modal de comprobantes en fase "configurar". El usuario elige el
    /// rango y luego toca Buscar (StartArcaComprobantes).
    /// </summary>
    private void OpenArcaComprobantesModal(ArcaAccountDto account)
    {
        if (arcaTestRunning) return;
        if (!account.HasPassword)
        {
            ToastService.Error("Esta cuenta no tiene contraseña cargada. Editala primero.");
            return;
        }
        arcaTestMode = "comprobantes";
        arcaCompFase = "configurar";
        arcaCompAccountId = account.Id;
        arcaTestCuit = FormatCuit(account.Cuit);
        arcaTestResult = null;
        arcaTestStep = "";
        arcaTestRunning = false;
        arcaScreenshotUrl = "";
        // Defaults del rango
        arcaCompTipoRango = "30dias";
        arcaCompDesde = DateTime.Today.AddDays(-30);
        arcaCompHasta = DateTime.Today;
        showArcaTestModal = true;
        StateHasChanged();
    }

    /// <summary>Lanza el flujo de descarga + scraping de comprobantes.</summary>
    private async Task StartArcaComprobantes()
    {
        if (arcaTestRunning) return;
        if (arcaCompTipoRango == "custom" && arcaCompDesde > arcaCompHasta)
        {
            ToastService.Error("El rango es inválido: 'Desde' es posterior a 'Hasta'");
            return;
        }

        arcaCompFase = "corriendo";
        arcaTestStep = "Iniciando...";
        arcaTestResult = null;
        arcaTestRunning = true;
        arcaScreenshotUrl = "";
        StateHasChanged();

        var rango = new ArcaRangoFechasRequest { Tipo = arcaCompTipoRango };
        if (arcaCompTipoRango == "custom")
        {
            rango.Desde = arcaCompDesde.ToString("yyyy-MM-dd");
            rango.Hasta = arcaCompHasta.ToString("yyyy-MM-dd");
        }

        var (ok, error) = await Api.StartArcaComprobantesAsync(arcaCompAccountId, rango);
        if (!ok)
        {
            arcaTestRunning = false;
            arcaCompFase = "resultado";
            arcaTestResult = new ArcaTestResultDto { Ok = false, Error = error ?? "No se pudo iniciar la descarga" };
            StateHasChanged();
            return;
        }

        arcaPollCts?.Cancel();
        arcaPollCts = new CancellationTokenSource();
        _ = PollArcaTestAsync(arcaPollCts.Token);
    }

    private async Task PollArcaTestAsync(CancellationToken ct)
    {
        // Hasta ~3 minutos por las dudas; el server timeoutea antes
        var deadline = DateTime.UtcNow.AddMinutes(4);
        while (!ct.IsCancellationRequested && DateTime.UtcNow < deadline)
        {
            try
            {
                await Task.Delay(1500, ct);
            }
            catch (TaskCanceledException) { return; }
            if (ct.IsCancellationRequested) return;

            ArcaTestStatusDto? status = null;
            try { status = await Api.GetArcaTestStatusAsync(); }
            catch { /* ignorar errores transitorios */ }

            if (status is null) continue;

            // Refrescar screenshot con cache-buster solo si está corriendo
            if (status.Running)
            {
                arcaScreenshotUrl = $"/api/arca/test/screenshot?t={DateTime.UtcNow.Ticks}";
            }

            arcaTestStep = string.IsNullOrEmpty(status.Step) ? "Procesando..." : status.Step;

            // Si terminó (running=false y hay result), salir del loop
            if (!status.Running && status.Result is not null)
            {
                arcaTestRunning = false;
                arcaTestResult = status.Result;
                arcaScreenshotUrl = "";
                if (arcaTestMode == "comprobantes") arcaCompFase = "resultado";
                StateHasChanged();
                return;
            }

            StateHasChanged();
        }

        // Timeout local (si el server quedó colgado)
        if (arcaTestRunning)
        {
            arcaTestRunning = false;
            arcaTestResult = new ArcaTestResultDto { Ok = false, Error = "Timeout esperando respuesta del servidor" };
            StateHasChanged();
        }
    }

    private void CloseArcaTestModal()
    {
        if (arcaTestRunning) return; // no permitir cerrar mientras corre
        showArcaTestModal = false;
        arcaTestResult = null;
        arcaTestStep = "";
        arcaTestMode = "test";
        arcaCompFase = "configurar";
        arcaPollCts?.Cancel();
        arcaPollCts = null;
    }

