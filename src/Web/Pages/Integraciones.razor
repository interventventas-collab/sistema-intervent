    private void OnArcaWsWizardCrtPicked(InputFileChangeEventArgs e)
    {
        arcaWsWizardError = null;
        var f = e.File;
        if (f is null) { arcaWsWizardCrtFile = null; arcaWsWizardCrtFileName = ""; return; }
        // Aceptamos .crt, .cer, .pem (no validamos extensión estricto: el back parsea
        // PEM o DER igual). Pero rechazamos lo que claramente no es un certificado.
        if (f.Size > 5 * 1024 * 1024)
        {
            arcaWsWizardError = "El archivo es muy grande (max 5 MB)";
            return;
        }
        arcaWsWizardCrtFile = f;
        arcaWsWizardCrtFileName = f.Name;
    }

