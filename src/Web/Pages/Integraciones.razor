    // --- OpenAI Methods ---
    private async Task LoadOpenAi()
    {
        try
        {
            var integration = await Api.GetIntegrationAsync("openai");
            if (integration is not null)
            {
                openaiId = integration.Id;
                openaiActive = integration.IsActive;
                openaiHasSecret = integration.HasSecret;
                if (!string.IsNullOrEmpty(integration.Settings))
                {
                    try
                    {
                        var doc = System.Text.Json.JsonDocument.Parse(integration.Settings);
                        var root = doc.RootElement;
                        if (root.TryGetProperty("model", out var m)) openaiModel = m.GetString() ?? "gpt-4o";
                        if (root.TryGetProperty("maxTokens", out var t)) openaiMaxTokens = t.GetInt32();
                        if (root.TryGetProperty("temperature", out var tp)) openaiTemperature = tp.GetDouble();
                    }
                    catch { }
                }
            }
        }
        catch { }
    }

