    private async Task DeleteArcaWsIntegration()
    {
        if (!await ConfirmAsync("¿Eliminar la integración? Se borrarán todos los certificados cargados.")) return;
        arcaWsSaving = true;
        try
        {
            // Borrar certificados primero (no hay cascade — borra archivos del disco)
            if (arcaWsCerts is not null)
            {
                foreach (var c in arcaWsCerts)
                {
                    try { await Api.DeleteArcaWebserviceAccountAsync(c.Id); } catch { }
                }
            }
            var deleted = await Api.DeleteIntegrationAsync("arca-webservice");
            if (deleted)
            {
                arcaWsId = 0;
                arcaWsActive = false;
                arcaWsCerts = new();
                showArcaWsConfigModal = false;
                ToastService.Success("Integración eliminada");
            }
        }
        catch
        {
            arcaWsError = "Error al eliminar la integración";
