    private async Task EmitirArcaWsComprobante()
    {
        arcaWsGenError = null;
        // Validaciones básicas
        if (arcaWsGenPtoVta <= 0) { arcaWsGenError = "PtoVta inválido"; return; }
        if (arcaWsGenItems.Count == 0) { arcaWsGenError = "Tenés que cargar al menos 1 item"; return; }
        if (arcaWsGenItems.Any(i => string.IsNullOrWhiteSpace(i.Descripcion))) { arcaWsGenError = "Hay items sin descripción"; return; }
        if (arcaWsGenItems.Any(i => i.Cantidad <= 0 || i.PrecioUnitario < 0)) { arcaWsGenError = "Cantidades / precios inválidos"; return; }
        if (arcaWsGenDocTipo != 99 && string.IsNullOrWhiteSpace(arcaWsGenDocNro)) { arcaWsGenError = "Falta el Nº de documento del receptor"; return; }

        var req = new EmitirComprobanteRequest
        {
            PtoVta = arcaWsGenPtoVta,
            CbteTipo = arcaWsGenCbteTipo,
            Concepto = arcaWsGenConcepto,
            DocTipo = arcaWsGenDocTipo,
            DocNro = arcaWsGenDocTipo == 99 ? "0" : (arcaWsGenDocNro ?? "0"),
            ReceptorNombre = string.IsNullOrWhiteSpace(arcaWsGenReceptorNombre) ? "Consumidor Final" : arcaWsGenReceptorNombre,
            ReceptorDomicilio = string.IsNullOrWhiteSpace(arcaWsGenReceptorDomicilio) ? null : arcaWsGenReceptorDomicilio,
            CondicionIVAReceptorId = arcaWsGenCondicionIVA,
            Items = arcaWsGenItems.Select(i => new EmitirComprobanteItemDto
            {
                Descripcion = i.Descripcion,
                Cantidad = i.Cantidad,
                PrecioUnitario = i.PrecioUnitario,
                AlicIvaId = i.AlicIvaId
            }).ToList(),
        };

        arcaWsGenLoading = true;
        StateHasChanged();
        try
        {
            arcaWsGenResult = await Api.GenerateArcaComprobanteAsync(arcaWsTestAccountId, req);
            if (arcaWsGenResult is null)
            {
                arcaWsGenError = "No se recibió respuesta del servidor";
            }
        }
        catch (Exception ex)
        {
            arcaWsGenError = ex.Message;
        }
        finally
        {
            arcaWsGenLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>"yyyymmdd" → "dd/mm/yyyy". Vacío si null/empty.</summary>
    private static string FormatYyyymmddOrEmpty(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        if (s.Length == 8 && s.All(char.IsDigit))
            return $"{s.Substring(6, 2)}/{s.Substring(4, 2)}/{s.Substring(0, 4)}";
        return s;
    }

