    private void OnArcaWsFilePicked(InputFileChangeEventArgs e)
    {
        var f = e.File;
        if (f is null)
        {
            arcaWsSelectedFile = null;
            arcaWsSelectedFileName = "";
            return;
        }
        if (!f.Name.EndsWith(".pfx", StringComparison.OrdinalIgnoreCase))
        {
            arcaWsCertError = "El archivo debe terminar en .pfx";
            arcaWsSelectedFile = null;
            arcaWsSelectedFileName = "";
            return;
        }
        if (f.Size > 10 * 1024 * 1024)
        {
            arcaWsCertError = "El archivo supera el máximo de 10 MB";
            arcaWsSelectedFile = null;
            arcaWsSelectedFileName = "";
            return;
        }
        arcaWsCertError = null;
        arcaWsSelectedFile = f;
        arcaWsSelectedFileName = f.Name;
    }

    private async Task SaveArcaWsCert()
    {
        arcaWsCertError = null;

        if (!arcaWsIsEditing)
        {
            // Carga nueva: necesitamos archivo + CUIT
            var cuitDigits = new string((arcaWsFormCuit ?? "").Where(char.IsDigit).ToArray());
            if (cuitDigits.Length != 11)
            {
                arcaWsCertError = "El CUIT debe tener 11 dígitos";
                return;
            }
            if (arcaWsSelectedFile is null)
            {
                arcaWsCertError = "Tenés que elegir un archivo .pfx";
                return;
            }
            arcaWsSaving2 = true;
            try
            {
                using var stream = arcaWsSelectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var (ok, error, dto) = await Api.UploadArcaWebserviceAccountAsync(
                    cuitDigits,
                    arcaWsFormAlias,
                    arcaWsFormPassword,
                    arcaWsFormEnvironment,
                    stream,
                    arcaWsSelectedFile.Name);
                if (!ok)
                {
                    arcaWsCertError = error ?? "No se pudo cargar el certificado";
                    return;
                }
                ToastService.Success("Certificado cargado");
                showArcaWsCertModal = false;
                await LoadArcaWsCerts();
            }
            catch (Exception ex)
            {
                arcaWsCertError = ex.Message;
            }
            finally
            {
                arcaWsSaving2 = false;
            }
        }
        else
        {
            // Editar — solo metadata (alias, password, environment, isActive)
            if (!arcaWsEditingId.HasValue) return;
            arcaWsSaving2 = true;
            try
            {
                var updated = await Api.UpdateArcaWebserviceAccountAsync(arcaWsEditingId.Value, new UpdateArcaWebserviceAccountRequest
                {
                    Alias = arcaWsFormAlias,
                    Password = arcaWsFormPassword, // si lo dejás igual a lo precargado, igual va; el back acepta ""/null como "no tocar" según convenga
                    Environment = arcaWsFormEnvironment,
                    IsActive = arcaWsFormIsActive
                });
                if (updated is null)
                {
                    arcaWsCertError = "No se pudo actualizar el certificado";
                    return;
                }
                ToastService.Success("Certificado actualizado");
                showArcaWsCertModal = false;
                await LoadArcaWsCerts();
            }
            catch (Exception ex)
            {
                arcaWsCertError = ex.Message;
            }
            finally
            {
                arcaWsSaving2 = false;
            }
        }
    }

