@page "/integraciones"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="view-header">
    <h2>Integraciones</h2>
    <div class="view-header-actions">
        @if (HasAvailableIntegrations)
        {
            <div class="add-integration-wrapper">
                <button class="btn btn-primary" @onclick="ToggleAddMenu">+ Nueva Integracion</button>
                @if (showAddMenu)
                {
                    <div class="add-integration-dropdown">
                        @if (mlId == 0)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_ML()">
                                <span class="integration-logo-icon ml-logo" style="width:28px;height:28px;font-size:0.7rem;">ML</span>
                                <div>
                                    <strong>MercadoLibre</strong>
                                    <small>Gestionar publicaciones, ordenes y mas</small>
                                </div>
                            </button>
                        }
                        @if (openaiId == 0)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_OpenAI()">
                                <span class="integration-logo-icon openai-logo" style="width:28px;height:28px;font-size:0.7rem;">AI</span>
                                <div>
                                    <strong>OpenAI</strong>
                                    <small>Modelos GPT para funciones de IA</small>
                                </div>
                            </button>
                        }
                        @if (claudeId == 0)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_Claude()">
                                <span class="integration-logo-icon claude-logo" style="width:28px;height:28px;font-size:0.7rem;">CL</span>
                                <div>
                                    <strong>Claude (Anthropic)</strong>
                                    <small>Modelos Claude para funciones de IA</small>
                                </div>
                            </button>
                        }
                        @if (emailId == 0)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_Email()">
                                <span class="integration-logo-icon email-logo" style="width:28px;height:28px;font-size:0.85rem;">&#9993;</span>
                                <div>
                                    <strong>Email (SMTP)</strong>
                                    <small>Enviar y recibir emails desde el sistema</small>
                                </div>
                            </button>
                        }
                        @if (!waLinked)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_WhatsApp()">
                                <span class="integration-logo-icon whatsapp-logo" style="width:28px;height:28px;font-size:0.7rem;">WA</span>
                                <div>
                                    <strong>WhatsApp</strong>
                                    <small>Envio de mensajes via WhatsApp Web</small>
                                </div>
                            </button>
                        }
                        @if (arcaId == 0)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_Arca()">
                                <span class="integration-logo-icon arca-logo" style="width:28px;height:28px;font-size:0.7rem;">AR</span>
                                <div>
                                    <strong>ARCA (scraping)</strong>
                                    <small>Login automatizado a ARCA (ex AFIP) con CUIT y clave</small>
                                </div>
                            </button>
                        }
                        @if (arcaWsId == 0)
                        {
                            <button class="add-integration-option" @onclick="() => AddIntegration_ArcaWs()">
                                <span class="integration-logo-icon arca-ws-logo" style="width:28px;height:28px;font-size:0.55rem; text-align:center; line-height:1.05; padding:2px;">ARCA<br/>WS</span>
                                <div>
                                    <strong>ARCA (webservice)</strong>
                                    <small>Certificados .pfx para los webservices de ARCA</small>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (!HasConfiguredIntegrations)
{
    <div class="empty-state">
        <div class="empty-state-icon"><i class="fa-solid fa-plug"></i></div>
        <h3>No hay integraciones configuradas</h3>
        <p>Hace clic en "+ Nueva Integracion" para agregar tu primera integracion con un servicio externo.</p>
    </div>
}

<div class="integrations-grid">
    <!-- MercadoLibre (solo si esta configurada) -->
    @if (mlId > 0)
    {
    <div class="integration-card @(mlActive ? "integration-active" : "")">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon ml-logo">ML</span>
            </div>
            <div class="integration-info">
                <h3>MercadoLibre</h3>
                <p>Conecta tu cuenta de MercadoLibre para gestionar publicaciones, ordenes y mas.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge @(mlActive ? "status-active" : "status-inactive")">
                    @(mlActive ? "Activa" : "Inactiva")
                </span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenConfigModal">Configurar</button>
            </div>
        </div>

        <!-- Cuentas conectadas -->
        @if (mlActive)
        {
            <div class="integration-accounts">
                <div class="integration-accounts-header">
                    <h4>Cuentas conectadas</h4>
                    <div class="connect-btn-wrapper" style="display:flex; gap:0.5rem; align-items:center;">
                        <button class="btn btn-primary" @onclick="ToggleConnectMenu" disabled="@connecting">
                            @(connecting ? "Conectando..." : "+ Conectar cuenta")
                        </button>
                        <button class="btn btn-secondary" @onclick="OpenTestUserModal" disabled="@creatingTestUser">
                            <i class="fa-solid fa-flask"></i> Crear cuenta de test
                        </button>
                        @if (showConnectMenu)
                        {
                            <div class="connect-dropdown">
                                <button class="connect-dropdown-item" @onclick="OpenInBrowser">
                                    Abrir en navegador
                                </button>
                                <button class="connect-dropdown-item" @onclick="CopyAuthUrl">
                                    @(urlCopied ? "URL copiada!" : "Copiar URL")
                                </button>
                            </div>
                        }
                    </div>
                </div>

                @if (waitingForCode)
                {
                    <div class="code-input-section">
                        <p class="code-input-instructions">Autoriza la aplicacion en MercadoLibre y luego pega aca el codigo que obtuviste:</p>
                        <div class="code-input-row">
                            <input type="text" class="form-input" @bind="authCode"
                                   placeholder="Pega el codigo aca" />
                            <button class="btn btn-primary" @onclick="SubmitCode" disabled="@connecting">
                                @(connecting ? "Conectando..." : "Conectar")
                            </button>
                            <button class="btn btn-secondary" @onclick="CancelConnect">Cancelar</button>
                        </div>
                    </div>
                }

                @if (accounts is not null && accounts.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Usuario</th>
                                    <th>Email</th>
                                    <th>ID MeLi</th>
                                    <th>Token</th>
                                    <th>Conectada</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in accounts)
                                {
                                    <tr>
                                        <td><strong>@account.Nickname</strong></td>
                                        <td>@(account.Email ?? "-")</td>
                                        <td>@account.MeliUserId</td>
                                        <td>
                                            <span class="status-badge @(account.TokenValid ? "status-active" : "status-inactive")">
                                                @(account.TokenValid ? "Valido" : "Expirado")
                                            </span>
                                        </td>
                                        <td>@account.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <div class="actions-cell">
                                                <button class="btn-icon btn-delete" @onclick="() => RemoveAccount(account.Id)"
                                                        title="Quitar cuenta">
                                                    @SvgIcons.Logout
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!waitingForCode)
                {
                    <p class="text-muted" style="padding: 1rem 1.5rem;">No hay cuentas conectadas. Hace clic en "Conectar cuenta" para vincular tu cuenta de MercadoLibre.</p>
                }
            </div>
        }
        else
        {
            <div style="padding: 1rem 1.5rem;">
                <p class="text-muted">Configura la aplicacion para comenzar a conectar cuentas.</p>
            </div>
        }
    </div>
    }
    <!-- OpenAI (solo si esta configurada) -->
    @if (openaiId > 0)
    {
    <div class="integration-card @(openaiActive ? "integration-active" : "")">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon openai-logo">AI</span>
            </div>
            <div class="integration-info">
                <h3>OpenAI</h3>
                <p>Conecta tu API Key de OpenAI para usar modelos GPT en otras funciones del programa.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge @(openaiActive ? "status-active" : "status-inactive")">
                    @(openaiActive ? "Activa" : "Inactiva")
                </span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenOpenAiModal">Configurar</button>
            </div>
        </div>

        @if (openaiId > 0 && openaiActive)
        {
            <div class="integration-accounts" style="padding: 1rem 1.5rem;">
                <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                    <div>
                        <small class="text-muted">Modelo</small>
                        <div><strong>@openaiModel</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Max Tokens</small>
                        <div><strong>@openaiMaxTokens</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Temperatura</small>
                        <div><strong>@openaiTemperature.ToString("F1")</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">API Key</small>
                        <div><strong>@(openaiHasSecret ? "Configurada" : "No configurada")</strong></div>
                    </div>
                </div>
            </div>
        }
    </div>
    }

    <!-- Claude (solo si esta configurada) -->
    @if (claudeId > 0)
    {
    <div class="integration-card @(claudeActive ? "integration-active" : "")">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon claude-logo">CL</span>
            </div>
            <div class="integration-info">
                <h3>Claude (Anthropic)</h3>
                <p>Conecta tu API Key de Anthropic para usar modelos Claude en otras funciones del programa.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge @(claudeActive ? "status-active" : "status-inactive")">
                    @(claudeActive ? "Activa" : "Inactiva")
                </span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenClaudeModal">Configurar</button>
            </div>
        </div>

        @if (claudeId > 0 && claudeActive)
        {
            <div class="integration-accounts" style="padding: 1rem 1.5rem;">
                <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                    <div>
                        <small class="text-muted">Modelo</small>
                        <div><strong>@claudeModel</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Max Tokens</small>
                        <div><strong>@claudeMaxTokens</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Temperatura</small>
                        <div><strong>@claudeTemperature.ToString("F1")</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">API Key</small>
                        <div><strong>@(claudeHasSecret ? "Configurada" : "No configurada")</strong></div>
                    </div>
                </div>
            </div>
        }
    </div>
    }

    <!-- Email SMTP (solo si esta configurada) -->
    @if (emailId > 0)
    {
    <div class="integration-card @(emailActive ? "integration-active" : "")">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon email-logo">&#9993;</span>
            </div>
            <div class="integration-info">
                <h3>Email (SMTP/IMAP)</h3>
                <p>Envia y recibe emails desde el sistema usando tu cuenta de correo.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge @(emailActive ? "status-active" : "status-inactive")">
                    @(emailActive ? "Activa" : "Inactiva")
                </span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenEmailModal">Configurar</button>
            </div>
        </div>

        @if (emailId > 0 && emailActive)
        {
            <div class="integration-accounts" style="padding: 1rem 1.5rem;">
                <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                    <div>
                        <small class="text-muted">Servidor SMTP</small>
                        <div><strong>@emailSmtpHost</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Puerto</small>
                        <div><strong>@emailSmtpPort</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Remitente</small>
                        <div><strong>@emailFromAddress</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">TLS</small>
                        <div><strong>@(emailSmtpTls ? "Si" : "No")</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">IMAP</small>
                        <div><strong>@(string.IsNullOrEmpty(emailImapHost) ? "No configurado" : emailImapHost)</strong></div>
                    </div>
                    <div>
                        <small class="text-muted">Contraseña</small>
                        <div><strong>@(emailHasSecret ? "Configurada" : "No configurada")</strong></div>
                    </div>
                </div>
            </div>
        }
    </div>
    }

    <!-- WhatsApp (solo si esta vinculada) -->
    @if (waLinked)
    {
    <div class="integration-card integration-active">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon whatsapp-logo">WA</span>
            </div>
            <div class="integration-info">
                <h3>WhatsApp</h3>
                <p>Envio de mensajes via WhatsApp Web. Sesion vinculada por QR.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge status-active">Activa</span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenWhatsAppTestModal">Probar</button>
                <button class="btn btn-secondary btn-sm" @onclick="UnlinkWhatsApp" disabled="@waBusy">Desvincular</button>
            </div>
        </div>
    </div>
    }

    <!-- ARCA (scraping) — solo si esta configurada -->
    @if (arcaId > 0)
    {
    <div class="integration-card @(arcaActive ? "integration-active" : "")">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon arca-logo">AR</span>
            </div>
            <div class="integration-info">
                <h3>ARCA (scraping)</h3>
                <p>Login automatizado a ARCA (ex AFIP). Cargá uno o varios CUITs con su clave; si tu usuario representa a otro CUIT, agregá el "CUIT Login" aparte.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge @(arcaActive ? "status-active" : "status-inactive")">
                    @(arcaActive ? "Activa" : "Inactiva")
                </span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenArcaConfigModal">Configurar</button>
            </div>
        </div>

        @if (arcaActive)
        {
            <div class="integration-accounts">
                <div class="integration-accounts-header">
                    <h4>Cuentas conectadas</h4>
                    <button class="btn btn-primary" @onclick="OpenArcaAddAccountModal">+ Agregar cuenta</button>
                </div>

                @if (arcaAccounts is not null && arcaAccounts.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>CUIT</th>
                                    <th>CUIT Login</th>
                                    <th>Alias</th>
                                    <th>Contraseña</th>
                                    <th>Estado</th>
                                    <th>Fecha</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in arcaAccounts)
                                {
                                    <tr>
                                        <td><strong>@FormatCuit(a.Cuit)</strong></td>
                                        <td>@(string.IsNullOrEmpty(a.CuitLogin) ? "—" : FormatCuit(a.CuitLogin))</td>
                                        <td>@(string.IsNullOrEmpty(a.Alias) ? "—" : a.Alias)</td>
                                        <td>
                                            <span class="status-badge @(a.HasPassword ? "status-active" : "status-inactive")">
                                                @(a.HasPassword ? "Cargada" : "Falta")
                                            </span>
                                        </td>
                                        <td>
                                            <span class="status-badge @(a.IsActive ? "status-active" : "status-inactive")">
                                                @(a.IsActive ? "Activa" : "Inactiva")
                                            </span>
                                        </td>
                                        <td>@a.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <div class="actions-cell">
                                                <button class="btn btn-secondary btn-sm"
                                                        style="font-size: 0.75rem; padding: 0.2rem 0.55rem;"
                                                        @onclick="() => StartArcaTest(a)"
                                                        disabled="@arcaTestRunning"
                                                        title="Verifica login y trae datos del Registro Único Tributario">
                                                    🔍 Probar Login
                                                </button>
                                                <button class="btn btn-secondary btn-sm"
                                                        style="font-size: 0.75rem; padding: 0.2rem 0.55rem;"
                                                        @onclick="() => OpenArcaComprobantesModal(a)"
                                                        disabled="@arcaTestRunning"
                                                        title="Descarga comprobantes Emitidos y Recibidos del rango elegido">
                                                    📄 Probar Comprobantes
                                                </button>
                                                <button class="btn-icon btn-edit" @onclick="() => OpenArcaEditAccountModal(a)" title="Editar">
                                                    @SvgIcons.Edit
                                                </button>
                                                <button class="btn-icon btn-delete" @onclick="() => DeleteArcaAccount(a.Id, a.Cuit)" title="Eliminar">
                                                    @SvgIcons.AlertCircle
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted" style="padding: 1rem 1.5rem;">No hay cuentas cargadas todavía. Tocá <strong>"+ Agregar cuenta"</strong> para sumar la primera.</p>
                }
            </div>
        }
        else
        {
            <div style="padding: 1rem 1.5rem;">
                <p class="text-muted">La integración está inactiva. Tocá <strong>Configurar</strong> para activarla.</p>
            </div>
        }
    </div>
    }

    <!-- ARCA Webservice (.pfx) — solo si esta configurada -->
    @if (arcaWsId > 0)
    {
    <div class="integration-card @(arcaWsActive ? "integration-active" : "")">
        <div class="integration-card-header">
            <div class="integration-logo">
                <span class="integration-logo-icon arca-ws-logo" style="text-align:center; line-height:1.05; padding:2px; font-size:0.85rem;">ARCA<br/>WS</span>
            </div>
            <div class="integration-info">
                <h3>ARCA (webservice)</h3>
                <p>Certificados .pfx para autenticarse contra los webservices de ARCA. Cargá uno por CUIT/ambiente; el archivo se guarda en <strong>Archivos → Certificados ARCA → &lt;CUIT&gt;</strong>.</p>
            </div>
            <div class="integration-header-actions">
                <span class="status-badge @(arcaWsActive ? "status-active" : "status-inactive")">
                    @(arcaWsActive ? "Activa" : "Inactiva")
                </span>
                <button class="btn btn-secondary btn-sm" @onclick="OpenArcaWsConfigModal">Configurar</button>
            </div>
        </div>

        @if (arcaWsActive)
        {
            <div class="integration-accounts">
                <div class="integration-accounts-header">
                    <h4>Certificados cargados</h4>
                    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                        <button class="btn btn-secondary" @onclick="OpenArcaWsWizardModal" title="Generar clave privada + CSR, después de subirlo a ARCA volvés con el .crt para armar el .pfx">
                            🔧 Generar nuevo certificado
                        </button>
                        <button class="btn btn-primary" @onclick="OpenArcaWsAddCertModal">+ Cargar certificado</button>
                    </div>
                </div>

                @if (arcaWsCerts is not null && arcaWsCerts.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>CUIT</th>
                                    <th>Alias</th>
                                    <th>Archivo</th>
                                    <th>Ambiente</th>
                                    <th>Vencimiento</th>
                                    <th>Estado</th>
                                    <th>Cargado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in arcaWsCerts)
                                {
                                    var (vencColor, vencTexto) = VencimientoEstilo(c.ExpiresAt);
                                    var ambienteEsHom = string.Equals(c.Environment, "homologation", StringComparison.OrdinalIgnoreCase);
                                    <tr>
                                        <td><strong>@FormatCuit(c.Cuit)</strong></td>
                                        <td>@(string.IsNullOrEmpty(c.Alias) ? "—" : c.Alias)</td>
                                        <td style="font-family: monospace; font-size: 0.82rem;">@c.FileName</td>
                                        <td>
                                            <span class="status-badge"
                                                  style="background: @(ambienteEsHom ? "#fef3c7" : "#dbeafe"); color: @(ambienteEsHom ? "#92400e" : "#1e40af"); border: 1px solid @(ambienteEsHom ? "#fcd34d" : "#93c5fd");">
                                                @(ambienteEsHom ? "Homologación" : "Producción")
                                            </span>
                                        </td>
                                        <td><span style="color: @vencColor; font-weight: 600;">@vencTexto</span></td>
                                        <td>
                                            <span class="status-badge @(c.IsActive ? "status-active" : "status-inactive")">
                                                @(c.IsActive ? "Activo" : "Inactivo")
                                            </span>
                                        </td>
                                        <td>@c.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <div class="actions-cell">
                                                <button class="btn-icon btn-edit" @onclick="() => OpenArcaWsEditCertModal(c)" title="Editar">
                                                    @SvgIcons.Edit
                                                </button>
                                                <button class="btn-icon btn-delete" @onclick="() => DeleteArcaWsCert(c.Id, c.FileName)" title="Eliminar">
                                                    @SvgIcons.AlertCircle
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted" style="padding: 1rem 1.5rem;">No hay certificados cargados todavía. Tocá <strong>"+ Cargar certificado"</strong>.</p>
                }
            </div>
        }
        else
        {
            <div style="padding: 1rem 1.5rem;">
                <p class="text-muted">La integración está inactiva. Tocá <strong>Configurar</strong> para activarla.</p>
            </div>
        }
    </div>
    }
</div>

<!-- Modal: Vincular WhatsApp (QR) -->
@if (showWaQrModal)
{
    <div class="modal-overlay" @onclick="CancelWhatsAppLink">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 480px;">
            <div class="modal-header">
                <h3>Vincular WhatsApp</h3>
                <button class="btn-close" @onclick="CancelWhatsAppLink">&times;</button>
            </div>
            <div class="modal-body">
                @if (waPreparingQr)
                {
