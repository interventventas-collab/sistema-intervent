        loadingModels = true;
        openaiModelsError = null;
        StateHasChanged();

        try
        {
            openaiModels = await Api.GetOpenAiModelsAsync();
            if (openaiModels.Count == 0)
                openaiModelsError = "No se encontraron modelos disponibles para esta API Key";
        }
        catch (Exception ex)
        {
            openaiModelsError = ex.Message;
            openaiModels = null;
