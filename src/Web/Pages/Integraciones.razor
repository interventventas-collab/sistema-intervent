    private async Task SaveArcaAccount()
    {
        arcaAccountError = null;

        // Normalización rápida del lado cliente — el server vuelve a normalizar.
        var cuitDigits = new string((arcaFormCuit ?? "").Where(char.IsDigit).ToArray());
        if (cuitDigits.Length != 11)
        {
            arcaAccountError = "El CUIT debe tener 11 dígitos";
            return;
        }
        var cuitLoginDigits = new string((arcaFormCuitLogin ?? "").Where(char.IsDigit).ToArray());
        if (!string.IsNullOrWhiteSpace(arcaFormCuitLogin) && cuitLoginDigits.Length != 11)
        {
            arcaAccountError = "El CUIT Login debe tener 11 dígitos (o dejarlo vacío)";
            return;
        }

        arcaAccountSaving = true;
        try
        {
            if (arcaIsEditingAccount && arcaEditingAccountId.HasValue)
            {
                var updated = await Api.UpdateArcaAccountAsync(arcaEditingAccountId.Value, new UpdateArcaAccountRequest
                {
                    Cuit = cuitDigits,
                    CuitLogin = string.IsNullOrWhiteSpace(arcaFormCuitLogin) ? "" : cuitLoginDigits,
                    Alias = arcaFormAlias,
                    Password = string.IsNullOrWhiteSpace(arcaFormPassword) ? null : arcaFormPassword,
                    IsActive = arcaFormIsActive
                });
                if (updated is null)
                {
                    arcaAccountError = "No se pudo actualizar la cuenta";
                    return;
                }
                ToastService.Success("Cuenta de ARCA actualizada");
            }
            else
            {
                if (string.IsNullOrWhiteSpace(arcaFormPassword))
                {
                    arcaAccountError = "La contraseña es obligatoria";
                    return;
                }
                var created = await Api.CreateArcaAccountAsync(new CreateArcaAccountRequest
                {
                    Cuit = cuitDigits,
                    CuitLogin = string.IsNullOrWhiteSpace(arcaFormCuitLogin) ? null : cuitLoginDigits,
                    Alias = arcaFormAlias,
                    Password = arcaFormPassword,
                    IsActive = arcaFormIsActive
                });
                if (created is null)
                {
                    arcaAccountError = "No se pudo crear la cuenta";
                    return;
                }
                ToastService.Success("Cuenta de ARCA agregada");
            }
            showArcaAccountModal = false;
            await LoadArcaAccounts();
        }
        catch (Exception ex)
        {
            arcaAccountError = ex.Message;
        }
        finally
        {
            arcaAccountSaving = false;
        }
    }

