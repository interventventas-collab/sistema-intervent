<!-- Modal: Quitar cuenta -->
@if (showDeleteConfirm && deleteStats != null)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #fff3f3;">
                <h3 style="color: var(--danger);">Quitar cuenta: @deleteStats.Nickname</h3>
                <button class="btn-close" @onclick="CloseDeleteModal">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 1rem; margin-bottom: 1rem;">
                    <strong style="color: #856404;">Atencion:</strong>
                    <span style="color: #856404;"> Esta accion eliminara de la base de datos local todos los datos asociados a esta cuenta.</span>
                </div>

                <p style="margin-bottom: 0.5rem;">Se van a eliminar los siguientes datos:</p>
                <ul style="margin: 0.5rem 0 1rem 1.5rem; line-height: 1.8;">
                    <li><strong>@deleteStats.OrderCount ordenes</strong> sincronizadas</li>
                    <li><strong>@deleteStats.ItemCount publicaciones</strong> sincronizadas</li>
                    <li>La conexion y tokens de acceso de la cuenta</li>
                </ul>

                <div style="background: #d4edda; border: 1px solid #28a745; border-radius: 8px; padding: 1rem; margin-bottom: 1rem;">
                    <strong style="color: #155724;">Importante:</strong>
                    <span style="color: #155724;"> NO se eliminara nada de MercadoLibre. Tus ordenes, publicaciones y datos en MercadoLibre no se van a modificar. Solo se borran los datos de esta aplicacion.</span>
                </div>

                <div class="form-group" style="margin-top: 1rem;">
                    <label class="form-label">Para confirmar, escribi <strong>@deleteStats.Nickname</strong> en el campo de abajo:</label>
                    <input type="text" class="form-input" @bind="deleteConfirmText" @bind:event="oninput" placeholder="Escribi el nombre de la cuenta..."
                           style="@(deleteConfirmText.Length > 0 && deleteConfirmText != deleteStats.Nickname ? "border-color: #dc3545;" : "")" />
                    @if (deleteConfirmText.Length > 0 && deleteConfirmText != deleteStats.Nickname)
                    {
                        <small style="color: #dc3545; margin-top: 0.25rem; display: block;">El texto no coincide. Escribi exactamente <strong>@deleteStats.Nickname</strong> para confirmar.</small>
                    }
                    else if (string.IsNullOrEmpty(deleteConfirmText))
                    {
                        <small style="color: #856404; margin-top: 0.25rem; display: block;">Debes completar este campo para confirmar la eliminacion.</small>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseDeleteModal">Cancelar</button>
                <button class="btn btn-danger" @onclick="ConfirmRemoveAccount"
                        disabled="@(deleteConfirmText != deleteStats.Nickname || deletingAccount)">
                    @(deletingAccount ? "Eliminando..." : "Quitar cuenta y datos")
                </button>
            </div>
        </div>
    </div>
}

