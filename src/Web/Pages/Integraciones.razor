        finally
        {
            loadingModels = false;
        }
    }

    private void CloseOpenAiModal() => showOpenaiModal = false;

    private async Task SaveOpenAi()
    {
        openaiSaving = true;
        try
        {
            var settings = System.Text.Json.JsonSerializer.Serialize(new
            {
                model = openaiModel,
                maxTokens = openaiMaxTokens,
                temperature = openaiTemperature
            });

            var request = new SaveIntegrationRequest
            {
                Provider = "openai",
                AppId = null,
                AppSecret = string.IsNullOrWhiteSpace(openaiApiKey) ? null : openaiApiKey,
                RedirectUrl = null,
                Settings = settings,
                IsActive = openaiActive
            };

            var result = await Api.SaveIntegrationAsync(request);
            if (result is not null)
            {
                openaiId = result.Id;
                openaiHasSecret = result.HasSecret;
                openaiApiKey = "";
                ToastService.Success("Configuracion de OpenAI guardada");
                // Reload models if key was just set
                if (!openaiHasSecret || openaiModels == null)
                {
                    openaiHasSecret = result.HasSecret;
                    await LoadOpenAiModels();
                }
                else
                {
                    showOpenaiModal = false;
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al guardar: " + ex.Message);
        }
        finally
        {
            openaiSaving = false;
        }
    }

