    /// <summary>
    /// Inicia el flujo OAuth con Google: pide la URL al backend y redirige el browser.
    /// Usamos redirect full (no popup) por simplicidad — el callback redirige a /integraciones.
    /// </summary>
    private async Task ConnectWithGoogle()
    {
        driveConnecting = true;
        try
        {
            // Antes de conectar, si el usuario tocó "Reconectar" pero pegó un client_id/secret
            // nuevo, guardamos primero para que el backend tenga la config actualizada.
            if (!string.IsNullOrWhiteSpace(driveClientSecret))
            {
                await SaveDrive();
            }

            var url = await Api.GetGoogleDriveOAuthUrlAsync(CallbackUrl);
            if (string.IsNullOrEmpty(url))
            {
                ToastService.Error("No se pudo obtener la URL de Google. Asegurate de haber guardado el Client ID y Client Secret primero.");
                return;
            }
            // Full-redirect (mismo flujo que MeLi): al volver, /google-drive-callback canjea el code.
            Navigation.NavigateTo(url, forceLoad: true);
        }
        catch (Exception ex)
        {
            ToastService.Error("Error al conectar: " + ex.Message);
        }
        finally
        {
            driveConnecting = false;
        }
    }

