                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- Modal: Probar Login / Probar Comprobantes ARCA -->
@if (showArcaTestModal)
{
    var isFinishedOk = arcaTestResult is not null && arcaTestResult.Ok;
    var isFinishedErr = arcaTestResult is not null && !arcaTestResult.Ok;

    // Tamaño del modal según fase: configurar→chico, corriendo→grande, resultado→ancho
    string modalMaxWidth;
    if (arcaTestMode == "comprobantes")
    {
        if (arcaCompFase == "configurar") modalMaxWidth = "560px";
        else if (arcaCompFase == "resultado" && isFinishedOk) modalMaxWidth = "1100px";
        else if (arcaCompFase == "resultado" && isFinishedErr) modalMaxWidth = "560px";
        else modalMaxWidth = "1100px";
    }
    else
    {
        modalMaxWidth = (isFinishedOk || isFinishedErr) ? "720px" : "1100px";
    }

    var screenshotVisible = arcaTestRunning && !string.IsNullOrEmpty(arcaTestStep)
                            && !arcaTestStep.StartsWith("Iniciando", StringComparison.OrdinalIgnoreCase)
                            && !arcaTestStep.StartsWith("Abriendo navegador", StringComparison.OrdinalIgnoreCase);

    var titulo = arcaTestMode == "comprobantes"
        ? $"📄 Mis Comprobantes ARCA — {arcaTestCuit}"
        : $"🔍 Prueba de login ARCA — {arcaTestCuit}";

    <div class="modal-overlay" @onclick="CloseArcaTestModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: @modalMaxWidth; overflow: hidden;">
            <div class="modal-header">
                <h3>@titulo</h3>
                <button class="btn-close" @onclick="CloseArcaTestModal" disabled="@arcaTestRunning">&times;</button>
            </div>
            <div class="modal-body" style="overflow: hidden;">

                @* ═════════════ FASE 1: configurar (solo modo comprobantes) ═════════════ *@
                @if (arcaTestMode == "comprobantes" && arcaCompFase == "configurar")
                {
                    <p class="text-muted" style="margin-bottom: 0.8rem;">
                        Elegí el rango de fechas a consultar y tocá <strong>Buscar</strong>.
                        Vamos a descargar los CSV de Emitidos y Recibidos desde "Mis Comprobantes" de ARCA.
                    </p>
                    <div class="form-group">
                        <label class="form-label">Rango</label>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                            @{
                                var rangos = new (string cod, string label)[] {
                                    ("30dias", "Últimos 30 días"),
                                    ("60dias", "Últimos 60 días"),
                                    ("90dias", "Últimos 90 días"),
                                    ("custom", "Personalizado")
                                };
                            }
                            @foreach (var r in rangos)
                            {
                                var sel = arcaCompTipoRango == r.cod;
                                <button type="button" class="btn"
                                        style="font-size: 0.85rem; padding: 0.35rem 0.7rem; border-radius: 999px; border: 1.5px solid @(sel ? "#1d4ed8" : "#d1d5db"); background: @(sel ? "#1d4ed8" : "white"); color: @(sel ? "white" : "#374151");"
                                        @onclick="() => arcaCompTipoRango = r.cod">
                                    @r.label
                                </button>
                            }
                        </div>
                    </div>
                    @if (arcaCompTipoRango == "custom")
                    {
                        <div class="form-row" style="margin-top: 0.6rem;">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Desde</label>
                                <input type="date" class="form-input" @bind="arcaCompDesde" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Hasta</label>
                                <input type="date" class="form-input" @bind="arcaCompHasta" />
                            </div>
                        </div>
                    }
                }

                @* ═════════════ FASE 2: corriendo (spinner + screenshot en vivo) ═════════════ *@
                @if (arcaTestRunning)
                {
                    <div style="display: flex; align-items: center; gap: 0.8rem; padding: 0.7rem 0.9rem; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; margin-bottom: 1rem;">
                        <div style="width: 24px; height: 24px; border: 3px solid #bfdbfe; border-top-color: #1d4ed8; border-radius: 50%; animation: spin 1s linear infinite; flex-shrink: 0;"></div>
                        <div>
                            <strong style="color: #1e3a8a;">@arcaTestStep</strong>
                            <div style="font-size: 0.75rem; color: #6b7280;">El navegador del servidor está trabajando — abajo ves lo que ve.</div>
                        </div>
                    </div>

                    @if (screenshotVisible)
                    {
                        <div style="background: #1f2937; border-radius: 8px; padding: 0.5rem; text-align: center;">
                            <img src="@arcaScreenshotUrl" alt="Lo que ve el navegador"
                                 style="max-width: 100%; max-height: 60vh; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.4);"
                                 onerror="this.style.visibility='hidden'" onload="this.style.visibility='visible'" />
                        </div>
                    }
                }

                @* ═════════════ FASE 3: resultado ═════════════ *@
                @if (!arcaTestRunning && isFinishedErr)
                {
                    <div class="form-error" style="padding: 0.8rem; font-size: 0.9rem;">
                        <strong>❌ Falló la prueba:</strong>
                        <div style="margin-top: 0.3rem;">@arcaTestResult!.Error</div>
                    </div>
                }
                else if (!arcaTestRunning && isFinishedOk && arcaTestMode == "test")
                {
                    <div class="form-success" style="padding: 0.8rem 1rem; margin-bottom: 1rem;">
                        <strong>✅ Login OK — datos traídos del Registro Único Tributario</strong>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <small class="text-muted" style="text-transform: uppercase; font-weight: 700; font-size: 0.7rem;">Titular</small>
                        <div style="font-size: 1.1rem; font-weight: 700;">@(string.IsNullOrEmpty(arcaTestResult!.Titular) ? "—" : arcaTestResult.Titular)</div>
                    </div>

                    @if (arcaTestResult.Domicilios is not null && arcaTestResult.Domicilios.Count > 0)
                    {
                        <div style="margin-bottom: 1rem;">
                            <small class="text-muted" style="text-transform: uppercase; font-weight: 700; font-size: 0.7rem;">Domicilios</small>
                            <table class="data-table" style="font-size: 0.85rem; margin-top: 0.3rem;">
                                <thead>
                                    <tr><th>Tipo</th><th>Dirección</th><th>Jurisdicción</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in arcaTestResult.Domicilios)
                                    {
                                        <tr>
                                            <td>@d.Tipo</td>
                                            <td>@d.Direccion</td>
                                            <td>@d.Jurisdiccion</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (arcaTestResult.Actividades is not null && arcaTestResult.Actividades.Count > 0)
                    {
                        <div>
                            <small class="text-muted" style="text-transform: uppercase; font-weight: 700; font-size: 0.7rem;">Actividades</small>
                            <table class="data-table" style="font-size: 0.85rem; margin-top: 0.3rem;">
                                <thead>
                                    <tr><th>Descripción</th><th>Inicio</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var a in arcaTestResult.Actividades)
                                    {
                                        <tr>
                                            <td>@a.Descripcion</td>
                                            <td>@a.FechaInicio</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else if (!arcaTestRunning && isFinishedOk && arcaTestMode == "comprobantes")
                {
                    var rangoFmt = FormatoRango(arcaTestResult!.RangoDesde, arcaTestResult.RangoHasta);
                    var emitidos = arcaTestResult.Emitidos ?? new();
                    var recibidos = arcaTestResult.Recibidos ?? new();

                    <div class="form-success" style="padding: 0.7rem 1rem; margin-bottom: 0.8rem;">
                        <strong>✅ Comprobantes descargados</strong>
                        <span style="margin-left: 0.5rem; color: #166534;">— @rangoFmt</span>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">
                        @* ═══ Tabla Emitidos ═══ *@
                        <div style="border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; min-width: 0;">
                            <div style="padding: 0.4rem 0.6rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-weight: 700; font-size: 0.8rem; color: #374151;">
                                Comprobantes Emitidos (@emitidos.Count) — @rangoFmt
                            </div>
                            <div style="overflow-y: auto; max-height: 280px;">
                                @if (emitidos.Count == 0)
                                {
                                    <div style="padding: 1rem; text-align: center; color: #6b7280; font-size: 0.85rem;">Sin comprobantes en el rango.</div>
                                }
                                else
                                {
                                    <table class="data-table" style="font-size: 0.78rem; margin: 0; table-layout: fixed; width: 100%;">
                                        <thead>
                                            <tr>
                                                <th style="width: 80px;">Fecha</th>
                                                <th style="width: 110px;">Nro Doc</th>
                                                <th>Denominación</th>
                                                <th style="width: 90px; text-align: right;">Imp Neto</th>
                                                <th style="width: 80px; text-align: right;">IVA</th>
                                                <th style="width: 95px; text-align: right;">Imp Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var c in emitidos)
                                            {
                                                <tr>
                                                    <td>@FormatFechaArca(c.Fecha)</td>
                                                    <td>@c.NroDoc</td>
                                                    <td style="word-break: break-word;">@c.Denominacion</td>
                                                    <td style="text-align: right;">@FormatMoneyOrEmpty(c.ImpNeto)</td>
                                                    <td style="text-align: right;">@FormatMoneyOrEmpty(c.TotalIva)</td>
                                                    <td style="text-align: right; font-weight: 600;">@FormatMoneyOrEmpty(c.ImpTotal)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        </div>

                        @* ═══ Tabla Recibidos ═══ *@
                        <div style="border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; min-width: 0;">
                            <div style="padding: 0.4rem 0.6rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-weight: 700; font-size: 0.8rem; color: #374151;">
                                Comprobantes Recibidos (@recibidos.Count) — @rangoFmt
                            </div>
                            <div style="overflow-y: auto; max-height: 280px;">
                                @if (recibidos.Count == 0)
                                {
                                    <div style="padding: 1rem; text-align: center; color: #6b7280; font-size: 0.85rem;">Sin comprobantes en el rango.</div>
                                }
                                else
                                {
                                    <table class="data-table" style="font-size: 0.78rem; margin: 0; table-layout: fixed; width: 100%;">
                                        <thead>
                                            <tr>
                                                <th style="width: 80px;">Fecha</th>
                                                <th style="width: 110px;">Nro Doc</th>
                                                <th>Denominación</th>
                                                <th style="width: 90px; text-align: right;">Imp Neto</th>
                                                <th style="width: 80px; text-align: right;">IVA</th>
                                                <th style="width: 95px; text-align: right;">Imp Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var c in recibidos)
                                            {
                                                <tr>
                                                    <td>@FormatFechaArca(c.Fecha)</td>
                                                    <td>@c.NroDoc</td>
                                                    <td style="word-break: break-word;">@c.Denominacion</td>
                                                    <td style="text-align: right;">@FormatMoneyOrEmpty(c.ImpNeto)</td>
                                                    <td style="text-align: right;">@FormatMoneyOrEmpty(c.TotalIva)</td>
                                                    <td style="text-align: right; font-weight: 600;">@FormatMoneyOrEmpty(c.ImpTotal)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (arcaTestMode == "comprobantes" && arcaCompFase == "configurar")
                {
                    <button class="btn btn-secondary" @onclick="CloseArcaTestModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="StartArcaComprobantes">Buscar</button>
                }
                else
                {
                    <button class="btn btn-secondary" @onclick="CloseArcaTestModal" disabled="@arcaTestRunning">
                        @(arcaTestRunning ? "Trabajando..." : "Cerrar")
                    </button>
                }
            </div>
        </div>
    </div>
}


<!-- Modal: Configuración ARCA Webservice -->
@if (showArcaWsConfigModal)
{
    <div class="modal-overlay" @onclick="CloseArcaWsConfigModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Configuración de ARCA (webservice)</h3>
                <button class="btn-close" @onclick="CloseArcaWsConfigModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(arcaWsError))
                {
                    <div class="form-error">@arcaWsError</div>
                }
                <p class="text-muted" style="margin-bottom: 1rem;">
                    Subí los certificados .pfx que usás para los webservices de ARCA (factura electrónica, padrón, etc.). Cada uno se asocia a un CUIT y un ambiente (Producción / Homologación).
                </p>
                <div class="form-group">
                    <label class="form-label">
                        <input type="checkbox" @bind="arcaWsActive" /> Integración activa
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                @if (arcaWsId > 0)
                {
                    <button class="btn btn-danger" @onclick="DeleteArcaWsIntegration" disabled="@arcaWsSaving">
                        Eliminar integración
                    </button>
                }
                <button class="btn btn-secondary" @onclick="CloseArcaWsConfigModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveArcaWsConfig" disabled="@arcaWsSaving">
                    @(arcaWsSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Cargar / Editar certificado .pfx -->
@if (showArcaWsCertModal)
{
    <div class="modal-overlay" @onclick="CloseArcaWsCertModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(arcaWsIsEditing ? "Editar certificado" : "Cargar certificado")</h3>
                <button class="btn-close" @onclick="CloseArcaWsCertModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(arcaWsCertError))
                {
                    <div class="form-error">@arcaWsCertError</div>
                }
                <div class="form-group">
                    <label class="form-label">CUIT *</label>
                    <input type="text" class="form-input" @bind="arcaWsFormCuit"
                           placeholder="Ej: 30-71593809-1" maxlength="13"
                           disabled="@arcaWsIsEditing" />
                    @if (arcaWsIsEditing)
                    {
                        <span class="input-hint">El CUIT no se puede cambiar; eliminá el certificado y cargá uno nuevo si necesitás cambiarlo.</span>
                    }
                </div>
                <div class="form-group">
                    <label class="form-label">Alias (opcional)</label>
                    <input type="text" class="form-input" @bind="arcaWsFormAlias"
                           placeholder="Ej: Facturación electrónica producción" maxlength="100" />
                </div>
                <div class="form-group">
                    <label class="form-label">Ambiente *</label>
                    <select class="form-input" @bind="arcaWsFormEnvironment">
                        <option value="production">Producción</option>
                        <option value="homologation">Homologación</option>
                    </select>
                </div>

                @if (!arcaWsIsEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Archivo .pfx *</label>
                        <InputFile OnChange="OnArcaWsFilePicked" accept=".pfx" class="form-input" />
                        @if (!string.IsNullOrEmpty(arcaWsSelectedFileName))
                        {
                            <span class="input-hint">Seleccionado: <strong>@arcaWsSelectedFileName</strong></span>
                        }
                        else
                        {
                            <span class="input-hint">Tamaño máximo 10 MB.</span>
                        }
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">Contraseña del .pfx (opcional)</label>
                    <div style="position: relative;">
                        <input type="@(arcaWsShowPassword ? "text" : "password")"
                               class="form-input" @bind="arcaWsFormPassword"
                               placeholder="Si el .pfx tiene clave de exportación, ponela acá"
                               style="padding-right: 2.4rem;" />
                        <button type="button" class="btn-icon"
                                @onclick="() => arcaWsShowPassword = !arcaWsShowPassword"
                                style="position: absolute; right: 0.4rem; top: 50%; transform: translateY(-50%); background: transparent; border: none;"
                                title="@(arcaWsShowPassword ? "Ocultar" : "Mostrar")">
                            <i class="fa-solid @(arcaWsShowPassword ? "fa-eye-slash" : "fa-eye")"></i>
                        </button>
                    </div>
                    @if (arcaWsIsEditing)
                    {
                        <span class="input-hint">Si la dejás como está, no se modifica.</span>
                    }
                </div>

                @if (arcaWsIsEditing)
                {
                    <div class="form-group">
                        <label class="form-label">
                            <input type="checkbox" @bind="arcaWsFormIsActive" /> Certificado activo
                        </label>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseArcaWsCertModal" disabled="@arcaWsSaving2">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveArcaWsCert" disabled="@arcaWsSaving2">
                    @(arcaWsSaving2 ? "Guardando..." : (arcaWsIsEditing ? "Guardar cambios" : "Cargar certificado"))
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Wizard de generación de certificado ARCA -->
@if (showArcaWsWizard)
{
    <div class="modal-overlay" @onclick="CloseArcaWsWizardModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 720px;">
            <div class="modal-header">
                <h3>🔧 Generar nuevo certificado de ARCA</h3>
                <button class="btn-close" @onclick="CloseArcaWsWizardModal" disabled="@arcaWsWizardBusy">&times;</button>
            </div>

            @* ─── Stepper ─── *@
            <div style="display: flex; gap: 0.5rem; padding: 0.7rem 1.2rem 0; align-items: center;">
                @for (int i = 1; i <= 3; i++)
                {
                    var s = i;
                    var done = arcaWsWizardStep > s;
                    var active = arcaWsWizardStep == s;
                    var bg = done ? "#10b981" : active ? "#1d4ed8" : "#e5e7eb";
                    var color = (done || active) ? "white" : "#6b7280";
                    var label = s == 1 ? "Generar CSR" : s == 2 ? "Subir a ARCA" : "Cargar .crt";
                    <div style="display: flex; align-items: center; gap: 0.4rem;">
                        <span style="display: inline-flex; align-items: center; justify-content: center; width: 26px; height: 26px; border-radius: 50%; background: @bg; color: @color; font-weight: 800; font-size: 0.78rem;">@(done ? "✓" : s.ToString())</span>
                        <span style="font-size: 0.85rem; font-weight: 600; color: @(active ? "#1d4ed8" : "#6b7280");">@label</span>
                    </div>
                    @if (s < 3)
                    {
                        <span style="flex: 0 0 24px; height: 2px; background: @(done ? "#10b981" : "#e5e7eb");"></span>
                    }
                }
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(arcaWsWizardError))
                {
                    <div class="form-error">@arcaWsWizardError</div>
                }

                @* ═══════════════ Paso 1: generar CSR ═══════════════ *@
                @if (arcaWsWizardStep == 1)
                {
                    <p class="text-muted">
                        Generamos para vos una <strong>clave privada RSA 2048</strong> y un
                        <strong>CSR firmado con SHA-256</strong>. Después lo subís a ARCA y te
                        devuelve el certificado (.crt) que combinamos con la clave acá para
                        armar el .pfx final.
                    </p>
                    <div class="form-group">
                        <label class="form-label">CUIT *</label>
                        <input type="text" class="form-input" @bind="arcaWsWizardCuit"
                               placeholder="Ej: 30-71593809-1" maxlength="13" />
                        <span class="input-hint">11 dígitos. Los guiones se sacan automáticamente.</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Alias *</label>
                        <input type="text" class="form-input" @bind="arcaWsWizardAlias"
                               placeholder="Ej: MI_EMPRESA" maxlength="100" />
                        <span class="input-hint">Se usa como nombre interno y forma parte del subject del CSR.</span>
                    </div>
                }

                @* ═══════════════ Paso 2: descargar CSR + ir a ARCA ═══════════════ *@
                else if (arcaWsWizardStep == 2)
                {
                    <div class="form-success" style="padding: 0.7rem 1rem; margin-bottom: 0.9rem;">
                        <strong>✅ CSR generado correctamente</strong>
                    </div>
                    <div style="background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.7rem 0.9rem; margin-bottom: 1rem;">
                        <div style="font-size: 0.72rem; color: #6b7280; text-transform: uppercase; font-weight: 700; margin-bottom: 0.3rem;">Subject</div>
                        <div style="font-family: monospace; font-size: 0.82rem; word-break: break-all;">@(arcaWsWizardCsrSubject ?? "—")</div>
                    </div>

                    <button class="btn btn-primary" @onclick="DownloadArcaWsCsr" disabled="@arcaWsWizardBusy" style="margin-bottom: 1rem;">
                        ⬇ Descargar archivo CSR
                    </button>

                    <div style="background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 0.9rem; font-size: 0.88rem;">
                        <strong style="display: block; margin-bottom: 0.5rem;">Ahora subilo a ARCA:</strong>
                        <ol style="margin: 0; padding-left: 1.2rem; line-height: 1.7;">
                            <li>Ingresá a <a href="https://auth.afip.gob.ar/contribuyente_/login.xhtml" target="_blank" rel="noopener" style="color: #1d4ed8; text-decoration: underline;">auth.afip.gob.ar/contribuyente_/login.xhtml</a></li>
                            <li>Buscá y entrá al servicio <strong>"Administración de Certificados Digitales"</strong></li>
                            <li>Solicitá un nuevo certificado y subí el archivo <strong>.csr</strong> que descargaste</li>
                            <li>ARCA te devuelve un archivo <strong>.crt</strong>. Guardalo a mano</li>
                            <li>Volvé acá y tocá <strong>"Ya tengo el .crt"</strong></li>
                        </ol>
                    </div>
                }

                @* ═══════════════ Paso 3: subir .crt y generar .pfx ═══════════════ *@
                else if (arcaWsWizardStep == 3)
                {
                    <p class="text-muted">Subí el archivo <strong>.crt</strong> que te devolvió ARCA. Vamos a combinarlo con la clave privada que generamos antes y crear el .pfx final.</p>

                    <div class="form-group">
                        <label class="form-label">Archivo .crt de ARCA *</label>
                        <label class="arca-ws-file-drop" style="display: block; padding: 1rem; border: 2px dashed #93c5fd; border-radius: 8px; background: #eff6ff; cursor: pointer; text-align: center; transition: all 0.15s;">
                            <InputFile OnChange="OnArcaWsWizardCrtPicked" accept=".crt,.cer,.pem" style="display: none;" />
                            @if (string.IsNullOrEmpty(arcaWsWizardCrtFileName))
                            {
                                <span style="display: block; font-weight: 600; color: #1d4ed8; margin-bottom: 0.2rem;">📎 Elegir archivo .crt</span>
                                <span style="font-size: 0.78rem; color: #6b7280;">Acepta .crt, .cer o .pem (PEM o DER binario)</span>
                            }
                            else
                            {
                                <span style="display: block; font-weight: 700; color: #047857; margin-bottom: 0.2rem;">✓ @arcaWsWizardCrtFileName</span>
                                <span style="font-size: 0.78rem; color: #6b7280;">Click para cambiar el archivo</span>
                            }
                        </label>
                    </div>

                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Ambiente *</label>
                            <select class="form-input" @bind="arcaWsWizardEnvironment">
                                <option value="production">Producción</option>
                                <option value="homologation">Homologación</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Alias final</label>
                            <input type="text" class="form-input" @bind="arcaWsWizardAliasFinal" maxlength="100" />
                            <span class="input-hint">Se usa como nombre del .pfx en disco.</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Contraseña del .pfx (opcional)</label>
                        <input type="password" class="form-input" @bind="arcaWsWizardPfxPassword"
                               placeholder="Dejalo vacío si no querés protegerlo con clave" />
                        <span class="input-hint">Si dejás esto vacío, el .pfx queda sin contraseña.</span>
                    </div>
                }
            </div>

            <div class="modal-footer">
                @if (arcaWsWizardStep == 1)
                {
                    <button class="btn btn-secondary" @onclick="CloseArcaWsWizardModal" disabled="@arcaWsWizardBusy">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ArcaWsWizardStep1Submit" disabled="@arcaWsWizardBusy">
                        @(arcaWsWizardBusy ? "Generando..." : "Generar CSR")
                    </button>
                }
                else if (arcaWsWizardStep == 2)
                {
                    <button class="btn btn-secondary" @onclick="CloseArcaWsWizardModal" disabled="@arcaWsWizardBusy">Cerrar y continuar luego</button>
                    <button class="btn btn-primary" @onclick="() => arcaWsWizardStep = 3" disabled="@arcaWsWizardBusy">Ya tengo el .crt →</button>
                }
                else if (arcaWsWizardStep == 3)
                {
                    <button class="btn btn-secondary" @onclick="() => arcaWsWizardStep = 2" disabled="@arcaWsWizardBusy">← Volver</button>
                    <button class="btn btn-primary" @onclick="ArcaWsWizardStep3Submit" disabled="@arcaWsWizardBusy">
                        @(arcaWsWizardBusy ? "Generando .pfx..." : "Crear .pfx y agregar")
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- Modal: Probar Certificado ARCA Webservice (WSAA + WSFEv1) -->
@if (showArcaWsTestModal)
{
    <div class="modal-overlay" @onclick="CloseArcaWsTestModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 1100px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header">
                <h3>🔐 Probar Certificado — @arcaWsTestCertLabel</h3>
                <button class="btn-close" @onclick="CloseArcaWsTestModal" disabled="@arcaWsTestLoading">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y: auto;">

                @if (arcaWsTestLoading)
                {
                    <div style="display: flex; align-items: center; gap: 0.8rem; padding: 0.7rem 0.9rem; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px;">
                        <div style="width: 24px; height: 24px; border: 3px solid #bfdbfe; border-top-color: #1d4ed8; border-radius: 50%; animation: spin 1s linear infinite; flex-shrink: 0;"></div>
                        <strong style="color: #1e3a8a;">Conectando con ARCA (WSAA → WSFEv1)...</strong>
                    </div>
                }
                else if (arcaWsTestResult is null)
                {
                    <p class="text-muted">Sin resultados todavía.</p>
                }
                else if (!arcaWsTestResult.Success)
                {
                    @* Si el error empieza con ✅ es realmente un "login OK pero falta autorizar el servicio" — usamos amarillo en lugar de rojo. *@
                    var esFaltaAutorizacion = arcaWsTestResult.Error?.StartsWith("✅") == true;
                    var bg = esFaltaAutorizacion ? "#fef3c7" : "#fee2e2";
                    var border = esFaltaAutorizacion ? "#fbbf24" : "#fca5a5";
                    var color = esFaltaAutorizacion ? "#78350f" : "#7f1d1d";
                    var titulo = esFaltaAutorizacion ? "Falta un paso más en ARCA" : "No se pudo validar el certificado";
                    <div style="padding: 0.8rem 1rem; background: @bg; border: 1px solid @border; border-radius: 8px; color: @color;">
                        <strong>@titulo</strong>
                        <div style="margin-top: 0.4rem; white-space: pre-wrap; font-size: 0.9rem; line-height: 1.5;">@arcaWsTestResult.Error</div>
                    </div>
                }
                else
                {
                    <div class="form-success" style="padding: 0.7rem 1rem; margin-bottom: 0.9rem;">
                        <strong>✅ Certificado válido — autenticado correctamente contra ARCA</strong>
                    </div>

                    @* ═════════════════════ HOMOLOGACIÓN ═════════════════════ *@
                    @if (arcaWsTestResult.IsHomologation)
                    {
                        <div style="background: #fef3c7; border: 1px solid #fbbf24; border-radius: 8px; padding: 0.7rem 0.9rem; font-size: 0.86rem; color: #78350f; margin-bottom: 1rem;">
                            En <strong>homologación</strong> los puntos de venta son libres y <code>FEParamGetPtosVenta</code> no los devuelve.
                            Indicá manualmente el PtoVta y el tipo de comprobante para consultar los últimos.
                        </div>

                        <div class="form-row">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">PtoVta</label>
                                <input type="number" min="1" class="form-input" @bind="arcaWsHomoPtoVta" />
                            </div>
                            <div class="form-group" style="flex: 2;">
                                <label class="form-label">Tipo de comprobante</label>
                                <select class="form-input" @bind="arcaWsHomoCbteTipo">
                                    @foreach (var t in arcaWsTiposDisponibles)
                                    {
                                        <option value="@t.Id">@t.Label</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group" style="flex: 0 0 160px; align-self: flex-end;">
                                <button class="btn btn-primary" style="width: 100%;" @onclick="CargarUltimosHomo" disabled="@arcaWsSubLoading">
                                    @(arcaWsSubLoading ? "Cargando..." : "Cargar últimos 5")
                                </button>
                            </div>
                            <div class="form-group" style="flex: 0 0 220px; align-self: flex-end;">
                                <button class="btn btn-secondary" style="width: 100%;" @onclick="OpenArcaWsGenerarModal">
                                    🧾 Generar Comprobante de Prueba
                                </button>
                            </div>
                        </div>

                        @if (arcaWsSubError is not null)
                        {
                            <div class="form-error" style="margin-top: 0.5rem;">@arcaWsSubError</div>
                        }
                        @if (arcaWsSubComprobantes is not null)
                        {
                            <div style="margin-top: 0.8rem; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
                                <div style="padding: 0.4rem 0.7rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-weight: 700; font-size: 0.82rem;">
                                    Detalle últimos comprobantes — PtoVta @arcaWsHomoPtoVta · @CbteNombre(arcaWsHomoCbteTipo)
                                </div>
                                @if (arcaWsSubComprobantes.Count == 0)
                                {
                                    <div style="padding: 0.6rem; text-align: center; color: #6b7280; font-size: 0.85rem;">Sin comprobantes.</div>
                                }
                                else
                                {
                                    <div style="overflow-y: auto; max-height: 300px;">
                                        <table class="data-table" style="font-size: 0.78rem; margin: 0;">
                                            <thead>
                                                <tr>
                                                    <th>Tipo</th>
                                                    <th style="width: 80px;">Nro</th>
                                                    <th style="width: 90px;">Fecha</th>
                                                    <th>Doc Receptor</th>
                                                    <th style="text-align: right;">Imp Neto</th>
                                                    <th style="text-align: right;">IVA</th>
                                                    <th style="text-align: right;">Imp Total</th>
                                                    <th style="font-family: monospace;">CAE</th>
                                                    <th style="width: 95px;">Vto CAE</th>
                                                    <th style="width: 90px;">Resultado</th>
                                                    <th style="width: 60px;"></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var c in arcaWsSubComprobantes)
                                                {
                                                    var resOk = string.Equals(c.Resultado, "A", StringComparison.OrdinalIgnoreCase);
                                                    <tr>
                                                        <td>@c.CbteTipo</td>
                                                        <td>@c.CbteNro</td>
                                                        <td>@c.Fecha</td>
                                                        <td>@c.DocNro</td>
                                                        <td style="text-align: right;">@FormatMoneyOrEmpty(c.ImpNeto)</td>
                                                        <td style="text-align: right;">@FormatMoneyOrEmpty(c.ImpIVA)</td>
                                                        <td style="text-align: right; font-weight: 600;">@FormatMoneyOrEmpty(c.ImpTotal)</td>
                                                        <td style="font-family: monospace;">@c.Cae</td>
                                                        <td>@c.CaeVto</td>
                                                        <td>
                                                            <span style="color: @(resOk ? "#059669" : "#dc2626"); font-weight: 700;">
                                                                @(resOk ? "Aprobado" : (string.Equals(c.Resultado, "R", StringComparison.OrdinalIgnoreCase) ? "Rechazado" : c.Resultado))
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-secondary btn-sm" style="font-size: 0.7rem; padding: 0.15rem 0.45rem;"
                                                                    @onclick="() => VerPdfComprobante(arcaWsHomoPtoVta, c.CbteTipoNro, c.CbteNro)"
                                                                    disabled="@arcaWsPdfLoading"
                                                                    title="Generar y abrir PDF en pestaña nueva">
                                                                📄 PDF
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        }
                    }
                    @* ═════════════════════ PRODUCCIÓN ═════════════════════ *@
                    else
                    {
                        <div style="background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.82rem; color: #075985; margin-bottom: 0.8rem;">
                            ℹ Estos son los puntos de venta autorizados para emitir comprobantes vía <code>WSFEv1</code>. Pueden existir otros puntos de venta del CUIT (ej: <em>Factura en Línea</em>) que no se exponen por este web service.
                        </div>

                        @if (arcaWsTestResult.Puntos.Count == 0)
                        {
                            <p class="text-muted">El CUIT no tiene puntos de venta autorizados para WSFEv1.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="data-table" style="font-size: 0.85rem;">
                                    <thead>
                                        <tr>
                                            <th style="width: 60px;">Nro</th>
                                            <th>Tipo Emisión</th>
                                            <th style="width: 90px;">Bloqueado</th>
                                            <th style="width: 120px;">Fecha Baja</th>
                                            <th>Último Comprobante</th>
                                            <th style="width: 110px;">Última Fecha</th>
                                            <th style="width: 130px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in arcaWsTestResult.Puntos)
                                        {
                                            var rowKey = $"{p.Nro}:{p.UltimoCbteTipoNro}";
                                            var expanded = arcaWsExpandedKey == rowKey;
                                            <tr>
                                                <td><strong>@p.Nro</strong></td>
                                                <td>@p.EmisionTipo</td>
                                                <td>
                                                    @if (p.Bloqueado) { <span style="color: #dc2626; font-weight: 700;">Sí</span> }
                                                    else { <span style="color: #6b7280;">—</span> }
                                                </td>
                                                <td>@(p.FchBaja ?? "—")</td>
                                                <td>
                                                    @if (p.UltimoCbteNro > 0)
                                                    {
                                                        <span>@p.UltimoCbteTipo Nro <strong>@p.UltimoCbteNro</strong></span>
                                                    }
                                                    else { <span class="text-muted">Sin comprobantes</span> }
                                                </td>
                                                <td>@(p.UltimaFecha ?? "—")</td>
                                                <td>
                                                    @if (p.UltimoCbteNro > 0)
                                                    {
                                                        <button class="btn btn-secondary btn-sm" style="font-size: 0.72rem;"
                                                                @onclick="() => VerUltimos5(p)"
                                                                disabled="@arcaWsSubLoading">
                                                            @(expanded ? "Ocultar" : "Ver últimos 5")
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                            @if (expanded && arcaWsSubComprobantes is not null)
                                            {
                                                <tr>
                                                    <td colspan="7" style="background: #f9fafb; padding: 0.5rem;">
                                                        <div style="font-weight: 700; font-size: 0.82rem; margin-bottom: 0.3rem; color: #374151;">
                                                            Detalle últimos comprobantes — PtoVta @p.Nro · @p.UltimoCbteTipo
                                                        </div>
                                                        @if (arcaWsSubComprobantes.Count == 0)
                                                        {
                                                            <div style="padding: 0.5rem; text-align: center; color: #6b7280; font-size: 0.85rem;">Sin comprobantes.</div>
                                                        }
                                                        else
                                                        {
                                                            <div style="overflow-y: auto; max-height: 300px;">
                                                                <table class="data-table" style="font-size: 0.78rem; margin: 0;">
                                                                    <thead>
                                                                        <tr>
                                                                            <th>Tipo</th>
                                                                            <th style="width: 80px;">Nro</th>
                                                                            <th style="width: 90px;">Fecha</th>
                                                                            <th>Doc Receptor</th>
                                                                            <th style="text-align: right;">Imp Neto</th>
                                                                            <th style="text-align: right;">IVA</th>
                                                                            <th style="text-align: right;">Imp Total</th>
                                                                            <th style="font-family: monospace;">CAE</th>
                                                                            <th style="width: 95px;">Vto CAE</th>
                                                                            <th style="width: 90px;">Resultado</th>
                                                                            <th style="width: 60px;"></th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var c in arcaWsSubComprobantes)
                                                                        {
                                                                            var resOkx = string.Equals(c.Resultado, "A", StringComparison.OrdinalIgnoreCase);
                                                                            <tr>
                                                                                <td>@c.CbteTipo</td>
                                                                                <td>@c.CbteNro</td>
                                                                                <td>@c.Fecha</td>
                                                                                <td>@c.DocNro</td>
                                                                                <td style="text-align: right;">@FormatMoneyOrEmpty(c.ImpNeto)</td>
                                                                                <td style="text-align: right;">@FormatMoneyOrEmpty(c.ImpIVA)</td>
                                                                                <td style="text-align: right; font-weight: 600;">@FormatMoneyOrEmpty(c.ImpTotal)</td>
                                                                                <td style="font-family: monospace;">@c.Cae</td>
                                                                                <td>@c.CaeVto</td>
                                                                                <td>
                                                                                    <span style="color: @(resOkx ? "#059669" : "#dc2626"); font-weight: 700;">
                                                                                        @(resOkx ? "Aprobado" : (string.Equals(c.Resultado, "R", StringComparison.OrdinalIgnoreCase) ? "Rechazado" : c.Resultado))
                                                                                    </span>
                                                                                </td>
                                                                                <td>
                                                                                    <button class="btn btn-secondary btn-sm" style="font-size: 0.7rem; padding: 0.15rem 0.45rem;"
                                                                                            @onclick="() => VerPdfComprobante(p.Nro, c.CbteTipoNro, c.CbteNro)"
                                                                                            disabled="@arcaWsPdfLoading"
                                                                                            title="Generar y abrir PDF en pestaña nueva">
                                                                                        📄 PDF
                                                                                    </button>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                            @if (expanded && arcaWsSubError is not null)
                                            {
                                                <tr>
                                                    <td colspan="7"><div class="form-error">@arcaWsSubError</div></td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseArcaWsTestModal" disabled="@arcaWsTestLoading">Cerrar</button>
            </div>
        </div>
    </div>

}

<!-- Modal: Generar Comprobante de Prueba ARCA -->
@if (showArcaWsGenerarModal)
{
    <div class="modal-overlay" @onclick="CloseArcaWsGenerarModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 920px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header">
                <h3>🧾 Generar Comprobante de Prueba — @arcaWsTestCertLabel</h3>
                <button class="btn-close" @onclick="CloseArcaWsGenerarModal" disabled="@arcaWsGenLoading">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y: auto;">

                @* ─── ESTADO: cargando ─── *@
                @if (arcaWsGenLoading)
                {
                    <div style="display: flex; align-items: center; gap: 0.8rem; padding: 0.7rem 0.9rem; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px;">
                        <div style="width: 24px; height: 24px; border: 3px solid #bfdbfe; border-top-color: #1d4ed8; border-radius: 50%; animation: spin 1s linear infinite; flex-shrink: 0;"></div>
                        <strong style="color: #1e3a8a;">Emitiendo comprobante contra ARCA y generando PDF...</strong>
                    </div>
                }
                @* ─── ESTADO: resultado ─── *@
                else if (arcaWsGenResult is not null)
                {
                    @if (arcaWsGenResult.Success)
                    {
                        <div class="form-success" style="padding: 0.8rem 1rem; margin-bottom: 1rem;">
                            <strong>✅ Comprobante autorizado</strong>
                            @if (!string.IsNullOrEmpty(arcaWsGenResult.Observaciones))
                            {
                                <div style="font-size: 0.82rem; margin-top: 0.3rem; color: #92400e;">⚠ Observaciones: @arcaWsGenResult.Observaciones</div>
                            }
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem 1.4rem; margin-bottom: 1rem;">
                            <div><small class="text-muted">Tipo</small><div><strong>@arcaWsGenResult.CbteTipoNombre</strong></div></div>
                            <div><small class="text-muted">Nro</small><div><strong>@($"{arcaWsGenResult.PtoVta:00000}-{arcaWsGenResult.CbteNro:00000000}")</strong></div></div>
                            <div><small class="text-muted">CAE</small><div style="font-family: monospace;"><strong>@arcaWsGenResult.Cae</strong></div></div>
                            <div><small class="text-muted">Vto. CAE</small><div><strong>@FormatYyyymmddOrEmpty(arcaWsGenResult.CaeVto)</strong></div></div>
                            <div><small class="text-muted">Importe Total</small><div style="font-size: 1.1rem; color: #059669;"><strong>$ @FormatMoneyOrEmpty(arcaWsGenResult.ImpTotal)</strong></div></div>
                            <div><small class="text-muted">Resultado</small><div><strong>@arcaWsGenResult.Resultado</strong></div></div>
                        </div>
                        @if (!string.IsNullOrEmpty(arcaWsGenResult.PdfDownloadUrl))
                        {
                            <a class="btn btn-primary" href="@arcaWsGenResult.PdfDownloadUrl" target="_blank" rel="noopener">
                                ⬇ Descargar PDF
                            </a>
                        }
                        else if (!string.IsNullOrEmpty(arcaWsGenResult.Error))
                        {
                            <div style="background: #fef3c7; border: 1px solid #fbbf24; padding: 0.6rem; border-radius: 6px; font-size: 0.85rem; color: #78350f;">
                                ⚠ @arcaWsGenResult.Error
                            </div>
                        }
                    }
                    else
                    {
                        <div class="form-error" style="padding: 0.8rem; font-size: 0.9rem;">
                            <strong>❌ No se pudo emitir el comprobante:</strong>
                            <div style="margin-top: 0.3rem; white-space: pre-wrap;">@arcaWsGenResult.Error</div>
                        </div>
                    }
                }
                @* ─── ESTADO: formulario ─── *@
                else
                {
                    <div style="background: #fef3c7; border: 1px solid #fbbf24; padding: 0.5rem 0.7rem; border-radius: 6px; font-size: 0.82rem; color: #78350f; margin-bottom: 0.8rem;">
                        ⚠ Estás en <strong>homologación</strong>. El comprobante se va a emitir contra el ambiente de pruebas de ARCA (sin valor fiscal).
                    </div>

                    @if (!string.IsNullOrEmpty(arcaWsGenError))
                    {
                        <div class="form-error">@arcaWsGenError</div>
                    }

                    <div class="form-row">
                        <div class="form-group" style="flex: 1.4;">
                            <label class="form-label">Tipo de comprobante *</label>
                            <select class="form-input" @bind="arcaWsGenCbteTipo">
                                <option value="1">Factura A</option>
                                <option value="6">Factura B</option>
                                <option value="11">Factura C</option>
                                <option value="2">Nota Débito A</option>
                                <option value="7">Nota Débito B</option>
                                <option value="12">Nota Débito C</option>
                                <option value="3">Nota Crédito A</option>
                                <option value="8">Nota Crédito B</option>
                                <option value="13">Nota Crédito C</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 0 0 110px;">
                            <label class="form-label">PtoVta *</label>
                            <input type="number" min="1" class="form-input" @bind="arcaWsGenPtoVta" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Concepto *</label>
                            <select class="form-input" @bind="arcaWsGenConcepto">
                                <option value="1">Productos</option>
                                <option value="2">Servicios</option>
                                <option value="3">Productos y Servicios</option>
                            </select>
                        </div>
                    </div>

                    <h4 style="margin: 1rem 0 0.4rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">Receptor</h4>
                    <div class="form-row">
                        <div class="form-group" style="flex: 0 0 140px;">
                            <label class="form-label">Tipo doc</label>
                            <select class="form-input" @bind="arcaWsGenDocTipo">
                                <option value="80">CUIT</option>
                                <option value="96">DNI</option>
                                <option value="99">Consumidor Final</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label class="form-label">Nro doc</label>
                            <input type="text" class="form-input" @bind="arcaWsGenDocNro" disabled="@(arcaWsGenDocTipo == 99)" />
                        </div>
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">Razón social / Nombre</label>
                            <input type="text" class="form-input" @bind="arcaWsGenReceptorNombre" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">Domicilio (opcional)</label>
                            <input type="text" class="form-input" @bind="arcaWsGenReceptorDomicilio" />
                        </div>
                        <div class="form-group" style="flex: 2;">
                            <label class="form-label">Condición IVA del receptor *</label>
                            <select class="form-input" @bind="arcaWsGenCondicionIVA">
                                <option value="1">Responsable Inscripto</option>
                                <option value="6">Responsable Monotributo</option>
                                <option value="13">Monotributista Social</option>
                                <option value="16">Monotributo Trab. Indep. Promovido</option>
                                <option value="4">Sujeto Exento</option>
                                <option value="5">Consumidor Final</option>
                                <option value="7">Sujeto No Categorizado</option>
                                <option value="8">Proveedor del Exterior</option>
                                <option value="9">Cliente del Exterior</option>
                                <option value="10">IVA Liberado Ley 19.640</option>
                                <option value="15">IVA No Alcanzado</option>
                            </select>
                        </div>
                    </div>

                    <h4 style="margin: 1rem 0 0.4rem; color: #6b7280; font-size: 0.85rem; text-transform: uppercase;">Items</h4>
                    <table class="data-table" style="font-size: 0.85rem; table-layout: fixed; width: 100%;">
                        <thead>
                            <tr>
                                <th>Descripción</th>
                                <th style="width: 80px;">Cantidad</th>
                                <th style="width: 110px;">Precio Unit.</th>
                                <th style="width: 110px;">Alícuota IVA</th>
                                <th style="width: 100px; text-align: right;">Subtotal</th>
                                <th style="width: 36px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < arcaWsGenItems.Count; i++)
                            {
                                var idx = i;
                                var it = arcaWsGenItems[idx];
                                var sub = Math.Round(it.Cantidad * it.PrecioUnitario, 2);
                                <tr>
                                    <td><input class="form-input" style="font-size: 0.85rem; padding: 0.3rem;" @bind="it.Descripcion" /></td>
                                    <td><input class="form-input" type="number" step="0.01" min="0" style="font-size: 0.85rem; padding: 0.3rem;" @bind="it.Cantidad" /></td>
                                    <td><input class="form-input" type="number" step="0.01" min="0" style="font-size: 0.85rem; padding: 0.3rem;" @bind="it.PrecioUnitario" /></td>
                                    <td>
                                        <select class="form-input" style="font-size: 0.82rem; padding: 0.3rem;" @bind="it.AlicIvaId">
                                            <option value="3">0%</option>
                                            <option value="4">10.5%</option>
                                            <option value="5">21%</option>
                                            <option value="6">27%</option>
                                            <option value="8">5%</option>
                                            <option value="9">2.5%</option>
                                        </select>
                                    </td>
                                    <td style="text-align: right; font-weight: 600;">$ @sub.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</td>
                                    <td>
                                        <button class="btn-icon btn-delete" @onclick="() => arcaWsGenItems.RemoveAt(idx)" disabled="@(arcaWsGenItems.Count <= 1)" title="Eliminar item">×</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <button class="btn btn-secondary btn-sm" style="margin-top: 0.4rem;" @onclick="AgregarArcaWsItem">+ Agregar item</button>

                    var esTipoC = arcaWsGenCbteTipo == 11 || arcaWsGenCbteTipo == 12 || arcaWsGenCbteTipo == 13;
                    var neto = arcaWsGenItems.Sum(i => Math.Round(i.Cantidad * i.PrecioUnitario, 2));
                    var iva = esTipoC ? 0m : arcaWsGenItems.Sum(i => Math.Round(Math.Round(i.Cantidad * i.PrecioUnitario, 2) * (i.AlicIvaId switch { 3 => 0m, 4 => 10.5m, 5 => 21m, 6 => 27m, 8 => 5m, 9 => 2.5m, _ => 21m }) / 100m, 2));
                    var total = esTipoC ? neto : neto + iva;

                    <div style="margin-top: 1rem; padding: 0.6rem 0.9rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; text-align: right;">
                        <div style="font-size: 0.88rem;">Neto: <strong>$ @neto.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</strong></div>
                        @if (!esTipoC)
                        {
                            <div style="font-size: 0.88rem;">IVA: <strong>$ @iva.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</strong></div>
                        }
                        <div style="font-size: 1.1rem; margin-top: 0.2rem; color: #059669;">Total: <strong>$ @total.ToString("N2", new System.Globalization.CultureInfo("es-AR"))</strong></div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (arcaWsGenResult is not null && !arcaWsGenLoading)
                {
                    <button class="btn btn-secondary" @onclick="ResetArcaWsGenForm">Generar otro</button>
                    <button class="btn btn-primary" @onclick="CloseArcaWsGenerarModal">Cerrar</button>
                }
                else
                {
                    <button class="btn btn-secondary" @onclick="CloseArcaWsGenerarModal" disabled="@arcaWsGenLoading">Cancelar</button>
                    <button class="btn btn-primary" @onclick="EmitirArcaWsComprobante" disabled="@arcaWsGenLoading">
                        @(arcaWsGenLoading ? "Emitiendo..." : "Generar y autorizar")
                    </button>
                }
            </div>
        </div>
    </div>
}

<!-- Modal: Configuracion Email SMTP -->
@if (showEmailModal)
{
    <div class="modal-overlay" @onclick="CloseEmailModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Configuracion de Email</h3>
                <button class="btn-close" @onclick="CloseEmailModal">&times;</button>
            </div>
            <div class="modal-body">
                <h4 style="margin-bottom: 0.75rem; color: var(--text-primary);">Envio (SMTP)</h4>
                <div class="form-row">
                    <div class="form-group" style="flex:2">
                        <label class="form-label">Servidor SMTP</label>
                        <input type="text" class="form-input" @bind="emailSmtpHost" placeholder="smtp.gmail.com" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Puerto</label>
                        <input type="number" class="form-input" @bind="emailSmtpPort" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="emailSmtpTls" /> Usar TLS/SSL
                    </label>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Nombre remitente</label>
                        <input type="text" class="form-input" @bind="emailFromName" placeholder="Mi Empresa" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Email remitente</label>
                        <input type="email" class="form-input" @bind="emailFromAddress" placeholder="info@empresa.com" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Usuario</label>
                        <input type="text" class="form-input" @bind="emailUsername" placeholder="Igual al email si no se especifica" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Contraseña</label>
                        <input type="password" class="form-input" @bind="emailPassword"
                               placeholder="@(emailHasSecret ? "••••••••  (ya configurada)" : "Contraseña o App Password")" />
                    </div>
                </div>

                <hr style="margin: 1.25rem 0; border: none; border-top: 1px solid var(--border);" />

                <h4 style="margin-bottom: 0.75rem; color: var(--text-primary);">Lectura (IMAP)</h4>
                <div class="form-row">
                    <div class="form-group" style="flex:2">
                        <label class="form-label">Servidor IMAP</label>
                        <input type="text" class="form-input" @bind="emailImapHost" placeholder="imap.gmail.com" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Puerto</label>
                        <input type="number" class="form-input" @bind="emailImapPort" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="emailImapTls" /> Usar TLS/SSL
                    </label>
                </div>

                <hr style="margin: 1.25rem 0; border: none; border-top: 1px solid var(--border);" />

                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="emailActive" /> Activo
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                @if (emailId > 0)
                {
                    <button class="btn btn-danger" @onclick="DeleteEmail" disabled="@emailSaving" style="margin-right: auto;">
                        Eliminar
                    </button>
                }
                <button class="btn btn-outline-primary" @onclick="TestEmail" disabled="@(emailSaving || emailTesting)">
                    @(emailTesting ? "Enviando..." : "Enviar prueba")
                </button>
                <button class="btn btn-secondary" @onclick="CloseEmailModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveEmail" disabled="@emailSaving">
                    @(emailSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Configuracion Google Drive -->
@if (showDriveModal)
{
    <div class="modal-overlay" @onclick="CloseDriveModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 720px;">
            <div class="modal-header">
                <h3>Configuración de Google Drive</h3>
                <button class="btn-close" @onclick="CloseDriveModal">&times;</button>
            </div>
            <div class="modal-body">
                <div style="background: #f0f9ff; border: 1px solid #bae6fd; padding: 0.75rem 1rem; border-radius: 6px; margin-bottom: 1rem; font-size: 0.85rem; color: #075985;">
                    <strong>Cómo configurar (OAuth 2.0):</strong>
                    <ol style="margin: 0.4rem 0 0 1.2rem; padding: 0;">
                        <li>En Google Cloud Console → APIs &amp; Services → Credentials, crear un <strong>OAuth 2.0 Client ID</strong> tipo "Web application".</li>
                        <li>En "Authorized redirect URIs" agregar exactamente: <code style="background:#fff;padding:1px 4px;border-radius:3px;">@CallbackUrl</code></li>
                        <li>Copiar acá abajo el <strong>Client ID</strong> y el <strong>Client Secret</strong> + el ID de la carpeta destino.</li>
                        <li>Tocar <strong>Guardar</strong> y después <strong>Conectar con Google</strong> para autorizar el acceso a tu Drive.</li>
                    </ol>
                </div>

                <div class="form-group">
                    <label class="form-label">Client ID</label>
                    <input type="text" class="form-input" @bind="driveClientId"
                           placeholder="123456789012-abc123def.apps.googleusercontent.com" />
                </div>

                <div class="form-group">
                    <label class="form-label">Client Secret</label>
                    <input type="password" class="form-input" @bind="driveClientSecret"
                           placeholder="@(driveHasClientSecret ? "•••••••• (ya configurado — pegá uno nuevo solo si querés reemplazarlo)" : "GOCSPX-...")" />
                </div>

                <div class="form-group">
                    <label class="form-label">ID de la carpeta raíz en Drive</label>
                    <input type="text" class="form-input" @bind="driveFolderId"
                           placeholder="Ej: 1zKaxT_c6jHcP7DXr2YoA3kiqN05mGMut" />
                    <small class="text-muted" style="display: block; margin-top: 0.25rem;">
                        Es el ID que aparece en la URL de la carpeta cuando la abrís en Drive.
                    </small>
                </div>

                @if (driveHasSecret)
                {
                    <div style="background:#dcfce7;border:1px solid #86efac;padding:0.6rem 0.9rem;border-radius:6px;margin-bottom:1rem;color:#166534;font-size:0.85rem;">
                        <strong>✓ Conectado con Google.</strong> Si querés cambiar de cuenta, tocá "Reconectar con Google".
                    </div>
                }
                else if (driveId > 0)
                {
                    <div style="background:#fef3c7;border:1px solid #fde68a;padding:0.6rem 0.9rem;border-radius:6px;margin-bottom:1rem;color:#92400e;font-size:0.85rem;">
                        <strong>⚠ Falta autorizar.</strong> Guardá la configuración y luego tocá "Conectar con Google".
                    </div>
                }

                <div class="form-group">
                    <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="checkbox" @bind="driveActive" /> Activo
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                @if (driveId > 0)
                {
                    <button class="btn btn-danger" @onclick="DeleteDrive" disabled="@driveSaving" style="margin-right: auto;">
                        Eliminar
                    </button>
                }
                @if (driveId > 0 && driveHasClientSecret)
                {
                    <button class="btn btn-outline-primary" @onclick="ConnectWithGoogle" disabled="@(driveSaving || driveConnecting)">
                        @(driveConnecting ? "Conectando..." : (driveHasSecret ? "🔐 Reconectar con Google" : "🔐 Conectar con Google"))
                    </button>
                }
                @if (driveHasSecret)
                {
                    <button class="btn btn-outline-primary" @onclick="TestDrive" disabled="@(driveSaving || driveTesting)">
                        @(driveTesting ? "Probando..." : "Probar conexión")
                    </button>
                }
                <button class="btn btn-secondary" @onclick="CloseDriveModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveDrive" disabled="@driveSaving">
                    @(driveSaving ? "Guardando..." : "Guardar")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal: Verificar comprobante en ARCA (FECompConsultar) -->
@if (showArcaConsultaModal)
{
    <div class="modal-overlay" @onclick="CloseArcaConsultaModal">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 720px; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header">
                <h3>🔎 Verificar comprobante en ARCA — @arcaConsultaCuit</h3>
                <button class="btn-close" @onclick="CloseArcaConsultaModal" disabled="@arcaConsultaLoading">&times;</button>
            </div>
            <div class="modal-body" style="overflow-y: auto;">
                <div style="background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.85rem; color: #075985; margin-bottom: 1rem;">
                    Consultá si un comprobante específico ya está autorizado en ARCA (FECompConsultar). Solo lectura — no modifica nada.
                </div>

                <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.6rem; margin-bottom: 0.8rem;">
                    <div class="form-group">
                        <label>Punto de venta</label>
                        <input type="number" class="form-control" min="1" @bind="arcaConsultaPtoVta" disabled="@arcaConsultaLoading" />
                    </div>
                    <div class="form-group">
                        <label>Tipo de comprobante</label>
                        <select class="form-control" @bind="arcaConsultaCbteTipo" disabled="@arcaConsultaLoading">
                            <option value="1">1 — Factura A</option>
                            <option value="6">6 — Factura B</option>
                            <option value="11">11 — Factura C</option>
                            <option value="3">3 — Nota de Crédito A</option>
                            <option value="8">8 — Nota de Crédito B</option>
                            <option value="13">13 — Nota de Crédito C</option>
                            <option value="2">2 — Nota de Débito A</option>
                            <option value="7">7 — Nota de Débito B</option>
                            <option value="12">12 — Nota de Débito C</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Número</label>
                        <input type="number" class="form-control" min="1" @bind="arcaConsultaCbteNro" disabled="@arcaConsultaLoading" />
                    </div>
                </div>

                <button class="btn btn-primary" @onclick="EjecutarArcaConsulta" disabled="@arcaConsultaLoading" style="width: 100%;">
                    @(arcaConsultaLoading ? "Consultando ARCA..." : "🔎 Consultar")
                </button>

                @if (arcaConsultaError is not null)
                {
                    <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 0.8rem 1rem; margin-top: 1rem;">
                        <div style="font-weight: 700; color: #b91c1c; margin-bottom: 0.3rem;">❌ ARCA respondió con error</div>
                        <div style="font-size: 0.88rem; color: #7f1d1d; font-family: monospace;">@arcaConsultaError</div>
                        <div style="font-size: 0.82rem; color: #7f1d1d; margin-top: 0.5rem;">
                            Esto puede significar que <strong>el comprobante NO existe en ARCA</strong> (fantasma), o que los datos consultados son incorrectos.
                        </div>
                    </div>
                }

                @if (arcaConsultaResult is not null && arcaConsultaResult.Success)
                {
                    var resOk = string.Equals(arcaConsultaResult.Resultado, "A", StringComparison.OrdinalIgnoreCase);
                    <div style="background: @(resOk ? "#ecfdf5" : "#fef2f2"); border: 1px solid @(resOk ? "#a7f3d0" : "#fecaca"); border-radius: 8px; padding: 0.9rem 1.1rem; margin-top: 1rem;">
                        <div style="font-weight: 800; font-size: 1.05rem; color: @(resOk ? "#065f46" : "#7f1d1d"); margin-bottom: 0.6rem;">
                            @(resOk ? "✅ Comprobante CONFIRMADO en ARCA" : "⚠ Comprobante existe pero NO está aprobado")
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem 1.2rem; font-size: 0.9rem;">
                            <div><strong>Tipo:</strong> @arcaConsultaResult.CbteTipoNombre (cód. @arcaConsultaResult.CbteTipo)</div>
                            <div><strong>PtoVta - Nro:</strong> @arcaConsultaResult.PtoVta - @arcaConsultaResult.CbteNro</div>
                            <div><strong>Fecha:</strong> @FormatFechaArca(arcaConsultaResult.FechaYyyymmdd)</div>
                            <div><strong>Doc receptor:</strong> @arcaConsultaResult.DocNro</div>
                            <div><strong>Importe neto:</strong> @FormatMoneyOrEmpty(arcaConsultaResult.ImpNeto)</div>
                            <div><strong>IVA:</strong> @FormatMoneyOrEmpty(arcaConsultaResult.ImpIVA)</div>
                            <div style="grid-column: 1 / -1;"><strong>Importe total:</strong> <span style="font-size: 1.05rem; font-weight: 800;">@FormatMoneyOrEmpty(arcaConsultaResult.ImpTotal)</span></div>
                            <div style="grid-column: 1 / -1; font-family: monospace; word-break: break-all;"><strong>CAE:</strong> @arcaConsultaResult.Cae</div>
                            <div><strong>Vto CAE:</strong> @FormatFechaArca(arcaConsultaResult.CaeVtoYyyymmdd)</div>
                            <div><strong>Resultado:</strong> @arcaConsultaResult.Resultado</div>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseArcaConsultaModal" disabled="@arcaConsultaLoading">Cerrar</button>
            </div>
        </div>
    </div>
}

