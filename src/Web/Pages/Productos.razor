    private async Task SaveProduct()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formTitle)) { formError = "El titulo es obligatorio"; return; }
        isSaving = true;
        try
        {
            // Si la marca exige manejar stock por lotes, no enviamos el campo Stock manual:
            // se calcula como suma de lotes en el backend.
            var requiresExpiry = FormRequiresExpiry;

            if (isEditing && editingProductId.HasValue)
            {
                // Detectar bajada de precio para alertar al usuario (no bloquea, solo avisa).
                var original = products?.FirstOrDefault(p => p.Id == editingProductId.Value);
                string? priceWarning = null;
                if (original is not null && !requiresExpiry && formBaseProductId == 0)
                {
                    var costDropped = formCostPrice > 0 && formCostPrice < original.CostPrice;
                    var retailDropped = formRetailPrice > 0 && formRetailPrice < original.RetailPrice;
                    if (costDropped && retailDropped)
                        priceWarning = $"Bajaron costo (de ${FormatPrice(original.CostPrice)} a ${FormatPrice(formCostPrice)}) y PVP (de ${FormatPrice(original.RetailPrice)} a ${FormatPrice(formRetailPrice)})";
                    else if (costDropped)
                        priceWarning = $"Bajo el costo de ${FormatPrice(original.CostPrice)} a ${FormatPrice(formCostPrice)}";
                    else if (retailDropped)
                        priceWarning = $"Bajo el PVP de ${FormatPrice(original.RetailPrice)} a ${FormatPrice(formRetailPrice)}";
                }

                var update = new UpdateProductRequest {
                    Title = formTitle, DisplayName = formDisplayName, Description = formDescription,
                    Sku = formSku, Barcode = formBarcode, OemCode = formOemCode, ImageUrl = formImageUrl,
                    Model = formModel,
                    CostPrice = formCostPrice, RetailPrice = formRetailPrice,
                    VatRate = formVatRate,
                    PurchaseAccount = formPurchaseAccount, SaleAccount = formSaleAccount, InventoryAccount = formInventoryAccount,
                    CriticalStock = formCriticalStock, IsActive = formIsActive,
                    Photo1 = formPhoto1 ?? "", Photo2 = formPhoto2 ?? "", Photo3 = formPhoto3 ?? ""
                };
                if (!requiresExpiry) update.Stock = formStock;
                if (formBaseProductId > 0) update.BaseProductId = formBaseProductId;
                else update.ClearBaseProduct = true;
                if (formBrandId > 0) update.BrandId = formBrandId;
                else update.ClearBrand = true;
                update.IsBase = formIsBase;
                // Solo mandamos StockUnit si es padre (los hijos siempre quedan en 'unidad')
                if (formIsBase) update.StockUnit = formStockUnit;
                if (formUnitsPerPack.HasValue && formUnitsPerPack.Value > 0)
                    update.UnitsPerPack = formUnitsPerPack.Value;
                else
                    update.ClearUnitsPerPack = true;
                // Fraccionamiento (solo afecta hijos, pero lo enviamos siempre — el backend ignora si no aplica)
                update.Fraction = formFraction <= 0 ? 1m : formFraction;
                update.MarkupAmount = formMarkupAmount;
                var result = await Api.UpdateProductAsync(editingProductId.Value, update);
                if (result is null) { formError = "Error al actualizar el producto"; return; }
                ToastService.Success("Producto actualizado");
                if (priceWarning is not null)
                    ToastService.Error("⚠ " + priceWarning);
            }
            else
            {
                // Si el SKU ya existe entre los productos cargados, el backend va a hacer upsert.
                // Detectamos posible bajada de precio para alertar.
                ProductDto? existingBySku = null;
                string? priceWarning = null;
                if (!string.IsNullOrWhiteSpace(formSku))
                {
                    existingBySku = products?.FirstOrDefault(p => string.Equals(p.Sku, formSku, StringComparison.OrdinalIgnoreCase));
                    if (existingBySku is not null && !requiresExpiry && formBaseProductId == 0)
                    {
                        var costDropped = formCostPrice > 0 && formCostPrice < existingBySku.CostPrice;
                        var retailDropped = formRetailPrice > 0 && formRetailPrice < existingBySku.RetailPrice;
                        if (costDropped && retailDropped)
                            priceWarning = $"Bajaron costo (de ${FormatPrice(existingBySku.CostPrice)} a ${FormatPrice(formCostPrice)}) y PVP (de ${FormatPrice(existingBySku.RetailPrice)} a ${FormatPrice(formRetailPrice)})";
                        else if (costDropped)
                            priceWarning = $"Bajo el costo de ${FormatPrice(existingBySku.CostPrice)} a ${FormatPrice(formCostPrice)}";
                        else if (retailDropped)
                            priceWarning = $"Bajo el PVP de ${FormatPrice(existingBySku.RetailPrice)} a ${FormatPrice(formRetailPrice)}";
                    }
                }

                var create = new CreateProductRequest {
                    Title = formTitle, DisplayName = formDisplayName, Description = formDescription,
                    Sku = formSku, Barcode = formBarcode, OemCode = formOemCode, ImageUrl = formImageUrl,
                    Model = formModel,
                    CostPrice = formCostPrice, RetailPrice = formRetailPrice,
                    VatRate = formVatRate,
                    PurchaseAccount = formPurchaseAccount, SaleAccount = formSaleAccount, InventoryAccount = formInventoryAccount,
                    Stock = requiresExpiry ? 0 : formStock, CriticalStock = formCriticalStock,
                    Photo1 = formPhoto1, Photo2 = formPhoto2, Photo3 = formPhoto3
                };
                if (formBaseProductId > 0) create.BaseProductId = formBaseProductId;
                if (formBrandId > 0) create.BrandId = formBrandId;
                create.IsBase = formIsBase;
                // StockUnit solo es relevante para padres
                create.StockUnit = formIsBase ? formStockUnit : "unidad";
                if (formUnitsPerPack.HasValue && formUnitsPerPack.Value > 0)
                    create.UnitsPerPack = formUnitsPerPack.Value;
                // Fraccionamiento (solo aplica si es hijo)
                create.Fraction = formFraction <= 0 ? 1m : formFraction;
                create.MarkupAmount = formMarkupAmount;
                var result = await Api.CreateProductAsync(create);
                if (result is null) { formError = "Error al crear el producto"; return; }
                if (existingBySku is not null)
                    ToastService.Success($"Producto actualizado (ya existia el SKU '{formSku}')");
                else
                    ToastService.Success(requiresExpiry
                        ? "Producto creado. Tocá '📅 Lotes' para cargar el stock con vencimiento."
                        : "Producto creado");
                if (priceWarning is not null)
                    ToastService.Error("⚠ " + priceWarning);
            }
            showForm = false; await LoadData();
        }
        catch (Exception ex) { formError = "Error al guardar: " + ex.Message; }
        finally { isSaving = false; }
    }

