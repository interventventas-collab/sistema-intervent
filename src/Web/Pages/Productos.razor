    private async Task ExecuteBulkPublish()
    {
        bulkPublishError = null;
        if (bulkPubAccountId == 0) { bulkPublishError = "Selecciona una cuenta"; return; }
        if (bulkPubPriceMode == "markup" && bulkPubMarkup < 0) { bulkPublishError = "El % de aumento no puede ser negativo"; return; }

        // Resolver listing type real (cuotas = gold_special + configuracion)
        var realListingType = bulkPubListingType;
        if (realListingType.StartsWith("gold_special_")) realListingType = "gold_special";

        isBulkPublishing = true;
        var allProductIds = selectedItems.ToList();
        bulkPublishTotal = allProductIds.Count;
        bulkPublishCurrent = 0;
        bulkPublishOkCount = 0; bulkPublishErrCount = 0; bulkPublishSkipCount = 0;
        bulkPublishCurrentTitle = null;
        StateHasChanged();

        var allResults = new List<BulkPublishItemResult>();

        // Publicar de a 1 producto para mostrar progreso
        foreach (var productId in allProductIds)
        {
            bulkPublishCurrent++;
            var prod = products?.FirstOrDefault(p => p.Id == productId);
            bulkPublishCurrentTitle = prod?.Title ?? "Producto #" + productId;
            StateHasChanged();
            await Task.Delay(1); // Dar tiempo al render

            try
            {
                var request = new BulkPublishRequest
                {
                    ProductIds = new List<int> { productId },
                    MeliAccountId = bulkPubAccountId,
                    ListingTypeId = realListingType,
                    PriceMode = bulkPubPriceMode,
                    MarkupPercent = bulkPubMarkup,
                    Condition = "new",
                    FreeShipping = bulkPubFreeShipping
                };
                var result = await Api.BulkPublishAsync(request);
                if (result?.Results != null)
                {
                    allResults.AddRange(result.Results);
                    bulkPublishOkCount += result.Successful;
                    bulkPublishErrCount += result.Failed;
                    bulkPublishSkipCount += result.Skipped;
                }
            }
            catch (Exception ex)
            {
                allResults.Add(new BulkPublishItemResult
                {
                    ProductId = productId,
                    ProductTitle = bulkPublishCurrentTitle,
                    Error = ex.Message
                });
                bulkPublishErrCount++;
            }
            StateHasChanged();
        }

        bulkPublishResult = new BulkPublishResponse
        {
            Total = allProductIds.Count,
            Successful = bulkPublishOkCount,
            Failed = bulkPublishErrCount,
            Skipped = bulkPublishSkipCount,
            Results = allResults
        };
        if (bulkPublishOkCount > 0)
            ToastService.Success(bulkPublishOkCount + " productos publicados en MercadoLibre");
        if (bulkPublishErrCount > 0)
            ToastService.Error(bulkPublishErrCount + " productos fallaron al publicar");
        isBulkPublishing = false;
        StateHasChanged();
    }

    private IEnumerable<string> GetPublicacionesFilterValues()
    {
        if (products is null) return Enumerable.Empty<string>();
        var accountNames = products
            .SelectMany(p => p.LinkedAccounts.Select(a => a.Nickname))
            .Distinct().OrderBy(x => x).ToList();
        var values = new List<string>();
        foreach (var name in accountNames)
            values.Add(name);
        foreach (var name in accountNames)
            values.Add("Sin " + name);
        values.Add("Sin publicar");
        return values;
    }

    private IEnumerable<ProductDto> ApplyPublicacionesFilter(IEnumerable<ProductDto> source, HashSet<string> selected)
    {
        return source.Where(p =>
        {
            // Positivos: cuentas donde SI esta publicado
            if (p.LinkedAccounts.Any(a => selected.Contains(a.Nickname)))
                return true;
            // "Sin publicar" = sin ninguna cuenta
            if (selected.Contains("Sin publicar") && p.LinkedAccounts.Count == 0)
                return true;
            // Negativos: "Sin X" = NO esta publicado en X
            foreach (var val in selected.Where(v => v.StartsWith("Sin ") && v != "Sin publicar"))
            {
                var accountName = val.Substring(4);
                if (!p.LinkedAccounts.Any(a => a.Nickname == accountName))
                    return true;
            }
            return false;
        });
    }

    private List<(string text, bool isWarning)> GetErrorLines(string error)
    {
        var lines = error.Split("|||", StringSplitOptions.RemoveEmptyEntries);
        var errors = new List<(string text, bool isWarning)>();
        var warnings = new List<(string text, bool isWarning)>();
        foreach (var line in lines)
        {
            var trimmed = line.Trim();
            if (trimmed.StartsWith("[WARN]"))
                warnings.Add((trimmed.Replace("[WARN] ", ""), true));
            else
                errors.Add((trimmed.Replace("[ERROR] ", ""), false));
        }
        errors.AddRange(warnings);
        return errors;
    }

