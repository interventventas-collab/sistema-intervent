    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        Company.OnChange += OnCompanyChanged;
        Operator.OnChange += OnOperatorChanged;
        await LoadData();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        Company.OnChange -= OnCompanyChanged;
        Operator.OnChange -= OnOperatorChanged;
    }

    private void OnOperatorChanged()
    {
        // Si el operador cambia y deja de ser OSMAR, cerramos todos los candados.
        if (!CanUnlock) unlockedColumns.Clear();
        InvokeAsync(StateHasChanged);
    }

    private void OnCompanyChanged()
    {
        InvalidateFilterCache();
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Cambio entre /productos y /productos-base: invalidar cache de filtros y refrescar.
        InvalidateFilterCache();
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            products = await Api.GetProductsAsync();
            totalProducts = products?.Count ?? 0;
            _filterDirty = true;
        }
        catch { ToastService.Error("Error al cargar los productos"); }
        try
        {
            brands = await Api.GetBrandsAsync() ?? new();
        }
        catch { brands = new(); }
        isLoading = false;
    }

    // ===== FILTER & SORT METHODS =====

    private void SetTextFilter(string column, string value)
    {
        textFilters[column] = value;
        _filterDirty = true;
    }

    private string GetTextFilter(string column) => textFilters.TryGetValue(column, out var val) ? val : "";

    private bool IsFilterActive(string column) => textFilters.TryGetValue(column, out var tv) && !string.IsNullOrEmpty(tv);

    private void ToggleSort(string column)
    {
        if (sortColumn == column) sortAsc = !sortAsc;
        else { sortColumn = column; sortAsc = true; }
        _filterDirty = true;
    }

    private void ToggleDropdownFilter(string column)
    {
        activeFilterColumn = activeFilterColumn == column ? null : column;
    }

    private void ToggleCheckboxValue(string column, string value)
    {
        if (!checkboxFilters.ContainsKey(column))
            checkboxFilters[column] = new HashSet<string>();
        if (!checkboxFilters[column].Remove(value))
            checkboxFilters[column].Add(value);
        _filterDirty = true;
    }

    private bool IsCheckboxChecked(string column, string value)
        => checkboxFilters.TryGetValue(column, out var set) && set.Contains(value);

    private bool IsCheckboxFilterActive(string column)
        => checkboxFilters.TryGetValue(column, out var cv) && cv.Count > 0;

    private IEnumerable<string> GetUniqueValues(string column)
    {
        if (products is null) return Enumerable.Empty<string>();
        return column switch
        {
            "estado" => products.Select(p => p.IsActive ? "Activo" : "Inactivo").Distinct().OrderBy(x => x),
            "publicaciones" => GetPublicacionesFilterValues(),
            _ => Enumerable.Empty<string>()
        };
    }

    private void ClearCheckboxFilter(string column)
    {
        checkboxFilters.Remove(column);
        _filterDirty = true;
        activeFilterColumn = null;
    }

    private List<ProductDto> GetFilteredProducts()
    {
        if (_filterDirty || _cachedFiltered is null)
        {
            _cachedFiltered = ApplyFiltersAndSort();
            _filterDirty = false;
        }
        return _cachedFiltered;
    }

    private void InvalidateFilterCache()
    {
        _filterDirty = true;
    }

    private void OnFilterTypeChanged() => InvalidateFilterCache();

    // Vista unificada: muestra padres + hijos en la misma pagina.
    // Mantenemos /productos-base como ruta valida por compatibilidad pero ya no filtra.
    // (Antes /productos-base mostraba solo padres y /productos solo hijos.)
    private bool IsBaseOnlyView => false;

    private string PageTitle => "Productos Padre e hijos";

    // Productos visibles para la empresa actual (filtra por la propiedad Companies de la marca asociada).
    // SIEMPRE excluye servicios (IsService=true): los servicios viven en su propia pagina.
    private IEnumerable<ProductDto> CompanyVisibleProducts()
    {
        if (products is null) return Enumerable.Empty<ProductDto>();
        var noServices = products.Where(p => !p.IsService);
        if (!Company.HasCompany || brands is null || brands.Count == 0) return noServices;
        var visibleBrandIds = brands
            .Where(b => CurrentCompanyService.IsVisibleForCompany(b.Companies, Company.Current!))
            .Select(b => b.Id)
            .ToHashSet();
        return noServices.Where(p => p.BrandId == null || visibleBrandIds.Contains(p.BrandId.Value));
    }

    private int VisibleTotal => CompanyVisibleProducts().Count();

    private List<ProductDto> ApplyFiltersAndSort()
    {
        if (products is null) return new();
        IEnumerable<ProductDto> result = products;

        // Excluir servicios (IsService=true) — viven en su propia pagina (/servicios).
        result = result.Where(p => !p.IsService);

        // Filtro por empresa actual: productos cuya marca no es visible en esta empresa, no se muestran.
        // Productos sin marca (BrandId == null) o con una marca sin restriccion de empresa, se muestran siempre.
        if (Company.HasCompany && brands is not null && brands.Count > 0)
        {
            var visibleBrandIds = brands
                .Where(b => CurrentCompanyService.IsVisibleForCompany(b.Companies, Company.Current!))
                .Select(b => b.Id)
                .ToHashSet();
            result = result.Where(p => p.BrandId == null || visibleBrandIds.Contains(p.BrandId.Value));
        }

        // Vista unificada: NO filtramos por padre/hijo. Mostramos todo y luego
        // los hijos quedan agrupados debajo de su padre (ver al final del metodo).

        // Filtro por Marca (selector arriba de la tabla)
        if (filterBrandId > 0)
            result = result.Where(p => p.BrandId == filterBrandId);
        else if (filterBrandId == -1)
            result = result.Where(p => p.BrandId == null);

        // Filtro por Tipo
        // Definiciones:
        // - PADRE confirmado: tiene hijos cargados (DerivedCount > 0).
        // - FUTURO PADRE: tildado IsBase=true pero todavia sin hijos.
        // - HIJO: BaseProductId NOT NULL.
        // - INDEPENDIENTE: ni hijo, ni padre, ni futuro padre.
        var ft = (filterType ?? "").ToLowerInvariant();
        if (ft == "default")
            // Lo que se vende: hijos + independientes (excluye padres confirmados Y futuros padres).
            result = result.Where(p => p.BaseProductId.HasValue || (!p.IsBase && p.DerivedCount == 0));
        else if (ft == "padre")
            result = result.Where(p => !p.BaseProductId.HasValue && p.DerivedCount > 0);
        else if (ft == "futuro-padre")
            result = result.Where(p => !p.BaseProductId.HasValue && p.IsBase && p.DerivedCount == 0);
        else if (ft == "hijo")
            result = result.Where(p => p.BaseProductId.HasValue);
        else if (ft == "indep")
            result = result.Where(p => p.BaseProductId == null && !p.IsBase && p.DerivedCount == 0);
        // ft == "" => no filtra (Todos).

        // Filtro por Estado (Activo / Inactivo / Todos)
        var fe = (filterEstado ?? "").ToLowerInvariant();
        if (fe == "activos")
            result = result.Where(p => p.IsActive);
        else if (fe == "inactivos")
            result = result.Where(p => !p.IsActive);
        // fe == "" => no filtra

        // Text filters
        foreach (var kv in textFilters.Where(f => !string.IsNullOrEmpty(f.Value)))
        {
            var search = kv.Value.ToLower();
            result = kv.Key switch
            {
                "titulo" => result.Where(p => p.Title.ToLower().Contains(search)),
                "sku" => result.Where(p => (p.Sku ?? "").ToLower().Contains(search)),
                "oem" => result.Where(p => (p.OemCode ?? "").ToLower().Contains(search)),
                _ => result
            };
        }

        // Checkbox filters
        foreach (var kv in checkboxFilters.Where(f => f.Value.Count > 0))
        {
            result = kv.Key switch
            {
                "estado" => result.Where(p => kv.Value.Contains(p.IsActive ? "Activo" : "Inactivo")),
                "publicaciones" => ApplyPublicacionesFilter(result, kv.Value),
                _ => result
            };
        }

        // Sort
        if (!string.IsNullOrEmpty(sortColumn))
        {
            result = sortColumn switch
            {
                "titulo" => sortAsc ? result.OrderBy(p => p.Title) : result.OrderByDescending(p => p.Title),
                "sku" => sortAsc ? result.OrderBy(p => p.Sku ?? "") : result.OrderByDescending(p => p.Sku ?? ""),
                "oem" => sortAsc ? result.OrderBy(p => p.OemCode ?? "") : result.OrderByDescending(p => p.OemCode ?? ""),
                "costo" => sortAsc ? result.OrderBy(p => p.CostPrice) : result.OrderByDescending(p => p.CostPrice),
                "pvp" => sortAsc ? result.OrderBy(p => p.RetailPrice) : result.OrderByDescending(p => p.RetailPrice),
                "stock" => sortAsc ? result.OrderBy(p => p.Stock) : result.OrderByDescending(p => p.Stock),
                "estado" => sortAsc ? result.OrderBy(p => p.IsActive) : result.OrderByDescending(p => p.IsActive),
                _ => result
            };
        }

        var flat = result.ToList();

        // === Agrupar: cada padre seguido por sus hijos ===
        // - Padres y standalone (BaseProductId == null) ya estan ordenados por la sort.
        // - Hijos del listado los pongo inmediatamente debajo de su padre, conservando
        //   el sort dentro del grupo.
        // - Si el padre quedo afuera del listado (filtrado), los hijos huerfanos quedan
        //   al final como un bloque suelto.
        var byParent = flat
            .Where(p => p.BaseProductId.HasValue)
            .GroupBy(p => p.BaseProductId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());

        var grouped = new List<ProductDto>(flat.Count);
        var emittedIds = new HashSet<int>();
        foreach (var p in flat.Where(x => x.BaseProductId == null))
        {
            grouped.Add(p);
            emittedIds.Add(p.Id);
            if (byParent.TryGetValue(p.Id, out var kids))
            {
                foreach (var k in kids)
                {
                    grouped.Add(k);
                    emittedIds.Add(k.Id);
                }
            }
        }
        // Hijos cuyo padre quedo fuera del listado (por filtro de marca, texto, etc.)
        foreach (var orphan in flat.Where(x => x.BaseProductId.HasValue && !emittedIds.Contains(x.Id)))
            grouped.Add(orphan);

        return grouped;
    }

