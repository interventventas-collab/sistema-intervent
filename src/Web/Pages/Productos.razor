    }

    /// <summary>El usuario tipea el % de rentabilidad → recalculamos PVP usando el costo actual.</summary>
    private void OnFormMarkupPercentInput(ChangeEventArgs e)
    {
        var raw = (e.Value?.ToString() ?? "").Trim();
        // Aceptar coma o punto, dejar valor literal en pantalla
        formMarkupPercentFormatted = raw;
        var normalized = raw.Replace(".", "").Replace(",", ".");
        if (!decimal.TryParse(normalized, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var pct))
        {
            return; // entrada parcial; no recalculamos
        }
        if (formCostPrice <= 0m) return; // sin costo, no se puede calcular
        formRetailPrice = Math.Round(formCostPrice * (1m + pct / 100m), 2, MidpointRounding.AwayFromZero);
        formRetailPriceFormatted = FormatPrice(formRetailPrice);
        formRetailPriceWithVatFormatted = FormatPrice(WithVat(formRetailPrice));
    }

    /// <summary>Recalcula el % de rentabilidad cuando cambian costo o PVP.</summary>
    private void RecalcMarkupFromPrices()
    {
        if (formCostPrice <= 0m)
        {
            formMarkupPercentFormatted = "";
            return;
        }
        var pct = (formRetailPrice - formCostPrice) / formCostPrice * 100m;
        formMarkupPercentFormatted = pct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture).Replace(".", ",");
    }

    // Bindeamos el dropdown de IVA via una propiedad string get/set, no directo a decimal?.
    // Razon: @bind sobre <select> con decimal? + opcion vacia ("Sin IVA") tiene un bug:
    // Blazor no logra sincronizar consistentemente la opcion seleccionada con el valor
    // programatico. Bindeando a un string, @bind funciona como se espera y el value
    // del <select> se aplica al render (HTML lo entiende correctamente).
    private string VatRateString
    {
        // Importante: el DECIMAL(18,2) de la DB devuelve scale=2 (ej. 21.00).
        // Sin formatear, "21.00m".ToString() da "21.00" y no matchea la
        // option value="21". El formato "0.##" remueve ceros sobrantes.
        get => formVatRate.HasValue
            ? formVatRate.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
            : "";
        set
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                formVatRate = null;
            }
            else if (decimal.TryParse(value, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v))
            {
                formVatRate = v;
            }
            SyncWithVatFromBase();
        }
    }

    private void SyncWithVatFromBase()
    {
        formCostPriceWithVatFormatted = FormatPrice(WithVat(formCostPrice));
        formRetailPriceWithVatFormatted = FormatPrice(WithVat(formRetailPrice));
    }

    // Helpers IVA: el valor canonico almacenado es SIN IVA. CON IVA se computa.
    private decimal WithVat(decimal priceWithoutVat)
    {
        var rate = formVatRate ?? 0m;
        if (rate <= 0m) return priceWithoutVat;
        return Math.Round(priceWithoutVat * (1m + rate / 100m), 2, MidpointRounding.AwayFromZero);
    }

    private decimal WithoutVat(decimal priceWithVat)
    {
        var rate = formVatRate ?? 0m;
        if (rate <= 0m) return priceWithVat;
        return Math.Round(priceWithVat / (1m + rate / 100m), 2, MidpointRounding.AwayFromZero);
    }

    private void OnPubPriceInput(ChangeEventArgs e) { pubPriceFormatted = FormatPriceInput(e.Value?.ToString() ?? ""); pubPrice = ParseFormattedPrice(pubPriceFormatted); }

    // PVP con IVA aplicado para mostrar en el listado.
    // Si el producto no tiene VatRate o es 0, devuelve el RetailPrice tal cual.
    private decimal RetailWithVat(ProductDto p)
    {
        var rate = p.VatRate ?? 0m;
        if (rate <= 0m) return p.RetailPrice;
        return Math.Round(p.RetailPrice * (1m + rate / 100m), 2, MidpointRounding.AwayFromZero);
    }
