    private async Task SaveProductCost(ProductDto product, string? rawValue)
    {
        if (product.BaseProductId.HasValue)
        {
            // No deberia llegar aca (el input esta deshabilitado), pero por las dudas:
            ToastService.Error($"Este producto hereda el costo del producto base {product.BaseProductSku ?? product.BaseProductTitle}.");
            return;
        }
        var newCost = ParseFormattedPrice(rawValue ?? "");
        if (newCost == product.CostPrice) return;
        if (newCost < 0)
        {
            ToastService.Error("El costo no puede ser negativo");
            return;
        }

        var original = product.CostPrice;
        savingCostId = product.Id;
        StateHasChanged();

        try
        {
            var req = new UpdateProductRequest { CostPrice = newCost };
            var updated = await Api.UpdateProductAsync(product.Id, req);
            if (updated is null)
            {
                product.CostPrice = original;
                ToastService.Error("No se pudo actualizar el costo");
            }
            else
            {
                product.CostPrice = newCost;
                if (product.DerivedCount > 0)
                {
                    ToastService.Success($"Costo actualizado: ${FormatPrice(newCost)}. Aplicado a {product.DerivedCount} producto(s) derivado(s).");
                    await LoadData();
                }
                else
                {
                    ToastService.Success($"Costo actualizado: ${FormatPrice(newCost)}");
                }
            }
        }
        catch (Exception ex)
        {
            product.CostPrice = original;
            ToastService.Error("Error al actualizar costo: " + ex.Message);
        }

        savingCostId = null;
        StateHasChanged();
    }

    // ===== Save inline: PVP (con IVA) =====
    private async Task SaveProductRetailWithVat(ProductDto product, string? rawValue)
    {
        if (product.BaseProductId.HasValue)
        {
            ToastService.Error($"Este producto hereda el PVP del producto base {product.BaseProductSku ?? product.BaseProductTitle}.");
            return;
        }
        var newWithVat = ParseFormattedPrice(rawValue ?? "");
        if (newWithVat < 0) { ToastService.Error("El PVP no puede ser negativo"); return; }

        // Convertir CON IVA -> SIN IVA usando el VatRate del producto
        var rate = product.VatRate ?? 0m;
        var newSinIva = rate > 0m
            ? Math.Round(newWithVat / (1m + rate / 100m), 2, MidpointRounding.AwayFromZero)
            : newWithVat;

        if (newSinIva == product.RetailPrice) return;

        var original = product.RetailPrice;
        savingPvpId = product.Id;
        StateHasChanged();
        try
        {
            var updated = await Api.UpdateProductAsync(product.Id, new UpdateProductRequest { RetailPrice = newSinIva });
            if (updated is null) { product.RetailPrice = original; ToastService.Error("No se pudo actualizar el PVP"); }
            else
            {
                product.RetailPrice = newSinIva;
                if (product.DerivedCount > 0)
                {
                    ToastService.Success($"PVP actualizado: ${FormatPrice(newWithVat)} c/IVA. Aplicado a {product.DerivedCount} derivado(s).");
                    await LoadData();
                }
                else
                {
                    ToastService.Success($"PVP actualizado: ${FormatPrice(newWithVat)} c/IVA");
                }
            }
        }
        catch (Exception ex) { product.RetailPrice = original; ToastService.Error("Error: " + ex.Message); }
        savingPvpId = null;
        StateHasChanged();
    }

    // ===== Save inline: Stock =====
    private async Task SaveProductStock(ProductDto product, string? rawValue)
    {
        if (!int.TryParse(rawValue ?? "", out var newStock)) return;
        if (newStock == product.Stock) return;
        if (newStock < 0) { ToastService.Error("El stock no puede ser negativo"); return; }
        if (product.DerivedCount > 0)
        {
            ToastService.Error("Los productos padre no manejan stock propio: la suma de los hijos es el stock total.");
            return;
        }

        var original = product.Stock;
        savingStockId = product.Id;
        StateHasChanged();
        try
        {
            var updated = await Api.UpdateProductAsync(product.Id, new UpdateProductRequest { Stock = newStock });
            if (updated is null) { product.Stock = original; ToastService.Error("No se pudo actualizar el stock"); }
            else
            {
                product.Stock = newStock;
                // Si es un hijo, refrescamos el listado completo para que el padre
                // muestre la suma actualizada en su columna Stock.
                if (product.BaseProductId.HasValue)
                {
                    ToastService.Success($"Stock actualizado: {newStock}. Stock total del padre se recalcula.");
                    await LoadData();
                }
                else
                {
                    ToastService.Success($"Stock actualizado: {newStock}");
                }
            }
        }
        catch (Exception ex) { product.Stock = original; ToastService.Error("Error: " + ex.Message); }
        savingStockId = null;
        StateHasChanged();
    }

    // ===== Save inline: UxB =====
    private async Task SaveProductUxB(ProductDto product, string? rawValue)
    {
        int? newUxb = null;
        if (!string.IsNullOrWhiteSpace(rawValue) && int.TryParse(rawValue, out var parsed))
            newUxb = parsed >= 0 ? parsed : null;

        if (newUxb == product.UnitsPerPack) return;

        var original = product.UnitsPerPack;
        savingUxbId = product.Id;
        StateHasChanged();
        try
        {
            var req = new UpdateProductRequest();
            if (newUxb.HasValue && newUxb.Value > 0) req.UnitsPerPack = newUxb.Value;
            else req.ClearUnitsPerPack = true;

            var updated = await Api.UpdateProductAsync(product.Id, req);
            if (updated is null) { product.UnitsPerPack = original; ToastService.Error("No se pudo actualizar UxB"); }
            else { product.UnitsPerPack = newUxb; ToastService.Success(newUxb.HasValue ? $"UxB: {newUxb}" : "UxB: vacio"); }
        }
        catch (Exception ex) { product.UnitsPerPack = original; ToastService.Error("Error: " + ex.Message); }
        savingUxbId = null;
        StateHasChanged();
    }

    // ===== Save inline: Estado (Activo/Inactivo) =====
    private async Task SaveProductEstado(ProductDto product, bool newActive)
    {
        if (newActive == product.IsActive) return;
        var original = product.IsActive;
        savingEstadoId = product.Id;
