    // Edicion rapida por columna: cada columna tiene su candadito que solo OSMAR puede abrir/cerrar.
    private HashSet<string> unlockedColumns = new(StringComparer.OrdinalIgnoreCase);
    private bool CanUnlock => Operator.HasOperator &&
                               string.Equals(Operator.Current, "OSMAR", StringComparison.OrdinalIgnoreCase);
    private bool IsUnlocked(string col) => unlockedColumns.Contains(col);
    private void ToggleUnlock(string col)
    {
        if (!CanUnlock)
        {
            ToastService.Error("Solo OSMAR puede activar la edicion rapida.");
            return;
        }
        if (unlockedColumns.Contains(col)) unlockedColumns.Remove(col);
        else unlockedColumns.Add(col);
    }

    private RenderFragment LockButton(string col) => @<button type="button"
                                                              @onclick="@(() => ToggleUnlock(col))"
                                                              @onclick:stopPropagation="true"
                                                              disabled="@(!CanUnlock)"
                                                              title="@(CanUnlock ? (IsUnlocked(col) ? "Click para BLOQUEAR la edicion rapida" : "Click para DESBLOQUEAR la edicion rapida") : "Solo OSMAR puede activar la edicion rapida")"
                                                              style="@($"background:transparent;border:none;cursor:{(CanUnlock ? "pointer" : "not-allowed")};padding:0 0.25rem;font-size:0.85rem;opacity:{(CanUnlock ? "1" : "0.5")};")">
        @(IsUnlocked(col) ? "🔓" : "🔒")
    </button>;

