    private bool ViewerHasDay(string day)
    {
        if (viewerSale?.WeekDays is null) return false;
        return viewerSale.WeekDays.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim()).Contains(day);
    }

    private async Task ToggleViewerDay(string day)
    {
        if (viewerSale is null) return;
        var current = (viewerSale.WeekDays ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .ToHashSet();
        if (current.Contains(day)) current.Remove(day);
        else current.Add(day);
        var ordered = string.Join(",", AllWeekDays.Where(d => current.Contains(d)));
        try
        {
            var updated = await Api.UpdateSaleFlagsAsync(viewerSale.Id, new UpdateSaleFlagsRequest { WeekDays = ordered });
            if (updated is not null) { viewerSale = updated; await RefreshSalesAsync(); }
        }
        catch (Exception ex) { ToastService.Error("No se pudo guardar: " + ex.Message); }
    }

    private async Task TogglePaid(ChangeEventArgs e)
    {
        if (viewerSale is null) return;
        var paid = e.Value is bool b && b;
        try
        {
            var updated = await Api.UpdateSaleFlagsAsync(viewerSale.Id, new UpdateSaleFlagsRequest { IsPaid = paid });
            if (updated is not null) { viewerSale = updated; await RefreshSalesAsync(); }
        }
        catch (Exception ex) { ToastService.Error("No se pudo guardar: " + ex.Message); }
    }

    private async Task RefreshSalesAsync()
    {
        try { sales = await Api.GetSalesAsync() ?? new(); } catch { }
    }

    private void ConfirmCancel(SaleDto s) => saleToCancel = s;

    // ===== Eliminar definitivamente =====

    private void OpenDeleteModal(SaleDto s)
    {
        if (!CanDelete)
        {
            ToastService.Error($"Solo {deleteSettings?.AllowedOperator ?? "OSMAR"} puede eliminar comprobantes.");
            return;
        }
        saleToDelete = s;
        deletePassword = "";
        deleteError = null;
    }

    private void CloseDeleteModal()
    {
        if (isDeleting) return;
        saleToDelete = null;
        deletePassword = "";
        deleteError = null;
    }

    private async Task OnDeletePasswordKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(deletePassword) && !isDeleting)
            await DoDelete();
    }

    private async Task DoDelete()
    {
        if (saleToDelete is null) return;
        if (string.IsNullOrEmpty(deletePassword)) { deleteError = "Ingresá la clave"; return; }
        deleteError = null; isDeleting = true;
        try
        {
            var ok = await Api.DeleteSaleAsync(saleToDelete.Id, deletePassword);
            if (ok)
            {
                ToastService.Success($"Comprobante {saleToDelete.Number} eliminado");
                saleToDelete = null;
                deletePassword = "";
                await LoadAll();
            }
        }
        catch (Exception ex) { deleteError = ex.Message; }
        finally { isDeleting = false; }
    }

    private async Task DoCancel()
    {
        if (saleToCancel is null) return;
        try
        {
            var updated = await Api.CancelSaleAsync(saleToCancel.Id);
            if (updated is not null) { ToastService.Success("Comprobante anulado"); await LoadAll(); }
            else ToastService.Error("No se pudo anular");
        }
        catch (Exception ex) { ToastService.Error(ex.Message); }
        finally { saleToCancel = null; }
    }

    // ===== Compartir por WhatsApp =====

    private void OpenWhatsappShare()
    {
        if (viewerSale is null) return;

        // Lookup del telefono del cliente, si tenemos el ClientId
        var phone = "";
        if (viewerSale.ClientId.HasValue && clients is not null)
        {
            var c = clients.FirstOrDefault(x => x.Id == viewerSale.ClientId.Value);
            phone = c?.Phone ?? "";
        }
        whatsappPhone = phone;

        // Construir mensaje default
        var sb = new System.Text.StringBuilder();
        var clientName = viewerSale.ClientNameSnapshot ?? "";
        var firstName = !string.IsNullOrEmpty(clientName)
            ? clientName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? ""
            : "";
        sb.AppendLine(string.IsNullOrEmpty(firstName) ? "Hola!" : $"Hola {firstName}!");
        sb.AppendLine();
        sb.AppendLine($"Te paso el comprobante *N° {viewerSale.Number}*");
        sb.AppendLine($"Fecha: {viewerSale.Date:dd/MM/yyyy}");
        if (!string.IsNullOrEmpty(viewerSale.CompanyNameSnapshot))
            sb.AppendLine($"Emisor: {viewerSale.CompanyNameSnapshot}");
        sb.AppendLine();
        sb.AppendLine("Detalle:");
        foreach (var it in viewerSale.Items)
        {
            sb.AppendLine($"• {FormatQty(it.Quantity)} x {it.Description} — ${FormatPrice(it.LineTotal)}");
        }
        sb.AppendLine();
        if (viewerSale.Discount > 0)
        {
            sb.AppendLine($"Subtotal: ${FormatPrice(viewerSale.Subtotal)}");
            sb.AppendLine($"Descuento: -${FormatPrice(viewerSale.Discount)}");
        }
        sb.AppendLine($"*Total: ${FormatPrice(viewerSale.Total)}*");
        if (viewerSale.IsPaid)
        {
            sb.AppendLine();
            sb.AppendLine("✅ PAGADO");
        }
        sb.AppendLine();
        sb.AppendLine("¡Gracias!");

        whatsappMessage = sb.ToString();
        showWhatsappModal = true;
    }

    private void CloseWhatsappModal() => showWhatsappModal = false;

    private async Task OpenWhatsapp()
    {
        // Normalizar telefono: solo digitos
        var digits = new string((whatsappPhone ?? "").Where(char.IsDigit).ToArray());

        // Si parece un celular argentino sin codigo de pais (10 digitos area+numero), prepender 549
        if (digits.Length == 10 && !digits.StartsWith("54"))
        {
            digits = "549" + digits;
        }
        // Si tiene codigo de pais (54) pero falta el 9 del celular AR (queda 12 digitos comenzando con 54 + algo distinto a 9)
        else if (digits.Length == 12 && digits.StartsWith("54") && !digits.StartsWith("549"))
        {
            // No tocamos: puede ser un fijo. Igual 12 digitos con 54 indica 549 normalmente, pero respetamos lo que puso el usuario.
        }

        var encoded = Uri.EscapeDataString(whatsappMessage ?? "");
        var url = string.IsNullOrEmpty(digits)
            ? $"https://web.whatsapp.com/send?text={encoded}"
            : $"https://wa.me/{digits}?text={encoded}";

        try
        {
            await JS.InvokeVoidAsync("open", url, "_blank", "noopener");
            showWhatsappModal = false;
            ToastService.Success("Abrí WhatsApp Web en una pestaña nueva. Si no la viste, fijate si el navegador bloqueó el popup.");
        }
        catch (Exception ex)
        {
            ToastService.Error("No pude abrir WhatsApp: " + ex.Message);
        }
    }

    private async Task CopyWhatsappMessage()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", whatsappMessage ?? "");
            ToastService.Success("Mensaje copiado. Pegalo en el chat con Ctrl+V.");
        }
        catch (Exception ex)
        {
            ToastService.Error("No pude copiar: " + ex.Message);
        }
    }

