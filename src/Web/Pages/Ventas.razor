    private void LoadFormFromSale(SaleDto s, string mode)
    {
        formMode = mode;
        editingSaleId = mode == "edit" ? s.Id : null;
        sourceSaleNumber = s.Number;

        // Para duplicar usamos la fecha de hoy; para editar conservamos la del comprobante.
        formDate = mode == "duplicate" ? DateTime.Today : s.Date;
        formClientId = s.ClientId ?? 0;
        formIvaCondition = string.IsNullOrEmpty(s.IvaCondition) ? "Consumidor final" : s.IvaCondition!;
        formPaymentCondition = string.IsNullOrEmpty(s.PaymentCondition) ? "Efectivo" : s.PaymentCondition!;
        formComprobanteType = string.IsNullOrEmpty(s.ComprobanteType) ? "X" : s.ComprobanteType;
        formDiscount = s.Discount;
        formNotes = s.Notes ?? "";
        formIsPaid = s.IsPaid;
        formCompanyName = !string.IsNullOrEmpty(s.CompanyNameSnapshot)
            ? s.CompanyNameSnapshot!
            : (companyInfo?.Name ?? "FRIKAF®");

        // WeekDays
        formWeekDays = new();
        if (!string.IsNullOrEmpty(s.WeekDays))
        {
            foreach (var d in s.WeekDays.Split(',', StringSplitOptions.RemoveEmptyEntries))
                formWeekDays.Add(d.Trim());
        }

        // Items
        formItems = s.Items.Select(it => new CreateSaleItemRequest
        {
            ProductId = it.ProductId,
            Code = it.Code,
            Description = it.Description,
            Quantity = it.Quantity,
            UnitPrice = it.UnitPrice,
            VatRate = it.VatRate,
            BonifPercent = it.BonifPercent
        }).ToList();

        addProductId = 0; addProductQty = 1;
        formError = null;
        showForm = true;

        // Cargar sugerencias del cliente (fire-and-forget)
        topProductsForClient = new();
        if (formClientId > 0)
        {
            _ = OnClientChanged();
        }
    }

