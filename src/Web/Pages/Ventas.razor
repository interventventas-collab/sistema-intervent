                    <div style="margin-top: 0.8rem; display: flex; gap: 0.3rem; justify-content: center; flex-wrap: wrap; align-items: center;">
                        <span style="font-size: 0.78rem; color: #6b7280; margin-right: 0.4rem;">Días de visita / reparto:</span>
                        @foreach (var d in AllWeekDays)
                        {
                            var isOn = ViewerHasDay(d);
                            <span class="day-pill @(isOn ? "on" : "")" @onclick="() => ToggleViewerDay(d)" title="Click para tildar/destildar">
                                @d
                            </span>
                        }
                    </div>

                    @* Espacios de firma *@
                    <div class="comprobante-firmas" style="margin-top: 1.5rem; display: flex; justify-content: space-around; gap: 2rem;">
                        <div style="flex: 1; text-align: center;">
                            <div style="border-top: 1px solid #6b7280; padding-top: 0.3rem; font-size: 0.75rem; color: #6b7280;">
                                Firma del cliente / Aclaración
                            </div>
                        </div>
                        <div style="flex: 1; text-align: center;">
                            <div style="border-top: 1px solid #6b7280; padding-top: 0.3rem; font-size: 0.75rem; color: #6b7280;">
                                Firma autorizada
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer no-print">
                <button class="btn btn-secondary" @onclick="CloseViewer">Cerrar</button>
            </div>
        </div>
