@code {
    private List<SaleDto>? sales;
    private List<ClientDto>? clients;
    private List<CustomerTierDto>? tiers;
    private List<ProductDto>? availableProducts;
    // Todos los productos (incluyendo padres) — usados para lookup por codigo en el input rapido.
    private List<ProductDto>? allProducts;
    // Input rapido por codigo
    private string codeInput = "";
    // Modal selector de hijos cuando el usuario tipea el codigo de un padre
    private ProductDto? parentForChildPicker;
    private List<ProductDto> childrenOfParent = new();
    private Dictionary<int, decimal> childPickerQuantities = new();
    private CompanyInfoDto? companyInfo;
    private bool isLoading = true;
    private bool showForm;
    private bool isSaving;
    private string? formError;

    // Form
    private DateTime formDate = DateTime.Today;
    private int formClientId;
    private string formIvaCondition = "Consumidor final";
    // 'X' por default. A futuro: 'FACTURA_A', 'FACTURA_B', 'FACTURA_C' cuando ARCA.
    private string formComprobanteType = "X";

    /// Vendedor inferido del operador logueado (snapshot que se guarda al emitir).
    private string? VendedorAuto => Operator.Current;

    /// Punto de venta segun tipo. Hoy hardcodeado al default conocido (que tambien
    /// estan en la tabla AppSettings del backend); el numero real se asigna alla.
    private static string PvForType(string tipo) => tipo switch
    {
        "X" => "0009",
        "FACTURA_A" => "0001",
        "FACTURA_B" => "0001",
        "FACTURA_C" => "0001",
        _ => "0001"
    };
    private string formPaymentCondition = "Efectivo";
    private decimal formDiscount;
    private string formNotes = "";
    private List<CreateSaleItemRequest> formItems = new();
    private int addProductId;
    private decimal addProductQty = 1;
    // Bonificacion opcional adicional al agregar un item (sobre el descuento de la lista)
    private decimal addProductBonif;
    // Texto del buscador con autocompletado (input + datalist)
    private string productSearchText = "";
    private HashSet<string> formWeekDays = new();
    private bool formIsPaid;
    private string formCompanyName = "FRIKAF®";

    // Modo del formulario: "new" | "edit" | "duplicate"
    private string formMode = "new";
    private int? editingSaleId;
    private string? sourceSaleNumber; // numero del comprobante origen (para banner de edit/duplicate)

    private static readonly string[] AllWeekDays = { "LUN", "MAR", "MIE", "JUE", "VIE", "SAB", "DOM" };
    private static readonly string[] BrandOptions = { "FRIKAF®", "INTERVENT®", "INTEREVENTOS®", "PALANICA®" };

    // Viewer / cancel
    private SaleDto? viewerSale;
    private SaleDto? saleToCancel;

    // Compartir por WhatsApp
    private bool showWhatsappModal;
    private string whatsappPhone = "";
    private string whatsappMessage = "";
    private bool whatsappSessionLinked;       // ¿hay sesión vinculada?
    private bool isCheckingWhatsappStatus;    // mientras hago el check al abrir
    private bool isSendingWhatsapp;           // mientras está mandando un envío directo

    // Eliminar definitivamente (solo operador autorizado, con clave)
    private SaleDto? saleToDelete;
    private string deletePassword = "";
    private string? deleteError;
    private bool isDeleting;
    private DeleteSaleSettingsDto? deleteSettings;

    private bool CanDelete =>
        deleteSettings is not null &&
        Operator.HasOperator &&
        string.Equals(Operator.Current, deleteSettings.AllowedOperator, StringComparison.OrdinalIgnoreCase);

    // Top 10 productos mas comprados por el cliente actual del form (sugerencias)
    private List<TopProductByClientDto> topProductsForClient = new();

    // Selección masiva
    private HashSet<int> selectedSaleIds = new();
    private bool showBulkDeleteModal;
    private string bulkDeletePassword = "";
    private string? bulkDeleteError;
    private bool isBulkDeleting;
    private int bulkDeleteProgress;

    private bool AllVisibleSelected =>
        sales is not null && sales.Count > 0 && sales.All(s => selectedSaleIds.Contains(s.Id));

    private void ToggleSelect(int id, bool isSelected)
    {
        if (isSelected) selectedSaleIds.Add(id);
        else selectedSaleIds.Remove(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var check = (bool)(e.Value ?? false);
        if (sales is null) return;
        if (check) foreach (var s in sales) selectedSaleIds.Add(s.Id);
        else selectedSaleIds.Clear();
    }

    private void ClearSelection() => selectedSaleIds.Clear();

    private void OpenBulkDeleteModal()
    {
        if (!CanDelete)
        {
            ToastService.Error($"Solo {deleteSettings?.AllowedOperator ?? "OSMAR"} puede eliminar comprobantes.");
            return;
        }
        if (selectedSaleIds.Count == 0) return;
        showBulkDeleteModal = true;
        bulkDeletePassword = "";
        bulkDeleteError = null;
        bulkDeleteProgress = 0;
    }

    private void CloseBulkDeleteModal()
    {
        if (isBulkDeleting) return;
        showBulkDeleteModal = false;
        bulkDeletePassword = "";
        bulkDeleteError = null;
    }

    private async Task OnBulkDeletePasswordKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(bulkDeletePassword) && !isBulkDeleting)
            await DoBulkDelete();
    }

    private async Task DoBulkDelete()
    {
        if (selectedSaleIds.Count == 0) return;
        if (string.IsNullOrEmpty(bulkDeletePassword)) { bulkDeleteError = "Ingresá la clave"; return; }

        isBulkDeleting = true;
        bulkDeleteError = null;
        bulkDeleteProgress = 0;
        int ok = 0;
        var errors = new List<string>();

        foreach (var id in selectedSaleIds.ToList())
        {
            bulkDeleteProgress++;
            StateHasChanged();
            try
            {
                var success = await Api.DeleteSaleAsync(id, bulkDeletePassword);
                if (success) ok++;
                else errors.Add($"#{id}: error desconocido");
            }
            catch (Exception ex) { errors.Add($"#{id}: {ex.Message}"); }
        }

        isBulkDeleting = false;
        if (errors.Count == 0)
        {
            ToastService.Success($"✓ {ok} comprobante{(ok == 1 ? "" : "s")} eliminado{(ok == 1 ? "" : "s")}");
            showBulkDeleteModal = false;
            selectedSaleIds.Clear();
            await LoadAll();
        }
        else
        {
            bulkDeleteError = $"{ok}/{selectedSaleIds.Count} eliminadas. Errores: " + string.Join(" | ", errors.Take(3));
            ToastService.Error("Algunos no se pudieron eliminar — revisá la lista");
            await LoadAll();
        }
    }

    private async Task DownloadSelectedAsCsv()
    {
        if (sales is null || selectedSaleIds.Count == 0) return;
        var seleccionadas = sales.Where(x => selectedSaleIds.Contains(x.Id))
            .OrderByDescending(x => x.Date).ThenByDescending(x => x.Id).ToList();

        var sb = new System.Text.StringBuilder();
        // BOM para que Excel detecte UTF-8
        sb.Append('﻿');
        sb.AppendLine("Numero;Fecha;Cliente;Codigo Cliente;Cond. IVA;Pago;Subtotal;Descuento;Total;Estado;Anulada por;Anulada el;Observaciones");

        string Esc(string? v)
        {
            if (string.IsNullOrEmpty(v)) return "";
            var s = v.Replace("\"", "\"\"").Replace("\r", " ").Replace("\n", " ");
            return s.Contains(';') || s.Contains('"') ? $"\"{s}\"" : s;
        }
        string Money(decimal v) => v.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);

        foreach (var s in seleccionadas)
        {
            sb.AppendLine(string.Join(";", new[]
            {
                Esc(s.Number),
                s.Date.ToString("yyyy-MM-dd"),
                Esc(s.ClientNameSnapshot ?? "Consumidor final"),
                Esc(s.ClientCode ?? ""),
                Esc(s.IvaCondition ?? ""),
                Esc(s.PaymentCondition ?? ""),
                Money(s.Subtotal),
                Money(s.Discount),
                Money(s.Total),
                s.IsCancelled ? "Anulada" : "Emitida",
                Esc(s.CancelledByOperator ?? ""),
                s.CancelledAt.HasValue ? s.CancelledAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "",
                Esc(s.Notes ?? "")
            }));
        }

        var filename = $"ventas_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        try
        {
            await JS.InvokeVoidAsync("downloadTextFile", filename, sb.ToString(), "text/csv;charset=utf-8");
            ToastService.Success($"✓ {seleccionadas.Count} venta{(seleccionadas.Count == 1 ? "" : "s")} exportada{(seleccionadas.Count == 1 ? "" : "s")} a CSV");
        }
        catch (Exception ex)
        {
            ToastService.Error("No se pudo descargar: " + ex.Message);
        }
    }

