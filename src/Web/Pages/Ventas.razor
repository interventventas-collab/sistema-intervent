    // ===== Cafe: dropdown de formato (granos / molido filtro / espress / moka) =====

    /// <summary>
    /// Detecta si la linea es un cafe que admite formato de molido. Reconoce por:
    ///  - Description contiene "café" o "cafe" (sin/con tilde)
    ///  - O ProductId apunta a un producto cuyo padre es kg-mode (cafe por kilo)
    /// </summary>
    private bool IsCoffeeItem(CreateSaleItemRequest i)
    {
        if (!string.IsNullOrEmpty(i.Description))
        {
            var d = i.Description.ToLowerInvariant();
            if (d.Contains("café") || d.Contains("cafe")) return true;
        }
        if (i.ProductId.HasValue && availableProducts is not null)
        {
            var p = availableProducts.FirstOrDefault(x => x.Id == i.ProductId.Value);
            if (p is not null)
            {
                if (string.Equals(p.StockUnit, "kg", StringComparison.OrdinalIgnoreCase)) return true;
                if (p.BaseProductId.HasValue)
                {
                    var parent = availableProducts.FirstOrDefault(x => x.Id == p.BaseProductId.Value);
                    if (parent is not null && string.Equals(parent.StockUnit, "kg", StringComparison.OrdinalIgnoreCase))
                        return true;
                }
            }
        }
        return false;
    }

    // Formatos estandar (los que aparecen como opciones fijas en el dropdown)
    private static readonly string[] CoffeeStandardFormats =
    {
        "EN GRANOS", "MOLIDO FILTRO", "MOLIDO ESPRESS"
    };

    /// <summary>
    /// Extrae el formato de cafe desde la descripcion. Devuelve:
    ///  - ("", "") si no hay sufijo
    ///  - (format, "") si el sufijo es uno de los 3 estandar
    ///  - ("OTROS", customText) si el sufijo es algo personalizado
    /// </summary>
    private (string format, string custom) ExtractCoffeeMeta(string? description)
    {
        if (string.IsNullOrEmpty(description)) return ("", "");

        // Buscar el ULTIMO " — " (em-dash con espacios) o " - " como fallback
        var idxEm = description.LastIndexOf(" — ", StringComparison.Ordinal);
        var idxAscii = description.LastIndexOf(" - ", StringComparison.Ordinal);
        var idx = Math.Max(idxEm, idxAscii);
        if (idx < 0) return ("", "");

        var suffix = description.Substring(idx + 3).Trim();
        if (string.IsNullOrEmpty(suffix)) return ("", "");

        foreach (var f in CoffeeStandardFormats)
        {
            if (string.Equals(suffix, f, StringComparison.OrdinalIgnoreCase))
                return (f, "");
        }
        return ("OTROS", suffix);
    }

    private const string DoyPackMarker = " [d.p.]";

    /// <summary>Renderiza la descripcion del item: [d.p.] queda BOLD para destacarlo en el comprobante.</summary>
    private MarkupString RenderItemDescription(string? description)
    {
        var d = description ?? "";
        var html = System.Net.WebUtility.HtmlEncode(d).Replace("[d.p.]", "<strong>d.p.</strong>");
        return new MarkupString(html);
    }

    /// <summary>True si la descripcion (sin contar el sufijo de formato) tiene el marcador d.p.</summary>
    private bool HasDoyPack(string? description)
    {
        if (string.IsNullOrEmpty(description)) return false;
        // Sacar primero el sufijo de formato si existe, asi quedamos con base + (opcional) d.p.
        var withoutFormat = StripFormatSuffix(description);
        return withoutFormat.TrimEnd().EndsWith(DoyPackMarker.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>Quita el sufijo " — FORMAT" si existe y devuelve el resto.</summary>
    private string StripFormatSuffix(string description)
    {
        var (format, custom) = ExtractCoffeeMeta(description);
        var suffix = format == "OTROS" ? custom : format;
        if (string.IsNullOrEmpty(suffix)) return description;
        foreach (var sep in new[] { $" — {suffix}", $" - {suffix}" })
        {
            if (description.EndsWith(sep, StringComparison.OrdinalIgnoreCase))
                return description.Substring(0, description.Length - sep.Length).TrimEnd();
        }
        return description;
    }

    /// <summary>Tildea/destildea el marcador [d.p.] preservando el formato si existe.</summary>
    private void ToggleDoyPack(CreateSaleItemRequest item)
    {
        var desc = item.Description ?? "";
        // 1. Sacar el sufijo de formato (lo guardamos para re-pegarlo despues)
        var (format, custom) = ExtractCoffeeMeta(desc);
        var withoutFormat = StripFormatSuffix(desc).TrimEnd();

        // 2. Toggle [d.p.] en el resto
        var marker = DoyPackMarker.Trim();
        if (withoutFormat.EndsWith(marker, StringComparison.OrdinalIgnoreCase))
        {
            withoutFormat = withoutFormat.Substring(0, withoutFormat.Length - marker.Length).TrimEnd();
        }
        else
        {
            withoutFormat = withoutFormat + DoyPackMarker;
        }

        // 3. Reconstruir con el formato si lo tenia
        item.Description = withoutFormat;
        if (!string.IsNullOrEmpty(format))
        {
            var fmtToUse = format == "OTROS" ? custom : format;
            if (!string.IsNullOrEmpty(fmtToUse))
                item.Description = $"{withoutFormat} — {fmtToUse}";
        }
    }

    /// <summary>Helper compatible: devuelve solo el "format" (sin el custom).</summary>
    private string ExtractCoffeeFormat(string? description) => ExtractCoffeeMeta(description).format;

    /// <summary>
    /// Reemplaza el formato de cafe en la descripcion.
    /// - format = ""        -> saca el sufijo
    /// - format = estandar  -> usa el formato literal
    /// - format = "OTROS"   -> usa customText (si esta vacio, deja sin sufijo hasta que tipeen)
    /// </summary>
    private void SetCoffeeFormat(CreateSaleItemRequest item, string format, string? customText = null)
    {
        var (currentFormat, currentCustom) = ExtractCoffeeMeta(item.Description);
        var baseDesc = item.Description ?? "";

        // Limpiar el sufijo actual si lo habia
        var currentSuffix = currentFormat == "OTROS" ? currentCustom : currentFormat;
        if (!string.IsNullOrEmpty(currentSuffix))
        {
            foreach (var sep in new[] { $" — {currentSuffix}", $" - {currentSuffix}" })
            {
                if (baseDesc.EndsWith(sep, StringComparison.OrdinalIgnoreCase))
                {
                    baseDesc = baseDesc.Substring(0, baseDesc.Length - sep.Length).TrimEnd();
                    break;
                }
            }
        }

        string? newSuffix = null;
        if (format == "OTROS")
        {
            // Si vienen con custom no vacio, lo usamos. Si no, dejamos el dropdown en "OTROS"
            // pero sin sufijo en la descripcion (el usuario va a tipear).
            newSuffix = string.IsNullOrWhiteSpace(customText) ? null : customText.Trim();
        }
        else if (!string.IsNullOrEmpty(format))
        {
            newSuffix = format;
        }

        item.Description = newSuffix is null ? baseDesc : $"{baseDesc} — {newSuffix}";
    }

    /// <summary>Cambia solo el texto custom cuando el formato es "OTROS".</summary>
    private void SetCoffeeCustomText(CreateSaleItemRequest item, string customText)
    {
        SetCoffeeFormat(item, "OTROS", customText);
    }

    private decimal LineTotal(CreateSaleItemRequest i)
    {
        var bruto = i.Quantity * i.UnitPrice;
        var bonif = bruto * (i.BonifPercent / 100m);
        return Math.Round(bruto - bonif, 2);
    }

    private decimal Subtotal => formItems.Sum(LineTotal);

    // Suma de IVA contenido en cada linea (informativo). Se calcula como
    // line_subtotal * vatRate / 100. El total guardado en BD NO incluye este IVA
    // (es el mismo criterio que ya tenia el sistema). Se muestra para que el
    // usuario tenga visibilidad de cuanto IVA estaria viendo el cliente.
    private decimal TotalIva => formItems.Sum(i => Math.Round(LineTotal(i) * (i.VatRate ?? 0m) / 100m, 2));

    private decimal TotalCalc => Math.Max(0, Subtotal - formDiscount);

    private async Task Save()
    {
        if (formItems.Count == 0) { formError = "Agregá al menos un item"; return; }
        if (formItems.Any(i => i.Quantity <= 0 || string.IsNullOrWhiteSpace(i.Description)))
        { formError = "Todos los items deben tener cantidad > 0 y descripcion."; return; }

        isSaving = true; formError = null;
        try
        {
            var weekDaysCsv = formWeekDays.Count == 0 ? null
                : string.Join(",", AllWeekDays.Where(d => formWeekDays.Contains(d)));

            SaleDto? saved = null;

            if (formMode == "edit" && editingSaleId.HasValue)
            {
                var upd = new UpdateSaleRequest
                {
                    Date = formDate,
                    ClientId = formClientId > 0 ? formClientId : null,
                    PaymentCondition = formPaymentCondition,
                    IvaCondition = formIvaCondition,
                    Discount = formDiscount,
                    Notes = formNotes,
                    WeekDays = weekDaysCsv,
                    IsPaid = formIsPaid,
                    CompanyNameOverride = formCompanyName,
                    Items = formItems.ToList(),
                    VendedorName = VendedorAuto
                };
                saved = await Api.UpdateSaleAsync(editingSaleId.Value, upd);
                if (saved is null) { formError = "No se pudo guardar los cambios"; return; }
                ToastService.Success($"Comprobante {saved.Number} actualizado");
            }
            else
            {
                var req = new CreateSaleRequest
                {
                    Date = formDate,
                    ClientId = formClientId > 0 ? formClientId : null,
                    PaymentCondition = formPaymentCondition,
                    IvaCondition = formIvaCondition,
                    Discount = formDiscount,
                    Notes = formNotes,
                    WeekDays = weekDaysCsv,
                    IsPaid = formIsPaid,
                    CompanyNameOverride = formCompanyName,
                    Items = formItems.ToList(),
                    ComprobanteType = formComprobanteType,
                    VendedorName = VendedorAuto
                };
                saved = await Api.CreateSaleAsync(req);
                if (saved is null) { formError = "No se pudo crear el comprobante"; return; }
                ToastService.Success($"Comprobante {saved.Number} emitido");
            }

            showForm = false;
            // Reset modo
            formMode = "new";
            editingSaleId = null;
            sourceSaleNumber = null;
            await LoadAll();
            // Abrir el visor automáticamente
            viewerSale = saved;
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

