@page "/ventas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@inject OperatorService Operator
@inject CurrentCompanyService Company

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Ventas (@(sales?.Count ?? 0))</h3>
        <div style="display: flex; gap: 0.4rem;">
            <button class="btn btn-secondary" @onclick="OpenCompanyForm" title="Datos de la empresa que aparecen en el comprobante">⚙ Datos empresa</button>
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ Nueva Venta</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando ventas...</p>
        }
        else if (sales is null || sales.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">Todavia no cargaste ninguna venta. Hace clic en "+ Nueva Venta" para empezar.</p>
        }
        else
        {
            @* Barra de acciones masivas — solo visible cuando hay seleccionadas *@
            @if (selectedSaleIds.Count > 0)
            {
                <div style="background: #1e3a8a; color: white; padding: 0.6rem 1rem; display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap;">
                    <div style="font-weight: 700;">
                        ☑ <strong>@selectedSaleIds.Count</strong> venta@(selectedSaleIds.Count == 1 ? "" : "s") seleccionada@(selectedSaleIds.Count == 1 ? "" : "s")
                        <span style="font-weight: 400; font-size: 0.82rem; margin-left: 0.5rem; opacity: 0.85;">
                            Total: <strong>$@FormatPrice(sales.Where(x => selectedSaleIds.Contains(x.Id)).Sum(x => x.Total))</strong>
                        </span>
                    </div>
                    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                        <button class="btn" style="background: white; color: #1e3a8a; border: none; font-weight: 700;"
                                @onclick="DownloadSelectedAsCsv">
                            ⬇ Descargar CSV
                        </button>
                        @if (CanDelete)
                        {
                            <button class="btn" style="background: #b91c1c; color: white; border: none; font-weight: 700;"
                                    @onclick="OpenBulkDeleteModal">
                                🗑 Eliminar @selectedSaleIds.Count
                            </button>
                        }
                        <button class="btn" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.3);"
                                @onclick="ClearSelection">
                            Cancelar
                        </button>
                    </div>
                </div>
            }
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 36px; text-align: center;">
                                <input type="checkbox" title="Seleccionar todas"
                                       checked="@AllVisibleSelected"
                                       @onchange="ToggleSelectAll" />
                            </th>
                            <th>Numero</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Cond. IVA</th>
                            <th>Pago</th>
                            <th style="text-align: right;">Total</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in sales)
                        {
                            <tr style="@(s.IsCancelled ? "opacity:0.55;text-decoration:line-through;" : "") @(selectedSaleIds.Contains(s.Id) ? "background:#eff6ff;" : "")">
                                <td style="text-align: center;">
                                    <input type="checkbox"
                                           checked="@selectedSaleIds.Contains(s.Id)"
                                           @onchange="@(e => ToggleSelect(s.Id, (bool)(e.Value ?? false)))" />
                                </td>
                                <td style="font-family: monospace;">@s.Number</td>
                                <td>@s.Date.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(s.ClientCode))
                                    {
                                        <span style="font-family: monospace; color: #6b7280; font-size: 0.78rem;">@s.ClientCode</span>
                                        <span> · </span>
                                    }
                                    <strong>@(s.ClientNameSnapshot ?? "Consumidor final")</strong>
                                </td>
                                <td style="font-size: 0.85rem;">@(s.IvaCondition ?? "")</td>
                                <td style="font-size: 0.85rem;">@(s.PaymentCondition ?? "")</td>
                                <td style="text-align: right; font-weight: 700;">$@FormatPrice(s.Total)</td>
                                <td>
                                    @if (s.IsCancelled)
                                    {
                                        var tip = "Anulada";
                                        if (!string.IsNullOrEmpty(s.CancelledByOperator))
                                            tip += $" por {s.CancelledByOperator}";
                                        if (s.CancelledAt.HasValue)
                                            tip += $" el {s.CancelledAt.Value.ToLocalTime():dd/MM/yyyy HH:mm}";
                                        <span class="status-badge" style="background:#fee2e2;color:#991b1b;cursor:help;" title="@tip">Anulada</span>
                                        @if (!string.IsNullOrEmpty(s.CancelledByOperator))
                                        {
                                            <div style="font-size:0.7rem;color:#991b1b;margin-top:0.2rem;">
                                                por @s.CancelledByOperator @(s.CancelledAt.HasValue ? "· " + s.CancelledAt.Value.ToLocalTime().ToString("dd/MM HH:mm") : "")
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="status-badge status-active">Emitida</span>
                                    }
                                </td>
                                <td class="actions-cell" style="white-space: nowrap;">
                                    <button class="btn-icon btn-edit" @onclick="() => OpenViewer(s)" title="Ver comprobante">@SvgIcons.Tag</button>
                                    @if (!s.IsCancelled)
                                    {
                                        <button class="btn-icon" style="background:#dbeafe;color:#1e40af;border:1px solid #1e40af;padding:2px 6px;border-radius:4px;font-size:0.7rem;font-weight:700;"
                                                @onclick="() => OpenEditForm(s)" title="Editar comprobante">✎ Editar</button>
                                    }
                                    <button class="btn-icon" style="background:#fef3c7;color:#92400e;border:1px solid #fbbf24;padding:2px 6px;border-radius:4px;font-size:0.7rem;font-weight:700;"
                                            @onclick="() => OpenDuplicateForm(s)" title="Duplicar como comprobante nuevo">⎘ Duplicar</button>
                                    @if (!s.IsCancelled)
                                    {
                                        <button class="btn-icon btn-delete" @onclick="() => ConfirmCancel(s)" title="Anular">@SvgIcons.AlertCircle</button>
                                    }
                                    @if (CanDelete)
                                    {
                                        <button class="btn-icon" style="background:#7f1d1d;color:white;border:1px solid #7f1d1d;padding:2px 6px;border-radius:4px;font-size:0.7rem;font-weight:700;"
                                                @onclick="() => OpenDeleteModal(s)" title="Eliminar definitivamente (solo @(deleteSettings?.AllowedOperator ?? "OSMAR"))">🗑</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@* ====== NUEVA VENTA ====== *@
@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-wide modal-fullscreen" @onclick:stopPropagation="true"
             style="width: 96vw; max-width: 1600px; height: 92vh; max-height: 92vh; display: flex; flex-direction: column;">
            <div class="modal-header" style="background: @(formMode == "edit" ? "#dbeafe" : (formMode == "duplicate" ? "#fef3c7" : "whitesmoke"));">
                <h3>
                    @(formMode switch
                    {
                        "edit" => $"✎ Editando comprobante {sourceSaleNumber}",
                        "duplicate" => $"⎘ Duplicando comprobante {sourceSaleNumber}",
                        _ => "Nueva Venta"
                    })
                </h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body" style="flex: 1; overflow-y: auto; min-height: 0;">
                @if (formMode == "edit")
                {
                    <div style="background:#dbeafe; border:2px solid #1e40af; color:#1e3a8a; padding:0.6rem 0.9rem; border-radius:6px; margin-bottom:0.8rem; display:flex; align-items:center; gap:0.5rem;">
                        <span style="font-size:1.4rem;">✎</span>
                        <div>
                            <div style="font-weight:800; font-size:1rem;">ESTAS EDITANDO el comprobante <strong>@sourceSaleNumber</strong></div>
                            <div style="font-size:0.82rem;">Cuando guardes, se sobreescriben los datos del mismo comprobante (no se crea uno nuevo).</div>
                        </div>
                    </div>
                }
                else if (formMode == "duplicate")
                {
                    <div style="background:#fef3c7; border:2px solid #d97706; color:#7c2d12; padding:0.6rem 0.9rem; border-radius:6px; margin-bottom:0.8rem; display:flex; align-items:center; gap:0.5rem;">
                        <span style="font-size:1.4rem;">⎘</span>
                        <div>
                            <div style="font-weight:800; font-size:1rem;">ESTAS DUPLICANDO el comprobante <strong>@sourceSaleNumber</strong></div>
                            <div style="font-size:0.82rem;">Se va a generar un comprobante NUEVO con la fecha de hoy. Modificá lo que quieras antes de emitirlo.</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                @* ════════════════════════════════════════════════════════════════
                   SECCION 1 · Datos del comprobante (cliente, fecha, condiciones)
                   ════════════════════════════════════════════════════════════════ *@
                <div class="venta-section">
                    <div class="venta-section-header">
                        <span class="venta-section-num">1</span>
                        <h4>Datos generales</h4>
                    </div>
                    <div class="venta-section-body">
                        @* Fila 1: Tipo de comprobante + Punto de venta + Vendedor + Fecha *@
                        <div class="form-row">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Tipo de comprobante *</label>
                                <select class="form-input" @bind="formComprobanteType">
                                    <option value="X">X — Cotización / Remito interno (sin IVA)</option>
                                    <option value="FACTURA_A" disabled>Factura A (próximamente — ARCA)</option>
                                    <option value="FACTURA_B" disabled>Factura B (próximamente — ARCA)</option>
                                    <option value="FACTURA_C" disabled>Factura C (próximamente — ARCA)</option>
                                </select>
                                <p style="font-size: 0.72rem; margin: 0.25rem 0 0; color: #6b7280;">
                                    Punto de venta: <strong>@PvForType(formComprobanteType)</strong> · descuenta stock, sin valor fiscal
                                </p>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Vendedor</label>
                                <input class="form-input" value="@(VendedorAuto ?? "—")" disabled />
                                <p style="font-size: 0.72rem; margin: 0.25rem 0 0; color: #6b7280;">
                                    Tomado del usuario logueado.
                                </p>
                            </div>
                            <div class="form-group" style="flex: 0 0 160px;">
                                <label class="form-label">Fecha *</label>
                                <input type="date" class="form-input" @bind="formDate" />
                            </div>
                        </div>

                        @* Fila 2: Cliente + (info de lista) *@
                        <div class="form-row">
                            <div class="form-group" style="flex: 2;">
                                <label class="form-label">Cliente</label>
                                <select class="form-input" @bind="formClientId" @bind:after="OnClientChanged">
                                    <option value="0">— Consumidor final —</option>
                                    @if (clients is not null)
                                    {
                                        @foreach (var c in clients.Where(x => x.IsActive || x.Id == formClientId))
                                        {
                                            <option value="@c.Id">@c.Code · @c.Name</option>
                                        }
                                    }
                                </select>
                                @{
                                    var activeTier = GetActiveTierForClient(formClientId);
                                }
                                @if (activeTier is not null)
                                {
                                    <p style="font-size: 0.72rem; margin: 0.25rem 0 0; color: #4b5563;">
                                        💳 Lista de precios: <strong>@activeTier.Name</strong>
                                        <span style="color: @(activeTier.AdjustmentPercent < 0 ? "#dc2626" : (activeTier.AdjustmentPercent > 0 ? "#059669" : "#6b7280"));"> (@FormatPercent(activeTier.AdjustmentPercent))</span>
                                    </p>
                                }
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Condición IVA del cliente</label>
                                <select class="form-input" @bind="formIvaCondition">
                                    <option value="Consumidor final">Consumidor final</option>
                                    <option value="Responsable Inscripto">Responsable Inscripto</option>
                                    <option value="Monotributo">Monotributo</option>
                                    <option value="Exento">Exento</option>
                                </select>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">Condición de pago</label>
                                <select class="form-input" @bind="formPaymentCondition">
                                    <option value="Efectivo">Efectivo</option>
                                    <option value="Transferencia">Transferencia</option>
                                    <option value="Tarjeta de debito">Tarjeta de débito</option>
                                    <option value="Tarjeta de credito">Tarjeta de crédito</option>
                                    <option value="Cuenta corriente">Cuenta corriente</option>
                                    <option value="Cheque">Cheque</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                @* ════════════════════════════════════════════════════════════════
                   SECCION 2 · Productos / Items (estilo Contabilium)
                   ════════════════════════════════════════════════════════════════ *@
                <div class="venta-section">
                    <div class="venta-section-header">
                        <span class="venta-section-num">2</span>
                        <h4>Productos o servicios facturados</h4>
                    </div>
                    <div class="venta-section-body">

                        @* Fila horizontal compacta para AGREGAR: cantidad / item / bonif% / agregar *@
                        <div class="venta-add-row">
                            <div class="form-group" style="flex: 0 0 80px;">
                                <label class="form-label">Cantidad</label>
                                <input class="form-input" type="number" step="0.01" min="0.01" @bind="addProductQty" style="text-align: right;" />
                            </div>
                            <div class="form-group" style="flex: 4;">
                                <label class="form-label">
                                    Seleccione un ítem
                                    @{
                                        var selectedAddProduct = (addProductId == 0 || availableProducts is null)
                                            ? null
                                            : availableProducts.FirstOrDefault(x => x.Id == addProductId);
                                    }
                                    @if (selectedAddProduct is not null && !selectedAddProduct.IsService)
                                    {
                                        var stk = selectedAddProduct.Stock;
                                        var unit = string.IsNullOrEmpty(selectedAddProduct.StockUnit) ? "u." : (selectedAddProduct.StockUnit == "kg" ? "kg" : "u.");
                                        string bg, fg, icon;
                                        if (stk <= 0) { bg = "#fee2e2"; fg = "#b91c1c"; icon = "⚠️"; }
                                        else if (stk < selectedAddProduct.CriticalStock) { bg = "#fef3c7"; fg = "#92400e"; icon = "⚠️"; }
                                        else { bg = "#dcfce7"; fg = "#15803d"; icon = "📦"; }
                                        <span style="display: inline-block; margin-left: 0.5rem; padding: 0.1rem 0.5rem; background: @bg; color: @fg; border-radius: 999px; font-size: 0.7rem; font-weight: 700; vertical-align: middle;">
                                            @icon Stock: @FormatQty(stk) @unit
                                        </span>
                                    }
                                    else if (selectedAddProduct is not null && selectedAddProduct.IsService)
                                    {
                                        <span style="display: inline-block; margin-left: 0.5rem; padding: 0.1rem 0.5rem; background: #e0e7ff; color: #3730a3; border-radius: 999px; font-size: 0.7rem; font-weight: 700; vertical-align: middle;">
                                            🛠️ Servicio (sin stock)
                                        </span>
                                    }
                                </label>
                                <input class="form-input"
                                       list="ventas-products-datalist"
                                       value="@productSearchText"
                                       @oninput="OnProductSearchInput"
                                       @onchange="OnProductSearchPicked"
                                       placeholder="Tipeá SKU o nombre..." />
                                <datalist id="ventas-products-datalist">
                                    @if (availableProducts is not null)
                                    {
                                        @foreach (var p in availableProducts.Take(2000))
                                        {
                                            <option value="@(p.Sku ?? "—") · @p.Title — $@FormatPrice(p.RetailPrice)"></option>
                                        }
                                    }
                                </datalist>
                            </div>
                            <div class="form-group" style="flex: 0 0 80px;">
                                <label class="form-label" title="Bonificación adicional sobre este item">Bonif %</label>
                                <input class="form-input" type="number" step="0.1" min="0" max="100" @bind="addProductBonif" style="text-align: right;" />
                            </div>
                            <div class="form-group" style="flex: 0 0 auto;">
                                <label class="form-label" style="visibility: hidden;">.</label>
                                <button class="btn btn-primary" @onclick="AddProduct" disabled="@(addProductId == 0)" style="white-space: nowrap;">+ Agregar</button>
                            </div>
                        </div>

                        @* Atajo: tipeo / escaneo rapido por codigo *@
                        <div class="venta-add-shortcuts">
                            <div class="form-group" style="flex: 1;">
                                <label class="form-label">⚡ Tipear o escanear código (Enter)</label>
                                <input class="form-input" @bind="codeInput" @bind:event="oninput"
                                       @onkeydown="OnCodeInputKey"
                                       placeholder="Si el código es padre, abre selector de hijos" />
                            </div>
                            <div class="form-group" style="flex: 0;">
                                <label class="form-label" style="visibility: hidden;">.</label>
                                <button class="btn btn-secondary" @onclick="AddByCode" disabled="@string.IsNullOrWhiteSpace(codeInput)" style="white-space: nowrap;">↵ Buscar</button>
                            </div>
                            <div class="form-group" style="flex: 0;">
                                <label class="form-label" style="visibility: hidden;">.</label>
                                <button class="btn btn-secondary" @onclick="AddManualItem" style="white-space: nowrap;" title="Agregar un item con descripción libre, sin producto">+ Item manual</button>
                            </div>
                        </div>

                        @* Sugerencias: top 10 productos historicos del cliente *@
                        @if (formClientId > 0 && topProductsForClient.Count > 0)
                        {
                            <div style="margin-top: 0.6rem; padding: 0.6rem 0.8rem; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #f59e0b; border-radius: 8px;">
                                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem;">
                                    <span style="font-size: 1rem;">⭐</span>
                                    <strong style="font-size: 0.85rem; color: #78350f;">
                                        Productos más comprados por @(clients?.FirstOrDefault(c => c.Id == formClientId)?.Name ?? "este cliente"):
                                    </strong>
                                    <span style="font-size: 0.75rem; color: #92400e;">(tocá uno para agregarlo)</span>
                                </div>
                                <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                                    @foreach (var t in topProductsForClient)
                                    {
                                        var stockColor = t.Stock <= 0 ? "#dc2626" : "#15803d";
                                        var unit = t.StockUnit == "kg" ? "kg" : "u.";
                                        <button type="button" class="btn"
                                                style="background: white; border: 1px solid #f59e0b; color: #78350f; padding: 0.35rem 0.6rem; border-radius: 6px; font-size: 0.78rem; display: inline-flex; align-items: center; gap: 0.4rem;"
                                                @onclick="() => AddSuggestedProduct(t.ProductId)"
                                                title="Comprado @t.TimesOrdered ve@(t.TimesOrdered == 1 ? "z" : "ces") · Cantidad total histórica: @FormatQty(t.TotalQuantity) · Última compra: @t.LastPurchase.ToString("dd/MM/yyyy")">
                                            <span style="background: #f59e0b; color: white; padding: 0.05rem 0.35rem; border-radius: 999px; font-size: 0.65rem; font-weight: 800;">@t.TimesOrdered×</span>
                                            <span style="font-family: monospace; color: #6b7280; font-size: 0.72rem;">@(string.IsNullOrEmpty(t.Sku) ? "—" : t.Sku)</span>
                                            <strong>@t.Title</strong>
                                            <span style="color: @stockColor; font-size: 0.7rem;">· @FormatQty(t.Stock) @unit</span>
                                            <span style="color: #6b7280; font-size: 0.72rem;">· $@FormatPrice(t.RetailPrice)</span>
                                            <span style="color: #f59e0b; font-weight: 700;">+</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @* Tabla de items agregados *@
                        @if (formItems.Count == 0)
                        {
                            <div style="padding: 1.5rem; text-align: center; color: #9ca3af; background: #f9fafb; border-radius: 6px; border: 1px dashed #d1d5db; margin-top: 0.5rem;">
                                <p style="margin: 0; font-size: 0.9rem;">Sin items todavía. Elegí un producto arriba y tocá <strong>+ Agregar</strong>.</p>
                            </div>
                        }
                        else
                        {
                            <table class="data-table venta-items-table" style="margin-top: 0.6rem;">
                                <thead>
                                    <tr>
                                        <th style="width: 32px; text-align: center;">#</th>
                                        <th style="width: 120px;">Código</th>
                                        <th>Descripción</th>
                                        <th style="width: 90px; text-align: center;">Cant.</th>
                                        <th style="width: 130px; text-align: right;">P. unit. s/IVA</th>
                                        <th style="width: 80px; text-align: right;">Bonif %</th>
                                        <th style="width: 70px; text-align: right;">IVA %</th>
                                        <th style="width: 130px; text-align: right;">Subtotal</th>
                                        <th style="width: 40px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int idx = 0; idx < formItems.Count; idx++)
                                    {
                                        var i = idx;
                                        var item = formItems[i];
                                        var isCafe = IsCoffeeItem(item);
                                        var (currentFormat, currentCustom) = isCafe ? ExtractCoffeeMeta(item.Description) : ("", "");
                                        var hasDp = isCafe && HasDoyPack(item.Description);
                                        <tr>
                                            <td style="text-align: center; color: #6b7280;">@(i + 1)</td>
                                            <td><input class="form-input" style="font-size: 0.8rem; padding: 0.25rem;" @bind="item.Code" /></td>
                                            <td>
                                                <input class="form-input" style="font-size: 0.85rem; padding: 0.25rem;" @bind="item.Description" />
                                                @if (isCafe)
                                                {
                                                    <div style="display: flex; gap: 0.4rem; margin-top: 0.25rem; align-items: center; flex-wrap: wrap;">
                                                        <select class="form-input"
                                                                style="font-size: 0.78rem; padding: 0.2rem; background: #fef3c7; border-color: #d97706; font-weight: 600; flex: 0 0 auto;"
                                                                value="@currentFormat"
                                                                @onchange="@(e => SetCoffeeFormat(item, e.Value?.ToString() ?? "", currentCustom))"
                                                                title="Formato de molido del café">
                                                            <option value="">☕ (sin especificar)</option>
                                                            <option value="EN GRANOS">🫘 EN GRANOS</option>
                                                            <option value="MOLIDO FILTRO">☕ MOLIDO FILTRO</option>
                                                            <option value="MOLIDO ESPRESS">⚡ MOLIDO ESPRESS</option>
                                                        </select>
                                                        <label style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.2rem 0.5rem; background: @(hasDp ? "#dbeafe" : "#f3f4f6"); border: 1px solid @(hasDp ? "#1e40af" : "#d1d5db"); border-radius: 6px; cursor: pointer; font-size: 0.78rem; font-weight: 600; color: @(hasDp ? "#1e3a8a" : "#6b7280");"
                                                               title="Doy pack (envase tipo pouch). Aparece como 'd.p.' al lado del producto en el comprobante">
                                                            <input type="checkbox" checked="@hasDp" @onchange="@(() => ToggleDoyPack(item))" style="margin: 0;" />
                                                            📦 Doy pack
                                                        </label>
                                                    </div>
                                                }
                                            </td>
                                            <td><input class="form-input" type="number" step="0.01" min="0.01" style="text-align: right; font-size: 0.85rem; padding: 0.25rem;" @bind="item.Quantity" /></td>
                                            <td><input class="form-input" type="number" step="0.01" min="0" style="text-align: right; font-size: 0.85rem; padding: 0.25rem;" @bind="item.UnitPrice" /></td>
                                            <td><input class="form-input" type="number" step="0.1" min="0" max="100" style="text-align: right; font-size: 0.85rem; padding: 0.25rem;" @bind="item.BonifPercent" /></td>
                                            <td style="text-align: right; font-size: 0.85rem; color: #6b7280;">@(item.VatRate?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture).Replace(".", ",") ?? "—")</td>
                                            <td style="text-align: right; font-weight: 700;">$@FormatPrice(LineTotal(item))</td>
                                            <td style="text-align: center;">
                                                <button class="btn-icon btn-delete" @onclick="() => RemoveItem(i)" title="Quitar">×</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>

                @* ════════════════════════════════════════════════════════════════
                   SECCION 3 · Detalle final + Totales (lado a lado)
                   ════════════════════════════════════════════════════════════════ *@
                <div class="venta-section">
                    <div class="venta-section-header">
                        <span class="venta-section-num">3</span>
                        <h4>Detalle del comprobante y totales</h4>
                    </div>
                    <div class="venta-section-body">
                        <div class="venta-final-grid">
                            @* Columna izquierda: detalle/observaciones *@
                            <div>
                                <div class="form-group">
                                    <label class="form-label">Marca / Logo del comprobante</label>
                                    <select class="form-input" @bind="formCompanyName" style="max-width: 300px;">
                                        @foreach (var b in BrandOptions)
                                        {
                                            <option value="@b">@b</option>
                                        }
                                        @if (!BrandOptions.Contains(formCompanyName))
                                        {
                                            <option value="@formCompanyName">@formCompanyName (personalizado)</option>
                                        }
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Días de la semana (aparecen abajo del comprobante)</label>
                                    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                                        @foreach (var d in AllWeekDays)
                                        {
                                            var isSel = formWeekDays.Contains(d);
                                            <label style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.3rem 0.6rem; border: 1px solid @(isSel ? "#15803d" : "#d1d5db"); background: @(isSel ? "#dcfce7" : "white"); border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.8rem;">
                                                <input type="checkbox" checked="@isSel" @onchange="() => ToggleFormDay(d)" style="margin: 0;" />
                                                @d
                                            </label>
                                        }
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; cursor: pointer;">
                                        <input type="checkbox" @bind="formIsPaid" style="width: 18px; height: 18px;" />
                                        Marcar como PAGADO (estampa el sello)
                                    </label>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Observaciones</label>
                                    <textarea class="form-input" rows="3" @bind="formNotes" placeholder="Notas que aparecen al pie del comprobante (opcional)"></textarea>
                                </div>
                            </div>

                            @* Columna derecha: caja de totales *@
                            <div>
                                <div class="venta-totals-box">
                                    <div class="venta-totals-row">
                                        <span>Subtotal s/IVA:</span>
                                        <strong>$@FormatPrice(Subtotal)</strong>
                                    </div>
                                    @if (TotalIva > 0)
                                    {
                                        <div class="venta-totals-row" style="color: #6b7280; font-size: 0.85rem;">
                                            <span>+ IVA:</span>
                                            <span>$@FormatPrice(TotalIva)</span>
                                        </div>
                                    }
                                    <div class="venta-totals-row">
                                        <span>Descuento ($):</span>
                                        <input class="form-input" type="number" step="0.01" min="0" @bind="formDiscount"
                                               style="text-align: right; max-width: 130px; font-weight: 700;" />
                                    </div>
                                    <hr style="margin: 0.5rem 0; border: none; border-top: 1px solid #d1d5db;" />
                                    <div class="venta-totals-row" style="font-size: 1.2rem; font-weight: 800; color: #059669;">
                                        <span>TOTAL:</span>
                                        <strong>$@FormatPrice(TotalCalc)</strong>
                                    </div>
                                    <p style="font-size: 0.7rem; color: #9ca3af; margin: 0.4rem 0 0; text-align: right;">
                                        @formItems.Count item@(formItems.Count == 1 ? "" : "s") · @(formClientId == 0 ? "Consumidor final" : (clients?.FirstOrDefault(c => c.Id == formClientId)?.Name ?? "—"))
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(isSaving || formItems.Count == 0)">
                    @(isSaving ? "Guardando..." : (formMode switch
                    {
                        "edit" => "Guardar cambios",
                        "duplicate" => "Emitir comprobante nuevo",
                        _ => "Emitir comprobante"
                    }))
                </button>
            </div>
        </div>
    </div>
}

@* ====== SELECTOR DE HIJOS DE UN PADRE (cuando se carga un codigo padre) ====== *@
@if (parentForChildPicker is not null)
{
    <div class="modal-overlay" @onclick="CloseChildPicker">
        <div class="modal-card modal-small" @onclick:stopPropagation="true" style="max-width: 600px;">
            <div class="modal-header" style="background: #dcfce7;">
                <h3 style="color: #15803d;">Elegí qué variantes querés agregar</h3>
                <button class="btn-close" @onclick="CloseChildPicker">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #374151; margin: 0 0 0.7rem;">
                    Tipeaste el código <strong>@parentForChildPicker.Sku</strong> que corresponde al producto padre
                    <strong>@parentForChildPicker.Title</strong>. Indicá cuántas unidades de cada variante querés sumar a la venta:
                </p>
                @if (childrenOfParent.Count == 0)
                {
                    <p class="text-muted">Este padre no tiene hijos cargados todavía.</p>
                }
                else
                {
                    <table class="data-table" style="margin: 0;">
                        <thead>
                            <tr>
                                <th style="width: 110px;">Código</th>
                                <th>Variante</th>
                                <th style="text-align: right; width: 110px;">PVP s/IVA</th>
                                <th style="text-align: center; width: 100px;">Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var child in childrenOfParent)
                            {
                                var cId = child.Id;
                                <tr>
                                    <td style="font-family: monospace; font-size: 0.85rem;">@(child.Sku ?? "—")</td>
                                    <td><strong>@child.Title</strong></td>
                                    <td style="text-align: right; font-weight: 700;">$@FormatPrice(child.RetailPrice)</td>
                                    <td style="text-align: center;">
                                        <input type="number" step="0.01" min="0" class="form-input" style="text-align:center; width: 80px;"
                                               value="@(childPickerQuantities.TryGetValue(cId, out var q) ? q : 0m)"
                                               @onchange="@(e => SetChildQty(cId, e.Value?.ToString()))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseChildPicker">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmChildPicker" disabled="@(!childPickerQuantities.Any(kv => kv.Value > 0))">
                    + Agregar a la venta
                </button>
            </div>
        </div>
    </div>
}

@* ====== VISOR DE COMPROBANTE ====== *@
@if (viewerSale is not null && companyInfo is not null)
{
    <style>
        .pagado-stamp {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%) rotate(-18deg);
            font-size: 2.2rem;
            font-weight: 800;
            color: rgba(220, 38, 38, 0.22);
            border: 3px solid rgba(220, 38, 38, 0.22);
            padding: 0.25rem 1.2rem;
            border-radius: 8px;
            letter-spacing: 0.2rem;
            pointer-events: none;
            user-select: none;
            z-index: 5;
        }
        .day-pill { display: inline-flex; align-items: center; justify-content: center; padding: 0.25rem 0.55rem; border: 1px solid #d1d5db; border-radius: 5px; font-weight: 700; font-size: 0.8rem; cursor: pointer; min-width: 38px; user-select: none; }
        .day-pill.on { background: #1f2937; color: white; border-color: #1f2937; }
        .comprobante-items th, .comprobante-items td { font-size: 0.82rem; padding: 0.3rem 0.4rem; }

        /* Etiqueta vertical en el margen derecho con el nombre de quien cargo la venta */
        .comprobante-vendedor-vertical {
            position: absolute;
            top: 0;
            right: -2px;
            height: 100%;
            display: flex;
            align-items: center;
            writing-mode: vertical-rl;
            transform: rotate(180deg); /* texto se lee de abajo hacia arriba */
            font-size: 0.72rem;
            font-weight: 600;
            color: #9ca3af;
            letter-spacing: 0.15rem;
            text-transform: uppercase;
            padding: 6mm 0;
            pointer-events: none;
            user-select: none;
            z-index: 4;
            white-space: nowrap;
        }

        /* Filas de relleno: linea punteada simulando un formulario de papel.
           Garantizan que el comprobante siempre tenga una altura estable
           y el pie/firmas siempre queden cerca del fondo de la hoja. */
        .comprobante-filler-row td {
            height: 7mm;
            border-bottom: 1px dotted #d1d5db !important;
            color: transparent;
            user-select: none;
        }

        /* === Reglas de impresion: ocultar artifacts del navegador === */
        @@media print {
            @@page { size: A4; margin: 12mm; }
            html, body { background: white !important; margin: 0 !important; padding: 0 !important; }

            body * { visibility: hidden; }
            #comprobante-print, #comprobante-print * { visibility: visible; }

            #comprobante-print {
                position: absolute !important;
                left: 0 !important; top: 0 !important; right: 0 !important;
                margin: 0 !important;
                padding: 0 !important;
                background: white !important;
            }

            .no-print { display: none !important; }
            .comprobante-items { page-break-inside: auto; }
            .comprobante-items th, .comprobante-items td { font-size: 0.78rem; }
            .comprobante-firmas { page-break-inside: avoid; }
        }
    </style>
    <div class="modal-overlay" @onclick="CloseViewer">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true" style="max-width: 800px;">
            <div class="modal-header no-print" style="background: whitesmoke;">
                <h3>Comprobante @viewerSale.Number</h3>
                <div style="display: flex; gap: 0.4rem; align-items: center;">
                    <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.85rem; cursor: pointer;">
                        <input type="checkbox" checked="@viewerSale.IsPaid" @onchange="TogglePaid" />
                        Pagado
                    </label>
                    <button class="btn" style="background:#25D366;color:white;border:none;font-size: 0.85rem;" @onclick="OpenWhatsappShare" title="Enviar por WhatsApp Web">📱 WhatsApp</button>
                    <button class="btn btn-secondary" @onclick="PrintViewer" style="font-size: 0.85rem;">🖨 Imprimir</button>
                    <button class="btn-close" @onclick="CloseViewer">&times;</button>
                </div>
            </div>
            <div class="modal-body" id="comprobante-print" style="background: white; position: relative;">
                @if (viewerSale.IsCancelled)
                {
                    <div style="background: #fee2e2; border: 2px solid #b91c1c; color: #7f1d1d; padding: 0.6rem 0.9rem; border-radius: 6px; margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.5rem;">
                        <span style="font-size: 1.4rem;">⚠</span>
                        <div>
                            <div style="font-weight: 800; font-size: 1rem;">COMPROBANTE ANULADO</div>
                            <div style="font-size: 0.85rem;">
                                @if (!string.IsNullOrEmpty(viewerSale.CancelledByOperator))
                                {
                                    <span>Anulado por <strong>@viewerSale.CancelledByOperator</strong></span>
                                }
                                @if (viewerSale.CancelledAt.HasValue)
                                {
                                    <span> el <strong>@viewerSale.CancelledAt.Value.ToLocalTime().ToString("dd/MM/yyyy")</strong> a las <strong>@viewerSale.CancelledAt.Value.ToLocalTime().ToString("HH:mm")</strong></span>
                                }
                            </div>
                        </div>
                    </div>
                }
                @if (viewerSale.IsPaid)
                {
                    <div class="pagado-stamp">PAGADO</div>
                }
                @* Etiqueta vertical con el nombre de quien cargo la venta. Solo si tenemos vendedor. *@
                @if (!string.IsNullOrWhiteSpace(viewerSale.VendedorName))
                {
                    <div class="comprobante-vendedor-vertical">
                        Cargado por: @viewerSale.VendedorName
                    </div>
                }
                <!-- Cabecera -->
                <div style="border: 1px solid #d1d5db; padding: 0.75rem;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                        <div style="flex: 1;">
                            <h2 style="margin: 0; font-size: 1.5rem; font-weight: 800;">@(viewerSale.CompanyNameSnapshot ?? companyInfo.Name)</h2>
                            @if (!string.IsNullOrEmpty(companyInfo.Phone))
                            {
                                <div style="font-size: 0.8rem;">@companyInfo.Phone</div>
                            }
                            @if (!string.IsNullOrEmpty(companyInfo.Email))
                            {
                                <div style="font-size: 0.78rem; font-style: italic;">@companyInfo.Email</div>
                            }
                            @if (!string.IsNullOrEmpty(companyInfo.Web))
                            {
                                <div style="font-size: 0.78rem; font-style: italic;">@companyInfo.Web</div>
                            }
                        </div>
                        <div style="background: #e5e7eb; padding: 0.6rem 1rem; font-weight: 700; font-size: 1.5rem;">X</div>
                        <div style="flex: 1; text-align: right; font-size: 0.85rem;">
                            <div style="color: #6b7280; font-style: italic; margin-bottom: 0.3rem;">Documento no valido como factura</div>
                            <div><strong>Original</strong></div>
                            <div><strong>N°:</strong> @viewerSale.Number</div>
                            <div><strong>Fecha:</strong> @viewerSale.Date.ToString("dd/MM/yyyy")</div>
                            <div><strong>CUIT:</strong> @companyInfo.Cuit</div>
                            @if (!string.IsNullOrEmpty(companyInfo.Iibb))
                            {
                                <div><strong>Ingresos brutos:</strong> @companyInfo.Iibb</div>
                            }
                            @if (!string.IsNullOrEmpty(companyInfo.ActivityStart))
                            {
                                <div><strong>Inicio de actividades:</strong> @companyInfo.ActivityStart</div>
                            }
                        </div>
                    </div>
                    <div style="font-size: 0.78rem; margin-top: 0.4rem;">
                        @if (!string.IsNullOrEmpty(companyInfo.Address))
                        {
                            <div>@companyInfo.Address</div>
                        }
                        <div>@companyInfo.IvaCondition</div>
                    </div>
                </div>

                <!-- Cliente -->
                <div style="border: 1px solid #d1d5db; border-top: 0; padding: 0.6rem; font-size: 0.85rem;">
                    <div><strong>Razón social:</strong> @(viewerSale.ClientNameSnapshot ?? "Consumidor final")</div>
                    @if (!string.IsNullOrEmpty(viewerSale.ClientAddressSnapshot))
                    {
                        <div><strong>Domicilio:</strong> @viewerSale.ClientAddressSnapshot</div>
                    }
                    @if (!string.IsNullOrEmpty(viewerSale.ClientCuitSnapshot))
                    {
                        <div><strong>CUIT/DNI:</strong> @viewerSale.ClientCuitSnapshot</div>
                    }
                    <div style="display: flex; justify-content: space-between; margin-top: 0.3rem;">
                        <span><strong>Condicion de venta:</strong> @viewerSale.PaymentCondition</span>
                        <span><strong>Condicion de IVA:</strong> @viewerSale.IvaCondition</span>
                    </div>
                </div>

                @* ===== Items ===== *@
                @{
                    // Mostrar columnas dinamicas: "P.U. lista" + "Desc." solo si algun item tiene
                    // descuento de lista; "Bonif" solo si algun item tiene bonificacion ad-hoc.
                    var anyTierDiscount = viewerSale.Items.Any(i => i.TierAdjustmentPercent != 0m && i.BasePrice > 0 && Math.Abs(i.BasePrice - i.UnitPrice) > 0.01m);
                    var anyBonif = viewerSale.Items.Any(i => i.BonifPercent > 0m);

                    // Subtotal sin descuento (sumando precios base, no los ya rebajados).
                    decimal subtotalSinDescuento = viewerSale.Items.Sum(i => i.Quantity * (i.BasePrice > 0 ? i.BasePrice : i.UnitPrice));
                    decimal totalAhorrado = Math.Max(0m, subtotalSinDescuento - viewerSale.Subtotal);

                    // Si todos los items tienen el mismo % de tier, mostramos el % en el pie.
                    var distinctTierPcts = viewerSale.Items.Where(i => i.TierAdjustmentPercent != 0m).Select(i => i.TierAdjustmentPercent).Distinct().ToList();
                    decimal? uniformTierPct = distinctTierPcts.Count == 1 ? distinctTierPcts[0] : (decimal?)null;
                }
                <table class="data-table comprobante-items" style="margin: 0; border: 1px solid #d1d5db; border-top: 0;">
                    <thead style="background: #f3f4f6;">
                        <tr>
                            <th style="width: 60px;">Cant.</th>
                            <th style="width: 100px;">Código</th>
                            <th>Descripción</th>
                            @if (anyTierDiscount)
                            {
                                <th style="text-align: right; width: 100px;">P.U. lista</th>
                                <th style="text-align: right; width: 60px;">Desc.</th>
                            }
                            <th style="text-align: right; width: 110px;">Precio unitario</th>
                            @if (anyBonif)
                            {
                                <th style="text-align: right; width: 60px;">Bonif</th>
                            }
                            <th style="text-align: right; width: 120px;">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in viewerSale.Items)
                        {
                            var hasDiscount = i.TierAdjustmentPercent != 0m && i.BasePrice > 0 && Math.Abs(i.BasePrice - i.UnitPrice) > 0.01m;
                            <tr>
                                <td>@FormatQty(i.Quantity)</td>
                                <td style="font-family: monospace;">@(i.Code ?? "")</td>
                                <td>@RenderItemDescription(i.Description)</td>
                                @if (anyTierDiscount)
                                {
                                    @if (hasDiscount)
                                    {
                                        <td style="text-align: right; color: #6b7280; text-decoration: line-through;">$@FormatPrice(i.BasePrice)</td>
                                        <td style="text-align: right; font-weight: 700; color: #dc2626;">@FormatPercent(i.TierAdjustmentPercent)</td>
                                    }
                                    else
                                    {
                                        <td style="text-align: right; color: #d1d5db;">—</td>
                                        <td style="text-align: right; color: #d1d5db;">—</td>
                                    }
                                }
                                <td style="text-align: right; font-weight: 600;">$@FormatPrice(i.UnitPrice)</td>
                                @if (anyBonif)
                                {
                                    <td style="text-align: right;">@(i.BonifPercent > 0 ? FormatQty(i.BonifPercent) + " %" : "—")</td>
                                }
                                <td style="text-align: right; font-weight: 600;">$@FormatPrice(i.LineTotal)</td>
                            </tr>
                        }
                        @* Filas vacias de relleno: garantizan que el comprobante siempre tenga
                           una altura minima estable, asi el pie/firmas quedan al fondo aunque
                           la venta tenga pocos items. Si hay mas items que MIN_ROWS, no se agregan rellenos. *@
                        @{
                            const int MIN_ROWS = 18;
                            int filasFijas = 3 + (anyTierDiscount ? 2 : 0) + (anyBonif ? 1 : 0); // Cant + Codigo + Descripcion + (P.U. lista + Desc) + (Bonif) + Precio + Subtotal
                            int totalCols = 5 + (anyTierDiscount ? 2 : 0) + (anyBonif ? 1 : 0);
                            int rellenos = Math.Max(0, MIN_ROWS - viewerSale.Items.Count);
                        }
                        @for (int r = 0; r < rellenos; r++)
                        {
                            <tr class="comprobante-filler-row">
                                <td colspan="@totalCols">&nbsp;</td>
                            </tr>
                        }
                    </tbody>
                </table>

                @* ===== Pie ===== *@
                <div style="border: 1px solid #d1d5db; border-top: 0; padding: 0.6rem; font-size: 0.85rem;">
                    <div style="display: flex; gap: 1rem; align-items: flex-start;">
                        <div style="flex: 1;">
                            @if (!string.IsNullOrEmpty(viewerSale.AmountInWords))
                            {
                                <div style="font-style: italic;">@viewerSale.AmountInWords</div>
                            }
                            @if (!string.IsNullOrEmpty(viewerSale.Notes))
                            {
                                <div style="margin-top: 0.4rem; color: #6b7280; font-size: 0.78rem;">
                                    <strong>Observaciones:</strong> @viewerSale.Notes
                                </div>
                            }
                        </div>
                        @* Caja de totales con desglose *@
                        <div style="min-width: 280px; border-left: 1px solid #e5e7eb; padding-left: 0.75rem;">
                            @if (totalAhorrado > 0 || viewerSale.Discount > 0)
                            {
                                <div style="display: flex; justify-content: space-between; padding: 0.15rem 0;">
                                    <span style="color: #6b7280;">Subtotal sin descuento:</span>
                                    <span>$@FormatPrice(subtotalSinDescuento)</span>
                                </div>
                            }
                            @if (totalAhorrado > 0)
                            {
                                <div style="display: flex; justify-content: space-between; padding: 0.15rem 0; color: #dc2626;">
                                    <span>Descuento de lista@(uniformTierPct.HasValue ? $" ({FormatPercent(uniformTierPct.Value)})" : ""):</span>
                                    <span>-$@FormatPrice(totalAhorrado)</span>
                                </div>
                            }
                            @if (viewerSale.Discount > 0)
                            {
                                <div style="display: flex; justify-content: space-between; padding: 0.15rem 0; color: #dc2626;">
                                    <span>Descuento adicional:</span>
                                    <span>-$@FormatPrice(viewerSale.Discount)</span>
                                </div>
                            }
                            <div style="border-top: 2px solid #1f2937; margin-top: 0.4rem; padding-top: 0.4rem; display: flex; justify-content: space-between; font-size: 1.1rem; font-weight: 800;">
                                <span>IMPORTE TOTAL:</span>
                                <span>$@FormatPrice(viewerSale.Total)</span>
                            </div>
                            @if (totalAhorrado > 0)
                            {
                                <div style="margin-top: 0.5rem; padding: 0.4rem 0.6rem; background: #dcfce7; color: #166534; border-radius: 4px; text-align: center; font-weight: 700; font-size: 0.85rem;">
