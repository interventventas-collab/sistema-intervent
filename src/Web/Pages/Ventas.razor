    // Mientras tipea: actualiza el texto y resetea el id elegido (porque puede no
    // haber match exacto todavia; el usuario sigue escribiendo).
    private void OnProductSearchInput(ChangeEventArgs e)
    {
        productSearchText = e.Value?.ToString() ?? "";
        addProductId = 0;
    }

    // Cuando elige una opcion del datalist: el texto del input pasa a ser
    // exactamente el value de un <option>. Buscamos el producto correspondiente.
    private void OnProductSearchPicked(ChangeEventArgs e)
    {
        productSearchText = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(productSearchText) || availableProducts is null)
        {
            addProductId = 0;
            return;
        }
        // Buscar por value exacto (lo que esta en <option value="...">):
        var match = availableProducts.FirstOrDefault(p =>
            string.Equals($"{(p.Sku ?? "—")} · {p.Title} — ${FormatPrice(p.RetailPrice)}",
                productSearchText, StringComparison.OrdinalIgnoreCase));
        if (match is null)
        {
            // Fallback: si tipeo solo el SKU
            match = availableProducts.FirstOrDefault(p =>
                !string.IsNullOrEmpty(p.Sku) &&
                string.Equals(p.Sku, productSearchText.Trim(), StringComparison.OrdinalIgnoreCase));
        }
        if (match is null)
        {
            // Fallback final: si tipeo parte del nombre y solo hay 1 que matchea
            var search = productSearchText.Trim().ToLower();
            var matches = availableProducts.Where(p =>
                (p.Title ?? "").ToLower().Contains(search) ||
                (p.Sku ?? "").ToLower().Contains(search)).Take(2).ToList();
            if (matches.Count == 1) match = matches[0];
        }
        addProductId = match?.Id ?? 0;
    }

    // Helper compartido: agrega un producto al carrito de la venta.
    // bonifPercent es opcional (0 por default) — sirve para descuento ad-hoc adicional sobre la lista.
    private void AddProductToSale(ProductDto p, decimal qty, decimal bonifPercent = 0m)
    {
        var item = new CreateSaleItemRequest
        {
            ProductId = p.Id,
            Code = p.Sku,
            Description = p.DisplayName ?? p.Title,
            Quantity = qty <= 0 ? 1 : qty,
            UnitPrice = GetTierAdjustedPrice(p, formClientId),
            VatRate = p.VatRate,
            BonifPercent = Math.Clamp(bonifPercent, 0m, 100m)
        };
        formItems.Add(item);

        // Si es cafe, default a "EN GRANOS" (lo mas comun). El usuario puede cambiar al toque.
        if (IsCoffeeItem(item))
        {
            SetCoffeeFormat(item, "EN GRANOS");
        }
    }

    // === Helpers de listas de precios (tiers) ===

    /// Devuelve la lista activa para un cliente: la suya (si esta visible para la empresa actual),
    /// o la default visible para la empresa, o null si no hay ninguna aplicable.
    private CustomerTierDto? GetActiveTierForClient(int clientId)
    {
        if (tiers is null || tiers.Count == 0) return null;

        // Filtrar listas por la empresa actual. Si no hay empresa elegida, considerar todas.
        bool isVisible(CustomerTierDto t) =>
            !Company.HasCompany || CurrentCompanyService.IsVisibleForCompany(t.Companies, Company.Current!);

        if (clientId > 0 && clients is not null)
        {
            var c = clients.FirstOrDefault(x => x.Id == clientId);
            if (c?.CustomerTierId is int tid)
            {
                var byClient = tiers.FirstOrDefault(t => t.Id == tid && isVisible(t));
                if (byClient is not null) return byClient;
            }
        }
        return tiers.FirstOrDefault(t => t.IsDefault && isVisible(t))
            ?? tiers.FirstOrDefault(t => t.IsDefault);
    }

    /// Calcula el PVP del producto aplicando el % de ajuste de la lista activa.
    /// (Sin overrides puntuales — esos los resuelve el backend si el frontend
    /// manda 0; aca priorizamos respuesta inmediata).
    private decimal GetTierAdjustedPrice(ProductDto p, int clientId)
    {
        var tier = GetActiveTierForClient(clientId);
        if (tier is null || tier.AdjustmentPercent == 0) return p.RetailPrice;
        return Math.Round(p.RetailPrice * (1m + tier.AdjustmentPercent / 100m), 2);
    }

    /// Cuando cambia el cliente, recalcula los UnitPrice del carrito segun
    /// la nueva lista. Solo afecta productos con ProductId (no items texto libre).
    /// Tambien dispara la carga del top 10 productos historicos del cliente.
    private async Task OnClientChanged()
    {
        if (availableProducts is not null)
        {
            foreach (var item in formItems)
            {
                if (!item.ProductId.HasValue) continue;
                var p = availableProducts.FirstOrDefault(x => x.Id == item.ProductId.Value);
                if (p is null) continue;
                item.UnitPrice = GetTierAdjustedPrice(p, formClientId);
            }
        }

        // Fetch sugerencias historicas
        if (formClientId > 0)
        {
            try
            {
                topProductsForClient = await Api.GetTopProductsByClientAsync(formClientId, 10) ?? new();
            }
            catch { topProductsForClient = new(); }
        }
        else
        {
            topProductsForClient = new();
        }

        StateHasChanged();
    }

    private static string FormatPercent(decimal p)
    {
        var sign = p > 0 ? "+" : "";
        return $"{sign}{p.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture).Replace(".", ",")}%";
    }

