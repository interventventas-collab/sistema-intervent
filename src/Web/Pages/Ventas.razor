@code {
    private List<SaleDto>? sales;
    private List<ClientDto>? clients;
    private List<ProductDto>? availableProducts;
    // Todos los productos (incluyendo padres) — usados para lookup por codigo en el input rapido.
    private List<ProductDto>? allProducts;
    // Input rapido por codigo
    private string codeInput = "";
    // Modal selector de hijos cuando el usuario tipea el codigo de un padre
    private ProductDto? parentForChildPicker;
    private List<ProductDto> childrenOfParent = new();
    private Dictionary<int, decimal> childPickerQuantities = new();
    private CompanyInfoDto? companyInfo;
    private bool isLoading = true;
    private bool showForm;
    private bool isSaving;
    private string? formError;

    // Form
    private DateTime formDate = DateTime.Today;
    private int formClientId;
    private string formIvaCondition = "Consumidor final";
    private string formPaymentCondition = "Efectivo";
    private decimal formDiscount;
    private string formNotes = "";
    private List<CreateSaleItemRequest> formItems = new();
    private int addProductId;
    private decimal addProductQty = 1;
    private HashSet<string> formWeekDays = new();
    private bool formIsPaid;
    private string formCompanyName = "FRIKAF®";

    // Modo del formulario: "new" | "edit" | "duplicate"
    private string formMode = "new";
    private int? editingSaleId;
    private string? sourceSaleNumber; // numero del comprobante origen (para banner de edit/duplicate)

    private static readonly string[] AllWeekDays = { "LUN", "MAR", "MIE", "JUE", "VIE", "SAB", "DOM" };
    private static readonly string[] BrandOptions = { "FRIKAF®", "INTERVENT®", "INTEREVENTOS®", "PALANICA®" };

    // Viewer / cancel
    private SaleDto? viewerSale;
    private SaleDto? saleToCancel;

    // Compartir por WhatsApp
    private bool showWhatsappModal;
    private string whatsappPhone = "";
    private string whatsappMessage = "";

    // Eliminar definitivamente (solo operador autorizado, con clave)
    private SaleDto? saleToDelete;
    private string deletePassword = "";
    private string? deleteError;
    private bool isDeleting;
    private DeleteSaleSettingsDto? deleteSettings;

    private bool CanDelete =>
        deleteSettings is not null &&
        Operator.HasOperator &&
        string.Equals(Operator.Current, deleteSettings.AllowedOperator, StringComparison.OrdinalIgnoreCase);

    // Company form
    private bool showCompanyForm;
    private CompanyInfoDto? companyForm;

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        isLoading = true;
        try { sales = await Api.GetSalesAsync() ?? new(); } catch { sales = new(); ToastService.Error("Error cargando ventas"); }
        try { clients = await Api.GetClientsAsync() ?? new(); } catch { clients = new(); }
        try
        {
            var all = await Api.GetProductsAsync() ?? new();
            allProducts = all;
            availableProducts = all.Where(p => p.IsActive && p.DerivedCount == 0)
                .OrderBy(p => p.Sku ?? "").ThenBy(p => p.Title).ToList();
        }
        catch { availableProducts = new(); allProducts = new(); }
        try { companyInfo = await Api.GetCompanyInfoAsync(); } catch { /* defaults */ }
        try { deleteSettings = await Api.GetSaleDeleteSettingsAsync(); } catch { deleteSettings = new DeleteSaleSettingsDto(); }
        isLoading = false;
    }

    private void ShowCreateForm()
    {
        formMode = "new";
        editingSaleId = null;
        sourceSaleNumber = null;
        formDate = DateTime.Today;
        formClientId = 0;
        formIvaCondition = "Consumidor final";
        formPaymentCondition = "Efectivo";
        formDiscount = 0;
        formNotes = "";
        formItems = new();
        addProductId = 0; addProductQty = 1;
        formWeekDays = new();
        formIsPaid = false;
        // Prioridad para la marca por defecto:
        // 1. La empresa actual del topbar (si esta seleccionada y matchea alguna BrandOption)
        // 2. La empresa configurada en companyInfo (si matchea alguna BrandOption)
        // 3. companyInfo.Name como esta
        // 4. FRIKAF®
        formCompanyName = ResolveDefaultBrand();
        formError = null; showForm = true;
    }

    private string ResolveDefaultBrand()
    {
        // Si hay empresa actual elegida, buscar la BrandOption que coincida (ignorando ® y mayusculas)
        if (Company.HasCompany)
        {
            var current = Company.Current!;
            var match = BrandOptions.FirstOrDefault(b =>
                string.Equals(b.TrimEnd('®').Trim(), current, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(match)) return match;
        }
        if (companyInfo is not null && BrandOptions.Contains(companyInfo.Name))
            return companyInfo.Name;
        return companyInfo?.Name ?? "FRIKAF®";
    }

    private async Task OpenEditForm(SaleDto s)
    {
        // Recargar para tener todos los items actualizados
        var fresh = await Api.GetSaleAsync(s.Id) ?? s;
        LoadFormFromSale(fresh, mode: "edit");
    }

    private async Task OpenDuplicateForm(SaleDto s)
    {
        var fresh = await Api.GetSaleAsync(s.Id) ?? s;
        LoadFormFromSale(fresh, mode: "duplicate");
    }

    private void LoadFormFromSale(SaleDto s, string mode)
    {
        formMode = mode;
        editingSaleId = mode == "edit" ? s.Id : null;
        sourceSaleNumber = s.Number;

        // Para duplicar usamos la fecha de hoy; para editar conservamos la del comprobante.
        formDate = mode == "duplicate" ? DateTime.Today : s.Date;
        formClientId = s.ClientId ?? 0;
        formIvaCondition = string.IsNullOrEmpty(s.IvaCondition) ? "Consumidor final" : s.IvaCondition!;
        formPaymentCondition = string.IsNullOrEmpty(s.PaymentCondition) ? "Efectivo" : s.PaymentCondition!;
        formDiscount = s.Discount;
        formNotes = s.Notes ?? "";
        formIsPaid = s.IsPaid;
        formCompanyName = !string.IsNullOrEmpty(s.CompanyNameSnapshot)
            ? s.CompanyNameSnapshot!
            : (companyInfo?.Name ?? "FRIKAF®");

        // WeekDays
        formWeekDays = new();
        if (!string.IsNullOrEmpty(s.WeekDays))
        {
            foreach (var d in s.WeekDays.Split(',', StringSplitOptions.RemoveEmptyEntries))
                formWeekDays.Add(d.Trim());
        }

        // Items
        formItems = s.Items.Select(it => new CreateSaleItemRequest
        {
            ProductId = it.ProductId,
            Code = it.Code,
            Description = it.Description,
            Quantity = it.Quantity,
            UnitPrice = it.UnitPrice,
            VatRate = it.VatRate,
            BonifPercent = it.BonifPercent
        }).ToList();

        addProductId = 0; addProductQty = 1;
        formError = null;
        showForm = true;
    }

    private void ToggleFormDay(string day)
    {
        if (formWeekDays.Contains(day)) formWeekDays.Remove(day);
        else formWeekDays.Add(day);
    }

    private void CloseForm() { showForm = false; formError = null; }

    private void AddProduct()
    {
        if (addProductId == 0) return;
        var p = availableProducts?.FirstOrDefault(x => x.Id == addProductId);
        if (p is null) return;
        AddProductToSale(p, addProductQty);
        addProductId = 0; addProductQty = 1;
    }

    // Helper compartido: agrega un producto al carrito de la venta.
    private void AddProductToSale(ProductDto p, decimal qty)
    {
        formItems.Add(new CreateSaleItemRequest
        {
            ProductId = p.Id,
            Code = p.Sku,
            Description = p.DisplayName ?? p.Title,
            Quantity = qty <= 0 ? 1 : qty,
            UnitPrice = p.RetailPrice,
            VatRate = p.VatRate,
            BonifPercent = 0
        });
    }

    // === Lookup por codigo (input rapido + Enter) ===

    private async Task OnCodeInputKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddByCode();
    }

    private Task AddByCode()
    {
        var code = (codeInput ?? "").Trim();
        if (string.IsNullOrEmpty(code)) return Task.CompletedTask;
        if (allProducts is null || allProducts.Count == 0)
        {
            ToastService.Error("No hay productos cargados todavia.");
            return Task.CompletedTask;
        }

        // Match por SKU exacto (case-insensitive). Excluye servicios solo si quisiera, pero
        // los servicios tambien son vendibles asi que los dejamos.
        var match = allProducts.FirstOrDefault(p =>
            p.IsActive && string.Equals(p.Sku, code, StringComparison.OrdinalIgnoreCase));

        if (match is null)
        {
            ToastService.Error($"No se encontró ningún producto con código '{code}'.");
            return Task.CompletedTask;
        }

        // Si es padre (tiene hijos), abrir el selector
        if (match.DerivedCount > 0)
        {
            parentForChildPicker = match;
            childrenOfParent = allProducts
                .Where(p => p.IsActive && p.BaseProductId == match.Id)
                .OrderBy(p => p.Sku ?? "").ThenBy(p => p.Title)
                .ToList();
            childPickerQuantities = childrenOfParent.ToDictionary(c => c.Id, _ => 0m);
            return Task.CompletedTask;
        }

        // Si es hijo o independiente: agregar directo con cantidad 1
        AddProductToSale(match, 1);
        ToastService.Success($"Agregado: {match.Title}");
        codeInput = "";
        return Task.CompletedTask;
    }

    private void SetChildQty(int childId, string? raw)
    {
        if (decimal.TryParse((raw ?? "").Replace(',', '.'),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            childPickerQuantities[childId] = v < 0 ? 0 : v;
        }
        else
        {
            childPickerQuantities[childId] = 0;
        }
    }

    private void ConfirmChildPicker()
    {
        if (parentForChildPicker is null) return;
        var added = 0;
        foreach (var child in childrenOfParent)
        {
            if (childPickerQuantities.TryGetValue(child.Id, out var qty) && qty > 0)
            {
                AddProductToSale(child, qty);
                added++;
            }
        }
        if (added > 0)
            ToastService.Success($"Agregadas {added} variante(s) de {parentForChildPicker.Title}");
        CloseChildPicker();
    }

    private void CloseChildPicker()
    {
        parentForChildPicker = null;
        childrenOfParent = new();
        childPickerQuantities = new();
        codeInput = "";
    }

    private void AddManualItem()
    {
        formItems.Add(new CreateSaleItemRequest
        {
            ProductId = null, Code = "", Description = "Item manual",
            Quantity = 1, UnitPrice = 0, BonifPercent = 0
        });
    }

    private void RemoveItem(int idx)
    {
        if (idx >= 0 && idx < formItems.Count) formItems.RemoveAt(idx);
    }

    private decimal LineTotal(CreateSaleItemRequest i)
    {
        var bruto = i.Quantity * i.UnitPrice;
        var bonif = bruto * (i.BonifPercent / 100m);
        return Math.Round(bruto - bonif, 2);
    }

    private decimal Subtotal => formItems.Sum(LineTotal);
    private decimal TotalCalc => Math.Max(0, Subtotal - formDiscount);

    private async Task Save()
    {
        if (formItems.Count == 0) { formError = "Agregá al menos un item"; return; }
        if (formItems.Any(i => i.Quantity <= 0 || string.IsNullOrWhiteSpace(i.Description)))
        { formError = "Todos los items deben tener cantidad > 0 y descripcion."; return; }

        isSaving = true; formError = null;
        try
        {
            var weekDaysCsv = formWeekDays.Count == 0 ? null
                : string.Join(",", AllWeekDays.Where(d => formWeekDays.Contains(d)));

            SaleDto? saved = null;

            if (formMode == "edit" && editingSaleId.HasValue)
            {
                var upd = new UpdateSaleRequest
                {
                    Date = formDate,
                    ClientId = formClientId > 0 ? formClientId : null,
                    PaymentCondition = formPaymentCondition,
                    IvaCondition = formIvaCondition,
                    Discount = formDiscount,
                    Notes = formNotes,
                    WeekDays = weekDaysCsv,
                    IsPaid = formIsPaid,
                    CompanyNameOverride = formCompanyName,
                    Items = formItems.ToList()
                };
                saved = await Api.UpdateSaleAsync(editingSaleId.Value, upd);
                if (saved is null) { formError = "No se pudo guardar los cambios"; return; }
                ToastService.Success($"Comprobante {saved.Number} actualizado");
            }
            else
            {
                var req = new CreateSaleRequest
                {
                    Date = formDate,
                    ClientId = formClientId > 0 ? formClientId : null,
                    PaymentCondition = formPaymentCondition,
                    IvaCondition = formIvaCondition,
                    Discount = formDiscount,
                    Notes = formNotes,
                    WeekDays = weekDaysCsv,
                    IsPaid = formIsPaid,
                    CompanyNameOverride = formCompanyName,
                    Items = formItems.ToList()
                };
                saved = await Api.CreateSaleAsync(req);
                if (saved is null) { formError = "No se pudo crear el comprobante"; return; }
                ToastService.Success($"Comprobante {saved.Number} emitido");
            }

            showForm = false;
            // Reset modo
            formMode = "new";
            editingSaleId = null;
            sourceSaleNumber = null;
            await LoadAll();
            // Abrir el visor automáticamente
            viewerSale = saved;
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task OpenViewer(SaleDto s)
