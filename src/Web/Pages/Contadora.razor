    // ── Pagos de facturas de compra ──
    private async Task AbrirPago(ContadoraComprobanteDto f)
    {
        pagoFactura = await Api.GetContadoraPagosCompraAsync(f.IdComprobante);
        if (pagoFactura is null) { ToastService.Error("No pude abrir la factura."); return; }
        pagoFecha = DateTime.Today;
        pagoMedio = "Transferencia";
        pagoReferencia = null;
        pagoObs = null;
        pagoImporte = Math.Max(0, pagoFactura.Saldo);
    }

    private void CerrarPago() => pagoFactura = null;

    private async Task GuardarPago()
    {
        if (pagoFactura is null || guardandoPago) return;
        if (pagoImporte <= 0) { ToastService.Error("Poné un importe mayor a cero."); return; }
        guardandoPago = true;
        try
        {
            var res = await Api.RegistrarPagoCompraAsync(new RegistrarPagoCompraRequest
            {
                IdComprobante = pagoFactura.IdComprobante,
                Fecha = pagoFecha,
                Medio = pagoMedio,
                Referencia = pagoReferencia,
                Importe = pagoImporte,
                Observaciones = pagoObs
            });
            if (res is null || !res.Ok) { ToastService.Error(res?.Error ?? "No se pudo guardar el pago."); return; }
            pagoFactura = res.Factura;
            pagoImporte = Math.Max(0, pagoFactura?.Saldo ?? 0);
            pagoReferencia = null; pagoObs = null;
            ToastService.Success("Pago registrado.");
            await CargarCompComps();
            if (verDeuda) await CargarDeuda();
        }
