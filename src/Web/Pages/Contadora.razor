    private async Task OnComprasSeleccionadas(InputFileChangeEventArgs e)
    {
        if (importandoCompras) return;
        importandoCompras = true; comprasResult = null;
        try
        {
            var archivos = new List<(string, Stream)>();
            foreach (var f in e.GetMultipleFiles(20))
            {
                var ms = new MemoryStream();
                await f.OpenReadStream(50_000_000).CopyToAsync(ms);
                ms.Position = 0;
                archivos.Add((f.Name, ms));
            }
            var (result, error) = await Api.ImportarComprasArchivosAsync(archivos);
            if (error is not null) { ToastService.Error(error); return; }
            comprasResult = result;
            if (result is not null && result.Ok) { ToastService.Success(result.Mensaje ?? "Importado."); await CargarBalanza(); }
            else ToastService.Error(result?.Mensaje ?? "No se pudo importar.");
        }
        catch (Exception ex) { ToastService.Error("Error al importar compras: " + ex.Message); }
        finally { importandoCompras = false; }
    }

    private static readonly string[] Meses = { "", "enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre" };
    private static string MesLabel(int anio, int mes) => (mes >= 1 && mes <= 12 ? Meses[mes] : mes.ToString()) + " " + anio;

    private static string DestinoLabel(string prov) => prov.StartsWith("(") ? prov : $"Argentina - {prov}";

    private static string Money(decimal v)
    {
        var neg = v < 0; v = Math.Abs(v);
        var s = v.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
        var parts = s.Split('.');
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < parts[0].Length; i++)
        {
            if (i > 0 && (parts[0].Length - i) % 3 == 0) sb.Append('.');
            sb.Append(parts[0][i]);
        }
        return (neg ? "-" : "") + sb.ToString() + "," + parts[1];
    }
