    // Convierte "yyyy-MM" a primer y último día del mes.
    private static (DateTime? desde, DateTime? hasta) RangoDelMes(string? mes)
    {
        if (string.IsNullOrWhiteSpace(mes) || !DateTime.TryParse(mes + "-01", out var d)) return (null, null);
        return (d, d.AddMonths(1).AddDays(-1));
    }

