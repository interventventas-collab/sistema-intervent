    {
        if (string.IsNullOrWhiteSpace(empresaSel)) { ToastService.Error("Elegí una empresa (arriba) para cargar retenciones."); return; }
        if (!decimal.TryParse(valor, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var monto)) monto = 0m;
        try
        {
            await Api.GuardarRetencionAsync(empresaSel, f.Anio, f.Mes, monto, null);
            await CargarBalanza();   // recalcula posición + arrastre
            ToastService.Success("Retenciones actualizadas.");
