    private async Task ImportarCarpeta()
    {
        if (importando) return;
        importando = true; importResult = null;
        try
        {
            importResult = await Api.ImportarReporteCarpetaAsync();
            if (importResult is not null && importResult.Ok)
            {
                ToastService.Success(importResult.Mensaje ?? "Importado.");
                await RecargarRep();
            }
            else ToastService.Error(importResult?.Mensaje ?? "No se pudo importar.");
        }
        catch (Exception ex) { ToastService.Error("Error al importar: " + ex.Message); }
        finally { importando = false; }
    }

    private async Task OnArchivosSeleccionados(InputFileChangeEventArgs e)
    {
        if (importando) return;
        importando = true; importResult = null;
        try
        {
            var archivos = new List<(string, Stream)>();
            foreach (var f in e.GetMultipleFiles(20))
            {
                var ms = new MemoryStream();
                await f.OpenReadStream(50_000_000).CopyToAsync(ms);
                ms.Position = 0;
                archivos.Add((f.Name, ms));
            }
            var (result, error) = await Api.ImportarReporteArchivosAsync(archivos);
            if (error is not null) { ToastService.Error(error); return; }
            importResult = result;
            if (result is not null && result.Ok) { ToastService.Success(result.Mensaje ?? "Importado."); await RecargarRep(); }
            else ToastService.Error(result?.Mensaje ?? "No se pudo importar.");
        }
        catch (Exception ex) { ToastService.Error("Error al importar: " + ex.Message); }
        finally { importando = false; }
    }

