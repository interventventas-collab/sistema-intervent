@page "/stock/reposicion"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject IJSRuntime JS
@using System.Globalization
@using System.Text

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <div>
            <h3 style="margin:0;">📦 Reposición / Pedidos a proveedor</h3>
            <p class="text-muted" style="margin:0.3rem 0 0; font-size:0.82rem;">
                Stock actual + movimientos del período + sugerido para reponer. Filtrá por marca y exportá Excel con formato de pedido.
            </p>
        </div>
        <div style="display:flex; gap:0.5rem;">
            <button class="btn btn-secondary" @onclick="CargarAsync" disabled="@cargando">🔄 Actualizar</button>
            <button class="btn btn-primary" @onclick="ExportarExcel" disabled="@(filas.Count == 0)">📄 Exportar Excel (pedido)</button>
        </div>
    </div>

    @* ===== Filtros ===== *@
    <div class="card-body" style="background:#f8fafc; border-bottom:1px solid #e5e7eb;">
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:0.7rem;">
            <div>
                <label class="form-label">Desde</label>
                <input type="date" class="form-control" @bind="desde" />
            </div>
            <div>
                <label class="form-label">Hasta</label>
                <input type="date" class="form-control" @bind="hasta" />
            </div>
            <div>
                <label class="form-label">Marca</label>
                <select class="form-control" @bind="marcaTexto">
                    <option value="">— Todas —</option>
                    @foreach (var m in marcas)
                    {
                        <option value="@m">@m</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Código OEM</label>
                <input type="text" class="form-control" placeholder="ej: 1076" @bind="oemCodigo" />
            </div>
            <div>
                <label class="form-label">SKU del sistema</label>
                <input type="text" class="form-control" placeholder="ej: C1076" @bind="sku" />
            </div>
            <div>
                <label class="form-label">Categoría</label>
                <select class="form-control" @bind="categoria">
                    <option value="">— Todas —</option>
                    <option value="CAFE">CAFE</option>
                    <option value="OTROS">OTROS</option>
                </select>
            </div>
            <div>
                <label class="form-label">Cliente (opcional)</label>
                <select class="form-control" @bind="clienteId">
                    <option value="0">— Todos —</option>
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>
        </div>

        <div style="margin-top:0.8rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
            <span style="font-size:0.78rem; color:#6b7280; font-weight:600; text-transform:uppercase;">Tipos de movimiento:</span>
            @foreach (var t in tiposMovDisponibles)
            {
                var tip = t;
                <label style="display:flex; align-items:center; gap:0.3rem; font-size:0.85rem; cursor:pointer;">
                    <input type="checkbox" checked="@tiposMovSel.Contains(tip)"
                           @onchange="@(e => ToggleTipo(tip, (bool)(e.Value ?? false)))" />
                    <span>@LabelTipo(tip)</span>
                </label>
            }
            <div style="margin-left:auto;">
                <button class="btn btn-primary" @onclick="CargarAsync" disabled="@cargando">
                    @(cargando ? "Buscando..." : "🔍 Buscar")
                </button>
            </div>
        </div>

        @* Atajos de período *@
        <div style="margin-top:0.5rem; display:flex; gap:0.3rem; flex-wrap:wrap;">
            <button class="btn-shortcut" @onclick="@(() => SetPeriodo(7))">Últimos 7 días</button>
            <button class="btn-shortcut" @onclick="@(() => SetPeriodo(30))">Últimos 30 días</button>
            <button class="btn-shortcut" @onclick="@(() => SetPeriodo(90))">Últimos 90 días</button>
            <button class="btn-shortcut" @onclick="SetMesActual">Este mes</button>
            <button class="btn-shortcut" @onclick="SetMesAnterior">Mes pasado</button>
        </div>
    </div>

    @* ===== Tabla resultados ===== *@
    <div class="card-body" style="padding:0;">
        @if (cargando)
        {
            <p class="text-muted" style="padding:1.5rem;">Calculando...</p>
        }
        else if (filas.Count == 0)
        {
            <p class="text-muted" style="padding:1.5rem;">No hay datos para mostrar con esos filtros. Tocá <strong>Buscar</strong> o ajustá los filtros.</p>
        }
        else
        {
            <div style="padding:0.75rem 1rem; background:#fffbeb; border-bottom:1px solid #fde68a; font-size:0.85rem;">
                📊 <strong>@filas.Count</strong> productos · Total vendido: <strong>@filas.Sum(f => f.VendidoUnidades) u</strong> · Facturado: <strong>$@filas.Sum(f => f.FacturadoTotal).ToString("N0", CultureInfo.GetCultureInfo("es-AR"))</strong>
            </div>
            <div style="overflow-x:auto;">
                <table class="table" style="margin:0; font-size:0.85rem;">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Producto</th>
                            <th>Marca</th>
                            <th>OEM</th>
                            <th style="text-align:right;">Stock</th>
                            <th style="text-align:right;">Entradas</th>
                            <th style="text-align:right;">Salidas</th>
                            <th style="text-align:right;">Ajustes</th>
                            <th style="text-align:right;">Vendido $</th>
                            <th style="text-align:right; background:#dbeafe;">Sugerido reponer</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in filas)
                        {
                            <tr>
                                <td><code>@(f.Sku ?? "—")</code></td>
                                <td>@f.Nombre</td>
                                <td>@(f.Marca ?? "—")</td>
                                <td>@(f.OemCodigo ?? "—")</td>
                                <td style="text-align:right; font-weight:700; @(f.StockActual <= 0 ? "color:#dc2626;" : "")">@f.StockActual</td>
                                <td style="text-align:right; color:#15803d;">@(f.Entradas > 0 ? "+" + f.Entradas.ToString("0.##") : "—")</td>
                                <td style="text-align:right; color:#991b1b;">@(f.Salidas > 0 ? "-" + f.Salidas.ToString("0.##") : "—")</td>
                                <td style="text-align:right; color:#6b7280;">@(f.Ajustes != 0 ? f.Ajustes.ToString("0.##") : "—")</td>
                                <td style="text-align:right;">$@f.FacturadoTotal.ToString("N0", CultureInfo.GetCultureInfo("es-AR"))</td>
                                <td style="text-align:right; background:#dbeafe; font-weight:700; @(f.SugeridoReponer > 0 ? "color:#1e40af;" : "color:#9ca3af;")">@f.SugeridoReponer</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
.btn-shortcut {
    background:#fff; border:1px solid #d1d5db; color:#374151;
    padding:0.3rem 0.7rem; border-radius:6px; font-size:0.78rem; cursor:pointer;
}
.btn-shortcut:hover { background:#f3f4f6; }
</style>

@code {
    private DateTime? desde = DateTime.Today.AddDays(-30);
    private DateTime? hasta = DateTime.Today;
    private string? marcaTexto;
    private string? oemCodigo;
    private string? sku;
    private string? categoria;
    private int clienteId;
    private HashSet<string> tiposMovSel = new() { "VENTA_NUESTRA", "VENTA_MELI", "VENTA_MELI_FULL", "SUMA", "RESTA", "SET" };
    private readonly string[] tiposMovDisponibles = { "VENTA_NUESTRA", "VENTA_MELI", "VENTA_MELI_FULL", "SUMA", "RESTA", "SET" };

    private List<string> marcas = new();
    private List<CafeClienteDto> clientes = new();
    private List<ApiClient.ReposicionRow> filas = new();
    private bool cargando;

    private string LabelTipo(string t) => t switch
    {
        "VENTA_NUESTRA" => "Ventas",
        "VENTA_MELI" => "Ventas MeLi",
        "VENTA_MELI_FULL" => "Ventas MeLi Full",
        "SUMA" => "Entradas",
        "RESTA" => "Salidas manuales",
        "SET" => "Ajustes (set)",
        _ => t
    };

    private void ToggleTipo(string t, bool on)
    {
        if (on) tiposMovSel.Add(t); else tiposMovSel.Remove(t);
    }

    private void SetPeriodo(int dias) { desde = DateTime.Today.AddDays(-dias); hasta = DateTime.Today; }
    private void SetMesActual() { var hoy = DateTime.Today; desde = new DateTime(hoy.Year, hoy.Month, 1); hasta = hoy; }
    private void SetMesAnterior() { var hoy = DateTime.Today; var inicio = new DateTime(hoy.Year, hoy.Month, 1).AddMonths(-1); desde = inicio; hasta = inicio.AddMonths(1).AddDays(-1); }

    protected override async Task OnInitializedAsync()
    {
        var marcasData = await Api.GetCafeMarcasAsync(activos: true);
        if (marcasData is not null) marcas = marcasData.Select(m => m.Nombre).OrderBy(n => n).ToList();
        var clientesData = await Api.GetCafeClientesAsync();
        if (clientesData is not null) clientes = clientesData.OrderBy(c => c.Nombre).ToList();
    }

    private async Task CargarAsync()
    {
        cargando = true;
        try
        {
            var tipos = string.Join(",", tiposMovSel);
            var res = await Api.GetReposicionAsync(
                desde: desde, hasta: hasta?.AddDays(1),
                marcaTexto: string.IsNullOrWhiteSpace(marcaTexto) ? null : marcaTexto,
                oemCodigo: string.IsNullOrWhiteSpace(oemCodigo) ? null : oemCodigo,
                sku: string.IsNullOrWhiteSpace(sku) ? null : sku,
                categoria: string.IsNullOrWhiteSpace(categoria) ? null : categoria,
                clienteId: clienteId > 0 ? clienteId : null,
                tiposMov: string.IsNullOrEmpty(tipos) ? null : tipos);
            filas = res?.Filas ?? new();
            if (filas.Count == 0) ToastService.Info("No hay resultados para esos filtros");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { cargando = false; }
    }

    private async Task ExportarExcel()
    {
        // Excel formato pedido a proveedor — CSV con BOM (UTF-8) que Excel abre directo.
        // Solo incluye productos con SugeridoReponer > 0 si filtraste por marca específica;
        // sino exporta todo el resultado actual.
        var soloSugeridos = !string.IsNullOrWhiteSpace(marcaTexto);
        var datos = soloSugeridos ? filas.Where(f => f.SugeridoReponer > 0).ToList() : filas;
        if (datos.Count == 0) { ToastService.Info("No hay filas para exportar"); return; }

        var sb = new StringBuilder();
        sb.Append('﻿'); // BOM
        var marca = string.IsNullOrWhiteSpace(marcaTexto) ? "VARIOS" : marcaTexto!.ToUpperInvariant();
        var hoy = DateTime.Today.ToString("dd/MM/yyyy");
        sb.AppendLine($"PEDIDO A {marca};;;;;");
        sb.AppendLine($"Fecha;{hoy};;;;");
        sb.AppendLine($"De;INTER VENT / PALANICA HERMANOS SRL;;;;");
        sb.AppendLine();
        sb.AppendLine("Código OEM;SKU;Descripción;Cantidad;Stock actual;Vendido período");
        foreach (var f in datos)
        {
            sb.AppendLine($"{Esc(f.OemCodigo)};{Esc(f.Sku)};{Esc(f.Nombre)};{(soloSugeridos ? f.SugeridoReponer : f.VendidoUnidades)};{f.StockActual};{f.VendidoUnidades}");
        }
        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var fileName = $"Pedido-{marca.Replace(' ', '_')}-{DateTime.Today:yyyy-MM-dd}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", Convert.ToBase64String(bytes));
        ToastService.Success($"Archivo {fileName} descargado");
    }

    private static string Esc(string? s) => string.IsNullOrEmpty(s) ? "" : s.Replace(";", ",").Replace("\n", " ").Replace("\r", " ");
}
