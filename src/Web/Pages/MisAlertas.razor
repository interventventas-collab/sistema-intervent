@page "/mis-alertas"
@attribute [Authorize]
@inject ApiClient Api
@inject IJSRuntime JS
@inject ToastService Toast

<PageTitle>Mis Alertas</PageTitle>

@* 2026-07-10 — Motor de alertas configurables (Paso 1). El usuario arma sus propias reglas:
   "SI pasa esto → avisame con este mensaje". Un robot las revisa cada 5 min y las dispara
   en la campanita 🔔 de la barra de arriba. *@

<div class="page-header">
    <div>
        <h1 class="page-title">🔔 Mis Alertas</h1>
        <p class="page-subtitle">Acá ves el historial de todos los avisos. Con el botón <strong>⚙️ Configurar</strong> armás tus propias alertas.</p>
    </div>
    @if (tab == "config" && !mostrandoEditor)
    {
        <button class="btn-primary" @onclick="NuevaAlerta">＋ Nueva alerta</button>
    }
</div>

@* Dos solapas: el Historial (lo que pasó) y la Configuración (armar/prender alertas). *@
<div class="ma-tabs">
    <button class="ma-tab @(tab == "historial" ? "on" : "")" @onclick='() => CambiarTab("historial")'>📜 Historial de avisos</button>
    <button class="ma-tab @(tab == "config" ? "on" : "")" @onclick='() => CambiarTab("config")'>⚙️ Configurar alertas</button>
</div>

@if (tab == "historial")
{
    <div class="ma-hist-box">
        <div class="ma-hist-toolbar">
            <div class="ma-hist-filter">
                <label class="ma-hist-filter-lbl">Mostrar:</label>
                <select class="ma-select" @bind="filtroTipo" @bind:after="CargarHistorial">
                    <option value="TODOS">Todos los avisos</option>
                    <option value="EMAIL_REMITENTE">📧 Correos</option>
                    <option value="VENTA_MELI">🛒 Ventas MercadoLibre</option>
                    <option value="FICHADA">🕐 Fichadas</option>
                    <option value="PUBLI_MELI">⚠️ Publicaciones MeLi para revisar</option>
                    <option value="SHELL_BAJO">⛽ Shell Flota</option>
                    <option value="BANCO_BAJO">🏦 Banco Galicia</option>
                    <option value="CHEQUE_VENCE">📄 Cheques</option>
                    <option value="FECHA_MES">📅 Recordatorios de fecha</option>
                </select>
            </div>
            <button class="btn-secondary" @onclick="CargarHistorial" title="Actualizar">🔄 Actualizar</button>
        </div>
        @if (historial.Count == 0)
        {
            <div class="ma-hist-empty">
                @(filtroTipo == "TODOS"
                    ? "Todavía no hay avisos. Acá van a ir apareciendo, uno por uno, todos los avisos que dispara el sistema (correos que entran, ventas, fichadas, saldos, cheques, etc.)."
                    : "No hay avisos de este tipo por ahora.")
            </div>
        }
        else
        {
            <div class="ma-hist-list">
                @foreach (var h in historial)
                {
                    <div class="ma-hist-row">
                        <div class="ma-hist-emoji">@Emoji(h.Tipo)</div>
                        <div class="ma-hist-mid">
                            <div class="ma-hist-msg">@h.Mensaje</div>
                            @if (!string.IsNullOrWhiteSpace(h.Detalle))
                            {
                                <div class="ma-hist-det">@h.Detalle</div>
                            }
                            <div class="ma-hist-meta">
                                <span>@FechaArg(h.CreatedAt)</span>
                                @if (h.PorTelegram)
                                {
                                    <span class="ma-hist-tg @(h.EnviadoTelegram ? "ok" : "fail")" title="@(h.EnviadoTelegram ? "Enviado a Telegram" : "No se pudo enviar a Telegram")">📲 @(h.EnviadoTelegram ? "enviado" : "no enviado")</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(h.GmailLink))
                                {
                                    <a href="@h.GmailLink" target="_blank" class="ma-hist-link">Abrir en Gmail →</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{

@if (mostrandoEditor)
{
    <div class="ma-editor">
        <div class="ma-editor-title">@(editandoId is null ? "Nueva alerta" : "Editar alerta")</div>

        <div class="ma-frase">
            <span class="ma-frase-txt">Avisame si</span>
            <select @bind="form.Tipo" @bind:after="OnTipoChanged" class="ma-select">
                <option value="SHELL_BAJO">⛽ Shell Flota baja de</option>
                <option value="BANCO_BAJO">🏦 el Banco Galicia baja de</option>
                <option value="CHEQUE_VENCE">📄 un cheque emitido vence en</option>
                <option value="FECHA_MES">📅 es el día del mes</option>
                <option value="EMAIL_REMITENTE">📧 entra un correo de</option>
            </select>

            @if (form.Tipo is "SHELL_BAJO" or "BANCO_BAJO")
            {
                <span class="ma-prefix">$</span>
                <input type="number" min="0" step="1000" @bind="form.Umbral" class="ma-num" placeholder="50000" />
            }
            else if (form.Tipo == "CHEQUE_VENCE")
            {
                <input type="number" min="0" max="60" step="1" @bind="form.Umbral" class="ma-num" placeholder="2" />
                <span class="ma-frase-txt">día(s) o menos</span>
            }
            else if (form.Tipo == "FECHA_MES")
            {
                <span class="ma-frase-txt">día</span>
                <input type="number" min="1" max="31" step="1" @bind="form.Umbral" class="ma-num" placeholder="15" />
                <span class="ma-frase-txt">de cada mes</span>
            }
        </div>
        @if (form.Tipo == "EMAIL_REMITENTE")
        {
            <div class="ma-field">
                <div class="ma-chips">
                    @if (form.Remitentes.Count == 0)
                    {
                        <span class="ma-chips-empty">Todavía no agregaste ningún correo</span>
                    }
                    @foreach (var r in form.Remitentes)
                    {
                        <span class="ma-chip">@r<button type="button" class="ma-chip-x" title="Quitar" @onclick="@(() => QuitarRemitente(r))">×</button></span>
                    }
                </div>
                <div class="ma-chip-add">
                    <input type="text" @bind="form.RemitenteNuevo" @bind:event="oninput" @onkeydown="OnRemitenteKey"
                           class="ma-text" style="max-width:300px;" placeholder="correo@@ejemplo.com" />
                    <button type="button" class="btn-secondary" @onclick="AgregarRemitente">＋ Agregar</button>
                </div>
                <div class="ma-hint" style="margin-top:6px;">Agregá los correos de a uno (Enter o el botón ＋). Sacá cualquiera con la × sin tocar los demás. Te avisa si entra un mail de cualquiera (solo de los que lleguen de ahora en adelante).</div>
            </div>
        }
        @if (form.Tipo == "EMAIL_REMITENTE" && (correoCfg is null || !correoCfg.Configurada))
        {
            <div class="ma-cfg-warn">⚠️ Todavía no configuraste la casilla de correo (más abajo). Sin eso, esta alerta no puede vigilar el mail.</div>
        }

        <div class="ma-field">
            <label class="ma-label">Con este mensaje</label>
            <input type="text" maxlength="300" @bind="form.Mensaje" class="ma-text" placeholder="@PlaceholderMensaje()" />
        </div>

        <div class="ma-field">
            <label class="ma-label">Mandámela por</label>
            <div class="ma-canales">
                <span class="ma-canal ma-canal-on" title="Aparece en la campanita 🔔 de la barra de arriba">🔔 Campanita</span>
                <label class="ma-canal @(form.PorTelegram ? "ma-canal-on" : "ma-canal-off")" style="cursor:pointer;display:inline-flex;align-items:center;gap:6px;" title="Además de la campanita, te llega al Telegram del dueño">
                    <input type="checkbox" @bind="form.PorTelegram" style="width:15px;height:15px;" /> 📲 Telegram
                </label>
                <span class="ma-canal ma-canal-off" title="Muy pronto">📧 Correo <em>(pronto)</em></span>
            </div>
        </div>

        <div class="ma-field">
            <label class="ma-label">¿Quién la ve?</label>
            <div class="ma-roles">
                <label class="ma-role"><input type="checkbox" @bind="form.VeAdmin" /> 👑 Admin</label>
                <label class="ma-role"><input type="checkbox" @bind="form.VeOficina" /> 🏢 Oficina</label>
                <label class="ma-role"><input type="checkbox" @bind="form.VeDeposito" /> 🏭 Depósito <em>(aún no lo ve en su menú)</em></label>
            </div>
        </div>

        <div class="ma-editor-actions">
            <button class="btn-secondary" @onclick="CancelarEditor">Cancelar</button>
            <button class="btn-primary" @onclick="Guardar" disabled="@guardando">@(guardando ? "Guardando..." : "Guardar alerta")</button>
        </div>
    </div>
}

@if (loading)
{
    <div class="loading">Cargando...</div>
}
else
{
    var sistema = alertas?.Where(a => a.EsSistema).ToList() ?? new();
    var propias = alertas?.Where(a => !a.EsSistema).ToList() ?? new();

    @* ── Avisos automáticos del sistema (Ventas MeLi / Fichadas) ── *@
    @if (sistema.Count > 0)
    {
        <div class="ma-sec-title">🤖 Avisos automáticos del sistema</div>
        <div class="ma-sec-sub">Estos los detecta el sistema solo. Elegí por dónde te avisa cada uno.</div>
        <div class="ma-list">
            @foreach (var a in sistema)
            {
                <div class="ma-card ma-card-sis @(a.Activa ? "" : "ma-card-off")">
                    <div class="ma-card-emoji">@Emoji(a.Tipo)</div>
                    <div class="ma-card-mid">
                        <div class="ma-card-msg">@TituloSistema(a.Tipo) <span class="ma-sis-tag">del sistema</span></div>
                        <div class="ma-card-desc">@DescSistema(a.Tipo)</div>
                        <div class="ma-sis-canales">
                            <span class="ma-sis-canales-lbl">Avisarme por:</span>
                            <label class="ma-canal-chk @(a.CanalCampanita ? "on" : "") @(a.Activa ? "" : "dis")" title="Aparece en la campanita 🔔 de arriba">
                                <input type="checkbox" checked="@a.CanalCampanita" disabled="@(!a.Activa)"
                                       @onchange="@(e => SetSistemaCampanita(a, Convert.ToBoolean(e.Value)))" /> 🔔 Campanita
                            </label>
                            <label class="ma-canal-chk @(a.CanalTelegram ? "on" : "") @(a.Activa ? "" : "dis")" title="Te llega al Telegram del dueño">
                                <input type="checkbox" checked="@a.CanalTelegram" disabled="@(!a.Activa)"
                                       @onchange="@(e => SetSistemaTelegram(a, Convert.ToBoolean(e.Value)))" /> 📲 Telegram
                            </label>
                        </div>
                        @if (a.Activa && a.EstaDisparada && !string.IsNullOrWhiteSpace(a.UltimoDetalle))
                        {
                            <div class="ma-card-fired">🔴 @a.UltimoDetalle</div>
                        }
                    </div>
                    <div class="ma-card-actions">
                        <label class="ma-switch" title="@(a.Activa ? "Aviso encendido" : "Aviso apagado")">
                            <input type="checkbox" checked="@a.Activa" @onchange="@(() => ToggleSistema(a))" />
                            <span class="ma-slider"></span>
                        </label>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Alertas armadas por el usuario ── *@
    <div class="ma-sec-title" style="margin-top:1.4rem;">🔔 Tus alertas</div>
    @if (propias.Count == 0)
    {
        @if (!mostrandoEditor)
        {
            <div class="empty-state">
                <p>Todavía no armaste ninguna alerta propia.</p>
                <p class="ma-empty-sub">Creá la primera con el botón <strong>＋ Nueva alerta</strong>. Por ejemplo: "avisame si Shell Flota baja de $50.000".</p>
            </div>
        }
    }
    else
    {
        <div class="ma-list">
            @foreach (var a in propias)
            {
                <div class="ma-card @(a.Activa ? "" : "ma-card-off")">
                    <div class="ma-card-emoji">@Emoji(a.Tipo)</div>
                    <div class="ma-card-mid">
                        <div class="ma-card-msg">@a.Mensaje</div>
                        <div class="ma-card-desc">@Describir(a)</div>
                        <div class="ma-card-roles">👁 La ven: @RolesTexto(a.Roles)</div>
                        @if (a.Activa && a.EstaDisparada)
                        {
                            <div class="ma-card-fired">🔴 Disparada ahora@(string.IsNullOrWhiteSpace(a.UltimoDetalle) ? "" : $" — {a.UltimoDetalle}")</div>
                        }
                    </div>
                    <div class="ma-card-actions">
                        <label class="ma-switch" title="@(a.Activa ? "Alerta encendida" : "Alerta apagada")">
                            <input type="checkbox" checked="@a.Activa" @onchange="@(() => Toggle(a))" />
                            <span class="ma-slider"></span>
                        </label>
                        <button class="ma-icon-btn" title="Editar" @onclick="@(() => Editar(a))">✏️</button>
                        <button class="ma-icon-btn" title="Borrar" @onclick="@(() => Borrar(a))">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
}

<div class="ma-correo-box">
    <div class="ma-correo-head">
        <span>📧 Casilla que reviso para las alertas de correo:
            <strong>@(correoCfg?.Configurada == true ? correoCfg!.Usuario : "sin configurar")</strong>
        </span>
        <button class="btn-secondary" @onclick="AbrirCfgCorreo">@(correoCfg?.Configurada == true ? "Cambiar" : "Configurar")</button>
    </div>
    @if (mostrandoCfgCorreo)
    {
        <div class="ma-correo-form">
            <div class="ma-field">
                <label class="ma-label">Correo (Gmail)</label>
                <input type="email" @bind="cfgUsuario" class="ma-text" placeholder="intervent.ventas@gmail.com" />
            </div>
            <div class="ma-field">
                <label class="ma-label">Clave de aplicación de Google</label>
                <input type="password" @bind="cfgPassword" class="ma-text" placeholder="@(correoCfg?.TieneClave == true ? "•••• (dejá vacío para no cambiarla)" : "pegá la clave de 16 letras")" />
                <div class="ma-hint">Es una clave especial que genera Google (no tu contraseña normal). Se guarda protegida y nunca se muestra.</div>
            </div>
            <div class="ma-editor-actions">
                <button class="btn-secondary" @onclick="() => mostrandoCfgCorreo = false">Cancelar</button>
                <button class="btn-primary" @onclick="GuardarCfgCorreo" disabled="@guardandoCfg">@(guardandoCfg ? "Guardando..." : "Guardar casilla")</button>
            </div>
        </div>
    }
</div>

}

<style>
    .ma-editor {
        background: #fff; border: 1px solid #e5e7eb; border-radius: 12px;
        padding: 1.25rem 1.5rem; margin-bottom: 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .ma-editor-title { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.03em; color: #9ca3af; margin-bottom: 14px; }
    .ma-frase { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-bottom: 16px; }
    .ma-frase-txt { color: #4b5563; font-size: 0.95rem; }
    .ma-select, .ma-num, .ma-text {
        border: 1px solid #d1d5db; border-radius: 8px; padding: 8px 10px;
        font-size: 0.95rem; background: #fff;
    }
    .ma-num { width: 110px; }
    .ma-text { width: 100%; max-width: 480px; }
    .ma-prefix { color: #6b7280; font-weight: 600; }
    .ma-field { margin-bottom: 16px; }
    .ma-label { display: block; font-size: 0.85rem; color: #4b5563; margin-bottom: 6px; }
    .ma-canales { display: flex; flex-wrap: wrap; gap: 8px; }
    .ma-canal { font-size: 0.85rem; padding: 6px 12px; border-radius: 8px; }
    .ma-canal-on { background: #E6F1FB; color: #185FA5; font-weight: 600; }
    .ma-canal-off { background: #f3f4f6; color: #9ca3af; }
    .ma-canal-off em { font-style: normal; font-size: 0.75rem; }
    .ma-roles { display: flex; flex-wrap: wrap; gap: 14px; }
    .ma-role { display: inline-flex; align-items: center; gap: 6px; font-size: 0.9rem; color: #374151; cursor: pointer; }
    .ma-role input { width: 16px; height: 16px; }
    .ma-role em { font-style: normal; font-size: 0.72rem; color: #9ca3af; }
    .ma-editor-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }

    .ma-list { display: flex; flex-direction: column; gap: 10px; }
    .ma-card {
        display: flex; align-items: center; gap: 14px;
        background: #fff; border: 1px solid #e5e7eb; border-radius: 12px;
        padding: 14px 16px;
    }
    .ma-card-off { opacity: 0.55; }
    .ma-card-emoji { font-size: 1.5rem; width: 32px; text-align: center; flex-shrink: 0; }
    .ma-card-mid { flex: 1; min-width: 0; }
    .ma-card-msg { font-size: 1rem; font-weight: 600; color: #111827; }
    .ma-card-desc { font-size: 0.82rem; color: #6b7280; margin-top: 2px; }
    .ma-card-roles { font-size: 0.75rem; color: #9ca3af; margin-top: 2px; }
    .ma-cfg-warn { background: #FEF3C7; color: #92400E; font-size: 0.8rem; padding: 8px 10px; border-radius: 8px; margin-bottom: 12px; }
    .ma-hint { font-size: 0.75rem; color: #6b7280; margin-top: 4px; }
    .ma-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; min-height: 24px; }
    .ma-chips-empty { font-size: 0.82rem; color: #9ca3af; font-style: italic; }
    .ma-chip { display: inline-flex; align-items: center; gap: 6px; background: #E6F1FB; color: #185FA5; font-size: 0.82rem; padding: 4px 6px 4px 10px; border-radius: 999px; }
    .ma-chip-x { border: none; background: rgba(24,95,165,0.15); color: #185FA5; width: 18px; height: 18px; border-radius: 50%; cursor: pointer; font-size: 0.9rem; line-height: 1; display: inline-flex; align-items: center; justify-content: center; padding: 0; }
    .ma-chip-x:hover { background: #185FA5; color: #fff; }
    .ma-chip-add { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .ma-correo-box { background: #F9FAFB; border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px 16px; margin-top: 1.5rem; }
    .ma-correo-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; font-size: 0.9rem; color: #374151; }
    .ma-correo-form { margin-top: 14px; border-top: 1px solid #e5e7eb; padding-top: 14px; }
    .ma-card-fired { font-size: 0.8rem; color: #991B1B; margin-top: 4px; font-weight: 600; }
    .ma-card-actions { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .ma-icon-btn {
        background: none; border: none; cursor: pointer; font-size: 1.05rem;
        padding: 4px 6px; border-radius: 6px;
    }
    .ma-icon-btn:hover { background: #f3f4f6; }
    .ma-empty-sub { color: #6b7280; font-size: 0.9rem; }

    /* Sección alertas del sistema */
    .ma-sec-title { font-size: 0.95rem; font-weight: 700; color: #374151; margin-bottom: 4px; }
    .ma-sec-sub { font-size: 0.8rem; color: #9ca3af; margin-bottom: 10px; }
    .ma-card-sis { border-color: #dbeafe; background: #f8fbff; }
    .ma-sis-tag { font-size: 0.68rem; font-weight: 600; color: #2563eb; background: #dbeafe; padding: 1px 7px; border-radius: 999px; margin-left: 6px; vertical-align: middle; }
    .ma-sis-canales { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 8px; }
    .ma-sis-canales-lbl { font-size: 0.8rem; color: #6b7280; }
    .ma-canal-chk { display: inline-flex; align-items: center; gap: 5px; font-size: 0.82rem; padding: 4px 10px; border-radius: 999px; background: #f3f4f6; color: #6b7280; cursor: pointer; border: 1px solid transparent; }
    .ma-canal-chk.on { background: #E6F1FB; color: #185FA5; border-color: #bcd8f2; font-weight: 600; }
    .ma-canal-chk.dis { opacity: 0.5; cursor: not-allowed; }
    .ma-canal-chk input { width: 14px; height: 14px; }

    /* Interruptor prender/apagar */
    .ma-switch { position: relative; display: inline-block; width: 42px; height: 24px; cursor: pointer; }
    .ma-switch input { opacity: 0; width: 0; height: 0; }
    .ma-slider {
        position: absolute; inset: 0; background: #cbd5e1; border-radius: 999px; transition: 0.2s;
    }
    .ma-slider::before {
        content: ""; position: absolute; height: 18px; width: 18px; left: 3px; top: 3px;
        background: #fff; border-radius: 50%; transition: 0.2s;
    }
    .ma-switch input:checked + .ma-slider { background: #22c55e; }
    .ma-switch input:checked + .ma-slider::before { transform: translateX(18px); }

    /* Solapas Historial / Configuración */
    .ma-tabs { display: flex; gap: 6px; border-bottom: 2px solid #e5e7eb; margin-bottom: 1.25rem; }
    .ma-tab {
        background: none; border: none; cursor: pointer; padding: 10px 16px;
        font-size: 0.92rem; font-weight: 600; color: #6b7280;
        border-bottom: 2px solid transparent; margin-bottom: -2px;
    }
    .ma-tab:hover { color: #374151; }
    .ma-tab.on { color: #185FA5; border-bottom-color: #185FA5; }

    /* Historial de avisos */
    .ma-hist-box { background: #F9FAFB; border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px 16px; }
    .ma-hist-toolbar { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
    .ma-hist-filter { display: flex; align-items: center; gap: 8px; }
    .ma-hist-filter-lbl { font-size: 0.85rem; color: #4b5563; }
    .ma-hist-empty { font-size: 0.85rem; color: #6b7280; margin-top: 14px; padding: 8px 0; }
    .ma-hist-list { display: flex; flex-direction: column; margin-top: 12px; }
    .ma-hist-row { display: flex; gap: 12px; padding: 10px 0; border-top: 1px solid #eef1f4; }
    .ma-hist-row:first-child { border-top: none; }
    .ma-hist-emoji { font-size: 1.2rem; width: 26px; text-align: center; flex-shrink: 0; }
    .ma-hist-mid { flex: 1; min-width: 0; }
    .ma-hist-msg { font-size: 0.92rem; font-weight: 600; color: #111827; }
    .ma-hist-det { font-size: 0.82rem; color: #4b5563; margin-top: 2px; }
    .ma-hist-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-top: 4px; font-size: 0.75rem; color: #9ca3af; }
    .ma-hist-tg { padding: 1px 7px; border-radius: 999px; font-weight: 600; }
    .ma-hist-tg.ok { background: #E6F1FB; color: #185FA5; }
    .ma-hist-tg.fail { background: #FEE2E2; color: #991B1B; }
    .ma-hist-link { color: #185FA5; text-decoration: none; font-weight: 600; }
    .ma-hist-link:hover { text-decoration: underline; }
</style>

@code {
    private List<ApiClient.AlertaDto>? alertas;
    private bool loading = true;
    private bool mostrandoEditor;
    private bool guardando;
    private int? editandoId;
    private AlertaForm form = new();
    // Al abrir el editor, subimos la pantalla hasta él (si no, se abre arriba y parece que "no hace nada").
    private bool scrollEditorPending;

    private class AlertaForm
    {
        public string Tipo { get; set; } = "SHELL_BAJO";
        public decimal? Umbral { get; set; }
        public List<string> Remitentes { get; set; } = new();
        public string RemitenteNuevo { get; set; } = "";
        public string Mensaje { get; set; } = "";
        public bool VeAdmin { get; set; } = true;
        public bool VeOficina { get; set; } = true;
        public bool VeDeposito { get; set; } = false;
        public bool PorTelegram { get; set; } = false;
    }

    // Solapa activa: "historial" (por defecto, lo que ve la campanita al entrar) o "config".
    private string tab = "historial";

    // Historial de avisos (bitácora)
    private List<ApiClient.HistorialAlertaDto> historial = new();
    private string filtroTipo = "TODOS";

    // Config de la casilla de correo (para alertas 📧)
    private ApiClient.ConfigCorreoAlertasDto? correoCfg;
    private bool mostrandoCfgCorreo;
    private bool guardandoCfg;
    private string cfgUsuario = "";
    private string cfgPassword = "";

    protected override async Task OnInitializedAsync() => await Cargar();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (scrollEditorPending)
        {
            scrollEditorPending = false;
            try { await JS.InvokeVoidAsync("scrollTo", new { top = 0, behavior = "smooth" }); } catch { }
        }
    }

    private async Task Cargar()
    {
        loading = true;
        alertas = await Api.GetMisAlertasAsync();
        correoCfg = await Api.GetConfigCorreoAlertasAsync();
        historial = await Api.GetHistorialAlertasAsync(filtroTipo);
        loading = false;
    }

    private void CambiarTab(string t) => tab = t;

    private async Task CargarHistorial()
        => historial = await Api.GetHistorialAlertasAsync(filtroTipo);

    private void AbrirCfgCorreo()
    {
        cfgUsuario = correoCfg?.Usuario ?? "";
        cfgPassword = "";
        mostrandoCfgCorreo = true;
    }

    private async Task GuardarCfgCorreo()
    {
        if (string.IsNullOrWhiteSpace(cfgUsuario)) { Toast.Error("Escribí el correo (Gmail)"); return; }
        if ((correoCfg is null || !correoCfg.TieneClave) && string.IsNullOrWhiteSpace(cfgPassword))
        { Toast.Error("Pegá la clave de aplicación de Google"); return; }

        guardandoCfg = true;
        var (ok, err) = await Api.SaveConfigCorreoAlertasAsync(new ApiClient.ConfigCorreoAlertasRequest(
            Host: "imap.gmail.com", Port: 993, Usuario: cfgUsuario.Trim(),
            Password: string.IsNullOrWhiteSpace(cfgPassword) ? null : cfgPassword));
        guardandoCfg = false;
        if (!ok) { Toast.Error(err ?? "No se pudo guardar"); return; }
        Toast.Success("Casilla de correo guardada");
        cfgPassword = "";
        mostrandoCfgCorreo = false;
        correoCfg = await Api.GetConfigCorreoAlertasAsync();
    }

    private void NuevaAlerta()
    {
        editandoId = null;
        form = new AlertaForm();
        mostrandoEditor = true;
        scrollEditorPending = true;
    }

    private void Editar(ApiClient.AlertaDto a)
    {
        editandoId = a.Id;
        form = new AlertaForm
        {
            Tipo = a.Tipo,
            Umbral = a.Umbral,
            Remitentes = string.IsNullOrWhiteSpace(a.TextoParam)
                ? new()
                : a.TextoParam.Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Distinct().ToList(),
            Mensaje = a.Mensaje,
            VeAdmin = a.Roles.Contains("admin"),
            VeOficina = a.Roles.Contains("oficina"),
            VeDeposito = a.Roles.Contains("deposito"),
            PorTelegram = a.CanalTelegram
        };
        mostrandoEditor = true;
        scrollEditorPending = true;
    }

    private void CancelarEditor()
    {
        mostrandoEditor = false;
        editandoId = null;
    }

    private void OnTipoChanged()
    {
        // Al cambiar de tipo, limpiamos los valores para no arrastrar un monto donde va un día o un correo.
        form.Umbral = null;
        form.Remitentes = new();
        form.RemitenteNuevo = "";
    }

    private void AgregarRemitente()
    {
        var v = form.RemitenteNuevo?.Trim();
        if (string.IsNullOrWhiteSpace(v)) return;
        // Por si pegó varios de una (con coma/espacio), los separo.
        var partes = v.Split(new[] { ',', ';', '\n', '\r', ' ' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var p in partes)
            if (!form.Remitentes.Contains(p, StringComparer.OrdinalIgnoreCase))
                form.Remitentes.Add(p);
        form.RemitenteNuevo = "";
    }

    private void QuitarRemitente(string r) => form.Remitentes.Remove(r);

    private void OnRemitenteKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AgregarRemitente();
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(form.Mensaje)) { Toast.Error("Escribí el mensaje del aviso"); return; }
        if (form.Tipo == "EMAIL_REMITENTE")
        {
            // Si quedó algo tipeado sin agregar, lo agregamos solo (para no perderlo).
            if (!string.IsNullOrWhiteSpace(form.RemitenteNuevo)) AgregarRemitente();
            if (form.Remitentes.Count == 0) { Toast.Error("Agregá al menos un correo a vigilar"); return; }
        }
        else
        {
            if (form.Umbral is null || form.Umbral <= 0) { Toast.Error("Completá el valor (monto, días o día del mes)"); return; }
            if (form.Tipo == "FECHA_MES" && (form.Umbral < 1 || form.Umbral > 31)) { Toast.Error("El día del mes va de 1 a 31"); return; }
        }

        var roles = new List<string>();
        if (form.VeAdmin) roles.Add("admin");
        if (form.VeOficina) roles.Add("oficina");
        if (form.VeDeposito) roles.Add("deposito");
        if (roles.Count == 0) { Toast.Error("Elegí al menos quién ve la alerta (Admin, Oficina o Depósito)"); return; }

        guardando = true;
        var texto = form.Tipo == "EMAIL_REMITENTE" ? string.Join(",", form.Remitentes) : null;
        var req = new ApiClient.AlertaUpsertRequest(form.Tipo, form.Umbral, texto, form.Mensaje.Trim(),
            CanalCampanita: true, CanalWhatsApp: false, CanalCorreo: false, CanalTelegram: form.PorTelegram,
            Activa: true, Roles: roles);

        if (editandoId is null)
        {
            var (a, err) = await Api.CrearAlertaAsync(req);
            guardando = false;
            if (a is null) { Toast.Error(err ?? "No se pudo crear"); return; }
            Toast.Success("Alerta creada");
        }
        else
        {
            // Al editar preservamos si estaba activa o no.
            var actual = alertas?.FirstOrDefault(x => x.Id == editandoId);
            var reqEdit = req with { Activa = actual?.Activa ?? true };
            var (a, err) = await Api.ActualizarAlertaAsync(editandoId.Value, reqEdit);
            guardando = false;
            if (a is null) { Toast.Error(err ?? "No se pudo guardar"); return; }
            Toast.Success("Alerta guardada");
        }

        mostrandoEditor = false;
        editandoId = null;
        await Cargar();
    }

    private async Task Toggle(ApiClient.AlertaDto a)
    {
        if (await Api.ToggleAlertaAsync(a.Id)) await Cargar();
        else Toast.Error("No se pudo cambiar");
    }

    // ── Alertas del sistema (Ventas MeLi / Fichadas) ──
    private Task ToggleSistema(ApiClient.AlertaDto a)
        => GuardarSistema(a, !a.Activa, a.CanalCampanita, a.CanalTelegram);
    private Task SetSistemaCampanita(ApiClient.AlertaDto a, bool v)
        => GuardarSistema(a, a.Activa, v, a.CanalTelegram);
    private Task SetSistemaTelegram(ApiClient.AlertaDto a, bool v)
        => GuardarSistema(a, a.Activa, a.CanalCampanita, v);

    private async Task GuardarSistema(ApiClient.AlertaDto a, bool activa, bool camp, bool tg)
    {
        var ok = await Api.UpdateSistemaAlertaAsync(a.Tipo, new ApiClient.SistemaAlertaRequest(activa, camp, tg));
        if (ok) await Cargar();
        else Toast.Error("No se pudo guardar el cambio");
    }

    private static string TituloSistema(string tipo) => tipo switch
    {
        "VENTA_MELI" => "Ventas nuevas de MercadoLibre",
        "FICHADA" => "Fichadas de empleados",
        "PUBLI_MELI" => "Publicaciones MeLi para revisar (precio)",
        _ => tipo
    };

    private static string DescSistema(string tipo) => tipo switch
    {
        "VENTA_MELI" => "Te aviso cada venta nueva que entra por MercadoLibre.",
        "FICHADA" => "Te aviso cada entrada/salida de empleados (y la plata a rendir al salir).",
        "PUBLI_MELI" => "Te aviso cuando una publicación pausada recibe stock (el robot NO la activa) o cuando una publicación se reactiva — para que revises el precio antes de vender.",
        _ => ""
    };

    private async Task Borrar(ApiClient.AlertaDto a)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"¿Borrar la alerta \"{a.Mensaje}\"?");
        if (!ok) return;
        if (await Api.EliminarAlertaAsync(a.Id)) { Toast.Success("Alerta borrada"); await Cargar(); }
        else Toast.Error("No se pudo borrar");
    }

    private string PlaceholderMensaje() => form.Tipo switch
    {
        "SHELL_BAJO" => "Recargar saldo Shell",
        "BANCO_BAJO" => "Poné plata en el banco",
        "CHEQUE_VENCE" => "Cubrí el cheque",
        "FECHA_MES" => "Pagar a la contadora",
        "EMAIL_REMITENTE" => "Llegó un mail importante",
        _ => "Escribí el aviso"
    };

    private static string RolesTexto(List<string> roles)
    {
        if (roles is null || roles.Count == 0) return "nadie";
        var nombres = roles.Select(r => r switch
        {
            "admin" => "Admin",
            "oficina" => "Oficina",
            "deposito" => "Depósito",
            _ => r
        });
        return string.Join(", ", nombres);
    }

    // El historial guarda la fecha en UTC; la mostramos en hora Argentina (UTC-3).
    private static string FechaArg(DateTime utc)
        => utc.AddHours(-3).ToString("dd/MM HH:mm");

    private static string Emoji(string tipo) => tipo switch
    {
        "SHELL_BAJO" => "⛽",
        "BANCO_BAJO" => "🏦",
        "CHEQUE_VENCE" => "📄",
        "FECHA_MES" => "📅",
        "EMAIL_REMITENTE" => "📧",
        "VENTA_MELI" => "🛒",
        "FICHADA" => "🕐",
        "PUBLI_MELI" => "⚠️",
        _ => "🔔"
    };

    private static string Describir(ApiClient.AlertaDto a)
    {
        var v = a.Umbral ?? 0;
        var money = "$" + v.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
        var canal = a.CanalTelegram ? "campanita + Telegram 📲" : "campanita";
        return a.Tipo switch
        {
            "SHELL_BAJO" => $"Si Shell Flota baja de {money} · por {canal}",
            "BANCO_BAJO" => $"Si el Banco Galicia baja de {money} · por {canal}",
            "CHEQUE_VENCE" => $"Si un cheque emitido vence en {(int)v} día(s) o menos · por {canal}",
            "FECHA_MES" => $"El día {(int)v} de cada mes · por {canal}",
            "EMAIL_REMITENTE" => $"Si entra un correo de: {FormatRemitentes(a.TextoParam)} · por {canal}",
            _ => ""
        };
    }

    private static string FormatRemitentes(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) return "(sin remitentes)";
        var lista = texto
            .Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Distinct().ToList();
        if (lista.Count <= 3) return string.Join(", ", lista);
        return string.Join(", ", lista.Take(3)) + $" y {lista.Count - 3} más";
    }
}
