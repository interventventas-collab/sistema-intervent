@page "/oems"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>📦 OEMs (códigos de proveedor)</h3>
        <div style="font-size: 0.82rem; color: #6b7280;">
            @if (oemRows is not null)
            {
                <span><strong>@oemRows.Count</strong> OEMs · <strong>@oemRows.Sum(o => o.VariantCount)</strong> variantes en total</span>
            }
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando...</p>
        }
        else if (oemRows is null || !oemRows.Any())
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay productos con OEM cargado todavía. Cargá productos por OEM desde Inventarios → Importar precios por OEM.</p>
        }
        else
        {
            <div style="display: flex; gap: 0.6rem; padding: 0.7rem 1rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
                <input type="text" class="form-input" style="flex: 1; max-width: 320px;"
                       @bind="searchTerm" @bind:event="oninput"
                       placeholder="Buscar por OEM, título o marca..." />
                <select class="form-input" style="max-width: 200px;" @bind="brandFilter">
                    <option value="">Todas las marcas</option>
                    @foreach (var b in oemRows.Where(o => !string.IsNullOrEmpty(o.Brand)).Select(o => o.Brand).Distinct().OrderBy(b => b))
                    {
                        <option value="@b">@b</option>
                    }
                </select>
                <select class="form-input" style="max-width: 180px;" @bind="variantsFilter">
                    <option value="all">Cualquier cantidad</option>
                    <option value="1">Con 1 variante</option>
                    <option value="2plus">Con 2+ variantes</option>
                </select>
            </div>

            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 110px;">OEM</th>
                            <th>Título genérico</th>
                            <th style="width: 140px;">Marca</th>
                            <th style="width: 100px; text-align: center;">Variantes</th>
                            <th style="width: 130px; text-align: right;">Costo s/IVA</th>
                            <th style="width: 130px; text-align: right;">PVP c/IVA</th>
                            <th style="width: 110px; text-align: center;">Activos</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var oem in GetFilteredRows())
                        {
                            <tr>
                                <td>
                                    <span style="background: #16a34a; color: white; padding: 0.2rem 0.55rem; border-radius: 6px; font-weight: 800; font-family: monospace; font-size: 0.85rem;">@oem.OemCode</span>
                                </td>
                                <td>
                                    <strong>@oem.GenericTitle</strong>
                                    @if (oem.VariantCount > 1)
                                    {
                                        <div style="font-size: 0.72rem; color: #6b7280; margin-top: 0.2rem;">
                                            @string.Join(" · ", oem.VariantSkus.Take(6))
                                            @(oem.VariantSkus.Count > 6 ? $" +{oem.VariantSkus.Count - 6} más" : "")
                                        </div>
                                    }
                                </td>
                                <td style="font-size: 0.85rem; color: #6b7280;">@(string.IsNullOrEmpty(oem.Brand) ? "—" : oem.Brand)</td>
                                <td style="text-align: center;">
                                    <span style="background: #dcfce7; color: #15803d; padding: 0.15rem 0.55rem; border-radius: 999px; font-size: 0.78rem; font-weight: 700;">
                                        @oem.VariantCount
                                    </span>
                                </td>
                                <td style="text-align: right; font-weight: 600;">
                                    @if (oem.SharedCost.HasValue)
                                    {
                                        <span>$@FormatPrice(oem.SharedCost.Value)</span>
                                    }
                                    else
                                    {
                                        <span style="color: #9ca3af; font-size: 0.78rem;" title="Las variantes tienen costos distintos">varía</span>
                                    }
                                </td>
                                <td style="text-align: right; font-weight: 600;">
                                    @if (oem.SharedRetailWithVat.HasValue)
                                    {
                                        <span>$@FormatPrice(oem.SharedRetailWithVat.Value)</span>
                                    }
                                    else
                                    {
                                        <span style="color: #9ca3af; font-size: 0.78rem;" title="Las variantes tienen PVP distintos">varía</span>
                                    }
                                </td>
                                <td style="text-align: center;">
                                    @if (oem.ActiveCount == oem.VariantCount)
                                    {
                                        <span style="color: #15803d;">@oem.ActiveCount / @oem.VariantCount</span>
                                    }
                                    else if (oem.ActiveCount == 0)
                                    {
                                        <span style="color: #9ca3af;">0 / @oem.VariantCount</span>
                                    }
                                    else
                                    {
                                        <span style="color: #92400e;">@oem.ActiveCount / @oem.VariantCount</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-secondary btn-sm" @onclick="() => OpenInProducts(oem.OemCode)" title="Ver variantes en Productos">
                                        🔍 Ver variantes
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool isLoading = true;
    private List<OemRow>? oemRows;
    private string searchTerm = "";
    private string brandFilter = "";
    private string variantsFilter = "all";

    private class OemRow
    {
        public string OemCode { get; set; } = "";
        public string GenericTitle { get; set; } = "";
        public string Brand { get; set; } = "";
        public int VariantCount { get; set; }
        public int ActiveCount { get; set; }
        public List<string> VariantSkus { get; set; } = new();
        public decimal? SharedCost { get; set; }   // null si las variantes tienen distinto costo
        public decimal? SharedRetailWithVat { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadOems();
    }

    private async Task LoadOems()
    {
        isLoading = true;
        try
        {
            var all = await Api.GetProductsAsync() ?? new();
            oemRows = all
                .Where(p => !string.IsNullOrEmpty(p.OemCode))
                .GroupBy(p => p.OemCode!.Trim())
                .Select(g => {
                    var first = g.First();
                    var costs = g.Select(p => p.CostPrice).Distinct().ToList();
                    var pvpsWithVat = g.Select(p => Math.Round(p.RetailPrice * (1m + (p.VatRate ?? 0m) / 100m), 2)).Distinct().ToList();
                    var firstTitle = first.Title ?? "";
                    // Sacar la parte despues del ultimo guion para tener el titulo "generico" sin color
                    var dashIdx = firstTitle.LastIndexOf('-');
                    var genericTitle = dashIdx > 5 ? firstTitle.Substring(0, dashIdx).Trim() : firstTitle;
                    return new OemRow
                    {
                        OemCode = g.Key,
                        GenericTitle = genericTitle,
                        Brand = first.Brand ?? first.BrandName ?? "",
                        VariantCount = g.Count(),
                        ActiveCount = g.Count(p => p.IsActive),
                        VariantSkus = g.Select(p => p.Sku ?? "").Where(s => !string.IsNullOrEmpty(s)).OrderBy(s => s).ToList(),
                        SharedCost = costs.Count == 1 ? costs[0] : null,
                        SharedRetailWithVat = pvpsWithVat.Count == 1 ? pvpsWithVat[0] : null,
                    };
                })
                .OrderBy(o => o.OemCode)
                .ToList();
        }
        catch (Exception ex) { ToastService.Error("Error cargando OEMs: " + ex.Message); oemRows = new(); }
        finally { isLoading = false; }
    }

    private List<OemRow> GetFilteredRows()
    {
        if (oemRows is null) return new();
        var result = oemRows.AsEnumerable();
        if (!string.IsNullOrEmpty(searchTerm))
        {
            var s = searchTerm.ToLower();
            result = result.Where(o =>
                o.OemCode.ToLower().Contains(s) ||
                o.GenericTitle.ToLower().Contains(s) ||
                (o.Brand ?? "").ToLower().Contains(s) ||
                o.VariantSkus.Any(sk => sk.ToLower().Contains(s)));
        }
        if (!string.IsNullOrEmpty(brandFilter))
            result = result.Where(o => o.Brand == brandFilter);
        if (variantsFilter == "1") result = result.Where(o => o.VariantCount == 1);
        else if (variantsFilter == "2plus") result = result.Where(o => o.VariantCount >= 2);
        return result.ToList();
    }

    private void OpenInProducts(string oemCode)
    {
        // Navegar a Productos con un query param que indique filtrar por OEM
        Navigation.NavigateTo($"/productos?oem={Uri.EscapeDataString(oemCode)}");
    }

    private string FormatPrice(decimal value)
    {
        var parts = value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture).Split('.');
        var sign = ""; var intPart = parts[0]; var decPart = parts.Length > 1 ? parts[1] : "00";
        if (intPart.StartsWith("-")) { sign = "-"; intPart = intPart[1..]; }
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) sb.Append('.');
            sb.Append(intPart[i]);
        }
        return sign + sb + "," + decPart;
    }
}
