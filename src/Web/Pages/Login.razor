@page "/login"
@layout LoginLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject ApiClient Api
@inject BrandSettingsService BrandSettings
@inject OperatorService Operator

<div class="login-card" role="main">
    <div class="login-header" style="@HeaderStyle">
        <div class="login-logo" aria-hidden="true">
            @if (BrandSettings.HasCustomLogo)
            {
                <img src="@BrandSettings.BrandLogo" alt="Logo" class="login-logo-img" />
            }
            else
            {
                @SvgIcons.GetByName(BrandSettings.BrandIcon)
            }
        </div>
        <h1>@BrandSettings.BrandName</h1>
        <p>Panel de administracion</p>
    </div>

    <div class="login-body">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="login-error visible" role="alert">
                @SvgIcons.AlertCircle
                <span>@errorMessage</span>
            </div>
        }

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
            <div class="form-group">
                <label class="form-label" for="username">Usuario</label>
                <InputText class="form-input" id="username" @bind-Value="loginModel.Username"
                           placeholder="Ingresa tu usuario" autocomplete="username" />
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Contrasena</label>
                <InputText class="form-input" id="password" @bind-Value="loginModel.Password"
                           type="password" placeholder="Ingresa tu contrasena" autocomplete="current-password" />
            </div>

            <button type="submit" class="login-btn" disabled="@isLoading">
                @(isLoading ? "Ingresando..." : "Iniciar Sesion")
            </button>
        </EditForm>
    </div>

</div>

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool isLoading;

    private string HeaderStyle => $"background: linear-gradient(135deg, {BrandSettings.PrimaryColor}, {BrandSettings.SidebarBgColor});";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                BrandSettings.LoadFromSettings(settings);
            }
        }
        catch { }

        if (await AuthService.IsSessionValidAsync())
        {
            Navigation.NavigateTo("/");
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "Completa todos los campos";
            return;
        }

        isLoading = true;

        try
        {
            await AuthService.LoginAsync(loginModel.Username, loginModel.Password);
            // 2026-06-25: cada login fresco vuelve a pedir PIN, aunque el navegador
            // tenga una marca reciente. Sin esto, si dos personas comparten la PC
            // y la segunda entra dentro de los 60 min, queda como el operador anterior.
            await Operator.LockAsync();
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
        }
    }
}
