@page "/combos"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
        <h3>Combos (@(filteredCombos?.Count ?? 0))</h3>
        <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.85rem; color: #374151;">
                <span>Marca:</span>
                <select class="form-input" style="font-size: 0.85rem; padding: 0.3rem 0.5rem; min-width: 160px;" @bind="filterBrandId">
                    <option value="0">— Todas —</option>
                    @if (brands is not null)
                    {
                        @foreach (var b in brands.Where(x => x.IsActive).OrderBy(x => x.Name))
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                </select>
            </label>
            <button class="btn btn-primary" @onclick="ShowCreateForm">+ Nuevo Combo</button>
            <button class="btn btn-primary" @onclick="() => showImport = true" title="Subir varios combos desde un Excel" style="background: #059669; border-color: #059669;">📤 Importar Excel</button>
        </div>
    </div>
    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando combos...</p>
        }
        else if (combos is null || combos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">Todavia no creaste ningun combo. Hace clic en "+ Nuevo Combo" para empezar.</p>
        }
        else if (filteredCombos is null || filteredCombos.Count == 0)
        {
            <p class="text-muted" style="padding: 1.5rem;">No hay combos para la marca seleccionada. Tocá "— Todas —" para verlos todos.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>SKU</th>
                            <th>Productos</th>
                            <th style="text-align: right;" title="Suma de los productos del combo, con IVA aplicado">Subtotal C/IVA</th>
                            <th>Precio</th>
                            <th style="text-align: right;" title="Precio final del combo, con IVA aplicado">Precio Final C/IVA</th>
                            <th>Estado</th>
                            <th style="width: 130px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in filteredCombos!)
                        {
                            <tr>
                                <td><strong>@c.Name</strong></td>
                                <td style="font-size: 0.85rem; color: #6b7280;">@(c.Sku ?? "")</td>
                                <td style="font-size: 0.85rem;">
                                    @c.Items.Count item(s)
                                    <div style="color: #6b7280; font-size: 0.75rem;">
                                        @string.Join(", ", c.Items.Take(3).Select(i => $"{i.Quantity}× {Trim(i.ProductTitle, 25)}"))
                                        @(c.Items.Count > 3 ? "..." : "")
                                    </div>
                                </td>
                                <td style="text-align: right; color: #6b7280;" title="Sin IVA: $@FormatPrice(c.SubtotalProductos)">$@FormatPrice(c.SubtotalProductosWithVat)</td>
                                <td>@PriceModeLabel(c.PriceMode, c.PercentAdjustment)</td>
                                <td style="text-align: right; font-weight: 700;" title="Sin IVA: $@FormatPrice(c.FinalPrice)">$@FormatPrice(c.FinalPriceWithVat)</td>
                                <td>
                                    <span class="status-badge @(c.IsActive ? "status-active" : "status-inactive")">
                                        @(c.IsActive ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="actions-cell">
                                    <button class="btn-icon btn-edit" @onclick="() => ShowEditForm(c)" title="Editar">@SvgIcons.Edit</button>
                                    <button class="btn-icon" style="background:#fef3c7;color:#92400e;border:1px solid #fbbf24;padding:2px 6px;border-radius:4px;font-size:0.7rem;font-weight:700;"
                                            @onclick="() => ShowCloneForm(c)" title="Crear similar (duplica este combo como uno nuevo)">⎘ Similar</button>
                                    <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(c)" title="Eliminar">@SvgIcons.AlertCircle</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-card modal-wide" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>@(isEditing ? "Editar Combo" : "Nuevo Combo")</h3>
                <button class="btn-close" @onclick="CloseForm">&times;</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="form-error">@formError</div>
                }

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Nombre del combo *</label>
                        <input class="form-input" @bind="formName" placeholder="Ej: Pack escolar 3 unidades" autofocus />
                    </div>
                    <div class="form-group">
                        <label class="form-label">SKU</label>
                        <input class="form-input" @bind="formSku" placeholder="Codigo del combo" />
                        @if (!isEditing)
                        {
                            <p style="font-size: 0.72rem; color: #6b7280; margin: 0.2rem 0 0;">
                                Sugerido automaticamente. Podes cambiarlo si queres.
                            </p>
                        }
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Descripcion</label>
                    <textarea class="form-input" @bind="formDescription" rows="2" placeholder="Que incluye este combo (opcional)"></textarea>
                </div>

                <hr style="margin: 1rem 0; border: none; border-top: 1px solid #e5e7eb;" />

                <h4 style="margin: 0 0 0.6rem; font-size: 0.95rem;">Productos del combo</h4>

                @if (formItems.Count == 0)
                {
                    <p style="color: #6b7280; font-size: 0.85rem; margin: 0 0 0.5rem;">
                        Todavia no agregaste productos. Elegi uno abajo y tocá <strong>Agregar</strong>.
                    </p>
                }
                else
                {
                    <table class="data-table" style="margin-bottom: 0.75rem;">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th style="width: 100px; text-align: center;">Cantidad</th>
                                <th style="text-align: right; width: 120px;" title="PVP del producto con IVA aplicado">PVP unit. C/IVA</th>
                                <th style="text-align: right; width: 120px;">Subtotal C/IVA</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in formItems)
                            {
                                var prod = availableProducts?.FirstOrDefault(p => p.Id == item.ProductId);
                                var unit = UnitWithVat(prod);
                                <tr>
                                    <td>
                                        <strong>@(prod?.Title ?? "(Producto eliminado)")</strong>
                                        @if (!string.IsNullOrEmpty(prod?.Sku))
                                        {
                                            <span style="color: #6b7280; font-size: 0.75rem;"> · @prod.Sku</span>
                                        }
                                    </td>
                                    <td style="text-align: center;">
                                        <input type="number" min="1" value="@item.Quantity"
                                               @onchange="@((ChangeEventArgs e) => UpdateQty(item, e.Value?.ToString()))"
                                               style="width: 70px; text-align: right; border: 1px solid #d1d5db; border-radius: 4px; padding: 0.25rem 0.4rem;" />
                                    </td>
                                    <td style="text-align: right; color: #6b7280;" title="Sin IVA: $@FormatPrice(prod?.RetailPrice ?? 0m)">$@FormatPrice(unit)</td>
                                    <td style="text-align: right; font-weight: 600;">$@FormatPrice(unit * item.Quantity)</td>
                                    <td style="text-align: center;">
                                        <button class="btn-icon btn-delete" @onclick="() => RemoveItem(item)" title="Quitar">×</button>
                                    </td>
                                </tr>
                            }
                            <tr>
                                <td colspan="3" style="text-align: right; font-weight: 600;">Subtotal productos C/IVA:</td>
                                <td style="text-align: right; font-weight: 700; font-size: 1rem;" title="Sin IVA: $@FormatPrice(SubtotalFormItems)">$@FormatPrice(SubtotalFormItemsWithVat)</td>
                                <td></td>
                            </tr>
                        </tbody>
                    </table>
                }

                @* Selector para agregar producto *@
                <div class="form-row" style="align-items: flex-end;">
                    <div class="form-group" style="flex: 3;">
                        <label class="form-label">Agregar producto</label>
                        <select class="form-input" @bind="addProductId">
                            <option value="0">— Elegi un producto —</option>
                            @if (availableProducts is not null)
                            {
                                @foreach (var p in availableProducts.Where(x => !formItems.Any(i => i.ProductId == x.Id)))
                                {
                                    <option value="@p.Id">@(p.Sku ?? "—") · @p.Title — $@FormatPrice(UnitWithVat(p)) c/IVA</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Cantidad</label>
                        <input class="form-input" type="number" min="1" @bind="addProductQty" />
                    </div>
                    <div class="form-group" style="flex: 0;">
                        <button class="btn btn-secondary" @onclick="AddItem" disabled="@(addProductId == 0)" style="white-space: nowrap;">+ Agregar</button>
                    </div>
                </div>

                <hr style="margin: 1rem 0; border: none; border-top: 1px solid #e5e7eb;" />

                @* Modo de precio *@
                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: 600; cursor: pointer;">
                        <input type="checkbox" checked="@autoPrice" @onchange="@((ChangeEventArgs e) => OnAutoPriceChanged(e))" style="width: 18px; height: 18px;" />
                        Precio automatico (suma de los productos del combo)
                    </label>
                    <p style="font-size: 0.78rem; color: #6b7280; margin: 0.3rem 0 0 1.7rem;">
                        Si lo destildas, podes definir un precio fijo o un porcentaje de ajuste sobre la suma.
                    </p>
                </div>

                @if (autoPrice)
                {
                    <div style="background: #f3f4f6; border-radius: 6px; padding: 0.75rem 1rem; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <span style="color: #6b7280;">Precio final del combo (c/IVA):</span>
                        <strong style="font-size: 1.2rem;" title="Sin IVA: $@FormatPrice(SubtotalFormItems)">$@FormatPrice(SubtotalFormItemsWithVat)</strong>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <div style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                            <label style="cursor: pointer;">
                                <input type="radio" name="priceMode" value="manual" checked="@(formPriceMode == "manual")"
                                       @onchange='() => formPriceMode = "manual"' />
                                Precio fijo
                            </label>
                            <label style="cursor: pointer;">
                                <input type="radio" name="priceMode" value="percent" checked="@(formPriceMode == "percent")"
                                       @onchange='() => formPriceMode = "percent"' />
                                Ajuste por porcentaje
                            </label>
                        </div>

                        @if (formPriceMode == "manual")
                        {
                            <div style="display: flex; align-items: center; gap: 0.5rem; max-width: 280px;">
                                <span style="font-size: 1.1rem; font-weight: 700;">$</span>
                                <input type="text" class="form-input" style="font-size: 1.1rem; font-weight: 700; text-align: right;"
                                       value="@formManualPriceFormatted" @oninput="OnManualPriceInput" inputmode="decimal" />
                                <span style="font-size: 0.85rem; color: #6b7280;">sin IVA</span>
                            </div>
                            <p style="font-size: 0.78rem; color: #6b7280; margin: 0.3rem 0 0;">
                                Subtotal de productos: $@FormatPrice(SubtotalFormItemsWithVat) c/IVA · $@FormatPrice(SubtotalFormItems) s/IVA
                            </p>
                        }
                        else if (formPriceMode == "percent")
                        {
                            <div style="display: flex; align-items: center; gap: 0.5rem; max-width: 280px;">
                                <input type="number" class="form-input" step="0.1" @bind="formPercentAdjustment"
                                       style="font-size: 1.1rem; font-weight: 700; text-align: right;" />
                                <span style="font-size: 1.1rem; font-weight: 700;">%</span>
                            </div>
                            <p style="font-size: 0.78rem; color: #6b7280; margin: 0.3rem 0 0;">
                                Positivo aumenta, negativo descuenta. Subtotal c/IVA: $@FormatPrice(SubtotalFormItemsWithVat) → Final c/IVA: <strong>$@FormatPrice(ComputedPercentPriceWithVat)</strong>
                            </p>
                        }
                    </div>
                }

                @if (isEditing)
                {
                    <div class="form-group">
                        <label class="form-label">Estado</label>
                        <select class="form-input" @bind="formIsActive" style="max-width: 200px;">
                            <option value="@true">Activo</option>
                            <option value="@false">Inactivo</option>
                        </select>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm" disabled="@isSaving">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@isSaving">
                    @(isSaving ? "Guardando..." : (isEditing ? "Guardar" : "Crear"))
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm && comboToDelete is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #dc3545; color: white;">
                <h4 style="margin: 0;">Eliminar combo</h4>
                <button class="btn-close" @onclick="() => showDeleteConfirm = false" style="color: white;">&times;</button>
            </div>
            <div class="modal-body">
                <p>Estas seguro que queres eliminar el combo <strong>@comboToDelete.Name</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">Esta accion no se puede deshacer. Los productos que componen el combo no se borran.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="Delete">Eliminar</button>
            </div>
        </div>
    </div>
}

<BulkImportModal @bind-Visible="showImport"
                 EntityNameSingular="combo"
                 EntityNamePlural="combos"
                 TemplateUrl="/api/combos/import-template"
                 TemplateFileName="combos-template.xlsx"
                 ImportUrl="/api/combos/bulk-import"
                 OnImported="LoadData" />

@code {
    private bool showImport;
    private List<ComboDto>? combos;
    private List<ProductDto>? availableProducts;
    private List<BrandDto>? brands;
    // 0 = Todas. >0 = id de la marca. Filtra los combos cuyos items tienen esa marca.
    private int filterBrandId;
    // Mapeo productId -> brandId construido desde los productos cargados.
    private Dictionary<int, int?> productBrandMap = new();

    private List<ComboDto>? filteredCombos
    {
        get
        {
            if (combos is null) return null;
            if (filterBrandId <= 0) return combos;
            return combos.Where(c =>
                c.Items.Any(i => productBrandMap.TryGetValue(i.ProductId, out var brandId) && brandId == filterBrandId)
            ).ToList();
        }
    }
    private bool isLoading = true;
    private bool showForm;
    private bool isEditing;
    private bool isSaving;
    private string? formError;
    private int? editingId;

    // Form state
    private string formName = "";
    private string formSku = "";
    private string formDescription = "";
    private bool formIsActive = true;
    private List<ComboItemRequest> formItems = new();

    // Add product helpers
    private int addProductId;
    private int addProductQty = 1;

    // Price mode
    private bool autoPrice = true;
    private string formPriceMode = "manual"; // cuando autoPrice=false: "manual" | "percent"
    private decimal formManualPrice;
    private string formManualPriceFormatted = "0,00";
    private decimal formPercentAdjustment;

    // Delete
    private bool showDeleteConfirm;
    private ComboDto? comboToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        // Si vinieron con ?new=1, abrir el formulario de creacion automaticamente.
        var uri = new Uri(Navigation.Uri);
        if (uri.Query.Contains("new=1", StringComparison.OrdinalIgnoreCase))
        {
            await ShowCreateForm();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            combos = await Api.GetCombosAsync() ?? new();
        }
        catch { ToastService.Error("Error al cargar los combos"); combos = new(); }

        try
        {
            // Productos elegibles para combos: NO los productos base (que tienen derivados).
            var allProducts = await Api.GetProductsAsync() ?? new();
            availableProducts = allProducts.Where(p => p.DerivedCount == 0 && p.IsActive)
                .OrderBy(p => p.Title).ToList();
            // Mapeo TODOS los productos (no solo los activos) para que el filtro
            // siga funcionando aunque un item del combo apunte a un producto inactivo.
            productBrandMap = allProducts.ToDictionary(p => p.Id, p => p.BrandId);
        }
        catch { availableProducts = new(); productBrandMap = new(); }

        try { brands = await Api.GetBrandsAsync() ?? new(); } catch { brands = new(); }

        isLoading = false;
    }

    private async Task ShowCreateForm()
    {
        isEditing = false; editingId = null;
        formName = ""; formSku = ""; formDescription = "";
        formIsActive = true;
        formItems = new();
        autoPrice = true;
        formPriceMode = "manual";
        formManualPrice = 0; formManualPriceFormatted = "0,00";
        formPercentAdjustment = 0;
        addProductId = 0; addProductQty = 1;
        formError = null; showForm = true;

        // Pedir SKU sugerido al backend (no bloqueante).
        try
        {
            var suggested = await Api.GetNextComboSkuAsync();
            if (!string.IsNullOrEmpty(suggested))
            {
                formSku = suggested;
                StateHasChanged();
            }
        }
        catch { /* dejar vacio si falla, el backend tambien lo genera al crear */ }
    }

    private void ShowEditForm(ComboDto c)
    {
        isEditing = true; editingId = c.Id;
        formName = c.Name; formSku = c.Sku ?? ""; formDescription = c.Description ?? "";
        formIsActive = c.IsActive;
        formItems = c.Items.Select(i => new ComboItemRequest { ProductId = i.ProductId, Quantity = i.Quantity }).ToList();
        autoPrice = c.PriceMode == "auto";
        formPriceMode = c.PriceMode == "auto" ? "manual" : c.PriceMode;
        formManualPrice = c.ManualPrice ?? 0;
        formManualPriceFormatted = FormatPrice(formManualPrice);
        formPercentAdjustment = c.PercentAdjustment ?? 0;
        addProductId = 0; addProductQty = 1;
        formError = null; showForm = true;
    }

    // Clona un combo: precarga el form con los items y configuracion de precios
    // pero como combo NUEVO. Limpia identificadores unicos (SKU se regenera).
    private void ShowCloneForm(ComboDto c)
    {
        isEditing = false; editingId = null;
        formName = c.Name + " (copia)";
        formSku = ""; // SKU unico, se regenera al guardar
        formDescription = c.Description ?? "";
        formIsActive = true;
        formItems = c.Items.Select(i => new ComboItemRequest { ProductId = i.ProductId, Quantity = i.Quantity }).ToList();
        autoPrice = c.PriceMode == "auto";
        formPriceMode = c.PriceMode == "auto" ? "manual" : c.PriceMode;
        formManualPrice = c.ManualPrice ?? 0;
        formManualPriceFormatted = FormatPrice(formManualPrice);
        formPercentAdjustment = c.PercentAdjustment ?? 0;
        addProductId = 0; addProductQty = 1;
        formError = null; showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private void AddItem()
    {
        if (addProductId == 0) return;
        if (addProductQty < 1) addProductQty = 1;
        if (formItems.Any(i => i.ProductId == addProductId)) return;
        formItems.Add(new ComboItemRequest { ProductId = addProductId, Quantity = addProductQty });
        addProductId = 0; addProductQty = 1;
    }

    private void RemoveItem(ComboItemRequest item)
    {
        formItems.Remove(item);
    }

    private void UpdateQty(ComboItemRequest item, string? raw)
    {
        if (int.TryParse(raw, out var q) && q >= 1)
            item.Quantity = q;
    }

    private void OnAutoPriceChanged(ChangeEventArgs e)
    {
        autoPrice = e.Value is bool b && b;
        if (!autoPrice && string.IsNullOrEmpty(formPriceMode))
            formPriceMode = "manual";
    }

    private void OnManualPriceInput(ChangeEventArgs e)
    {
        formManualPriceFormatted = FormatPriceInput(e.Value?.ToString() ?? "");
        formManualPrice = ParseFormattedPrice(formManualPriceFormatted);
    }

    private decimal SubtotalFormItems
    {
        get
        {
            decimal sum = 0;
            foreach (var item in formItems)
            {
                var p = availableProducts?.FirstOrDefault(x => x.Id == item.ProductId);
                if (p is not null) sum += p.RetailPrice * item.Quantity;
            }
            return sum;
        }
    }

    private decimal SubtotalFormItemsWithVat
    {
        get
        {
            decimal sum = 0;
            foreach (var item in formItems)
            {
                var p = availableProducts?.FirstOrDefault(x => x.Id == item.ProductId);
                if (p is not null) sum += UnitWithVat(p) * item.Quantity;
            }
            return sum;
        }
    }

    // PVP unitario con IVA aplicado. Si el producto no tiene VatRate cargado, se asume 0% (no se infla).
    private static decimal UnitWithVat(ProductDto? p)
    {
        if (p is null) return 0m;
        var rate = (p.VatRate ?? 0m) / 100m;
        return Math.Round(p.RetailPrice * (1m + rate), 2);
    }

    private decimal ComputedPercentPrice =>
        Math.Round(SubtotalFormItems * (1m + formPercentAdjustment / 100m), 2);

    private decimal ComputedPercentPriceWithVat =>
        Math.Round(SubtotalFormItemsWithVat * (1m + formPercentAdjustment / 100m), 2);

    private async Task Save()
    {
        formError = null;
        if (string.IsNullOrWhiteSpace(formName)) { formError = "El nombre es obligatorio"; return; }
        if (formItems.Count == 0) { formError = "Agrega al menos un producto al combo"; return; }

        var priceMode = autoPrice ? "auto" : formPriceMode;
        decimal? manualPrice = priceMode == "manual" ? formManualPrice : (decimal?)null;
        decimal? percent = priceMode == "percent" ? formPercentAdjustment : (decimal?)null;

        isSaving = true;
        try
        {
            if (isEditing && editingId.HasValue)
            {
                var updated = await Api.UpdateComboAsync(editingId.Value, new UpdateComboRequest
                {
                    Name = formName, Sku = formSku, Description = formDescription,
                    PriceMode = priceMode, ManualPrice = manualPrice, PercentAdjustment = percent,
                    IsActive = formIsActive, Items = formItems
                });
                if (updated is null) { formError = "No se pudo actualizar"; return; }
                ToastService.Success("Combo actualizado");
            }
            else
            {
                var created = await Api.CreateComboAsync(new CreateComboRequest
                {
                    Name = formName, Sku = formSku, Description = formDescription,
                    PriceMode = priceMode, ManualPrice = manualPrice, PercentAdjustment = percent,
                    Items = formItems
                });
                if (created is null) { formError = "No se pudo crear"; return; }
                ToastService.Success("Combo creado");
            }
            showForm = false;
            await LoadData();
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSaving = false; }
    }

    private void ConfirmDelete(ComboDto c) { comboToDelete = c; showDeleteConfirm = true; }

    private async Task Delete()
    {
        if (comboToDelete is null) return;
        try
        {
            var ok = await Api.DeleteComboAsync(comboToDelete.Id);
            if (ok) { ToastService.Success("Combo eliminado"); await LoadData(); }
            else { ToastService.Error("No se pudo eliminar"); }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { showDeleteConfirm = false; comboToDelete = null; }
    }

    // --- Helpers de formato ---

    private static string PriceModeLabel(string mode, decimal? percent) => mode switch
    {
        "manual" => "Manual",
        "percent" => $"{(percent >= 0 ? "+" : "")}{percent?.ToString("0.##")}%",
        _ => "Automatico"
    };

    private static string Trim(string s, int max) => s.Length <= max ? s : s.Substring(0, max - 1) + "…";

    private string FormatPrice(decimal value)
    {
        var parts = value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture).Split('.');
        var intPart = parts[0]; var decPart = parts.Length > 1 ? parts[1] : "00";
        var sign = "";
        if (intPart.StartsWith("-")) { sign = "-"; intPart = intPart[1..]; }
        var formatted = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) formatted.Append('.');
            formatted.Append(intPart[i]);
        }
        return sign + formatted + "," + decPart;
    }

    private decimal ParseFormattedPrice(string formatted)
    {
        if (string.IsNullOrWhiteSpace(formatted)) return 0;
        var clean = formatted.Replace(".", "").Replace(",", ".");
        return decimal.TryParse(clean, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v) ? v : 0;
    }

    private string FormatPriceInput(string raw)
    {
        if (raw.EndsWith(".") && !raw.Contains(',')) raw = raw[..^1] + ",";
        else if (!raw.Contains(',') && raw.Count(c => c == '.') == 1)
        {
            var dotIdx = raw.IndexOf('.'); var afterDot = raw[(dotIdx + 1)..];
            if (afterDot.Length <= 2 && afterDot.All(char.IsDigit)) raw = raw[..dotIdx] + "," + afterDot;
        }
        var cleaned = new string(raw.Where(c => char.IsDigit(c) || c == ',').ToArray());
        var commaIdx = cleaned.IndexOf(',');
        string intPart, decPart;
        if (commaIdx >= 0)
        {
            intPart = cleaned[..commaIdx];
            decPart = new string(cleaned[(commaIdx + 1)..].Where(char.IsDigit).ToArray());
            if (decPart.Length > 2) decPart = decPart[..2];
        }
        else { intPart = cleaned; decPart = ""; }
        intPart = intPart.TrimStart('0');
        if (string.IsNullOrEmpty(intPart)) intPart = "0";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) sb.Append('.');
            sb.Append(intPart[i]);
        }
        return commaIdx >= 0 ? sb + "," + decPart : sb.ToString();
    }
}
