@page "/combos"
@attribute [Authorize]

<div class="view-header">
    <h2>Combos</h2>
    <p class="view-subtitle">Agrupaciones de productos base que se venden como un combo unico.</p>
</div>

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Combos</h3>
    </div>
    <div class="card-body">
        <div style="text-align: center; padding: 2.5rem 1rem; color: #6b7280;">
            <div style="font-size: 2rem; margin-bottom: 0.5rem;">📦</div>
            <h4 style="margin: 0 0 0.5rem; color: #374151;">Proximamente</h4>
            <p style="margin: 0; font-size: 0.9rem;">
                Aca vas a poder armar combos juntando varios productos base
                en una sola unidad de venta.
            </p>
        </div>
    </div>
</div>
