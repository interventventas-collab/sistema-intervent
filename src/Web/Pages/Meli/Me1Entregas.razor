@page "/meli/me1/entregas"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.6rem;">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
            <span style="display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 8px; background: #e6f1fb; color: #185fa5; font-size: 1.15rem;">🏎</span>
            <div>
                <h3 style="margin: 0; line-height: 1.1;">me1 · Entregas <span style="color: #9ca3af; font-weight: 500;">(@Visible.Count())</span></h3>
                <div style="font-size: 0.75rem; color: #9ca3af;">envios manuales de MercadoLibre</div>
            </div>
        </div>
        <button class="btn btn-secondary" @onclick="SyncFromMeli" disabled="@isSyncing" title="Trae envios ME1 nuevos desde MercadoLibre">
            @(isSyncing ? "Sincronizando..." : "🔄 Sincronizar con MeLi")
        </button>
    </div>

    @* 2026-06-08: importar un envío puntual por número de ORDEN MeLi cuando el sync masivo no la trae *@
    <div style="padding: 0.6rem 1rem; background: #fef3c7; border-bottom: 1px solid #fde68a; display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
        <span style="font-size: 0.85rem; color: #78350f; font-weight: 600;">🔍 ¿No aparece un envío?</span>
        <input type="text" class="form-input" style="flex: 1; min-width: 220px; max-width: 320px; padding: 0.4rem 0.6rem; font-size: 0.9rem; font-family: monospace;"
               @bind="importOrderId" @bind:event="oninput"
               placeholder="Pegá el N° de venta MeLi (ej: 2000016778633314)" />
        <button class="btn" style="background: #f59e0b; color: white; padding: 0.4rem 0.9rem; font-size: 0.85rem;"
                @onclick="ImportByOrderId" disabled="@(isImporting || string.IsNullOrWhiteSpace(importOrderId))"
                title="Va directo a MeLi, busca esa orden y trae el envío correspondiente">
            @(isImporting ? "Buscando..." : "📥 Traer del MeLi")
        </button>
        @if (!string.IsNullOrEmpty(importMessage))
        {
            <span style="font-size: 0.82rem; color: @(importOk ? "#166534" : "#b91c1c"); padding: 0.3rem 0.5rem; background: @(importOk ? "#dcfce7" : "#fee2e2"); border-radius: 6px;">
                @importMessage
            </span>
        }
    </div>

    @* 2026-07-08: buscador (venta, envio, comprador, direccion) — filtra al instante, del lado del navegador. *@
    <div style="padding: 0.8rem 1rem 0.4rem;">
        <div style="position: relative; max-width: 520px;">
            <span style="position: absolute; left: 0.7rem; top: 50%; transform: translateY(-50%); color: #9ca3af;">🔎</span>
            <input type="text" class="form-input" style="width: 100%; padding: 0.55rem 0.6rem 0.55rem 2.1rem; font-size: 0.9rem;"
                   @bind="searchText" @bind:event="oninput"
                   placeholder="Buscar por N° de venta, N° de envío, comprador o dirección…" />
            @if (!string.IsNullOrWhiteSpace(searchText))
            {
                <button @onclick="@(() => searchText = "")" title="Limpiar"
                        style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); border: none; background: transparent; color: #9ca3af; cursor: pointer; font-size: 1rem;">✕</button>
            }
        </div>
    </div>

    @* 2026-07-08: filtros como chips con contador + el nuevo "En camino" *@
    <div style="display: flex; gap: 0.5rem; padding: 0.6rem 1rem 0.9rem; flex-wrap: wrap; border-bottom: 1px solid #eef0f2;">
        @foreach (var c in Chips)
        {
            var active = filter == c.Key;
            <button @onclick="@(() => SetFilter(c.Key))"
                    style="display: inline-flex; align-items: center; gap: 0.45rem; font-size: 0.82rem; padding: 0.4rem 0.8rem; border-radius: 999px; cursor: pointer;
                           background: @(active ? c.Bg : "#fff");
                           border: @(active ? $"1.5px solid {c.Border}" : "1px solid #e5e7eb");
                           color: @(active ? c.Txt : "#6b7280"); font-weight: @(active ? "600" : "500");">
                <span style="width: 8px; height: 8px; border-radius: 50%; background: @c.Dot;"></span>
                @c.Label <b style="font-weight: 600;">@c.Count</b>
            </button>
        }
    </div>

    <div class="card-body" style="padding: 0;">
        @if (isLoading)
        {
            <p class="text-muted" style="padding: 1.5rem;">Cargando envios ME1...</p>
        }
        else if (!Visible.Any())
        {
            <div style="padding: 1.8rem 1.5rem; text-align: center; color: #6b7280;">
                @if (!string.IsNullOrWhiteSpace(searchText))
                {
                    <p style="margin: 0;">No hay envios que coincidan con <b>"@searchText"</b>.</p>
                    <p style="font-size: 0.85rem; margin: 0.4rem 0 0;">Probá con otro dato, o buscá el N° de venta en el recuadro amarillo de arriba.</p>
                }
                else
                {
                    <p style="margin: 0 0 0.4rem;">No hay envios ME1 con este filtro.</p>
                    <p style="font-size: 0.85rem; margin: 0;">El sistema los trae solo cada hora. Tambien podés apretar <b>"Sincronizar con MeLi"</b>.</p>
                }
            </div>
        }
        else
        {
            @foreach (var s in Visible)
            {
                var isFinal = s.Status == "delivered" || s.Status == "not_delivered" || s.Status == "cancelled";
                var (bBg, bTxt, bLabel) = BadgeStyle(s);
                var rowBg = s.Status switch
                {
                    "delivered" => "#f7fdf9",
                    "not_delivered" => "#fdf6f6",
                    _ => "#fff"
                };
                <div style="display: flex; gap: 0.9rem; align-items: flex-start; padding: 0.85rem 1rem; border-bottom: 1px solid #f1f2f4; background: @rowBg;">
                    <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 50%; background: #e6f1fb; color: #185fa5; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 600;">
                        @Initials(s)
                    </div>

                    <div style="flex: 1; min-width: 0;">
                        <div style="font-size: 0.9rem; font-weight: 600; color: #111827;">@(s.ReceiverName ?? s.BuyerNickname ?? "—")</div>
                        @if (!string.IsNullOrWhiteSpace(s.BuyerNickname))
                        {
                            <div style="font-size: 0.72rem; color: #1d4ed8; font-family: monospace;">👤 @s.BuyerNickname</div>
                        }
                        <div style="font-size: 0.8rem; color: #6b7280; margin-top: 0.1rem;">
                            @(s.ItemsSummary ?? "—")@(string.IsNullOrWhiteSpace(s.AddressLine) ? "" : $" · {s.AddressLine}, {s.City}")
                        </div>
                        <div style="font-size: 0.7rem; color: #9ca3af; font-family: monospace; margin-top: 0.15rem;">
                            @if (s.MeliOrderId.HasValue)
                            {
                                <span>Venta #@s.MeliOrderId · </span>
                            }
                            Envío #@s.MeliShipmentId
                            @if (s.DateShipped.HasValue)
                            {
                                <span> · Despachado @s.DateShipped.Value.ToArTime().ToString("dd/MM HH:mm")</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(s.TrackingNumber))
                            {
                                <span> · Tracking @s.TrackingNumber</span>
                            }
                        </div>

                        @* Asignacion de repartidor (solo si no esta finalizado) o quien entrego *@
                        @if (!isFinal)
                        {
                            <div style="margin-top: 0.4rem; display: flex; align-items: center; gap: 0.3rem;">
                                <span style="font-size: 0.72rem; color: #6b7280;">🚚</span>
                                <select class="form-input" style="padding: 0.2rem 0.35rem; font-size: 0.78rem; max-width: 190px;"
                                        value="@(s.RepartidorAsignadoId?.ToString() ?? "")"
                                        @onchange="@(e => OnRepartidorChange(s, e.Value?.ToString()))"
                                        disabled="@(busyAsig == s.Id)">
                                    <option value="">— Asignar repartidor —</option>
                                    @foreach (var r in repartidores)
                                    {
                                        <option value="@r.Id">@r.Nombre</option>
                                    }
                                </select>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(s.EntregadoPorRepartidorNombre))
                        {
                            <div style="margin-top: 0.35rem; font-size: 0.75rem; color: #15803d;">
                                ✅ Entregó @s.EntregadoPorRepartidorNombre
                            </div>
                        }
                    </div>

                    <div style="flex-shrink: 0; text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 0.35rem; min-width: 150px;">
                        <div style="font-size: 0.95rem; font-weight: 700; color: #111827;">
                            @(s.OrderTotal.HasValue ? $"${s.OrderTotal.Value:N0}" : "—")
                        </div>
                        <span style="display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.76rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 999px; background: @bBg; color: @bTxt;">
                            @bLabel@(isFinal ? " · final" : "")
                        </span>
                        @if (!isFinal)
                        {
                            <select class="form-input" style="padding: 0.3rem 0.4rem; font-size: 0.8rem; max-width: 190px;"
                                    value=""
                                    @onchange="@(e => OnStateChange(s, e.Value?.ToString()))"
                                    disabled="@(busyRow == s.Id)">
                                <option value="">— Cambiar estado… —</option>
                                @if (CurrentKey(s) != "shipped|null")
                                {
                                    <option value="shipped|null">📦 Marcar Despachado</option>
                                }
                                @if (CurrentKey(s) != "shipped|out_for_delivery")
                                {
                                    <option value="shipped|out_for_delivery">🚚 Salio a entregar</option>
                                }
                                <option value="delivered|null">✅ Marcar Entregado (final)</option>
                                <option value="not_delivered|returning_to_sender">❌ No entregado (final)</option>
                            </select>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@* Modal de confirmacion antes de mandar el cambio a MeLi *@
@if (pendingChange is not null)
{
    var p = pendingChange;
    var isIrreversible = p.NewStatus == "delivered" || p.NewStatus == "not_delivered";
    <div class="modal-overlay" @onclick="CancelChange">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: @(isIrreversible ? "#fef2f2" : "whitesmoke");">
                <h4 style="margin: 0;">@(isIrreversible ? "⚠ Cambio irreversible" : "Confirmar cambio")</h4>
                <button class="btn-close" @onclick="CancelChange">&times;</button>
            </div>
            <div class="modal-body">
                <p style="margin: 0 0 0.6rem; font-size: 0.9rem;">
                    Vas a marcar el envio en MeLi como:
                </p>
                <p style="font-size: 1.05rem; font-weight: 700; padding: 0.6rem; background: #f3f4f6; border-radius: 6px; text-align: center; margin: 0 0 0.8rem;">
                    @StatusLabel(p.NewStatus, p.NewSubstatus)
                </p>
                @if (isIrreversible)
                {
                    <p style="color: #b91c1c; font-size: 0.85rem; margin: 0 0 0.6rem; font-weight: 600;">
                        ⚠ Este cambio NO se puede deshacer. MeLi lo va a tomar como definitivo.
                    </p>
                }
                <div class="form-group" style="margin-bottom: 0.6rem;">
                    <label class="form-label">Comentario (opcional)</label>
                    <input class="form-input" @bind="commentInput" placeholder="ej: entregado a Juan en mano" />
                </div>
                @if (p.NewStatus == "shipped")
                {
                    <div class="form-group">
                        <label class="form-label">Numero de tracking / remito (opcional)</label>
                        <input class="form-input" @bind="trackingInput" placeholder="@(p.Ship.TrackingNumber ?? "OP123...")" />
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CancelChange" disabled="@isSubmitting">Cancelar</button>
                <button class="btn @(isIrreversible ? "btn-danger" : "btn-primary")" @onclick="ConfirmChange" disabled="@isSubmitting">
                    @(isSubmitting ? "Procesando..." : isIrreversible ? "Si, marcar igual" : "Confirmar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    // 2026-07-08: la pantalla se trae TODAS las ME1 una vez (allShipments) y filtra en el navegador
    // (estado + buscador). La lista es chica, asi que es instantaneo y no recarga.
    private List<MeliMe1ShipmentDto> allShipments = new();
    private bool isLoading = true;
    private bool isSyncing = false;
    private string filter = "todos";
    private string searchText = "";
    private int? busyRow;

    // 2026-06-17: asignacion de repartidor a envios ME1.
    private List<CafeRepartidorMiniDto> repartidores = new();
    private int? busyAsig;
    public record CafeRepartidorMiniDto(int Id, string Nombre);

    private class PendingChange
    {
        public MeliMe1ShipmentDto Ship { get; set; } = default!;
        public string NewStatus { get; set; } = "";
        public string? NewSubstatus { get; set; }
    }
    private PendingChange? pendingChange;
    private bool isSubmitting;
    private string commentInput = "";
    private string trackingInput = "";

    private static bool EsPendiente(MeliMe1ShipmentDto s)
        => s.Status != "delivered" && s.Status != "not_delivered" && s.Status != "cancelled";

    // Contadores por estado (para los chips)
    private int countTotal => allShipments.Count;
    private int countPendientes => allShipments.Count(EsPendiente);
    private int countEnCamino => allShipments.Count(s => s.Status == "shipped");
    private int countEntregados => allShipments.Count(s => s.Status == "delivered");
    private int countNoEntregados => allShipments.Count(s => s.Status == "not_delivered");

    // Definicion de los chips de filtro (clave, etiqueta, color del punto, y colores cuando esta activo)
    private record ChipDef(string Key, string Label, string Dot, string Bg, string Border, string Txt, int Count);
    private IEnumerable<ChipDef> Chips => new[]
    {
        new ChipDef("todos", "Todos", "#185fa5", "#e6f1fb", "#85b7eb", "#0c447c", countTotal),
        new ChipDef("pendientes", "Pendientes", "#888780", "#f1efe8", "#b4b2a9", "#444441", countPendientes),
        new ChipDef("despachado", "En camino", "#ba7517", "#faeeda", "#ef9f27", "#854f0b", countEnCamino),
        new ChipDef("entregados", "Entregados", "#639922", "#eaf3de", "#97c459", "#3b6d11", countEntregados),
        new ChipDef("no_entregados", "No entregados", "#e24b4a", "#fcebeb", "#f09595", "#a32d2d", countNoEntregados),
    };

    // Lista visible = filtro por estado + buscador
    private IEnumerable<MeliMe1ShipmentDto> Visible
    {
        get
        {
            IEnumerable<MeliMe1ShipmentDto> q = allShipments;
            q = filter switch
            {
                "pendientes" => q.Where(EsPendiente),
                "despachado" => q.Where(s => s.Status == "shipped"),
                "entregados" => q.Where(s => s.Status == "delivered"),
                "no_entregados" => q.Where(s => s.Status == "not_delivered"),
                _ => q
            };

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var t = searchText.Trim().ToLowerInvariant();
                bool Has(string? v) => !string.IsNullOrEmpty(v) && v.ToLowerInvariant().Contains(t);
                q = q.Where(s =>
                    (s.MeliOrderId?.ToString().Contains(t) ?? false) ||
                    s.MeliShipmentId.ToString().Contains(t) ||
                    Has(s.TrackingNumber) || Has(s.BuyerNickname) || Has(s.ReceiverName) ||
                    Has(s.AddressLine) || Has(s.City) || Has(s.ZipCode));
            }
            return q;
        }
    }

    private static string Initials(MeliMe1ShipmentDto s)
    {
        var name = s.ReceiverName ?? s.BuyerNickname ?? "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpperInvariant();
    }

    // Estilo del cartelito de estado (fondo, texto, etiqueta)
    private static (string bg, string txt, string label) BadgeStyle(MeliMe1ShipmentDto s) => s.Status switch
    {
        "delivered" => ("#eaf3de", "#3b6d11", "✅ Entregado"),
        "not_delivered" => ("#fcebeb", "#a32d2d", "❌ No entregado"),
        "cancelled" => ("#f1efe8", "#5f5e5a", "🚫 Cancelado"),
        "shipped" when s.Substatus == "out_for_delivery" => ("#faeeda", "#854f0b", "🚚 Salió a entregar"),
        "shipped" => ("#faeeda", "#854f0b", "📦 En camino"),
        "ready_to_ship" => ("#e6f1fb", "#185fa5", "📋 Listo p/ despachar"),
        "pending" => ("#e6f1fb", "#185fa5", "⏳ Pendiente"),
        _ => ("#f1efe8", "#5f5e5a", s.Status ?? "—")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadRepartidoresAsync();
        await LoadAsync();
    }

    private async Task LoadRepartidoresAsync()
    {
        try
        {
            var list = await Api.GetRepartidoresAsync();
            repartidores = (list ?? new())
                .Where(r => r.IsActive)
                .Select(r => new CafeRepartidorMiniDto(r.Id, r.Nombre))
                .ToList();
        }
        catch { /* silencioso — si falla, el dropdown queda vacio */ }
    }

    private async Task OnRepartidorChange(MeliMe1ShipmentDto s, string? value)
    {
        int? newRepId = int.TryParse(value, out var v) ? v : (int?)null;
        if (newRepId == s.RepartidorAsignadoId) return;
        busyAsig = s.Id;
        try
        {
            var ok = await Api.AsignarRepartidorMe1Async(s.Id, newRepId);
            if (ok)
            {
                s.RepartidorAsignadoId = newRepId;
                s.RepartidorAsignadoNombre = newRepId.HasValue ? repartidores.FirstOrDefault(r => r.Id == newRepId.Value)?.Nombre : null;
                ToastService.Success(newRepId.HasValue ? "✓ Repartidor asignado" : "✓ Asignación quitada");
            }
            else ToastService.Error("No se pudo asignar el repartidor");
        }
        catch (Exception ex) { ToastService.Error($"Error: {ex.Message}"); }
        finally { busyAsig = null; }
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        try
        {
            var list = await Api.GetMeliMe1ShipmentsAsync("todos");
            allShipments = list ?? new();
        }
        catch (Exception ex) { ToastService.Error($"Error cargando envios: {ex.Message}"); }
        finally { isLoading = false; }
    }

    private void SetFilter(string f)
    {
        filter = f;
    }

    private async Task SyncFromMeli()
    {
        isSyncing = true;
        try
        {
            var r = await Api.SyncMeliMe1ShipmentsAsync(45, 300);
            if (r is null) { ToastService.Error("No se pudo sincronizar con MeLi"); return; }
            ToastService.Success($"Sincronizacion lista: {r.TotalMe1} envios ME1 traidos");
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.Error($"Error sincronizando: {ex.Message}"); }
        finally { isSyncing = false; }
    }

    // 2026-06-08: importar un envío puntual por número de orden MeLi
    private string importOrderId = "";
    private bool isImporting = false;
    private string importMessage = "";
    private bool importOk = false;

    private async Task ImportByOrderId()
    {
        if (string.IsNullOrWhiteSpace(importOrderId)) return;
        isImporting = true;
        importMessage = "";
        try
        {
            var (ok, mensaje) = await Api.ImportMeliMe1ByOrderIdAsync(importOrderId.Trim());
            importOk = ok;
            importMessage = mensaje;
            if (ok)
            {
                ToastService.Success(mensaje);
                importOrderId = "";
                await LoadAsync();
            }
            else
            {
                ToastService.Error(mensaje);
            }
        }
        catch (Exception ex)
        {
            importOk = false;
            importMessage = $"Error: {ex.Message}";
            ToastService.Error(importMessage);
        }
        finally { isImporting = false; }
    }

    private static string CurrentKey(MeliMe1ShipmentDto s)
        => $"{s.Status ?? ""}|{s.Substatus ?? "null"}";

    private static string StatusLabel(string? status, string? substatus) => (status, substatus) switch
    {
        ("shipped", null) or ("shipped", "null") => "📦 Despachado",
        ("shipped", "out_for_delivery") => "🚚 Salio a entregar",
        ("delivered", _) => "✅ Entregado",
        ("not_delivered", _) => "❌ No entregado",
        ("cancelled", _) => "🚫 Cancelado",
        ("pending", _) => "⏳ Pendiente",
        ("ready_to_ship", _) => "📋 Listo p/ despachar",
        (null, _) => "—",
        _ => $"{status}/{substatus}"
    };

    private void OnStateChange(MeliMe1ShipmentDto s, string? selectedKey)
    {
        if (string.IsNullOrEmpty(selectedKey)) return;
        var parts = selectedKey.Split('|');
        if (parts.Length != 2) return;
        var newStatus = parts[0];
        var newSubstatus = parts[1] == "null" ? null : parts[1];

        // Si elige el estado actual, no hacer nada
        if (newStatus == s.Status && (newSubstatus ?? "null") == (s.Substatus ?? "null")) return;

        pendingChange = new PendingChange { Ship = s, NewStatus = newStatus, NewSubstatus = newSubstatus };
        commentInput = "";
        trackingInput = s.TrackingNumber ?? "";
    }

    private void CancelChange()
    {
        if (isSubmitting) return;
        pendingChange = null;
        commentInput = "";
        trackingInput = "";
    }

    private async Task ConfirmChange()
    {
        if (pendingChange is null) return;
        isSubmitting = true;
        busyRow = pendingChange.Ship.Id;
        try
        {
            var (ok, error) = await Api.SetMeliMe1ShipmentStatusAsync(
                pendingChange.Ship.Id,
                pendingChange.NewStatus,
                pendingChange.NewSubstatus,
                trackingNumber: string.IsNullOrWhiteSpace(trackingInput) ? null : trackingInput,
                trackingUrl: null,
                comment: string.IsNullOrWhiteSpace(commentInput) ? null : commentInput);

            if (!ok) { ToastService.Error(error ?? "MeLi rechazo el cambio"); return; }
            ToastService.Success($"Estado actualizado en MeLi: {StatusLabel(pendingChange.NewStatus, pendingChange.NewSubstatus)}");
            pendingChange = null;
            commentInput = "";
            trackingInput = "";
            await LoadAsync();
        }
        catch (Exception ex) { ToastService.Error($"Error: {ex.Message}"); }
        finally { isSubmitting = false; busyRow = null; }
    }
}
