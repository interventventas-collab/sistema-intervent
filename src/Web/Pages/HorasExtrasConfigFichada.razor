@page "/horas-extras/configuracion-fichada"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject OperatorService Operator
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Configuración Fichada — Modo Nuevo</PageTitle>

@* 2026-06-06: layout 2 columnas — config a la izquierda, QR grande a la derecha *@
<div style="display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 1.5rem; padding: 1rem; max-width: 1300px; margin: 0 auto;">

<div style="min-width: 0;">
    <h2 style="margin: 0 0 0.5rem;">🔒 Configuración de Fichada</h2>
    <p style="color: #6b7280; font-size: 0.9rem; margin-bottom: 1.5rem;">
        Piloto del modo nuevo de fichada: bloqueo por WiFi del negocio + log de GPS.
        Mientras el toggle maestro esté <strong>OFF</strong>, los empleados siguen fichando
        como hasta ahora (PIN de 3 dígitos del DNI). Cuando lo prendas, se aplican las reglas.
    </p>

    @if (cargando)
    {
        <p>Cargando configuración...</p>
    }
    else if (cfg is null)
    {
        <p style="color: #b91c1c;">No se pudo cargar la configuración. Recargá la página.</p>
    }
    else
    {
        @* ── TOGGLE MAESTRO ───────────────────────────────────────── *@
        <div style="padding: 1rem 1.2rem; background: @(cfg.ActivarModoNuevo ? "#dcfce7" : "#fef3c7"); border: 2px solid @(cfg.ActivarModoNuevo ? "#16a34a" : "#f59e0b"); border-radius: 10px; margin-bottom: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 0.8rem; cursor: pointer;" @onclick="ToggleMaestro">
                <input type="checkbox" checked="@cfg.ActivarModoNuevo" style="width: 22px; height: 22px;" />
                <div style="flex: 1;">
                    <div style="font-weight: 800; font-size: 1.05rem; color: @(cfg.ActivarModoNuevo ? "#14532d" : "#92400e");">
                        @(cfg.ActivarModoNuevo ? "✅ Modo nuevo ACTIVO" : "🔒 Modo nuevo DESACTIVADO (DORMIDO)")
                    </div>
                    <div style="font-size: 0.82rem; color: #4b5563; margin-top: 0.2rem;">
                        @(cfg.ActivarModoNuevo
                            ? "Los empleados solo pueden fichar conectados al WiFi del negocio."
                            : "Los empleados fichan como siempre, sin restricciones de WiFi.")
                    </div>
                </div>
            </div>
        </div>

        @* ── CONFIG WIFI ───────────────────────────────────────────── *@
        <div style="background: #eff6ff; border: 1px solid #93c5fd; border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.2rem;">
            <h3 style="margin: 0 0 0.5rem; color: #1e3a8a;">📡 WiFi autorizadas</h3>
            <p style="font-size: 0.8rem; color: #1e40af; margin: 0 0 0.8rem;">
                Cargá hasta 2 IPs (1 por WiFi). Conectate al WiFi del negocio y tocá "📍 Capturar mi IP" para tomarla automáticamente.
            </p>

            @* WiFi 1 *@
            <div style="margin-bottom: 0.8rem;">
                <label style="font-size: 0.85rem; font-weight: 700; color: #1f2937;">WiFi #1</label>
                <div style="display: flex; gap: 0.4rem; align-items: center; margin-top: 0.2rem;">
                    <input type="text" class="form-input" placeholder="Nombre/etiqueta (ej: Depósito)" style="flex: 1; max-width: 200px;"
                           value="@cfg.Wifi1Label" @onchange="@(e => OnChange(c => c.Wifi1Label = e.Value?.ToString()))" />
                    <input type="text" class="form-input" placeholder="IP pública (ej: 200.123.45.67)" style="flex: 1; font-family: monospace;"
                           value="@cfg.Wifi1Ip" @onchange="@(e => OnChange(c => c.Wifi1Ip = e.Value?.ToString()))" />
                    <button class="btn btn-secondary" @onclick="() => CapturarMiIp(1)" disabled="@guardando" title="Tomar la IP pública desde la que estás conectándote ahora">
                        📍 Capturar mi IP
                    </button>
                </div>
            </div>

            @* WiFi 2 *@
            <div>
                <label style="font-size: 0.85rem; font-weight: 700; color: #1f2937;">WiFi #2 (opcional)</label>
                <div style="display: flex; gap: 0.4rem; align-items: center; margin-top: 0.2rem;">
                    <input type="text" class="form-input" placeholder="Nombre/etiqueta (ej: Oficina)" style="flex: 1; max-width: 200px;"
                           value="@cfg.Wifi2Label" @onchange="@(e => OnChange(c => c.Wifi2Label = e.Value?.ToString()))" />
                    <input type="text" class="form-input" placeholder="IP pública" style="flex: 1; font-family: monospace;"
                           value="@cfg.Wifi2Ip" @onchange="@(e => OnChange(c => c.Wifi2Ip = e.Value?.ToString()))" />
                    <button class="btn btn-secondary" @onclick="() => CapturarMiIp(2)" disabled="@guardando">
                        📍 Capturar mi IP
                    </button>
                </div>
            </div>
        </div>

        @* ── 2026-06-27: BLOQUEO POR GPS (GEOCERCA) ─────────────────── *@
        <div style="background: #f0fdf4; border: 1px solid #86efac; border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.2rem;">
            <h3 style="margin: 0 0 0.5rem; color: #166534;">📍 Bloqueo por ubicación (GPS)</h3>
            <p style="font-size: 0.8rem; color: #15803d; margin: 0 0 0.9rem;">
                Solo deja fichar a quien esté <strong>cerca del negocio</strong>. Es independiente del WiFi.
                Por ahora es una <strong>prueba</strong>: solo se les controla la ubicación a los empleados que marques abajo.
            </p>

            @* Toggle GPS *@
            <div style="padding: 0.8rem 1rem; background: @(cfg.BloquearPorGps ? "#dcfce7" : "white"); border: 2px solid @(cfg.BloquearPorGps ? "#16a34a" : "#d1d5db"); border-radius: 8px; margin-bottom: 0.9rem;">
                <div style="display: flex; align-items: center; gap: 0.8rem; cursor: pointer;" @onclick="ToggleBloqueoGps">
                    <input type="checkbox" checked="@cfg.BloquearPorGps" style="width: 20px; height: 20px;" />
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: @(cfg.BloquearPorGps ? "#14532d" : "#4b5563");">
                            @(cfg.BloquearPorGps ? "✅ Bloqueo por GPS ACTIVO" : "⭕ Bloqueo por GPS apagado")
                        </div>
                        <div style="font-size: 0.78rem; color: #6b7280;">
                            @(cfg.BloquearPorGps
                                ? "Los empleados marcados solo pueden fichar dentro del radio."
                                : "Nadie tiene control de ubicación todavía.")
                        </div>
                    </div>
                </div>
            </div>

            @* Ubicación del negocio + radio *@
            <div style="display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.6rem;">
                <button class="btn btn-secondary" @onclick="CapturarUbicacionNegocio" disabled="@(capturandoUbic || guardando)">
                    @(capturandoUbic ? "📡 Obteniendo ubicación..." : "📍 Capturar ubicación del negocio")
                </button>
                @if (cfg.NegocioLat.HasValue && cfg.NegocioLon.HasValue)
                {
                    <span style="font-size: 0.82rem; color: #166534; font-family: monospace;">
                        ✓ @cfg.NegocioLat.Value.ToString("0.######"), @cfg.NegocioLon.Value.ToString("0.######")
                    </span>
                    <a href="@($"https://www.google.com/maps?q={cfg.NegocioLat.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)},{cfg.NegocioLon.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}")"
                       target="_blank" style="font-size: 0.8rem; color: #2563eb;">🗺️ ver en mapa</a>
                }
                else
                {
                    <span style="font-size: 0.82rem; color: #b91c1c;">Sin ubicación capturada</span>
                }
            </div>

            <div style="display: flex; gap: 0.5rem; align-items: center;">
                <label style="font-size: 0.85rem; font-weight: 700; color: #1f2937;">Radio permitido:</label>
                <input type="number" class="form-input" min="20" max="5000" step="10" style="width: 100px;"
                       value="@cfg.RadioMetros" @onchange="@(e => OnChange(c => { if (int.TryParse(e.Value?.ToString(), out var v)) c.RadioMetros = v; }))" />
                <span style="font-size: 0.85rem; color: #4b5563;">metros</span>
                <small style="color: #9ca3af;">(recomendado 150 — el GPS adentro de un galpón es impreciso)</small>
            </div>

            @* Empleados del piloto GPS *@
            <div style="margin-top: 1rem; padding-top: 0.8rem; border-top: 1px dashed #86efac;">
                <div style="font-size: 0.85rem; font-weight: 700; color: #166534; margin-bottom: 0.5rem;">
                    👥 ¿A quién se le controla el GPS? (marcá los de la prueba)
                </div>
                @if (empleadosGps.Count == 0)
                {
                    <p style="font-size: 0.8rem; color: #6b7280; margin: 0;">No hay empleados activos.</p>
                }
                else
                {
                    <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                        @foreach (var emp in empleadosGps)
                        {
                            <label style="display: flex; gap: 0.4rem; align-items: center; cursor: pointer; padding: 0.35rem 0.6rem; border-radius: 6px; border: 1px solid @(emp.ProbarGps ? "#16a34a" : "#e5e7eb"); background: @(emp.ProbarGps ? "#dcfce7" : "white"); font-size: 0.82rem;">
                                <input type="checkbox" checked="@emp.ProbarGps"
                                       @onchange="@(e => ToggleEmpleadoGps(emp, (bool)e.Value!))" />
                                <span>@emp.Nombre</span>
                            </label>
                        }
                    </div>
                }
            </div>
        </div>

        @* ── OPCIONES ADICIONALES ───────────────────────────────────── *@
        <div style="background: #f9fafb; border: 1px solid #d1d5db; border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1.2rem;">
            <h3 style="margin: 0 0 0.6rem; color: #1f2937;">⚙ Opciones</h3>

            <label style="display: flex; gap: 0.6rem; align-items: flex-start; cursor: pointer; padding: 0.5rem; border-radius: 6px; margin-bottom: 0.3rem;">
                <input type="checkbox" checked="@cfg.LoguearGps" @onchange="@(e => OnChange(c => c.LoguearGps = (bool)e.Value!))" style="margin-top: 0.2rem;" />
                <div>
                    <strong>📍 Loguear ubicación GPS al fichar</strong>
                    <div style="font-size: 0.78rem; color: #6b7280;">
                        Guarda lat/long de cada fichada para auditoría. NO bloquea — solo registra.
                    </div>
                </div>
            </label>

            <label style="display: flex; gap: 0.6rem; align-items: flex-start; cursor: pointer; padding: 0.5rem; border-radius: 6px; opacity: 0.5;">
                <input type="checkbox" checked="@cfg.RequiereHuella" disabled="true" style="margin-top: 0.2rem;" />
                <div>
                    <strong>👆 Requerir huella biométrica</strong>
                    <div style="font-size: 0.78rem; color: #6b7280;">
                        🚧 <strong>Fase 2 — Próximamente.</strong> Requiere registrar la huella de cada empleado en su celular (WebAuthn).
                    </div>
                </div>
            </label>
        </div>

        @* ── ACCIONES ───────────────────────────────────────────────── *@
        <div style="display: flex; gap: 0.5rem; align-items: center;">
            <button class="btn btn-primary" @onclick="Guardar" disabled="@guardando">
                @(guardando ? "Guardando..." : "💾 Guardar cambios")
            </button>
            @if (cfg.UpdatedAt.HasValue)
            {
                <small style="color: #6b7280; margin-left: auto;">
                    Última modificación: @cfg.UpdatedAt.Value.ToArTime().ToString("dd/MM HH:mm")
                    @if (!string.IsNullOrEmpty(cfg.UpdatedBy)) { <span> por @cfg.UpdatedBy</span> }
                </small>
            }
        </div>

        @* ── INSTRUCCIONES DE PRIMER USO ─────────────────────────────── *@
        <div style="background: #fef3c7; border: 1px solid #f59e0b; border-radius: 8px; padding: 0.9rem 1rem; margin-top: 2rem;">
            <strong style="color: #92400e;">💡 Cómo activarlo (primera vez)</strong>
            <ol style="margin: 0.5rem 0 0; padding-left: 1.4rem; font-size: 0.88rem; line-height: 1.5;">
                <li><strong>Conectate al WiFi del depósito</strong> con tu compu o celular.</li>
                <li>Tocá <strong>📍 Capturar mi IP</strong> en WiFi #1. La IP se completa sola.</li>
                <li>Ponele un nombre (ej. "Depósito").</li>
                <li>Si tenés un 2do WiFi (oficina, etc), conectate a ese y repetí en WiFi #2.</li>
                <li>Tocá el toggle <strong>"Modo nuevo ACTIVO"</strong> arriba.</li>
                <li>Probá fichar desde un celu en el WiFi → debería funcionar.</li>
                <li>Probá fichar desde un celu con datos móviles (NO WiFi) → debería bloquearse.</li>
            </ol>
        </div>
    }
</div>

@* ════════ 2026-06-06: Panel QR a la derecha — para que los empleados escaneen y abran la app de fichaje ════════ *@
<aside style="position: sticky; top: 1rem; align-self: start; background: white; border: 2px solid #3b82f6; border-radius: 12px; padding: 1.2rem 1rem; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15); text-align: center;">
    <div style="font-size: 1.05rem; font-weight: 700; color: #1d4ed8; margin-bottom: 0.4rem;">
        📱 App de Fichaje
    </div>
    <div style="font-size: 0.78rem; color: #6b7280; margin-bottom: 0.8rem; line-height: 1.3;">
        Escanealo con la cámara del celu para abrir el fichador
    </div>
    <div style="background: white; padding: 0.5rem; border: 1px solid #e5e7eb; border-radius: 8px; display: inline-block;">
        <img src="@QrFichadorUrl" alt="QR Fichador" style="width: 280px; height: 280px; display: block;" />
    </div>
    <div style="margin-top: 0.7rem; font-size: 0.72rem; color: #9ca3af; word-break: break-all; padding: 0 0.3rem;">
        @FichadorUrl
    </div>
    <div style="margin-top: 0.7rem; display: flex; gap: 0.4rem; justify-content: center; flex-wrap: wrap;">
        <button class="btn btn-secondary" style="font-size: 0.75rem; padding: 0.4rem 0.7rem;"
                @onclick="CopiarLink">
            📋 Copiar link
        </button>
        <a href="@FichadorUrl" target="_blank" class="btn btn-primary" style="font-size: 0.75rem; padding: 0.4rem 0.7rem; text-decoration: none;">
            🔗 Abrir
        </a>
    </div>
    <div style="margin-top: 0.9rem; padding: 0.6rem; background: #eff6ff; border-radius: 6px; font-size: 0.72rem; color: #1e40af; text-align: left; line-height: 1.4;">
        <strong>💡 Cómo instalar como app:</strong><br/>
        <strong>iPhone (Safari)</strong>: Compartir → "Agregar a inicio"<br/>
        <strong>Android (Chrome)</strong>: ⋮ → "Instalar app" o "Agregar a inicio"
    </div>
</aside>

</div>

@code {
    private ApiClient.ConfigFichadaDto? cfg;
    private bool cargando = true;
    private bool guardando;
    // 2026-06-06: URL del fichador + QR (qrserver.com) para que los empleados escaneen
    private string FichadorUrl => $"{Nav.BaseUri.TrimEnd('/')}/fichador";
    private string QrFichadorUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=400x400&margin=10&data={Uri.EscapeDataString(FichadorUrl)}";

    private async Task CopiarLink()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", FichadorUrl);
            ToastService.Success("Link copiado ✓");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    // Estado mutable local (para los inputs). Se sincroniza con cfg al cargar y al guardar.
    private Dictionary<string, object?> changes = new();

    protected override async Task OnInitializedAsync()
    {
        await Operator.LoadAsync();
        await CargarConfig();
        await CargarEmpleadosGps();
    }

    private async Task CargarConfig()
    {
        cargando = true;
        try
        {
            cfg = await Api.GetConfigFichadaAsync();
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { cargando = false; }
    }

    /// <summary>Aplica el cambio al cfg local (cliente) sin guardar todavia. Para que la UI
    /// muestre el valor al toque sin que pierda foco. Guarda recién en el botón.</summary>
    private void OnChange(Action<MutableCfg> apply)
    {
        if (cfg is null) return;
        var m = new MutableCfg
        {
            Wifi1Ip = cfg.Wifi1Ip, Wifi1Label = cfg.Wifi1Label,
            Wifi2Ip = cfg.Wifi2Ip, Wifi2Label = cfg.Wifi2Label,
            RequiereHuella = cfg.RequiereHuella, LoguearGps = cfg.LoguearGps,
            ActivarModoNuevo = cfg.ActivarModoNuevo,
            BloquearPorGps = cfg.BloquearPorGps, NegocioLat = cfg.NegocioLat,
            NegocioLon = cfg.NegocioLon, RadioMetros = cfg.RadioMetros
        };
        apply(m);
        cfg = new ApiClient.ConfigFichadaDto(m.ActivarModoNuevo, m.Wifi1Ip, m.Wifi1Label,
            m.Wifi2Ip, m.Wifi2Label, m.RequiereHuella, m.LoguearGps,
            m.BloquearPorGps, m.NegocioLat, m.NegocioLon, m.RadioMetros,
            cfg.UpdatedAt, cfg.UpdatedBy);
    }

    private async Task ToggleMaestro()
    {
        if (cfg is null) return;
        OnChange(c => c.ActivarModoNuevo = !cfg.ActivarModoNuevo);
        await Guardar();
    }

    private async Task ToggleBloqueoGps()
    {
        if (cfg is null) return;
        // Si se prende sin ubicación capturada, avisar (el backend igual lo rechaza).
        if (!cfg.BloquearPorGps && (cfg.NegocioLat is null || cfg.NegocioLon is null))
        {
            ToastService.Error("Primero capturá la ubicación del negocio (parado en el local) y tocá Guardar.");
            return;
        }
        OnChange(c => c.BloquearPorGps = !cfg.BloquearPorGps);
        await Guardar();
    }

    private async Task CapturarMiIp(int slot)
    {
        try
        {
            var ip = await Api.GetMiIpFichadaAsync();
            if (string.IsNullOrEmpty(ip)) { ToastService.Error("No se pudo detectar tu IP"); return; }
            if (slot == 1) OnChange(c => c.Wifi1Ip = ip);
            else OnChange(c => c.Wifi2Ip = ip);
            ToastService.Success($"IP capturada: {ip}. Acordate de tocar 💾 Guardar.");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task Guardar()
    {
        if (cfg is null) return;
        guardando = true;
        try
        {
            var (nuevo, err) = await Api.UpdateConfigFichadaAsync(new ApiClient.UpdateConfigFichadaRequest
            {
                ActivarModoNuevo = cfg.ActivarModoNuevo,
                Wifi1Ip = cfg.Wifi1Ip ?? "", Wifi1Label = cfg.Wifi1Label ?? "",
                Wifi2Ip = cfg.Wifi2Ip ?? "", Wifi2Label = cfg.Wifi2Label ?? "",
                RequiereHuella = cfg.RequiereHuella, LoguearGps = cfg.LoguearGps,
                BloquearPorGps = cfg.BloquearPorGps,
                NegocioLat = cfg.NegocioLat, NegocioLon = cfg.NegocioLon,
                RadioMetros = cfg.RadioMetros,
                UpdatedBy = Operator.Current
            });
            if (nuevo is null) { ToastService.Error(err ?? "Error guardando"); return; }
            cfg = nuevo;
            ToastService.Success("Configuración guardada ✅");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { guardando = false; }
    }

    private class MutableCfg
    {
        public bool ActivarModoNuevo { get; set; }
        public string? Wifi1Ip { get; set; }
        public string? Wifi1Label { get; set; }
        public string? Wifi2Ip { get; set; }
        public string? Wifi2Label { get; set; }
        public bool RequiereHuella { get; set; }
        public bool LoguearGps { get; set; }
        public bool BloquearPorGps { get; set; }
        public decimal? NegocioLat { get; set; }
        public decimal? NegocioLon { get; set; }
        public int RadioMetros { get; set; }
    }

    // ─── 2026-06-27: piloto bloqueo por GPS ───
    private List<ApiClient.EmpleadoGpsDto> empleadosGps = new();
    private bool capturandoUbic;

    private async Task CargarEmpleadosGps()
    {
        try { empleadosGps = await Api.GetEmpleadosGpsAsync() ?? new(); }
        catch (Exception ex) { ToastService.Error("Error cargando empleados: " + ex.Message); }
    }

    private async Task ToggleEmpleadoGps(ApiClient.EmpleadoGpsDto emp, bool probar)
    {
        var ok = await Api.SetEmpleadoGpsAsync(emp.Id, probar);
        if (ok)
        {
            var i = empleadosGps.FindIndex(e => e.Id == emp.Id);
            if (i >= 0) empleadosGps[i] = emp with { ProbarGps = probar };
            ToastService.Success(probar ? $"{emp.Nombre} entra al piloto GPS ✓" : $"{emp.Nombre} sale del piloto GPS");
        }
        else ToastService.Error("No se pudo guardar el cambio");
    }

    /// <summary>Capturar la ubicación del negocio: pide GPS preciso al navegador y la guarda como
    /// centro de la geocerca. Hay que estar parado en el local con buena señal.</summary>
    private async Task CapturarUbicacionNegocio()
    {
        capturandoUbic = true;
        try
        {
            var pos = await JS.InvokeAsync<GpsCapture?>("heGetPositionAccurate", 12000);
            if (pos is null || pos.Lat is null || pos.Lon is null)
            {
                ToastService.Error("No se pudo obtener la ubicación. Activá el GPS, dale permiso y probá de nuevo (mejor cerca de una ventana).");
                return;
            }
            OnChange(c => { c.NegocioLat = pos.Lat; c.NegocioLon = pos.Lon; });
            var precision = pos.Accuracy.HasValue ? $" (precisión ~{pos.Accuracy} m)" : "";
            ToastService.Success($"Ubicación capturada{precision}. Acordate de tocar 💾 Guardar.");
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
        finally { capturandoUbic = false; }
    }

    private record GpsCapture(decimal? Lat, decimal? Lon, int? Accuracy);
}
