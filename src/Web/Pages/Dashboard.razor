@page "/"
@page "/index.html"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject AuthService AuthService
@inject OperatorService Operator
@inject ToastService ToastService
@inject CurrentCompanyService Company
@inject NavigationManager Navigation

<div class="view-header">
    <h2>Bienvenido, @username</h2>
    <p class="view-subtitle">Panel de control</p>
</div>

@* 2026-05-30: para usuarios SOLO depósito (sin cafe ni oficina), ocultar todos los
   widgets del dashboard — ellos operan solo desde el sidebar (Imprimir pedidos,
   Productos, Stock). El resto sigue viendo el dashboard normal. *@
@if (!isDepositoOnly)
{
@* Fila superior: HOLA + dolar + reloj AR/ES combinado + postits (responsive) *@
<div class="dashboard-top-grid">
    <div class="dashboard-detail-card" style="padding: 1rem; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem;">
        <span style="font-size: 1.2rem; font-weight: 700;">👋 HOLA EQUIPO:</span>
        <select class="form-input" style="font-size: 1rem; font-weight: 700; max-width: 220px;"
                value="@(Operator.Current ?? "")"
                @onchange="OnSelectOperator">
            <option value="">— Elegi tu nombre —</option>
            @foreach (var op in OperatorService.Operators)
            {
                <option value="@op">@op</option>
            }
        </select>
        @if (Operator.HasOperator)
        {
            <div style="font-size: 0.78rem; color: #6b7280;">Estás trabajando como <strong>@Operator.Current</strong></div>
        }
    </div>

    @* Widget Dolar BNA *@
    <div class="dashboard-detail-card" style="padding: 0.85rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem;">
            <span style="font-size: 1.4rem;">💵</span>
            <div>
                <div style="font-weight: 700; font-size: 0.85rem;">Dolar Banco Nacion</div>
                <div style="font-size: 0.7rem; color: #6b7280;">@(dolar?.Fecha ?? "Cargando...")</div>
            </div>
        </div>
        @if (dolarLoading && dolar is null)
        {
            <div style="font-size: 0.8rem; color: #6b7280;">Consultando BNA...</div>
        }
        else if (dolar is not null && dolar.Compra is not null && dolar.Venta is not null)
        {
            <div style="display: flex; justify-content: space-around; align-items: center; padding-top: 0.3rem;">
                <div style="text-align: center;">
                    <div style="font-size: 0.7rem; color: #15803d; font-weight: 600;">COMPRA</div>
                    <div style="font-size: 1.2rem; font-weight: 800; color: #15803d;">$@FormatMoney(dolar.Compra.Value)</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 0.7rem; color: #b91c1c; font-weight: 600;">VENTA</div>
                    <div style="font-size: 1.2rem; font-weight: 800; color: #b91c1c;">$@FormatMoney(dolar.Venta.Value)</div>
                </div>
            </div>
        }
        else
        {
            <div style="font-size: 0.78rem; color: #b91c1c;">@(dolar?.Error ?? "No se pudo obtener la cotizacion")</div>
        }
    </div>

    @* Reloj combinado: Argentina + España en un solo modulo *@
    <div class="dashboard-detail-card dashboard-clock-card">
        <div class="dashboard-clock-row">
            <span style="font-size: 1.3rem;">🇦🇷</span>
            <div style="flex: 1; min-width: 0;">
                <div style="font-size: 0.72rem; color: #6b7280; font-weight: 600;">Argentina</div>
                <div class="dashboard-clock-time">@arTime.ToString("HH:mm:ss")</div>
                <div class="dashboard-clock-date">@arTime.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-AR"))</div>
            </div>
        </div>
        <div style="border-top: 1px dashed #d1d5db; margin: 0.4rem 0;"></div>
        <div class="dashboard-clock-row">
            <span style="font-size: 1.3rem;">🇪🇸</span>
            <div style="flex: 1; min-width: 0;">
                <div style="font-size: 0.72rem; color: #6b7280; font-weight: 600;">España</div>
                <div class="dashboard-clock-time">@esTime.ToString("HH:mm:ss")</div>
                <div class="dashboard-clock-date">@esTime.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-ES"))</div>
            </div>
        </div>
    </div>

    @* Postits: block de notas compartido (componente reusable, scope=dashboard) *@
    <PostitsWidget Scope="dashboard" Title="Postits del equipo" CardStyle="max-height: 220px;" />

    @* Balanza de café FRIKAF — circulo con imagen + labels abajo (estilo "balanza") *@
    <div class="cafe-frikaf-balanza">
        <div class="cafe-frikaf-circle"
             style="background-image: linear-gradient(rgba(255,255,255,0.10), rgba(255,255,255,0.25)), url('/api/branding/cafe-frikaf-bg?v=@bgVersion');">
            @* Boton para subir / cambiar la imagen de fondo *@
            <label class="cafe-frikaf-upload-btn" title="Cambiar imagen de fondo">
                📷
                <InputFile OnChange="OnCafeBgFilePicked" accept=".png,.jpg,.jpeg,.webp" style="display: none;" />
            </label>

            <div class="cafe-frikaf-circle-content">
                @if (coffeeKg is null)
                {
                    <div class="cafe-frikaf-loading">…</div>
                }
                else
                {
                    <div class="cafe-frikaf-kg-number">@FormatKg(coffeeKg.KgTotal)</div>
                    <div class="cafe-frikaf-kg-unit">kg</div>
                }
            </div>

            @if (cafeBgUploading)
            {
                <div class="cafe-frikaf-uploading">Subiendo...</div>
            }
        </div>

        @* Labels abajo del circulo: BALANZA + mes/año *@
        <div class="cafe-frikaf-balanza-label">BALANZA</div>
        <div class="cafe-frikaf-balanza-period">
            @if (coffeeKg is not null)
            {
                @coffeeKg.PeriodStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR")).ToUpper()
            }
        </div>
    </div>

    @* Stock total de cafe disponible — mismo estilo circular que la balanza *@
    <div class="cafe-frikaf-balanza" title="Suma del stock de todos los cafés (kg-mode parents)">
        <div class="cafe-frikaf-circle cafe-stock-circle">
            <div class="cafe-frikaf-circle-content">
                @if (coffeeStock is null)
                {
                    <div class="cafe-frikaf-loading">…</div>
                }
                else
                {
                    <div class="cafe-frikaf-kg-number">@FormatKg(coffeeStock.KgTotal)</div>
                    <div class="cafe-frikaf-kg-unit">kg</div>
                }
            </div>
        </div>
        <div class="cafe-frikaf-balanza-label">STOCK</div>
        <div class="cafe-frikaf-balanza-period">
            @if (coffeeStock is not null)
            {
                <span>@coffeeStock.VariedadesConStock / @coffeeStock.Variedades VARIEDADES</span>
            }
            else
            {
                <span>DISPONIBLE</span>
            }
        </div>
    </div>
</div>

<style>
    /* ═══════════════ Top grid responsive ═══════════════ */
    .dashboard-top-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: 0.8rem;
        margin-bottom: 1rem;
    }
    @@media (max-width: 1024px) {
        .dashboard-top-grid { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 640px) {
        .dashboard-top-grid { grid-template-columns: 1fr; gap: 0.6rem; }
    }

    /* ═══════════════ Reloj combinado AR + ES ═══════════════ */
    .dashboard-clock-card { padding: 0.7rem 0.85rem; }
    .dashboard-clock-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .dashboard-clock-time {
        font-size: 1.3rem;
        font-weight: 800;
        font-family: 'Courier New', monospace;
        line-height: 1.1;
    }
    .dashboard-clock-date {
        font-size: 0.68rem;
        color: #6b7280;
        text-transform: capitalize;
    }
    @@media (max-width: 640px) {
        .dashboard-clock-time { font-size: 1.5rem; }
    }

    /* ═══════════════ Postits del equipo ═══════════════ */
    .dashboard-postits-card { padding: 0.7rem 0.85rem; display: flex; flex-direction: column; gap: 0.4rem; max-height: 220px; }
    .dashboard-postits-header { display: flex; align-items: center; gap: 0.4rem; padding-bottom: 0.3rem; border-bottom: 1px solid #e5e7eb; }
    .dashboard-postits-body {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding-right: 0.2rem;
    }
    .dashboard-postit {
        padding: 0.35rem 0.5rem;
        border-radius: 4px;
        cursor: pointer;
        transition: filter 0.1s;
    }
    .dashboard-postit:hover { filter: brightness(0.95); }
    .dashboard-postit-text {
        font-size: 0.82rem;
        line-height: 1.3;
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 4.2em;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
    }
    .dashboard-postit-meta { font-size: 0.65rem; color: #6b7280; margin-top: 0.15rem; }
    @@media (max-width: 640px) {
        .dashboard-postits-card { max-height: 280px; }
    }
    .postit-color-pick {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
    }

    .cafe-frikaf-balanza {
        flex: 0 0 180px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
    }
    .cafe-frikaf-circle {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        position: relative;
        overflow: hidden;
        background-color: #fde68a;
        background-size: cover;
        background-position: center;
        border: 4px solid #f59e0b;
        box-shadow: 0 6px 16px rgba(120, 53, 15, 0.35), inset 0 0 30px rgba(120, 53, 15, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }
    /* Variante verde para el indicador de stock disponible (vs balanza ventas) */
    .cafe-stock-circle {
        background-color: #86efac;
        background-image: linear-gradient(135deg, #86efac 0%, #16a34a 100%);
        border-color: #15803d;
        box-shadow: 0 6px 16px rgba(20, 83, 45, 0.35), inset 0 0 30px rgba(20, 83, 45, 0.20);
    }
    .cafe-frikaf-circle-content {
        position: relative;
        z-index: 1;
        padding: 0 0.5rem;
    }
    .cafe-frikaf-kg-number {
        font-size: 2.6rem;
        font-weight: 900;
        color: #ffffff;
        line-height: 1;
        text-shadow: 2px 2px 6px rgba(0,0,0,0.7), 0 0 12px rgba(0,0,0,0.5);
        letter-spacing: -0.03em;
    }
    .cafe-frikaf-kg-unit {
        font-size: 1.05rem;
        font-weight: 800;
        color: #ffffff;
        line-height: 1;
        margin-top: 0.1rem;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.7);
        letter-spacing: 0.05em;
    }
    .cafe-frikaf-loading {
        font-size: 1.5rem;
        color: #ffffff;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.7);
    }
    .cafe-frikaf-balanza-label {
        font-size: 1.1rem;
        font-weight: 800;
        color: #1f2937;
        letter-spacing: 0.15em;
        margin-top: 0.4rem;
    }
    .cafe-frikaf-balanza-period {
        font-size: 0.85rem;
        font-weight: 700;
        color: #4b5563;
        letter-spacing: 0.1em;
        margin-top: -0.15rem;
    }
    .cafe-frikaf-uploading {
        position: absolute; inset: 0;
        background: rgba(255,255,255,0.92);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; color: #78350f; font-weight: 700;
        border-radius: 50%; text-align: center; padding: 0 0.5rem;
    }
    .cafe-frikaf-upload-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 26px;
        height: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid #f59e0b;
        border-radius: 50%;
        cursor: pointer;
        font-size: 0.85rem;
        z-index: 2;
        transition: background 0.15s, transform 0.15s;
    }
    .cafe-frikaf-upload-btn:hover { background: white; transform: scale(1.1); }
</style>

@* === Fila de KPIs financieros: Ventas del mes / Saldos clientes / Cuentas a pagar === *@
<div class="dashboard-cards-row">
    @* Ventas del mes *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%); border: 1px solid #10b981;">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">💵</span>
            <strong style="font-size: 0.85rem; color: #065f46;">Ventas del mes</strong>
        </div>
        @if (salesSummary is null)
        {
            <div style="font-size: 1rem; color: #047857;">Cargando...</div>
        }
        else
        {
            <div style="font-size: 1.5rem; font-weight: 800; color: #065f46; line-height: 1.2;">
                $@FormatMoney(salesSummary.MonthlySalesTotal)
            </div>
            <div style="font-size: 0.72rem; color: #047857; margin-top: 0.15rem;">
                @salesSummary.MonthlySalesCount comprobante@(salesSummary.MonthlySalesCount == 1 ? "" : "s") en @salesSummary.PeriodStart.ToString("MMMM", new System.Globalization.CultureInfo("es-AR"))
            </div>
        }
    </div>

    @* Saldos de clientes *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); border: 1px solid #ef4444;">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">📋</span>
            <strong style="font-size: 0.85rem; color: #991b1b;">Saldos de clientes</strong>
        </div>
        @if (salesSummary is null)
        {
            <div style="font-size: 1rem; color: #b91c1c;">Cargando...</div>
        }
        else
        {
            <div style="font-size: 1.5rem; font-weight: 800; color: #991b1b; line-height: 1.2;">
                $@FormatMoney(salesSummary.ClientBalanceTotal)
            </div>
            <div style="font-size: 0.72rem; color: #b91c1c; margin-top: 0.15rem;">
                @salesSummary.ClientsWithBalance cliente@(salesSummary.ClientsWithBalance == 1 ? "" : "s") · @salesSummary.ClientBalanceCount comprobante@(salesSummary.ClientBalanceCount == 1 ? "" : "s") sin pagar
            </div>
        }
    </div>

    @* Documentación importante — acceso directo + stats *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #ede9fe 0%, #ddd6fe 100%); border: 1px solid #8b5cf6; cursor: pointer;" @onclick='() => Navigation.NavigateTo("/documentacion")' title="Ir a Documentación importante">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">📑</span>
            <strong style="font-size: 0.85rem; color: #5b21b6;">Documentación</strong>
        </div>
        @if (docStats is null)
        {
            <div style="font-size: 0.95rem; color: #6d28d9;">Cargando...</div>
        }
        else
        {
            <div style="font-size: 1.3rem; font-weight: 800; color: #5b21b6; line-height: 1.2;">
                📁 @docStats.Folders · 📄 @docStats.Files
            </div>
            <div style="font-size: 0.72rem; color: #6d28d9; margin-top: 0.15rem;">
                @(docStats.Files == 0 ? "Subí tus primeros archivos →" : $"{docStats.Folders} carpeta{(docStats.Folders == 1 ? "" : "s")} · {docStats.Files} archivo{(docStats.Files == 1 ? "" : "s")}")
            </div>
            @if (docStats.LastUploadAt.HasValue)
            {
                <div style="font-size: 0.65rem; color: #7c3aed; margin-top: 0.15rem; font-style: italic;">
                    🔄 Última subida: @FormatearUltimaActualizacion(docStats.LastUploadAt.Value)
                </div>
            }
        }
    </div>

    @* Shell Flota — placeholder, esperando API *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #f59e0b; position: relative; opacity: 0.85;" title="Próximamente — cuando tengamos la API de Shell, este recuadro mostrará los datos de la flota.">
        <div style="position: absolute; top: 0.5rem; right: 0.5rem; background: #f59e0b; color: white; font-size: 0.6rem; font-weight: 800; letter-spacing: 0.05em; padding: 0.15rem 0.45rem; border-radius: 4px;">🚧 EN CONSTRUCCIÓN</div>
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">⛽</span>
            <strong style="font-size: 0.85rem; color: #92400e;">Shell Flota</strong>
        </div>
        <div style="font-size: 1.05rem; font-weight: 800; color: #92400e; line-height: 1.2;">
            Próximamente
        </div>
        <div style="font-size: 0.7rem; color: #b45309; margin-top: 0.15rem; font-style: italic;">
            Esperando API de Shell para integrar
        </div>
    </div>

    @* Saldo banco Galicia *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #1e40af, #2563eb); cursor: pointer;" @onclick='() => Navigation.NavigateTo("/cafe/tesoreria/extracto-banco")' title="Ir al extracto bancario">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">🏦</span>
            <strong style="font-size: 0.85rem; color: white;">Saldo banco Galicia</strong>
        </div>
        @if (saldoBanco is null || saldoBanco.CantidadMovimientos == 0)
        {
            <div style="font-size: 0.95rem; font-weight: 700; color: rgba(255,255,255,0.85); line-height: 1.2;">
                Subí el extracto →
            </div>
            <div style="font-size: 0.7rem; color: rgba(255,255,255,0.7); margin-top: 0.15rem;">
                Click para importar
            </div>
        }
        else
        {
            <div style="font-size: 1.45rem; font-weight: 800; color: white; line-height: 1.2;">
                $@FormatMoney(saldoBanco.Saldo)
            </div>
            <div style="font-size: 0.7rem; color: rgba(255,255,255,0.8); margin-top: 0.15rem;">
                al @saldoBanco.UltimaFecha.ToString("dd/MM/yyyy")
            </div>
            @if (saldoBanco.UltimoImportadoAt.HasValue)
            {
                <div style="font-size: 0.65rem; color: rgba(255,255,255,0.65); margin-top: 0.15rem; font-style: italic;">
                    🔄 Última actualización: @FormatearUltimaActualizacion(saldoBanco.UltimoImportadoAt.Value)
                </div>
            }
        }
    </div>
</div>

@* === Cheques por pagar — calendario visual === *@
<ChequesPorPagarCalendario />


<div class="dashboard-cards-row">
    @* Publicaciones (MercadoLibre): solo visible para INTERVENT *@
    @if (ShowMlWidgets)
    {
        <div class="dashboard-detail-card">
            <div class="detail-card-header">
                <div class="detail-card-icon primary">@SvgIcons.Tag</div>
                <div>
                    <span class="detail-card-value">@totalItems</span>
                    <span class="detail-card-label">Publicaciones</span>
                </div>
                <div class="detail-card-badge warning">@itemsSinProducto sin producto</div>
            </div>

            @if (accountStats.Any())
            {
                <table class="detail-card-table">
                    <thead>
                        <tr>
                            <th>Cuenta</th>
                            <th>Publicaciones</th>
                            <th>Con producto</th>
                            <th>Sin producto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in accountStats)
                        {
                            <tr>
                                <td><strong>@acc.Nickname</strong></td>
                                <td>@acc.TotalItems</td>
                                <td>@acc.ItemsConProducto</td>
                                <td class="@(acc.ItemsSinProducto > 0 ? "text-warning-bold" : "")">@acc.ItemsSinProducto</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <div class="dashboard-detail-card">
        <div class="detail-card-header">
            <div class="detail-card-icon info">@SvgIcons.Box</div>
            <div>
                <span class="detail-card-value">@totalProducts</span>
                <span class="detail-card-label">Productos</span>
            </div>
            @if (ShowMlWidgets)
            {
                <div class="detail-card-badge warning">@productosSinItems sin publicacion</div>
            }
        </div>

        @if (ShowMlWidgets && accountStats.Any())
        {
            <table class="detail-card-table">
                <thead>
                    <tr>
                        <th>Cuenta</th>
                        <th>Productos vinculados</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var acc in accountStats)
                    {
                        <tr>
                            <td><strong>@acc.Nickname</strong></td>
                            <td>@acc.ProductosVinculados</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
} @* fin @if (!isDepositoOnly) *@

@code {
    private string username = "usuario";
    // 2026-05-30: hide widgets dashboard para usuarios SOLO depósito.
    private List<string> userPermissions = new();
    private bool isDepositoOnly => userPermissions.Contains("deposito")
        && !userPermissions.Contains("cafe")
        && !userPermissions.Contains("oficina");
    private string totalItems = "--";
    private string totalProducts = "--";
    private string itemsSinProducto = "--";
    private string productosSinItems = "--";
    private List<AccountStatsRow> accountStats = new();

    // Widgets nuevos
    private DolarBnaDto? dolar;
    private bool dolarLoading = true;
    private DateTime arTime;
    private DateTime esTime;
    private System.Threading.Timer? clockTimer;
    private System.Threading.Timer? quoteTimer;
    private System.Threading.Timer? coffeeTimer;
    private CoffeeMonthlyKgDto? coffeeKg;
    private CoffeeStockKgDto? coffeeStock;
    private System.Threading.Timer? salesSummaryTimer;
    private SalesSummaryDto? salesSummary;
    private Web.Models.SaldoBancoDto? saldoBanco;
    private Web.Models.FilesStatsDto? docStats;


    // Cache-buster para la imagen de fondo (cuando se reemplaza, sube este numero
    // y el navegador recarga la URL en vez de usar la version cacheada).
    private long bgVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
    private bool cafeBgUploading;

    private static readonly TimeZoneInfo ArgentinaTz = SafeTz("America/Argentina/Buenos_Aires", -3);
    private static readonly TimeZoneInfo SpainTz = SafeTz("Europe/Madrid", 1);

    // MercadoLibre solo aplica a INTERVENT. Si no hay empresa elegida, lo mostramos
    // para mantener compatibilidad con usuarios que todavia no eligieron empresa.
    private bool ShowMlWidgets =>
        !Company.HasCompany ||
        string.Equals(Company.Current, "INTERVENT", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            // 2026-05-30: cargar permisos para ocultar widgets a usuarios solo depósito.
            userPermissions = user.Permissions ?? new();
        }

        // Re-renderizar cuando el usuario cambia de empresa desde el topbar
        Company.OnChange += OnCompanyChanged;

        // Inicializar relojes y arrancar timer que actualiza cada segundo.
        UpdateClocks();
        clockTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            UpdateClocks();
            StateHasChanged();
        }), null, 1000, 1000);

        // Cargar cotizacion dolar BNA y refrescar cada 5 minutos.
        _ = LoadDolarAsync();
        quoteTimer = new System.Threading.Timer(_ => InvokeAsync(LoadDolarAsync), null,
            TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));

        // Contador de café FRIKAF vendido en el mes: cargar y refrescar cada 30 segundos
        _ = LoadCoffeeKgAsync();
        coffeeTimer = new System.Threading.Timer(_ => InvokeAsync(LoadCoffeeKgAsync), null,
            TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        // Resumen financiero (ventas del mes + saldos): refrescar cada 30 segundos
        _ = LoadSalesSummaryAsync();
        salesSummaryTimer = new System.Threading.Timer(_ => InvokeAsync(LoadSalesSummaryAsync), null,
            TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        // Stats de la carpeta de Documentacion para la card del dashboard.
        _ = LoadDocStatsAsync();


        try
        {
            var stats = await Api.GetDashboardStatsAsync();
            if (stats is not null)
            {
                totalItems = stats.TotalItems.ToString();
                totalProducts = stats.TotalProducts.ToString();
                itemsSinProducto = stats.ItemsSinProducto.ToString();
                productosSinItems = stats.ProductosSinItems.ToString();
                accountStats = stats.AccountStats;
            }
        }
        catch
        {
            // defaults already set
        }
    }

    private void UpdateClocks()
    {
        var nowUtc = DateTime.UtcNow;
        arTime = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, ArgentinaTz);
        esTime = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, SpainTz);
    }

