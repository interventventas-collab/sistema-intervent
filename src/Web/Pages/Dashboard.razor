@page "/"
@page "/index.html"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject AuthService AuthService
@inject OperatorService Operator
@inject ToastService ToastService
@inject CurrentCompanyService Company

<div class="view-header">
    <h2>Bienvenido, @username</h2>
    <p class="view-subtitle">Panel de control</p>
</div>

@* Fila superior: HOLA MUNDO + 3 widgets (dolar BNA, reloj AR, reloj ES) *@
<div style="display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 0.8rem; margin-bottom: 1rem;">
    <div class="dashboard-detail-card" style="padding: 1rem; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem;">
        <span style="font-size: 1.2rem; font-weight: 700;">👋 HOLA EQUIPO:</span>
        <select class="form-input" style="font-size: 1rem; font-weight: 700; max-width: 220px;"
                value="@(Operator.Current ?? "")"
                @onchange="OnSelectOperator">
            <option value="">— Elegi tu nombre —</option>
            @foreach (var op in OperatorService.Operators)
            {
                <option value="@op">@op</option>
            }
        </select>
        @if (Operator.HasOperator)
        {
            <div style="font-size: 0.78rem; color: #6b7280;">Estás trabajando como <strong>@Operator.Current</strong></div>
        }
    </div>

    @* Widget Dolar BNA *@
    <div class="dashboard-detail-card" style="padding: 0.85rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem;">
            <span style="font-size: 1.4rem;">💵</span>
            <div>
                <div style="font-weight: 700; font-size: 0.85rem;">Dolar Banco Nacion</div>
                <div style="font-size: 0.7rem; color: #6b7280;">@(dolar?.Fecha ?? "Cargando...")</div>
            </div>
        </div>
        @if (dolarLoading && dolar is null)
        {
            <div style="font-size: 0.8rem; color: #6b7280;">Consultando BNA...</div>
        }
        else if (dolar is not null && dolar.Compra is not null && dolar.Venta is not null)
        {
            <div style="display: flex; justify-content: space-around; align-items: center; padding-top: 0.3rem;">
                <div style="text-align: center;">
                    <div style="font-size: 0.7rem; color: #15803d; font-weight: 600;">COMPRA</div>
                    <div style="font-size: 1.2rem; font-weight: 800; color: #15803d;">$@FormatMoney(dolar.Compra.Value)</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 0.7rem; color: #b91c1c; font-weight: 600;">VENTA</div>
                    <div style="font-size: 1.2rem; font-weight: 800; color: #b91c1c;">$@FormatMoney(dolar.Venta.Value)</div>
                </div>
            </div>
        }
        else
        {
            <div style="font-size: 0.78rem; color: #b91c1c;">@(dolar?.Error ?? "No se pudo obtener la cotizacion")</div>
        }
    </div>

    @* Reloj Argentina *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; text-align: center;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.5rem;">🇦🇷</span>
            <strong style="font-size: 0.9rem;">Argentina</strong>
        </div>
        <div style="font-size: 1.6rem; font-weight: 800; font-family: 'Courier New', monospace; line-height: 1.2;">
            @arTime.ToString("HH:mm:ss")
        </div>
        <div style="font-size: 0.72rem; color: #6b7280;">@arTime.ToString("dddd dd/MM/yyyy", new System.Globalization.CultureInfo("es-AR"))</div>
    </div>

    @* Reloj España *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; text-align: center;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.5rem;">🇪🇸</span>
            <strong style="font-size: 0.9rem;">España</strong>
        </div>
        <div style="font-size: 1.6rem; font-weight: 800; font-family: 'Courier New', monospace; line-height: 1.2;">
            @esTime.ToString("HH:mm:ss")
        </div>
        <div style="font-size: 0.72rem; color: #6b7280;">@esTime.ToString("dddd dd/MM/yyyy", new System.Globalization.CultureInfo("es-ES"))</div>
    </div>

    @* Contador de café FRIKAF vendido en el mes *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; text-align: center; background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%); border: 1px solid #f59e0b;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.5rem;">☕</span>
            <strong style="font-size: 0.9rem; color: #78350f;">Café FRIKAF</strong>
        </div>
        @if (coffeeKg is null)
        {
            <div style="font-size: 1rem; color: #92400e;">Cargando...</div>
        }
        else
        {
            <div style="font-size: 1.6rem; font-weight: 800; color: #78350f; line-height: 1.2;">
                @FormatKg(coffeeKg.KgTotal) <span style="font-size: 0.95rem; font-weight: 600;">kg</span>
            </div>
            <div style="font-size: 0.7rem; color: #92400e;">
                vendidos en @coffeeKg.PeriodStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))
            </div>
            <div style="font-size: 0.65rem; color: #b45309; margin-top: 0.15rem;">
                @coffeeKg.Sales venta@(coffeeKg.Sales == 1 ? "" : "s") · @coffeeKg.Items línea@(coffeeKg.Items == 1 ? "" : "s")
            </div>
        }
    </div>
</div>

@* === Fila de KPIs financieros: Ventas del mes / Saldos clientes / Cuentas a pagar === *@
<div class="dashboard-cards-row">
    @* Ventas del mes *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%); border: 1px solid #10b981;">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">💵</span>
            <strong style="font-size: 0.85rem; color: #065f46;">Ventas del mes</strong>
        </div>
        @if (salesSummary is null)
        {
            <div style="font-size: 1rem; color: #047857;">Cargando...</div>
        }
        else
        {
            <div style="font-size: 1.5rem; font-weight: 800; color: #065f46; line-height: 1.2;">
                $@FormatMoney(salesSummary.MonthlySalesTotal)
            </div>
            <div style="font-size: 0.72rem; color: #047857; margin-top: 0.15rem;">
                @salesSummary.MonthlySalesCount comprobante@(salesSummary.MonthlySalesCount == 1 ? "" : "s") en @salesSummary.PeriodStart.ToString("MMMM", new System.Globalization.CultureInfo("es-AR"))
            </div>
        }
    </div>

    @* Saldos de clientes *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%); border: 1px solid #ef4444;">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">📋</span>
            <strong style="font-size: 0.85rem; color: #991b1b;">Saldos de clientes</strong>
        </div>
        @if (salesSummary is null)
        {
            <div style="font-size: 1rem; color: #b91c1c;">Cargando...</div>
        }
        else
        {
            <div style="font-size: 1.5rem; font-weight: 800; color: #991b1b; line-height: 1.2;">
                $@FormatMoney(salesSummary.ClientBalanceTotal)
            </div>
            <div style="font-size: 0.72rem; color: #b91c1c; margin-top: 0.15rem;">
                @salesSummary.ClientsWithBalance cliente@(salesSummary.ClientsWithBalance == 1 ? "" : "s") · @salesSummary.ClientBalanceCount comprobante@(salesSummary.ClientBalanceCount == 1 ? "" : "s") sin pagar
            </div>
        }
    </div>

    @* Cuentas a pagar (en construccion) *@
    <div class="dashboard-detail-card" style="padding: 0.85rem; background: #f3f4f6; border: 1px dashed #9ca3af; opacity: 0.85;">
        <div style="display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem;">
            <span style="font-size: 1.3rem;">🧾</span>
            <strong style="font-size: 0.85rem; color: #4b5563;">Cuentas a pagar</strong>
        </div>
        <div style="font-size: 1rem; font-weight: 700; color: #6b7280; line-height: 1.2;">
            🚧 En construcción
        </div>
        <div style="font-size: 0.7rem; color: #6b7280; margin-top: 0.15rem;">
            Pronto: facturas de proveedores con vencimientos
        </div>
    </div>
</div>

<div class="dashboard-cards-row">
    @* Publicaciones (MercadoLibre): solo visible para INTERVENT *@
    @if (ShowMlWidgets)
    {
        <div class="dashboard-detail-card">
            <div class="detail-card-header">
                <div class="detail-card-icon primary">@SvgIcons.Tag</div>
                <div>
                    <span class="detail-card-value">@totalItems</span>
                    <span class="detail-card-label">Publicaciones</span>
                </div>
                <div class="detail-card-badge warning">@itemsSinProducto sin producto</div>
            </div>

            @if (accountStats.Any())
            {
                <table class="detail-card-table">
                    <thead>
                        <tr>
                            <th>Cuenta</th>
                            <th>Publicaciones</th>
                            <th>Con producto</th>
                            <th>Sin producto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in accountStats)
                        {
                            <tr>
                                <td><strong>@acc.Nickname</strong></td>
                                <td>@acc.TotalItems</td>
                                <td>@acc.ItemsConProducto</td>
                                <td class="@(acc.ItemsSinProducto > 0 ? "text-warning-bold" : "")">@acc.ItemsSinProducto</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    <div class="dashboard-detail-card">
        <div class="detail-card-header">
            <div class="detail-card-icon info">@SvgIcons.Box</div>
            <div>
                <span class="detail-card-value">@totalProducts</span>
                <span class="detail-card-label">Productos</span>
            </div>
            @if (ShowMlWidgets)
            {
                <div class="detail-card-badge warning">@productosSinItems sin publicacion</div>
            }
        </div>

        @if (ShowMlWidgets && accountStats.Any())
        {
            <table class="detail-card-table">
                <thead>
                    <tr>
                        <th>Cuenta</th>
                        <th>Productos vinculados</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var acc in accountStats)
                    {
                        <tr>
                            <td><strong>@acc.Nickname</strong></td>
                            <td>@acc.ProductosVinculados</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private string username = "usuario";
    private string totalItems = "--";
    private string totalProducts = "--";
    private string itemsSinProducto = "--";
    private string productosSinItems = "--";
    private List<AccountStatsRow> accountStats = new();

    // Widgets nuevos
    private DolarBnaDto? dolar;
    private bool dolarLoading = true;
    private DateTime arTime;
    private DateTime esTime;
    private System.Threading.Timer? clockTimer;
    private System.Threading.Timer? quoteTimer;
    private System.Threading.Timer? coffeeTimer;
    private CoffeeMonthlyKgDto? coffeeKg;
    private System.Threading.Timer? salesSummaryTimer;
    private SalesSummaryDto? salesSummary;

    private static readonly TimeZoneInfo ArgentinaTz = SafeTz("America/Argentina/Buenos_Aires", -3);
    private static readonly TimeZoneInfo SpainTz = SafeTz("Europe/Madrid", 1);

    // MercadoLibre solo aplica a INTERVENT. Si no hay empresa elegida, lo mostramos
    // para mantener compatibilidad con usuarios que todavia no eligieron empresa.
    private bool ShowMlWidgets =>
        !Company.HasCompany ||
        string.Equals(Company.Current, "INTERVENT", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
        }

        // Re-renderizar cuando el usuario cambia de empresa desde el topbar
        Company.OnChange += OnCompanyChanged;

        // Inicializar relojes y arrancar timer que actualiza cada segundo.
        UpdateClocks();
        clockTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            UpdateClocks();
            StateHasChanged();
        }), null, 1000, 1000);

        // Cargar cotizacion dolar BNA y refrescar cada 5 minutos.
        _ = LoadDolarAsync();
        quoteTimer = new System.Threading.Timer(_ => InvokeAsync(LoadDolarAsync), null,
            TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));

        // Contador de café FRIKAF vendido en el mes: cargar y refrescar cada 30 segundos
        _ = LoadCoffeeKgAsync();
        coffeeTimer = new System.Threading.Timer(_ => InvokeAsync(LoadCoffeeKgAsync), null,
            TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        // Resumen financiero (ventas del mes + saldos): refrescar cada 30 segundos
        _ = LoadSalesSummaryAsync();
        salesSummaryTimer = new System.Threading.Timer(_ => InvokeAsync(LoadSalesSummaryAsync), null,
            TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        try
        {
            var stats = await Api.GetDashboardStatsAsync();
            if (stats is not null)
            {
                totalItems = stats.TotalItems.ToString();
                totalProducts = stats.TotalProducts.ToString();
                itemsSinProducto = stats.ItemsSinProducto.ToString();
                productosSinItems = stats.ProductosSinItems.ToString();
                accountStats = stats.AccountStats;
            }
        }
        catch
        {
            // defaults already set
        }
    }

    private void UpdateClocks()
    {
        var nowUtc = DateTime.UtcNow;
        arTime = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, ArgentinaTz);
        esTime = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, SpainTz);
    }

    private async Task LoadDolarAsync()
    {
        try
        {
            dolar = await Api.GetDolarBnaAsync();
        }
        catch (Exception ex)
        {
            dolar = new DolarBnaDto { Error = ex.Message };
        }
        dolarLoading = false;
        StateHasChanged();
    }

    private async Task LoadCoffeeKgAsync()
    {
        try
        {
            coffeeKg = await Api.GetCoffeeMonthlyKgAsync();
        }
        catch
        {
            // Mantener el valor anterior si falla, no romper el dashboard
        }
        StateHasChanged();
    }

    private async Task LoadSalesSummaryAsync()
    {
        try
        {
            salesSummary = await Api.GetSalesSummaryAsync();
        }
        catch
        {
            // Mantener el valor anterior si falla
        }
        StateHasChanged();
    }

    /// <summary>Formatea kg con punto y coma argentinos: 12.345,5 → "12.345,5".</summary>
    private static string FormatKg(decimal value)
    {
        var s = value.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        // Si tiene parte decimal, separar
        var parts = s.Split('.');
        var intPart = parts[0];
        var decPart = parts.Length > 1 ? parts[1] : "";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) sb.Append('.');
            sb.Append(intPart[i]);
        }
        return decPart.Length > 0 ? $"{sb},{decPart}" : sb.ToString();
    }

    private async Task OnSelectOperator(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        await Operator.SetAsync(string.IsNullOrWhiteSpace(name) ? null : name);
        if (!string.IsNullOrWhiteSpace(name))
            ToastService.Success($"Trabajando como {name}");
    }

    private static string FormatMoney(decimal value)
    {
        var parts = value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture).Split('.');
        var intPart = parts[0]; var decPart = parts.Length > 1 ? parts[1] : "00";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) sb.Append('.');
            sb.Append(intPart[i]);
        }
        return sb + "," + decPart;
    }

    private static TimeZoneInfo SafeTz(string id, int offsetHours)
    {
        try { return TimeZoneInfo.FindSystemTimeZoneById(id); }
        catch { return TimeZoneInfo.CreateCustomTimeZone(id, TimeSpan.FromHours(offsetHours), id, id); }
    }

    public void Dispose()
    {
        clockTimer?.Dispose();
        quoteTimer?.Dispose();
        coffeeTimer?.Dispose();
        salesSummaryTimer?.Dispose();
        Company.OnChange -= OnCompanyChanged;
    }

    private void OnCompanyChanged() => InvokeAsync(StateHasChanged);
}
