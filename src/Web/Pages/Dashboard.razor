@* 2026-06-05: modal de clave para activar operador protegido (OSMAR) desde el dropdown. *@
@if (showProtectedOperatorModal)
{
    <div class="modal-overlay" style="z-index: 9100;" @onclick="CancelProtectedOperator">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background:#fef3c7;">
                <h3 style="margin:0;">🔒 Confirmar clave de @pendingProtectedOperator</h3>
                <button class="btn-close" @onclick="CancelProtectedOperator">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color:#6b7280; margin: 0 0 0.7rem;">
                    Para trabajar como <strong>@pendingProtectedOperator</strong> ingresá la clave (la misma que usás para eliminar comprobantes).
                </p>
                @if (!string.IsNullOrEmpty(protectedOperatorError))
                {
                    <div class="form-error" style="margin-bottom:0.5rem;">@protectedOperatorError</div>
                }
                <input class="form-input" type="password" @bind="protectedOperatorPassword"
                       @bind:event="oninput" @onkeydown="OnProtectedOperatorKeyDown"
                       placeholder="••••••••" autofocus />
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CancelProtectedOperator">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmProtectedOperator"
                        disabled="@(string.IsNullOrEmpty(protectedOperatorPassword) || validatingProtectedOperator)">
                    @(validatingProtectedOperator ? "Validando..." : "Activar")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string username = "usuario";
    // 2026-05-30: hide widgets dashboard para usuarios SOLO depósito.
    private List<string> userPermissions = new();
    private bool isDepositoOnly => userPermissions.Contains("deposito")
        && !userPermissions.Contains("cafe")
        && !userPermissions.Contains("oficina");
    private string totalItems = "--";
    private string totalProducts = "--";
    private string itemsSinProducto = "--";
    private string productosSinItems = "--";
    private List<AccountStatsRow> accountStats = new();

    // Widgets nuevos
    private DolarBnaDto? dolar;
    private bool dolarLoading = true;
    private DateTime arTime;
    private DateTime esTime;
    private System.Threading.Timer? clockTimer;
    private System.Threading.Timer? quoteTimer;
    private System.Threading.Timer? coffeeTimer;
    private CoffeeMonthlyKgDto? coffeeKg;
    // 2026-06-05: histórico balanza (tooltip al hover)
    private List<ApiClient.CoffeeMonthlyHistoricoRow>? historicoMeses;
    private bool mostrandoHistorico;

    private async Task MostrarHistoricoBalanza()
    {
        mostrandoHistorico = true;
        if (historicoMeses is null)
        {
            try { historicoMeses = await Api.GetCoffeeMonthlyKgHistoricoAsync(12); } catch { historicoMeses = new(); }
        }
        StateHasChanged();
    }
    private void OcultarHistoricoBalanza()
    {
        mostrandoHistorico = false;
        StateHasChanged();
    }
    private CoffeeStockKgDto? coffeeStock;
    private System.Threading.Timer? salesSummaryTimer;
    private SalesSummaryDto? salesSummary;
    private Web.Models.SaldoBancoDto? saldoBanco;
    private Web.Models.FilesStatsDto? docStats;


    // Cache-buster para la imagen de fondo (cuando se reemplaza, sube este numero
    // y el navegador recarga la URL en vez de usar la version cacheada).
    private long bgVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
    private bool cafeBgUploading;

    private static readonly TimeZoneInfo ArgentinaTz = SafeTz("America/Argentina/Buenos_Aires", -3);
    private static readonly TimeZoneInfo SpainTz = SafeTz("Europe/Madrid", 1);

    // MercadoLibre solo aplica a INTERVENT. Si no hay empresa elegida, lo mostramos
    // para mantener compatibilidad con usuarios que todavia no eligieron empresa.
    private bool ShowMlWidgets =>
        !Company.HasCompany ||
        string.Equals(Company.Current, "INTERVENT", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            // 2026-05-30: cargar permisos para ocultar widgets a usuarios solo depósito.
            userPermissions = user.Permissions ?? new();
        }

        // Re-renderizar cuando el usuario cambia de empresa desde el topbar
        Company.OnChange += OnCompanyChanged;

        // Inicializar relojes y arrancar timer que actualiza cada segundo.
        UpdateClocks();
        clockTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            UpdateClocks();
            StateHasChanged();
        }), null, 1000, 1000);

        // Cargar cotizacion dolar BNA y refrescar cada 5 minutos.
        _ = LoadDolarAsync();
        quoteTimer = new System.Threading.Timer(_ => InvokeAsync(LoadDolarAsync), null,
            TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));

        // Contador de café FRIKAF vendido en el mes: cargar y refrescar cada 30 segundos
        _ = LoadCoffeeKgAsync();
        coffeeTimer = new System.Threading.Timer(_ => InvokeAsync(LoadCoffeeKgAsync), null,
            TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        // Resumen financiero (ventas del mes + saldos): refrescar cada 30 segundos
        _ = LoadSalesSummaryAsync();
        salesSummaryTimer = new System.Threading.Timer(_ => InvokeAsync(LoadSalesSummaryAsync), null,
            TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        // Stats de la carpeta de Documentacion para la card del dashboard.
        _ = LoadDocStatsAsync();


        try
        {
            var stats = await Api.GetDashboardStatsAsync();
            if (stats is not null)
            {
                totalItems = stats.TotalItems.ToString();
                totalProducts = stats.TotalProducts.ToString();
                itemsSinProducto = stats.ItemsSinProducto.ToString();
                productosSinItems = stats.ProductosSinItems.ToString();
                accountStats = stats.AccountStats;
            }
        }
        catch
        {
            // defaults already set
        }
    }

    private void UpdateClocks()
    {
        var nowUtc = DateTime.UtcNow;
        arTime = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, ArgentinaTz);
        esTime = TimeZoneInfo.ConvertTimeFromUtc(nowUtc, SpainTz);
    }

    private async Task LoadDolarAsync()
    {
        try
        {
            dolar = await Api.GetDolarBnaAsync();
        }
        catch (Exception ex)
        {
            dolar = new DolarBnaDto { Error = ex.Message };
        }
        dolarLoading = false;
        StateHasChanged();
    }

    private async Task LoadCoffeeKgAsync()
    {
        try
        {
            coffeeKg = await Api.GetCoffeeMonthlyKgAsync();
        }
        catch
        {
            // Mantener el valor anterior si falla, no romper el dashboard
        }
        try
        {
            coffeeStock = await Api.GetCoffeeStockKgAsync();
        }
        catch { /* idem */ }
        StateHasChanged();
    }

    private async Task LoadSalesSummaryAsync()
    {
        try
        {
            salesSummary = await Api.GetSalesSummaryAsync();
        }
        catch
        {
            // Mantener el valor anterior si falla
        }
        try
        {
            saldoBanco = await Api.GetSaldoBancoAsync();
        }
        catch { /* idem, opcional */ }
        StateHasChanged();
    }

    private async Task LoadDocStatsAsync()
    {
        try
        {
            docStats = await Api.GetFilesStatsAsync("Documentacion-Importante");
        }
        catch { /* opcional, no rompe */ }
        StateHasChanged();
    }

    /// <summary>Subir la imagen elegida como fondo de la card "Café FRIKAF".</summary>
    private async Task OnCafeBgFilePicked(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        if (e.File is null) return;
        await UploadCafeBg(e.File);
    }

    private async Task UploadCafeBg(Microsoft.AspNetCore.Components.Forms.IBrowserFile file)
    {
        cafeBgUploading = true;
        StateHasChanged();
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB
            await Api.UploadBrandingImageAsync("cafe-frikaf-bg", stream, file.Name, file.ContentType);
            // Actualizar version → fuerza al navegador a recargar la imagen
            bgVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            ToastService.Success("Imagen actualizada ✓");
        }
        catch (Exception ex)
        {
            ToastService.Error("No se pudo subir la imagen: " + ex.Message);
        }
        finally
        {
            cafeBgUploading = false;
            StateHasChanged();
        }
    }

    /// <summary>Formatea kg con punto y coma argentinos: 12.345,5 → "12.345,5".</summary>
    private static string FormatKg(decimal value)
    {
        var s = value.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        // Si tiene parte decimal, separar
        var parts = s.Split('.');
        var intPart = parts[0];
        var decPart = parts.Length > 1 ? parts[1] : "";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) sb.Append('.');
            sb.Append(intPart[i]);
        }
        return decPart.Length > 0 ? $"{sb},{decPart}" : sb.ToString();
    }

    private async Task OnSelectOperator(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        // 2026-06-05: si eligio un operador protegido (formato __PROTECTED__OSMAR),
        // abrir modal para pedir clave antes de activarlo.
        if (!string.IsNullOrWhiteSpace(name) && name.StartsWith("__PROTECTED__"))
        {
            var realName = name["__PROTECTED__".Length..];
            pendingProtectedOperator = realName;
            protectedOperatorPassword = "";
            protectedOperatorError = "";
            showProtectedOperatorModal = true;
            StateHasChanged();
            return;
        }
        await Operator.SetAsync(string.IsNullOrWhiteSpace(name) ? null : name);
        if (!string.IsNullOrWhiteSpace(name))
            ToastService.Success($"Trabajando como {name}");
    }

    // 2026-06-05: modal de clave para activar OSMAR desde el dropdown del dashboard.
    private bool showProtectedOperatorModal = false;
    private string pendingProtectedOperator = "";
    private string protectedOperatorPassword = "";
    private string protectedOperatorError = "";
    private bool validatingProtectedOperator = false;

    private void CancelProtectedOperator()
    {
        showProtectedOperatorModal = false;
        pendingProtectedOperator = "";
        protectedOperatorPassword = "";
        protectedOperatorError = "";
    }

    private async Task OnProtectedOperatorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(protectedOperatorPassword))
            await ConfirmProtectedOperator();
    }

    private async Task ConfirmProtectedOperator()
    {
        if (string.IsNullOrEmpty(protectedOperatorPassword)) return;
        validatingProtectedOperator = true;
        protectedOperatorError = "";
        try
        {
            var ok = await Api.ValidateProtectedOperatorAsync(protectedOperatorPassword);
            if (!ok)
            {
                protectedOperatorError = "Clave incorrecta.";
                validatingProtectedOperator = false;
                return;
            }
            await Operator.SetAsync(pendingProtectedOperator);
            ToastService.Success($"Trabajando como {pendingProtectedOperator}");
            showProtectedOperatorModal = false;
            pendingProtectedOperator = "";
            protectedOperatorPassword = "";
        }
        catch (Exception ex) { protectedOperatorError = ex.Message; }
        finally { validatingProtectedOperator = false; }
    }

    private static string FormatMoney(decimal value)
    {
        var parts = value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture).Split('.');
        var intPart = parts[0]; var decPart = parts.Length > 1 ? parts[1] : "00";
        var sb = new System.Text.StringBuilder();
        for (int i = 0; i < intPart.Length; i++)
        {
            if (i > 0 && (intPart.Length - i) % 3 == 0) sb.Append('.');
            sb.Append(intPart[i]);
        }
        return sb + "," + decPart;
    }

    /// <summary>Formato amigable de fecha+hora: "hoy a las 17:45 hs", "ayer a las 09:30 hs",
    /// "20/05 a las 17:45 hs". Convierte de UTC a Argentina antes de mostrar.</summary>
    private static string FormatearUltimaActualizacion(DateTime utcDate)
    {
        var dt = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utcDate, DateTimeKind.Utc), ArgentinaTz);
        var hoy = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, ArgentinaTz).Date;
        var fechaSolo = dt.Date;
        if (fechaSolo == hoy) return $"hoy a las {dt:HH:mm} hs";
        if (fechaSolo == hoy.AddDays(-1)) return $"ayer a las {dt:HH:mm} hs";
        return $"{dt:dd/MM} a las {dt:HH:mm} hs";
    }

    private static TimeZoneInfo SafeTz(string id, int offsetHours)
    {
        try { return TimeZoneInfo.FindSystemTimeZoneById(id); }
        catch { return TimeZoneInfo.CreateCustomTimeZone(id, TimeSpan.FromHours(offsetHours), id, id); }
    }

    public void Dispose()
    {
        clockTimer?.Dispose();
        quoteTimer?.Dispose();
        coffeeTimer?.Dispose();
        salesSummaryTimer?.Dispose();
        Company.OnChange -= OnCompanyChanged;
    }

    private void OnCompanyChanged() => InvokeAsync(StateHasChanged);
}
