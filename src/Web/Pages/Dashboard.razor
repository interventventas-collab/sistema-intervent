@page "/"
@page "/index.html"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject AuthService AuthService
@inject OperatorService Operator
@inject ToastService ToastService
@inject CurrentCompanyService Company
@inject NavigationManager Navigation

<div class="view-header">
    <h2>Bienvenido, @username</h2>
    <p class="view-subtitle">Panel de control</p>
</div>

@* 2026-05-30: para usuarios SOLO depósito (sin cafe ni oficina), ocultar todos los
   widgets del dashboard — ellos operan solo desde el sidebar (Imprimir pedidos,
   Productos, Stock). El resto sigue viendo el dashboard normal. *@
@if (!isDepositoOnly)
{
@* 2026-06-22: rediseño Mac/iOS — tarjetas blancas, bordes finos, iconos SVG uniformes.
   Las acciones y dropdowns NO cambian: misma logica, mismas rutas. *@
@* 2026-06-25: cards "Operador", "Hora" y "Dólar" grandes se sacaron del dashboard.
   El nombre del operador y la hora viven ahora en el topbar; el dólar va en el strip mini
   de arriba. Lo que importa al arrancar el día (equipo + cheques + Meli) sube de prioridad. *@

@* ═══ Strip mini de stats: dólar + balanza + stock (compacto, ocupa 1 línea) ═══ *@
<div class="dash-strip">
    <div class="dash-strip-item">
        <div class="dash-strip-ico" style="background:#eaf3de; color:#16a34a;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <div class="dash-strip-body">
            <span class="dash-strip-label">Dólar BNA @(dolar?.Fecha is null ? "" : "· " + dolar.Fecha)</span>
            @if (dolar is not null && dolar.Compra is not null && dolar.Venta is not null)
            {
                <span class="dash-strip-value">
                    <span style="color:#16a34a;">$@FormatMoney(dolar.Compra.Value)</span>
                    <span style="color:#9ca3af; margin:0 4px;">/</span>
                    <span style="color:#dc2626;">$@FormatMoney(dolar.Venta.Value)</span>
                </span>
            }
            else
            {
                <span class="dash-strip-value" style="color:#9ca3af;">…</span>
            }
        </div>
    </div>
    <div class="dash-strip-item">
        <div class="dash-strip-ico" style="background:#faeeda; color:#d97706;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M6 6l6-1l6 1"/><path d="M12 3v17"/><path d="M9 12L6 6l-3 6a3 3 0 006 0z"/><path d="M21 12l-3-6l-3 6a3 3 0 006 0z"/></svg>
        </div>
        <div class="dash-strip-body">
            <span class="dash-strip-label">Balanza @(coffeeKg is not null ? coffeeKg.PeriodStart.ToString("MMM", new System.Globalization.CultureInfo("es-AR")) : "")</span>
            <span class="dash-strip-value">@(coffeeKg is null ? "…" : $"{FormatKg(coffeeKg.KgTotal)} kg")</span>
        </div>
    </div>
    <div class="dash-strip-item">
        <div class="dash-strip-ico" style="background:#eaf3de; color:#16a34a;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/></svg>
        </div>
        <div class="dash-strip-body">
            <span class="dash-strip-label">Stock total @(coffeeStock is null ? "" : $"· {coffeeStock.VariedadesConStock}/{coffeeStock.Variedades} variedades")</span>
            <span class="dash-strip-value">@(coffeeStock is null ? "…" : $"{FormatKg(coffeeStock.KgTotal)} kg")</span>
        </div>
    </div>
</div>

@* ═══ Card: equipo trabajando ahora ═══ *@
<div class="dash-card">
    <div class="dash-card-title">
        <span class="dash-card-title-ico"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
        Equipo trabajando ahora
        <span class="dash-card-title-pill">en vivo</span>
        @if (equipoResp?.Resumen is not null)
        {
            <span class="dash-equipo-summary">
                <span><span class="dash-dot" style="background:#16a34a;"></span>@equipoResp.Resumen.Trabajando trabajando</span>
                <span><span class="dash-dot" style="background:#3b82f6;"></span>@equipoResp.Resumen.Salio salió</span>
                <span><span class="dash-dot" style="background:#dc2626;"></span>@equipoResp.Resumen.SinFichar sin fichar</span>
            </span>
        }
    </div>
    @if (equipoLoading && equipoResp is null)
    {
        <div class="dash-card-sub">Cargando equipo…</div>
    }
    else if (equipoResp is not null && equipoResp.Items.Count > 0)
    {
        <div class="dash-equipo-grid">
            @foreach (var emp in equipoResp.Items)
            {
                <button class="dash-emp-tile dash-emp-tile-btn" @onclick="() => OpenEmpDetalle(emp)" title="Ver detalle">
                    <div class="dash-emp-head">
                        <div class="dash-emp-avatar" style="background:@OperatorService.ShortBgColor(emp.ApodoKiosko ?? emp.Nombre);">@AvatarLabel(emp)</div>
                        <div style="min-width:0; text-align:left;">
                            <div class="dash-emp-name">@ShortName(emp.Nombre)</div>
                            <div class="dash-emp-status">
                                <span class="dash-dot" style="background:@EstadoColor(emp.Estado);"></span>@EstadoTexto(emp)
                            </div>
                        </div>
                    </div>
                    <div class="dash-emp-rinde">
                        @if (!emp.TieneRepartidor)
                        {
                            <span class="dash-emp-rinde-label">No reparte</span>
                            <span class="dash-emp-rinde-value muted">—</span>
                        }
                        else if (emp.PorRendir > 0)
                        {
                            <span class="dash-emp-rinde-label">Tiene que rendir</span>
                            <span class="dash-emp-rinde-value warn">$@FormatMoney(emp.PorRendir)</span>
                        }
                        else
                        {
                            <span class="dash-emp-rinde-label">Al día</span>
                            <span class="dash-emp-rinde-value ok">$0</span>
                        }
                    </div>
                    <div class="dash-emp-tile-cta">Ver detalle ›</div>
                </button>
            }
        </div>
    }
    else
    {
        <div class="dash-card-sub">No hay empleados activos para mostrar.</div>
    }
</div>

@* 2026-06-25: modal de detalle de un empleado del card "Equipo trabajando ahora".
   Se abre al hacer click en cualquier tile. Muestra todo el detalle financiero
   (rinde + sueldo + pagué + le debo) y atajos a las pantallas relevantes. *@
@if (empDetalle is not null)
{
    <div class="modal-overlay" style="z-index: 9100;" @onclick="CloseEmpDetalle">
        <div class="modal-card" @onclick:stopPropagation="true" style="max-width: 460px;">
            <div class="modal-header" style="background: @OperatorService.ShortBgColor(empDetalle.ApodoKiosko ?? empDetalle.Nombre); color:white;">
                <div style="display:flex; align-items:center; gap:12px;">
                    <div class="dash-emp-avatar" style="background:rgba(255,255,255,0.25); width:38px; height:38px; font-size:0.9rem;">@AvatarLabel(empDetalle)</div>
                    <div>
                        <h3 style="margin:0; font-size:1.05rem;">@ShortName(empDetalle.Nombre)</h3>
                        <div style="font-size:0.78rem; opacity:0.85; font-variant-numeric:tabular-nums;">@EstadoTexto(empDetalle)</div>
                    </div>
                </div>
                <button class="btn-close" style="color:white;" @onclick="CloseEmpDetalle">&times;</button>
            </div>
            <div class="modal-body" style="padding: 18px 20px;">
                <div style="display:grid; grid-template-columns: 1fr; gap: 12px;">
                    @* Rinde *@
                    <div class="dash-detalle-block">
                        <div class="dash-detalle-label">Cobranzas pendientes de rendir</div>
                        @if (!empDetalle.TieneRepartidor)
                        {
                            <div class="dash-detalle-big muted">— No es repartidor</div>
                        }
                        else if (empDetalle.PorRendir > 0)
                        {
                            <div class="dash-detalle-big warn">$@FormatMoney(empDetalle.PorRendir)</div>
                            @if (empDetalle.PorRendirVentas > 0)
                            {
                                <button class="btn btn-link" style="padding:0; font-size:0.8rem; display:block;"
                                        @onclick='() => { CloseEmpDetalle(); Navigation.NavigateTo("/cafe/cobranzas-pendientes"); }'>
                                    🛒 Aprobar cobranzas de ventas ($@FormatMoney(empDetalle.PorRendirVentas)) ›
                                </button>
                            }
                            @if (empDetalle.PorRendirAlquiler > 0)
                            {
                                <button class="btn btn-link" style="padding:0; font-size:0.8rem; display:block;"
                                        @onclick='() => { CloseEmpDetalle(); Navigation.NavigateTo("/alquileres/cobranzas-pendientes"); }'>
                                    📦 Aprobar cobranzas de alquiler ($@FormatMoney(empDetalle.PorRendirAlquiler)) ›
                                </button>
                            }
                        }
                        else
                        {
                            <div class="dash-detalle-big ok">Al día</div>
                        }
                    </div>

                    @* Sueldo del mes *@
                    <div class="dash-detalle-block">
                        <div class="dash-detalle-label">Sueldo del mes (junio)</div>
                        @if (empDetalle.LeDebo == 0 && empDetalle.Pagado == 0)
                        {
                            <div class="dash-detalle-big muted">Sin liquidación cargada</div>
                            <button class="btn btn-link" style="padding:0; font-size:0.8rem;"
                                    @onclick='() => { CloseEmpDetalle(); Navigation.NavigateTo("/nominas/liquidaciones"); }'>
                                Ir a liquidaciones ›
                            </button>
                        }
                        else
                        {
                            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:8px; margin-top:6px;">
                                <div>
                                    <div class="dash-detalle-sublabel">Le debo</div>
                                    <div class="dash-detalle-mid @(empDetalle.LeDebo > 0 ? "danger" : "muted")">@(empDetalle.LeDebo > 0 ? $"${FormatMoney(empDetalle.LeDebo)}" : "—")</div>
                                </div>
                                <div>
                                    <div class="dash-detalle-sublabel">Pagué este mes</div>
                                    <div class="dash-detalle-mid @(empDetalle.Pagado > 0 ? "ok" : "muted")">@(empDetalle.Pagado > 0 ? $"${FormatMoney(empDetalle.Pagado)}" : "—")</div>
                                </div>
                            </div>
                            <button class="btn btn-link" style="padding:0; font-size:0.8rem; margin-top:8px;"
                                    @onclick='() => { CloseEmpDetalle(); Navigation.NavigateTo("/nominas/panel"); }'>
                                Ver liquidaciones completas ›
                            </button>
                        }
                    </div>

                    @* Apodos (para que sepa cómo aparece en otros lados) *@
                    @if (!string.IsNullOrEmpty(empDetalle.ApodoKiosko) || !string.IsNullOrEmpty(empDetalle.ApodoRepartidor))
                    {
                        <div class="dash-detalle-block" style="background:#f9fafb;">
                            <div class="dash-detalle-label">Aparece como</div>
                            @if (!string.IsNullOrEmpty(empDetalle.ApodoKiosko))
                            {
                                <div style="font-size:0.85rem; color:#374151; margin-top:4px;">
                                    <span style="color:#9ca3af;">En el kiosko:</span> <strong>@empDetalle.ApodoKiosko</strong>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(empDetalle.ApodoRepartidor))
                            {
                                <div style="font-size:0.85rem; color:#374151;">
                                    <span style="color:#9ca3af;">Como repartidor:</span> <strong>@empDetalle.ApodoRepartidor</strong>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ═══ Card: resumen del día (cheques + saldo Galicia + preguntas MeLi) ═══ *@
<div class="dash-card">
    <div class="dash-card-title">
        <span class="dash-card-title-ico"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11H5a2 2 0 00-2 2v7a2 2 0 002 2h14a2 2 0 002-2v-7a2 2 0 00-2-2h-4"/><path d="M9 11V7a3 3 0 016 0v4"/></svg></span>
        Resumen del día
        <span class="dash-card-title-pill">@arTime.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-AR"))</span>
    </div>
    <div class="dash-resumen-grid">
        @* Cheques a cubrir hoy *@
        <div class="dash-resumen-block" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo("/cafe/tesoreria/cheques")' title="Ir a cheques">
            <div class="dash-resumen-head">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                Cheques a cubrir hoy
                @if (resumenDia?.ChequesHoyCantidad > 0)
                {
                    <span class="dash-badge-warn">@resumenDia.ChequesHoyCantidad</span>
                }
            </div>
            <div class="dash-resumen-big">@(resumenDia is null ? "…" : (resumenDia.ChequesHoyCantidad == 0 ? "Nada hoy" : $"${FormatMoney(resumenDia.ChequesHoyImporte)}"))</div>
            @if (resumenDia is not null && resumenDia.ChequesProxima7DiasCantidad > 0)
            {
                <div class="dash-resumen-line"><span>Próximos 7 días</span><span>@resumenDia.ChequesProxima7DiasCantidad cheques · $@FormatMoney(resumenDia.ChequesProxima7DiasImporte)</span></div>
            }
        </div>

        @* Saldo Banco Galicia *@
        <div class="dash-resumen-block" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo("/cafe/tesoreria/extracto-banco")' title="Ir al extracto">
            <div class="dash-resumen-head">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>
                Saldo Banco Galicia
            </div>
            @if (saldoBanco is null || saldoBanco.CantidadMovimientos == 0)
            {
                <div class="dash-resumen-big" style="font-size:14px; color:#9ca3af;">Subí el extracto →</div>
            }
            else
            {
                <div class="dash-resumen-big">$@FormatMoney(saldoBanco.Saldo)</div>
                <div class="dash-resumen-line"><span>al @saldoBanco.UltimaFecha.ToString("dd/MM/yyyy")</span><span>@(saldoBanco.UltimoImportadoAt is null ? "" : $"act. {FormatearUltimaActualizacion(saldoBanco.UltimoImportadoAt.Value)}")</span></div>
            }
        </div>

        @* Preguntas MeLi sin responder *@
        <div class="dash-resumen-block" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo("/meli-preguntas")' title="Ir a preguntas MeLi">
            <div class="dash-resumen-head">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Preguntas MeLi sin responder
                @if (resumenDia?.PreguntasMeliPendientes > 0)
                {
                    <span class="dash-badge-warn">@resumenDia.PreguntasMeliPendientes</span>
                }
            </div>
            <div class="dash-resumen-big">@(resumenDia is null ? "…" : (resumenDia.PreguntasMeliPendientes == 0 ? "Al día" : resumenDia.PreguntasMeliPendientes.ToString()))</div>
            @if (resumenDia is not null && resumenDia.PreguntasMeliNoVistas > 0 && resumenDia.PreguntasMeliNoVistas != resumenDia.PreguntasMeliPendientes)
            {
                <div class="dash-resumen-line"><span>Sin abrir</span><span>@resumenDia.PreguntasMeliNoVistas</span></div>
            }
        </div>

        @* Ventas del mes (un cuarto bloque útil) *@
        <div class="dash-resumen-block" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo("/cafe/ventas")' title="Ir a ventas">
            <div class="dash-resumen-head">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                Ventas del mes
            </div>
            <div class="dash-resumen-big">@(salesSummary is null ? "…" : $"${FormatMoney(salesSummary.MonthlySalesTotal)}")</div>
            @if (salesSummary is not null)
            {
                <div class="dash-resumen-line"><span>@salesSummary.MonthlySalesCount comprobantes</span><span>@salesSummary.PeriodStart.ToString("MMMM", new System.Globalization.CultureInfo("es-AR"))</span></div>
            }
        </div>
    </div>
</div>

@* ═══ Fila vieja: solo postits + (los otros widgets se fueron al strip) ═══ *@
<div class="dashboard-top-grid dashboard-modern">
    @* Postits: block de notas compartido (componente reusable, scope=dashboard) *@
    <PostitsWidget Scope="dashboard" Title="Postits del equipo" CardStyle="max-height: 220px;" />

    @* 2026-06-22: Balanza + Stock unificados en una sola tarjeta partida por un divisor vertical.
       Mitad izquierda = Balanza (con histórico al pasar mouse).
       Mitad derecha = Stock (con ring de variedades). *@
    <div class="dashboard-detail-card mac-card mac-card-split" style="grid-column: span 2; position:relative;">
        @* === Mitad izquierda: BALANZA === *@
        <div class="mac-card-split-half" @onmouseenter="MostrarHistoricoBalanza" @onmouseleave="OcultarHistoricoBalanza">
            <div class="mac-card-header">
                <div class="mac-card-iconbox" style="background:#faeeda; color:#d97706;">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M6 6l6-1l6 1"/><path d="M12 3v17"/><path d="M9 12L6 6l-3 6a3 3 0 006 0z"/><path d="M21 12l-3-6l-3 6a3 3 0 006 0z"/></svg>
                </div>
                <span class="mac-card-eyebrow">Balanza</span>
                <label class="mac-card-iconbtn" title="Cambiar imagen de fondo" style="margin-left:auto;">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    <InputFile OnChange="OnCafeBgFilePicked" accept=".png,.jpg,.jpeg,.webp" style="display: none;" />
                </label>
            </div>
            @if (coffeeKg is null)
            {
                <div class="mac-card-bignum" style="color:#9ca3af;">…</div>
            }
            else
            {
                <div class="mac-card-bignum">@FormatKg(coffeeKg.KgTotal)<span class="mac-card-unit">kg</span></div>
                <div class="mac-card-sub">@coffeeKg.PeriodStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))</div>
                @* 2026-07-01: linea con mes anterior + total (12 meses). Se ve todo el hover al pasar el mouse. *@
                @if (historicoMeses is not null && historicoMeses.Count > 0)
                {
                    var mesActualKey = coffeeKg.PeriodStart.Year * 100 + coffeeKg.PeriodStart.Month;
                    var previos = historicoMeses.Where(m => (m.Year * 100 + m.Month) < mesActualKey).OrderByDescending(m => m.Year * 100 + m.Month).ToList();
                    var mesAnterior = previos.FirstOrDefault();
                    var totalKg = historicoMeses.Sum(m => m.KgTotal);
                    <div style="display:flex; gap:14px; margin-top:8px; font-size:0.78rem; color:#6b7280;">
                        @if (mesAnterior is not null)
                        {
                            <div style="display:flex; flex-direction:column;">
                                <span style="font-size:0.68rem; text-transform:uppercase; letter-spacing:0.04em;">Mes anterior</span>
                                <strong style="font-variant-numeric:tabular-nums; color:#374151;">@mesAnterior.KgTotal.ToString("N1") kg</strong>
                            </div>
                        }
                        <div style="display:flex; flex-direction:column;">
                            <span style="font-size:0.68rem; text-transform:uppercase; letter-spacing:0.04em;">Total 12m</span>
                            <strong style="font-variant-numeric:tabular-nums; color:#374151;">@totalKg.ToString("N1") kg</strong>
                        </div>
                    </div>
                }
            }
        </div>

        @* Divisor vertical *@
        <div class="mac-card-split-divider"></div>

        @* === Mitad derecha: STOCK === *@
        <div class="mac-card-split-half" title="Suma del stock de todos los cafés (kg-mode parents)">
            <div class="mac-card-header">
                <div class="mac-card-iconbox" style="background:#eaf3de; color:#16a34a;">
                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                </div>
                <span class="mac-card-eyebrow">Stock</span>
            </div>
            @if (coffeeStock is null)
            {
                <div class="mac-card-bignum" style="color:#9ca3af;">…</div>
            }
            else
            {
                <div style="display:flex; align-items:center; gap:14px; margin-top:4px;">
                    @{
                        var pct = coffeeStock.Variedades > 0 ? (coffeeStock.VariedadesConStock * 201.0 / coffeeStock.Variedades) : 0;
                    }
                    <svg viewBox="0 0 80 80" width="60" height="60" style="flex-shrink:0;">
                        <circle cx="40" cy="40" r="32" fill="none" stroke="#eaf3de" stroke-width="7"></circle>
                        <circle cx="40" cy="40" r="32" fill="none" stroke="#16a34a" stroke-width="7" stroke-dasharray="@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) 201" stroke-linecap="round" transform="rotate(-90 40 40)"></circle>
                        <text x="40" y="38" text-anchor="middle" font-size="14" font-weight="500" fill="#16a34a" font-family="system-ui">@coffeeStock.VariedadesConStock</text>
                        <text x="40" y="51" text-anchor="middle" font-size="9" fill="#9ca3af" font-family="system-ui">de @coffeeStock.Variedades</text>
                    </svg>
                    <div style="min-width:0;">
                        <div class="mac-card-bignum" style="margin:0;">@FormatKg(coffeeStock.KgTotal)<span class="mac-card-unit">kg</span></div>
                        <div class="mac-card-sub">variedades en stock</div>
                    </div>
                </div>
            }
        </div>

        @if (cafeBgUploading)
        {
            <div style="position:absolute; top:8px; left:8px; background:white; border:0.5px solid #e5e7eb; border-radius:6px; padding:2px 6px; font-size:0.7rem; color:#6b7280;">Subiendo…</div>
        }
        @if (mostrandoHistorico && historicoMeses is not null && historicoMeses.Count > 0)
        {
            <div style="position:absolute; top:calc(100% + 8px); left:0; right:50%;
                        background:white; border:0.5px solid #e5e7eb; border-radius:12px; padding:0.8rem 1rem;
                        box-shadow:0 12px 40px rgba(0,0,0,0.08); z-index:1000; min-width:240px;">
                <div style="font-weight:500; font-size:0.75rem; color:#6b7280; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.5rem;">
                    Histórico balanza
                </div>
                @foreach (var m in historicoMeses)
                {
                    var esActual = m.Year == DateTime.UtcNow.Year && m.Month == DateTime.UtcNow.Month;
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:0.3rem 0; font-size:0.85rem; @(esActual ? "background:#faeeda; border-radius:6px; padding-left:0.4rem; padding-right:0.4rem;" : "")">
                        <span style="color:@(esActual ? "#92400e" : "#3f3f46"); font-weight:@(esActual ? "500" : "400"); text-transform:capitalize;">
                            @m.PeriodStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))
                            @if (esActual) { <span style="font-size:0.7rem; color:#d97706;"> (actual)</span> }
                        </span>
                        <span style="font-variant-numeric:tabular-nums; font-weight:500; color:@(esActual ? "#92400e" : "#1f2937");">@m.KgTotal.ToString("N1") kg</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

