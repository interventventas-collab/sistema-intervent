@* === Fila de KPIs financieros: Ventas del mes / Saldos clientes / Cuentas a pagar ===
   2026-06-22: rediseño Mac — blanco con borde izquierdo de color, icono pastel, tipografia limpia. *@
<div class="dashboard-cards-row">
    @* Ventas del mes *@
    <div class="dashboard-detail-card mac-stat-card accent-green">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#eaf3de; color:#16a34a;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <span class="mac-card-eyebrow" style="color:#3f3f46;">Ventas del mes</span>
        </div>
        @if (salesSummary is null)
        {
            <div class="mac-card-sub">Cargando…</div>
        }
        else
        {
            <div class="mac-card-bignum">$@FormatMoney(salesSummary.MonthlySalesTotal)</div>
            <div class="mac-card-sub">@salesSummary.MonthlySalesCount comprobante@(salesSummary.MonthlySalesCount == 1 ? "" : "s") en @salesSummary.PeriodStart.ToString("MMMM", new System.Globalization.CultureInfo("es-AR"))</div>
        }
    </div>

    @* Saldos de clientes *@
    <div class="dashboard-detail-card mac-stat-card accent-red">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#fceaea; color:#dc2626;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
