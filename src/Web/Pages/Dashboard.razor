@page "/"
@page "/index.html"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject AuthService AuthService
@inject OperatorService Operator
@inject ToastService ToastService
@inject CurrentCompanyService Company
@inject NavigationManager Navigation

<div class="view-header">
    <h2>Bienvenido, @username</h2>
    <p class="view-subtitle">Panel de control</p>
</div>

@* 2026-05-30: para usuarios SOLO depósito (sin cafe ni oficina), ocultar todos los
   widgets del dashboard — ellos operan solo desde el sidebar (Imprimir pedidos,
   Productos, Stock). El resto sigue viendo el dashboard normal. *@
@if (!isDepositoOnly)
{
@* 2026-06-22: rediseño Mac/iOS — tarjetas blancas, bordes finos, iconos SVG uniformes.
   Las acciones y dropdowns NO cambian: misma logica, mismas rutas. *@
@* Fila superior: HOLA + dolar + reloj AR/ES combinado + postits (responsive) *@
<div class="dashboard-top-grid dashboard-modern">
    <div class="dashboard-detail-card mac-card">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#e6f1fb; color:#2563eb;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="mac-card-eyebrow">Operador</span>
        </div>
        @if (Operator.HasOperator)
        {
            <div class="mac-card-bignum" style="font-size:1.35rem; margin-top:2px;">@Operator.Current</div>
        }
        <select class="form-input mac-card-select"
                value="@(Operator.Current ?? "")"
                @onchange="OnSelectOperator">
            <option value="">— Elegi tu nombre —</option>
            @foreach (var op in OperatorService.ForPermissions(userPermissions))
            {
                <option value="@op">@op</option>
            }
            @foreach (var op in OperatorService.ProtectedForPermissions(userPermissions))
            {
                <option value="@($"__PROTECTED__{op}")">🔒 @op (clave)</option>
            }
            @if (!string.IsNullOrEmpty(Operator.Current)
                && OperatorService.ProtectedOperators.Contains(Operator.Current)
                && !OperatorService.ForPermissions(userPermissions).Contains(Operator.Current))
            {
                <option value="@Operator.Current" selected>@Operator.Current ✓</option>
            }
        </select>
    </div>

    @* Widget Dolar BNA *@
    <div class="dashboard-detail-card mac-card">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#eaf3de; color:#16a34a;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            </div>
            <span class="mac-card-eyebrow">Dólar Nación</span>
            <span class="mac-card-meta">@(dolar?.Fecha ?? "…")</span>
        </div>
        @if (dolarLoading && dolar is null)
        {
            <div class="mac-card-sub" style="margin-top:8px;">Consultando BNA…</div>
        }
        else if (dolar is not null && dolar.Compra is not null && dolar.Venta is not null)
        {
            <div style="display:flex; gap:18px; margin-top:6px;">
                <div>
                    <div class="mac-card-sub" style="font-size:0.7rem;">Compra</div>
                    <div style="font-size:1.05rem; font-weight:500; color:#16a34a; font-variant-numeric:tabular-nums;">$@FormatMoney(dolar.Compra.Value)</div>
                </div>
                <div>
                    <div class="mac-card-sub" style="font-size:0.7rem;">Venta</div>
                    <div style="font-size:1.05rem; font-weight:500; color:#dc2626; font-variant-numeric:tabular-nums;">$@FormatMoney(dolar.Venta.Value)</div>
                </div>
            </div>
        }
        else
        {
            <div class="mac-card-sub" style="color:#dc2626; margin-top:8px;">@(dolar?.Error ?? "No se pudo obtener la cotizacion")</div>
        }
    </div>

    @* Reloj combinado: Argentina + España en un solo modulo *@
    <div class="dashboard-detail-card mac-card dashboard-clock-card">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#f1efe8; color:#5f5e5a;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <span class="mac-card-eyebrow">Hora</span>
        </div>
        <div class="mac-clock-row" style="margin-top:6px;">
            <span class="mac-clock-pill">AR</span>
            <div>
                <div class="dashboard-clock-time">@arTime.ToString("HH:mm:ss")</div>
                <div class="dashboard-clock-date">@arTime.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-AR"))</div>
            </div>
        </div>
        <div class="mac-clock-row" style="margin-top:6px;">
            <span class="mac-clock-pill mac-clock-pill-muted">ES</span>
            <div>
                <div class="dashboard-clock-time" style="color:#5f5e5a;">@esTime.ToString("HH:mm:ss")</div>
                <div class="dashboard-clock-date">@esTime.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-ES"))</div>
            </div>
        </div>
    </div>

    @* Postits: block de notas compartido (componente reusable, scope=dashboard) *@
    <PostitsWidget Scope="dashboard" Title="Postits del equipo" CardStyle="max-height: 220px;" />

    @* Balanza de café FRIKAF — tarjeta Mac compacta con icono balanza al costado.
       2026-06-22: Sin ring porcentual (era inventado). Hover sigue mostrando histórico. *@
    <div class="dashboard-detail-card mac-card" @onmouseenter="MostrarHistoricoBalanza" @onmouseleave="OcultarHistoricoBalanza" style="position:relative;">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#faeeda; color:#d97706;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M6 6l6-1l6 1"/><path d="M12 3v17"/><path d="M9 12L6 6l-3 6a3 3 0 006 0z"/><path d="M21 12l-3-6l-3 6a3 3 0 006 0z"/></svg>
            </div>
            <span class="mac-card-eyebrow">Balanza</span>
            <label class="mac-card-iconbtn" title="Cambiar imagen de fondo" style="margin-left:auto;">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <InputFile OnChange="OnCafeBgFilePicked" accept=".png,.jpg,.jpeg,.webp" style="display: none;" />
            </label>
        </div>
        @if (coffeeKg is null)
        {
            <div class="mac-card-bignum" style="color:#9ca3af;">…</div>
        }
        else
        {
            <div class="mac-card-bignum">@FormatKg(coffeeKg.KgTotal)<span class="mac-card-unit">kg</span></div>
            <div class="mac-card-sub">@coffeeKg.PeriodStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))</div>
        }
        @if (cafeBgUploading)
        {
            <div style="position:absolute; top:8px; right:8px; background:white; border:0.5px solid #e5e7eb; border-radius:6px; padding:2px 6px; font-size:0.7rem; color:#6b7280;">Subiendo…</div>
        }
        @if (mostrandoHistorico && historicoMeses is not null && historicoMeses.Count > 0)
        {
            <div style="position:absolute; top:calc(100% + 8px); left:0; right:0;
                        background:white; border:0.5px solid #e5e7eb; border-radius:12px; padding:0.8rem 1rem;
                        box-shadow:0 12px 40px rgba(0,0,0,0.08); z-index:1000; min-width:240px;">
                <div style="font-weight:500; font-size:0.75rem; color:#6b7280; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.5rem;">
                    Histórico balanza
                </div>
                @foreach (var m in historicoMeses)
                {
                    var esActual = m.Year == DateTime.UtcNow.Year && m.Month == DateTime.UtcNow.Month;
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:0.3rem 0; font-size:0.85rem; @(esActual ? "background:#faeeda; border-radius:6px; padding-left:0.4rem; padding-right:0.4rem;" : "")">
                        <span style="color:@(esActual ? "#92400e" : "#3f3f46"); font-weight:@(esActual ? "500" : "400"); text-transform:capitalize;">
                            @m.PeriodStart.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-AR"))
                            @if (esActual) { <span style="font-size:0.7rem; color:#d97706;"> (actual)</span> }
                        </span>
                        <span style="font-variant-numeric:tabular-nums; font-weight:500; color:@(esActual ? "#92400e" : "#1f2937");">@m.KgTotal.ToString("N1") kg</span>
                    </div>
                }
            </div>
        }
    </div>

    @* Stock total de cafe disponible — ring chart con variedades en stock vs total *@
    <div class="dashboard-detail-card mac-card" title="Suma del stock de todos los cafés (kg-mode parents)">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#eaf3de; color:#16a34a;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <span class="mac-card-eyebrow">Stock</span>
        </div>
        @if (coffeeStock is null)
        {
            <div class="mac-card-bignum" style="color:#9ca3af;">…</div>
        }
        else
        {
            <div style="display:flex; align-items:center; gap:14px; margin-top:4px;">
                @{
                    var pct = coffeeStock.Variedades > 0 ? (coffeeStock.VariedadesConStock * 201.0 / coffeeStock.Variedades) : 0;
                }
                <svg viewBox="0 0 80 80" width="60" height="60" style="flex-shrink:0;">
                    <circle cx="40" cy="40" r="32" fill="none" stroke="#eaf3de" stroke-width="7"></circle>
                    <circle cx="40" cy="40" r="32" fill="none" stroke="#16a34a" stroke-width="7" stroke-dasharray="@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) 201" stroke-linecap="round" transform="rotate(-90 40 40)"></circle>
                    <text x="40" y="38" text-anchor="middle" font-size="14" font-weight="500" fill="#16a34a" font-family="system-ui">@coffeeStock.VariedadesConStock</text>
                    <text x="40" y="51" text-anchor="middle" font-size="9" fill="#9ca3af" font-family="system-ui">de @coffeeStock.Variedades</text>
                </svg>
                <div style="min-width:0;">
                    <div class="mac-card-bignum" style="margin:0;">@FormatKg(coffeeStock.KgTotal)<span class="mac-card-unit">kg</span></div>
                    <div class="mac-card-sub">variedades en stock</div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* ═══════════════ 2026-06-22 — Look Mac/iOS para tarjetas del Dashboard ═══════════════
       Override scoped a .dashboard-modern: blanco, borde fino, redondeo grande, iconos pareja. */
    .dashboard-modern .dashboard-detail-card.mac-card,
    .dashboard-cards-row .dashboard-detail-card.mac-card {
        background: #ffffff;
        border: 0.5px solid rgba(0,0,0,0.08);
        border-top: 0.5px solid rgba(0,0,0,0.08); /* override del border-top: 3px primary del base */
        border-radius: 14px;
        box-shadow: none;
        padding: 14px;
        margin-top: 0;
    }
    .mac-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }
    .mac-card-iconbox {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .mac-card-eyebrow {
        font-size: 0.7rem;
        color: #6b7280;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .mac-card-meta {
        margin-left: auto;
        font-size: 0.7rem;
        color: #9ca3af;
    }
    .mac-card-bignum {
        font-size: 1.5rem;
        font-weight: 500;
        color: #111827;
        line-height: 1.1;
        margin: 4px 0 2px;
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.5px;
    }
    .mac-card-unit {
        font-size: 0.78rem;
        color: #9ca3af;
        font-weight: 400;
        margin-left: 4px;
    }
    .mac-card-sub {
        font-size: 0.72rem;
        color: #9ca3af;
        margin: 0;
    }
    .mac-card-select {
        margin-top: 6px;
        font-size: 0.85rem;
        font-weight: 500;
        background: rgba(245,245,247,0.9);
        border: 0.5px solid rgba(0,0,0,0.06);
        border-radius: 7px;
        padding: 6px 8px;
        width: 100%;
    }
    .mac-card-iconbtn {
        width: 24px; height: 24px;
        background: rgba(245,245,247,0.85);
        border: 0.5px solid rgba(0,0,0,0.06);
        border-radius: 6px;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; color: #6b7280;
    }
    .mac-card-iconbtn:hover { background: rgba(0,0,0,0.05); }
    .mac-clock-row {
        display: flex; align-items: center; gap: 10px;
    }
    .mac-clock-pill {
        background: #eef2ff;
        color: #4338ca;
        font-size: 0.65rem;
        font-weight: 500;
        padding: 2px 7px;
        border-radius: 6px;
        letter-spacing: 0.05em;
    }
    .mac-clock-pill.mac-clock-pill-muted {
        background: #f3f4f6;
        color: #6b7280;
    }

    /* Stat cards (Ventas/Saldos/etc): blanco con borde izquierdo de color */
    .mac-stat-card {
        background: #ffffff !important;
        border: 0.5px solid rgba(0,0,0,0.08) !important;
        border-left-width: 3px !important;
        border-top: 0.5px solid rgba(0,0,0,0.08) !important;
        border-radius: 12px !important;
        box-shadow: none !important;
        padding: 14px !important;
        margin-top: 0 !important;
    }
    .mac-stat-card.accent-green { border-left-color: #16a34a !important; }
    .mac-stat-card.accent-red   { border-left-color: #dc2626 !important; }
    .mac-stat-card.accent-purple{ border-left-color: #7c3aed !important; }
    .mac-stat-card.accent-amber { border-left-color: #d97706 !important; }
    .mac-stat-card.accent-blue  { border-left-color: #2563eb !important; }

    /* ═══════════════ Top grid responsive ═══════════════ */
    .dashboard-top-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: 0.8rem;
        margin-bottom: 1rem;
    }
    @@media (max-width: 1024px) {
        .dashboard-top-grid { grid-template-columns: 1fr 1fr; }
    }
    @@media (max-width: 640px) {
        .dashboard-top-grid { grid-template-columns: 1fr; gap: 0.6rem; }
    }

    /* ═══════════════ Reloj combinado AR + ES ═══════════════ */
    .dashboard-clock-card { padding: 0.7rem 0.85rem; }
    .dashboard-clock-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .dashboard-clock-time {
        font-size: 1.3rem;
        font-weight: 800;
        font-family: 'Courier New', monospace;
        line-height: 1.1;
    }
    .dashboard-clock-date {
        font-size: 0.68rem;
        color: #6b7280;
        text-transform: capitalize;
    }
    /* 2026-06-22: dentro de mac-card el reloj es más sutil y tabular */
    .mac-card .dashboard-clock-time {
        font-size: 1.15rem;
        font-weight: 500;
        font-family: 'SF Mono','Menlo','Monaco','Courier New',monospace;
        color: #111827;
        letter-spacing: -0.2px;
        font-variant-numeric: tabular-nums;
    }
    .mac-card .dashboard-clock-date {
        font-size: 0.7rem;
        color: #9ca3af;
    }
    @@media (max-width: 640px) {
        .dashboard-clock-time { font-size: 1.5rem; }
    }

    /* ═══════════════ Postits del equipo ═══════════════ */
    .dashboard-postits-card { padding: 0.7rem 0.85rem; display: flex; flex-direction: column; gap: 0.4rem; max-height: 220px; }
    .dashboard-postits-header { display: flex; align-items: center; gap: 0.4rem; padding-bottom: 0.3rem; border-bottom: 1px solid #e5e7eb; }
    .dashboard-postits-body {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding-right: 0.2rem;
    }
    .dashboard-postit {
        padding: 0.35rem 0.5rem;
        border-radius: 4px;
        cursor: pointer;
        transition: filter 0.1s;
    }
    .dashboard-postit:hover { filter: brightness(0.95); }
    .dashboard-postit-text {
        font-size: 0.82rem;
        line-height: 1.3;
        white-space: pre-wrap;
        word-break: break-word;
        max-height: 4.2em;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
    }
    .dashboard-postit-meta { font-size: 0.65rem; color: #6b7280; margin-top: 0.15rem; }
    @@media (max-width: 640px) {
        .dashboard-postits-card { max-height: 280px; }
    }
    .postit-color-pick {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
    }

    .cafe-frikaf-balanza {
        flex: 0 0 180px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
    }
    .cafe-frikaf-circle {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        position: relative;
        overflow: hidden;
        background-color: #fde68a;
        background-size: cover;
        background-position: center;
        border: 4px solid #f59e0b;
        box-shadow: 0 6px 16px rgba(120, 53, 15, 0.35), inset 0 0 30px rgba(120, 53, 15, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }
    /* Variante verde para el indicador de stock disponible (vs balanza ventas) */
    .cafe-stock-circle {
        background-color: #86efac;
        background-image: linear-gradient(135deg, #86efac 0%, #16a34a 100%);
        border-color: #15803d;
        box-shadow: 0 6px 16px rgba(20, 83, 45, 0.35), inset 0 0 30px rgba(20, 83, 45, 0.20);
    }
    .cafe-frikaf-circle-content {
        position: relative;
        z-index: 1;
        padding: 0 0.5rem;
    }
    .cafe-frikaf-kg-number {
        font-size: 2.6rem;
        font-weight: 900;
        color: #ffffff;
        line-height: 1;
        text-shadow: 2px 2px 6px rgba(0,0,0,0.7), 0 0 12px rgba(0,0,0,0.5);
        letter-spacing: -0.03em;
    }
    .cafe-frikaf-kg-unit {
        font-size: 1.05rem;
        font-weight: 800;
        color: #ffffff;
        line-height: 1;
        margin-top: 0.1rem;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.7);
        letter-spacing: 0.05em;
    }
    .cafe-frikaf-loading {
        font-size: 1.5rem;
        color: #ffffff;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.7);
    }
    .cafe-frikaf-balanza-label {
        font-size: 1.1rem;
        font-weight: 800;
        color: #1f2937;
        letter-spacing: 0.15em;
        margin-top: 0.4rem;
    }
    .cafe-frikaf-balanza-period {
        font-size: 0.85rem;
        font-weight: 700;
        color: #4b5563;
        letter-spacing: 0.1em;
        margin-top: -0.15rem;
    }
    .cafe-frikaf-uploading {
        position: absolute; inset: 0;
        background: rgba(255,255,255,0.92);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; color: #78350f; font-weight: 700;
        border-radius: 50%; text-align: center; padding: 0 0.5rem;
    }
    .cafe-frikaf-upload-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 26px;
        height: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid #f59e0b;
        border-radius: 50%;
        cursor: pointer;
        font-size: 0.85rem;
        z-index: 2;
        transition: background 0.15s, transform 0.15s;
    }
    .cafe-frikaf-upload-btn:hover { background: white; transform: scale(1.1); }
</style>

@* === Fila de KPIs financieros: Ventas del mes / Saldos clientes / Cuentas a pagar ===
   2026-06-22: rediseño Mac — blanco con borde izquierdo de color, icono pastel, tipografia limpia. *@
<div class="dashboard-cards-row">
    @* Ventas del mes *@
    <div class="dashboard-detail-card mac-stat-card accent-green">
        <div class="mac-card-header">
            <div class="mac-card-iconbox" style="background:#eaf3de; color:#16a34a;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <span class="mac-card-eyebrow" style="color:#3f3f46;">Ventas del mes</span>
        </div>
        @if (salesSummary is null)
        {
            <div class="mac-card-sub">Cargando…</div>
        }
        else
        {
