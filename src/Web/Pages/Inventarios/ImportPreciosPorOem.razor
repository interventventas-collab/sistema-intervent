@page "/import-precios-oem"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>📥 Importar precios por código del proveedor (OEM)</h3>
        <button class="btn btn-primary" @onclick="() => showImport = true" style="background: #059669; border-color: #059669;">
            📤 Subir Excel
        </button>
    </div>
    <div class="card-body">
        <div style="background: #eff6ff; border: 1px solid #93c5fd; padding: 0.8rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.88rem; line-height: 1.55;">
            <strong>💡 Cuándo usar esta importación</strong>
            <p style="margin: 0.4rem 0 0;">
                Cuando el proveedor te manda una lista de precios con <strong>sus códigos</strong> (ej: <code>8733</code>, <code>9335</code>).
                Si el OEM ya existe en el sistema, el costo y el PVP se actualizan en todos los productos que comparten ese OEM (sus colores/variantes).
                Si el OEM no existe, se crea como producto nuevo.
            </p>
        </div>

        <div style="background: #f3f4f6; padding: 0.9rem 1.1rem; border-radius: 6px; font-size: 0.85rem; line-height: 1.6;">
            <strong>📋 Columnas que reconoce el Excel</strong>
            <ul style="margin: 0.5rem 0 0; padding-left: 1.4rem;">
                <li><code>codigo_oem</code> ⭐ <strong>obligatorio</strong> — el código del proveedor.</li>
                <li><code>sku_interno</code> — el SKU que querés usar internamente (ej: <code>C8733BL</code>). Si lo dejás vacío, se usa el OEM como SKU.</li>
                <li><code>titulo</code> — solo necesario si vas a crear productos nuevos.</li>
                <li><code>marca</code> — nombre exacto de la marca cargada en el sistema.</li>
                <li><code>precio_costo</code> — sin IVA.</li>
                <li><code>precio_venta</code> o <code>precio_venta_con_iva</code> — el segundo prevalece si llenás los dos.</li>
                <li><code>iva</code> — porcentaje (ej <code>21</code>).</li>
                <li><code>codigo_de_barras</code>, <code>stock_critico</code> — opcionales.</li>
            </ul>
            <p style="margin: 0.6rem 0 0; color: #6b7280; font-size: 0.78rem;">
                El stock NO se carga por esta vía: los productos creados arrancan en 0. Cargá el stock real desde "Modificación de stock".
            </p>
        </div>

        <div style="background: #fef3c7; border: 1px solid #fbbf24; padding: 0.7rem 1rem; border-radius: 8px; margin-top: 1rem; font-size: 0.85rem;">
            <strong>🔁 Re-vinculación con Mercado Libre</strong>
            <p style="margin: 0.4rem 0 0;">
                Cuando creas productos con SKU igual al SellerSku de tus publicaciones en ML
                (ej: <code>C9335GR</code>), las publicaciones huérfanas se re-vinculan solas usando matcheo exacto
                (no se mezclan combos como <code>C9335GRX2</code>). En modo "carga inactiva" la re-vinculación
                automática se desactiva — ejecutala después manualmente desde el botón
                <a href="/relink-meli-orphans" @onclick:preventDefault @onclick='() => Navigation.NavigateTo("/relink-meli-orphans")' style="color: #92400e; text-decoration: underline;">"Re-vincular publicaciones ML"</a>.
            </p>
        </div>

        <div style="margin-top: 1rem; padding: 0.6rem 0.9rem; background: #f9fafb; border-radius: 6px; font-size: 0.82rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                <input type="checkbox" id="createIfMissing" @bind="createIfMissing" style="width: 16px; height: 16px;" />
                <label for="createIfMissing" style="cursor: pointer;">
                    <strong>Crear productos nuevos</strong> si el OEM no existe todavía (necesario para cargar catálogo desde cero;
                    apagalo si solo querés actualizar precios de los que ya tenés).
                </label>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <input type="checkbox" id="loadAsInactive" @bind="loadAsInactive" style="width: 16px; height: 16px;" />
                <label for="loadAsInactive" style="cursor: pointer;">
                    <strong>Cargar como INACTIVO</strong> (sin stock, sin re-vincular ML).
                    Útil para volcar el catálogo completo del proveedor sin riesgo: los productos no aparecen en listados ni ventas
                    hasta que vos los actives uno por uno.
                </label>
            </div>
        </div>
    </div>
</div>

<BulkImportModal @bind-Visible="showImport"
                 EntityNameSingular="precio por OEM"
                 EntityNamePlural="precios por OEM"
                 TemplateUrl="/api/products/import-by-oem-template"
                 TemplateFileName="productos-por-oem-template.xlsx"
                 @key="@($"oem-import-{createIfMissing}-{loadAsInactive}")"
                 ImportUrl="@($"/api/products/bulk-import-by-oem?createIfMissing={createIfMissing.ToString().ToLower()}&loadAsInactive={loadAsInactive.ToString().ToLower()}")"
                 OnImported="OnImported" />

@code {
    private bool showImport;
    private bool createIfMissing = true;
    private bool loadAsInactive;

    private void OnImported()
    {
        if (loadAsInactive)
            ToastService.Success("Catálogo cargado como inactivo. Activá los productos uno por uno cuando los necesites.");
        else
            ToastService.Success("Importación lista. Revisá las alertas para ver re-vinculaciones de ML.");
        showImport = false;
    }
}
