@page "/import-precios-oem"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService ToastService
@inject NavigationManager Navigation

<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>📥 Importar precios por código del proveedor (OEM)</h3>
        <button class="btn btn-primary" @onclick="() => showImport = true" style="background: #059669; border-color: #059669;">
            📤 Subir Excel
        </button>
    </div>
    <div class="card-body">
        <div style="background: #eff6ff; border: 1px solid #93c5fd; padding: 0.8rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.88rem; line-height: 1.55;">
            <strong>💡 Cuándo usar esta importación</strong>
            <p style="margin: 0.4rem 0 0;">
                Cuando el proveedor te manda una lista de precios con <strong>sus códigos</strong> (ej: <code>8733</code>, <code>9335</code>),
                no con tus SKUs internos (<code>C8733BL</code>). El sistema busca por <strong>código OEM</strong> y actualiza
                el costo, el PVP y la marca de todos los productos que tengan ese OEM cargado (incluye todos sus colores/variantes).
            </p>
        </div>

        <div style="background: #f3f4f6; padding: 0.9rem 1.1rem; border-radius: 6px; font-size: 0.85rem; line-height: 1.6;">
            <strong>📋 Columnas que reconoce el Excel</strong>
            <ul style="margin: 0.5rem 0 0; padding-left: 1.4rem;">
                <li><code>codigo_oem</code> ⭐ <strong>obligatorio</strong> — el código del proveedor.</li>
                <li><code>titulo</code> — solo necesario si vas a crear productos nuevos.</li>
                <li><code>marca</code> — nombre exacto de la marca cargada en el sistema.</li>
                <li><code>precio_costo</code> — sin IVA.</li>
                <li><code>precio_venta</code> — sin IVA <em>(opcional)</em>.</li>
                <li><code>precio_venta_con_iva</code> — el precio final tal como te lo manda el proveedor <em>(si llenás esta, ignora <code>precio_venta</code>)</em>.</li>
                <li><code>iva</code> — porcentaje (ej <code>21</code>).</li>
                <li><code>codigo_de_barras</code>, <code>stock</code>, <code>stock_critico</code> — opcionales.</li>
            </ul>
        </div>

        <div style="background: #fef3c7; border: 1px solid #fbbf24; padding: 0.7rem 1rem; border-radius: 8px; margin-top: 1rem; font-size: 0.85rem;">
            <strong>🔁 Re-vinculación automática de Mercado Libre</strong>
            <p style="margin: 0.4rem 0 0;">
                Si hay publicaciones de ML que quedaron sin producto vinculado (porque borraste un producto antes), al subir este Excel
                el sistema intenta <strong>re-vincularlas automáticamente</strong> usando el OEM. Si el OEM coincide, la publicación
                se ata al producto nuevo y mantiene su histórico.
            </p>
        </div>

        <p style="font-size: 0.78rem; color: #9ca3af; margin-top: 1rem;">
            ¿Querés actualizar productos por SKU interno en lugar de OEM?
            <a href="/import-productos" @onclick:preventDefault @onclick='() => Navigation.NavigateTo("/import-productos")' style="color: #2563eb; text-decoration: underline; cursor: pointer;">Andá a Importación masiva clásica</a>.
        </p>

        <div style="margin-top: 1rem; padding: 0.6rem 0.9rem; background: #f9fafb; border-radius: 6px; font-size: 0.82rem; display: flex; align-items: center; gap: 0.5rem;">
            <input type="checkbox" id="createIfMissing" @bind="createIfMissing" style="width: 16px; height: 16px;" />
            <label for="createIfMissing" style="cursor: pointer;">
                <strong>Crear productos nuevos</strong> si el OEM no existe todavía (lo necesitás para cargar el catálogo desde cero;
                si solo querés actualizar precios, dejalo apagado).
            </label>
        </div>
    </div>
</div>

<BulkImportModal @bind-Visible="showImport"
                 EntityNameSingular="precio por OEM"
                 EntityNamePlural="precios por OEM"
                 TemplateUrl="/api/products/import-by-oem-template"
                 TemplateFileName="productos-por-oem-template.xlsx"
                 @key="@($"oem-import-{createIfMissing}")"
                 ImportUrl="@($"/api/products/bulk-import-by-oem?createIfMissing={createIfMissing.ToString().ToLower()}")"
                 OnImported="OnImported" />

@code {
    private bool showImport;
    private bool createIfMissing = true;

    private void OnImported()
    {
        ToastService.Success("Importación lista. Si había publicaciones de ML huérfanas con OEM coincidente, se re-vincularon.");
        showImport = false;
    }
}
