@inject IJSRuntime JS
@inject Web.Services.Mobile.KeyboardPrefs Prefs
@implements IDisposable

@*
  CustomKeyboard — Teclado in-app reutilizable.
  Diseño (decidido 2026-05-26 noche):
    - Prefijos grandes 2x3 (los 6 top más usados por el operario)
    - Numérico estilo teléfono grande (1-2-3 arriba)
    - Letras A-Z escondidas detrás de botón "ABC" (se despliega)
    - Layout ALTURA FIJA para no causar shifts en pantalla
  Props: Value (two-way), OnEnter, NumericOnly, ContextualHints, MaxLength
*@

<div class="kbd-root @(NumericOnly ? "kbd-numeric" : "")">

    @* Acciones SIEMPRE visibles arriba: LIMPIAR + ABC (para que no se corten en pantallas chicas) *@
    @if (!NumericOnly && !showAbc)
    {
        <div class="kbd-top-actions">
            <button class="kbd-action-clear" @onclick="Clear">⌫ LIMPIAR</button>
            <button class="kbd-action-abc" @onclick="@(() => { showAbc = true; })">ABC ↕</button>
        </div>
    }

    @if (showAbc && !NumericOnly)
    {
        @* Modo expandido: muestra A-Z completo, sin prefijos ni numérico *@
        <div class="kbd-abc-mode">
            <div class="kbd-abc-header">
                <button class="kbd-abc-close" @onclick="@(() => { showAbc = false; })">← Volver al numérico</button>
                <button class="kbd-toggle-layout" @onclick="ToggleLayoutAsync">
                    @(Prefs.Layout == "abc" ? "ABC" : "QWE")
                </button>
            </div>
            @foreach (var row in GetLetterRows())
            {
                <div class="kbd-row-letters">
                    @foreach (var k in row)
                    {
                        <button class="kbd-key kbd-key-letter" @onclick="@(() => InsertText(k))">@k</button>
                    }
                </div>
            }
        </div>
    }
    else if (NumericOnly)
    {
        @* Modo solo numérico, grande *@
        <div class="kbd-num-grid">
            <button class="kbd-num-key" @onclick="@(() => InsertText("1"))">1</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("2"))">2</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("3"))">3</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("4"))">4</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("5"))">5</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("6"))">6</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("7"))">7</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("8"))">8</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("9"))">9</button>
            <button class="kbd-num-back" @onclick="Backspace">⌫</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("0"))">0</button>
            <button class="kbd-num-enter" @onclick="EnterAsync">↵</button>
        </div>
    }
    else
    {
        @* Modo normal: prefijos arriba (o sufijos sugeridos si el operario ya tipeó) + numérico abajo *@
        @* Cartelito SIEMPRE ocupa el espacio (visibility:hidden cuando no aplica) para NO mover el teclado *@
        <div class="kbd-suffix-label" style="@(HasDynamicSuffixes ? "" : "visibility:hidden;")">
            ↓ SUFIJOS POSIBLES PARA "@Value"
        </div>
        <div class="kbd-prefix-grid">
            @foreach (var p in TopList)
            {
                @if (HasDynamicSuffixes)
                {
                    <button class="kbd-suffix-big" @onclick="@(() => InsertText(p))">+@p</button>
                }
                else
                {
                    <button class="kbd-prefix-big" @onclick="@(() => InsertPrefijoAsync(p))">@p</button>
                }
            }
            @* Si hay menos de 6, llenar con celdas vacías para mantener el grid *@
            @for (int i = TopList.Count; i < 6; i++)
            {
                <div></div>
            }
        </div>

        @* Numérico estilo teléfono grande *@
        <div class="kbd-num-grid">
            <button class="kbd-num-key" @onclick="@(() => InsertText("1"))">1</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("2"))">2</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("3"))">3</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("4"))">4</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("5"))">5</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("6"))">6</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("7"))">7</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("8"))">8</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("9"))">9</button>
            <button class="kbd-num-back" @onclick="Backspace">⌫</button>
            <button class="kbd-num-key" @onclick="@(() => InsertText("0"))">0</button>
            <button class="kbd-num-enter" @onclick="EnterAsync">↵</button>
        </div>

        @* Sufijos contextuales (color, tipo BL/ROJ/NEG) — abajo de todo *@
        <div class="kbd-hint-row">
            <span class="kbd-hint-label">💡</span>
            @if (ContextualHints != null && ContextualHints.Count > 0)
            {
                @foreach (var h in ContextualHints)
                {
                    <button class="kbd-hint-btn" @onclick="@(() => InsertText(h))">+@h</button>
                }
            }
            else
            {
                <span class="kbd-hint-empty">sufijos de color aparecen al escribir</span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback OnEnter { get; set; }
    [Parameter] public bool NumericOnly { get; set; } = false;
    [Parameter] public List<string>? Prefixes { get; set; }
    [Parameter] public List<string>? ContextualHints { get; set; }
    // Sufijos sugeridos dinámicamente desde el catálogo. Si vienen, REEMPLAZAN visualmente
    // a los prefijos azules (mismo grid 2x3) en color naranja, con label "+XX".
    [Parameter] public List<string>? DynamicSuffixes { get; set; }
    [Parameter] public int MaxLength { get; set; } = 20;
    [Parameter] public bool HapticFeedback { get; set; } = true;

    private bool showAbc = false;

    // Helpers para el grid de arriba: si hay sufijos dinámicos, muestra esos (naranjas);
    // si no, muestra los prefijos del operario (azules).
    private bool HasDynamicSuffixes => DynamicSuffixes != null && DynamicSuffixes.Count > 0;
    private List<string> TopList => HasDynamicSuffixes
        ? DynamicSuffixes!.Take(6).ToList()
        : (Prefixes ?? Prefs.Prefijos).Take(6).ToList();

    // QWERTY layout
    private static readonly List<string[]> QwertyRows = new()
    {
        new[] {"Q","W","E","R","T","Y","U","I","O","P"},
        new[] {"A","S","D","F","G","H","J","K","L","Ñ"},
        new[] {"Z","X","C","V","B","N","M","-",".","/"},
    };

    // ABC alfabético (default)
    private static readonly List<string[]> AbcRows = new()
    {
        new[] {"A","B","C","D","E","F","G","H","I","J"},
        new[] {"K","L","M","N","Ñ","O","P","Q","R","S"},
        new[] {"T","U","V","W","X","Y","Z","-",".","/"},
    };

    private List<string[]> GetLetterRows()
        => Prefs.Layout == "qwerty" ? QwertyRows : AbcRows;

    private async Task InsertText(string s)
    {
        if (Value.Length + s.Length > MaxLength) return;
        await Haptic();
        Value += s;
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task InsertPrefijoAsync(string prefijo)
    {
        if (Value.Length + prefijo.Length > MaxLength) return;
        await Haptic();
        await Prefs.RegistrarUsoPrefijoAsync(prefijo);
        Value += prefijo;
        await ValueChanged.InvokeAsync(Value);
        StateHasChanged();
    }

    private async Task Backspace()
    {
        if (Value.Length == 0) return;
        await Haptic();
        Value = Value.Substring(0, Value.Length - 1);
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task Clear()
    {
        if (Value.Length == 0) return;
        await Haptic();
        Value = "";
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task EnterAsync()
    {
        await Haptic();
        await OnEnter.InvokeAsync();
    }

    private async Task ToggleLayoutAsync()
    {
        await Haptic();
        await Prefs.SetLayoutAsync(Prefs.Layout == "abc" ? "qwerty" : "abc");
        StateHasChanged();
    }

    private async Task Haptic()
    {
        if (!HapticFeedback) return;
        try { await JS.InvokeVoidAsync("navigator.vibrate", 10); } catch { }
    }

    public void Dispose() { }
}

<style>
    .kbd-root {
        background: #f3f4f6;
        padding: 8px 8px 12px;
        border-top: 2px solid #d1d5db;
        user-select: none;
        -webkit-user-select: none;
        -webkit-tap-highlight-color: transparent;
        /* CRÍTICO: altura mínima fija para evitar layout shift al mostrar/ocultar sufijos */
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    /* Sufijos contextuales (siempre 1 fila, con texto placeholder si está vacía) */
    .kbd-hint-row {
        display: flex;
        gap: 8px;
        padding: 4px 2px;
        align-items: center;
        overflow-x: auto;
        scrollbar-width: none;
        min-height: 36px;
        background: #fffbeb;
        border-radius: 8px;
    }
    .kbd-hint-row::-webkit-scrollbar { display: none; }
    .kbd-hint-label { font-size: 0.95rem; padding-left: 6px; padding-right: 2px; }
    .kbd-hint-empty { font-size: 0.78rem; color: #92400e; opacity: 0.7; font-style: italic; }
    .kbd-hint-btn {
        min-width: 64px; min-height: 32px;
        background: #fef3c7; color: #92400e;
        border: 1px solid #fbbf24; border-radius: 10px;
        font-weight: 700; font-size: 0.95rem;
        cursor: pointer;
        touch-action: manipulation;
    }
    .kbd-hint-btn:active { background: #fde68a; }

    /* Top actions row (LIMPIAR + ABC) — siempre visible arriba de prefijos */
    .kbd-top-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    /* Prefijos grandes 2x3 */
    .kbd-prefix-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }
    .kbd-prefix-big {
        min-height: 56px;
        background: #1e40af; color: white;
        border: none; border-radius: 12px;
        font-weight: 800; font-size: 1.35rem;
        cursor: pointer;
        touch-action: manipulation;
        box-shadow: 0 2px 4px rgba(30,64,175,0.25);
    }
    .kbd-prefix-big:active {
        background: #1e3a8a;
        transform: scale(0.96);
        transition: all 0.05s ease;
    }

    /* Sufijos dinámicos (mismo grid 2x3 que prefijos, color naranja para distinguir) */
    .kbd-suffix-label {
        font-size: 0.72rem; font-weight: 700;
        color: #c2410c; letter-spacing: 0.3px;
        padding: 2px 4px; margin-bottom: -2px;
    }
    .kbd-suffix-big {
        min-height: 56px;
        background: #ea580c; color: white;
        border: none; border-radius: 12px;
        font-weight: 800; font-size: 1.35rem;
        cursor: pointer;
        touch-action: manipulation;
        box-shadow: 0 2px 4px rgba(234,88,12,0.25);
    }
    .kbd-suffix-big:active {
        background: #c2410c;
        transform: scale(0.96);
        transition: all 0.05s ease;
    }

    /* Numérico estilo teléfono grande (4x3) */
    .kbd-num-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        padding: 4px 0;
    }
    .kbd-num-grid > * {
        min-height: 64px;
        font-size: 1.6rem;
        font-weight: 800;
        background: white;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        cursor: pointer;
        color: #111827;
        touch-action: manipulation;
        box-shadow: 0 1px 0 rgba(0,0,0,0.08);
    }
    .kbd-num-key:active {
        background: #e5e7eb;
        transform: scale(0.96);
        transition: all 0.05s ease;
    }
    .kbd-num-back {
        background: #fef3c7; color: #92400e;
        border-color: #fcd34d;
    }
    .kbd-num-back:active { background: #fde68a; }
    .kbd-num-enter {
        background: #16a34a; color: white;
        border-color: #15803d;
    }
    .kbd-num-enter:active { background: #15803d; }

    /* Acciones (LIMPIAR + ABC) — usadas en .kbd-top-actions */
    .kbd-action-clear, .kbd-action-abc {
        min-height: 44px;
        border: 1px solid #d1d5db;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        touch-action: manipulation;
    }
    .kbd-action-clear { background: #fef2f2; color: #991b1b; border-color: #fca5a5; }
    .kbd-action-clear:active { background: #fecaca; }
    .kbd-action-abc { background: #475569; color: white; border-color: #334155; font-size: 1rem; }
    .kbd-action-abc:active { background: #334155; }

    /* Modo ABC expandido (cuando el usuario quiere letras) */
    .kbd-abc-mode {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .kbd-abc-header {
        display: flex;
        gap: 10px;
        align-items: center;
    }
    .kbd-abc-close {
        flex: 1;
        min-height: 44px;
        background: #1e40af; color: white;
        border: none; border-radius: 10px;
        font-weight: 700; font-size: 0.95rem;
        cursor: pointer;
    }
    .kbd-toggle-layout {
        min-width: 60px; min-height: 44px;
        background: #6b7280; color: white;
        border: none; border-radius: 10px;
        font-size: 0.85rem; font-weight: 700;
        cursor: pointer;
    }
    .kbd-row-letters {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 6px;
    }
    .kbd-key-letter {
        min-height: 50px;
        background: white;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
        cursor: pointer;
        touch-action: manipulation;
        box-shadow: 0 1px 0 rgba(0,0,0,0.05);
    }
    .kbd-key-letter:active {
        background: #d1d5db;
        transform: scale(0.95);
    }
</style>
