@inject Web.Services.Mobile.CatalogIndex Catalog
@inject Web.Services.Mobile.KeyboardPrefs Prefs
@inject IJSRuntime JS
@using Web.Models.Mobile
@using Web.Components.Mobile.Keyboard

@*
  ProductSearchInput — Buscador inteligente reutilizable.
  Props:
    - OnSelect: callback al seleccionar un producto
    - Placeholder: texto del input
    - AutoFocus: bool
    - Context: string opcional ("stock" | "ventas" | "remitos") para tracking
    - FilterFn: filtro opcional sobre el catálogo
    - ShowRecent / ShowFavorites: bool (default true)
    - KeyboardMode: "custom" (default) | "native"
*@

<div class="psi-root">
    @* Input visible con el valor que va tipeando *@
    <div class="psi-input-row">
        <div class="psi-input">
            <span class="psi-search-icon">🔍</span>
            <span class="psi-value">@(string.IsNullOrEmpty(value) ? Placeholder : value)</span>
            @if (!string.IsNullOrEmpty(value))
            {
                <button class="psi-clear-btn" @onclick="ClearValue">✕</button>
            }
        </div>
        @if (LastSearchMs.HasValue)
        {
            <span class="psi-search-time">@LastSearchMs ms · @results.Count hits</span>
        }
    </div>


    @* Resultados o estado vacío — wrapper con flex:1 para absorber el cambio de tamaño y NO mover el teclado *@
    <div class="psi-results-wrap">
    @if (string.IsNullOrEmpty(value))
    {
        @if (!isCatalogLoaded)
        {
            <div class="psi-empty-state">
                <p>⏳ Cargando catálogo...</p>
            </div>
        }
        @if (favoritos.Count > 0)
        {
            <div class="psi-section-label">⭐ FAVORITOS</div>
            <div class="psi-chips">
                @foreach (var item in favoritos)
                {
                    @RenderChip(item, isFav: true)
                }
            </div>
        }
        @if (frecuentes.Count > 0)
        {
            <div class="psi-section-label">🔥 FRECUENTES</div>
            <div class="psi-chips">
                @foreach (var item in frecuentes)
                {
                    @RenderChip(item)
                }
            </div>
        }

        @* MARCAS — SIEMPRE visible en empty state (no dentro de otro if) *@
        @if (marcas.Count > 0)
        {
            <div class="psi-section-label">🏷 MARCAS (tocá una para filtrar)</div>
            <div class="psi-marca-grid">
                @foreach (var (m, count) in marcas)
                {
                    <button class="psi-marca-chip @(marcaFiltro == m ? "active" : "")"
                            @onclick="@(() => SelectMarca(m))">
                        <span class="psi-marca-name">@m</span>
                        <span class="psi-marca-count">@count</span>
                    </button>
                }
            </div>
        }

        @if (favoritos.Count == 0 && frecuentes.Count == 0 && marcas.Count == 0 && isCatalogLoaded)
        {
            <div class="psi-empty-state">
                <p>👋 Tocá las teclas o un prefijo rápido para empezar.</p>
                <p style="color:#6b7280">Catálogo: @Catalog.Count productos.</p>
            </div>
        }
    }
    else
    {
        @if (results.Count == 0)
        {
            <div class="psi-no-results">
                <p>Sin resultados para <strong>"@value"</strong></p>
                <p style="font-size:0.85rem; color:#6b7280">Probá con menos letras o cambiá el prefijo.</p>
            </div>
        }
        else
        {
            <div class="psi-chips">
                @foreach (var hit in results)
                {
                    @RenderChip(hit.Item, hit: hit)
                }
            </div>
        }
    }
    </div>

    @* Teclado custom abajo *@
    @if (KeyboardMode == "custom")
    {
        <CustomKeyboard
            Value="@value"
            ValueChanged="@OnKeyboardValueChanged"
            OnEnter="OnEnterPressed"
            Prefixes="@GetPrefixesForKeyboard()"
            ContextualHints="@GetContextualHints()"
            DynamicSuffixes="@GetDynamicSuffixes()" />
    }

    @* Chip de marca activa AL FINAL — debajo del teclado, último elemento de la pantalla.
       Cuando no hay marca, no se ve. Cuando hay, aparece como una franja chica abajo de todo. *@
    @if (!string.IsNullOrEmpty(marcaFiltro))
    {
        <div class="psi-marca-footer">
            <span>🏷 Filtrando: <strong>@marcaFiltro</strong></span>
            <button class="psi-marca-clear" @onclick="@(() => { marcaFiltro = null; RunSearch(); StateHasChanged(); })">✕ Quitar</button>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<CatalogItem> OnSelect { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Buscar SKU o nombre...";
    [Parameter] public bool AutoFocus { get; set; } = true;
    [Parameter] public string Context { get; set; } = "default";
    [Parameter] public Func<CatalogItem, bool>? FilterFn { get; set; }
    [Parameter] public bool ShowRecent { get; set; } = true;
    [Parameter] public bool ShowFavorites { get; set; } = true;
    [Parameter] public string KeyboardMode { get; set; } = "custom";
    // Por defecto NO mostrar combos/kits (caso típico stock: solo productos individuales).
    // En /cafe/ventas se va a pasar IncludeCombos="true" cuando integremos.
    [Parameter] public bool IncludeCombos { get; set; } = false;

    private string value = "";
    private List<SearchHit> results = new();
    private List<CatalogItem> favoritos = new();
    private List<CatalogItem> cargadosHoy = new();
    private List<CatalogItem> frecuentes = new();
    private List<(string Marca, int Count)> marcas = new();
    private string? marcaFiltro = null;  // marca activa (null = todas)
    private bool isCatalogLoaded = false;
    public double? LastSearchMs { get; private set; }

    protected override async Task OnInitializedAsync()
    {
        await Prefs.LoadAsync();
        await Catalog.EnsureLoadedAsync();
        isCatalogLoaded = Catalog.Count > 0;
        marcas = Catalog.GetMarcas(20);
        RefreshEmptyState();
    }

    private void SelectMarca(string marca)
    {
        marcaFiltro = (marcaFiltro == marca) ? null : marca;
        RunSearch();
        StateHasChanged();
    }

    /// <summary>Filtro combinado: combos (según IncludeCombos) + marca activa (si hay).</summary>
    private Func<CatalogItem, bool>? BuildFilter()
    {
        Func<CatalogItem, bool>? f = FilterFn;
        if (!IncludeCombos)
        {
            var prev = f;
            f = it => it.Tipo == "producto" && (prev == null || prev(it));
        }
        if (!string.IsNullOrEmpty(marcaFiltro))
        {
            var prev = f;
            f = it => !string.IsNullOrWhiteSpace(it.Marca)
                      && it.Marca.Trim().Equals(marcaFiltro, StringComparison.OrdinalIgnoreCase)
                      && (prev == null || prev(it));
        }
        return f;
    }

    private void RefreshEmptyState()
    {
        var (fav, hoy, frec) = Catalog.EmptyState();
        // Si no incluimos combos, filtrarlos también del estado vacío
        Func<CatalogItem, bool> okType = it => IncludeCombos || it.Tipo == "producto";
        favoritos = ShowFavorites ? fav.Where(okType).ToList() : new();
        cargadosHoy = ShowRecent ? hoy.Where(okType).ToList() : new();
        frecuentes = frec.Where(okType).ToList();
    }

    private async Task OnKeyboardValueChanged(string newValue)
    {
        value = newValue;
        RunSearch();
        await Task.CompletedTask;
    }

    private void RunSearch()
    {
        if (string.IsNullOrEmpty(value))
        {
            results.Clear();
            RefreshEmptyState();
            LastSearchMs = null;
            return;
        }
        var t0 = DateTime.UtcNow;
        results = Catalog.Search(value, 10, BuildFilter());
        LastSearchMs = (DateTime.UtcNow - t0).TotalMilliseconds;
    }

    private async Task OnEnterPressed()
    {
        // SOLO selecciona automáticamente si hay un único resultado o si el top match es EXACTO con el SKU
        // tipeado. Evita agregar cualquier cosa por error cuando hay matches débiles (fuzzy/contains).
        if (string.IsNullOrEmpty(value) || results.Count == 0) return;
        var top = results[0];
        bool exact = top.Item.SkuUpper.Equals(value.ToUpperInvariant(), StringComparison.Ordinal);
        if (exact || results.Count == 1)
        {
            await SelectItem(top.Item);
        }
        // Si hay varios y ninguno es exacto, NO selecciona — el operario tiene que tocar el chip
    }

    /// <summary>
    /// Prefijos a mostrar en los botones azules del teclado.
    /// Si hay marca activa, calcula los prefijos más comunes de esa marca (mejor predicción).
    /// Si no hay marca, devuelve null y el teclado usa los prefijos default del operario.
    /// </summary>
    private List<string>? GetPrefixesForKeyboard()
    {
        if (string.IsNullOrEmpty(marcaFiltro)) return null;
        return Catalog.GetCommonPrefixes(BuildFilter(), 6);
    }

    private async Task SelectItem(CatalogItem item)
    {
        await Prefs.RegistrarUsoAsync(item.Sku);
        await OnSelect.InvokeAsync(item);
        // Limpiar el input y resetear estado para listo-para-el-siguiente
        value = "";
        results.Clear();
        LastSearchMs = null;
        RefreshEmptyState();
        StateHasChanged();
    }

    private async Task ClearValue()
    {
        value = "";
        RunSearch();
        await Task.CompletedTask;
    }

    private List<string>? GetContextualHints()
    {
        // Sufijos hint del fondo: SOLO cuando NO hay sufijos dinámicos del catálogo (para no duplicar info).
        if (GetDynamicSuffixes() != null) return null;
        if (string.IsNullOrEmpty(value)) return null;
        bool hasLetter = value.Any(char.IsLetter);
        bool hasDigit = value.Any(char.IsDigit);
        if (hasLetter && hasDigit)
            return new() { "BL", "ROJ", "NEG", "VER", "AZ" };
        return null;
    }

    /// <summary>
    /// Sufijos sugeridos en tiempo real para REEMPLAZAR a los prefijos azules
    /// apenas el operario tipea letra+dígito (estado típico "ya empecé a escribir un SKU").
    /// Cascada: catálogo con filtro → catálogo sin filtro → colores comunes hardcodeados.
    /// SIEMPRE devuelve algo cuando hay letra+dígito (para que los prefijos azules siempre se oculten).
    /// </summary>
    private List<string>? GetDynamicSuffixes()
    {
        if (string.IsNullOrEmpty(value)) return null;
        bool hasLetter = value.Any(char.IsLetter);
        bool hasDigit = value.Any(char.IsDigit);
        if (!hasLetter || !hasDigit) return null;

        // 1) Catálogo con filtro completo (productos + marca activa si hay)
        var sufs = Catalog.SuggestSuffixes(value, 6, BuildFilter());
        if (sufs.Count > 0) return sufs;

        // 2) Catálogo SIN filtro (incluir combos sólo como hint visual: ayuda a entender la convención de SKU)
        sufs = Catalog.SuggestSuffixes(value, 6, null);
        if (sufs.Count > 0) return sufs;

        // 3) Último recurso: sufijos de color comunes (hardcoded)
        return new() { "BL", "ROJ", "NEG", "VER", "AZ", "GR" };
    }

    private async Task ToggleFavoritoAsync(string sku)
    {
        await Prefs.ToggleFavoritoAsync(sku);
        RefreshEmptyState();
        StateHasChanged();
    }

    private RenderFragment RenderChip(CatalogItem item, bool isFav = false, SearchHit? hit = null) => @<text>
        <button class="psi-chip @(item.Stock <= 0 ? "psi-chip-nostock" : "")"
                @onclick="@(() => SelectItem(item))"
                @oncontextmenu:preventDefault
                @oncontextmenu="@(() => ToggleFavoritoAsync(item.Sku))">
            @if (Prefs.IsFavorito(item.Sku))
            {
                <span class="psi-chip-fav">⭐</span>
            }
            <span class="psi-chip-sku">@HighlightMatch(item.Sku)</span>
            <span class="psi-chip-name">@TruncSafe(item.Nombre, 28)</span>
            <span class="psi-chip-stock @(item.Stock > 0 ? "ok" : "zero")">
                @FormatStock(item)
            </span>
        </button>
    </text>;

    private MarkupString HighlightMatch(string sku)
    {
        if (string.IsNullOrEmpty(value)) return (MarkupString)sku;
        var skuUp = sku.ToUpperInvariant();
        var q = value.ToUpperInvariant();
        int idx = skuUp.IndexOf(q);
        if (idx < 0) return (MarkupString)sku;
        var pre = sku.Substring(0, idx);
        var mid = sku.Substring(idx, q.Length);
        var post = sku.Substring(idx + q.Length);
        return (MarkupString)$"{pre}<mark>{mid}</mark>{post}";
    }

    private static string TruncSafe(string s, int len)
        => string.IsNullOrEmpty(s) ? "" : (s.Length > len ? s.Substring(0, len) + "..." : s);

    private static string FormatStock(CatalogItem it)
    {
        if (it.Tipo == "combo") return "combo";
        if (it.EsCafe) return $"{it.Stock:0}g";
        return $"{it.Stock:0}u";
    }
}

<style>
    .psi-root {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: #fafafa;
    }
    .psi-input-row {
        padding: 8px 10px;
        background: white;
        border-bottom: 1px solid #e5e7eb;
        display: flex; align-items: center; gap: 8px;
    }
    .psi-input {
        flex: 1; display: flex; align-items: center; gap: 6px;
        padding: 10px 12px;
        background: #f3f4f6; border-radius: 10px;
        min-height: 44px;
    }
    .psi-search-icon { font-size: 1.1rem; }
    .psi-value {
        flex: 1;
        font-family: monospace;
        font-size: 1.15rem;
        font-weight: 700;
        color: #111827;
        letter-spacing: 0.5px;
    }
    .psi-value:empty::before {
        content: attr(data-placeholder);
        color: #9ca3af;
    }
    .psi-clear-btn {
        background: transparent; border: none; cursor: pointer;
        font-size: 1rem; color: #6b7280; padding: 4px 8px;
    }
    .psi-search-time { font-size: 0.7rem; color: #6b7280; }

    /* Área de resultados toma todo el espacio sobrante y scrollea si se llena.
       Así el teclado de abajo NO se mueve al cambiar el contenido. */
    .psi-results-wrap {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
        -webkit-overflow-scrolling: touch;
    }

    /* Chip de marca activa al final (abajo del teclado, última cosa en pantalla) */
    .psi-marca-footer {
        background: #fef3c7;
        border-top: 2px solid #f59e0b;
        padding: 6px 12px;
        display: flex; align-items: center; justify-content: space-between;
        gap: 8px;
        font-size: 0.8rem;
        color: #78350f;
    }
    .psi-marca-clear {
        background: #b91c1c; color: white;
        border: none; border-radius: 8px;
        padding: 4px 10px;
        font-size: 0.75rem; font-weight: 700;
        cursor: pointer;
    }

    /* Grid de marcas (scrolleable, en el empty state) */
    .psi-marca-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        padding: 4px 10px 16px;
    }
    .psi-marca-chip {
        background: white;
        border: 2px solid #d1d5db;
        border-radius: 10px;
        padding: 10px 12px;
        display: flex; flex-direction: column; align-items: flex-start; gap: 2px;
        cursor: pointer;
        touch-action: manipulation;
    }
    .psi-marca-chip:active { background: #e0f2fe; border-color: #0284c7; }
    .psi-marca-chip.active { background: #1e40af; color: white; border-color: #1e3a8a; }
    .psi-marca-name { font-weight: 800; font-size: 0.92rem; }
    .psi-marca-count { font-size: 0.72rem; opacity: 0.7; }

    .psi-section-label {
        font-size: 0.78rem; font-weight: 700;
        color: #6b7280; padding: 10px 12px 4px;
        letter-spacing: 0.5px;
    }
    .psi-chips {
        display: flex; gap: 8px;
        padding: 4px 10px 10px;
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }
    .psi-chips::-webkit-scrollbar { display: none; }
    .psi-chip {
        position: relative;
        min-width: 130px; max-width: 160px;
        min-height: 78px;
        padding: 10px 12px;
        background: white;
        border: 2px solid #d1d5db;
        border-radius: 12px;
        display: flex; flex-direction: column; gap: 4px;
        cursor: pointer;
        text-align: left;
        touch-action: manipulation;
    }
    .psi-chip:active { background: #e0f2fe; border-color: #0284c7; }
    .psi-chip-nostock { border-color: #fca5a5; background: #fef2f2; }
    .psi-chip-sku {
        font-family: monospace; font-weight: 800;
        font-size: 1.05rem; color: #111827;
        line-height: 1.2;
    }
    .psi-chip-sku mark {
        background: #fef08a; color: #854d0e;
        padding: 0 1px; border-radius: 2px;
    }
    .psi-chip-name {
        font-size: 0.75rem; color: #4b5563;
        line-height: 1.2;
    }
    .psi-chip-stock {
        position: absolute; bottom: 6px; right: 8px;
        font-size: 0.72rem; font-weight: 700;
    }
    .psi-chip-stock.ok { color: #16a34a; }
    .psi-chip-stock.zero { color: #b91c1c; }
    .psi-chip-fav {
        position: absolute; top: 4px; right: 6px;
        font-size: 0.85rem;
    }
    .psi-empty-state, .psi-no-results {
        text-align: center; padding: 30px 20px;
        color: #4b5563;
    }
</style>
