@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            @{
                // Rutas publicas (no requieren login). Se renderizan con RouteView directo
                // para esquivar el AuthorizeRouteView, que por default exige auth para TODAS
                // las paginas y dispara <NotAuthorized> antes de leer [AllowAnonymous].
                // Incluye: /r/ (mapeo chofer), /he/ (horas extras empleados), /v/ (viajes),
                // /stock/ (carga stock deposito), /login.
                var relPath = Navigation.ToBaseRelativePath(Navigation.Uri);
                var isPublic = relPath.StartsWith("r/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("he/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("v/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("stock/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("pedidos/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("comprobante/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("panel-pagos/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("saldos-clientes/", StringComparison.OrdinalIgnoreCase)
                            || relPath.StartsWith("login", StringComparison.OrdinalIgnoreCase);
            }
            @if (isPublic)
            {
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.LoginLayout)" />
            }
            else
            {
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                    <NotAuthorized>
                        <Web.Shared.RedirectToLogin />
                    </NotAuthorized>
                </AuthorizeRouteView>
            }
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <div class="view-header">
                    <h2>Pagina no encontrada</h2>
                    <p class="view-subtitle">La pagina que buscas no existe.</p>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
