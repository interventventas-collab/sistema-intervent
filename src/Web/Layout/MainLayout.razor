@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject SyncProgressTracker SyncProgress
@inject UploadProgressService UploadProgress
@inject BrandSettingsService BrandSettings
@inject IJSRuntime JS
@inject ApiClient Api
@inject OperatorService Operator
@inject CurrentCompanyService Company
@implements IDisposable

<aside class="sidebar @(sidebarOpen ? "open" : "") @(sidebarCollapsed ? "collapsed" : "") @(IsDevEnvironment ? "sidebar-dev" : "sidebar-prod")" id="sidebar">
    @if (IsDevEnvironment)
    {
        <div class="dev-environment-banner" title="Estás en el entorno de DESARROLLO. Los datos NO son los de producción.">
            🛠 DESARROLLO
        </div>
    }
    else
    {
        <div class="prod-environment-banner" title="Estás en el entorno de PRODUCCIÓN. Todo lo que hagas afecta los datos reales del negocio.">
            🔒 PRODUCCIÓN
        </div>
    }
    <div class="sidebar-brand">
        @if (BrandSettings.HasCustomLogo)
        {
            <img src="@BrandSettings.BrandLogo" alt="Logo" class="sidebar-brand-logo" />
        }
        else
        {
            <span class="sidebar-brand-icon">@SvgIcons.GetByName(BrandSettings.BrandIcon)</span>
        }
        <span class="sidebar-brand-text">@BrandSettings.BrandName</span>
        <button class="sidebar-collapse-btn" @onclick="ToggleCollapse" title="@(sidebarCollapsed ? "Expandir menu" : "Colapsar menu")">
            <span class="sidebar-collapse-icon">@(sidebarCollapsed ? SvgIcons.ChevronRight : SvgIcons.ChevronLeft)</span>
        </button>
    </div>
    <nav class="sidebar-nav" role="navigation" aria-label="Menu principal">
        @* ═════════════ 1. DASHBOARD ═════════════ *@
        @if (HasPerm("dashboard"))
        {
            <NavItem Href="/" Label="Dashboard" Icon="@SvgIcons.Dashboard"
                     IsActive="@IsActive("/")" OnClick="@(() => NavigateTo("/"))" />
        }

        @* ═════════════ 1B. CAFE (modulo independiente, debajo de Dashboard) ═════════════
           Negocio de venta de cafe e insumos, totalmente aislado del resto del ERP. *@
        @if (HasPerm("cafe"))
        {
            <NavGroup Label="Ventas por fuera" Icon="@SvgIcons.Brand"
                      HasActiveChild="@(IsActive("/cafe") || IsActive("/cafe/ventas") || IsActive("/cafe/productos") || IsActive("/cafe/combos") || IsActive("/cafe/oems") || IsActive("/cafe/clientes") || IsActive("/cafe/clientes-mapeados") || IsActive("/cafe/configuracion") || IsActive("/cafe/compras") || IsActive("/cafe/proveedores") || IsActive("/cafe/marcas") || IsActive("/cafe/listas-precios") || IsActive("/cafe/consultas") || IsActive("/cafe/cotejo") || IsActive("/cafe/descuentos") || IsActive("/cafe/kits") || IsActive("/cafe/reglas-precios") || IsActive("/cafe/saldos") || IsActive("/cafe/maquinas"))">
                <NavItem Href="/cafe" Label="Inicio" Icon="@SvgIcons.Dashboard"
                         IsActive="@IsActive("/cafe")" OnClick="@(() => NavigateTo("/cafe"))" />
                <NavItem Href="/cafe/consultas" Label="Consultas" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/consultas")" OnClick="@(() => NavigateTo("/cafe/consultas"))" />
                <NavItem Href="/cafe/cotejo" Label="Cotejo MeLi" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/cotejo")" OnClick="@(() => NavigateTo("/cafe/cotejo"))" />
                @* Pantallas "Descuentos" y "Reglas de precios" ocultas — la matriz fue deprecada el
                   2026-05-12 a favor de precios directos PrecioBar/PrecioOtro por producto. Las paginas
                   y tablas siguen existiendo (para no perder datos historicos), pero ya no se accede
                   desde el sidebar ni se usan en el motor de precios. *@
                <NavItem Href="/cafe/ventas" Label="Ventas" Icon="@SvgIcons.ShoppingBag"
                         IsActive="@IsActive("/cafe/ventas")" OnClick="@(() => NavigateTo("/cafe/ventas"))" />
                <NavItem Href="/cafe/listas-precios" Label="Listas de precios" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/listas-precios")" OnClick="@(() => NavigateTo("/cafe/listas-precios"))" />
                <NavItem Href="/cafe/compras" Label="Compras" Icon="@SvgIcons.Folder"
                         IsActive="@IsActive("/cafe/compras")" OnClick="@(() => NavigateTo("/cafe/compras"))" />
                <NavItem Href="/cafe/productos" Label="Productos" Icon="@SvgIcons.Package"
                         IsActive="@IsActive("/cafe/productos")" OnClick="@(() => NavigateTo("/cafe/productos"))" />
                <NavItem Href="/cafe/combos" Label="Combos" Icon="@SvgIcons.Package"
                         IsActive="@IsActive("/cafe/combos")" OnClick="@(() => NavigateTo("/cafe/combos"))" />
                <NavItem Href="/cafe/kits" Label="Kits" Icon="@SvgIcons.Package"
                         IsActive="@IsActive("/cafe/kits")" OnClick="@(() => NavigateTo("/cafe/kits"))" />
                <NavItem Href="/cafe/oems" Label="OEMs" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/oems")" OnClick="@(() => NavigateTo("/cafe/oems"))" />
                <NavItem Href="/cafe/marcas" Label="Marcas" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/marcas")" OnClick="@(() => NavigateTo("/cafe/marcas"))" />
                <NavItem Href="/cafe/proveedores" Label="Proveedores" Icon="@SvgIcons.Users"
                         IsActive="@IsActive("/cafe/proveedores")" OnClick="@(() => NavigateTo("/cafe/proveedores"))" />
                <NavItem Href="/cafe/clientes" Label="Clientes" Icon="@SvgIcons.Users"
                         IsActive="@IsActive("/cafe/clientes")" OnClick="@(() => NavigateTo("/cafe/clientes"))" />
                <NavItem Href="/cafe/clientes-mapeados" Label="Clientes Mapeados" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/clientes-mapeados")" OnClick="@(() => NavigateTo("/cafe/clientes-mapeados"))" />
                <NavItem Href="/cafe/configuracion" Label="Configuración" Icon="@SvgIcons.Settings"
                         IsActive="@IsActive("/cafe/configuracion")" OnClick="@(() => NavigateTo("/cafe/configuracion"))" />
                @* Migracion temporal: saldos del sistema viejo a matchear con clientes *@
                <NavItem Href="/cafe/saldos" Label="💰 Saldos migración" Icon="@SvgIcons.Database"
                         IsActive="@IsActive("/cafe/saldos")" OnClick="@(() => NavigateTo("/cafe/saldos"))" />
                <NavItem Href="/cafe/maquinas" Label="☕ Máquinas (comodato/financ.)" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/cafe/maquinas")" OnClick="@(() => NavigateTo("/cafe/maquinas"))" />

                @* Subgrupo Tesoreria — agregado 2026-05-12 (Fase 1) *@
                @if (HasPerm("cafe-tesoreria"))
                {
                    <NavItem Href="/cafe/tesoreria/cajas" Label="💰 Cajas" Icon="@SvgIcons.Database"
                             IsActive="@IsActive("/cafe/tesoreria/cajas")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cajas"))" />
                    <NavItem Href="/cafe/tesoreria/resumen" Label="📊 Resumen Tesorería" Icon="@SvgIcons.Dashboard"
                             IsActive="@IsActive("/cafe/tesoreria/resumen")" OnClick="@(() => NavigateTo("/cafe/tesoreria/resumen"))" />
                    <NavItem Href="/cafe/tesoreria/cobranzas" Label="📥 Cobranzas" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/cafe/tesoreria/cobranzas")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cobranzas"))" />
                    <NavItem Href="/cafe/tesoreria/pagos" Label="📤 Pagos" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/cafe/tesoreria/pagos")" OnClick="@(() => NavigateTo("/cafe/tesoreria/pagos"))" />
                    <NavItem Href="/cafe/tesoreria/cheques" Label="📄 Cheques" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/tesoreria/cheques")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cheques"))" />
                }

                @* Subgrupo Depositos / Stock — agregado 2026-05-13 (Fase 1 multi-deposito) *@
                @if (HasPerm("cafe-depositos"))
                {
                    <NavItem Href="/cafe/depositos" Label="📦 Depósitos" Icon="@SvgIcons.Store"
                             IsActive="@IsActive("/cafe/depositos")" OnClick="@(() => NavigateTo("/cafe/depositos"))" />
                    <NavItem Href="/cafe/stock-masivo" Label="📊 Stock masivo" Icon="@SvgIcons.Edit"
                             IsActive="@IsActive("/cafe/stock-masivo")" OnClick="@(() => NavigateTo("/cafe/stock-masivo"))" />
                }

                @* Horas Extras de empleados — agregado 2026-05-15 *@
                <NavItem Href="/horas-extras" Label="🕐 Horas Extras" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/horas-extras")" OnClick="@(() => NavigateTo("/horas-extras"))" />
            </NavGroup>
        }

        @* ═════════════ 2. INVENTARIOS (LEGACY — DESACTIVADO 2026-05-13) ═════════════
           Modulo inventario viejo basado en tablas vacias (Products, Depositos). Se reemplazo por:
           - Cafe → Depositos (multi-deposito sobre Cafe_Productos)
           - Cafe → Stock masivo (edicion bulk de stock por deposito)
           Para reactivar, cambiar ENABLE_INVENTARIOS_LEGACY a true. *@
        @{ const bool ENABLE_INVENTARIOS_LEGACY = false; }
        @if (ENABLE_INVENTARIOS_LEGACY && (HasPerm("depositos") || HasPerm("modificacion-stock") || HasPerm("movimientos-depositos") || HasPerm("actualizacion-stock")))
        {
            <NavGroup Label="Inventarios" Icon="@SvgIcons.Store"
                      HasActiveChild="@(IsActive("/depositos") || IsActive("/modificacion-stock") || IsActive("/movimientos-depositos") || IsActive("/actualizacion-stock"))">
                @if (HasPerm("depositos"))
                {
                    <NavItem Href="/depositos" Label="Depósitos" Icon="@SvgIcons.Store"
                             IsActive="@IsActive("/depositos")" OnClick="@(() => NavigateTo("/depositos"))" />
                }
                @if (HasPerm("modificacion-stock"))
                {
                    <NavItem Href="/modificacion-stock" Label="Modificación de stock" Icon="@SvgIcons.Edit"
                             IsActive="@IsActive("/modificacion-stock")" OnClick="@(() => NavigateTo("/modificacion-stock"))" />
                }
                @if (HasPerm("movimientos-depositos"))
                {
                    <NavItem Href="/movimientos-depositos" Label="Movimientos entre depósitos" Icon="@SvgIcons.Refresh"
                             IsActive="@IsActive("/movimientos-depositos")" OnClick="@(() => NavigateTo("/movimientos-depositos"))" />
                }
                @if (HasPerm("actualizacion-stock"))
                {
                    <NavItem Href="/actualizacion-stock" Label="Actualización masiva de stock" Icon="@SvgIcons.Folder"
                             IsActive="@IsActive("/actualizacion-stock")" OnClick="@(() => NavigateTo("/actualizacion-stock"))" />
                }
            </NavGroup>
        }

        @* ═════════════ 4. MERCADOLIBRE ═════════════
           Solo visible para INTERVENT (es la unica empresa que vende por ML).
           Si no hay empresa elegida, se sigue mostrando para no esconderlo a usuarios viejos.
           Re-vincular publicaciones vive aca (es una accion de ML, no de inventario). *@
        @if ((HasPerm("publicaciones") || HasPerm("ordenes") || HasPerm("import-productos") || HasPerm("mapeo") || HasPerm("me1")) && (!Company.HasCompany || string.Equals(Company.Current, "INTERVENT", StringComparison.OrdinalIgnoreCase)))
        {
            <NavGroup Label="MercadoLibre" Icon="@SvgIcons.Store"
                      HasActiveChild="@(IsActive("/publicaciones") || IsActive("/ordenes") || IsActive("/relink-meli-orphans") || IsActive("/mapeo") || IsActive("/meli/me1/entregas"))">
                @if (HasPerm("publicaciones"))
                {
                    <NavItem Href="/publicaciones" Label="Publicaciones" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/publicaciones")" OnClick="@(() => NavigateTo("/publicaciones"))" />
                }
                @if (HasPerm("ordenes"))
                {
                    <NavItem Href="/ordenes" Label="Ordenes" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/ordenes")" OnClick="@(() => NavigateTo("/ordenes"))" />
                }
                @if (HasPerm("mapeo"))
                {
                    <NavItem Href="/mapeo" Label="Mapeo" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/mapeo")" OnClick="@(() => NavigateTo("/mapeo"))" />
                }
                @* Grupo me1: por ahora solo tiene 'Entregas'. Pensado para colgarle mas pantallas adelante. *@
                @if (HasPerm("me1"))
                {
                    <NavGroup Label="me1" Icon="@SvgIcons.Torino"
                              HasActiveChild="@IsActive("/meli/me1/entregas")">
                        <NavItem Href="/meli/me1/entregas" Label="Entregas" Icon="@SvgIcons.Check"
                                 IsActive="@IsActive("/meli/me1/entregas")" OnClick="@(() => NavigateTo("/meli/me1/entregas"))" />
                    </NavGroup>
                }
                @if (HasPerm("import-productos"))
                {
                    <NavItem Href="/relink-meli-orphans" Label="Re-vincular publicaciones" Icon="@SvgIcons.Refresh"
                             IsActive="@IsActive("/relink-meli-orphans")" OnClick="@(() => NavigateTo("/relink-meli-orphans"))" />
                }
            </NavGroup>
        }

        @* ═════════════ 6. FINANZAS Y RRHH (DESACTIVADO) ═════════════
           Reemplazado por el modulo "Nominas" que ya cubre Empleados+Sueldos del flujo nuevo.
           Los datos viejos en las tablas siguen intactos. Para reactivar el menu,
           cambiá ENABLE_FINANZAS a true. *@
        @{ const bool ENABLE_FINANZAS = false; }
        @if (ENABLE_FINANZAS && (HasPerm("tesoreria") || HasPerm("empleados") || HasPerm("sueldos")))
        {
            <NavGroup Label="Finanzas" Icon="@SvgIcons.Admin"
                      HasActiveChild="@(IsActive("/tesoreria") || IsActive("/empleados") || IsActive("/sueldos"))">
                @if (HasPerm("tesoreria"))
                {
                    <NavItem Href="/tesoreria" Label="Tesoreria" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/tesoreria")" OnClick="@(() => NavigateTo("/tesoreria"))" />
                }
                @if (HasPerm("empleados"))
                {
                    <NavItem Href="/empleados" Label="Empleados" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/empleados")" OnClick="@(() => NavigateTo("/empleados"))" />
                }
                @if (HasPerm("sueldos"))
                {
                    <NavItem Href="/sueldos" Label="Sueldos" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/sueldos")" OnClick="@(() => NavigateTo("/sueldos"))" />
                }
            </NavGroup>
        }

        @* ═════════════ 7. ALQUILERES (modulo independiente) ═════════════
           Modulo aparte para alquiler de equipos para eventos.
           No comparte datos con el resto del ERP (productos, ventas, marcas, etc.). *@
        @if (HasPerm("alquileres"))
        {
            <NavGroup Label="Alquileres" Icon="@SvgIcons.Calendar"
                      HasActiveChild="@(IsActive("/alquileres") || IsActive("/alquileres/equipos") || IsActive("/alquileres/clientes") || IsActive("/alquileres/reservas") || IsActive("/alquileres/calendario"))">
                <NavItem Href="/alquileres" Label="Inicio" Icon="@SvgIcons.Dashboard"
                         IsActive="@IsActive("/alquileres")" OnClick="@(() => NavigateTo("/alquileres"))" />
                <NavItem Href="/alquileres/reservas" Label="Reservas" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/alquileres/reservas")" OnClick="@(() => NavigateTo("/alquileres/reservas"))" />
                <NavItem Href="/alquileres/calendario" Label="Calendario" Icon="@SvgIcons.Calendar"
                         IsActive="@IsActive("/alquileres/calendario")" OnClick="@(() => NavigateTo("/alquileres/calendario"))" />
                <NavItem Href="/alquileres/equipos" Label="Equipos" Icon="@SvgIcons.Package"
                         IsActive="@IsActive("/alquileres/equipos")" OnClick="@(() => NavigateTo("/alquileres/equipos"))" />
                <NavItem Href="/alquileres/clientes" Label="Clientes" Icon="@SvgIcons.Users"
                         IsActive="@IsActive("/alquileres/clientes")" OnClick="@(() => NavigateTo("/alquileres/clientes"))" />
            </NavGroup>
        }

        @* ═════════════ 8. NOMINAS (modulo independiente) ═════════════
           Modulo aparte para liquidacion de sueldos.
           No comparte datos con Empleados/Sueldos del ERP principal. *@
        @if (HasPerm("nominas"))
        {
            <NavGroup Label="Nóminas" Icon="@SvgIcons.Users"
                      HasActiveChild="@(IsActive("/nominas") || IsActive("/nominas/empleados") || IsActive("/nominas/liquidaciones"))">
                <NavItem Href="/nominas" Label="Inicio" Icon="@SvgIcons.Dashboard"
                         IsActive="@IsActive("/nominas")" OnClick="@(() => NavigateTo("/nominas"))" />
                <NavItem Href="/nominas/empleados" Label="Empleados" Icon="@SvgIcons.Users"
                         IsActive="@IsActive("/nominas/empleados")" OnClick="@(() => NavigateTo("/nominas/empleados"))" />
                <NavItem Href="/nominas/liquidaciones" Label="Liquidaciones" Icon="@SvgIcons.Tag"
                         IsActive="@IsActive("/nominas/liquidaciones")" OnClick="@(() => NavigateTo("/nominas/liquidaciones"))" />
            </NavGroup>
        }

        @* ═════════════ 9. COMUNICACIONES (links externos) ═════════════ *@
        <NavGroup Label="Comunicaciones" Icon="@SvgIcons.MessageCircle" HasActiveChild="false">
            <NavItem Href="https://web.whatsapp.com" Label="WhatsApp Web" Icon="@SvgIcons.MessageCircle" IsExternal="true" />
            <NavItem Href="https://mail.google.com" Label="Gmail" Icon="@SvgIcons.Mail" IsExternal="true" />
            <NavItem Href="https://calendar.google.com" Label="Google Calendar" Icon="@SvgIcons.Calendar" IsExternal="true" />
            <NavItem Href="https://drive.google.com" Label="Google Drive" Icon="@SvgIcons.Folder" IsExternal="true" />
        </NavGroup>

        @* ═════════════ 10. ADMINISTRACION (sistema) ═════════════
           Solo cosas de configuracion del sistema: usuarios, roles, integraciones, archivos
           tecnicos, auditoria, backups, configuracion general. *@
        @if (HasPerm("usuarios") || HasPerm("roles") || HasPerm("integraciones") || HasPerm("procesos") || HasPerm("archivos") || HasPerm("auditoria") || HasPerm("backups") || HasPerm("vault"))
        {
            <NavGroup Label="Administración" Icon="@SvgIcons.Admin"
                      HasActiveChild="@(IsActive("/usuarios") || IsActive("/roles") || IsActive("/integraciones") || IsActive("/procesos") || IsActive("/archivos") || IsActive("/auditoria") || IsActive("/backups") || IsActive("/config") || IsActive("/vault"))">
                @if (HasPerm("usuarios"))
                {
                    <NavItem Href="/usuarios" Label="Usuarios" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/usuarios")" OnClick="@(() => NavigateTo("/usuarios"))" />
                }
                @if (HasPerm("roles"))
                {
                    <NavItem Href="/roles" Label="Roles" Icon="@SvgIcons.Shield"
                             IsActive="@IsActive("/roles")" OnClick="@(() => NavigateTo("/roles"))" />
                }
                @if (HasPerm("integraciones"))
                {
                    <NavItem Href="/integraciones" Label="Integraciones" Icon="@SvgIcons.Link"
                             IsActive="@IsActive("/integraciones")" OnClick="@(() => NavigateTo("/integraciones"))" />
                }
                @if (HasPerm("procesos"))
                {
                    <NavItem Href="/procesos" Label="Procesos" Icon="@SvgIcons.Timer"
                             IsActive="@IsActive("/procesos")" OnClick="@(() => NavigateTo("/procesos"))" />
                }
                @if (HasPerm("archivos"))
                {
                    <NavItem Href="/archivos" Label="Archivos" Icon="@SvgIcons.Folder"
                             IsActive="@IsActive("/archivos")" OnClick="@(() => NavigateTo("/archivos"))" />
                }
                @if (HasPerm("auditoria"))
                {
                    <NavItem Href="/auditoria" Label="Auditoría" Icon="@SvgIcons.History"
                             IsActive="@IsActive("/auditoria")" OnClick="@(() => NavigateTo("/auditoria"))" />
                }
                @if (HasPerm("backups"))
                {
                    <NavItem Href="/backups" Label="Backups" Icon="@SvgIcons.Backup"
                             IsActive="@IsActive("/backups")" OnClick="@(() => NavigateTo("/backups"))" />
                }
                @if (HasPerm("vault"))
                {
                    <NavItem Href="/vault" Label="Bóveda" Icon="@SvgIcons.Shield"
                             IsActive="@IsActive("/vault")" OnClick="@(() => NavigateTo("/vault"))" />
                }
                @if (HasPerm("config"))
                {
                    <NavItem Href="/config" Label="Configuración" Icon="@SvgIcons.Settings"
                             IsActive="@IsActive("/config")" OnClick="@(() => NavigateTo("/config"))" />
                }
            </NavGroup>
        }
    </nav>
    <div class="sidebar-user">
        <div class="sidebar-user-avatar">@SvgIcons.User</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">@username</span>
            <span class="sidebar-user-role">@role</span>
        </div>
        <button class="sidebar-menu-btn" @onclick="ToggleUserMenu" @onclick:stopPropagation="true" title="Menu">
            <span class="sidebar-menu-icon @(userMenuOpen ? "rotated" : "")">@SvgIcons.ChevronUp</span>
        </button>
        @if (userMenuOpen)
        {
            <div class="sidebar-user-dropdown">
                <button class="sidebar-dropdown-item" @onclick="GoToProfile">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Edit</span>
                    <span class="sidebar-dropdown-text">Editar Perfil</span>
                </button>
                <button class="sidebar-dropdown-item sidebar-dropdown-danger" @onclick="Logout">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Logout</span>
                    <span class="sidebar-dropdown-text">Cerrar Sesion</span>
                </button>
            </div>
        }
    </div>
</aside>

@* ═════════════ FAB: Botón flotante "Nueva Venta" siempre visible ═════════════
   Atajo rápido para abrir el modal de Nueva Venta del módulo Café desde cualquier
   pantalla. Click navega a /cafe/ventas?nueva=<timestamp> — la página de ventas
   detecta el query y dispara ShowCreate() automáticamente. *@
@if (HasPerm("cafe"))
{
    <button class="fab-nueva-venta" @onclick="OpenNuevaVentaShortcut"
            title="Cargar una venta nueva (atajo)"
            aria-label="Nueva venta">
        <span class="fab-nueva-venta-plus">+</span>
        <span class="fab-nueva-venta-label">Nueva Venta</span>
    </button>
}

<main class="main-wrapper @(sidebarCollapsed ? "main-collapsed" : "")">
    <header class="topbar">
        <div class="topbar-left">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Abrir menu">
                @SvgIcons.Menu
            </button>
            @* Selector de empresa desactivado — el sistema funciona sin filtro por empresa.
               Si en algun momento querés volver a habilitarlo, cambiá ENABLE_COMPANY_SELECTOR a true. *@
            @{ const bool ENABLE_COMPANY_SELECTOR = false; }
            @if (ENABLE_COMPANY_SELECTOR)
            {
                <button class="topbar-company-btn" @onclick="() => showCompanyModal = true" title="Cambiar empresa de trabajo">
                    <span class="topbar-company-name">@(Company.HasCompany ? Company.CurrentDisplayName : BrandSettings.BrandName)</span>
                    <span class="topbar-company-chevron">@SvgIcons.ChevronRight</span>
                </button>
            }
            else
            {
                <span class="topbar-company-name" style="font-weight: 700; padding: 0.4rem 0.6rem;">@BrandSettings.BrandName</span>
            }
            @if (Operator.HasOperator)
            {
                <button class="btn btn-secondary" style="margin-left: 0.8rem; font-size: 0.78rem; padding: 0.25rem 0.6rem;"
                        @onclick="() => showOperatorModal = true" title="Cambiar operador">
                    👤 @Operator.Current
                </button>
            }
        </div>
        <div class="topbar-actions">
            <MeliQuestionsBell />
            @if (UploadProgress.IsUploading)
            {
                <div class="topbar-upload-indicator" @onclick="() => UploadProgress.RequestReopen()" title="Ver detalle de subida">
                    <span class="topbar-upload-spinner"></span>
                    <span class="topbar-upload-text">Subiendo @UploadProgress.DoneCount/@UploadProgress.TotalCount</span>
                    <div class="topbar-upload-bar">
                        <div class="topbar-upload-bar-fill" style="width: @(UploadProgress.Percentage)%"></div>
                    </div>
                    <button class="topbar-upload-cancel" @onclick="CancelUpload" @onclick:stopPropagation="true" title="Cancelar subida"><i class="fa-solid fa-xmark"></i></button>
                </div>
            }
            @if (SyncProgress.State.IsActive && !SyncProgress.State.ShowModal)
            {
                <div class="topbar-sync-indicator @(SyncProgress.State.Status)" @onclick="OpenSyncModal" title="@SyncProgress.State.Description">
                    @if (SyncProgress.State.Status == "running")
                    {
                        <span class="topbar-sync-spinner"></span>
                        <span class="topbar-sync-text">@SyncProgress.State.Percentage%</span>
                        <div class="topbar-sync-bar">
                            <div class="topbar-sync-bar-fill" style="width: @(SyncProgress.State.Percentage)%"></div>
                        </div>
                    }
                    else if (SyncProgress.State.Status == "completed")
                    {
                        <span class="topbar-sync-text"><i class="fa-solid fa-circle-check"></i> Sincronizado</span>
                        <button class="topbar-sync-dismiss" @onclick="DismissSync" @onclick:stopPropagation="true" title="Cerrar"><i class="fa-solid fa-xmark"></i></button>
                    }
                    else if (SyncProgress.State.Status == "error")
                    {
                        <span class="topbar-sync-text"><i class="fa-solid fa-circle-xmark"></i> Error</span>
                        <button class="topbar-sync-dismiss" @onclick="DismissSync" @onclick:stopPropagation="true" title="Cerrar"><i class="fa-solid fa-xmark"></i></button>
                    }
                </div>
            }
        </div>
    </header>
    <div class="content">
        @Body
    </div>
</main>

