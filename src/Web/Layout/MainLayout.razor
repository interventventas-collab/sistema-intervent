                    <NavItem Href="/integraciones" Label="Integraciones" Icon="@SvgIcons.Link"
                             IsActive="@IsActive("/integraciones")" OnClick="@(() => NavigateTo("/integraciones"))" />
                    <NavItem Href="/sitios" Label="Marcas / Sitios" Icon="@SvgIcons.Link"
                             IsActive="@IsActive("/sitios")" OnClick="@(() => NavigateTo("/sitios"))" />
                    <NavItem Href="/integraciones/camaras" Label="Cámaras" Icon="@SvgIcons.Camera"
                             IsActive="@IsActive("/integraciones/camaras")" OnClick="@(() => NavigateTo("/integraciones/camaras"))" />
                    <NavItem Href="/integraciones/telegram" Label="Telegram" Icon="@SvgIcons.MessageCircle"
                             IsActive="@IsActive("/integraciones/telegram")" OnClick="@(() => NavigateTo("/integraciones/telegram"))" />
                }
                @if (HasPerm("procesos"))
                {
                    <NavItem Href="/procesos" Label="Procesos" Icon="@SvgIcons.Timer"
                             IsActive="@IsActive("/procesos")" OnClick="@(() => NavigateTo("/procesos"))" />
                }
                @if (HasPerm("archivos"))
                {
                    <NavItem Href="/archivos" Label="Archivos" Icon="@SvgIcons.Folder"
                             IsActive="@IsActive("/archivos")" OnClick="@(() => NavigateTo("/archivos"))" />
                }
                @if (HasPerm("auditoria"))
                {
                    <NavItem Href="/auditoria" Label="Auditoría" Icon="@SvgIcons.History"
                             IsActive="@IsActive("/auditoria")" OnClick="@(() => NavigateTo("/auditoria"))" />
                }
                @if (HasPerm("backups"))
                {
                    <NavItem Href="/backups" Label="Backups" Icon="@SvgIcons.Backup"
                             IsActive="@IsActive("/backups")" OnClick="@(() => NavigateTo("/backups"))" />
                }
                @if (HasPerm("vault"))
                {
                    <NavItem Href="/vault" Label="Bóveda" Icon="@SvgIcons.Shield"
                             IsActive="@IsActive("/vault")" OnClick="@(() => NavigateTo("/vault"))" />
                }
                @if (HasPerm("config"))
                {
                    <NavItem Href="/config" Label="Configuración" Icon="@SvgIcons.Settings"
                             IsActive="@IsActive("/config")" OnClick="@(() => NavigateTo("/config"))" />
                }
                @* 2026-07-21: "Editar visibilidad" reubicado acá (antes estaba arriba de todo, muy
                   llamativo). Solo admin (permiso "cafe"). Al activarlo aparece el panel con chips D/O. *@
                @if (HasPerm("cafe"))
                {
                    <button class="sidebar-edit-btn @(menuEditMode ? "active" : "")" @onclick="ToggleMenuEditMode"
                            title="@(menuEditMode ? "Salir del modo edición" : "Modo edición de visibilidad por rol")">
                        @if (menuEditMode)
                        {
                            <span>✓ Terminar edición</span>
                        }
                        else
                        {
                            <span>✏️ Editar visibilidad</span>
                        }
                    </button>
                    @if (menuEditMode)
                    {
                        <div class="menu-edit-panel">
                            <div class="menu-edit-panel-header">
                                🛠 Editar visibilidad por rol
                                <div style="font-size:0.72rem; font-weight:400; margin-top: 0.2rem; color: #fed7aa;">
                                    Tildá <strong>D</strong> (DEPOSITO) u <strong>O</strong> (OFICINA) según querés
                                    que vean cada item. Guarda al toque.
                                </div>
                            </div>
                            <div class="menu-edit-panel-body">
                                @foreach (var entry in MenuCatalog)
                                {
                                    var key = entry.Key;
                                    var label = entry.Value.Label;
                                    var emoji = entry.Value.Emoji;
                                    var depo = MenuVisibility.IsEnabled("deposito", key);
                                    var ofi = MenuVisibility.IsEnabled("oficina", key);
                                    <div class="menu-edit-row">
                                        <span class="menu-edit-row-label">@emoji @label</span>
                                        <button class="nav-chip @(depo ? "on" : "off")"
                                                title="Mostrar a DEPOSITO"
                                                @onclick="@(() => OnMenuToggleVisibility(key, "deposito", !depo))">D</button>
                                        <button class="nav-chip @(ofi ? "on" : "off")"
                                                title="Mostrar a OFICINA"
                                                @onclick="@(() => OnMenuToggleVisibility(key, "oficina", !ofi))">O</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </NavGroup>
        }
    </nav>
    @* 2026-07-06: chat del equipo embebido en el menú, SOLO para el usuario Depósito
       (menú corto con espacio libre). Siempre a la vista en cualquier pantalla. *@
    @if (HasPerm("deposito"))
    {
        <SidebarChat />
    }
    <div class="sidebar-user">
        <div class="sidebar-user-avatar">@SvgIcons.User</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">@username</span>
            <span class="sidebar-user-role">@role</span>
        </div>
        <button class="sidebar-menu-btn" @onclick="ToggleUserMenu" @onclick:stopPropagation="true" title="Menu">
            <span class="sidebar-menu-icon @(userMenuOpen ? "rotated" : "")">@SvgIcons.ChevronUp</span>
        </button>
        @if (userMenuOpen)
        {
            <div class="sidebar-user-dropdown">
                <button class="sidebar-dropdown-item" @onclick="GoToProfile">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Edit</span>
                    <span class="sidebar-dropdown-text">Editar Perfil</span>
                </button>
                <button class="sidebar-dropdown-item sidebar-dropdown-danger" @onclick="Logout">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Logout</span>
                    <span class="sidebar-dropdown-text">Cerrar Sesion</span>
                </button>
            </div>
        }
    </div>
</aside>
}

@* Botón "Nueva Venta" - vive dentro del topbar (ver más abajo) para quedar
   siempre visible arriba a la derecha sin tapar otros íconos. *@

<main class="main-wrapper @(sidebarCollapsed ? "main-collapsed" : "") @(IsEmbedded ? "main-embedded" : "")">
@if (!IsEmbedded)
{
    @* 2026-07-08: fila de chips arriba de todo (empresa/usuario · reloj · dólar · disco).
       Se movió acá lo que antes estaba suelto en la barra de menú y en la tira del dashboard,
       para que todo el resumen viva en una fila propia, sin encimarse con el menú. *@
    <div class="topstrip">
        <div class="topstrip-chips">
        @* Empresa + usuario. Click = cambiar operador (pide PIN). Candado = bloquear ahora. *@
        <div class="topchip @(Operator.HasOperator ? "topchip-btn" : "")"
             @onclick="OnEmpresaChipClick"
             title="@(Operator.HasOperator ? "Cambiar operador (pide PIN)" : "")">
            <span class="topchip-ico" style="background:#eef2ff; color:#4338ca;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l7-4l7 4v14"/><path d="M9 9h.01M9 12h.01M9 15h.01M15 9h.01M15 12h.01M15 15h.01"/></svg>
            </span>
            <span>
                <span class="topchip-value" style="display:block;">@BrandSettings.BrandName</span>
                @if (Operator.HasOperator)
                {
                    <span class="topchip-label" style="display:inline-flex; align-items:center; gap:3px;">
                        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        @Operator.Current
                    </span>
                }
            </span>
            @if (Operator.HasOperator && requierePinLock)
            {
                <button class="topchip-lock" @onclick="OnBloquearAhoraClick" @onclick:stopPropagation="true"
                        title="Bloquear ahora (vuelve a pedir PIN)">
                    <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                </button>
            }
        </div>

        @* Reloj *@
        <div class="topchip" title="Hora Argentina">
            <span class="topchip-ico" style="background:#eef2ff; color:#4338ca;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            </span>
            <span>
                <span class="topchip-value" style="display:block;">@_arNow.ToString("HH:mm")</span>
                <span class="topchip-label" style="text-transform:capitalize;">@_arNow.ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-AR"))</span>
            </span>
        </div>

        @* Dólar BNA (se esconde en celu para no amontonar) *@
        <div class="topchip topchip-secondary" title="Dólar BNA">
            <span class="topchip-ico" style="background:#eaf3de; color:#3B6D11;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            </span>
            <span>
                <span class="topchip-label" style="display:block;">Dólar BNA@(_dolar?.Fecha is null ? "" : " · " + _dolar.Fecha)</span>
                @if (_dolar is not null && _dolar.Compra is not null && _dolar.Venta is not null)
                {
                    <span class="topchip-value">
                        <span style="color:#16a34a;">$@_dolar.Compra.Value.ToString("N0", new System.Globalization.CultureInfo("es-AR"))</span>
                        <span style="color:#9ca3af;"> / </span>
                        <span style="color:#dc2626;">$@_dolar.Venta.Value.ToString("N0", new System.Globalization.CultureInfo("es-AR"))</span>
                    </span>
                }
                else
                {
                    <span class="topchip-value" style="color:#9ca3af;">…</span>
                }
            </span>
        </div>

        @* Disco del servidor (se esconde en celu). Dato que deja el robot de las 2 AM. *@
        <div class="topchip topchip-secondary" title="Espacio en disco del servidor">
            <span class="topchip-ico" style="background:#e6f1fb; color:#185fa5;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>
            </span>
            <span>
                <span class="topchip-label" style="display:block;">Disco@(_disk?.At is null ? "" : " · " + _disk.At)</span>
                @if (_disk is null)
                {
                    <span class="topchip-value" style="color:#9ca3af;">…</span>
                }
                else
                {
                    var dColor = _disk.Pct >= 85 ? "#dc2626" : _disk.Pct >= 70 ? "#d97706" : "#16a34a";
                    <span class="topchip-value" style="display:inline-flex; align-items:center; gap:6px;">
                        <span>@_disk.FreeGb GB<span style="color:#9ca3af; font-weight:400;"> de @_disk.TotalGb</span></span>
                        <span style="width:34px; height:5px; border-radius:4px; background:#e5e7eb; overflow:hidden; display:inline-block;">
                            <span style="display:block; width:@(_disk.Pct)%; height:100%; background:@dColor;"></span>
                        </span>
                        <span style="font-size:0.7rem; color:@dColor;">@_disk.Pct%</span>
                    </span>
                }
            </span>
        </div>
        @* 2026-07-17: código de autorización del día para colectas/devoluciones de MeLi.
           Chip clickeable: un clic copia el código. Si todavía no llegó el mail de hoy,
           muestra "esperando…" en gris (no muestra uno viejo como si fuera el de hoy). *@
        @{
            var _cc = _codigoColecta;
            var _ccCod = _cc is not null && !string.IsNullOrWhiteSpace(_cc.Codigo);
            var _ccLabel = _cc is null ? "Colecta hoy"
                : _cc.Cancelada ? "Colecta CANCELADA"
                : !string.IsNullOrWhiteSpace(_cc.Horario) ? $"Colecta {_cc.Horario}"
                : "Colecta hoy";
        }
        @if (_ccCod)
        {
            <div class="topchip" title="Código del día para colectas/devoluciones. Clic para copiar." style="cursor:pointer; border-color:#f59e0b; background:#fffbeb;" @onclick="CopiarCodigoColecta">
                <span class="topchip-ico" style="background:#fef3c7; color:#92400e;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6"/><path d="M15.5 7.5l3 3L22 7l-3-3"/></svg>
                </span>
                <span>
                    <span class="topchip-label" style="display:block; color:@(_cc!.Cancelada ? "#b91c1c" : "#b45309");">@_ccLabel</span>
                    <span class="topchip-value" style="display:inline-flex; align-items:center; gap:6px; font-family:ui-monospace,Menlo,monospace; letter-spacing:1px; color:#92400e;">
                        @_cc.Codigo
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="#b45309" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                    </span>
                </span>
            </div>
        }
        else
        {
            <div class="topchip topchip-secondary" title="Código del día para colectas/devoluciones de MercadoLibre. Todavía no llegó el código de hoy.">
                <span class="topchip-ico" style="background:#f3f4f6; color:#9ca3af;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6"/><path d="M15.5 7.5l3 3L22 7l-3-3"/></svg>
                </span>
                <span>
                    <span class="topchip-label" style="display:block;">@_ccLabel</span>
                    <span class="topchip-value" style="color:#9ca3af;">
                        @(_cc is not null && _cc.Cancelada ? "cancelada"
                          : _cc is not null && !string.IsNullOrWhiteSpace(_cc.Horario) ? "esperando cód."
                          : "esperando…")
                    </span>
                </span>
            </div>
        }
        </div>

        @* 2026-07-08: grupo de iconitos movido acá desde la barra de menú (descongestiona
           esa fila). Misma lógica y mismos botones: Widgets/Apps, Buscar, Actualizar, campanas,
           Chat, WhatsApp, e indicadores de subida/sincro. *@
        <div class="topstrip-icons">
            @* Widgets como dropdown (calc + post-its + zoom) *@
            <div class="topbar-widgets-wrap">
                <button class="topbar-square-btn topbar-widgets-btn @(showWidgetsDropdown ? "abierto" : "")"
                        @onclick="ToggleWidgetsDropdown"
                        title="Widgets (Calculadora, Post-its)"
                        aria-label="Widgets">@SvgIcons.Apps</button>
                @if (showWidgetsDropdown)
                {
                    <div class="topbar-widgets-menu" @onclick:stopPropagation="true">
                        <div class="topbar-widgets-header">Widgets</div>
                        <button class="topbar-widgets-item" @onclick="OpenCalculatorAndCloseWidgets">
                            <span class="ico">@SvgIcons.Calculator</span>
                            <div>
                                <div class="label">Calculadora</div>
                                <div class="desc">Se mueve por la pantalla</div>
                            </div>
                        </button>
                        <button class="topbar-widgets-item" @onclick="OpenPostitsAndCloseWidgets">
                            <span class="ico">@SvgIcons.Notes</span>
                            <div>
                                <div class="label">Post-its</div>
                                <div class="desc">Mis notas flotantes</div>
                            </div>
                        </button>
                        <div class="topbar-widgets-zoom">
                            <span class="ico">🔍</span>
                            <div class="meta">
                                <div class="label">Zoom</div>
                                <div class="desc">Agranda o achica todo el sistema</div>
                            </div>
                            <div class="ctrls">
                                <button class="zbtn" @onclick="ZoomDecrement" title="Reducir zoom (Ctrl −)">−</button>
                                <button class="zlvl" @onclick="ZoomReset" title="Volver a 100%">@zoomLevel%</button>
                                <button class="zbtn" @onclick="ZoomIncrement" title="Aumentar zoom (Ctrl +)">+</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="topbar-square-btn" @onclick="OpenCommandPalette"
                    title="Buscar pantalla rápido (Ctrl + K)"
                    aria-label="Buscar pantalla">@SvgIcons.Search</button>
            <button class="topbar-square-btn" @onclick="DoHardReload"
                    title="Forzar recarga (limpia el cache del navegador). Usalo si un cambio nuevo no aparece."
                    aria-label="Forzar recarga">@SvgIcons.Refresh</button>
            @* 2026-06-08: ocultar campanas a deposito EXCEPTO Preguntas MeLi — el usuario
               quiere que deposito vea las preguntas para responderlas. *@
            @if (!IsRoleWithCustomSidebar())
            {
                <CobranzasPendientesBell />
                <AlqCobranzasPendientesBell />
            }
            <ChatBell />
            <MeliQuestionsBell />
            @if (!IsRoleWithCustomSidebar())
            {
                <MeliCambiosBell />
                <WhatsAppPedidosBell />
                <MisAlertasBell />
            }
            @if (UploadProgress.IsUploading)
            {
                <div class="topbar-upload-indicator" @onclick="() => UploadProgress.RequestReopen()" title="Ver detalle de subida">
                    <span class="topbar-upload-spinner"></span>
                    <span class="topbar-upload-text">Subiendo @UploadProgress.DoneCount/@UploadProgress.TotalCount</span>
                    <div class="topbar-upload-bar">
                        <div class="topbar-upload-bar-fill" style="width: @(UploadProgress.Percentage)%"></div>
                    </div>
                    <button class="topbar-upload-cancel" @onclick="CancelUpload" @onclick:stopPropagation="true" title="Cancelar subida"><i class="fa-solid fa-xmark"></i></button>
                </div>
            }
            @if (SyncProgress.State.IsActive && !SyncProgress.State.ShowModal)
            {
                <div class="topbar-sync-indicator @(SyncProgress.State.Status)" @onclick="OpenSyncModal" title="@SyncProgress.State.Description">
                    @if (SyncProgress.State.Status == "running")
                    {
                        <span class="topbar-sync-spinner"></span>
                        <span class="topbar-sync-text">@SyncProgress.State.Percentage%</span>
                        <div class="topbar-sync-bar">
                            <div class="topbar-sync-bar-fill" style="width: @(SyncProgress.State.Percentage)%"></div>
                        </div>
                    }
                    else if (SyncProgress.State.Status == "completed")
                    {
                        <span class="topbar-sync-text"><i class="fa-solid fa-circle-check"></i> Sincronizado</span>
                        <button class="topbar-sync-dismiss" @onclick="DismissSync" @onclick:stopPropagation="true" title="Cerrar"><i class="fa-solid fa-xmark"></i></button>
                    }
                    else if (SyncProgress.State.Status == "error")
                    {
                        <span class="topbar-sync-text"><i class="fa-solid fa-circle-xmark"></i> Error</span>
                        <button class="topbar-sync-dismiss" @onclick="DismissSync" @onclick:stopPropagation="true" title="Cerrar"><i class="fa-solid fa-xmark"></i></button>
                    }
                </div>
            }
        </div>
    </div>

    @* Banner rojo de WhatsApp desvinculado removido 2026-06-24: el boton gris con punto rojo
       en la topbar (ver waDesvinculado en linea ~1033) ya avisa el estado sin ocupar espacio. *@
    <header class="topbar">
        <div class="topbar-left">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Abrir menu">
                @SvgIcons.Menu
            </button>
            <BackButton />
            @* 2026-07-08: empresa, usuario, candado y reloj se movieron a la fila de chips
               de arriba (.topstrip, ver arriba del <header>). Acá quedan solo el menú y Volver. *@
        </div>
        <div class="topbar-actions">
            @* Atajos del modulo Cafe — stack vertical para que entren varios sin agrandar el topbar.
               Iteramos con el usuario, sumando botones de uno: '+ Nueva Venta', 'Ventas', etc. *@
            @* 2026-05-30: oficina también puede cargar ventas (igual que admin con permiso cafe). *@
            @if (HasPerm("cafe") || HasPerm("oficina"))
            {
                @* 2026-06-17 v9: rediseno moderno — paleta neutra (blanco + gris) + iconos sutiles + separador visual.
                   Quitamos los gradientes saturados y unificamos altura/tipografia. La logica (onclick, dropdowns) no cambia. *@
                @* Bloque NAVEGACION — botones secundarios con fondo transparente *@
                <button class="topbar-nav-modern"
                        @onclick="@(() => NavigateTo("/vault"))"
                        title="Bóveda de contraseñas">
                    <span class="topbar-nav-modern-ico">@SvgIcons.Shield</span>
                    <span>BOVEDA CONT</span>
                </button>
                <button class="topbar-nav-modern calcuprecios-btn"
                        @onclick="OpenCalcFromNav"
                        title="CalcuPrecios — buscar costo y precio sugerido">
                    <span class="topbar-nav-modern-ico">@SvgIcons.Calculator</span>
                    <span>CALCUPRECIOS</span>
                    @if (calcNuevoBadge)
                    {
                        <span class="calc-nuevo-badge">nuevo</span>
                    }
                </button>
                <button class="topbar-nav-modern"
                        @onclick="@(() => NavigateTo("/cafe/stock-masivo"))"
                        title="Stock masivo (todos los productos)">
                    <span class="topbar-nav-modern-ico">@SvgIcons.Package</span>
                    <span>Stock</span>
                </button>
                <button class="topbar-nav-modern"
                        @onclick="@(() => NavigateTo("/cafe/listas-precios"))"
                        title="Listas de precios">
                    <span class="topbar-nav-modern-ico">@SvgIcons.DollarSign</span>
                    <span>Listas</span>
                </button>
                <button class="topbar-nav-modern"
                        @onclick="@(() => NavigateTo("/cafe/preparacion"))"
                        title="Imprimir pedidos / preparación de pedidos">
                    <span class="topbar-nav-modern-ico">@SvgIcons.ClipboardList</span>
                    <span>Preparación</span>
                </button>
                <div class="topbar-empleados-wrap">
                    <button class="topbar-nav-modern @(showEmpleadosDropdown ? "abierto" : "")"
                            @onclick="ToggleEmpleadosDropdown"
                            title="Accesos rápidos a Empleados">
                        <span class="topbar-nav-modern-ico">@SvgIcons.Users</span>
                        <span>Empleados</span>
                        <span class="topbar-nav-modern-caret">▾</span>
                    </button>
                    @if (showEmpleadosDropdown)
                    {
                        <div class="topbar-empleados-menu" @onclick:stopPropagation="true">
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/horas-extras"))">
                                <span class="ico">🕐</span> Horario
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/viajes"))">
                                <span class="ico">🚚</span> Viajes
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/cafe/repartidores"))">
                                <span class="ico">🚚</span> Repartidores
                            </button>
                            @* 2026-06-08: tambien aca abajo de Repartidores, como en el sidebar *@
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/cafe/arqueo-repartidor"))">
                                <span class="ico">🧾</span> Arqueo repartidor
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/nominas/empleados"))">
                                <span class="ico">👤</span> Ficha empleados
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/nominas/panel"))">
                                <span class="ico">💰</span> ¿Cuánto debo pagar?
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/nominas/liquidaciones"))">
                                <span class="ico">📑</span> Liquidaciones
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseEmpleados("/nominas"))">
                                <span class="ico">📊</span> Inicio nóminas
                            </button>
                        </div>
                    }
                </div>
                @* 2026-06-29: Ventas como dropdown estilo Empleados — agrupa todo lo relacionado con
                   ventas, clientes y deudas. Reemplazo del split-button anterior (Ventas + caret de
                   Presupuestos) y del boton "Saldos" suelto. *@
                <div class="topbar-empleados-wrap">
                    <button class="topbar-nav-modern @(showVentasDropdown ? "abierto" : "")"
                            @onclick="ToggleVentasDropdown"
                            title="Accesos rápidos a Ventas">
                        <span class="topbar-nav-modern-ico">@SvgIcons.BarChart</span>
                        <span>Ventas</span>
                        <span class="topbar-nav-modern-caret">▾</span>
                    </button>
                    @if (showVentasDropdown)
                    {
                        <div class="topbar-empleados-menu" @onclick:stopPropagation="true">
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/ventas"))">
                                <span class="ico">🛒</span> Ventas
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/tesoreria/cobranzas"))">
                                <span class="ico">📥</span> Cobranzas
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/presupuestos"))">
                                <span class="ico">📋</span> Presupuestos
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/preparacion"))">
                                <span class="ico">📦</span> Preparación
                            </button>
                            <div class="topbar-empleados-sep"></div>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/clientes"))">
                                <span class="ico">👤</span> Clientes
                            </button>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/clientes-mapeados"))">
                                <span class="ico">📍</span> Clientes mapeados
                            </button>
                            <div class="topbar-empleados-sep"></div>
                            <button class="topbar-empleados-item" @onclick="@(() => NavigateAndCloseVentas("/cafe/clientes/panel-deudas"))">
                                <span class="ico">💼</span> ¿Quién me debe?
                            </button>
                        </div>
                    }
                </div>

                @* 2026-07-08: se sacó el badge "Cheques" de la barra — ahora hay una card de
                   "Cheques por pagar" en el dashboard con la misma info, así que era redundante. *@

                @* Separador visual entre navegacion y acciones primarias *@
                <div class="topbar-divider-modern"></div>

                @* ACCIONES PRIMARIAS — 2026-07-08: tres accesos rapidos con color por modulo.
                   Venta (oscuro), Alquiler (azul), Cobranza (verde). Cada uno muestra su atajo de teclado. *@
                <div class="tb-nuevo-group">
                    <button class="tb-nuevo tb-nuevo-venta" @onclick='() => NuevoRapido("venta")'
                            title="Nueva venta — atajo: apretá N y después V" aria-label="Nueva venta">
                        <span class="ic" aria-hidden="true">🛒</span>
                        <span class="lbl">Venta</span>
                        <span class="keys"><span class="kbd">N</span><span class="kbd">V</span></span>
                    </button>
                    <button class="tb-nuevo tb-nuevo-alq" @onclick='() => NuevoRapido("alquiler")'
                            title="Nueva reserva de alquiler — atajo: apretá N y después A" aria-label="Nueva reserva de alquiler">
                        <span class="ic" aria-hidden="true">📅</span>
                        <span class="lbl">Alquiler</span>
                        <span class="keys"><span class="kbd">N</span><span class="kbd">A</span></span>
                    </button>
                    <button class="tb-nuevo tb-nuevo-cob" @onclick='() => NuevoRapido("cobranza")'
                            title="Nueva cobranza — atajo: apretá N y después C" aria-label="Nueva cobranza">
                        <span class="ic" aria-hidden="true">💵</span>
                        <span class="lbl">Cobranza</span>
                        <span class="keys"><span class="kbd">N</span><span class="kbd">C</span></span>
                    </button>
                </div>
                @* 2026-06-29: el boton 'Cobranzas' suelto se movio al dropdown Ventas (abajo de Ventas) *@
                @* 2026-06-19: boton WhatsApp llamativo verde — chat Twilio para pedidos de hermanos/empleados *@
                @* 2026-06-23: si Playwright esta linked -> va al chat. Si NO -> abre modal QR directo. *@
                <button class="topbar-action-whatsapp"
                        style="@(waDesvinculado ? "background:#9ca3af !important; box-shadow:none !important; position:relative;" : "position:relative;")"
                        @onclick="ToggleWaFlotante"
                        title="WhatsApp — abrir el panel de conversaciones (↗ para verlo en una pestaña aparte)"
                        aria-label="WhatsApp">
                    @SvgIcons.MessageCircle
                    <span>WhatsApp</span>
                    @if (waStatus is not null)
                    {
                        <span style="@($"position:absolute; top:4px; right:4px; width:10px; height:10px; border-radius:50%; background:{(waLinked ? "#22c55e" : "#ef4444")}; border:2px solid white; box-shadow:0 0 0 1px rgba(0,0,0,0.1); {(waLinked ? "" : "animation: wa-pulse 1.5s ease-in-out infinite;")}")"></span>
                    }
                </button>
            }
            @* 2026-07-08: el grupo de iconitos (Widgets/Apps, Buscar, Actualizar, campanas,
               Chat, WhatsApp, indicadores de subida/sincro) se movió a la DERECHA de la fila
               de chips de arriba (.topstrip-icons), para descongestionar esta barra de menú. *@
        </div>
    </header>
}
    @* 2026-07-16 (incidente cápsulas KDOR): cartelón rojo cuando hay publicaciones MeLi esperando
       revisión de precio (pausadas con stock que el robot NO despertó / reactivadas). Visible en
       todas las páginas para admin/oficina hasta que se revisen (se marca visto o se activa). *@
    @if (publisRevisar > 0 && !IsEmbedded)
    {
        <div class="publi-revisar-banner" @onclick="IrARevisarPublis" title="Click para ir a revisar">
            <span class="publi-revisar-icono">⚠️</span>
            <span class="publi-revisar-texto">
                <strong>@publisRevisar publicaci@(publisRevisar == 1 ? "ón" : "ones") de MercadoLibre esperando revisión de PRECIO</strong>
                — pausadas con stock o reactivadas. No se venden hasta que las revises y actives.
            </span>
            <span class="publi-revisar-cta">Revisar ahora →</span>
        </div>
    }
    <div class="content">
        @Body
    </div>
</main>

@* 2026-06-15: Pantalla bloqueante de PIN por operador. Mientras Operator.IsValidated == false
   (no hay PIN ingresado, o pasaron 30 min sin actividad), tapa todo. Solo aplica a roles que
   cargan ventas (cafe/oficina/deposito). Para "deposito-only" usamos su lista propia. *@
@if (mostrarPinLock)
{
    <OperatorLockScreen Disponibles="@operadoresParaPinLock" />
}

@if (sidebarOpen)
{
    <div class="sidebar-overlay visible" @onclick="CloseSidebar"></div>
}

@* 2026-07-09: botón de menú FLOTANTE fijo. Solo aparece en pantallas angostas (celular / zoom alto),
   donde el menú lateral se esconde. Al ser position:fixed nunca se pierde de vista aunque una tabla
   ancha empuje la pantalla para el costado — garantiza que siempre se pueda volver a abrir el menú.
   Se oculta cuando el menú ya está abierto o en modo embebido. *@
@if (!IsEmbedded && !sidebarOpen)
{
    <button class="floating-menu-btn" @onclick="ToggleSidebar" aria-label="Abrir menú" title="Abrir menú">
        @SvgIcons.Menu
    </button>
}

@* Modal de seleccion de empresa *@
@if (showCompanyModal)
{
    <div class="modal-overlay" style="z-index: 9000;" @onclick="() => showCompanyModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>🏢 ¿Con qué empresa estás trabajando?</h3>
                <div style="display: flex; gap: 0.3rem; align-items: center;">
                    @if (CanEditCompanyNames)
                    {
                        <button class="btn-icon" @onclick="OpenCompanyAdminPasswordModal"
                                title="Editar nombres de las empresas (solo OSMAR)"
                                style="background: transparent; border: none; cursor: pointer; font-size: 1.1rem; padding: 0.3rem;">
                            ⚙
                        </button>
                    }
                    <button class="btn-close" @onclick="() => showCompanyModal = false">&times;</button>
                </div>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #6b7280; margin: 0 0 0.75rem;">
                    Elegí la empresa actual. Va a ser la marca por defecto al emitir comprobantes
                    y el nombre que aparece arriba en la barra.
                </p>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem;">
                    @foreach (var co in CurrentCompanyService.Companies)
                    {
                        var id = co;
                        var displayName = Company.GetDisplayName(id);
                        <button class="btn @(Company.Current == id ? "btn-primary" : "btn-secondary")"
                                @onclick="() => SelectCompany(id)"
                                style="padding: 0.7rem; font-weight: 700; font-size: 0.95rem;">
                            @displayName
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* Sub-modal: pedir clave a OSMAR *@
@if (showCompanyAdminPasswordModal)
{
    <div class="modal-overlay" style="z-index: 9100;" @onclick="CloseCompanyAdminPasswordModal">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: #1f2937; color: white;">
                <h4 style="margin: 0;">🔒 Clave de OSMAR</h4>
                <button class="btn-close" @onclick="CloseCompanyAdminPasswordModal" style="color: white;">&times;</button>
