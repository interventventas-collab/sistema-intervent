    protected override async Task OnInitializedAsync()
    {
        SyncProgress.OnChange += OnSyncProgressChanged;
        UploadProgress.OnChanged += OnUploadProgressChanged;
        Operator.OnChange += OnOperatorChanged;
        Company.OnChange += OnCompanyChanged;
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            role = user.Role;
            permissions = user.Permissions ?? new();
        }

        // Cargar operador desde localStorage. Si no hay, abrir modal obligatorio.
        await Operator.LoadAsync();
        if (!Operator.HasOperator) showOperatorModal = true;

        // Selector de empresa DESACTIVADO: limpiamos la empresa al arrancar para que la app
        // funcione sin filtros (Company.HasCompany == false → todo se muestra sin restriccion).
        // Si volves a habilitar el selector, reemplazá esto por:  await Company.LoadAsync();
        await Company.ClearAsync();

        // Cargar los nombres visibles de las empresas (los que el admin puede editar).
        await LoadCompanyNamesAsync();

        // Refrescar permisos desde el servidor para reflejar cambios sin necesidad de re-login.
        try
        {
            var fresh = await Api.GetMeAsync();
            if (fresh?.Permissions is not null)
            {
                permissions = fresh.Permissions;
            }
        }
        catch { /* offline o sin sesion: dejamos lo que vino del cache */ }

        // Load brand settings
        try
        {
            var settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                BrandSettings.LoadFromSettings(settings);
                await JS.InvokeVoidAsync("applyBrandColors", BrandSettings.PrimaryColor, BrandSettings.SidebarBgColor);
                await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName);
            }
        }
        catch { }

        BrandSettings.OnChange += OnBrandChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.LocationChanged += OnLocationChanged;
            CheckRoutePermission();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        CheckRoutePermission();
        _ = InvokeAsync(async () => await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName));
    }

    private void CheckRoutePermission()
    {
        if (permissions.Count == 0) return; // permissions not loaded yet

        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/').Split('?')[0].Split('#')[0];

        if (RouteToMenuKey.TryGetValue(relativePath, out var menuKey))
        {
            // Empty menuKey means always allowed (like /perfil)
            if (!string.IsNullOrEmpty(menuKey) && !permissions.Contains(menuKey))
            {
                Navigation.NavigateTo("/");
            }
        }
    }

    private bool HasPerm(string key) => permissions.Contains(key);

    private void OnSyncProgressChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OpenSyncModal()
    {
        if (SyncProgress.State.Status == "running")
        {
            SyncProgress.State.ShowModal = true;
            Navigation.NavigateTo("/publicaciones");
        }
    }

    private void DismissSync()
    {
        SyncProgress.Dismiss();
    }

    private async void OnBrandChanged()
    {
        await InvokeAsync(async () =>
        {
            await JS.InvokeVoidAsync("applyBrandColors", BrandSettings.PrimaryColor, BrandSettings.SidebarBgColor);
            await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName);
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SyncProgress.OnChange -= OnSyncProgressChanged;
        UploadProgress.OnChanged -= OnUploadProgressChanged;
        Operator.OnChange -= OnOperatorChanged;
        Company.OnChange -= OnCompanyChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        BrandSettings.OnChange -= OnBrandChanged;
    }

    private void OnUploadProgressChanged() => InvokeAsync(StateHasChanged);
    private void OnOperatorChanged() => InvokeAsync(StateHasChanged);
    private void OnCompanyChanged() => InvokeAsync(StateHasChanged);

    private async Task SelectCompany(string name)
    {
        await Company.SetAsync(name);
        showCompanyModal = false;
        ToastService.Success($"Trabajando con {Company.GetDisplayName(name)}");
    }

    // ===== Edicion de nombres de empresas (solo OSMAR con clave) =====

    private bool CanEditCompanyNames =>
        Operator.HasOperator &&
        string.Equals(Operator.Current, "OSMAR", StringComparison.OrdinalIgnoreCase);

    private async Task LoadCompanyNamesAsync()
    {
        try
        {
            var list = await Api.GetCompanyNamesAsync();
            if (list is null) return;
            var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var c in list)
                if (!string.IsNullOrEmpty(c.Id))
                    map[c.Id] = string.IsNullOrWhiteSpace(c.DisplayName) ? c.Id : c.DisplayName;
            Company.SetDisplayNames(map);
        }
        catch { /* primer arranque sin migracion / sin sesion */ }
    }

    private void OpenCompanyAdminPasswordModal()
    {
        if (!CanEditCompanyNames) return;
        companyAdminPassword = "";
        companyAdminError = null;
        showCompanyAdminPasswordModal = true;
    }

    private void CloseCompanyAdminPasswordModal()
    {
        showCompanyAdminPasswordModal = false;
        companyAdminPassword = "";
        companyAdminError = null;
    }

    private async Task OnCompanyAdminPasswordKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(companyAdminPassword))
            await ConfirmCompanyAdminPassword();
    }

    private Task ConfirmCompanyAdminPassword()
    {
        // No validamos contra el backend aca: el backend valida la clave cuando se guarda.
        // Avanzamos al modal de edicion. Si la clave es incorrecta, el guardado va a tirar error.
        if (string.IsNullOrEmpty(companyAdminPassword))
        {
            companyAdminError = "Ingresá tu clave";
            return Task.CompletedTask;
        }
        // Pre-cargar los inputs con los nombres actuales
        companyNameEdits = new(StringComparer.OrdinalIgnoreCase);
        foreach (var id in CurrentCompanyService.Companies)
        {
            // Si el display name = ID, dejamos vacio para que el usuario vea el placeholder con el default
            var current = Company.GetDisplayName(id);
            companyNameEdits[id] = string.Equals(current, id, StringComparison.OrdinalIgnoreCase) ? "" : current;
        }
        showCompanyAdminPasswordModal = false;
        companyNamesEditError = null;
        showCompanyNamesEditModal = true;
        return Task.CompletedTask;
    }

    private void CloseCompanyNamesEditModal()
    {
        if (isSavingCompanyNames) return;
        showCompanyNamesEditModal = false;
        companyNamesEditError = null;
        companyAdminPassword = ""; // limpiamos la clave en memoria
    }

    private async Task SaveCompanyNames()
    {
        if (string.IsNullOrEmpty(companyAdminPassword))
        {
            companyNamesEditError = "Sesion expirada, ingresá tu clave de nuevo.";
            showCompanyNamesEditModal = false;
            showCompanyAdminPasswordModal = true;
            return;
        }
        isSavingCompanyNames = true;
        companyNamesEditError = null;
        try
        {
            var payload = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var id in CurrentCompanyService.Companies)
            {
                payload[id] = (companyNameEdits.GetValueOrDefault(id) ?? "").Trim();
            }
            var updated = await Api.UpdateCompanyNamesAsync(companyAdminPassword, payload);
            if (updated is null) { companyNamesEditError = "No se pudo guardar."; return; }

            var newMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var c in updated)
                newMap[c.Id] = string.IsNullOrWhiteSpace(c.DisplayName) ? c.Id : c.DisplayName;
            Company.SetDisplayNames(newMap);

            ToastService.Success("Nombres de empresas actualizados");
            showCompanyNamesEditModal = false;
            companyAdminPassword = "";
        }
        catch (Exception ex) { companyNamesEditError = ex.Message; }
        finally { isSavingCompanyNames = false; }
    }

    private async Task SelectOperator(string name)
    {
        await Operator.SetAsync(name);
        showOperatorModal = false;
        ToastService.Success($"Trabajando como {name}");
    }

    private async Task CancelUpload()
    {
        await UploadProgress.RequestCancelAsync();
    }

    private bool IsActive(string href)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0].TrimEnd('/');
        var target = href.TrimStart('/').TrimEnd('/');
        if (string.IsNullOrEmpty(target))
            return string.IsNullOrEmpty(relativePath) || relativePath.Equals("index.html", StringComparison.OrdinalIgnoreCase);
        return relativePath.Equals(target, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string url)
    {
        CloseSidebar();
        Navigation.NavigateTo(url);
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;
    private void ToggleCollapse()
    {
        sidebarCollapsed = !sidebarCollapsed;
        userMenuOpen = false;
    }
    private void ToggleUserMenu() => userMenuOpen = !userMenuOpen;

    private void GoToProfile()
    {
        userMenuOpen = false;
        CloseSidebar();
        Navigation.NavigateTo("/perfil");
    }

    private async Task Logout()
    {
        userMenuOpen = false;
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
