    protected override async Task OnInitializedAsync()
    {
        SyncProgress.OnChange += OnSyncProgressChanged;
        UploadProgress.OnChanged += OnUploadProgressChanged;
        Operator.OnChange += OnOperatorChanged;
        Company.OnChange += OnCompanyChanged;
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            role = user.Role;
            permissions = user.Permissions ?? new();
        }

        // 2026-05-28: cargar mapa de visibilidad del sidebar (qué items ve cada rol).
        // Lo necesitan tanto el sidebar reducido de DEPOSITO/OFICINA como el modo edición del admin.
        await MenuVisibility.EnsureLoadedAsync();
        MenuVisibility.OnChange += OnMenuVisibilityChanged;

        // Cargar operador desde localStorage. Si no hay, abrir modal obligatorio.
        await Operator.LoadAsync();
        // 2026-05-28: validar que el operador cargado esté en la lista permitida para este rol.
        // Si OFICINA tenía GERMAN guardado y se loguea DEPOSITO (que solo ve ALEXIS/WALTER/RODRIGO),
        // limpiamos el operador para forzar a elegir uno válido.
        // 2026-06-05 FIX: la lista de "permitidos" debe incluir TAMBIÉN los operadores protegidos
        // (OSMAR), porque si el usuario activó OSMAR via clave, no queremos que el siguiente
        // refresh lo borre y le pida elegir de nuevo a cada rato.
        var operadoresPermitidos = OperatorService.ForPermissions(permissions)
            .Concat(OperatorService.ProtectedForPermissions(permissions))
            .ToArray();
        if (Operator.HasOperator && !operadoresPermitidos.Contains(Operator.Current!))
        {
            await Operator.ClearAsync();
        }
        // 2026-05-30: usuarios SOLO depósito (sin cafe ni oficina) no necesitan elegir
        // operador todavía. No abrimos el modal automático para ellos.
        bool isDepositoOnly = permissions.Contains("deposito")
            && !permissions.Contains("cafe")
            && !permissions.Contains("oficina");
        // 2026-06-15: con PIN bloqueante activo, NO abrimos el modal viejo automáticamente
        // para los roles cafe/oficina — la OperatorLockScreen ya tapa todo y se encarga.
        // Solo abrimos el modal viejo para depósito (que no tiene PIN bloqueante).
        if (!Operator.HasOperator && !isDepositoOnly && !requierePinLock) showOperatorModal = true;

        // 2026-06-15: timer que cada 30s evalúa si pasaron 60 min de inactividad para
        // re-bloquear automáticamente. Como IsValidated mira el timestamp, basta con
        // forzar un StateHasChanged periódico.
        if (requierePinLock)
        {
            _pinLockTimer = new System.Threading.Timer(_ => InvokeAsync(StateHasChanged),
                null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }

        // Selector de empresa DESACTIVADO: limpiamos la empresa al arrancar para que la app
        // funcione sin filtros (Company.HasCompany == false → todo se muestra sin restriccion).
        // Si volves a habilitar el selector, reemplazá esto por:  await Company.LoadAsync();
        await Company.ClearAsync();

        // Cargar los nombres visibles de las empresas (los que el admin puede editar).
        await LoadCompanyNamesAsync();

        // Refrescar permisos desde el servidor para reflejar cambios sin necesidad de re-login.
        try
        {
            var fresh = await Api.GetMeAsync();
            if (fresh?.Permissions is not null)
            {
                permissions = fresh.Permissions;
            }
        }
        catch { /* offline o sin sesion: dejamos lo que vino del cache */ }

        // Load brand settings
        try
        {
            var settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                BrandSettings.LoadFromSettings(settings);
                await JS.InvokeVoidAsync("applyBrandColors", BrandSettings.PrimaryColor, BrandSettings.SidebarBgColor);
                await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName);
            }
        }
        catch { }

        BrandSettings.OnChange += OnBrandChanged;

        // 2026-06-23: chequear estado WhatsApp en background. Primera vez ya, después cada 60s.
        _ = RefrescarWaStatus();
        _waStatusTimer = new System.Threading.Timer(_ => _ = RefrescarWaStatus(), null, 60000, 60000);

        // 2026-06-25: reloj del topbar — refresca cada 30s (no necesitamos segundo a segundo
        // para mostrar HH:mm, alcanza con minuto).
        _arNow = DateTime.UtcNow.AddHours(-3);
        _clockTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            _arNow = DateTime.UtcNow.AddHours(-3);
            StateHasChanged();
        }), null, 30000, 30000);

        // 2026-07-08: dólar + disco de los chips de arriba. Carga inicial + refresco cada 5 min.
        _ = LoadTopChipsAsync();
        _topChipsTimer = new System.Threading.Timer(_ => InvokeAsync(LoadTopChipsAsync), null,
            TimeSpan.FromMinutes(5), TimeSpan.FromMinutes(5));
    }

