@code {
    // 2026-06-23: estado del WhatsApp Web vía Playwright. Polling cada 60s.
    // Si la sesión se cae mostramos banner rojo y el botón verde se pone gris.
    private Web.Models.WhatsAppStatusDto? waStatus;
    private System.Threading.Timer? _waStatusTimer;
    private bool waLinked => waStatus?.Linked == true;
    private bool waDesvinculado => waStatus is not null && !waStatus.Linked && !waStatus.IsLinking;

    // 2026-06-23: modal de vinculacion (QR) accesible desde el boton WhatsApp y el banner rojo,
    // sin tener que entrar a /integraciones.
    private bool showWaQrModal;
    private bool waPreparingQr;
    private string waQrUrl = "";
    private System.Threading.CancellationTokenSource? _waLinkPollCts;

    // 2026-06-15: pantalla bloqueante de PIN
    private System.Threading.Timer? _pinLockTimer;
    // 2026-06-25: reloj chiquito del topbar (reemplaza al card grande del dashboard).
    private System.Threading.Timer? _clockTimer;
    private DateTime _arNow = DateTime.UtcNow.AddHours(-3);

    // 2026-07-08: datos de los chips de la fila superior (antes vivían en el Dashboard).
    // El dólar refresca cada 5 min; el disco cambia 1x/día (lo deja el robot de las 2 AM).
    private DolarBnaDto? _dolar;
    private DiskUsageDto? _disk;
    private ApiClient.MeliCodigoColectaDto? _codigoColecta;
    private System.Threading.Timer? _topChipsTimer;

    /// <summary>Click en el chip del código de colecta: lo copia al portapapeles.</summary>
    private async Task CopiarCodigoColecta()
    {
        if (_codigoColecta is null || string.IsNullOrWhiteSpace(_codigoColecta.Codigo)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _codigoColecta.Codigo);
            ToastService.Success($"Código copiado: {_codigoColecta.Codigo}");
        }
        catch { ToastService.Info($"Código: {_codigoColecta.Codigo}"); }
    }

    /// <summary>Click en el chip Empresa/Usuario: si hay operador, ofrece cambiarlo (pide PIN).</summary>
    private async Task OnEmpresaChipClick()
    {
        if (Operator.HasOperator) await OnCambiarOperadorClick();
    }

    private async Task LoadTopChipsAsync()
    {
        try { _dolar = await Api.GetDolarBnaAsync(); } catch { /* deja el valor previo */ }
        try { _disk = await Api.GetDiskUsageAsync(); } catch { /* deja el valor previo */ }
        try { _codigoColecta = await Api.GetMeliCodigoColectaAsync(); } catch { /* deja el valor previo */ }
        // 2026-07-16: publicaciones MeLi esperando revisión de precio → cartelón rojo.
        // Solo lo cargan los roles que lo pueden atender (admin/oficina).
        if (puedeVerPublisRevisar)
        {
            try { publisRevisar = await Api.GetMeliCambiosCountRevisarAsync(); } catch { /* deja el valor previo */ }
        }
        await InvokeAsync(StateHasChanged);
    }

    // 2026-07-16: cartelón "publicaciones MeLi a revisar" (incidente cápsulas KDOR)
    private int publisRevisar = 0;
    private bool puedeVerPublisRevisar => string.Equals(role, "admin", StringComparison.OrdinalIgnoreCase)
        || permissions.Contains("oficina");
    private void IrARevisarPublis() => Navigation.NavigateTo("/cafe/cambios-meli");
    private bool mostrarPinLock => requierePinLock && !Operator.IsValidated;
    /// <summary>2026-06-15: aplica a admin/oficina/cafe. Deposito-only queda exento
    /// para no romper su flujo (cargan stock, no ventas con identidad).</summary>
    private bool requierePinLock => permissions.Contains("cafe")
        || permissions.Contains("oficina")
        || string.Equals(role, "admin", StringComparison.OrdinalIgnoreCase);
    private List<string> operadoresParaPinLock => OperatorService.ForPermissions(permissions).ToList();
    private void OnOperatorChange() { InvokeAsync(StateHasChanged); }

    /// <summary>2026-06-15: el botón "Cambiar operador" del topbar ahora bloquea la sesión
    /// (la pantalla del PIN aparece sola). Para depósito, sigue usando el modal viejo.</summary>
    private async Task OnCambiarOperadorClick()
    {
        if (requierePinLock)
        {
            await Operator.LockAsync();
        }
        else
        {
            showOperatorModal = true;
        }
    }

    /// <summary>2026-06-24: botón explícito "🔒 Bloquear ahora". Para cuando el operador
    /// se va de la oficina y quiere que el próximo que use la PC tenga que poner el PIN.</summary>
    private async Task OnBloquearAhoraClick()
    {
        await Operator.LockAsync();
    }

    /// <summary>True si la app está corriendo en el entorno de DESARROLLO (puerto 3000 o
    /// el host es una IP en vez de un dominio). En ese caso se muestra un banner visible
    /// "DESARROLLO" y el sidebar tiene fondo distinto para evitar confundirlo con producción
    /// (app.palanica.com.ar).</summary>
    private bool IsDevEnvironment
    {
        get
        {
            var uri = new Uri(Navigation.BaseUri);
            // Cualquier acceso al puerto 3000 = dev (docker-compose dev)
            if (uri.Port == 3000) return true;
            // Acceso vía IP en vez de dominio = típico de testing remoto contra dev
            if (System.Net.IPAddress.TryParse(uri.Host, out _)) return true;
            // localhost también es dev
            if (uri.Host == "localhost" || uri.Host == "127.0.0.1") return true;
            return false;
        }
    }

    private bool sidebarOpen;
    // 2026-07-21: por default el menú arranca PLEGADO (finito, solo iconos). Si el usuario
    // lo expande o lo vuelve a plegar, se recuerda en el navegador (localStorage) y respeta
    // esa elección la próxima vez. Ver ToggleCollapse + OnAfterRenderAsync.
    private bool sidebarCollapsed = true;
    /// <summary>2026-06-20: modo embebido — cuando la pantalla se carga dentro del drawer del chat WhatsApp
    /// (con ?embedded=1), oculta sidebar y topbar para mostrar solo el contenido. Usado para iframes.</summary>
    private bool IsEmbedded => Navigation.Uri.Contains("embedded=1", StringComparison.OrdinalIgnoreCase);

    // 2026-05-28: Modo edición de visibilidad del sidebar (solo admin).
    // Al activarlo, todos los NavItems muestran chips D/O al lado para tildar quién los ve.
    [Inject] private MenuVisibilityService MenuVisibility { get; set; } = default!;
    private bool menuEditMode = false;
    private bool showMenuEditPasswordModal = false;
    private string menuEditPassword = "";
    private string? menuEditPasswordError;

    /// <summary>El "rol" del usuario para chequear visibilidad. Tomamos el primer permiso
    /// no-default que no sea "dashboard". Para deposito/oficina, devuelve esos.</summary>
    private string GetEffectiveRoleForVisibility()
    {
        if (permissions.Contains("oficina")) return "oficina";
        if (permissions.Contains("deposito")) return "deposito";
        return "";
    }

    // 2026-06-06: Oficina ahora ve el MISMO sidebar que admin (los grupos Ventas/Favoritos/etc).
    // Solo deposito tiene el "custom sidebar reducido" controlado por el admin.
    private bool IsRoleWithCustomSidebar() => !permissions.Contains("cafe")
        && permissions.Contains("deposito") && !permissions.Contains("oficina");

    private async Task ToggleMenuEditMode()
    {
        if (menuEditMode)
        {
            // Salir sin clave
            menuEditMode = false;
            StateHasChanged();
            return;
        }
        // Para entrar, pedir clave del admin
        menuEditPassword = "";
        menuEditPasswordError = null;
        showMenuEditPasswordModal = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task ConfirmMenuEditPassword()
    {
        if (string.IsNullOrEmpty(menuEditPassword))
        {
            menuEditPasswordError = "Ingresá tu clave";
            return;
        }
        var ok = await Api.VerifyMyPasswordAsync(menuEditPassword);
        if (!ok)
        {
            menuEditPasswordError = "Clave incorrecta";
            return;
        }
        menuEditMode = true;
        showMenuEditPasswordModal = false;
        menuEditPassword = "";
        StateHasChanged();
    }

    private async Task OnMenuToggleVisibility(string menuKey, string role, bool enabled)
    {
        try
        {
            await MenuVisibility.SetAsync(role, menuKey, enabled);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ToastService.Error("Error guardando: " + ex.Message);
        }
    }

    /// <summary>Catálogo de items conocidos: key → (icon, label, href). Usado en el sidebar
    /// reducido de DEPOSITO/OFICINA para renderizar lo que el admin habilitó. La key es la ruta
    /// relativa sin slash inicial (ej: "cafe/ventas").</summary>
    /// <summary>2026-06-08: para el rol DEPOSITO (sidebar reducido), solo las pantallas que
    /// realmente puede ver. Para los demás roles, todo el catalogo. Evita que el Command
    /// Palette (Ctrl+K) muestre pantallas a las que el usuario no debería acceder.</summary>
    private static readonly HashSet<string> DepositoWhitelistKeys = new(StringComparer.OrdinalIgnoreCase)
    {
        "cafe/productos",
        "cafe/stock-masivo",
        "cafe/historial-stock",
        "cafe/preparacion",
        "cafe/depositos",
        "",   // Dashboard
    };

    private Dictionary<string, (string Emoji, string Label, string Href)> FilteredMenuCatalog
    {
        get
