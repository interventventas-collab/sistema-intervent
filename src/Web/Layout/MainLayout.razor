    private Task ConfirmCompanyAdminPassword()
    {
        // No validamos contra el backend aca: el backend valida la clave cuando se guarda.
        // Avanzamos al modal de edicion. Si la clave es incorrecta, el guardado va a tirar error.
        if (string.IsNullOrEmpty(companyAdminPassword))
        {
            companyAdminError = "Ingresá tu clave";
            return Task.CompletedTask;
        }
        // Pre-cargar los inputs con los nombres actuales
        companyNameEdits = new(StringComparer.OrdinalIgnoreCase);
        foreach (var id in CurrentCompanyService.Companies)
        {
            // Si el display name = ID, dejamos vacio para que el usuario vea el placeholder con el default
            var current = Company.GetDisplayName(id);
            companyNameEdits[id] = string.Equals(current, id, StringComparison.OrdinalIgnoreCase) ? "" : current;
        }
        showCompanyAdminPasswordModal = false;
        companyNamesEditError = null;
        showCompanyNamesEditModal = true;
        return Task.CompletedTask;
    }

    private void CloseCompanyNamesEditModal()
    {
        if (isSavingCompanyNames) return;
        showCompanyNamesEditModal = false;
        companyNamesEditError = null;
        companyAdminPassword = ""; // limpiamos la clave en memoria
    }

    private async Task SaveCompanyNames()
    {
        if (string.IsNullOrEmpty(companyAdminPassword))
        {
            companyNamesEditError = "Sesion expirada, ingresá tu clave de nuevo.";
            showCompanyNamesEditModal = false;
            showCompanyAdminPasswordModal = true;
            return;
        }
        isSavingCompanyNames = true;
        companyNamesEditError = null;
        try
        {
            var payload = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var id in CurrentCompanyService.Companies)
            {
                payload[id] = (companyNameEdits.GetValueOrDefault(id) ?? "").Trim();
            }
            var updated = await Api.UpdateCompanyNamesAsync(companyAdminPassword, payload);
            if (updated is null) { companyNamesEditError = "No se pudo guardar."; return; }

            var newMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var c in updated)
                newMap[c.Id] = string.IsNullOrWhiteSpace(c.DisplayName) ? c.Id : c.DisplayName;
            Company.SetDisplayNames(newMap);

            ToastService.Success("Nombres de empresas actualizados");
            showCompanyNamesEditModal = false;
            companyAdminPassword = "";
        }
        catch (Exception ex) { companyNamesEditError = ex.Message; }
        finally { isSavingCompanyNames = false; }
    }

    private async Task SelectOperator(string name)
    {
        await Operator.SetAsync(name);
        showOperatorModal = false;
        ToastService.Success($"Trabajando como {name}");
    }

    // 2026-06-05: Operador protegido (OSMAR) — pide clave antes de activarlo.
    private bool showProtectedOperatorModal = false;
    private string pendingProtectedOperator = "";
    private string protectedOperatorPassword = "";
    private string protectedOperatorError = "";
    private bool validatingProtectedOperator = false;

    private void OpenProtectedOperatorModal(string name)
    {
        pendingProtectedOperator = name;
        protectedOperatorPassword = "";
        protectedOperatorError = "";
        showProtectedOperatorModal = true;
    }

    private void CancelProtectedOperator()
    {
        showProtectedOperatorModal = false;
        pendingProtectedOperator = "";
        protectedOperatorPassword = "";
        protectedOperatorError = "";
    }

    private async Task OnProtectedOperatorKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(protectedOperatorPassword))
            await ConfirmProtectedOperator();
    }

    private async Task ConfirmProtectedOperator()
    {
        if (string.IsNullOrEmpty(protectedOperatorPassword)) return;
        validatingProtectedOperator = true;
        protectedOperatorError = "";
        try
        {
            var ok = await Api.ValidateProtectedOperatorAsync(protectedOperatorPassword);
            if (!ok)
            {
                protectedOperatorError = "Clave incorrecta.";
                validatingProtectedOperator = false;
                return;
            }
            // Clave OK -> activar el operador protegido
            await Operator.SetAsync(pendingProtectedOperator);
            ToastService.Success($"Trabajando como {pendingProtectedOperator}");
            showProtectedOperatorModal = false;
            showOperatorModal = false;
            pendingProtectedOperator = "";
            protectedOperatorPassword = "";
        }
        catch (Exception ex)
        {
            protectedOperatorError = ex.Message;
        }
        finally { validatingProtectedOperator = false; }
    }

    private async Task CancelUpload()
    {
        await UploadProgress.RequestCancelAsync();
    }

    private bool IsActive(string href)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0].TrimEnd('/');
        var target = href.TrimStart('/').TrimEnd('/');
        if (string.IsNullOrEmpty(target))
            return string.IsNullOrEmpty(relativePath) || relativePath.Equals("index.html", StringComparison.OrdinalIgnoreCase);
        return relativePath.Equals(target, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string url)
    {
        CloseSidebar();
        Navigation.NavigateTo(url);
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;
    private void ToggleCollapse()
    {
        sidebarCollapsed = !sidebarCollapsed;
        userMenuOpen = false;
    }
    private void ToggleUserMenu() => userMenuOpen = !userMenuOpen;

    private void GoToProfile()
    {
