@inherits LayoutComponentBase

<style>
    /* 2026-07-08: fila superior de "chips" (arriba de la barra de menú).
       Empresa+Usuario · Reloj · Dólar · Disco. Se sacaron de la barra de menú y de
       la tira del dashboard para que todo el resumen viva arriba de todo, en una fila
       aparte y sin encimarse con el menú. En pantallas chicas hace wrap (bajan solos). */
    .topstrip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding: 0.4rem 1.5rem;
        background: var(--topbar-bg);
        border-bottom: 1px solid var(--border);
    }
    /* Chips a la izquierda, iconos (buscar/sincronizar/campanas/WhatsApp/apps) a la derecha. */
    .topstrip-chips { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .topstrip-icons { display: flex; align-items: center; gap: 0.15rem; flex-shrink: 0; margin-left: auto; }
    .topchip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #fff;
        border: 0.5px solid var(--border);
        border-radius: 10px;
        padding: 0.3rem 0.7rem;
        line-height: 1.15;
    }
    .topchip-ico {
        width: 26px; height: 26px;
        border-radius: 7px;
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .topchip-ico svg { width: 15px; height: 15px; }
    .topchip-label { font-size: 0.66rem; color: #6b7280; }
    .topchip-value { font-size: 0.82rem; font-weight: 500; color: #1f2937; font-variant-numeric: tabular-nums; }
    .topchip-btn { cursor: pointer; }
    .topchip-btn:hover { background: #f9fafb; border-color: #9ca3af; }
    .topchip-lock {
        border: none; background: transparent; cursor: pointer;
        padding: 2px; border-radius: 6px; display: inline-flex; color: #b45309;
    }
    .topchip-lock:hover { background: #fef3c7; }
    /* En celu, el dólar y el disco se esconden para no amontonar (lo importante
       —empresa/usuario y hora— queda siempre). */
    @@media (max-width: 640px) {
        .topchip-secondary { display: none; }
    }

    /* 2026-05-28: botón para abrir herramientas flotantes (calculadora + post-its). */
    .topbar-tool-btn {
        background: transparent;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 0.35rem 0.5rem;
        font-size: 1rem;
        line-height: 1;
        cursor: pointer;
        transition: background 0.1s;
    }
    .topbar-tool-btn:hover { background: #f3f4f6; }
    .topbar-tool-btn:active { transform: scale(0.95); }

    /* 2026-06-22: Look Mac/iOS — cápsula gris glass tipo "segment control" para agrupar
       botones-icono uniformes (tools: calc, notes, search, reload). */
    .topbar-icon-group {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        background: rgba(245, 245, 247, 0.85);
        border: 0.5px solid rgba(0, 0, 0, 0.06);
        border-radius: 10px;
        padding: 4px;
        flex-shrink: 0;
    }
    .topbar-icon-btn {
        width: 32px;
        height: 32px;
        background: transparent;
        border: none;
        border-radius: 7px;
        color: #3c3c43;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.12s ease, transform 0.06s ease;
        padding: 0;
        position: relative;
        font-family: inherit;
    }
    .topbar-icon-btn:hover { background: rgba(0, 0, 0, 0.05); }
    .topbar-icon-btn:active { transform: scale(0.92); }
    .topbar-icon-btn svg {
        width: 17px;
        height: 17px;
        display: block;
    }
    /* Punto rojo discreto para badge de notificación dentro de topbar-icon-btn */
    .topbar-icon-btn .badge-dot {
        position: absolute;
        top: 5px;
        right: 5px;
        width: 7px;
        height: 7px;
        background: #ff3b30;
        border-radius: 50%;
        border: 1.5px solid #f5f5f7;
    }

    /* SVG dentro de nav-modern alineado al texto */
    /* 2026-06-29: bump 15→18px (texto a 15px) */
    .topbar-nav-modern-ico svg {
        width: 18px;
        height: 18px;
        display: block;
    }
    /* SVG dentro de botones de acción (Nueva venta, WhatsApp) */
    /* 2026-06-29: bump 16→18px */
    .topbar-action-primary svg,
    .topbar-action-secondary svg,
    .topbar-action-whatsapp svg {
        width: 18px;
        height: 18px;
        display: block;
    }

    /* 2026-06-17 v9: rediseno topbar moderno — paleta neutra estilo Linear/Notion.
       2026-06-29: tipografia subida de 0.85rem (13px) a 0.95rem (15px) + padding/altura proporcional. */
    .topbar-nav-modern {
        background: transparent;
        border: none;
        padding: 0.55rem 0.9rem;
        height: 40px;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 500;
        color: #1f2937;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1;
        transition: background 0.12s ease;
        white-space: nowrap;
    }
    .topbar-nav-modern:hover { background: #f3f4f6; }
    .topbar-nav-modern.abierto { background: #f3f4f6; }
    .calc-nuevo-badge {
        background: #dc2626; color: #fff; font-size: 9px; font-weight: 700;
        padding: 1px 5px; border-radius: 999px; margin-left: 4px; line-height: 1.4;
        animation: calcnuevo 1s ease-in-out infinite;
    }
    /* Botón CALCUPRECIOS: relleno rosa llamativo para que resalte entre los grises */
    .calcuprecios-btn { background: #db2777 !important; color: #fff !important; font-weight: 700; }
    .calcuprecios-btn:hover { background: #be185d !important; }
    .calcuprecios-btn .topbar-nav-modern-ico,
    .calcuprecios-btn .topbar-nav-modern-ico svg { color: #fff !important; }
    .calcuprecios-btn .calc-nuevo-badge { background: #fff; color: #be185d; }
    @@keyframes calcnuevo { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
    .topbar-nav-modern-ico {
        font-size: 1.1rem;
        opacity: 0.85;
        line-height: 1;
    }
    .topbar-nav-modern-caret {
        font-size: 0.78rem;
        color: #9ca3af;
        margin-left: 0.1rem;
    }

    .topbar-divider-modern {
        width: 1px;
        height: 22px;
        background: #e5e7eb;
        margin: 0 0.4rem;
        align-self: center;
    }

    /* Accion primaria — fondo oscuro como Linear */
    .topbar-action-primary {
        background: #111827;
        border: 1px solid #111827;
        color: white;
        padding: 0.6rem 1rem;
        height: 40px;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1;
        transition: background 0.12s ease, transform 0.06s ease;
        white-space: nowrap;
    }
    .topbar-action-primary:hover { background: #1f2937; }
    .topbar-action-primary:active { transform: scale(0.97); }

    /* 2026-07-08: tres accesos rapidos con color por modulo (Venta / Alquiler / Cobranza) */
    .tb-nuevo-group { display: inline-flex; align-items: center; gap: 0.4rem; }
    .tb-nuevo {
        border: none; color: white; height: 40px;
        padding: 0 0.7rem; border-radius: 6px;
        font-family: inherit; font-size: 0.82rem; font-weight: 600;
        cursor: pointer; display: inline-flex; align-items: center; gap: 0.4rem;
        line-height: 1; white-space: nowrap;
        transition: background 0.12s ease, transform 0.06s ease;
    }
    .tb-nuevo:active { transform: scale(0.97); }
    .tb-nuevo .ic { font-size: 1rem; }
    .tb-nuevo .keys { display: inline-flex; gap: 3px; }
    .tb-nuevo .kbd {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.64rem; font-weight: 700;
        padding: 1px 4px; border-radius: 3px; background: rgba(255,255,255,0.2);
    }
    .tb-nuevo-venta { background: #111827; } .tb-nuevo-venta:hover { background: #1f2937; }
    .tb-nuevo-alq   { background: #2563eb; } .tb-nuevo-alq:hover   { background: #1d4ed8; }
    .tb-nuevo-cob   { background: #059669; } .tb-nuevo-cob:hover   { background: #047857; }
    /* Pantallas chicas: solo el icono (en el celu no hay teclado fisico) */
    @@media (max-width: 900px) {
        .tb-nuevo .lbl, .tb-nuevo .keys { display: none; }
        .tb-nuevo { padding: 0 0.55rem; }
    }

    /* 2026-07-08: globito de bienvenida (novedades) — flota abajo a la derecha */
    .welcome-globito {
        position: fixed; right: 22px; bottom: 24px; width: 330px; z-index: 3000;
        background: #fff; border: 1px solid #c7d2fe; border-radius: 12px;
        box-shadow: 0 12px 34px rgba(17, 24, 39, 0.20); padding: 16px;
        animation: wg-in 0.25s ease;
    }
    @@keyframes wg-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    .welcome-globito .wg-head { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; }
    .welcome-globito .wg-ic { flex-shrink: 0; width: 34px; height: 34px; border-radius: 50%; background: #eef2ff; color: #4f46e5; display: inline-flex; align-items: center; justify-content: center; font-size: 18px; }
    .welcome-globito .wg-title { font-size: 15px; font-weight: 700; color: #111827; }
    .welcome-globito .wg-sub { font-size: 12px; color: #6b7280; }
    .welcome-globito .wg-x { margin-left: auto; flex-shrink: 0; width: 26px; height: 26px; border: 1px solid #e5e7eb; border-radius: 6px; background: transparent; color: #6b7280; cursor: pointer; font-size: 14px; line-height: 1; }
    .welcome-globito .wg-x:hover { background: #f3f4f6; }
    .welcome-globito .wg-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-size: 13px; color: #111827; }
    .welcome-globito .wg-kbd { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; font-weight: 700; color: #374151; background: #f3f4f6; border: 1px solid #d1d5db; border-bottom-width: 2px; border-radius: 5px; padding: 2px 6px; }
    .welcome-globito .wg-foot { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid #f3f4f6; padding-top: 11px; margin-top: 8px; }
    .welcome-globito .wg-nomostrar { background: none; border: none; color: #6b7280; font-size: 12px; cursor: pointer; text-decoration: underline; padding: 0; }
    .welcome-globito .wg-nomostrar:hover { color: #374151; }
    .welcome-globito .wg-ok { background: #4f46e5; color: #fff; border: none; border-radius: 6px; padding: 7px 16px; font-size: 13px; font-weight: 600; cursor: pointer; }
    .welcome-globito .wg-ok:hover { background: #4338ca; }
    @@media (max-width: 640px) { .welcome-globito { left: 12px; right: 12px; width: auto; bottom: 12px; } }

    /* Accion secundaria — borde fino, fondo blanco */
    .topbar-action-secondary {
        background: white;
        border: 1px solid #d1d5db;
        color: #1f2937;
        padding: 0.6rem 1rem;
        height: 40px;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        line-height: 1;
        transition: background 0.12s ease, transform 0.06s ease;
        white-space: nowrap;
    }
    /* 2026-06-20: modo embebido (iframe en drawer del chat) — main sin margen del sidebar */
    .main-wrapper.main-embedded { margin-left: 0 !important; padding: 0 !important; }

    /* 2026-07-16: cartelón rojo "publicaciones MeLi esperando revisión de precio" (incidente KDOR) */
    .publi-revisar-banner {
        display: flex; align-items: center; gap: 0.75rem;
        background: linear-gradient(90deg, #dc2626, #b91c1c);
        color: #fff; padding: 0.75rem 1.1rem; margin: 0.5rem 1rem 0.25rem;
        border-radius: 10px; cursor: pointer; font-size: 0.95rem;
        box-shadow: 0 4px 14px rgba(220, 38, 38, 0.35);
        animation: publi-revisar-pulse 2s ease-in-out infinite;
    }
    .publi-revisar-banner:hover { filter: brightness(1.08); }
    .publi-revisar-icono { font-size: 1.6rem; flex-shrink: 0; }
    .publi-revisar-texto { flex: 1; line-height: 1.35; }
    .publi-revisar-cta {
        flex-shrink: 0; background: #fff; color: #b91c1c; font-weight: 700;
        padding: 0.35rem 0.8rem; border-radius: 6px; font-size: 0.85rem; white-space: nowrap;
    }
    @@keyframes publi-revisar-pulse {
        0%, 100% { box-shadow: 0 4px 14px rgba(220, 38, 38, 0.35); }
        50% { box-shadow: 0 4px 22px rgba(220, 38, 38, 0.65); }
    }
    .topbar-action-secondary:hover { background: #f9fafb; border-color: #9ca3af; }
    .topbar-action-secondary:active { transform: scale(0.97); }

    /* 2026-06-29: botones cuadrados robustos (Widgets, Buscar, Actualizar) */
    .topbar-square-btn {
        width: 44px;
        height: 44px;
        background: white;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        cursor: pointer;
        color: #1f2937;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: inherit;
        transition: background 0.12s ease, border-color 0.12s ease, transform 0.06s ease;
        padding: 0;
    }
    .topbar-square-btn:hover { background: #f9fafb; border-color: #9ca3af; }
    .topbar-square-btn:active { transform: scale(0.95); }
    .topbar-square-btn svg { width: 22px; height: 22px; }
    /* Tinte violeta para distinguir el boton de Widgets */
    .topbar-widgets-btn { background: #eef2ff; border-color: #a5b4fc; color: #4338ca; }
    .topbar-widgets-btn:hover { background: #e0e7ff; border-color: #818cf8; }
    .topbar-widgets-btn.abierto { background: #c7d2fe; border-color: #6366f1; }
    /* Dropdown de widgets */
    .topbar-widgets-wrap { position: relative; display: inline-block; }
    .topbar-widgets-menu {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 6px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 6px;
        min-width: 240px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.10);
        z-index: 100;
    }
    .topbar-widgets-header {
        font-size: 10px;
        letter-spacing: 0.08em;
        color: #6b7280;
        font-weight: 500;
        padding: 6px 10px 4px;
        text-transform: uppercase;
    }
    .topbar-widgets-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border-radius: 8px;
        color: #1f2937;
        font-size: 14px;
        cursor: pointer;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
        font-family: inherit;
    }
    .topbar-widgets-item:hover { background: #f3f4f6; }
    .topbar-widgets-item .ico {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        color: #6b7280;
    }
    .topbar-widgets-item .ico svg { width: 20px; height: 20px; }
    .topbar-widgets-item .label { font-weight: 500; }
    .topbar-widgets-item .desc { font-size: 12px; color: #6b7280; }
    /* 2026-06-29: control de Zoom dentro del dropdown — separador arriba */
    .topbar-widgets-zoom {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        margin-top: 4px;
        border-top: 1px solid #e5e7eb;
    }
    .topbar-widgets-zoom .ico {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        font-size: 18px;
    }
    .topbar-widgets-zoom .meta { flex: 1; min-width: 0; }
    .topbar-widgets-zoom .meta .label { font-weight: 500; font-size: 14px; color: #1f2937; }
    .topbar-widgets-zoom .meta .desc { font-size: 12px; color: #6b7280; }
    .topbar-widgets-zoom .ctrls {
        display: inline-flex;
        align-items: center;
        background: #f3f4f6;
        border-radius: 8px;
        padding: 2px;
        gap: 2px;
    }
    .topbar-widgets-zoom .zbtn {
        width: 26px;
        height: 26px;
        border: none;
        background: white;
        border-radius: 6px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        color: #1f2937;
        font-family: inherit;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .topbar-widgets-zoom .zbtn:hover { background: #e5e7eb; }
    .topbar-widgets-zoom .zlvl {
        min-width: 46px;
        height: 26px;
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
        color: #4b5563;
        font-family: inherit;
        padding: 0 6px;
    }
    .topbar-widgets-zoom .zlvl:hover { color: #1f2937; }

    /* 2026-06-19: boton WhatsApp llamativo, verde estilo WhatsApp con leve glow */
    /* 2026-06-29: bump alto 32→40 y font 0.875→0.95 para alinear con el resto */
    .topbar-action-whatsapp {
        height: 40px;
        padding: 0 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #25d366;
        color: #fff;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: inherit;
        line-height: 1;
        transition: background 0.12s ease, transform 0.06s ease, box-shadow 0.18s ease;
        white-space: nowrap;
        box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5);
        animation: wa-pulse 2.4s ease-in-out infinite;
    }
    .topbar-action-whatsapp:hover { background: #20bd5a; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(37, 211, 102, 0.35); }
    .topbar-action-whatsapp:active { transform: scale(0.97); }
    @@keyframes wa-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6), 0 0 0 2px white inset; }
        50% { box-shadow: 0 0 0 6px rgba(239, 68, 68, 0), 0 0 0 2px white inset; }
    }
    @@keyframes wa-banner-shake {
        0% { transform: translateY(-3px); opacity: 0.3; }
        50% { transform: translateY(1px); opacity: 1; }
        100% { transform: translateY(0); opacity: 1; }
    }

    .topbar-action-plus {
        font-size: 1.05rem;
        font-weight: 400;
        line-height: 1;
        opacity: 0.9;
    }

    /* 2026-05-28: botón "Editar visibilidad" en el sidebar del admin.
       2026-07-21: reubicado dentro del grupo Administración y con look discreto (antes
       era un botón amarillo llamativo arriba de todo). Se mimetiza con los items del menú. */
    .sidebar-edit-btn {
        margin: 2px 8px 6px;
        padding: 0.4rem 0.7rem;
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.45);
        border-radius: 8px;
        font-size: 0.78rem;
        font-weight: 500;
        cursor: pointer;
        width: calc(100% - 16px);
        text-align: left;
    }
    .sidebar-edit-btn:hover { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.85); }
    .sidebar-edit-btn.active {
        background: #16a34a;
        color: white;
        border-color: #15803d;
        border-style: solid;
    }
    /* Panel de edición de visibilidad — solo visible cuando menuEditMode=true */
    .menu-edit-panel {
        margin: 4px 12px 12px;
        background: rgba(251,191,36,0.08);
        border: 1px solid rgba(251,191,36,0.35);
        border-radius: 10px;
        overflow: hidden;
    }
    .menu-edit-panel-header {
        padding: 0.55rem 0.7rem;
        background: rgba(251,191,36,0.18);
        color: #fbbf24;
        font-weight: 700;
        font-size: 0.85rem;
    }
    .menu-edit-panel-body {
        max-height: 70vh;
        overflow-y: auto;
        padding: 4px;
    }
    .menu-edit-row {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 5px 6px;
        border-radius: 6px;
    }
    .menu-edit-row:hover { background: rgba(255,255,255,0.05); }
    .menu-edit-row-label {
        flex: 1;
        color: #e5e7eb;
        font-size: 0.78rem;
        line-height: 1.25;
        word-break: break-word;
        min-width: 0;
    }
    /* Chips del modo edición — reuso los estilos de NavItem.razor */
    .menu-edit-row .nav-chip {
        width: 24px; height: 24px;
        border: 1px solid rgba(255,255,255,0.25);
        border-radius: 6px;
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.5);
        font-size: 0.7rem;
        font-weight: 800;
        cursor: pointer;
        padding: 0;
        line-height: 1;
        flex-shrink: 0;
    }
    .menu-edit-row .nav-chip.on {
        background: #16a34a;
        color: white;
        border-color: #15803d;
    }
    .menu-edit-row .nav-chip.off:hover { background: rgba(255,255,255,0.15); color: white; }
    .menu-edit-row .nav-chip:active { transform: scale(0.9); }
</style>

@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject SyncProgressTracker SyncProgress
@inject UploadProgressService UploadProgress
@inject BrandSettingsService BrandSettings
@inject IJSRuntime JS
@inject ApiClient Api
@inject OperatorService Operator
@inject NuevaVentaSignal NuevaVentaSignal
@inject CurrentCompanyService Company
@implements IDisposable

@if (!IsEmbedded)
{
<aside class="sidebar @(sidebarOpen ? "open" : "") @(sidebarCollapsed ? "collapsed" : "") @(IsDevEnvironment ? "sidebar-dev" : "sidebar-prod") @(HasPerm("deposito") ? "sidebar-with-chat" : "")" id="sidebar">
    @if (IsDevEnvironment)
    {
        <div class="dev-environment-banner" title="Estás en el entorno de DESARROLLO. Los datos NO son los de producción.">
            🛠 DESARROLLO
        </div>
    }
    else
    {
        <div class="prod-environment-banner" title="Estás en el entorno de PRODUCCIÓN. Todo lo que hagas afecta los datos reales del negocio.">
            🔒 PRODUCCIÓN
        </div>
    }
    <div class="sidebar-brand">
        @if (BrandSettings.HasCustomLogo)
        {
            <img src="@BrandSettings.BrandLogo" alt="Logo" class="sidebar-brand-logo" />
        }
        else
        {
            <span class="sidebar-brand-icon">@SvgIcons.GetByName(BrandSettings.BrandIcon)</span>
        }
        <span class="sidebar-brand-text">@BrandSettings.BrandName</span>
        <button class="sidebar-collapse-btn" @onclick="ToggleCollapse" title="@(sidebarCollapsed ? "Expandir menu" : "Colapsar menu")">
            <span class="sidebar-collapse-icon">@(sidebarCollapsed ? SvgIcons.ChevronRight : SvgIcons.ChevronLeft)</span>
        </button>
    </div>
    <nav class="sidebar-nav" role="navigation" aria-label="Menu principal">
        @* 2026-07-21: "Editar visibilidad" se movió al grupo Administración (abajo), porque casi
           no se usa y quedaba muy llamativo arriba de todo. Ver más abajo dentro del NavGroup. *@
        @* ═════════════ 1. DASHBOARD ═════════════ *@
        @if (HasPerm("dashboard"))
        {
            <NavItem Href="/" Label="Dashboard" Icon="@SvgIcons.Dashboard"
                     IsActive="@IsActive("/")" OnClick="@(() => NavigateTo("/"))" />
        }

        @* ═════════════ CHAT INTERNO (visible para todos los usuarios) ═════════════ *@
        <NavItem Href="/chat" Label="💬 Chat" Icon="@SvgIcons.Users"
                 IsActive="@IsActive("/chat")" OnClick="@(() => NavigateTo("/chat"))" />

        @* ═════════════ MIS ALERTAS (motor de alertas configurables, 2026-07-10) ═════════════ *@
        @if (!IsRoleWithCustomSidebar())
        {
            <NavItem Href="/mis-alertas" Label="🔔 Mis Alertas" Icon="@SvgIcons.AlertCircle"
                     IsActive="@IsActive("/mis-alertas")" OnClick="@(() => NavigateTo("/mis-alertas"))" />
        }

        @* ═════════════ CARPETA COMPARTIDA (2026-07-06) ═════════════
           Carpeta de archivos compartida entre admin y depósito (permiso "compartido").
           Top-level para que la vean tambien los usuarios de depósito (no ven el grupo Café). *@
        @if (HasPerm("compartido"))
        {
            <NavItem Href="/compartido" Label="📂 Compartido" Icon="@SvgIcons.Folder"
                     IsActive="@IsActive("/compartido")" OnClick="@(() => NavigateTo("/compartido"))" />
        }

        @* ═════════════ 1B. CAFE (modulo independiente, debajo de Dashboard) ═════════════
           Negocio de venta de cafe e insumos, totalmente aislado del resto del ERP. *@
        @* ═════════════ MENÚ REDUCIDO PARA USUARIOS DE DEPÓSITO Y OFICINA ═════════════
           Ahora dinámico: lee de la tabla MenuVisibility (admin edita desde su sidebar).
           Cada item habilitado se renderiza con su emoji/label/href del MenuCatalog. *@
        @if (IsRoleWithCustomSidebar())
        {
            var role = GetEffectiveRoleForVisibility();
            var enabledKeys = MenuVisibility.GetEnabledKeys(role);
            <NavGroup Label="@(role == "oficina" ? "🏢 Oficina" : "🏭 Depósito")" Icon="@SvgIcons.Store"
                      Highlight="true" DefaultExpanded="true"
                      HasActiveChild="@(enabledKeys.Any(k => IsActive("/" + k)))">
                @foreach (var k in enabledKeys)
                {
                    if (MenuCatalog.TryGetValue(k, out var entry))
                    {
                        var href = entry.Href;
                        var label = $"{entry.Emoji} {entry.Label}";
                        <NavItem Href="@href" Label="@label" Icon="@SvgIcons.Package"
                                 IsActive="@IsActive(href)" OnClick="@(() => NavigateTo(href))" />
                    }
                }
                @if (enabledKeys.Count == 0)
                {
                    <div style="padding: 0.5rem 0.8rem; font-size: 0.78rem; color: #9ca3af; font-style: italic;">
                        El admin todavía no te asignó pantallas.
                    </div>
                }
            </NavGroup>
        }

        @* 2026-06-06: oficina ve EXACTAMENTE el mismo sidebar que admin *@
        @if (HasPerm("cafe") || HasPerm("oficina"))
        {
            <NavGroup Label="Ventas por fuera" Icon="@SvgIcons.Brand"
                      HasActiveChild="@(IsActive("/cafe") || IsActive("/cafe/ventas") || IsActive("/cafe/productos") || IsActive("/cafe/skus-meli") || IsActive("/cafe/combos") || IsActive("/cafe/oems") || IsActive("/cafe/clientes") || IsActive("/cafe/clientes-mapeados") || IsActive("/cafe/configuracion") || IsActive("/cafe/compras") || IsActive("/cafe/proveedores") || IsActive("/cafe/marcas") || IsActive("/cafe/listas-precios") || IsActive("/cafe/consultas") || IsActive("/cafe/cotejo") || IsActive("/cafe/descuentos") || IsActive("/cafe/kits") || IsActive("/cafe/reglas-precios") || IsActive("/cafe/saldos") || IsActive("/cafe/saldos-pendientes") || IsActive("/cafe/maquinas") || IsActive("/cafe/tesoreria/cajas") || IsActive("/cafe/tesoreria/resumen") || IsActive("/cafe/tesoreria/cobranzas") || IsActive("/cafe/tesoreria/pagos") || IsActive("/cafe/tesoreria/cheques") || IsActive("/cafe/depositos") || IsActive("/cafe/stock-masivo") || IsActive("/cafe/preventas") || IsActive("/cafe/arca/errores") || IsActive("/cafe/clientes/panel-deudas") || IsActive("/cafe/preparacion") || IsActive("/cafe/tesoreria/cheques-banco") || IsActive("/cafe/tesoreria/extracto-banco") || IsActive("/cafe/cobranzas-pendientes") || IsActive("/cafe/arqueo-repartidor") || IsActive("/cafe/repartidores") || IsActive("/horas-extras") || IsActive("/viajes") || IsActive("/stock"))">

                @* ───────── 1. ⭐ FAVORITOS (destacado verde, expandido por default) ─────────
                   Pedido del usuario 2026-05-19: una carpeta con los accesos mas usados que aparezca
                   PRIMERO y RESALTADA. Para que empleados (proxima sesion con login propio) tengan
                   todo a un click sin tener que recorrer el resto del sidebar. *@
                @* Reordenado 2026-05-24 por uso real (últimos 14 días en prod):
                   1. Ventas (#1 más usado)
                   2. Cobranzas (155 CREATE en 14 días)
                   3. Pedidos WhatsApp (nuevo flujo crítico)
                   4. Stock + Historial (control diario)
                   5. Clientes (consulta diaria)
                   6. Productos / Listas precios (uso medio)
                   7. Mapa de clientes / Mapeados (uso bajo)
                   8. Documentación (al final) *@
                <NavGroup Label="⭐ Favoritos" Icon="@SvgIcons.Dashboard" FlyoutMode="true"
                          Highlight="true" DefaultExpanded="true"
                          HasActiveChild="@(IsActive("/cafe/ventas") || IsActive("/cafe/tesoreria/cobranzas") || IsActive("/cafe/pedidos-whatsapp") || IsActive("/cafe/productos") || IsActive("/cafe/listas-precios") || IsActive("/cafe/stock-masivo") || IsActive("/cafe/historial-stock") || IsActive("/cafe/clientes") || IsActive("/mapeo") || IsActive("/cafe/clientes-mapeados") || IsActive("/documentacion"))">
                    <NavItem Href="/cafe/ventas" Label="🛒 Ventas" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/cafe/ventas")" OnClick="@(() => NavigateTo("/cafe/ventas"))" />
                    @if (HasPerm("cafe-tesoreria"))
                    {
                        <NavItem Href="/cafe/tesoreria/cobranzas" Label="📥 Cobranzas" Icon="@SvgIcons.ShoppingBag"
                                 IsActive="@IsActive("/cafe/tesoreria/cobranzas")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cobranzas"))" />
                    }
                    @if (HasPerm("cafe-depositos"))
                    {
                        <NavItem Href="/cafe/pedidos-whatsapp" Label="💬 Pedidos WhatsApp" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/cafe/pedidos-whatsapp")" OnClick="@(() => NavigateTo("/cafe/pedidos-whatsapp"))" />
                        <NavItem Href="/whatsapp" Label="📲 WhatsApp (Twilio)" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/whatsapp")" OnClick="@(() => NavigateTo("/whatsapp"))" />
                        @* Stock unificado: entra a Stock masivo, y desde la pantalla hay boton para abrir Stock movil. *@
                        <NavItem Href="/cafe/stock-masivo" Label="📦 Stock" Icon="@SvgIcons.Package"
                                 IsActive="@(IsActive("/cafe/stock-masivo") || IsActive("/stock"))" OnClick="@(() => NavigateTo("/cafe/stock-masivo"))" />
                        <NavItem Href="/cafe/historial-stock" Label="📊 Historial stock" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/cafe/historial-stock")" OnClick="@(() => NavigateTo("/cafe/historial-stock"))" />
                    }
                    <NavItem Href="/cafe/clientes" Label="👤 Clientes" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/cafe/clientes")" OnClick="@(() => NavigateTo("/cafe/clientes"))" />
                    <NavItem Href="/cafe/productos" Label="🏷 Productos" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/cafe/productos")" OnClick="@(() => NavigateTo("/cafe/productos"))" />
                    <NavItem Href="/cafe/listas-precios" Label="💲 Listas de precios" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/listas-precios")" OnClick="@(() => NavigateTo("/cafe/listas-precios"))" />
                    <NavItem Href="/cafe/listas-precios-custom" Label="📋 Listas personalizadas" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/listas-precios-custom")" OnClick="@(() => NavigateTo("/cafe/listas-precios-custom"))" />
                    <NavItem Href="/mapeo" Label="🗺 Mapa de clientes" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/mapeo")" OnClick="@(() => NavigateTo("/mapeo"))" />
                    <NavItem Href="/cafe/clientes-mapeados" Label="👥 Clientes Mapeados" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/clientes-mapeados")" OnClick="@(() => NavigateTo("/cafe/clientes-mapeados"))" />
                    <NavItem Href="/documentacion" Label="📑 Documentación" Icon="@SvgIcons.Folder"
                             IsActive="@IsActive("/documentacion")" OnClick="@(() => NavigateTo("/documentacion"))" />
                </NavGroup>

                @* ───────── 2. OPERACIÓN DIARIA (ya no destacado — Favoritos lo es) ─────────
                   Items que quedaron acá despues de mover los mas usados a Favoritos. *@
                <NavGroup Label="🟢 Operación diaria" Icon="@SvgIcons.Dashboard" FlyoutMode="true"
                          HasActiveChild="@(IsActive("/cafe") || IsActive("/cafe/saldos-pendientes") || IsActive("/cafe/clientes/panel-deudas") || IsActive("/cafe/tesoreria/resumen") || IsActive("/cafe/preventas") || IsActive("/cafe/consultas"))">
                    <NavItem Href="/cafe" Label="Inicio" Icon="@SvgIcons.Dashboard"
                             IsActive="@IsActive("/cafe")" OnClick="@(() => NavigateTo("/cafe"))" />
                    @if (HasPerm("cafe-tesoreria"))
                    {
                        <NavItem Href="/cafe/clientes/panel-deudas" Label="💰 ¿Quién me debe?" Icon="@SvgIcons.Database"
                                 IsActive="@(IsActive("/cafe/clientes/panel-deudas") || IsActive("/cafe/saldos-pendientes"))" OnClick="@(() => NavigateTo("/cafe/clientes/panel-deudas"))" />
                        <NavItem Href="/cafe/tesoreria/resumen" Label="📊 Resumen Tesorería" Icon="@SvgIcons.Dashboard"
                                 IsActive="@IsActive("/cafe/tesoreria/resumen")" OnClick="@(() => NavigateTo("/cafe/tesoreria/resumen"))" />
                    }
                    <NavItem Href="/cafe/preventas" Label="🛒 Pedidos de Gaby" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/cafe/preventas")" OnClick="@(() => NavigateTo("/cafe/preventas"))" />
                    <NavItem Href="/cafe/preparacion" Label="📦 Preparación pedidos" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/cafe/preparacion")" OnClick="@(() => NavigateTo("/cafe/preparacion"))" />
                    <NavItem Href="/cafe/consultas" Label="🔍 Consultas" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/consultas")" OnClick="@(() => NavigateTo("/cafe/consultas"))" />
                </NavGroup>

                @* ───────── 2. CATÁLOGO ───────── *@
                <NavGroup Label="🏬 Catálogo" Icon="@SvgIcons.Package" FlyoutMode="true"
                          HasActiveChild="@(IsActive("/cafe/productos") || IsActive("/cafe/skus-meli") || IsActive("/cafe/combos") || IsActive("/cafe/kits") || IsActive("/cafe/servicios") || IsActive("/cafe/oems") || IsActive("/cafe/marcas") || IsActive("/cafe/listas-precios"))">
                    <NavItem Href="/cafe/productos" Label="Productos" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/cafe/productos")" OnClick="@(() => NavigateTo("/cafe/productos"))" />
                    <NavItem Href="/cafe/skus-meli" Label="🛒 SKUs MeLi" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/skus-meli")" OnClick="@(() => NavigateTo("/cafe/skus-meli"))" />
                    <NavItem Href="/cafe/combos" Label="Combos MeLi" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/cafe/combos")" OnClick="@(() => NavigateTo("/cafe/combos"))" />
                    <NavItem Href="/cafe/kits" Label="Kits" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/cafe/kits")" OnClick="@(() => NavigateTo("/cafe/kits"))" />
                    <NavItem Href="/cafe/servicios" Label="🛠 Servicios" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/servicios")" OnClick="@(() => NavigateTo("/cafe/servicios"))" />
                    <NavItem Href="/cafe/oems" Label="OEMs" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/oems")" OnClick="@(() => NavigateTo("/cafe/oems"))" />
                    <NavItem Href="/cafe/marcas" Label="Marcas" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/marcas")" OnClick="@(() => NavigateTo("/cafe/marcas"))" />
                    <NavItem Href="/cafe/listas-precios" Label="Listas de precios" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/listas-precios")" OnClick="@(() => NavigateTo("/cafe/listas-precios"))" />
                    <NavItem Href="/cafe/listas-precios-custom" Label="📋 Listas personalizadas" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/listas-precios-custom")" OnClick="@(() => NavigateTo("/cafe/listas-precios-custom"))" />
                </NavGroup>

                @* ───────── 3. CLIENTES Y PROVEEDORES ───────── *@
                <NavGroup Label="👥 Clientes y proveedores" Icon="@SvgIcons.Users" FlyoutMode="true"
                          HasActiveChild="@(IsActive("/cafe/clientes") || IsActive("/cafe/clientes-mapeados") || IsActive("/cafe/proveedores") || IsActive("/cafe/telefonos-clientes-meli"))">
                    <NavItem Href="/cafe/clientes" Label="Clientes" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/cafe/clientes")" OnClick="@(() => NavigateTo("/cafe/clientes"))" />
                    <NavItem Href="/cafe/telefonos-clientes-meli" Label="📞 Teléfonos clientes MeLi" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/cafe/telefonos-clientes-meli")" OnClick="@(() => NavigateTo("/cafe/telefonos-clientes-meli"))" />
                    <NavItem Href="/cafe/clientes-mapeados" Label="Clientes Mapeados" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/clientes-mapeados")" OnClick="@(() => NavigateTo("/cafe/clientes-mapeados"))" />
                    <NavItem Href="/cafe/proveedores" Label="Proveedores" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/cafe/proveedores")" OnClick="@(() => NavigateTo("/cafe/proveedores"))" />
                </NavGroup>

                @* ───────── 4. TESORERÍA (Cajas / Pagos / Cheques) ───────── *@
                @if (HasPerm("cafe-tesoreria"))
                {
                    <NavGroup Label="💵 Tesorería" Icon="@SvgIcons.Database" FlyoutMode="true"
                              HasActiveChild="@(IsActive("/cafe/tesoreria/cajas") || IsActive("/cafe/tesoreria/pagos") || IsActive("/cafe/tesoreria/cheques") || IsActive("/cafe/tesoreria/cheques-banco") || IsActive("/cafe/configuracion/bancos"))">
                        <NavItem Href="/cafe/tesoreria/cajas" Label="💰 Cajas" Icon="@SvgIcons.Database"
                                 IsActive="@IsActive("/cafe/tesoreria/cajas")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cajas"))" />
                        <NavItem Href="/cafe/tesoreria/pagos" Label="📤 Pagos" Icon="@SvgIcons.ShoppingBag"
                                 IsActive="@IsActive("/cafe/tesoreria/pagos")" OnClick="@(() => NavigateTo("/cafe/tesoreria/pagos"))" />
                        <NavItem Href="/cafe/tesoreria/cheques" Label="📄 Cheques" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/cafe/tesoreria/cheques")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cheques"))" />
                        <NavItem Href="/cafe/tesoreria/cheques-banco" Label="💳 Cheques (banco)" Icon="@SvgIcons.Database"
                                 IsActive="@IsActive("/cafe/tesoreria/cheques-banco")" OnClick="@(() => NavigateTo("/cafe/tesoreria/cheques-banco"))" />
                        <NavItem Href="/cafe/tesoreria/extracto-banco" Label="🏦 Extracto banco" Icon="@SvgIcons.Database"
                                 IsActive="@IsActive("/cafe/tesoreria/extracto-banco")" OnClick="@(() => NavigateTo("/cafe/tesoreria/extracto-banco"))" />
                        <NavItem Href="/cafe/configuracion/bancos" Label="🏛 Catálogo de bancos" Icon="@SvgIcons.Settings"
                                 IsActive="@IsActive("/cafe/configuracion/bancos")" OnClick="@(() => NavigateTo("/cafe/configuracion/bancos"))" />
                        <NavItem Href="/cafe/cobranzas-pendientes" Label="💰 Cobranzas a aprobar" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/cafe/cobranzas-pendientes")" OnClick="@(() => NavigateTo("/cafe/cobranzas-pendientes"))" />
                        @* 2026-06-22: Pagos Movil (celu) + bandeja PC de pendientes *@
                        <NavItem Href="/pagos-movil" Label="📱 Pagos rápidos (celu)" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/pagos-movil")" OnClick="@(() => NavigateTo("/pagos-movil"))" />
                        <NavItem Href="/tesoreria/pagos-pendientes" Label="📋 Pagos a confirmar" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/tesoreria/pagos-pendientes")" OnClick="@(() => NavigateTo("/tesoreria/pagos-pendientes"))" />
                        @* 2026-06-06: Repartidores movido a grupo Empleados (mas abajo) *@
                        @* 2026-06-08: Arqueo repartidor movido al grupo Empleados (al lado de Repartidores) *@
                    </NavGroup>
                }

                @* ───────── 5. STOCK Y COMPRAS ─────────
                   2026-06-09: Stock masivo + Historial stock vuelven aca tambien (ademas de Favoritos)
                   porque el usuario penso que Favoritos era solo acceso directo y no encontraba Stock. *@
                <NavGroup Label="📦 Stock y compras" Icon="@SvgIcons.Store" FlyoutMode="true"
                          HasActiveChild="@(IsActive("/cafe/compras") || IsActive("/cafe/depositos") || IsActive("/cafe/stock-masivo") || IsActive("/cafe/historial-stock") || IsActive("/stock/reposicion") || IsActive("/stock/ranking") || IsActive("/stock/valuacion"))">
                    <NavItem Href="/cafe/stock-masivo" Label="📦 Stock" Icon="@SvgIcons.Package"
                             IsActive="@(IsActive("/cafe/stock-masivo") || IsActive("/stock"))" OnClick="@(() => NavigateTo("/cafe/stock-masivo"))" />
                    <NavItem Href="/cafe/historial-stock" Label="📊 Historial stock" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/historial-stock")" OnClick="@(() => NavigateTo("/cafe/historial-stock"))" />
                    @* 2026-06-15: pantalla nueva — listar reservas activas con detalle por orden MeLi *@
                    <NavItem Href="/cafe/reservados" Label="📦 Reservados MeLi" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/cafe/reservados")" OnClick="@(() => NavigateTo("/cafe/reservados"))" />
                    @* 2026-06-15: reportes nuevos — reposición (pedidos a proveedor) y ranking *@
                    <NavItem Href="/stock/reposicion" Label="📦 Reposición / Pedidos" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/stock/reposicion")" OnClick="@(() => NavigateTo("/stock/reposicion"))" />
                    <NavItem Href="/stock/ranking" Label="🏆 Ranking productos" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/stock/ranking")" OnClick="@(() => NavigateTo("/stock/ranking"))" />
                    @* 2026-07-09: valor de stock a costo (con exclusión de stock falso por marca/producto) *@
                    <NavItem Href="/stock/valuacion" Label="💰 Valor de stock" Icon="@SvgIcons.Database"
                             IsActive="@IsActive("/stock/valuacion")" OnClick="@(() => NavigateTo("/stock/valuacion"))" />
                    <NavItem Href="/cafe/compras" Label="🛒 Compras" Icon="@SvgIcons.Folder"
                             IsActive="@IsActive("/cafe/compras")" OnClick="@(() => NavigateTo("/cafe/compras"))" />
                    @if (HasPerm("cafe-depositos"))
                    {
                        <NavItem Href="/cafe/depositos" Label="🏬 Depósitos" Icon="@SvgIcons.Store"
                                 IsActive="@IsActive("/cafe/depositos")" OnClick="@(() => NavigateTo("/cafe/depositos"))" />
                    }
                </NavGroup>

                @* ───────── 6. EMPLEADOS (unificado Personal + Nóminas 2026-06-03) ─────────
                   2026-06-06: Repartidores movido aca desde el grupo Tesoreria *@
                <NavGroup Label="👥 Empleados" Icon="@SvgIcons.Users" FlyoutMode="true"
                          HasActiveChild="@(IsActive("/horas-extras") || IsActive("/viajes") || IsActive("/cafe/repartidores") || IsActive("/nominas") || IsActive("/nominas/empleados") || IsActive("/nominas/liquidaciones") || IsActive("/nominas/panel"))">
                    <NavItem Href="/horas-extras" Label="🕐 Horario" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/horas-extras")" OnClick="@(() => NavigateTo("/horas-extras"))" />
                    <NavItem Href="/viajes" Label="🚚 Viajes" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/viajes")" OnClick="@(() => NavigateTo("/viajes"))" />
                    <NavItem Href="/cafe/repartidores" Label="🚚 Repartidores" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/cafe/repartidores")" OnClick="@(() => NavigateTo("/cafe/repartidores"))" />
                    @* 2026-06-08: Arqueo repartidor movido aca desde Tesorería (mas relacionado con repartidores) *@
                    <NavItem Href="/cafe/arqueo-repartidor" Label="🧾 Arqueo repartidor" Icon="@SvgIcons.Database"
                             IsActive="@IsActive("/cafe/arqueo-repartidor")" OnClick="@(() => NavigateTo("/cafe/arqueo-repartidor"))" />
                    @if (HasPerm("nominas"))
                    {
                        <NavItem Href="/nominas/empleados" Label="👤 Ficha empleados" Icon="@SvgIcons.Users"
                                 IsActive="@IsActive("/nominas/empleados")" OnClick="@(() => NavigateTo("/nominas/empleados"))" />
                        <NavItem Href="/nominas/panel" Label="💰 ¿Cuánto debo pagar?" Icon="@SvgIcons.Dashboard"
                                 IsActive="@IsActive("/nominas/panel")" OnClick="@(() => NavigateTo("/nominas/panel"))" />
                        <NavItem Href="/nominas/liquidaciones" Label="📑 Liquidaciones" Icon="@SvgIcons.Tag"
                                 IsActive="@IsActive("/nominas/liquidaciones")" OnClick="@(() => NavigateTo("/nominas/liquidaciones"))" />
                        <NavItem Href="/nominas" Label="📊 Inicio nóminas" Icon="@SvgIcons.Dashboard"
                                 IsActive="@IsActive("/nominas")" OnClick="@(() => NavigateTo("/nominas"))" />
                    }
                </NavGroup>

                @* ───────── 7. CONFIG / TEMPORAL ───────── *@
                <NavGroup Label="⚙️ Config / Temporal" Icon="@SvgIcons.Settings" FlyoutMode="true"
