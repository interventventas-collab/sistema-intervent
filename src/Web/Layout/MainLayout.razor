@code {
    /// <summary>True si la app está corriendo en el entorno de DESARROLLO (puerto 3000 o
    /// el host es una IP en vez de un dominio). En ese caso se muestra un banner visible
    /// "DESARROLLO" y el sidebar tiene fondo distinto para evitar confundirlo con producción
    /// (app.palanica.com.ar).</summary>
    private bool IsDevEnvironment
    {
        get
        {
            var uri = new Uri(Navigation.BaseUri);
            // Cualquier acceso al puerto 3000 = dev (docker-compose dev)
            if (uri.Port == 3000) return true;
            // Acceso vía IP en vez de dominio = típico de testing remoto contra dev
            if (System.Net.IPAddress.TryParse(uri.Host, out _)) return true;
            // localhost también es dev
            if (uri.Host == "localhost" || uri.Host == "127.0.0.1") return true;
            return false;
        }
    }

    private bool sidebarOpen;
    private bool sidebarCollapsed;

    /// <summary>Atajo del FAB "Nueva Venta": navega a /cafe/ventas con un timestamp
    /// que dispara la apertura del modal en CafeVentas.razor. El timestamp asegura que
    /// si ya estás en esa página, igual se re-detecta y se abre el modal nuevamente.</summary>
    private void OpenNuevaVentaShortcut()
    {
        Navigation.NavigateTo($"/cafe/ventas?nueva={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}");
    }
    private bool userMenuOpen;
    private bool showOperatorModal;
    private bool showCompanyModal;
    private bool showCompanyAdminPasswordModal;
    private bool showCompanyNamesEditModal;
    private string companyAdminPassword = "";
    private string? companyAdminError;
    private Dictionary<string, string> companyNameEdits = new(StringComparer.OrdinalIgnoreCase);
    private string? companyNamesEditError;
    private bool isSavingCompanyNames;
    private string username = "usuario";
    private string role = "user";
    private List<string> permissions = new();

    private static readonly Dictionary<string, string> RouteToMenuKey = new()
    {
        { "", "dashboard" },
        { "publicaciones", "publicaciones" },
        { "ordenes", "ordenes" },
        { "mapeo", "mapeo" },
