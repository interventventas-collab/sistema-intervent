    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        CheckRoutePermission();
        _ = InvokeAsync(async () => await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName));
        // 2026-06-15: cada vez que navegas, refrescamos el timestamp de "última actividad"
        // para que la sesión no se bloquee mientras estás trabajando.
        _ = InvokeAsync(async () => await Operator.TouchAsync());
    }

    private void CheckRoutePermission()
    {
        if (permissions.Count == 0) return; // permissions not loaded yet

        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/').Split('?')[0].Split('#')[0];

        // 2026-05-28: rol "deposito" puede entrar a productos, stock y preparacion aunque no tenga "cafe".
        if (permissions.Contains("deposito") && (relativePath == "cafe/productos" || relativePath == "cafe/stock-masivo" || relativePath == "cafe/preparacion" || relativePath == "stock"))
        {
            return; // permitido
        }
        // 2026-05-28: rol "oficina" — lo mismo que deposito + cobranzas + mapeo.
        // 2026-05-30: oficina amplia: tambien puede acceder a ventas, clientes, listas, pedidos
        //             whatsapp, historial stock, clientes mapeados y documentacion (todo lo que
        //             ya esta en su sidebar pero antes no podia abrir por falta de whitelist).
        if (permissions.Contains("oficina") && (
                relativePath == "cafe/productos"
             || relativePath == "cafe/stock-masivo"
             || relativePath == "cafe/preparacion"
             || relativePath == "stock"
             || relativePath == "cafe/tesoreria/cobranzas"
             || relativePath == "mapeo"
             || relativePath == "cafe/ventas"
             || relativePath == "cafe/clientes"
             || relativePath == "cafe/listas-precios"
             || relativePath == "cafe/pedidos-whatsapp"
             || relativePath == "cafe/historial-stock"
             || relativePath == "cafe/clientes-mapeados"
             || relativePath == "documentacion"
             || relativePath == "cafe/preventas"
             || relativePath == "cafe/consultas"
             || relativePath == "cafe"))
        {
            return; // permitido
        }

        if (RouteToMenuKey.TryGetValue(relativePath, out var menuKey))
        {
            // Empty menuKey means always allowed (like /perfil)
            if (!string.IsNullOrEmpty(menuKey) && !permissions.Contains(menuKey))
            {
                // 2026-05-28: si no tiene dashboard pero es deposito/oficina, llevarlo a su home.
                // Antes redirigia a "/" que es la misma ruta → loop sin efecto → el dashboard se renderizaba igual.
                var homeRoute = GetHomeRouteForUser();
                Navigation.NavigateTo(homeRoute);
            }
        }
    }

    /// <summary>Ruta "home" según el rol del usuario. Si no tiene dashboard, lo llevamos a la
    /// pantalla principal de su rol. Para admins (con cafe) la home sigue siendo "/".</summary>
    private string GetHomeRouteForUser()
    {
        if (permissions.Contains("dashboard")) return "/";
        if (permissions.Contains("deposito") || permissions.Contains("oficina")) return "/cafe/preparacion";
        return "/perfil";
    }

