@code {
    // 2026-06-15: pantalla bloqueante de PIN
    private System.Threading.Timer? _pinLockTimer;
    private bool mostrarPinLock => requierePinLock && !Operator.IsValidated;
    /// <summary>2026-06-15: aplica a admin/oficina/cafe. Deposito-only queda exento
    /// para no romper su flujo (cargan stock, no ventas con identidad).</summary>
    private bool requierePinLock => permissions.Contains("cafe")
        || permissions.Contains("oficina")
        || string.Equals(role, "admin", StringComparison.OrdinalIgnoreCase);
    private List<string> operadoresParaPinLock => OperatorService.ForPermissions(permissions).ToList();
    private void OnOperatorChange() { InvokeAsync(StateHasChanged); }

    /// <summary>2026-06-15: el botón "Cambiar operador" del topbar ahora bloquea la sesión
    /// (la pantalla del PIN aparece sola). Para depósito, sigue usando el modal viejo.</summary>
    private async Task OnCambiarOperadorClick()
    {
        if (requierePinLock)
        {
            await Operator.LockAsync();
        }
        else
        {
            showOperatorModal = true;
        }
    }

    /// <summary>True si la app está corriendo en el entorno de DESARROLLO (puerto 3000 o
    /// el host es una IP en vez de un dominio). En ese caso se muestra un banner visible
    /// "DESARROLLO" y el sidebar tiene fondo distinto para evitar confundirlo con producción
    /// (app.palanica.com.ar).</summary>
    private bool IsDevEnvironment
    {
        get
        {
            var uri = new Uri(Navigation.BaseUri);
            // Cualquier acceso al puerto 3000 = dev (docker-compose dev)
            if (uri.Port == 3000) return true;
            // Acceso vía IP en vez de dominio = típico de testing remoto contra dev
            if (System.Net.IPAddress.TryParse(uri.Host, out _)) return true;
            // localhost también es dev
            if (uri.Host == "localhost" || uri.Host == "127.0.0.1") return true;
            return false;
        }
    }

