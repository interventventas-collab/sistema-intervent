    /// <summary>Recibe la acción del atajo de teclado (N+V / N+A / N+C / ?) y la ejecuta.
    /// Venta reusa el mismo camino que el botón "+ Nueva venta". Alquiler y Cobranza navegan
    /// a su pantalla con el query que auto-abre el formulario. "help" muestra la ayuda.</summary>
    [JSInvokable]
    public Task HandleNuevoShortcut(string action)
    {
        if (action == "help")
        {
            showShortcutsHelp = !showShortcutsHelp;
            InvokeAsync(StateHasChanged);
        }
        else if (action == "calc")
        {
            _ = OpenCalcFromNav();
        }
        else
        {
            NuevoRapido(action);
        }
        return Task.CompletedTask;
    }

    /// <summary>Abre el formulario de creación según el tipo. Lo usan tanto los tres botones
    /// de la barra como los atajos de teclado (N+V / N+A / N+C).</summary>
    private void NuevoRapido(string tipo)
    {
        switch (tipo)
        {
            case "venta":
                OpenNuevaVentaShortcut();
                break;
            case "alquiler":
                Navigation.NavigateTo($"/alquileres/reservas?nueva={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}");
                break;
            case "cobranza":
                Navigation.NavigateTo("/cafe/tesoreria/cobranzas?nueva=1");
                break;
        }
    }

    /// <summary>Atajo del FAB "Nueva Venta": si ya estamos en /cafe/ventas, emitimos
    /// una señal directa al componente (mas confiable que depender de LocationChanged
    /// cuando el path es el mismo). Si estamos en otra pagina, navegamos con timestamp.</summary>
    private void OpenNuevaVentaShortcut()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (uri.StartsWith("cafe/ventas", System.StringComparison.OrdinalIgnoreCase))
        {
            NuevaVentaSignal.Request();
        }
        else
        {
            Navigation.NavigateTo($"/cafe/ventas?nueva={DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}");
        }
    }
