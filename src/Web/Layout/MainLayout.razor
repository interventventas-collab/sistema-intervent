                @* 2026-07-08: Modulo Contadora — cuadro de ventas por jurisdiccion (Ingresos Brutos) *@
                <NavItem Href="/contadora" Label="🧾 Contadora" Icon="@SvgIcons.Database"
                         IsActive="@IsActive("/contadora")" OnClick="@(() => NavigateTo("/contadora"))" />
                @if (HasPerm("usuarios"))
                {
                    <NavItem Href="/usuarios" Label="Usuarios" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/usuarios")" OnClick="@(() => NavigateTo("/usuarios"))" />
                    <NavItem Href="/operadores-pin" Label="PINs operadores" Icon="@SvgIcons.User"
