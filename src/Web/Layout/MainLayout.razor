@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject SyncProgressTracker SyncProgress
@inject UploadProgressService UploadProgress
@inject BrandSettingsService BrandSettings
@inject IJSRuntime JS
@inject ApiClient Api
@inject OperatorService Operator
@inject CurrentCompanyService Company
@implements IDisposable

<aside class="sidebar @(sidebarOpen ? "open" : "") @(sidebarCollapsed ? "collapsed" : "")" id="sidebar">
    <div class="sidebar-brand">
        @if (BrandSettings.HasCustomLogo)
        {
            <img src="@BrandSettings.BrandLogo" alt="Logo" class="sidebar-brand-logo" />
        }
        else
        {
            <span class="sidebar-brand-icon">@SvgIcons.GetByName(BrandSettings.BrandIcon)</span>
        }
        <span class="sidebar-brand-text">@BrandSettings.BrandName</span>
        <button class="sidebar-collapse-btn" @onclick="ToggleCollapse" title="@(sidebarCollapsed ? "Expandir menu" : "Colapsar menu")">
            <span class="sidebar-collapse-icon">@(sidebarCollapsed ? SvgIcons.ChevronRight : SvgIcons.ChevronLeft)</span>
        </button>
    </div>
    <nav class="sidebar-nav" role="navigation" aria-label="Menu principal">
        @if (HasPerm("dashboard"))
        {
            <NavItem Href="/" Label="Dashboard" Icon="@SvgIcons.Dashboard"
                     IsActive="@IsActive("/")" OnClick="@(() => NavigateTo("/"))" />
        }

        @* MercadoLibre: solo visible para INTERVENT (es la unica empresa que vende por ML).
           Si no hay empresa elegida, se sigue mostrando para no esconderlo a usuarios viejos. *@
        @if ((HasPerm("publicaciones") || HasPerm("ordenes")) && (!Company.HasCompany || string.Equals(Company.Current, "INTERVENT", StringComparison.OrdinalIgnoreCase)))
        {
            <NavGroup Label="MercadoLibre" Icon="@SvgIcons.Store"
                      HasActiveChild="@(IsActive("/publicaciones") || IsActive("/ordenes"))">
                @if (HasPerm("publicaciones"))
                {
                    <NavItem Href="/publicaciones" Label="Publicaciones" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/publicaciones")" OnClick="@(() => NavigateTo("/publicaciones"))" />
                }
                @if (HasPerm("ordenes"))
                {
                    <NavItem Href="/ordenes" Label="Ordenes" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/ordenes")" OnClick="@(() => NavigateTo("/ordenes"))" />
                }
            </NavGroup>
        }

        @if (HasPerm("productos") || HasPerm("combos") || HasPerm("proveedores") || HasPerm("marcas") || HasPerm("listas-precios"))
        {
            <NavGroup Label="Productos y Servicios" Icon="@SvgIcons.Inventory"
                      HasActiveChild="@(IsActive("/productos") || IsActive("/combos") || IsActive("/listas-precios") || IsActive("/proveedores") || IsActive("/marcas"))">
                @if (HasPerm("productos"))
                {
                    <NavItem Href="/productos" Label="Productos" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/productos")" OnClick="@(() => NavigateTo("/productos"))" />
                }
                @if (HasPerm("combos"))
                {
                    <NavItem Href="/combos" Label="Combos" Icon="@SvgIcons.Package"
                             IsActive="@IsActive("/combos")" OnClick="@(() => NavigateTo("/combos"))" />
                }
                @if (HasPerm("listas-precios"))
                {
                    <NavItem Href="/listas-precios" Label="Listas de precios" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/listas-precios")" OnClick="@(() => NavigateTo("/listas-precios"))" />
                }
                @if (HasPerm("proveedores"))
                {
                    <NavItem Href="/proveedores" Label="Proveedores" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/proveedores")" OnClick="@(() => NavigateTo("/proveedores"))" />
                }
                @if (HasPerm("marcas"))
                {
                    <NavItem Href="/marcas" Label="Marcas" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/marcas")" OnClick="@(() => NavigateTo("/marcas"))" />
                }
            </NavGroup>
        }

        @if (HasPerm("ventas") || HasPerm("clientes"))
        {
            <NavGroup Label="Ventas" Icon="@SvgIcons.ShoppingBag"
                      HasActiveChild="@(IsActive("/ventas") || IsActive("/clientes"))">
                @if (HasPerm("ventas"))
                {
                    <NavItem Href="/ventas" Label="Comprobantes" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/ventas")" OnClick="@(() => NavigateTo("/ventas"))" />
                }
                @if (HasPerm("clientes"))
                {
                    <NavItem Href="/clientes" Label="Clientes" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/clientes")" OnClick="@(() => NavigateTo("/clientes"))" />
                }
            </NavGroup>
        }

        @if (HasPerm("tesoreria") || HasPerm("empleados") || HasPerm("sueldos"))
        {
            <NavGroup Label="Finanzas" Icon="@SvgIcons.Admin"
                      HasActiveChild="@(IsActive("/tesoreria") || IsActive("/empleados") || IsActive("/sueldos"))">
                @if (HasPerm("tesoreria"))
                {
                    <NavItem Href="/tesoreria" Label="Tesoreria" Icon="@SvgIcons.ShoppingBag"
                             IsActive="@IsActive("/tesoreria")" OnClick="@(() => NavigateTo("/tesoreria"))" />
                }
                @if (HasPerm("empleados"))
                {
                    <NavItem Href="/empleados" Label="Empleados" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/empleados")" OnClick="@(() => NavigateTo("/empleados"))" />
                }
                @if (HasPerm("sueldos"))
                {
                    <NavItem Href="/sueldos" Label="Sueldos" Icon="@SvgIcons.Tag"
                             IsActive="@IsActive("/sueldos")" OnClick="@(() => NavigateTo("/sueldos"))" />
                }
            </NavGroup>
        }

        <NavGroup Label="Comunicaciones" Icon="@SvgIcons.MessageCircle" HasActiveChild="false">
            <NavItem Href="https://web.whatsapp.com" Label="WhatsApp Web" Icon="@SvgIcons.MessageCircle" IsExternal="true" />
            <NavItem Href="https://mail.google.com" Label="Gmail" Icon="@SvgIcons.Mail" IsExternal="true" />
            <NavItem Href="https://calendar.google.com" Label="Google Calendar" Icon="@SvgIcons.Calendar" IsExternal="true" />
        </NavGroup>

        @if (HasPerm("usuarios") || HasPerm("roles") || HasPerm("integraciones") || HasPerm("procesos") || HasPerm("archivos") || HasPerm("auditoria") || HasPerm("backups"))
        {
            <NavGroup Label="Administracion" Icon="@SvgIcons.Admin"
                      HasActiveChild="@(IsActive("/usuarios") || IsActive("/roles") || IsActive("/integraciones") || IsActive("/procesos") || IsActive("/archivos") || IsActive("/auditoria") || IsActive("/backups") || IsActive("/config"))">
                @if (HasPerm("usuarios"))
                {
                    <NavItem Href="/usuarios" Label="Usuarios" Icon="@SvgIcons.Users"
                             IsActive="@IsActive("/usuarios")" OnClick="@(() => NavigateTo("/usuarios"))" />
                }
                @if (HasPerm("roles"))
                {
                    <NavItem Href="/roles" Label="Roles" Icon="@SvgIcons.Shield"
                             IsActive="@IsActive("/roles")" OnClick="@(() => NavigateTo("/roles"))" />
                }
                @if (HasPerm("integraciones"))
                {
                    <NavItem Href="/integraciones" Label="Integraciones" Icon="@SvgIcons.Link"
                             IsActive="@IsActive("/integraciones")" OnClick="@(() => NavigateTo("/integraciones"))" />
                }
                @if (HasPerm("procesos"))
                {
                    <NavItem Href="/procesos" Label="Procesos" Icon="@SvgIcons.Timer"
                             IsActive="@IsActive("/procesos")" OnClick="@(() => NavigateTo("/procesos"))" />
                }
                @if (HasPerm("archivos"))
                {
                    <NavItem Href="/archivos" Label="Archivos" Icon="@SvgIcons.Folder"
                             IsActive="@IsActive("/archivos")" OnClick="@(() => NavigateTo("/archivos"))" />
                }
                @if (HasPerm("auditoria"))
                {
                    <NavItem Href="/auditoria" Label="Auditoria" Icon="@SvgIcons.History"
                             IsActive="@IsActive("/auditoria")" OnClick="@(() => NavigateTo("/auditoria"))" />
                }
                @if (HasPerm("backups"))
                {
                    <NavItem Href="/backups" Label="Backups" Icon="@SvgIcons.Backup"
                             IsActive="@IsActive("/backups")" OnClick="@(() => NavigateTo("/backups"))" />
                }
                @if (HasPerm("config"))
                {
                    <NavItem Href="/config" Label="Configuracion" Icon="@SvgIcons.Settings"
                             IsActive="@IsActive("/config")" OnClick="@(() => NavigateTo("/config"))" />
                }
            </NavGroup>
        }
    </nav>
    <div class="sidebar-user">
        <div class="sidebar-user-avatar">@SvgIcons.User</div>
        <div class="sidebar-user-info">
            <span class="sidebar-user-name">@username</span>
            <span class="sidebar-user-role">@role</span>
        </div>
        <button class="sidebar-menu-btn" @onclick="ToggleUserMenu" @onclick:stopPropagation="true" title="Menu">
            <span class="sidebar-menu-icon @(userMenuOpen ? "rotated" : "")">@SvgIcons.ChevronUp</span>
        </button>
        @if (userMenuOpen)
        {
            <div class="sidebar-user-dropdown">
                <button class="sidebar-dropdown-item" @onclick="GoToProfile">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Edit</span>
                    <span class="sidebar-dropdown-text">Editar Perfil</span>
                </button>
                <button class="sidebar-dropdown-item sidebar-dropdown-danger" @onclick="Logout">
                    <span class="sidebar-dropdown-icon">@SvgIcons.Logout</span>
                    <span class="sidebar-dropdown-text">Cerrar Sesion</span>
                </button>
            </div>
        }
    </div>
</aside>

<main class="main-wrapper @(sidebarCollapsed ? "main-collapsed" : "")">
    <header class="topbar">
        <div class="topbar-left">
            <button class="topbar-menu-btn" @onclick="ToggleSidebar" aria-label="Abrir menu">
                @SvgIcons.Menu
            </button>
            <button class="topbar-company-btn" @onclick="() => showCompanyModal = true" title="Cambiar empresa de trabajo">
                <span class="topbar-company-name">@(Company.HasCompany ? Company.Current : BrandSettings.BrandName)</span>
                <span class="topbar-company-chevron">@SvgIcons.ChevronRight</span>
            </button>
            @if (Operator.HasOperator)
            {
                <button class="btn btn-secondary" style="margin-left: 0.8rem; font-size: 0.78rem; padding: 0.25rem 0.6rem;"
                        @onclick="() => showOperatorModal = true" title="Cambiar operador">
                    👤 @Operator.Current
                </button>
            }
        </div>
        <div class="topbar-actions">
            @if (UploadProgress.IsUploading)
            {
                <div class="topbar-upload-indicator" @onclick="() => UploadProgress.RequestReopen()" title="Ver detalle de subida">
                    <span class="topbar-upload-spinner"></span>
                    <span class="topbar-upload-text">Subiendo @UploadProgress.DoneCount/@UploadProgress.TotalCount</span>
                    <div class="topbar-upload-bar">
                        <div class="topbar-upload-bar-fill" style="width: @(UploadProgress.Percentage)%"></div>
                    </div>
                    <button class="topbar-upload-cancel" @onclick="CancelUpload" @onclick:stopPropagation="true" title="Cancelar subida"><i class="fa-solid fa-xmark"></i></button>
                </div>
            }
            @if (SyncProgress.State.IsActive && !SyncProgress.State.ShowModal)
            {
                <div class="topbar-sync-indicator @(SyncProgress.State.Status)" @onclick="OpenSyncModal" title="@SyncProgress.State.Description">
                    @if (SyncProgress.State.Status == "running")
                    {
                        <span class="topbar-sync-spinner"></span>
                        <span class="topbar-sync-text">@SyncProgress.State.Percentage%</span>
                        <div class="topbar-sync-bar">
                            <div class="topbar-sync-bar-fill" style="width: @(SyncProgress.State.Percentage)%"></div>
                        </div>
                    }
                    else if (SyncProgress.State.Status == "completed")
                    {
                        <span class="topbar-sync-text"><i class="fa-solid fa-circle-check"></i> Sincronizado</span>
                        <button class="topbar-sync-dismiss" @onclick="DismissSync" @onclick:stopPropagation="true" title="Cerrar"><i class="fa-solid fa-xmark"></i></button>
                    }
                    else if (SyncProgress.State.Status == "error")
                    {
                        <span class="topbar-sync-text"><i class="fa-solid fa-circle-xmark"></i> Error</span>
                        <button class="topbar-sync-dismiss" @onclick="DismissSync" @onclick:stopPropagation="true" title="Cerrar"><i class="fa-solid fa-xmark"></i></button>
                    }
                </div>
            }
        </div>
    </header>
    <div class="content">
        @Body
    </div>
</main>

@if (sidebarOpen)
{
    <div class="sidebar-overlay visible" @onclick="CloseSidebar"></div>
}

@* Modal de seleccion de empresa *@
@if (showCompanyModal)
{
    <div class="modal-overlay" style="z-index: 9000;" @onclick="() => showCompanyModal = false">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>🏢 ¿Con qué empresa estás trabajando?</h3>
                <button class="btn-close" @onclick="() => showCompanyModal = false">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #6b7280; margin: 0 0 0.75rem;">
                    Elegí la empresa actual. Va a ser la marca por defecto al emitir comprobantes
                    y el nombre que aparece arriba en la barra.
                </p>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem;">
                    @foreach (var co in CurrentCompanyService.Companies)
                    {
                        var name = co;
                        <button class="btn @(Company.Current == name ? "btn-primary" : "btn-secondary")"
                                @onclick="() => SelectCompany(name)"
                                style="padding: 0.7rem; font-weight: 700; font-size: 0.95rem;">
                            @name
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* Modal obligatorio: hay que elegir operador antes de operar *@
@if (showOperatorModal)
{
    <div class="modal-overlay" style="z-index: 9000;" @onclick:stopPropagation="true">
        <div class="modal-card modal-small" @onclick:stopPropagation="true">
            <div class="modal-header" style="background: whitesmoke;">
                <h3>👤 ¿Quién está trabajando?</h3>
                @if (Operator.HasOperator)
                {
                    <button class="btn-close" @onclick="() => showOperatorModal = false">&times;</button>
                }
            </div>
            <div class="modal-body">
                <p style="font-size: 0.85rem; color: #6b7280; margin: 0 0 0.75rem;">
                    Elegi tu nombre para que el sistema registre quien hace cada accion.
                </p>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem;">
                    @foreach (var op in OperatorService.Operators)
                    {
                        var name = op;
                        <button class="btn @(Operator.Current == name ? "btn-primary" : "btn-secondary")"
                                @onclick="() => SelectOperator(name)"
                                style="padding: 0.7rem; font-weight: 700; font-size: 0.95rem;">
                            @name
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

<ToastContainer />

@code {
    private bool sidebarOpen;
    private bool sidebarCollapsed;
    private bool userMenuOpen;
    private bool showOperatorModal;
    private bool showCompanyModal;
    private string username = "usuario";
    private string role = "user";
    private List<string> permissions = new();

    private static readonly Dictionary<string, string> RouteToMenuKey = new()
    {
        { "", "dashboard" },
        { "publicaciones", "publicaciones" },
        { "ordenes", "ordenes" },
        { "productos", "productos" },
        { "productos-base", "productos" },
        { "listas-precios", "listas-precios" },
        { "combos", "combos" },
        { "proveedores", "proveedores" },
        { "marcas", "marcas" },
        { "clientes", "clientes" },
        { "ventas", "ventas" },
        { "tesoreria", "tesoreria" },
        { "empleados", "empleados" },
        { "sueldos", "sueldos" },
        { "usuarios", "usuarios" },
        { "roles", "roles" },
        { "integraciones", "integraciones" },
        { "procesos", "procesos" },
        { "auditoria", "auditoria" },
        { "config", "config" },
        { "perfil", "" } // perfil always allowed
    };

    protected override async Task OnInitializedAsync()
    {
        SyncProgress.OnChange += OnSyncProgressChanged;
        UploadProgress.OnChanged += OnUploadProgressChanged;
        Operator.OnChange += OnOperatorChanged;
        Company.OnChange += OnCompanyChanged;
        var user = await AuthService.GetUserAsync();
        if (user is not null)
        {
            username = user.Username;
            role = user.Role;
            permissions = user.Permissions ?? new();
        }

        // Cargar operador desde localStorage. Si no hay, abrir modal obligatorio.
        await Operator.LoadAsync();
        if (!Operator.HasOperator) showOperatorModal = true;

        // Cargar empresa actual desde localStorage (no es obligatoria; cae al BrandSettings.BrandName si no hay).
        await Company.LoadAsync();

        // Refrescar permisos desde el servidor para reflejar cambios sin necesidad de re-login.
        try
        {
            var fresh = await Api.GetMeAsync();
            if (fresh?.Permissions is not null)
            {
                permissions = fresh.Permissions;
            }
        }
        catch { /* offline o sin sesion: dejamos lo que vino del cache */ }

        // Load brand settings
        try
        {
            var settings = await Api.GetSettingsAsync();
            if (settings is not null)
            {
                BrandSettings.LoadFromSettings(settings);
                await JS.InvokeVoidAsync("applyBrandColors", BrandSettings.PrimaryColor, BrandSettings.SidebarBgColor);
                await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName);
            }
        }
        catch { }

        BrandSettings.OnChange += OnBrandChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.LocationChanged += OnLocationChanged;
            CheckRoutePermission();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        CheckRoutePermission();
        _ = InvokeAsync(async () => await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName));
    }

    private void CheckRoutePermission()
    {
        if (permissions.Count == 0) return; // permissions not loaded yet

        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/').Split('?')[0].Split('#')[0];

        if (RouteToMenuKey.TryGetValue(relativePath, out var menuKey))
        {
            // Empty menuKey means always allowed (like /perfil)
            if (!string.IsNullOrEmpty(menuKey) && !permissions.Contains(menuKey))
            {
                Navigation.NavigateTo("/");
            }
        }
    }

    private bool HasPerm(string key) => permissions.Contains(key);

    private void OnSyncProgressChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OpenSyncModal()
    {
        if (SyncProgress.State.Status == "running")
        {
            SyncProgress.State.ShowModal = true;
            Navigation.NavigateTo("/publicaciones");
        }
    }

    private void DismissSync()
    {
        SyncProgress.Dismiss();
    }

    private async void OnBrandChanged()
    {
        await InvokeAsync(async () =>
        {
            await JS.InvokeVoidAsync("applyBrandColors", BrandSettings.PrimaryColor, BrandSettings.SidebarBgColor);
            await JS.InvokeVoidAsync("updatePageTitle", BrandSettings.BrandName);
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SyncProgress.OnChange -= OnSyncProgressChanged;
        UploadProgress.OnChanged -= OnUploadProgressChanged;
        Operator.OnChange -= OnOperatorChanged;
        Company.OnChange -= OnCompanyChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        BrandSettings.OnChange -= OnBrandChanged;
    }

    private void OnUploadProgressChanged() => InvokeAsync(StateHasChanged);
    private void OnOperatorChanged() => InvokeAsync(StateHasChanged);
    private void OnCompanyChanged() => InvokeAsync(StateHasChanged);

    private async Task SelectCompany(string name)
    {
        await Company.SetAsync(name);
        showCompanyModal = false;
        ToastService.Success($"Trabajando con {name}");
    }

    private async Task SelectOperator(string name)
    {
        await Operator.SetAsync(name);
        showOperatorModal = false;
        ToastService.Success($"Trabajando como {name}");
    }

    private async Task CancelUpload()
    {
        await UploadProgress.RequestCancelAsync();
    }

    private bool IsActive(string href)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0].TrimEnd('/');
        var target = href.TrimStart('/').TrimEnd('/');
        if (string.IsNullOrEmpty(target))
            return string.IsNullOrEmpty(relativePath) || relativePath.Equals("index.html", StringComparison.OrdinalIgnoreCase);
        return relativePath.Equals(target, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string url)
    {
        CloseSidebar();
        Navigation.NavigateTo(url);
    }

    private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    private void CloseSidebar() => sidebarOpen = false;
    private void ToggleCollapse()
    {
        sidebarCollapsed = !sidebarCollapsed;
        userMenuOpen = false;
    }
    private void ToggleUserMenu() => userMenuOpen = !userMenuOpen;

    private void GoToProfile()
    {
        userMenuOpen = false;
        CloseSidebar();
        Navigation.NavigateTo("/perfil");
    }

    private async Task Logout()
    {
        userMenuOpen = false;
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
