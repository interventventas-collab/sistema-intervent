    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 2026-06-05: registrar atajo Ctrl+K (o Cmd+K en Mac) para abrir el CommandPalette.
        if (firstRender && !cmdPalHandlerRegistered)
        {
            cmdPalHandlerRegistered = true;
            cmdPalRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("registerCommandPaletteShortcut", cmdPalRef);
                // 2026-07-08: atajos "N + inicial" (N V / N A / N C) y "?" de ayuda.
                await JS.InvokeVoidAsync("registerNuevoShortcuts", cmdPalRef);
            }
            catch { /* navegador viejo o JS bloqueado */ }
            // 2026-07-08: chequear si corresponde mostrar el globito de bienvenida.
            await CargarWelcomeAsync();
            // 2026-07-15: apagar el cartel "nuevo" de la calculadora si ya la usaron.
            try
            {
                var usada = await JS.InvokeAsync<string?>("localStorage.getItem", "calc.usada");
                if (usada == "1") { calcNuevoBadge = false; await InvokeAsync(StateHasChanged); }
            }
            catch { }
            // 2026-07-21: respetar cómo dejó el menú el usuario (plegado/expandido).
            // Default = plegado; solo se expande si el usuario lo guardó así antes.
            try
            {
                var savedCollapsed = await JS.InvokeAsync<string?>("localStorage.getItem", "sidebarCollapsed");
                if (savedCollapsed == "false" && sidebarCollapsed)
                {
                    sidebarCollapsed = false;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }

    /// <summary>2026-06-23: handler unico del boton WhatsApp y del banner rojo.
    /// Si esta linked -> va a /whatsapp-web (chats reales del WA Web via Playwright).
    /// Si NO esta linked -> abre modal con QR sin pasar por /integraciones.
    /// La pantalla /whatsapp original (Twilio sandbox) sigue accesible por URL directa.</summary>
    private async Task ClickBotonWhatsApp()
    {
        if (waLinked)
        {
            NavigateTo("/whatsapp-web");
            return;
        }
        // No vinculado: abro el modal con QR directo
        showWaQrModal = true;
        waPreparingQr = true;
        waQrUrl = "";
        await InvokeAsync(StateHasChanged);
        try
        {
            var ok = await Api.StartWhatsAppLinkAsync();
            if (!ok)
            {
                showWaQrModal = false;
                ToastService.Error("No se pudo iniciar la vinculacion de WhatsApp");
                return;
            }
            await Task.Delay(4000);
            waQrUrl = $"/api/whatsapp/qr?t={DateTimeOffset.Now.ToUnixTimeMilliseconds()}";
            waPreparingQr = false;
            await InvokeAsync(StateHasChanged);
            StartWaLinkPolling();
        }
        catch (Exception ex)
        {
            showWaQrModal = false;
            ToastService.Error("Error: " + ex.Message);
        }
    }

    /// <summary>Polling del QR mientras el modal esta abierto. Refresca la imagen cada 3s
    /// (el QR de WhatsApp Web rota solo) y chequea si ya escaneo. Cuando se vincula, cierra el modal.</summary>
    private void StartWaLinkPolling()
    {
        _waLinkPollCts?.Cancel();
        _waLinkPollCts = new System.Threading.CancellationTokenSource();
        var token = _waLinkPollCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(3000, token);
                    if (token.IsCancellationRequested) break;
                    waQrUrl = $"/api/whatsapp/qr?t={DateTimeOffset.Now.ToUnixTimeMilliseconds()}";
                    var linked = await Api.CheckWhatsAppLinkedAsync();
                    await InvokeAsync(StateHasChanged);
                    if (linked)
                    {
                        showWaQrModal = false;
                        waStatus = await Api.GetWhatsAppStatusAsync();
                        ToastService.Success("✅ WhatsApp vinculado correctamente");
                        await InvokeAsync(StateHasChanged);
                        break;
                    }
                }
                catch (TaskCanceledException) { break; }
                catch { }
            }
        }, token);
    }

    private void CerrarWaQrModal()
    {
        _waLinkPollCts?.Cancel();
        showWaQrModal = false;
    }

    /// <summary>2026-06-23: chequea el estado del WhatsApp Web cada 60s.
    /// Si Playwright dice linked=false, mostramos banner rojo en la topbar.</summary>
    private async Task RefrescarWaStatus()
    {
        try
        {
            var s = await Api.GetWhatsAppStatusAsync();
            var prevLinked = waStatus?.Linked == true;
            waStatus = s;
            // Si justo se cayó (transicion true->false), notificar UNA vez
            if (prevLinked && s is not null && !s.Linked && !s.IsLinking)
            {
                ToastService.Error("⚠️ WhatsApp desvinculado — rescaneá el QR para seguir mandando mensajes");
            }
            await InvokeAsync(StateHasChanged);
        }
        catch { /* el servicio puede estar caído; el polling vuelve a intentar en 60s */ }
    }

