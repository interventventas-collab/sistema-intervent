@inject ApiClient Api
@inject IJSRuntime JS

<div class="assistant-fab @(open ? "open" : "")">
    @if (!open)
    {
        <button class="assistant-bubble" @onclick="ToggleOpen" title="Asistente">
            💬
            @if (unread > 0) { <span class="assistant-dot">@unread</span> }
        </button>
    }
    else
    {
        <div class="assistant-panel">
            <div class="assistant-header">
                <div style="display: flex; align-items: center; gap: 0.4rem;">
                    <span style="font-size: 1.1rem;">💬</span>
                    <strong style="font-size: 0.9rem;">Asistente</strong>
                    @if (loading)
                    {
                        <span style="font-size: 0.72rem; color: #cbd5e1;">pensando...</span>
                    }
                </div>
                <div style="display: flex; gap: 0.3rem;">
                    <button class="assistant-iconbtn" title="Limpiar charla" @onclick="ClearChat">🧹</button>
                    <button class="assistant-iconbtn" title="Cerrar" @onclick="ToggleOpen">&times;</button>
                </div>
            </div>
            <div class="assistant-body" @ref="bodyRef">
                @if (messages.Count == 0)
                {
                    <div class="assistant-empty">
                        <p style="margin: 0 0 0.5rem; font-weight: 700;">¡Hola! Soy tu asistente.</p>
                        <p style="margin: 0; font-size: 0.82rem; color: #6b7280; line-height: 1.4;">
                            Pregunteme sobre los datos del sistema. Por ejemplo:
                        </p>
                        <ul style="margin: 0.4rem 0 0; padding-left: 1.2rem; font-size: 0.8rem; color: #374151;">
                            <li>"¿Cuánto debe Pérez?"</li>
                            <li>"Stock de F1-1KG"</li>
                            <li>"Último comprobante de tal cliente"</li>
                            <li>"¿Cuánto le debo del sueldo a Maxi?"</li>
                        </ul>
                    </div>
                }
                else
                {
                    @foreach (var m in messages)
                    {
                        <div class="assistant-msg @(m.Role == "user" ? "user" : "asst")">
                            @if (m.Role == "assistant")
                            {
                                @* renderizado simple de texto con saltos de linea *@
                                @foreach (var line in (m.Content ?? "").Split('\n'))
                                {
                                    <div>@line</div>
                                }
                            }
                            else
                            {
                                @m.Content
                            }
                        </div>
                    }
                    @if (loading)
                    {
                        <div class="assistant-msg asst typing">
                            <span class="assistant-dot-anim"></span>
                            <span class="assistant-dot-anim"></span>
                            <span class="assistant-dot-anim"></span>
                        </div>
                    }
                }
            </div>
            <div class="assistant-input">
                <textarea @bind="input" @bind:event="oninput" @onkeydown="OnKey"
                          placeholder="Escribí tu pregunta..." rows="1"
                          disabled="@loading"></textarea>
                <button class="assistant-sendbtn" @onclick="Send" disabled="@(loading || string.IsNullOrWhiteSpace(input))" title="Enviar (Enter)">
                    ➤
                </button>
            </div>
        </div>
    }
</div>

<style>
    .assistant-fab {
        position: fixed;
        bottom: 18px;
        right: 18px;
        z-index: 9999;
    }
    .assistant-bubble {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #1f2937;
        color: white;
        border: none;
        font-size: 1.6rem;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(0,0,0,0.25);
        position: relative;
        transition: transform 0.15s;
    }
    .assistant-bubble:hover { transform: scale(1.06); }
    .assistant-dot {
        position: absolute;
        top: -2px;
        right: -2px;
        background: #ef4444;
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 999px;
        padding: 0 4px;
        display: flex; align-items: center; justify-content: center;
    }

    .assistant-panel {
        width: 360px;
        max-width: calc(100vw - 36px);
        height: 520px;
        max-height: calc(100vh - 100px);
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.30);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid #e5e7eb;
    }
    .assistant-header {
        background: #1f2937;
        color: white;
        padding: 0.55rem 0.75rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }
    .assistant-iconbtn {
        background: transparent;
        color: white;
        border: none;
        font-size: 0.95rem;
        cursor: pointer;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
    }
    .assistant-iconbtn:hover { background: rgba(255,255,255,0.12); }

    .assistant-body {
        flex: 1;
        overflow-y: auto;
        padding: 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        background: #f9fafb;
        font-size: 0.88rem;
    }
    .assistant-empty {
        background: white;
        border: 1px dashed #d1d5db;
        border-radius: 8px;
        padding: 0.8rem;
    }
    .assistant-msg {
        max-width: 85%;
        padding: 0.45rem 0.7rem;
        border-radius: 10px;
        word-wrap: break-word;
        line-height: 1.4;
    }
    .assistant-msg.user {
        align-self: flex-end;
        background: #1d4ed8;
        color: white;
        border-bottom-right-radius: 2px;
    }
    .assistant-msg.asst {
        align-self: flex-start;
        background: white;
        color: #111827;
        border: 1px solid #e5e7eb;
        border-bottom-left-radius: 2px;
    }
    .assistant-msg.typing {
        display: flex;
        gap: 4px;
        align-items: center;
        padding: 0.6rem 0.8rem;
    }
    .assistant-dot-anim {
        width: 6px; height: 6px;
        background: #94a3b8;
        border-radius: 50%;
        animation: assistant-bounce 1.2s infinite ease-in-out;
    }
    .assistant-dot-anim:nth-child(2) { animation-delay: 0.15s; }
    .assistant-dot-anim:nth-child(3) { animation-delay: 0.3s; }
    @@keyframes assistant-bounce {
        0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
        40% { transform: scale(1); opacity: 1; }
    }

    .assistant-input {
        display: flex;
        padding: 0.45rem;
        border-top: 1px solid #e5e7eb;
        gap: 0.4rem;
        align-items: flex-end;
        background: white;
    }
    .assistant-input textarea {
        flex: 1;
        resize: none;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 0.45rem 0.6rem;
        font-size: 0.9rem;
        font-family: inherit;
        max-height: 120px;
        min-height: 36px;
        outline: none;
    }
    .assistant-input textarea:focus { border-color: #1d4ed8; }
    .assistant-sendbtn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #1d4ed8;
        color: white;
        border: none;
        font-size: 1rem;
        cursor: pointer;
        flex-shrink: 0;
    }
    .assistant-sendbtn:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Mobile: panel full width */
    @@media (max-width: 480px) {
        .assistant-panel {
            width: calc(100vw - 24px);
            height: calc(100vh - 90px);
        }
        .assistant-fab { bottom: 12px; right: 12px; }
    }

    /* Imprimir: ocultar widget */
    @@media print {
        .assistant-fab { display: none !important; }
    }
</style>

@code {
    private bool open;
    private bool loading;
    private string input = "";
    private int unread;
    private List<AssistantChatMessage> messages = new();
    private ElementReference bodyRef;
    private const string STORAGE_KEY = "assistant.session";

    protected override async Task OnInitializedAsync()
    {
        // Restaurar la charla de sessionStorage (se borra al cerrar la pestaña)
        try
        {
            var saved = await JS.InvokeAsync<string?>("sessionStorage.getItem", STORAGE_KEY);
            if (!string.IsNullOrEmpty(saved))
            {
                var parsed = System.Text.Json.JsonSerializer.Deserialize<List<AssistantChatMessage>>(saved);
                if (parsed is not null) messages = parsed;
            }
        }
        catch { }
    }

    private async Task ToggleOpen()
    {
        open = !open;
        if (open) { unread = 0; await ScrollToBottom(); }
    }

    private async Task ClearChat()
    {
        messages.Clear();
        try { await JS.InvokeVoidAsync("sessionStorage.removeItem", STORAGE_KEY); } catch { }
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task Send()
    {
        var text = (input ?? "").Trim();
        if (string.IsNullOrEmpty(text) || loading) return;
        input = "";
        messages.Add(new AssistantChatMessage { Role = "user", Content = text });
        await PersistAndScroll();
        loading = true;
        StateHasChanged();
        try
        {
            var resp = await Api.AssistantChatAsync(messages);
            if (resp is null)
            {
                messages.Add(new AssistantChatMessage { Role = "assistant", Content = "No pude conectar con el asistente. Probá de nuevo." });
            }
            else if (!resp.Configured)
            {
                messages.Add(new AssistantChatMessage { Role = "assistant", Content = resp.Reply });
            }
            else
            {
                messages.Add(new AssistantChatMessage { Role = "assistant", Content = string.IsNullOrEmpty(resp.Reply) ? "(sin respuesta)" : resp.Reply });
            }
            if (!open) unread++;
        }
        catch (Exception ex)
        {
            messages.Add(new AssistantChatMessage { Role = "assistant", Content = "Error: " + ex.Message });
        }
        finally
        {
            loading = false;
            await PersistAndScroll();
        }
    }

    private async Task PersistAndScroll()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(messages);
            await JS.InvokeVoidAsync("sessionStorage.setItem", STORAGE_KEY, json);
        }
        catch { }
        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("eval", "(function(){var els=document.getElementsByClassName('assistant-body');for(var i=0;i<els.length;i++){els[i].scrollTop=els[i].scrollHeight;}})()"); }
        catch { }
    }
}
