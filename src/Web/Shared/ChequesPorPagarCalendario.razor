@inject ApiClient Api
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject OperatorService Operator
@using Web.Models

@* ════════════════════════════════════════════════════════════════════════════
   Calendario del dashboard. Modo COMPACTO (default) muestra solo el mes actual,
   chiquito. Modo EXPANDIDO muestra mes actual + siguiente.
   Eventos:
     - 🔴 Cheques EMITIDOS por pagar (estado Aceptado, automatico)
     - 📝 Notas manuales (sueldos, comisiones, recordatorios, etc.)
   Click en un dia → modal con detalle + boton "Agregar nota".
   ════════════════════════════════════════════════════════════════════════════ *@

<style>
    .cal-wrap { background: white; border-radius: 12px; padding: 0.7rem 1rem; margin-bottom: 1rem; box-shadow: 0 2px 6px rgba(0,0,0,0.05); border-left: 4px solid #f59e0b; }
    .cal-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.5rem; }
    .cal-title { font-size: 0.95rem; font-weight: 800; color: #92400e; }
    .cal-actions { display: flex; gap: 0.4rem; align-items: center; }
    .cal-btn { padding: 0.3rem 0.7rem; font-size: 0.78rem; border: 1px solid #d1d5db; background: white; color: #374151; border-radius: 6px; cursor: pointer; font-weight: 600; }
    .cal-btn:hover { background: #f3f4f6; }
    .cal-btn.activo { background: #1d4ed8; color: white; border-color: #1d4ed8; }

    .cal-summary { display: flex; gap: 0.8rem; flex-wrap: wrap; font-size: 0.78rem; color: #6b7280; margin-bottom: 0.5rem; }
    .cal-summary b { color: #1f2937; }

    .cal-calendars { display: grid; gap: 0.8rem; }
    .cal-calendars.compacto { grid-template-columns: repeat(3, 1fr); }
    .cal-calendars.expandido { grid-template-columns: repeat(3, 1fr); }
    @@media (max-width: 900px) { .cal-calendars.compacto, .cal-calendars.expandido { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 600px) { .cal-calendars.compacto, .cal-calendars.expandido { grid-template-columns: 1fr; } }
    .cal-mes.actual { background: #fffbeb; border-radius: 8px; padding: 0.3rem; box-shadow: 0 0 0 2px #fcd34d; }

    .cal-mes { }
    .cal-mes-title { font-weight: 700; color: #4b5563; text-align: center; margin-bottom: 0.3rem; font-size: 0.85rem; letter-spacing: 0.04em; }
    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
    .cal-dayheader { text-align: center; font-size: 0.6rem; color: #6b7280; font-weight: 700; padding: 0.15rem 0; }
    .cal-day { aspect-ratio: 1; display: flex; flex-direction: column; align-items: stretch; justify-content: flex-start; position: relative; border-radius: 5px; font-size: 0.7rem; color: #374151; background: #f9fafb; cursor: pointer; transition: transform 0.1s; padding: 2px; gap: 1px; min-height: 50px; }
    .cal-day:hover { transform: scale(1.06); z-index: 2; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
    .cal-day.empty { background: transparent; cursor: default; }
    .cal-day.empty:hover { transform: none; box-shadow: none; }
    .cal-day-numero { font-size: 0.7rem; color: #6b7280; font-weight: 700; line-height: 1; text-align: right; padding: 1px 3px; }
    .cal-day.hoy { outline: 2px solid #1d4ed8; outline-offset: -2px; background: #dbeafe; box-shadow: 0 0 8px rgba(29, 78, 216, 0.3); }
    .cal-day.hoy .cal-day-numero { color: #1e3a8a; font-weight: 900; }
    .cal-day-events { display: flex; flex-direction: column; gap: 1px; flex: 1; overflow: hidden; }
    .cal-pill { font-size: 0.6rem; padding: 1px 3px; border-radius: 3px; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 700; }
    .cal-pill-cheque { background: #dc2626; color: white; }
    .cal-pill-cheque-pagado { background: #d1fae5; color: #065f46; }
    .cal-pill-nota { background: #ede9fe; color: #6b21a8; border: 1px solid #c4b5fd; }

    .cal-leyenda { display: flex; gap: 0.7rem; font-size: 0.66rem; color: #6b7280; margin-top: 0.4rem; justify-content: center; flex-wrap: wrap; }
    .cal-leyenda-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 2px; vertical-align: middle; }
    .cal-vacio { text-align: center; padding: 0.8rem; color: #6b7280; font-style: italic; font-size: 0.85rem; }

    /* Modal del dia */
    .day-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 9000; }
    .day-modal { background: white; border-radius: 10px; max-width: 500px; width: 90%; max-height: 85vh; overflow: auto; }
    .day-modal-header { padding: 0.8rem 1rem; background: #1d4ed8; color: white; display: flex; justify-content: space-between; align-items: center; border-radius: 10px 10px 0 0; }
    .day-modal-header h3 { margin: 0; font-size: 1.05rem; }
    .day-modal-close { background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; padding: 0; line-height: 1; }
    .day-modal-body { padding: 0.8rem 1rem; }
    .day-section { margin-bottom: 0.8rem; }
    .day-section-title { font-size: 0.78rem; font-weight: 700; color: #4b5563; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.3rem; }
    .day-item { padding: 0.4rem 0.6rem; border-radius: 6px; margin-bottom: 0.3rem; display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; }
    .day-item.cheque { background: #fef3c7; border-left: 3px solid #f59e0b; }
    .day-item.nota { background: #ede9fe; border-left: 3px solid #8b5cf6; }
    .day-item-info { flex: 1; min-width: 0; }
    .day-item-title { font-weight: 700; font-size: 0.88rem; }
    .day-item-desc { font-size: 0.75rem; color: #6b7280; margin-top: 0.15rem; }
    .day-item-importe { font-weight: 800; color: #1f2937; }
    .day-item-borrar { background: none; border: none; color: #b91c1c; cursor: pointer; padding: 0.2rem; font-size: 1rem; }
    .day-form { background: #f9fafb; padding: 0.7rem; border-radius: 6px; }
    .day-form input, .day-form textarea { width: 100%; padding: 0.4rem 0.6rem; border: 1px solid #d1d5db; border-radius: 4px; font-size: 0.85rem; margin-bottom: 0.4rem; box-sizing: border-box; }
</style>

<div class="cal-wrap">
    <div class="cal-header">
        <span class="cal-title">🟡 Calendario — cheques y notas</span>
        <div class="cal-actions">
            <button class="cal-btn @(expandido ? "" : "activo")" @onclick="@(() => expandido = false)" title="Vista compacta (1 mes)">▫️ Compacto</button>
            <button class="cal-btn @(expandido ? "activo" : "")" @onclick="@(() => expandido = true)" title="Vista expandida (2 meses)">▭ Expandir</button>
            <button class="cal-btn" @onclick='() => Navigation.NavigateTo("/cafe/tesoreria/cheques-banco")'>Ver cheques →</button>
        </div>
    </div>

    @if (loading)
    {
        <p class="cal-vacio">⏳ Cargando…</p>
    }
    else
    {
        <div class="cal-summary">
            @if (chequesPorPagarTotal > 0)
            {
                <span>🔴 <b>$@chequesPorPagarTotal.ToString("N0")</b> en cheques por pagar</span>
            }
            @if (notas.Count > 0)
            {
                <span>📝 <b>@notas.Count</b> nota@(notas.Count == 1 ? "" : "s")</span>
            }
            @if (chequesPorPagarTotal == 0 && notas.Count == 0)
            {
                <span>Sin eventos en el rango visible. Click en un día para agregar notas.</span>
            }
        </div>

        <div class="cal-calendars @(expandido ? "expandido" : "compacto")">
            @{
                // Compacto: mes anterior + actual + siguiente (3 meses). Expandido: 6 meses
                // (1 atras + actual + 4 adelante). El mes actual se resalta con un highlight.
                var inicioOffset = expandido ? -1 : -1;
                var cantidad = expandido ? 6 : 3;
            }
            @for (int m = 0; m < cantidad; m++)
            {
                var primerDia = new DateTime(DateTime.Today.AddMonths(m + inicioOffset).Year, DateTime.Today.AddMonths(m + inicioOffset).Month, 1);
                var esMesActual = primerDia.Year == DateTime.Today.Year && primerDia.Month == DateTime.Today.Month;
                <div class="cal-mes @(esMesActual ? "actual" : "")">
                    <div class="cal-mes-title">@NombreMes(primerDia) @primerDia.Year</div>
                    <div class="cal-grid">
                        @foreach (var d in new[] { "L", "M", "M", "J", "V", "S", "D" })
                        {
                            <div class="cal-dayheader">@d</div>
                        }
                        @{
                            var offset = ((int)primerDia.DayOfWeek + 6) % 7;
                        }
                        @for (int i = 0; i < offset; i++)
                        {
                            <div class="cal-day empty"></div>
                        }
                        @{
                            var diasMes = DateTime.DaysInMonth(primerDia.Year, primerDia.Month);
                        }
                        @for (int d = 1; d <= diasMes; d++)
                        {
                            var fecha = new DateTime(primerDia.Year, primerDia.Month, d);
                            var enFecha = chequesPorFecha.TryGetValue(fecha, out var lista) ? lista : null;
                            var notasFecha = notas.Where(n => n.Fecha.Date == fecha).ToList();
                            var esHoy = fecha == DateTime.Today;
                            var clase = "cal-day" + (esHoy ? " hoy" : "");
                            // Resumimos eventos del dia para mostrar pildoritas
                            var chequesPendientes = enFecha?.Where(c => !string.Equals(c.Estado, "Pagado", StringComparison.OrdinalIgnoreCase)).ToList() ?? new();
                            var chequesPagados = enFecha?.Where(c => string.Equals(c.Estado, "Pagado", StringComparison.OrdinalIgnoreCase)).ToList() ?? new();
                            var entregasFecha = alqEntregasPorFecha.TryGetValue(fecha, out var le) ? le : null;
                            var retirosFecha = alqRetirosPorFecha.TryGetValue(fecha, out var lr) ? lr : null;
                            <div class="@clase" @onclick="() => AbrirDia(fecha)">
                                <div class="cal-day-numero">@d</div>
                                <div class="cal-day-events">
                                    @if (entregasFecha is { Count: > 0 })
                                    {
                                        <div class="cal-pill" style="background:#ede9fe; color:#5b21b6;" title="@string.Join(", ", entregasFecha.Select(r => r.ClienteNombre))">
                                            📦 @(entregasFecha.Count == 1 ? "Entrega" : $"Entregas x{entregasFecha.Count}")
                                        </div>
                                    }
                                    @if (retirosFecha is { Count: > 0 })
                                    {
                                        <div class="cal-pill" style="background:#ffedd5; color:#9a3412;" title="@string.Join(", ", retirosFecha.Select(r => r.ClienteNombre))">
                                            🔙 @(retirosFecha.Count == 1 ? "Retiro" : $"Retiros x{retirosFecha.Count}")
                                        </div>
                                    }
                                    @if (chequesPendientes.Count > 0)
                                    {
                                        <div class="cal-pill cal-pill-cheque" title="@chequesPendientes.Count cheque(s) a pagar — total $@chequesPendientes.Sum(c => c.Importe).ToString("N0")">
                                            🔴 @(chequesPendientes.Count == 1 ? "Cheque" : $"Cheques x{chequesPendientes.Count}")
                                        </div>
                                    }
                                    @if (chequesPagados.Count > 0)
                                    {
                                        <div class="cal-pill cal-pill-cheque-pagado" title="@chequesPagados.Count cheque(s) ya pagado(s)">
                                            ✓ @(chequesPagados.Count == 1 ? "Cheque" : $"Cheques x{chequesPagados.Count}")
                                        </div>
                                    }
                                    @if (notasFecha.Count > 0)
                                    {
                                        <div class="cal-pill cal-pill-nota" title="@notasFecha.Count nota(s)">
                                            📝 @(notasFecha.Count == 1 ? "Nota" : $"Notas x{notasFecha.Count}")
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="cal-leyenda">
            <span><span class="cal-leyenda-dot" style="background:#dc2626;"></span>cheque a pagar</span>
            <span><span class="cal-leyenda-dot" style="background:#d1fae5; border:1px solid #065f46;"></span>cheque ya pagado</span>
            <span><span class="cal-leyenda-dot" style="background:#ede9fe; border:1px solid #c4b5fd;"></span>nota</span>
            <span><span class="cal-leyenda-dot" style="background:#dbeafe; border:1px solid #1d4ed8;"></span>hoy</span>
        </div>
    }
</div>

@* Modal: detalle del día + agregar nota *@
@if (diaAbierto is not null)
{
    <div class="day-modal-overlay" @onclick="@(() => diaAbierto = null)">
        <div class="day-modal" @onclick:stopPropagation="true">
            <div class="day-modal-header">
                <h3>📅 @diaAbierto.Value.ToString("dddd dd 'de' MMMM 'de' yyyy", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</h3>
                <button class="day-modal-close" @onclick="@(() => diaAbierto = null)">&times;</button>
            </div>
            <div class="day-modal-body">
                @{
                    var chs = chequesPorFecha.TryGetValue(diaAbierto.Value, out var l) ? l : new List<ChequeBancoDto>();
                    var ns = notas.Where(x => x.Fecha.Date == diaAbierto.Value).ToList();
                    var ents = alqEntregasPorFecha.TryGetValue(diaAbierto.Value, out var le2) ? le2 : new List<AlqReservaDto>();
                    var rets = alqRetirosPorFecha.TryGetValue(diaAbierto.Value, out var lr2) ? lr2 : new List<AlqReservaDto>();
                }
                @if (ents.Count > 0 || rets.Count > 0)
                {
                    <div class="day-section">
                        <div class="day-section-title">📦 Alquileres</div>
                        @foreach (var r in ents)
                        {
                            <div class="day-item" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo($"/alquileres/reservas?openId={r.Id}")'>
                                <div class="day-item-info">
                                    <div class="day-item-title">📦 Entrega · @r.ClienteNombre</div>
                                    <div class="day-item-desc">@r.Numero · retiro @r.FechaRetiro.ToString("dd/MM")</div>
                                </div>
                                <div class="day-item-importe">$@r.MontoTotal.ToString("N0")</div>
                            </div>
                        }
                        @foreach (var r in rets)
                        {
                            <div class="day-item" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo($"/alquileres/reservas?openId={r.Id}")'>
                                <div class="day-item-info">
                                    <div class="day-item-title">🔙 Retiro · @r.ClienteNombre</div>
                                    <div class="day-item-desc">@r.Numero</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                @if (chs.Count > 0)
                {
                    <div class="day-section">
                        <div class="day-section-title">🔴 Cheques a pagar</div>
                        @foreach (var ch in chs)
                        {
                            <div class="day-item cheque">
                                <div class="day-item-info">
                                    <div class="day-item-title">@(ch.ContraparteNombre ?? "(sin beneficiario)")</div>
                                    <div class="day-item-desc">Cheque @ch.Numero · @(ch.Motivo ?? "")</div>
                                </div>
                                <div class="day-item-importe">$@ch.Importe.ToString("N2")</div>
                            </div>
                        }
                    </div>
                }
                @if (ns.Count > 0)
                {
                    <div class="day-section">
                        <div class="day-section-title">📝 Mis notas</div>
                        @foreach (var n in ns)
                        {
                            <div class="day-item nota">
                                <div class="day-item-info">
                                    <div class="day-item-title">@n.Titulo</div>
                                    @if (!string.IsNullOrEmpty(n.Descripcion))
                                    {
                                        <div class="day-item-desc">@n.Descripcion</div>
                                    }
                                </div>
                                @if (n.Importe.HasValue)
                                {
                                    <div class="day-item-importe">$@n.Importe.Value.ToString("N2")</div>
                                }
                                <button class="day-item-borrar" @onclick="() => BorrarNota(n.Id)" title="Borrar">🗑</button>
                            </div>
                        }
                    </div>
                }

                <div class="day-form">
                    <div class="day-section-title">➕ Agregar nota</div>
                    <input @bind="formTitulo" placeholder="Título (ej: Pagar sueldo a Maxi)" />
                    <input @bind="formDescripcion" placeholder="Descripción (opcional)" />
                    <input type="number" step="0.01" @bind="formImporte" placeholder="Importe (opcional)" />
                    <button class="cal-btn activo" style="width: 100%; padding: 0.5rem;" disabled="@string.IsNullOrWhiteSpace(formTitulo)" @onclick="GuardarNota">✓ Guardar nota</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool expandido = false;
    private List<ChequeBancoDto> cheques = new();
    private Dictionary<DateTime, List<ChequeBancoDto>> chequesPorFecha = new();
    private decimal chequesPorPagarTotal;

    private List<CalendarioNotaDto> notas = new();
    // 2026-06-26: entregas/retiros de alquiler por fecha
    private Dictionary<DateTime, List<AlqReservaDto>> alqEntregasPorFecha = new();
    private Dictionary<DateTime, List<AlqReservaDto>> alqRetirosPorFecha = new();
    private DateTime? diaAbierto;
    private string formTitulo = "";
    private string? formDescripcion;
    private decimal? formImporte;

    protected override async Task OnInitializedAsync()
    {
        await Recargar();
    }

    private async Task Recargar()
    {
        loading = true;
        try
        {
            // Cheques: traemos los pendientes + los que ya estan en historico del mes pasado
            // para que se vean los puntos en el mes anterior tambien (mas contexto visual).
            var hoy = DateTime.Today;
            var desde = new DateTime(hoy.Year, hoy.Month, 1).AddMonths(-1);
            var hasta = hoy.AddDays(180);
            var pendientes = await Api.GetChequesBancoAsync(tipo: "EMITIDO", estado: "Aceptado") ?? new();
            var pagados = await Api.GetChequesBancoAsync(tipo: "EMITIDO", estado: "Pagado") ?? new();
            var todos = pendientes.Concat(pagados);
            cheques = todos.Where(c => c.FechaPago.HasValue && c.FechaPago.Value.Date >= desde && c.FechaPago.Value.Date <= hasta).OrderBy(c => c.FechaPago).ToList();
            chequesPorFecha = cheques.GroupBy(c => c.FechaPago!.Value.Date).ToDictionary(g => g.Key, g => g.ToList());
            // El total "por pagar" solo cuenta los Aceptados a futuro
            chequesPorPagarTotal = pendientes.Where(c => c.FechaPago.HasValue && c.FechaPago.Value.Date >= hoy).Sum(c => c.Importe);

            notas = await Api.GetCalendarioNotasAsync(desde, hasta) ?? new();

            // 2026-06-26: entregas/retiros de alquiler (las no canceladas) en el rango.
            var reservasAlq = await Api.GetAlqReservasAsync() ?? new();
            var vigentes = reservasAlq.Where(r => r.Estado != "cancelado").ToList();
            alqEntregasPorFecha = vigentes
                .Where(r => r.FechaEntrega.Date >= desde && r.FechaEntrega.Date <= hasta)
                .GroupBy(r => r.FechaEntrega.Date).ToDictionary(g => g.Key, g => g.ToList());
            alqRetirosPorFecha = vigentes
                .Where(r => r.FechaRetiro.Date >= desde && r.FechaRetiro.Date <= hasta)
                .GroupBy(r => r.FechaRetiro.Date).ToDictionary(g => g.Key, g => g.ToList());
        }
        catch { }
        finally { loading = false; }
    }

    private void AbrirDia(DateTime fecha)
    {
        diaAbierto = fecha;
        formTitulo = "";
        formDescripcion = null;
        formImporte = null;
    }

    private async Task GuardarNota()
    {
        if (string.IsNullOrWhiteSpace(formTitulo) || diaAbierto is null) return;
        try
        {
            var nueva = await Api.CrearCalendarioNotaAsync(new CrearCalendarioNotaRequest
            {
                Fecha = diaAbierto.Value,
                Titulo = formTitulo.Trim(),
                Descripcion = string.IsNullOrWhiteSpace(formDescripcion) ? null : formDescripcion!.Trim(),
                Importe = formImporte,
                CreadoPor = Operator.Current
            });
            if (nueva is not null)
            {
                notas.Add(nueva);
                ToastService.Success("✓ Nota guardada");
                formTitulo = "";
                formDescripcion = null;
                formImporte = null;
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private async Task BorrarNota(int id)
    {
        try
        {
            var ok = await Api.BorrarCalendarioNotaAsync(id);
            if (ok)
            {
                notas.RemoveAll(n => n.Id == id);
                ToastService.Info("Nota borrada");
            }
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); }
    }

    private static string NombreMes(DateTime d) => d.Month switch
    {
        1 => "Enero", 2 => "Febrero", 3 => "Marzo", 4 => "Abril",
        5 => "Mayo", 6 => "Junio", 7 => "Julio", 8 => "Agosto",
        9 => "Septiembre", 10 => "Octubre", 11 => "Noviembre", 12 => "Diciembre",
        _ => ""
    };
}
