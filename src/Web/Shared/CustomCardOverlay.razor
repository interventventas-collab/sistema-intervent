@inject ApiClient Api
@inject ToastService Toast
@inject IJSRuntime JS

@* 2026-07-03 v3: overlay compacto. Un solo boton "⋯" siempre visible arriba a la
   derecha; al tocarlo se despliega un menu con Subir foto / Agregar nota /
   Quitar foto + hint de formato. La card queda limpia. *@

<div class="cco-root">
    @if (!hideImage)
    {
        <div class="cco-bg-wrap">
            <img src="@ImgUrl" class="cco-bg-img"
                 onload="this.closest('.cco-root').classList.add('cco-image-loaded');"
                 onerror="this.style.display='none'; this.closest('.cco-root').classList.remove('cco-image-loaded');"
                 alt="" />
            <div class="cco-bg-tint"></div>
        </div>
    }

    @* InputFile aparte, oculto pero clickeable via label. onclick nativo para frenar bubble a la card. *@
    <InputFile id="@FileInputId" class="cco-hidden-file" OnChange="OnBgPicked"
               accept=".png,.jpg,.jpeg,.webp"
               onclick="event.stopPropagation();" />

    <button type="button" class="cco-toggle" id="@ToggleId" @onclick="ToggleMenu" @onclick:stopPropagation="true"
            title="Personalizar tarjeta" aria-label="Personalizar tarjeta">
        <span>⋯</span>
    </button>

    @if (menuOpen)
    {
        <div class="cco-menu" @onclick="NoOp" @onclick:stopPropagation="true">
            <div class="cco-menu-title">Personalizar tarjeta</div>
            <button type="button" class="cco-menu-item" @onclick="OpenFilePicker" @onclick:stopPropagation="true">
                <span class="cco-menu-icon">📷</span>
                <span>@(hasImage ? "Cambiar foto de fondo" : "Subir foto de fondo")</span>
            </button>
            <button type="button" class="cco-menu-item" @onclick="StartEdit" @onclick:stopPropagation="true">
                <span class="cco-menu-icon">📝</span>
                <span>@(string.IsNullOrWhiteSpace(comment) ? "Agregar nota" : "Editar nota")</span>
            </button>
            <button type="button" class="cco-menu-item cco-menu-item-danger cco-menu-item-only-if-image"
                    @onclick="OnDeleteBg" @onclick:stopPropagation="true">
                <span class="cco-menu-icon">🗑</span>
                <span>Quitar foto</span>
            </button>
            @if (!string.IsNullOrWhiteSpace(comment))
            {
                <button type="button" class="cco-menu-item cco-menu-item-danger"
                        @onclick="ClearComment" @onclick:stopPropagation="true">
                    <span class="cco-menu-icon">🗑</span>
                    <span>Quitar nota</span>
                </button>
            }
            <div class="cco-menu-hint">
                Foto: PNG · JPG · WEBP<br />
                Máx 10 MB · ideal ~600×300 px
            </div>
        </div>
    }

    @if (editing || !string.IsNullOrWhiteSpace(comment))
    {
        <div class="cco-comment @(editing ? "cco-comment-editing" : "")" @onclick="NoOp" @onclick:stopPropagation="true">
            @if (editing)
            {
                <input type="text" class="cco-input"
                       placeholder="Escribí tu nota y apretá Enter…"
                       @bind="commentEdit" @bind:event="oninput"
                       @onblur="SaveComment"
                       @onkeydown="OnKeyComment"
                       @onclick:stopPropagation="true"
                       @ref="inputRef" />
            }
            else
            {
                <span class="cco-text" @onclick="StartEdit" @onclick:stopPropagation="true" title="Click para editar">@comment</span>
            }
        </div>
    }
</div>

<style>
    /* Root SIN overflow:hidden asi el menu desplegable puede escapar. La foto
       (que si necesita clip) va en un wrapper propio con overflow:hidden. */
    .cco-root {
        position: absolute;
        inset: 0;
        pointer-events: none;
        border-radius: inherit;
    }
    .cco-bg-wrap {
        position: absolute;
        inset: 0;
        overflow: hidden;
        border-radius: inherit;
    }
    .cco-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 1;
    }
    .cco-bg-tint {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.35);
    }
    .cco-hidden-file {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        opacity: 0;
        pointer-events: none;
    }
    .cco-toggle {
        position: absolute;
        top: 10px;
        right: 10px;
        width: 28px;
        height: 28px;
        padding: 0;
        border-radius: 8px;
        border: 0.5px solid rgba(0,0,0,0.10);
        background: rgba(255,255,255,0.85);
        color: #6b7280;
        font-size: 18px;
        font-weight: 700;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        pointer-events: auto;
        z-index: 3;
        transition: background 0.12s ease, color 0.12s ease;
    }
    .cco-toggle:hover {
        background: white;
        color: #1f2937;
        box-shadow: 0 2px 8px rgba(0,0,0,0.10);
    }
    .cco-menu {
        position: absolute;
        top: 46px;
        right: 10px;
        min-width: 220px;
        background: white;
        border: 0.5px solid rgba(0,0,0,0.10);
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.16), 0 2px 6px rgba(0,0,0,0.10);
        overflow: hidden;
        pointer-events: auto;
        z-index: 9999;
    }
    .cco-menu-title {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
        font-weight: 600;
        padding: 12px 14px 8px;
        border-bottom: 0.5px solid #e5e7eb;
    }
    .cco-menu-item {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 10px 14px;
        border: none;
        border-top: 0.5px solid #f3f4f6;
        background: transparent;
        color: #1f2937;
        font-size: 13px;
        text-align: left;
        cursor: pointer;
    }
    .cco-menu-item:first-of-type { border-top: none; }
    .cco-menu-item:hover { background: #f9fafb; }
    .cco-menu-icon { font-size: 15px; width: 18px; text-align: center; }
    .cco-menu-item-danger { color: #b91c1c; }
    .cco-menu-item-danger:hover { background: #fef2f2; }
    /* "Quitar foto" solo aparece cuando el <img> cargo bien (clase agregada por onload). */
    .cco-menu-item-only-if-image { display: none; }
    .cco-image-loaded .cco-menu-item-only-if-image { display: flex; }
    .cco-menu-hint {
        font-size: 10px;
        color: #6b7280;
        padding: 8px 14px 12px;
        border-top: 0.5px solid #e5e7eb;
        background: #f9fafb;
        line-height: 1.5;
    }
    .cco-comment {
        position: absolute;
        left: 0; right: 0; bottom: 0;
        min-height: 24px;
        background: rgba(17, 24, 39, 0.72);
        color: white;
        font-size: 12px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 6px;
        pointer-events: auto;
        z-index: 2;
    }
    .cco-comment-editing { background: rgba(17, 24, 39, 0.95); }
    .cco-text {
        flex: 1;
        cursor: text;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .cco-input {
        flex: 1;
        background: transparent;
        border: none;
        color: white;
        font-size: 12px;
        outline: none;
        padding: 0;
    }
    /* Hijos de las cards que NO son este overlay: por encima del bg del overlay. */
    .dashboard-detail-card > *:not(.cco-root),
    .mac-card > *:not(.cco-root) {
        position: relative;
        z-index: 1;
    }
</style>

@code {
    [Parameter, EditorRequired] public string CardKey { get; set; } = "";
    [Parameter] public Dictionary<string, string>? Settings { get; set; }

    private string comment = "";
    private string commentEdit = "";
    private bool editing;
    private bool menuOpen;
    private ElementReference inputRef;
    private long imgVersion;
    private bool hideImage;

    private string BgKey => $"dashcard-bg-{CardKey}";
    private string CommentKey => $"dashcard-cmt-{CardKey}";
    private string ImgUrl => $"/api/branding/{BgKey}?v={imgVersion}";
    private string FileInputId => $"cco-file-{CardKey}";
    private string ToggleId => $"cco-toggle-{CardKey}";
    private bool hasImage => !hideImage;

    protected override void OnParametersSet()
    {
        try
        {
            if (Settings is not null && Settings.TryGetValue(CommentKey, out var v))
                comment = v ?? "";
            if (imgVersion == 0) imgVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        }
        catch { }
    }

    /// <summary>2026-07-04: en vez de depender de <label for=...> (que no siempre
    /// activa el InputFile hidden dentro de un componente Blazor), disparamos el
    /// picker programaticamente con JS. Es la forma mas confiable.</summary>
    private async Task OpenFilePicker()
    {
        await CloseMenu();
        try
        {
            var js = "var el=document.getElementById('" + FileInputId + "'); if(el){el.click();}";
            await JS.InvokeVoidAsync("eval", js);
        }
        catch (Exception ex) { Toast.Error("No se pudo abrir el selector: " + ex.Message); }
    }

    private async Task ToggleMenu()
    {
        menuOpen = !menuOpen;
        await ApplyCardZIndex();
    }

    /// <summary>Eleva la card por encima de las hermanas mientras el menu esta abierto
    /// (asi el desplegable no queda tapado por la card de abajo). Al cerrarse resetea.</summary>
    private async Task ApplyCardZIndex()
    {
        try
        {
            var zVal = menuOpen ? "50" : "auto";
            var js = "(function(){var btn=document.getElementById('" + ToggleId + "');if(!btn)return;var card=btn.closest('.dashboard-detail-card');if(!card)return;card.style.zIndex='" + zVal + "';card.style.position='relative';})()";
            await JS.InvokeVoidAsync("eval", js);
        }
        catch { }
    }

    private async Task CloseMenu()
    {
        if (!menuOpen) return;
        await CloseMenu();
        await ApplyCardZIndex();
    }

    private async Task OnBgPicked(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        await CloseMenu();
        if (e.File is null) return;
        const long maxBytes = 10L * 1024 * 1024;
        var permitidos = new[] { ".png", ".jpg", ".jpeg", ".webp" };
        var ext = System.IO.Path.GetExtension(e.File.Name)?.ToLowerInvariant() ?? "";
        if (!permitidos.Contains(ext))
        {
            Toast.Error($"Formato no permitido ({ext}). Usá PNG, JPG o WEBP.");
            return;
        }
        if (e.File.Size > maxBytes)
        {
            var mb = e.File.Size / (1024d * 1024d);
            Toast.Error($"El archivo pesa {mb:F1} MB. El máximo es 10 MB.");
            return;
        }
        Toast.Info($"Subiendo imagen ({e.File.Size / 1024} KB)…");
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: maxBytes);
            await Api.UploadBrandingImageAsync(BgKey, stream, e.File.Name, e.File.ContentType);
            imgVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
            hideImage = false;
            Toast.Success("Fondo actualizado ✓");
            StateHasChanged();
        }
        catch (Exception ex) { Toast.Error("No se pudo subir la imagen: " + ex.Message); }
    }

    private async Task OnDeleteBg()
    {
        await CloseMenu();
        try
        {
            await Api.DeleteBrandingImageAsync(BgKey);
            hideImage = true;
            Toast.Success("Fondo quitado");
            StateHasChanged();
        }
        catch (Exception ex) { Toast.Error("No se pudo borrar: " + ex.Message); }
    }

    private async Task StartEdit()
    {
        await CloseMenu();
        editing = true;
        commentEdit = comment;
        StateHasChanged();
        await Task.Delay(30);
        try { await inputRef.FocusAsync(); } catch { }
    }

    private async Task SaveComment()
    {
        if (!editing) return;
        var newVal = (commentEdit ?? "").Trim();
        if (newVal == comment) { editing = false; StateHasChanged(); return; }
        try
        {
            await Api.UpdateSettingAsync(CommentKey, newVal);
            comment = newVal;
            if (Settings is not null) Settings[CommentKey] = newVal;
        }
        catch (Exception ex) { Toast.Error("No se pudo guardar el comentario: " + ex.Message); }
        editing = false;
        StateHasChanged();
    }

    private async Task ClearComment()
    {
        await CloseMenu();
        try
        {
            await Api.UpdateSettingAsync(CommentKey, "");
            comment = "";
            if (Settings is not null) Settings[CommentKey] = "";
            StateHasChanged();
        }
        catch (Exception ex) { Toast.Error("No se pudo quitar: " + ex.Message); }
    }

    private async Task OnKeyComment(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await SaveComment(); }
        else if (e.Key == "Escape") { editing = false; StateHasChanged(); }
    }

    private void NoOp() { }
}
