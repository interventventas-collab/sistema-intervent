@inject ApiClient Api
@inject ToastService ToastService

<div class="card">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <div>
            <h3 style="margin:0;">🔄 Sincronización con MercadoLibre</h3>
            <p style="font-size:0.78rem; color:#6b7280; margin:0.25rem 0 0;">
                Control de precio + stock por publicación. Te muestra costo, margen y comisión real de MeLi.
            </p>
        </div>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
            <input class="form-input" style="font-size:0.8rem; max-width:240px;" placeholder="Buscar SKU, título o MLA..."
                   @bind="busqueda" @bind:event="oninput" @bind:after="Buscar" />
            <select class="form-input" style="font-size:0.8rem;" @bind="ordenar" @bind:after="Recargar">
                <option value="diferencia">Mayor diferencia ↓</option>
                <option value="margen">Mejor margen real ↓</option>
                <option value="neto">Mayor neto en bolsillo ↓</option>
                <option value="precio">Mayor precio MeLi ↓</option>
            </select>
            <label style="font-size:0.78rem; color:#6b7280; display:flex; align-items:center; gap:0.3rem; cursor:pointer;">
                <input type="checkbox" @bind="soloConPrecio" @bind:after="Recargar" />
                Solo con precio cargado
            </label>
        </div>
    </div>
    <div class="card-body" style="padding:0;">
        @if (loading)
        {
            <p class="text-muted" style="padding:1rem;">Cargando...</p>
        }
        else if (publicaciones is null || publicaciones.Count == 0)
        {
            <p class="text-muted" style="padding:1rem;">Sin publicaciones linkeadas. (Solo se muestran las que tienen un producto del sistema vinculado.)</p>
        }
        else
        {
            var grupos = GetGrupos();
            <div style="padding:0.5rem 1rem; font-size:0.78rem; color:#6b7280; background:#f9fafb; border-bottom:1px solid #e5e7eb;">
                @grupos.Count publicaciones (@publicaciones.Count filas con variantes) · Total margen real en MeLi: $@FormatMoney(publicaciones.Sum(x => x.MargenRealConMeli)) (sumando 1 venta de c/u)
            </div>

            @foreach (var grupo in grupos)
            {
                var p = grupo.Representative;
                var isExpanded = expandedSyncGroups.Contains(p.MeliItemId);
                var diffMuyDistinto = Math.Abs(p.DiferenciaPrecioPct) > 5;
                var stockDistinto = p.StockSistema != p.StockMeli;
                var margenBueno = p.MargenRealConMeliPct > 50;
                <div style="border-bottom:1px solid #e5e7eb; padding:0.7rem 1rem;">
                    <div style="display:flex; gap:1rem; align-items:flex-start;">
                        @if (!string.IsNullOrEmpty(p.Thumbnail))
                        {
                            <img src="@p.Thumbnail" style="width:56px; height:56px; border-radius:4px; object-fit:contain; background:#f3f4f6;" />
                        }
                        else
                        {
                            <div style="width:56px; height:56px; border-radius:4px; background:#f3f4f6;"></div>
                        }
                        <div style="flex:1;">
                            <div style="display:flex; gap:0.5rem; align-items:baseline; flex-wrap:wrap;">
                                <strong style="font-size:0.95rem;">@p.CafeProductoNombre</strong>
                                <span style="font-family:monospace; background:#dbeafe; color:#1e40af; padding:0.1rem 0.4rem; border-radius:3px; font-size:0.78rem; font-weight:700;">@p.Sku</span>
                                @if (!string.IsNullOrEmpty(p.CafeProductoMarca))
                                {
                                    <span style="font-size:0.74rem; color:#6b7280;">@p.CafeProductoMarca</span>
                                }
                                <a href="https://www.mercadolibre.com.ar/p/@p.MeliItemId" target="_blank" style="font-size:0.74rem; color:#2563eb; text-decoration:none;">@p.MeliItemId ↗</a>
                                @if (grupo.HasVariants)
                                {
                                    <button @onclick="() => ToggleSyncGroupExpand(p.MeliItemId)"
                                            style="padding:0.1rem 0.4rem; background:#dbeafe; color:#1e40af; border:1px solid #3b82f6; border-radius:8px; font-size:0.72rem; font-weight:600; cursor:pointer;">
                                        @(isExpanded ? "▲" : "▼") @grupo.Variants.Count variantes
                                    </button>
                                }
                            </div>
                            <div style="color:#6b7280; font-size:0.78rem; margin-top:0.1rem;">@p.Title</div>

                            @{
                                var tienePrecioSist = p.PrecioOtroConIva.HasValue && p.PrecioOtroConIva.Value > 0;
                            }
                            @* ─── Grid de números clave ─── *@
                            <div style="display:grid; grid-template-columns:repeat(4, 1fr); gap:0.5rem; margin-top:0.6rem; font-size:0.82rem;">
                                @* Columna 1: Costo + Precio sistema *@
                                <div style="background:#f9fafb; padding:0.4rem 0.6rem; border-radius:4px;">
                                    <div style="color:#6b7280; font-size:0.7rem; text-transform:uppercase;">Costo (s/IVA)</div>
                                    <div style="font-weight:700;">$@FormatMoney(p.Costo)</div>
                                    <div style="color:#6b7280; font-size:0.7rem; margin-top:0.2rem;">Sistema OTRO c/IVA</div>
                                    @if (tienePrecioSist)
                                    {
                                        <div style="font-weight:600;">$@FormatMoney(p.PrecioOtroConIva!.Value)</div>
                                    }
                                    else
                                    {
                                        <div style="font-weight:600; color:#9ca3af; font-style:italic;">sin cargar</div>
                                    }
                                </div>
                                @* Columna 2: Precio MeLi + diferencia (solo si hay precio sistema) *@
                                <div style="background:@(tienePrecioSist && diffMuyDistinto ? "#fef2f2" : "#f0fdf4"); padding:0.4rem 0.6rem; border-radius:4px;">
                                    <div style="color:#6b7280; font-size:0.7rem; text-transform:uppercase;">Precio MeLi</div>
                                    <div style="font-weight:700;">$@FormatMoney(p.PrecioMeli)</div>
                                    @if (tienePrecioSist)
                                    {
                                        <div style="color:@(diffMuyDistinto ? "#991b1b" : "#15803d"); font-size:0.7rem; margin-top:0.2rem;">
                                            Dif: @(p.DiferenciaPrecio >= 0 ? "+" : "")$@FormatMoney(p.DiferenciaPrecio) (@(p.DiferenciaPrecioPct >= 0 ? "+" : "")@p.DiferenciaPrecioPct.ToString("0.#")%)
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="color:#9ca3af; font-size:0.7rem; margin-top:0.2rem; font-style:italic;">sin comparar (cargá PrecioOtro)</div>
                                    }
                                </div>
                                @* Columna 3: Margen sin comisiones (solo si hay precio sistema) *@
                                <div style="background:@(tienePrecioSist ? "#ecfdf5" : "#f9fafb"); padding:0.4rem 0.6rem; border-radius:4px;">
                                    <div style="color:#6b7280; font-size:0.7rem; text-transform:uppercase;">Margen sin comisión MeLi</div>
                                    @if (tienePrecioSist)
                                    {
                                        <div style="font-weight:700; color:@(p.MargenSinComisDollar > 0 ? "#065f46" : "#991b1b");">$@FormatMoney(p.MargenSinComisDollar)</div>
                                        <div style="color:#065f46; font-size:0.7rem; margin-top:0.2rem;">@p.MargenSinComisPct.ToString("0")% sobre costo</div>
                                    }
                                    else
                                    {
                                        <div style="color:#9ca3af; font-style:italic;">—</div>
                                        <div style="color:#9ca3af; font-size:0.7rem; margin-top:0.2rem;">cargá precio en el producto</div>
                                    }
                                </div>
                                @* Columna 4: Comisión MeLi + margen real (siempre se puede calcular) *@
                                <div style="background:@(margenBueno ? "#fef3c7" : "#fee2e2"); padding:0.4rem 0.6rem; border-radius:4px;">
                                    <div style="color:@(margenBueno ? "#92400e" : "#991b1b"); font-size:0.7rem; text-transform:uppercase;">Comisión MeLi</div>
                                    <div style="font-weight:700;">−$@FormatMoney(p.ComisionTotal)</div>
                                    <div style="color:@(margenBueno ? "#92400e" : "#991b1b"); font-size:0.7rem; margin-top:0.2rem;">
                                        Margen real: $@FormatMoney(p.MargenRealConMeli) (@p.MargenRealConMeliPct.ToString("0")%)
                                    </div>
                                </div>
                            </div>

                            @* ─── Stock + Última sync ─── *@
                            <div style="display:flex; gap:1rem; margin-top:0.4rem; font-size:0.76rem; color:#6b7280; align-items:center; flex-wrap:wrap;">
                                <span>📦 Stock sistema: <strong style="color:#111;">@p.StockSistema</strong></span>
                                <span style="@(stockDistinto ? "color:#dc2626; font-weight:600;" : "")">MeLi: <strong>@p.StockMeli</strong></span>
                                @if (p.Config.LastSyncAt.HasValue)
                                {
                                    <span>Última sync: @p.Config.LastSyncAt.Value.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                }
                                <span style="margin-left:auto; display:flex; gap:0.3rem; align-items:center;">
                                    <label style="display:flex; gap:0.2rem; align-items:center; cursor:pointer;">
                                        <input type="checkbox" checked="@p.Config.SyncStock" @onchange="@(e => OnToggleSyncStock(p, (bool)e.Value!))" />
                                        <span>Sync stock</span>
                                    </label>
                                    <label style="display:flex; gap:0.2rem; align-items:center; cursor:pointer;">
                                        <input type="checkbox" checked="@p.Config.SyncPrecio" @onchange="@(e => OnToggleSyncPrecio(p, (bool)e.Value!))" />
                                        <span>Sync precio</span>
                                    </label>
                                </span>
                            </div>

                            @* ─── Acciones ─── *@
                            <div style="display:flex; gap:0.4rem; margin-top:0.5rem;">
                                <button class="btn btn-sm btn-primary" style="font-size:0.78rem;" @onclick="() => AbrirEditarPrecio(p)">✏ Editar precio</button>
                                <button class="btn btn-sm btn-secondary" style="font-size:0.78rem;" @onclick="() => AbrirConfigurarAjuste(p)">⚙ Ajuste %/$</button>
                            </div>

                            @* ─── Variantes expandibles ─── *@
                            @if (grupo.HasVariants && isExpanded)
                            {
                                <div style="margin-top:0.7rem; padding-top:0.6rem; border-top:1px dashed #d1d5db;">
                                    <div style="font-size:0.78rem; color:#6b7280; margin-bottom:0.3rem;">Variantes individuales:</div>
                                    @foreach (var v in grupo.Variants)
                                    {
                                        <div style="display:flex; gap:0.7rem; align-items:center; padding:0.3rem 0.5rem; background:#f9fafb; border-radius:4px; margin-bottom:0.2rem; font-size:0.82rem;">
                                            <span style="color:#6b7280; min-width:14px;">↳</span>
                                            <strong style="flex:1;">@(v.VariationAttributes ?? "(variante)")</strong>
                                            <span style="font-family:monospace; background:#dbeafe; color:#1e40af; padding:0.05rem 0.3rem; border-radius:3px; font-size:0.74rem;">@v.Sku</span>
                                            <span>Stock MeLi: <strong>@v.StockMeli</strong></span>
                                            <span style="color:#6b7280;">var. @v.VariationId</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* ════════════ Modal Editar precio ════════════ *@
@if (editPrecioOpen && editItem is not null)
{
    <div class="modal-overlay">
        <div class="modal-card" style="max-width:560px;">
            <div class="modal-header">
                <h3 style="margin:0;">✏ Editar precio MeLi</h3>
                <button class="btn-close" @onclick="CerrarEditarPrecio">✕</button>
            </div>
            <div class="modal-body">
                <div style="background:#dbeafe; padding:0.5rem 0.7rem; border-radius:4px; margin-bottom:0.7rem; font-size:0.82rem;">
                    <strong>@editItem.CafeProductoNombre</strong> · SKU @editItem.Sku<br/>
                    Costo: $@FormatMoney(editItem.Costo) · PrecioOtro c/IVA: $@FormatMoney(editItem.PrecioOtroConIva ?? 0)
                </div>
                <div class="form-group">
                    <label class="form-label">Precio nuevo en MeLi *</label>
                    <input class="form-input" type="number" step="1" min="0" @bind="precioNuevo" @bind:event="oninput" />
                </div>

                @* Desglose en vivo *@
                @{
                    var comisCalc = Math.Round(precioNuevo * editItem.ComisionPct / 100m + editItem.ComisionFija, 2);
                    var netoConIvaCalc = precioNuevo - comisCalc;
                    var netoSinIvaCalc = editItem.IvaPct > 0 ? Math.Round(netoConIvaCalc / (1 + editItem.IvaPct/100m), 2) : netoConIvaCalc;
                    var margenCalc = netoSinIvaCalc - editItem.Costo;
                    var margenPctCalc = editItem.Costo > 0 ? Math.Round(margenCalc / editItem.Costo * 100m, 0) : 0m;
                }
                <div style="background:#ecfdf5; border:1px solid #059669; border-radius:6px; padding:0.7rem; font-size:0.85rem;">
                    <div style="font-weight:700; color:#065f46; margin-bottom:0.3rem;">💰 Desglose en vivo</div>
                    <table style="width:100%;">
                        <tr><td>Precio venta MeLi:</td><td style="text-align:right; font-weight:700;">$@FormatMoney(precioNuevo)</td></tr>
                        <tr><td>Comisión MeLi (@editItem.ComisionPct.ToString("0.#")% + $@FormatMoney(editItem.ComisionFija)):</td><td style="text-align:right; color:#dc2626;">−$@FormatMoney(comisCalc)</td></tr>
                        <tr style="border-top:1px solid #a7f3d0;"><td><strong>MeLi te deposita:</strong></td><td style="text-align:right; font-weight:700;">$@FormatMoney(netoConIvaCalc)</td></tr>
                        <tr><td style="color:#6b7280; font-size:0.78rem;">↳ IVA contenido:</td><td style="text-align:right; color:#6b7280; font-size:0.78rem;">$@FormatMoney(netoConIvaCalc - netoSinIvaCalc)</td></tr>
                        <tr><td style="color:#6b7280; font-size:0.78rem;">↳ Neto sin IVA:</td><td style="text-align:right; color:#6b7280; font-size:0.78rem;">$@FormatMoney(netoSinIvaCalc)</td></tr>
                        <tr style="border-top:1px solid #a7f3d0;"><td>Costo:</td><td style="text-align:right; color:#dc2626;">−$@FormatMoney(editItem.Costo)</td></tr>
                        <tr style="background:#fef3c7;"><td><strong>🏆 Ganancia real:</strong></td><td style="text-align:right; font-weight:700; color:@(margenCalc > 0 ? "#065f46" : "#991b1b");">$@FormatMoney(margenCalc) (@margenPctCalc.ToString("0")%)</td></tr>
                    </table>
                </div>

                @if (!string.IsNullOrEmpty(editError))
                {
                    <div style="background:#fee2e2; color:#991b1b; padding:0.5rem 0.7rem; border-radius:4px; font-size:0.82rem; margin-top:0.5rem;">@editError</div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarEditarPrecio" disabled="@editPushing">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmarEditarPrecio" disabled="@(editPushing || precioNuevo <= 0)">@(editPushing ? "Pusheando..." : "Pushear a MeLi")</button>
            </div>
        </div>
    </div>
}

@* ════════════ Modal Configurar ajuste %/$ ════════════ *@
@if (ajusteOpen && editItem is not null)
{
    <div class="modal-overlay">
        <div class="modal-card" style="max-width:520px;">
            <div class="modal-header">
                <h3 style="margin:0;">⚙ Configurar ajuste de precio MeLi</h3>
                <button class="btn-close" @onclick="CerrarConfigurarAjuste">✕</button>
            </div>
            <div class="modal-body">
                <p style="font-size:0.82rem; color:#6b7280; margin:0 0 0.7rem;">
                    Cuando "Sync precio" esté activo, el sistema pushea automáticamente a MeLi este precio cada vez que cambies el PrecioOtro del producto:
                </p>
                <div style="background:#f3f4f6; padding:0.6rem; border-radius:4px; font-family:monospace; font-size:0.85rem; margin-bottom:0.7rem;">
                    Precio MeLi = PrecioOtro_cIVA × (1 + <strong>Ajuste%</strong>/100) + <strong>$Fijo</strong>
                </div>
                <div class="form-row">
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Ajuste % (sobre PrecioOtro c/IVA)</label>
                        <input class="form-input" type="number" step="0.01" @bind="ajustePct" @bind:event="oninput" />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Ajuste fijo $</label>
                        <input class="form-input" type="number" step="1" @bind="ajusteFijo" @bind:event="oninput" />
                    </div>
                </div>
                @{
                    var baseAj = editItem.PrecioOtroConIva ?? 0m;
                    var precioCalc = Math.Round(baseAj * (1 + ajustePct/100m) + ajusteFijo, 2);
                }
                <div style="background:#dbeafe; padding:0.6rem; border-radius:4px; font-size:0.85rem;">
                    <strong>Resultado:</strong> $@FormatMoney(baseAj) × (1 + @ajustePct/100) + $@FormatMoney(ajusteFijo) = <strong>$@FormatMoney(precioCalc)</strong>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarConfigurarAjuste">Cancelar</button>
                <button class="btn btn-primary" @onclick="ConfirmarConfigurarAjuste">Guardar ajuste</button>
            </div>
        </div>
    </div>
}

@code {
    private List<PublicacionExtendidaDto>? publicaciones;
    private bool loading = true;
    private string busqueda = "";
    private string ordenar = "diferencia";
    private bool soloConPrecio = false;
    private System.Threading.CancellationTokenSource? buscarCts;

    // Modal editar precio
    private bool editPrecioOpen;
    private bool editPushing;
    private string? editError;
    private PublicacionExtendidaDto? editItem;
    private decimal precioNuevo;

    // Modal configurar ajuste
    private bool ajusteOpen;
    private decimal ajustePct;
    private decimal ajusteFijo;

    // ── Agrupacion por MeliItemId (estilo Mercado Libre) ──
    public class GrupoSync
    {
        public PublicacionExtendidaDto Representative { get; set; } = default!;
        public List<PublicacionExtendidaDto> Variants { get; set; } = new();
        public bool HasVariants => Variants.Count > 1;
    }

    private HashSet<string> expandedSyncGroups = new();

    private void ToggleSyncGroupExpand(string meliItemId)
    {
        if (!expandedSyncGroups.Remove(meliItemId)) expandedSyncGroups.Add(meliItemId);
    }

    /// <summary>Agrupa las publicaciones por MeliItemId. Si hay > 1 fila con mismo MLA, son variantes.</summary>
    private List<GrupoSync> GetGrupos()
    {
        var lista = publicaciones ?? new();
        var grupos = new List<GrupoSync>();
        var seen = new Dictionary<string, GrupoSync>();
        foreach (var p in lista)
        {
            if (!seen.TryGetValue(p.MeliItemId, out var g))
            {
                g = new GrupoSync { Representative = p };
                seen[p.MeliItemId] = g;
                grupos.Add(g);
            }
            g.Variants.Add(p);
        }
        return grupos;
    }

    protected override async Task OnInitializedAsync() => await Recargar();

    private async Task Recargar()
    {
        loading = true;
        try
        {
            var todas = await Api.GetPublicacionesSincroAsync(
                string.IsNullOrWhiteSpace(busqueda) ? null : busqueda,
                null, ordenar) ?? new();
            if (soloConPrecio)
                todas = todas.Where(p => p.PrecioOtroConIva.HasValue && p.PrecioOtroConIva.Value > 0).ToList();
            publicaciones = todas;
        }
        catch (Exception ex) { ToastService.Error("Error: " + ex.Message); publicaciones = new(); }
        loading = false;
    }

    private async Task Buscar()
    {
        // Debounce 300ms
        buscarCts?.Cancel();
        buscarCts = new();
        try
        {
            await Task.Delay(300, buscarCts.Token);
            await Recargar();
        }
        catch (TaskCanceledException) { }
    }

    // ===== Editar precio =====
    private void AbrirEditarPrecio(PublicacionExtendidaDto p)
    {
        editItem = p;
        precioNuevo = p.PrecioMeli;
        editError = null;
        editPrecioOpen = true;
    }

    private void CerrarEditarPrecio()
    {
        if (editPushing) return;
        editPrecioOpen = false;
        editItem = null;
    }

    private async Task ConfirmarEditarPrecio()
    {
        if (editItem is null || precioNuevo <= 0) return;
        editPushing = true;
        editError = null;
        try
        {
            var (result, err) = await Api.PushPrecioAMeliAsync(editItem.MeliItemId, precioNuevo);
            if (result is null) { editError = err ?? "Error"; return; }
            ToastService.Success($"✓ Precio actualizado en MeLi a ${result.NuevoPrecio:N2}. Te queda ${result.NetoSinIva:N2} sin IVA.");
            editPrecioOpen = false;
            await Recargar();
        }
        finally { editPushing = false; }
    }

    // ===== Toggle sync stock/precio =====
    private async Task OnToggleSyncStock(PublicacionExtendidaDto p, bool valor)
    {
        var (cfg, err) = await Api.ActualizarSyncConfigAsync(p.MeliItemId, new UpdateSyncConfigRequest
        {
            SyncStock = valor, SyncPrecio = p.Config.SyncPrecio,
            AjustePct = p.Config.AjustePct, AjusteFijo = p.Config.AjusteFijo
        });
        if (cfg is not null) { p.Config = cfg; ToastService.Success($"Sync stock: {(valor ? "ON" : "OFF")}"); }
        else ToastService.Error(err ?? "Error");
    }

    private async Task OnToggleSyncPrecio(PublicacionExtendidaDto p, bool valor)
    {
        var (cfg, err) = await Api.ActualizarSyncConfigAsync(p.MeliItemId, new UpdateSyncConfigRequest
        {
            SyncStock = p.Config.SyncStock, SyncPrecio = valor,
            AjustePct = p.Config.AjustePct, AjusteFijo = p.Config.AjusteFijo
        });
        if (cfg is not null) { p.Config = cfg; ToastService.Success($"Sync precio: {(valor ? "ON" : "OFF")}"); }
        else ToastService.Error(err ?? "Error");
    }

    // ===== Configurar ajuste =====
    private void AbrirConfigurarAjuste(PublicacionExtendidaDto p)
    {
        editItem = p;
        ajustePct = p.Config.AjustePct;
        ajusteFijo = p.Config.AjusteFijo;
        ajusteOpen = true;
    }

    private void CerrarConfigurarAjuste() { ajusteOpen = false; editItem = null; }

    private async Task ConfirmarConfigurarAjuste()
    {
        if (editItem is null) return;
        var (cfg, err) = await Api.ActualizarSyncConfigAsync(editItem.MeliItemId, new UpdateSyncConfigRequest
        {
            SyncStock = editItem.Config.SyncStock, SyncPrecio = editItem.Config.SyncPrecio,
            AjustePct = ajustePct, AjusteFijo = ajusteFijo
        });
        if (cfg is not null)
        {
            editItem.Config = cfg;
            ToastService.Success("Ajuste guardado");
            ajusteOpen = false;
            await Recargar();
        }
        else ToastService.Error(err ?? "Error");
    }

    private static string FormatMoney(decimal v) => v.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
