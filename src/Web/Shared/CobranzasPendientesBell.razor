@inject ApiClient Api
@inject NavigationManager Navigation
@implements IDisposable

@* Badge en topbar: cobranzas precargadas por repartidores esperando aprobacion.
   2026-06-29: siempre visible — apagada (gris) cuando no hay pendientes, encendida
   (ambar) y titilando cuando count > 0. Click → /cafe/cobranzas-pendientes. Refresca cada 60s. *@

<div class="cpb-square @(count > 0 ? "active" : "quiet")"
     @onclick="@(() => Navigation.NavigateTo("/cafe/cobranzas-pendientes"))"
     title="@(count > 0 ? $"{count} cobranzas de repartidores esperando aprobación" : "Cobranzas de repartidores (sin pendientes)")">
    <span class="cpb-icon">💰</span>
    @if (count > 0)
    {
        <span class="cpb-num">@count</span>
    }
</div>

<style>
    .cpb-square {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.12s ease, border-color 0.12s ease, opacity 0.12s ease, transform 0.06s ease;
        position: relative;
        margin: 0 0.15rem;
        box-sizing: border-box;
    }
    .cpb-square:active { transform: scale(0.95); }
    .cpb-square.quiet {
        background: white;
        border: 1px solid #d1d5db;
        opacity: 0.55;
    }
    .cpb-square.quiet:hover { opacity: 1; background: #f9fafb; border-color: #9ca3af; }
    .cpb-square.quiet .cpb-icon { filter: grayscale(1); opacity: 0.7; }
    .cpb-square.active {
        background: linear-gradient(135deg, #fef3c7, #fde68a);
        border: 1px solid #f59e0b;
        animation: cpb-pulse 1.6s ease-in-out infinite;
    }
    .cpb-square.active:hover { transform: scale(1.05); }
    .cpb-square .cpb-icon { font-size: 22px; line-height: 1; }
    .cpb-square .cpb-num {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #b45309;
        color: white;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 999px;
        font-weight: 600;
        line-height: 1;
        border: 2px solid white;
        min-width: 18px;
        text-align: center;
        box-sizing: border-box;
    }
    @@keyframes cpb-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.5); }
        50% { box-shadow: 0 0 0 8px rgba(245, 158, 11, 0); }
    }
</style>

@code {
    private int count;
    private System.Threading.Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        timer = new System.Threading.Timer(async _ => await InvokeAsync(Refresh), null, 60000, 60000);
    }

    private async Task Refresh()
    {
        try
        {
            count = await Api.GetCountCobranzasPendientesAsync();
            StateHasChanged();
        }
        catch { /* no critico */ }
    }

    public void Dispose() => timer?.Dispose();
}
