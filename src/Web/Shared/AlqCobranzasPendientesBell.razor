@inject ApiClient Api
@inject NavigationManager Navigation
@implements IDisposable

@* Badge topbar: cobros de ALQUILER precargados por repartidores esperando aprobación.
   2026-06-29: siempre visible — apagada (gris) cuando no hay pendientes, encendida
   (violeta) y titilando cuando count > 0. Click → /alquileres/cobranzas-pendientes. *@

<div class="acpb-square @(count > 0 ? "active" : "quiet")"
     @onclick="@(() => Navigation.NavigateTo("/alquileres/cobranzas-pendientes"))"
     title="@(count > 0 ? $"{count} cobros de alquiler esperando aprobación" : "Cobros de alquiler (sin pendientes)")">
    <span class="acpb-icon">📦</span>
    @if (count > 0)
    {
        <span class="acpb-num">@count</span>
    }
</div>

<style>
    .acpb-square {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.12s ease, border-color 0.12s ease, opacity 0.12s ease, transform 0.06s ease;
        position: relative;
        margin: 0 0.15rem;
        box-sizing: border-box;
    }
    .acpb-square:active { transform: scale(0.95); }
    .acpb-square.quiet {
        background: white;
        border: 1px solid #d1d5db;
        opacity: 0.55;
    }
    .acpb-square.quiet:hover { opacity: 1; background: #f9fafb; border-color: #9ca3af; }
    .acpb-square.quiet .acpb-icon { filter: grayscale(1); opacity: 0.7; }
    .acpb-square.active {
        background: linear-gradient(135deg, #ede9fe, #ddd6fe);
        border: 1px solid #8b5cf6;
        animation: acpb-pulse 1.6s ease-in-out infinite;
    }
    .acpb-square.active:hover { transform: scale(1.05); }
    .acpb-square .acpb-icon { font-size: 22px; line-height: 1; }
    .acpb-square .acpb-num {
        position: absolute;
        top: -4px;
        right: -4px;
        background: #6d28d9;
        color: white;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 999px;
        font-weight: 600;
        line-height: 1;
        border: 2px solid white;
        min-width: 18px;
        text-align: center;
        box-sizing: border-box;
    }
    @@keyframes acpb-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.5); }
        50% { box-shadow: 0 0 0 8px rgba(139, 92, 246, 0); }
    }
</style>

@code {
    private int count;
    private System.Threading.Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        timer = new System.Threading.Timer(async _ => await InvokeAsync(Refresh), null, 60000, 60000);
    }

    private async Task Refresh()
    {
        try { count = await Api.GetCountAlqCobranzasPendientesAsync(); StateHasChanged(); }
        catch { }
    }

    public void Dispose() => timer?.Dispose();
}
