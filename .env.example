# ============================================================
# Variables de entorno del proyecto
# Copiar este archivo a .env y completar los valores.
# IMPORTANTE: .env nunca se sube al repositorio (esta en .gitignore).
# ============================================================

# --- Secretos de la aplicacion ---
# EN PRODUCCION: reemplazar TODOS estos valores por valores nuevos y seguros.
# Generar aleatorios con:
#   openssl rand -base64 32         (para JWT_SECRET)
#   openssl rand -base64 24         (para passwords)

# Password del usuario "sa" de SQL Server.
# SQL Server exige: min 8 chars + mayuscula + minuscula + numero + simbolo.
SQL_SA_PASSWORD=YourStrong@Passw0rd

# Clave de firma de los tokens JWT. Minimo 32 caracteres.
# Si cambia, todos los tokens ya emitidos dejan de ser validos.
JWT_SECRET=YourSuperSecretKeyThatIsAtLeast32CharactersLong!

# Password inicial del usuario "admin" del dashboard.
# Solo se usa la PRIMERA vez que arranca la API (cuando el hash del admin aun es
# el placeholder del init.sql). Si la clave ya se cambio desde el dashboard,
# esta variable se ignora en los arranques siguientes.
# Para forzar un reseteo (ej. olvido de clave), setear ademas FORCE_RESET_ADMIN_PASSWORD=true
# en un arranque, despues vaciarlo.
DEFAULT_ADMIN_PASSWORD=admin123
# FORCE_RESET_ADMIN_PASSWORD=true

# --- Bóveda de contraseñas (modulo Vault) ---
# Maestra inicial. Solo se usa para crear la bóveda en el primer arranque.
# Despues podés cambiarla desde la UI y/o vaciar esta variable.
VAULT_DEFAULT_PASSWORD=changeme

# --- HTTPS (opcional, usado por Caddy) ---
# Si se completa, Caddy pide certificado real a Let's Encrypt para este dominio.
# Si se deja vacio, Caddy usa certificado autofirmado (navegador mostrara advertencia).
DOMAIN=
# Email para notificaciones de Let's Encrypt (requerido si hay DOMAIN).
ACME_EMAIL=

# IP publica del servidor (opcional). Solo hace falta si vas a entrar al
# dashboard escribiendo la IP directo en el browser (ej: https://1.2.3.4/)
# en vez de usar un dominio.
# Sin esto, los browsers no pueden negociar HTTPS por IP pelada porque no
# mandan SNI al conectarse a una IP literal (RFC 6066), y Caddy aborta el
# handshake. Setear esto le dice a Caddy "si llega un cliente sin SNI,
# servile el certificado de esta IP".
# Si dejas la variable vacia, no rompe nada: simplemente el acceso por IP
# pelada no va a funcionar via HTTPS (pero si por dominio o por localhost).
# Ejemplo: PUBLIC_IP=190.210.123.45
PUBLIC_IP=

# --- CORS (opcional) ---
# Lista de origenes permitidos para llamar a la API desde otro dominio,
# separados por coma. Ej:
#   CORS_ALLOWED_ORIGINS=https://midominio.com,https://app.midominio.com
# Si se deja vacio en produccion, CORS queda cerrado (solo same-origin),
# que es lo correcto cuando el frontend se sirve detras del mismo Caddy.
# En desarrollo, si esta vacio, la API permite http://localhost:3000 por default.
CORS_ALLOWED_ORIGINS=

# --- API Keys para los agentes AI (opcional) ---

# Anthropic - Claude Code
ANTHROPIC_API_KEY=

# OpenAI - Codex CLI
OPENAI_API_KEY=

# Google - Gemini CLI
GEMINI_API_KEY=
GOOGLE_API_KEY=
